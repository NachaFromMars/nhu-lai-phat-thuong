་ན་མཚན་མ་ལ་སྤྱོད་དོ། །བདག་བྱང་ཆུབ་སེམས་དཔའོ་སྙམ་དུ་སྤྱོད་ན་མཚན་མ་ལ་སྤྱོད་དོ། །བདག་བྱང་ཆུབ་སེམས་དཔའོ་སྙམ་ན་དེ་དམིགས་པ་ཉིད་ལ་སྤྱོད་དོ། །\\nགལ་ཏེ་ཡང་དེ་འདི་སྙམ་དུ་གང་དེ་ལྟར་སྤྱོད་པ་དེ་ནི་ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ་ལ་སྤྱོད་པ་སྟེ་དེ་ནི་ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ་སྒོམ་པར་བྱེད་པ་ཡིན་ནོ་སྙམ་དུ་སེམས་ན་དེ་མཚན་མ་ཉིད་ལ་སྤྱོད་པ་སྟེ། བྱང་ཆུབ་སེམས་དཔའ་འདི་ནི་ཐབས་མི་མཁས་པར་རིག་པར་བྱའོ། །\",\"folioNumber\":6,\"volumeNumber\":33}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1707,\"uuid\":\"17c98a63-cb4c-4841-a2af-0b99ad62f315\"},\"content\":[{\"type\":\"text\",\"text\":\"“Likewise, if he or she \",\"attrs\":{\"start\":0,\"end\":24}},{\"type\":\"text\",\"text\":\"goes about life\",\"attrs\":{\"start\":24,\"end\":39},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e47cf8c1-4e22-4e6c-af2f-a5dac51c76a0\",\"uuid\":\"ef3e5681-473a-415b-ac58-dcba69d37457\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\" in feelings, conceptions, conditioning factors, and consciousness, then he or she is \",\"attrs\":{\"start\":39,\"end\":125}},{\"type\":\"text\",\"text\":\"going about life\",\"attrs\":{\"start\":125,\"end\":141},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e47cf8c1-4e22-4e6c-af2f-a5dac51c76a0\",\"uuid\":\"b3b13e6b-ff40-44bb-899a-a40e9548a435\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\" in a conventional \",\"attrs\":{\"start\":141,\"end\":160}},{\"type\":\"text\",\"text\":\"sign\",\"attrs\":{\"start\":160,\"end\":164},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5475bf32-88c2-4471-9cf6-eff28ffb3061\",\"uuid\":\"aebb5962-298e-419d-a932-4d487e16aafe\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\". If he or she \",\"attrs\":{\"start\":164,\"end\":179}},{\"type\":\"text\",\"text\":\"goes about life\",\"attrs\":{\"start\":179,\"end\":194},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e47cf8c1-4e22-4e6c-af2f-a5dac51c76a0\",\"uuid\":\"38e1ed98-14ea-4b63-b020-57e5a3