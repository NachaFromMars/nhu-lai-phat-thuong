ུ་མ་ཉིད་ཚོར་བ་\\nདང་འདུ་ཤེས་དང་འདུ་བྱེད་རྣམས་ལགས་སོ། །བཅོམ་ལྡན་འདས་སྒྱུ་མ་དེ་གཞན་ལ་རྣམ་པར་ཤེས་པ་དེ་གཞན་ཡང་མ་ལགས་ཏེ། བཅོམ་ལྡན་འདས་རྣམ་པར་ཤེས་པ་ཉིད་སྒྱུ་མ་ལགས་སོ་སྒྱུ་མ་ཉིད་རྣམ་པར་ཤེས་པ་ལགས་སོ། །\",\"folioNumber\":9,\"volumeNumber\":33}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":637,\"uuid\":\"b95de157-ec3b-4253-9c08-8d3815e83035\"},\"content\":[{\"type\":\"text\",\"text\":\"“Definitely not, \",\"attrs\":{\"start\":0,\"end\":17}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":17,\"end\":28},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7bf45dd5-3e8d-4495-bc65-ecf0a51d3597\",\"uuid\":\"5ac66e15-69af-4ccb-92f3-0adc65226d3d\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\",” replied \",\"attrs\":{\"start\":28,\"end\":39}},{\"type\":\"text\",\"text\":\"Subhūti\",\"attrs\":{\"start\":39,\"end\":46},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"22f9f523-3d5f-4683-ac40-82bee1ab5a5f\",\"uuid\":\"a0f22be9-72ac-4190-973d-e3e3e2f6c89e\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\". “For, O \",\"attrs\":{\"start\":46,\"end\":56}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":56,\"end\":67},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7bf45dd5-3e8d-4495-bc65-ecf0a51d3597\",\"uuid\":\"53830a65-f6a2-4bab-b246-758f07198278\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\", it is not that physical forms are one thing, and the \",\"attrs\":{\"start\":67,\"end\":122}},{\"type\":\"text\",\"text\":\"magical illusion\",\"attrs\":{\"start\":122,\"end\":138},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"691144a1-87c6-495c-bb6b-8ce8d204d2fc\",\"uuid\":\"6bad7bc4-f644-4fc9-af79-873241e2473d\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\" a different thing. Physical forms themselves, \",\"attrs\":{\"start\":138,\"end\":185}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":185,\"end\":196},\"marks\":[{\"