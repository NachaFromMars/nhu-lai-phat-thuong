d\",\"attrs\":{\"start\":213,\"end\":222},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d0bf98ce-1d85-4751-abd2-a3da0982fbd4\",\"uuid\":\"f44cc98b-de16-4383-af78-fa5499efee2f\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":222,\"end\":224}},{\"type\":\"text\",\"text\":\"untransformed\",\"attrs\":{\"start\":224,\"end\":237},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"774c8de1-4765-408e-8e62-1a0b0dee8cd4\",\"uuid\":\"4f6c1e69-b170-4f57-ac74-c3e8d836b003\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\", and \",\"attrs\":{\"start\":237,\"end\":243}},{\"type\":\"text\",\"text\":\"unconditioned\",\"attrs\":{\"start\":243,\"end\":256},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cd35d9e4-576e-4c60-9d07-144110b0c808\",\"uuid\":\"70a3bc6c-f893-458b-b75f-0c8e9990db77\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\". Also, those sentient beings for whose sake he or she has donned the great armor are neither created, transformed, nor conditioned.”\",\"attrs\":{\"start\":256,\"end\":389}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"c74d0f28-fd5c-402b-9795-ba8fedfa360c\",\"sort\":11974,\"type\":\"translation\",\"label\":\"1.79\",\"alignments\":{\"toh12\":{\"folioUuid\":\"f15ec1ce-b397-45a0-8c5d-151d3797fd8d\",\"toh\":\"toh12\",\"tibetan\":\"དེ་སྐད་ཅེས་བཀའ་སྩལ་བ་དང་བཅོམ་ལྡན་འདས་ལ་ཚེ་དང་ལྡན་པ་རབ་འབྱོར་གྱིས་འདི་སྐད་ཅེས་གསོལ་ཏོ། །བཅོམ་ལྡན་འདས་དེ་དེ་བཞིན་ནོ་བདེ་བར་གཤེགས་པ་དེ་དེ་བཞིན་ནོ། །དེ་ཅིའི་སླད་དུ་ཞེ་ན།[F.12.b]བཅོམ་ལྡན་འདས་འདི་ལྟར་གཟུགས་ནི་མ་བཅིངས་མ་གྲོལ་བའོ། །དེ་བཞིན་དུ་ཚོར་བ་དང་འདུ་ཤེས་དང་འདུ་བྱེད་རྣམས་དང་བཅོམ་ལྡན་འདས་འདི་ལྟར་རྣམ་པར་ཤེས་པ་ནི་མ་བཅིངས་མ་གྲོལ་བའོ། །བཅོམ་ལྡན་འདས་གཟུགས་ཀྱི་དེ་བཞིན་ཉིད་ཀྱང་མ་བཅིངས་མ་\\nགྲོལ་བའོ། །དེ་བཞིན་དུ་ཚོར་བའི་དེ་བཞིན་ཉིད་དང་འདུ་ཤེས་ཀྱི་དེ་བཞིན་ཉིད་དང་འདུ་བྱེད་རྣམས་ཀྱི་དེ་བཞིན་ཉིད་དང་བཅོམ་ལྡན་འདས་རྣམ་པར་ཤེས་པའི་དེ་བཞིན་ཉིད་ཀྱང་མ་བཅིངས་མ་གྲོལ་བའོ། །\",\"folioNumber\":12,\"volumeNumber\":33}}},\"content\":[{\"type\":\"paragraph\",\"