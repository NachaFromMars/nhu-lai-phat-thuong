ation\":\"68a29151-90aa-43ac-aecd-3605658a95ad\",\"uuid\":\"6372463f-1e8a-4596-b3e9-0e92c257982d\"},\"content\":[{\"type\":\"text\",\"text\":\"BHSD\"}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":4,\"end\":5}},{\"type\":\"hasAbbreviation\",\"text\":\"Edgerton’s Buddhist Hybrid Sanskrit Dictionary\",\"attrs\":{\"start\":5,\"end\":51,\"uuid\":\"71285d68-f986-434d-a400-ea20ac0e2d3c\"},\"content\":[{\"type\":\"text\",\"text\":\"Edgerton’s Buddhist Hybrid Sanskrit Dictionary\"}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"4467d336-215d-478b-bc3b-59e7fa6b1ab6\",\"sort\":1000025,\"type\":\"abbreviations\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"class\":\"flex flex-row gap-2\",\"start\":0,\"end\":32,\"uuid\":\"4467d336-215d-478b-bc3b-59e7fa6b1ab6\"},\"content\":[{\"type\":\"abbreviation\",\"text\":\"DOP\",\"attrs\":{\"start\":0,\"end\":3,\"abbreviation\":\"4467d336-215d-478b-bc3b-59e7fa6b1ab6\",\"uuid\":\"2ac9c31e-7fb4-4631-a178-040147d6f79c\"},\"content\":[{\"type\":\"text\",\"text\":\"DOP\"}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":3,\"end\":4}},{\"type\":\"hasAbbreviation\",\"text\":\"Cone’s A Dictionary of Pāli.\",\"attrs\":{\"start\":4,\"end\":32,\"uuid\":\"a85ee34b-28bd-440f-9417-72f4e5f790c2\"},\"content\":[{\"type\":\"text\",\"text\":\"Cone’s A Dictionary of Pāli.\"}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"a9365a8c-d982-4c1c-ad51-cd86f929e0d1\",\"sort\":1000029,\"type\":\"abbreviations\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"class\":\"flex flex-row gap-2\",\"start\":0,\"end\":72,\"uuid\":\"a9365a8c-d982-4c1c-ad51-cd86f929e0d1\"},\"content\":[{\"type\":\"abbreviation\",\"text\":\"Hari/Haribhadra\",\"attrs\":{\"start\":0,\"end\":15,\"abbreviation\":\"a9365a8c-d982-4c1c-ad51-cd86f929e0d1\",\"uuid\":\"b001789b-b614-48df-a975-f024501522dd\"},\"content\":[{\"type\":\"text\",\"text\":\"Hari/Haribhadra\"}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":15,\"end\":16}},{\"type\":\"hasAbbreviation\",\"text\":\"Haribhadra, and citations from his Abhisamayālaṃkārāloka\",\"attrs\":{\"start\":16,\"end\":72,\"uuid\":\"394e21cc-3b49-4947-8c16-b5f33d64ed49\"},\"content\":[{\"type\":\"text\",\"text\":\"Haribhadra, and citations from his Abhisamayālaṃkārāloka\"}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"74cec7b7-867e-4d15-b58b-ee7c6cb50f42\",\"sort\":1000032,\"type\":\"abbreviations\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"class\":\"flex flex-row gap-2\",\"start\":0,\"end\":45,\"uuid\":\"74cec7b7-867e-4d15-b58b-ee7c6cb50f42\"},\"content\":[{\"type\":\"abbreviation\",\"text\":\"Kāś.\",\"attrs\":{\"start\":0,\"end\":4,\"abbreviation\":\"74cec7b7-867e-4d15-b58b-ee7c6cb50f42\",\"uuid\":\"ab1a97d9-e8b5-41af-8124-9ea4c2087bb4\"},\"content\":[{\"type\":\"text\",\"text\":\"Kāś.\"}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":4,\"end\":5}},{\"type\":\"hasAbbreviation\",\"text\":\"Kāśika’s commentary on Pāṇini’s Grammar.\",\"attrs\":{\"start\":5,\"end\":45,\"uuid\":\"aecf709f-a60d-4960-ab7e-8d4b048b4a24\"},\"content\":[{\"type\":\"text\",\"text\":\"Kāśika’s commentary on Pāṇini’s Grammar.\"}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"94814675-174e-4d87-b195-ff679debc6b2\",\"sort\":1000036,\"type\":\"abbreviations\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"class\":\"flex flex-row gap-2\",\"start\":0,\"end\":59,\"uuid\":\"94814675-174e-4d87-b195-ff679debc6b2\"},\"content\":[{\"type\":\"abbreviation\",\"text\":\"MSABh\",\"attrs\":{\"start\":0,\"end\":5,\"abbreviation\":\"94814675-174e-4d87-b195-ff679debc6b2\",\"uuid\":\"6629a965-b71c-42e4-9b03-1bc5a7142864\"},\"content\":[{\"type\":\"text\",\"text\":\"MSABh\"}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":5,\"end\":6}},{\"type\":\"hasAbbreviation\",\"text\":\"Vasubandhu’s Mahā­yāna­sūtrālaṃkāra­bhāṣya (Toh 4026)\",\"attrs\":{\"start\":6,\"end\":