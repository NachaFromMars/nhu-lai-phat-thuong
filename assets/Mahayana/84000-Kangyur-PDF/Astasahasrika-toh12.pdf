s\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b6d126c4-75af-4ae3-a06d-ed6e6e6a2ad7\",\"uuid\":\"fc73c963-7189-486e-a4a1-4a05979b06ee\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\", uninformed, ordinary persons.”\",\"attrs\":{\"start\":297,\"end\":329},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"80a06d21-d10f-4ab2-9f8a-69a87e2541dc\",\"label\":\"140\",\"uuid\":\"8501e7cc-e2de-46f3-8445-5113c52bf0db\",\"start\":329,\"end\":329,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"60b1314e-ba76-47a3-9ad1-9edf6e4474bc\",\"sort\":11261,\"type\":\"translation\",\"label\":\"1.46\",\"alignments\":{\"toh12\":{\"folioUuid\":\"71d868a0-9a15-469f-a1b0-ed2d7bf356b4\",\"toh\":\"toh12\",\"tibetan\":\"$5b\",\"folioNumber\":8,\"volumeNumber\":33}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":72,\"uuid\":\"de66b2cd-b43d-440f-b25e-301dd9d8d74c\"},\"content\":[{\"type\":\"text\",\"text\":\"“How then are those things experienced?”\",\"attrs\":{\"start\":0,\"end\":40},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"23e5a847-d3b1-4090-acb1-00644956641b\",\"label\":\"141\",\"uuid\":\"7302d70b-577f-4ecd-befe-dd97baa6b368\",\"start\":40,\"end\":40,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" asked the \",\"attrs\":{\"start\":40,\"end\":51}},{\"type\":\"text\",\"text\":\"venerable\",\"attrs\":{\"start\":51,\"end\":60},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"91107107-3f31-4442-8365-9099041efadf\",\"uuid\":\"e435201f-b43f-4da8-8f8f-d509a66a03d8\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":60,\"end\":61}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":61,\"end\":70},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"3df1bcb6-86da-4978-8191-8dbd8f56b919\",\"uuid\":\"9045cd70-c18b-44ff-a562-897e456d4275\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\". \",\"attrs\":{\"start\":70,\"end\":72}}]},{\"type\":\"paragraph\",\"attrs\":{\"start\":72,\"end\":1538,\"uuid\":\"4f2293ed-ff8f-4473-bb7b-c9d79ab2a23a\"},\"content\":[{\"type\":\"text\",\"text\":\"The \",\"attrs\":{\"start\":72,\"end\":76}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":76,\"end\":87},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7bf45dd5-3e8d-4495-bc65-ecf0a51d3597\",\"uuid\":\"474e728a-aad6-4873-9525-564a2646e3a4\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\" replied, “O \",\"attrs\":{\"start\":87,\"end\":100}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":100,\"end\":109},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"3df1bcb6-86da-4978-8191-8dbd8f56b919\",\"uuid\":\"25873f56-9119-40a3-a6b2-06af059fdeb2\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\", insofar as those things are \",\"attrs\":{\"start\":109,\"end\":139}},{\"type\":\"text\",\"text\":\"not experienced as existing\",\"attrs\":{\"start\":139,\"end\":166},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"0c54e749-10c0-431c-83c0-129b6d86a251\",\"uuid\":\"30638887-5e03-4cfc-aa1e-9ec67de2709f\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\", they are experienced. And, since those things are not known to exist as such by that bodhisattva \",\"attrs\":{\"start\":166,\"end\":265}},{\"type\":\"text\",\"text\":\"great being\",\"attrs\":{\"start\":265,\"end\":276},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"be37efde-2f63-40d0-8e8e-e93b3b3a581e\",\"uuid\":\"efd5e72a-989e-4e55-9772-78be9c7b0bfe\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\", they are called \",\"attrs\":{\"start\":276,\"end\":294}},{\"type\":\"text\",\"text\":\"ignorance\",\"attrs\":{\"start\":294,\"end\":303},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":294,\"end\":303,\"uuid\":\"dfe2b8eb-d50f-4106-83ae-8de48383f801\",\"type\":\"span\",\"textStyle\":\"distinct\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b7a756de-b2ad-4958-bd7f-f0447f6f8f27\",\"uuid\":\"9a8e6c62-9106-40ca-a669-76d3116ed233\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":303,\"end\":304},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"9de24d57-adf6-444e-80f5-0642e4276de6\",\"label\":\"142\",\"uuid\":\"5bbecf43-fa2d-4013-b689-5d8da6854133\",\"start\":304,\"end\":304,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" Those things are habitually fixated upon by \",\"attrs\":{\"start\":304,\"end\":349}},{\"type\":\"text\",\"text\":\"immature\",\"attrs\":{\"start\":349,\"end\":357},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b6d126c4-75af-4ae3-a06d-ed6e6e6a2ad7\",\"uuid\":\"89a865f8-e738-49ae-b4d9-d503778c823d\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\", uninformed, ordinary persons. But all things‍—insofar as they are not actually experienced‍—are just imagined by them.\",\"attrs\":{\"start\":357,\"end\":477},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"6e379a8d-dbda-414a-9153-2420a19d8692\",\"label\":\"143\",\"uuid\":\"182660fe-ade0-4448-a41f-3f8274832398\",\"start\":477,\"end\":477,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" After imagining them, those \",\"attrs\":{\"start\":477,\"end\":506}},{\"type\":\"text\",\"text\":\"immature\",\"attrs\":{\"start\":506,\"end\":514},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b6d126c4-75af-4ae3-a06d-ed6e6e6a2ad7\",\"uuid\":\"0ac4ea23-c5f4-48e4-9220-94327e5bd4d2\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\", ordinary beings become entangled in the \",\"attrs\":{\"start\":514,\"end\":556}},{\"type\":\"text\",\"text\":\"two extremes\",\"attrs\":{\"start\":556,\"end\":568},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d54f7db2-be22-4bb6-8953-4cb74728ec05\",\"uuid\":\"e34d1934-f5ea-4a91-90b1-c5a279cc19be\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\", and neither perceive nor see those things.\",\"attrs\":{\"start\":568,\"end\":612},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"637a17b1-be41-48e1-836b-d1de5d585f46\",\"label\":\"144\",\"uuid\":\"66b24733-b7fd-4447-86b0-0c238c5d4e36\",\"start\":612,\"end\":612,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" Hence, they imagine all the things not being experienced, and after imagining those, they become habitually fixated on the \",\"attrs\":{\"start\":612,\"end\":736}},{\"type\":\"text\",\"text\":\"two extremes\",\"attrs\":{\"start\":736,\"end\":748},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d54f7db2-be22-4bb6-8953-4cb74728ec05\",\"uuid\":\"fa1e9261-a54f-413a-b395-75c931854c8f\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\". After habitually fixating on those extremes, they resort to their mental perception as a \",\"attrs\":{\"start\":748,\"end\":839}},{\"type\":\"text\",\"text\":\"foundation\",\"attrs\":{\"start\":839,\"end\":849},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cf4920b7-8e10-4fa5-94ec-faa94b096f50\",\"uuid\":\"d13e1d54-b7ad-45a6-8727-445efb50982b\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\", and imagine things as past, things as future, and things as present.\",\"attrs\":{\"start\":849,\"end\":919},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"ca0033f6-c9fc-432a-b391-9f57dbbd9139\",\"label\":\"145\",\"uuid\":\"d1f7fabd-7e6f-4e51-95e1-063266a627e4\",\"start\":919,\"end\":919,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" After imagining those, they become fixated on names and physical forms.\",\"attrs\":{\"start\":919,\"end\":991},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"873fe8de-ea08-4cf3-84f0-eca473421f3a\",\"label\":\"146\",\"uuid\":\"b37af340-b026-48af-8d65-4d78a6f69e30\",\"start\":991,\"end\":991,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" These things are also imagined by them. While they are imagining all these things not being experienced, they neither perceive nor do they see the path \",\"attrs\":{\"start\":991,\"end\":1144}},{\"type\":\"text\",\"text\":\"in accordance with reality\",\"attrs\":{\"start\":1144,\"end\":1170},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"656c6fb9-baff-42ed-92cc-c3566df18e32\",\"uuid\":\"402aa48c-0743-4ddc-960c-be521c8f3611\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\". Since they are not perceiving or seeing the path \",\"attrs\":{\"start\":1170,\"end\":1221}},{\"type\":\"text\",\"text\":\"in accordance with reality\",\"attrs\":{\"start\":1221,\"end\":1247},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"656c6fb9-baff-42ed-92cc-c3566df18e32\",\"uuid\":\"ec08b2ab-5335-45a9-b46f-86509bbe1c13\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\", they neither go beyond the three realms nor awaken to the \",\"attrs\":{\"start\":1247,\"end\":1307}},{\"type\":\"text\",\"text\":\"pinnacle of reality\",\"attrs\":{\"start\":1307,\"end\":1326},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"aaeba2e6-a279-4a6d-af18-709a428b75ee\",\"uuid\":\"984fefaf-a032-4673-ae63-918cd27ffbeb\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":1326,\"end\":1327},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"9fddd16d-377f-4e84-8821-c2d45839b8fc\",\"label\":\"147\",\"uuid\":\"1cdbec18-6869-49ef-add7-1e9ea32868a9\",\"start\":1327,\"end\":1327,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" For this reason, those beings are considered \",\"attrs\":{\"start\":1327,\"end\":1373}},{\"type\":\"text\",\"text\":\"immature\",\"attrs\":{\"start\":1373,\"end\":1381},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":1373,\"end\":1381,\"uuid\":\"bbc7474f-90c0-4960-8