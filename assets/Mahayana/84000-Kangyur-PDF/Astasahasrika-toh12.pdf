f8ac7-fa9d-42ee-8d6d-8780604876a6\",\"toh\":\"toh12\",\"tibetan\":\"རང་སངས་རྒྱས་ཀྱི་ས་ལ་སློབ་པར་འདོད་པས་ཀྱང་ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ་འདི་ཉིད་མཉན་པར་བྱ་གཟུང་བར་བྱ་བཅང་བར་བྱ་\\nཀླག་པར་བྱ་ཀུན་ཆུབ་པར་བྱ་རབ་ཏུ་གདོན་པར་བྱའོ། །ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ་འདི་ཉིད་ལ་བསླབ་པར་བྱའོ་རྣལ་འབྱོར་དུ་བྱའོ། །\",\"folioNumber\":3,\"volumeNumber\":33}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":266,\"uuid\":\"42ba14c7-b457-4034-ae9d-d3ad52913ad5\"},\"content\":[{\"type\":\"text\",\"text\":\"“Furthermore, anyone who wishes to train for the level of a \",\"attrs\":{\"start\":0,\"end\":60}},{\"type\":\"text\",\"text\":\"solitary realizer\",\"attrs\":{\"start\":60,\"end\":77},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"91eb4850-6549-4ee5-ae57-ec33c68112f1\",\"uuid\":\"001d08f2-4418-4c75-8044-d084bfc0bce7\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\" must listen to this perfection of wisdom, take it in, keep it in mind, chant it, master it, and pass it on. He or she must train and \",\"attrs\":{\"start\":77,\"end\":211}},{\"type\":\"text\",\"text\":\"engage in meditation\",\"attrs\":{\"start\":211,\"end\":231},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bb81289a-6f28-427c-897b-ab8835bb5493\",\"uuid\":\"38845763-ec3e-4e97-a9ce-c0db167b9744\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\" in this very perfection of wisdom.\",\"attrs\":{\"start\":231,\"end\":266}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"fe7b6298-b1a0-4777-ae70-4ed85ed43451\",\"sort\":10410,\"type\":\"translation\",\"label\":\"1.16\",\"alignments\":{\"toh12\":{\"folioUuid\":\"73ef8ac7-fa9d-42ee-8d6d-8780604876a6\",\"toh\":\"toh12\",\"tibetan\":\"བྱང་ཆུབ་སེམས་དཔའི་ས་ལ་སློབ་པར་འདོད་པས་ཀྱང་ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ་འདི་ཉིད་མཉན་པར་བྱ་གཟུང་བར་བྱ་བཅང་བར་བྱ་ཀླག་པར་བྱ་ཀུན་ཆུབ་\\nཔར་བྱ་རབ་ཏུ་གདོན་པར་བྱའོ། །ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ་འདི་ཉིད་ལ་ཐབས་མཁས་པ་དང་ལྡན་པས་བྱང་ཆུབ་སེམས་དཔའི་ཆོས་ཐམས་ཅད་ཐོབ་པར་བྱ་བའི་ཕྱིར་རྣལ་འབྱོར་དུ་བྱའོ། །དེ་ཅིའི་ཕྱིར་ཞེ་ན། བྱང་ཆུབ་སེམས་དཔའ་སེམས་དཔའ་ཆེན་པོས་གང་ལ་བསླབས་ཤིང་རྣལ་\\nའབྱོར་དུ་བྱ་བའི་བྱང་ཆུབ་སེམས་དཔའི་ཆོས་ཐམས་ཅད་རྒྱས་པར་ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ་འདི་ཉིད་ལས་བསྟན་ཏོ། །\",\"folioNumber\":3,\"volumeNumber\":33}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":505,\"uuid\":\"fe7b6298-b1a0-4777-ae70-4ed85ed43451\"},\"content\":[{\"type\":\"text\",\"text\":\"“Furthermore, anyone who wishes to train for the level of a bodhisattva must listen to this very perfection of wisdom, take it in, keep it in mind, chant it, master it, and pass it on. Anyone endowed with skill in means must \",\"attrs\":{\"start\":0,\"end\":225}},{\"type\":\"text\",\"text\":\"engage in meditation\",\"attrs\":{\"start\":225,\"end\":245},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bb81289a-6f28-427c-897b-ab8835bb5493\",\"uuid\":\"c2cd9033-4b26-4167-a49e-be44af6e506c\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\" in this very perfection of wisdom in order to achieve all the bodhisattva qualities.\",\"attrs\":{\"start\":245,\"end\":330},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"aafbb194-8854-42d1-9df1-996700bb6944\",\"label\":\"104\",\"uuid\":\"c828490d-32b1-4cfb-9d81-3fd249d5b24e\",\"start\":330,\"end\":330,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" Why is that? It is because all the bodhisattva qualities are expounded in detail in this very perfection of wisdom in which a bodhisattva must train and \",\"attrs\":{\"start\":330,\"end\":484}},{\"type\":\"text\",\"text\":\"engage in meditation\",\"attrs\":{\"start\":484,\"end\":504},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bb81289a-6f28-427c-897b-ab8835bb5493\",\"uuid\":\"b9a67767-84b2-49ef-984e-0f8a8c0d0bf6\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":504,\"end\":505}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"65f5f57c-1a04-4b93-9a99-e690a8c17bb0\",\"sort\":10418,\"type\":\"translation\",\"label\":\"1.17\",\"alignments\":{\"toh12\":{\"folioUuid\":\"73ef8ac7-fa9d-42ee-8d6d-8780604876a6\",\"toh\":\"toh12\",\"tibetan\":\"བླ་ན་མེད་པ་ཡང་དག་པར་རྫོགས་པའི་བྱང་ཆུབ་ལ་སློབ་པར་འདོད་པས་ཀྱང་ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ་འདི་ཉིད་མཉན་པར་བྱ་གཟུང་བར་བྱ་བཅང་བར་\\nབྱ་ཀླག་པར་བྱ་ཀུན་ཆུབ་པར་བྱ་རབ་ཏུ་གདོན་པར་བྱའོ། །ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ་འདི་ཉིད་ལ་ཐབས་མཁས་པ་དང་ལྡན་པས་སངས་རྒྱས་ཀྱི་ཆོས་ཐམས་ཅད་ཐོབ་པར་བྱ་བའི་ཕྱིར་རྣལ་འབྱོར་དུ་བྱའོ། །དེ་ཅིའི་ཕྱིར་ཞེ་ན། ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ་འདི་ཉིད་ལས་[F.4.a]ནི་བྱང་ཆུབ་སེམས་དཔའ་སེམས་དཔའ་ཆེན་པོས་གང་ལ་བསླབ་པར་བྱ་བ་རྣལ་འབྱོར་དུ་བྱ་བའི་སངས་རྒྱས་ཀྱི་ཆོས་ཐམས་ཅད་རྒྱས་པར་བསྟན་ཏོ། །\",\"folioNumber\":3,\"volumeNumber\":33}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":359,\"uuid\":\"65f5f57c-1a04-4b93-9a99-e690a8c17bb0\"},\"content\":[{\"type\":\"text\",\"text\":\"“Finally, anyone who wishes to train even in \",\"attrs\":{\"start\":0,\"end\":45}},{\"type\":\"text\",\"text\":\"unsurpassed\",\"attrs\":{\"start\":45,\"end\":56},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"025da177-4bdf-47b4-b3f7-639bedf16eb9\",\"uuid\":\"e845f577-7bf7-44e3-8e14-3ca4403e3d7f\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\", perfect awakening must listen to this perfection of wisdom, take it in, keep it in mind, chant it, master it, and pass it on. Why is that? It is because all the buddha qualities are expounded in detail here in this very perfection of wisdom in which a bodhisattva must train and \",\"attrs\":{\"start\":56,\"end\":337}},{\"type\":\"text\",\"text\":\"engage in meditation\",\"attrs\":{\"start\":337,\"end\":357},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bb81289a-6f28-427c-897b-ab8835bb5493\",\"uuid\":\"f61d3e61-79b6-4747-8dad-b715f8a866aa\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\".”\",\"attrs\":{\"start\":357,\"end\":359}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"1bde732c-d933-4ce7-97c5-4478f3115f3b\",\"sort\":10427,\"type\":\"translation\",\"label\":\"1.18\",\"alignments\":{\"toh12\":{\"folioUuid\":\"9b99a91f-466d-4138-b604-94aa2be1f16d\",\"toh\":\"toh12\",\"tibetan\":\"དེ་ནས་བཅོམ་ལྡན་འདས་ལ་ཚེ་དང་ལྡན་པ་རབ་འབྱོར་གྱིས་འདི་སྐད་ཅེས་གསོལ་ཏོ། །བཅོམ་ལྡན་འདས་\\nབྱང་ཆུབ་སེམས་དཔའི་མིང་གང་ལགས་པ་འདི་ཉིད་བདག་གིས་མ་འཚལ་མ་དམིགས་ཡང་དག་པར་རྗེས་སུ་མི་མཐོང་ངོ་། །ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ་ཡང་མ་འཚལ་མ་དམིགས་ཡང་དག་པར་རྗེས་སུ་མི་མཐོང་ངོ་། །བཅོམ་ལྡན་འདས་བདག་གིས་བྱང་ཆུབ་སེམས་\\nདཔའི་མིང་འདི་ཉིད་མ་འཚལ་མ་དམིགས་ཡང་དག་པར་རྗེས་སུ་མ་མཐོང་ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ་ཡང་མ་འཚལ་མ་དམིགས་ཡང་དག་པར་རྗེས་སུ་མ་མཐོང་ན་བྱང་ཆུབ་སེམས་དཔའ་གང་ཞིག་ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ་གང་ལ་གདམས་ཤིང་རྗེས་སུ་བསྟན་པར་བགྱི། \\nབཅོམ་ལྡན་འདས་གང་བདག་གིས་དངོས་པོ་མ་འཚལ་མ་དམིགས་ཡང་དག་པར་རྗེས་སུ་མ་མཐོང་ན། མིང་ཙམ་གྱིས་འདི་ལྟ་སྟེ་བྱང་ཆུབ་སེམས་དཔའ་ཞེས་འདུ་བ་དང་འགོད་པར་བགྱིད་པ་ནི་བདག་གི་གློ་བ་ལ་གཅགས་ལགས་སོ། །བཅོམ་ལྡན་འདས་འོན་ཀྱང་མིང་དེ་ཡང་\\nགནས་པ་མ་ལགས་ཤིང་མི་གནས་པ་ཡང་མ་ལགས་ལ་གནས་པ་དང་བྲལ་བ་མ་ལགས་ཤིང་གནས་པ་དང་བྲལ་བ་མ་ལགས་པ་ཡང་མ་ལགས་སོ། །དེ་ཅིའི་སླད་དུ་ཞེ་ན། མིང་དེ་མ་མཆིས་པའི་སླད་དུའོ། །དེ་ལྟར་མིང་དེ་གནས་པ་མ་ལགས་ཤིང་མི་གནས་པ་ཡང་མ་ལགས་ལ་\\nགནས་པ་དང་བྲལ་བ་མ་ལགས་ཤིང་གནས་པ་དང་བྲལ་བ་མ་ལགས་པ་ཡང་མ་ལགས་སོ། །\",\"folioNumber\":4,\"volumeNumber\":33}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1178,\"uuid\":\"1bde732c-d933-4ce7-97c5-4478f3115f3b\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"b92d6cb9-0836-44e8-a95f-831fdb9dd914\"},\"content\":[{\"type\":\"text\",\"text\":\"T\",\"attrs\":{\"start\":0,\"end\":1},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"51056e43-fd5a-45c0-83b1-8f43e4091e9a\",\"label\":\"105\",\"uuid\":\"d35e5bb0-49f3-42ca-afb6-ba613923094f\",\"start\":0,\"end\":0,\"location\":\"start\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\"he \",\"attrs\":{\"start\":1,\"end\":4}},{\"type\":\"text\",\"text\":\"Venerable\",\"attrs\":{\"start\":4,\"end\":13},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"91107107-3f31-4442-8365-9099041efadf\",\"uuid\":\"250ca39c-b61f-4a62-86a2-7b3bc797b268\",\"toh\":\"toh