475bf32-88c2-4471-9cf6-eff28ffb3061\",\"uuid\":\"f116b2d8-1932-48c2-a515-a29708172b35\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":460,\"end\":461}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"2ce0b422-a8ad-458f-bc27-e9219c120561\",\"sort\":10582,\"type\":\"translation\",\"label\":\"1.23\",\"alignments\":{\"toh12\":{\"folioUuid\":\"ad2ed953-27e9-48e2-9f9d-47f2cfd273f0\",\"toh\":\"toh12\",\"tibetan\":\"གལ་ཏེ་མཚན་མར་བཟུང་བར་གྱུར་ན་ཀུན་\\nཏུ་རྒྱུ་ཕྲེང་བ་ཅན་འདི་ལ་དད་པར་མི་འགྱུར་བ་ཞིག་ན། ཀུན་ཏུ་རྒྱུ་ཕྲེང་བ་ཅན་ཐམས་ཅད་མཁྱེན་པའི་ཡེ་ཤེས་འདི་ལ་མོས་ནས་དད་པས་རྗེས་སུ་འབྲང་ཞིང་ཕྱོགས་གཅིག་པའི་ཡེ་ཤེས་ཀྱིས་ཞུགས་སོ། །དེ་ཞུགས་ནས་ཀྱང་གཟུགས་ཡོངས་སུ་མི་འཛིན་ཏོ། །དེ་བཞིན་དུ་ཚོར་བ་མ་\\nལགས་འདུ་ཤེས་མ་ལགས་འདུ་བྱེད་རྣམས་མ་ལགས་རྣམ་པར་ཤེས་པ་ཡོངས་སུ་མི་འཛིན་ཏོ། །དེ་ལ་ཤེས་པ་དེ་དགའ་བ་དང་བདེ་བར་ཡང་ཡང་དག་པར་རྗེས་སུ་མི་མཐོང་ངོ་། །ཤེས་པ་དེ་ནང་གི་གཟུགས་ཀྱི་ཡིན་པར་ཡང་དག་པར་རྗེས་སུ་མི་མཐོང་ངོ་། །ཤེས་པ་དེ་ཕྱི་རོལ་\\nགྱི་གཟུགས་ཀྱི་ཡིན་པར་ཡང་དག་པར་རྗེས་སུ་མི་མཐོང་། །ཤེས་པ་དེ་ཕྱི་ནང་གི་གཟུགས་ཀྱི་ཡིན་པར་ཡང་དག་པར་རྗེས་སུ་མི་མཐོང་། ཤེས་པ་དེ་གཟུགས་ལས་གཞན་དུ་ཡང་ཡང་དག་པར་རྗེས་སུ་མི་མཐོང་ངོ་། །དེ་བཞིན་དུ་ཤེས་པ་དེ་ནང་གི་ཚོར་བ་དང་འདུ་ཤེས་དང་འདུ་\\nབྱེད་རྣམས་ཀྱི་མ་ཡིན། ཤེས་པ་དེ་ནང་གི་རྣམ་པར་ཤེས་པའི་ཡིན་པར་ཡང་དག་པར་རྗེས་སུ་མི་མཐོང་ངོ་། །ཤེས་པ་དེ་ཕྱི་རོལ་གྱི་རྣམ་པར་ཤེས་པའི་ཡིན་པར་ཡང་དག་པར་རྗེས་སུ་མི་མཐོང་། །ཤེས་པ་དེ་ཕྱི་ནང་གི་རྣམ་པར་ཤེས་པའི་ཡིན་པར་ཡང་དག་པར་རྗེས་སུ་མི་མཐོང་། \\nཤེས་པ་དེ་རྣམ་པར་ཤེས་པ་ལས་གཞན་དུ་ཡང་ཡང་དག་པར་རྗེས་སུ་མི་མཐོང་སྟེ། \",\"folioNumber\":5,\"volumeNumber\":33}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1316,\"uuid\":\"2ce0b422-a8ad-458f-bc27-e9219c120561\"},\"content\":[{\"type\":\"text\",\"text\":\"“If it were something to be grasped through conventional \",\"attrs\":{\"start\":0,\"end\":57}},{\"type\":\"text\",\"text\":\"signs\",\"attrs\":{\"start\":57,\"end\":62},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5475bf32-88c2-4471-9cf6-eff28ffb3061\",\"uuid\":\"9da92461-3b36-460c-9a9b-9109693971ee\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\", then the wandering ascetic \",\"attrs\":{\"start\":62,\"end\":91}},{\"type\":\"text\",\"text\":\"Śreṇika\",\"attrs\":{\"start\":91,\"end\":98},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c6eeefbc-2b12-4439-986c-1c38ae18a036\",\"uuid\":\"07508a2a-1b4a-42a1-a7c4-4897a3b99fac\",\"toh\":\"toh12\"}},{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"e530f824-5bcd-48b9-ace9-c1390264ab62\",\"label\":\"115\",\"uuid\":\"e47a4559-c38a-4680-b351-6302854b5bd3\",\"start\":98,\"end\":98,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" would never have gained faith in this teaching of the Buddha.\",\"attrs\":{\"start\":98,\"end\":160},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"c1da67e6-659b-4234-85d5-d500cdf11009\",\"label\":\"116\",\"uuid\":\"e5783e2d-9667-46f1-b40d-c4b8dacabbc9\",\"start\":160,\"end\":160,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" Indeed, as someone who \",\"attrs\":{\"start\":160,\"end\":184}},{\"type\":\"text\",\"text\":\"proceeded based on faith\",\"attrs\":{\"start\":184,\"end\":208},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2e6ab6d0-661a-4953-a0ea-8227e8db9f31\",\"uuid\":\"6e2dd53d-6b5b-4d2b-87e9-559a86b93c67\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\", the wandering ascetic \",\"attrs\":{\"start\":208,\"end\":232}},{\"type\":\"text\",\"text\":\"Śreṇika\",\"attrs\":{\"start\":232,\"end\":239},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c6eeefbc-2b12-4439-986c-1c38ae18a036\",\"uuid\":\"5d2dead8-484e-4f1d-a05c-a627ed3714ea\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\" had \",\"attrs\":{\"start\":239,\"end\":244}},{\"type\":\"text\",\"text\":\"firm conviction\",\"attrs\":{\"start\":244,\"end\":259},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"14d822fc-e184-4e5e-affd-9e3b08918c08\",\"uuid\":\"1128e1df-1645-43dd-8be0-d74306437d57\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\" in the \",\"attrs\":{\"start\":259,\"end\":267}},{\"type\":\"text\",\"text\":\"knowing of someone who has complete knowing\",\"attrs\":{\"start\":267,\"end\":310},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"984c7a94-e1eb-45a9-8a0d-4a56573a3727\",\"uuid\":\"5ab16d22-c8f1-47b3-9ade-053520f8ed27\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\" and he entered into it through a knowing limited in scope.\",\"attrs\":{\"start\":310,\"end\":369},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"f02aee54-1169-4517-b27c-d1e413e5bcf8\",\"label\":\"117\",\"uuid\":\"56a9264e-be5e-4dcf-a010-aac4d0c4ca29\",\"start\":369,\"end\":369,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" After entering it, he did not apprehend physical forms.\",\"attrs\":{\"start\":369,\"end\":425},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"72c85dcb-03e9-40a6-8a5e-f0f609840b8c\",\"label\":\"118\",\"uuid\":\"40198c4f-5ea8-4818-b247-255d5a6c2850\",\"start\":425,\"end\":425,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" Likewise, he did not apprehend feelings, conceptions, conditioning factors, or consciousness. In that state, he did not even identify that knowing as delight or ease.\",\"attrs\":{\"start\":425,\"end\":592},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"1bb40664-1a3b-4a91-a77d-f0d76f73ec32\",\"label\":\"119\",\"uuid\":\"28ad0bf0-8c62-4695-9065-1e4045539681\",\"start\":592,\"end\":592,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" Nor did he identify that knowing as inside physical forms. Nor did he identify that knowing as outside physical forms. Nor did he identify that knowing as both inside and outside physical forms. Nor did he identify that knowing as other than physical forms. Likewise, he did not identify that knowing as inside feelings, conceptions, conditioning factors, or consciousness. Nor did he identify that knowing as outside feelings, conceptions, conditioning factors, or consciousness. Nor did he identify that knowing as both inside and outside feelings, conceptions, conditioning factors, or consciousness. Nor did he identify that knowing as something other than feelings, conceptions, conditioning factors, or consciousness.\",\"attrs\":{\"start\":592,\"end\":1316}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"71782a5b-a4cd-4bae-8501-e7304e904af2\",\"sort\":10605,\"type\":\"translation\",\"label\":\"1.24\",\"alignments\":{\"toh12\":{\"folioUuid\":\"ad2ed953-27e9-48e2-9f9d-47f2cfd273f0\",\"toh\":\"toh12\",\"tibetan\":\"ཚིག་གི་རྣམ་གྲངས་འདི་ལ་ཀུན་ཏུ་རྒྱུ་ཕྲེང་བ་ཅན་མོས་སོ། །དེ་ཐམས་ཅད་མཁྱེན་པའི་ཡེ་ཤེས་འདི་ལ་ཐམས་ཅད་དུ་དད་པས་རྗེས་སུ་འབྲང་ཞིང་ཆོས་ཉིད་ཚད་མར་བགྱིས་ཏེ་འདི་ལྟར་མོས་པ་[F.5.b]ཞེས་བགྱིའོ། །དེས་ཆོས་གང་ཡང་ཡོངས་སུ་མ་བཟུང་ངོ་། །གང་གཟུང་བའམ་གཏང་བར་བགྱི་བའི་ཆོས་དེ་གང་ཡང་མ་དམིགས་སོ། །དེ་མྱ་ངན་ལས་འདས་པར་ཡང་རློམ་སེམས་སུ་མི་བགྱིད་དོ། །\",\"folioNumber\":5,\"volumeNumber\":33}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":473,\"uuid\":\"71782a5b-a4cd-4bae-8501-e7304e904af2\"},\"content\":[{\"type\":\"text\",\"text\":\"“The wandering ascetic \",\"attrs\":{\"start\":0,\"end\":23}},{\"type\":\"text\",\"text\":\"Śreṇika\",\"attrs\":{\"start\":23,\"end\":30},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c6eeefbc-2b12-4439-986c-1c38ae18a036\",\"uuid\":\"3c2b8d4a-c27a-48af-b917-ce07338b2ce1\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\" had \",\"attrs\":{\"start\":30,\"end\":35}},{\"type\":\"text\",\"text\":\"firm conviction\",\"attrs\":{\"start\":35,\"end\":50},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"14d822fc-e184-4e5e-affd-9e3b08918c08\",\"uuid\":\"5573a802-312f-466d-90ed-6703c53abbc2\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\" in this \",\"attrs\":{\"start\":50,\"end\":59}},{\"type\":\"text\",\"text\":\"way of proceeding\",\"attrs\":{\"start\":59,\"end\":76},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8e5153df-d01f-4825-a3b3-d9f0bea924df\",\"uuid\":\"00be8c71-d7a4-463f-80a3-09b7f8fa02b6\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":76,\"end\":77},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"ffa12b85-5fe3-414d-a0e2-47210809083c\",\"label\":\"120\",\"uuid\":\"38d6836b-3d0a-47ea-b811-158128a36ea2\",\"start\":77,\"end\":77,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" Everywhere along this way, he was someone who \",\"attrs\":{\"start\":77,\"end\":124}},{\"type\":\"text\",\"text\":\"proceeded based on faith\",\"attrs\":{\"start\":124,\"end\":148},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2e6ab6d0-661a-4953-a0ea-8227e8db9f31\",\"uuid\":\"3efe1a72-713d-4015-8a35-f60daca90149\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\" in the \",\"attrs\":{\"start\":148,\"end\":156}},{\"type\":\"text\",\"text\":\"knowing of someone who has complete knowing\",\"attrs\":{\"start\":156,\"end\":199},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"984c7a94-e1eb-45a9-8a0d-4a56573a3727\",\"uuid\":\"4ca9440d-18cc-4aa1-b297-4ab8bb9b5e4e\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\". Hence, it is said, ‘He took the \",\"attrs\":{\"start\":199,\"end\":233}},{\"type\":\"text\",\"text\":\"true nature\",\"attrs\":{\"start\":233,\"end\":244},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"dd571a94-b6b3-4e5a-acb3-f5c0068a3df0\",\"uuid\":\"90d2c895-66c7-431f-a137-e74e12bf1a68\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\" of Dharma to be authoritative in this way and had \",\"attrs\":{\"start\":244,\"end\":295}},{\"type\":\"text\",\"text\":\"firm conviction\",\"attrs\":{\"start\":295,\"end\":310},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"14d822fc-e184-4e5e-affd-9e3b08918c08\",\"uuid\":\