ེ་བར་འགྱུར་རོ། །ཅི་ལྟ་ཅི་ལྟར་ཐམས་ཅད་མཁྱེན་པ་ཉིད་ལ་ཉེ་བར་\\nགྱུར་པ་དེ་ལྟ་དེ་ལྟར་སེམས་ཅན་ཡོངས་སུ་སྨིན་པའི་ཕྱིར། ལུས་དང་སེམས་ཡོངས་སུ་དག་པ་དང་མཚན་ཡོངས་སུ་དག་པ་དང་སངས་རྒྱས་ཀྱི་ཞིང་ཡོངས་སུ་དག་པ་དང་སངས་རྒྱས་དང་ཉེ་བར་ཡང་འགྱུར་རོ། །ཚེ་དང་ལྡན་པ་ཤཱ་རིའི་བུ་བྱང་ཆུབ་སེམས་དཔའ་སེམས་\\nདཔའ་ཆེན་པོ་དེ་ལྟར་ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ་ལ་སྤྱོད་པ་ནི་ཐམས་ཅད་མཁྱེན་པ་ཉིད་ལ་ཉེ་བ་ཡིན་ནོ། །\",\"folioNumber\":6,\"volumeNumber\":33}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":917,\"uuid\":\"1a658e45-8400-4a00-8543-427edbd6992e\"},\"content\":[{\"type\":\"text\",\"text\":\"The \",\"attrs\":{\"start\":0,\"end\":4}},{\"type\":\"text\",\"text\":\"venerable\",\"attrs\":{\"start\":4,\"end\":13},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"91107107-3f31-4442-8365-9099041efadf\",\"uuid\":\"03707d6f-3904-4f6e-ac0f-62bb8ee8eafe\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":13,\"end\":14}},{\"type\":\"text\",\"text\":\"Subhūti\",\"attrs\":{\"start\":14,\"end\":21},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"22f9f523-3d5f-4683-ac40-82bee1ab5a5f\",\"uuid\":\"eedb50fc-9471-4606-bbd5-7ce8334f910f\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\" replied to the \",\"attrs\":{\"start\":21,\"end\":37}},{\"type\":\"text\",\"text\":\"venerable\",\"attrs\":{\"start\":37,\"end\":46},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"91107107-3f31-4442-8365-9099041efadf\",\"uuid\":\"71a97395-2c66-48aa-8a81-60dad1e1e73f\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":46,\"end\":47}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":47,\"end\":56},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"3df1bcb6-86da-4978-8191-8dbd8f56b919\",\"uuid\":\"75413e68-b2ff-4630-a7b5-0ad7410dd94b\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\", “Yes, that bodhisattva \",\"attrs\":{\"start\":56,\"end\":81}},{\"type\":\"text\",\"text\":\"great 