abel\":\"8.\",\"sort\":80006,\"level\":3,\"section\":\"translation\",\"children\":[]},{\"uuid\":\"0ebd33c2-47dd-4bd3-8008-37a28444adc9\",\"content\":\"Chapter 9: Praise\",\"label\":\"9.\",\"sort\":90006,\"level\":3,\"section\":\"translation\",\"children\":[]},{\"uuid\":\"a474b11b-0e67-4866-8c34-23a11de34aca\",\"content\":\"Chapter 10: Extolling the Positive Qualities of Recollection\",\"label\":\"10.\",\"sort\":100006,\"level\":3,\"section\":\"translation\",\"children\":[]},{\"uuid\":\"0c4e50d1-1bf1-43bd-8485-563d721df76a\",\"content\":\"Chapter 11: Māra’s Activity\",\"label\":\"11.\",\"sort\":110006,\"level\":3,\"section\":\"translation\",\"children\":[]},{\"uuid\":\"a9a09d98-9ffa-497f-8cc6-a2d2bd8c0d42\",\"content\":\"Chapter 12: Showing the World\",\"label\":\"12.\",\"sort\":120006,\"level\":3,\"section\":\"translation\",\"children\":[]},{\"uuid\":\"38e012c2-8f25-4d83-ab98-d484c31eb4bc\",\"content\":\"Chapter 13: The Inconceivable\",\"label\":\"13.\",\"sort\":130006,\"level\":3,\"section\":\"translation\",\"children\":[]},{\"uuid\":\"4dcb6eca-233f-44b9-9fef-ec68cb50c93a\",\"content\":\"Chapter 14: The Comparisons\",\"label\":\"14.\",\"sort\":140006,\"level\":3,\"section\":\"translation\",\"children\":[]},{\"uuid\":\"4f3a7eea-7e8c-4b83-86c7-4b8efd11f993\",\"content\":\"Chapter 15: The Gods\",\"label\":\"15.\",\"sort\":150006,\"level\":3,\"section\":\"translation\",\"children\":[]},{\"uuid\":\"11c55f65-626f-46f8-9570-4ed07ca1aef5\",\"content\":\"Chapter 16: The Actual Nature\",\"label\":\"16.\",\"sort\":160006,\"level\":3,\"section\":\"translation\",\"children\":[]},{\"uuid\":\"3da982be-f84e-46df-a7a5-81d27119a3ce\",\"content\":\"Chapter 17: The Attributes, Indications, and Signs of Those Beyond Regressing\",\"label\":\"17.\",\"sort\":170006,\"level\":3,\"section\":\"translation\",\"children\":[]},{\"uuid\":\"65d7db60-2258-44d1-82b5-a06088bec7f9\",\"content\":\"Chapter 18: Emptiness\",\"label\":\"18.\",\"sort\":180006,\"level\":3,\"section\":\"translation\",\"children\":[]},{\"uuid\":\"36f8e7b4-0bdb-4cc3-a5ca-3f1c047ed7c8\",\"content\":\"Chapter 19: The Noble Lady Gaṅgadevī\",\"label\":\"19.\",\"sort\":190006,\"level\":3,\"section\":\"translation\",\"children\":[]},{\"uuid\":\"7251f60e-cad8-4d0d-8684-b7af5ed144d1\",\"content\":\"Chapter 20: Examining Skill in Means\",\"label\":\"20.\",\"sort\":200006,\"level\":3,\"section\":\"translation\",\"children\":[]},{\"uuid\":\"3b01d61a-fcf4-4e6a-9f7b-7493daf922a1\",\"content\":\"Chapter 21: Detailing Māra’s Activities\",\"label\":\"21.\",\"sort\":210006,\"level\":3,\"section\":\"translation\",\"children\":[]},{\"uuid\":\"19b9722a-4e7f-4e43-9ec3-bcc8746973b7\",\"content\":\"Chapter 22: Virtuous Friends\",\"label\":\"22.\",\"sort\":220006,\"level\":3,\"section\":\"translation\",\"children\":[]},{\"uuid\":\"0fa43b0d-bccb-4508-a80f-8f41b6d8cd2d\",\"content\":\"Chapter 23: Śakra\",\"label\":\"23.\",\"sort\":230006,\"level\":3,\"section\":\"translation\",\"children\":[]},{\"uuid\":\"49473fd6-5f4d-429b-b711-52876d6ab790\",\"content\":\"Chapter 24: Conceitedness\",\"label\":\"24.\",\"sort\":240006,\"level\":3,\"section\":\"translation\",\"children\":[]},{\"uuid\":\"1c0a06eb-f21f-4093-bfec-d1326191b87e\",\"content\":\"Chapter 25: The Training\",\"label\":\"25.\",\"sort\":250006,\"level\":3,\"section\":\"translation\",\"children\":[]},{\"uuid\":\"c54d191c-c3e5-422d-8095-5d09b15b08a8\",\"content\":\"Chapter 26: The Magical Illusion\",\"label\":\"26.\",\"sort\":260006,\"level\":3,\"section\":\"translation\",\"children\":[]},{\"uuid\":\"452451a2-f746-4dd9-9b21-848bb77a989d\",\"content\":\"Chapter 27: The Essence\",\"label\":\"27.\",\"sort\":270006,\"level\":3,\"section\":\"translation\",\"children\":[]},{\"uuid\":\"4befd925-3e22-4da3-a5d7-c219823d76d2\",\"content\":\"Chapter 28: Avakīrṇakusuma\",\"label\":\"28.\",\"sort\":280006,\"level\":3,\"section\":\"translation\",\"children\":[]},{\"uuid\":\"c4ed1199-8c44-4169-a6c4-01ba1b69b12b\",\"content\":\"Chapter 29: The Approach\",\"label\":\"29.\",\"sort\":290006,\"level\":3,\"section\":\"translation\",\"children\":[]},{\"uuid\":\"0e1a7fc5-ba9d-4668-8cb3-e9f625fc0b9d\",\"content\":\"Chapter 30: Sadāprarudita\",\"label\":\"30.\",\"sort\":300006,\"level\":3,\"section\":\"translation\",\"children\":[]},{\"uuid\":\"e2b5fc07-5554-4f39-a639-ddb478c5fc81\",\"content\":\"Chapter 31: Dharmodgata\",\"label\":\"31.\",\"sort\":310006,\"level\":3,\"section\":\"translation\",\"children\":[]},{\"uuid\":\"04b4b796-1551-49b0-a593-9c40fe7dd220\",\"content\":\"Chapter 32: The Entrustment\",\"label\":\"32.\",\"sort\":320006,\"level\":3,\"section\":\"translation\",\"children\":[]},{\"uuid\":\"7b8f1db6-9360-46b4-9711-45d78a24012f\",\"content\":\"Colophon\",\"label\":\"c.\",\"sort\":330006,\"level\":3,\"section\":\"colophon\",\"children\":[{\"uuid\":\"7ced5c46-5b05-4cf8-9134-00e18b102cc1\",\"content\":\"Colophon from the Sanskrit\",\"label\":\"$undefined\",\"sort\":330007,\"level\":4,\"section\":\"colophon\",\"children\":[]},{\"uuid\":\"2dc4b091-f1fb-483f-be65-d223dc3cb905\",\"content\":\"Translators’ colophon from the Tibetan\",\"label\":\"$undefined\",\"sort\":330027,\"level\":4,\"section\":\"colophon\",\"children\":[]}]}]}],\"backMatter\":[{\"uuid\":\"974460f8-c3ee-47f4-b886-738d82d76787\",\"content\":\"Abbreviations\",\"label\":\"ab.\",\"sort\":1000006,\"level\":2,\"section\":\"abbreviations\",\"children\":[]},{\"uuid\":\"de25905b-998c-4b2c-a1b8-93fabe8e9d8c\",\"content\":\"Notes\",\"label\":\"n.\",\"sort\":1000050,\"level\":2,\"section\":\"endnotes\",\"children\":[]}]},\"work\":{\"uuid\":\"b43ac3f8-f616-4db3-a6ff-cbce4e6ad6dc\",\"title\":\"The Perfection of Wisdom in Eight Thousand Lines\",\"toh\":[\"toh12\"],\"publicationDate\":\"$D2026-02-06T00:00:00.000Z\",\"publicationVersion\":\"1.0.0\",\"pages\":570,\"restriction\":false,\"section\":\"Perfection of Wisdom\"}}]\n"])</script><div hidden id="S:3"><div dir="ltr" data-orientation="horizontal" data-slot="tabs" class="flex flex-col w-full gap-0 @container/sidebar"><div class="stick