པ་ནི་འདི་ལྟ་བུར་རིག་པར་\\nབྱ། བདུད་ཀྱི་ཉེས་པ་ནི་འདི་དག་ཡིན། བདུད་ཀྱི་ལས་ནི་འདི་དག་ཡིན་པར་རིག་པར་བྱ། བདུད་ཀྱི་ལས་འདི་དག་ཁྱེད་ཀྱིས་རྟོགས་ནས་སྤང་བར་བྱའོ་ཞེས་བྱ་བ་སྟེ། རབ་འབྱོར་འདི་དག་ནི་བྱང་ཆུབ་སེམས་དཔའ་སེམས་དཔའ་ཆེན་པོ་གོ་ཆ་ཆེན་པོ་བགོས་པ་ཐེག་པ་ཆེན་\\nཔོ་ལ་ཡང་དག་པར་ཞུགས་པ་ཐེག་པ་ཆེན་པོ་ལ་ཡང་དག་པར་གནས་པའི་དགེ་བའི་བཤེས་གཉེན་རྣམས་སུ་རིག་པར་བྱའོ། །\",\"folioNumber\":10,\"volumeNumber\":33}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":610,\"uuid\":\"b99297d5-0bf0-41cb-989e-32b8cd85ac2e\"},\"content\":[{\"type\":\"text\",\"text\":\"The \",\"attrs\":{\"start\":0,\"end\":4}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":4,\"end\":15},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7bf45dd5-3e8d-4495-bc65-ecf0a51d3597\",\"uuid\":\"9e9a9013-27ee-4cbc-b951-0eafa74a24e2\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\" said, “\",\"attrs\":{\"start\":15,\"end\":23}},{\"type\":\"text\",\"text\":\"Virtuous friends\",\"attrs\":{\"start\":23,\"end\":39},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cb1774cb-402d-465e-a33f-c45b2edb5bae\",\"uuid\":\"5ab0cc49-4d55-47e4-bb52-7593ddf862c7\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\" are those who instruct and guide a bodhisattva \",\"attrs\":{\"start\":39,\"end\":87}},{\"type\":\"text\",\"text\":\"great being\",\"attrs\":{\"start\":87,\"end\":98},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"be37efde-2f63-40d0-8e8e-e93b3b3a581e\",\"uuid\":\"ba196a79-794c-4cf9-a8bd-74145c59b690\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\" in the perfections and expound to him or her the activities of \",\"attrs\":{\"start\":98,\"end\":162}},{\"type\":\"text\",\"text\":\"Māra\",\"attrs\":{\"start\":162,\"end\":166},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cca61a77-75d5-4500-a990-23b3336c569d\",\"uuid\":\"d6c12d20-4572-443c-8be3-ddda6dfbadb0\",\"toh\":\"toh12\"}}]},{\"type\":\"text\",\"text\":\" like this