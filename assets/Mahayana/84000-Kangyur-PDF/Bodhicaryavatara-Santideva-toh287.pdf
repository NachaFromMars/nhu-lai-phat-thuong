"}},{\"uuid\":\"06246652-cd17-4520-8ccc-52da84a1863a\",\"authority\":\"944233c2-dd28-46ce-bcb6-ff6602282aad\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA sea to the north of \u003cspan data-glossary-id=\\\"UT22084-068-021-9338\\\"\u003eJambudvīpa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Garlands of Lightning\",\"tibetan\":\"གློག་གི་ཕྲེང་བ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"glog gi phreng ba\"}},{\"uuid\":\"ceb227ad-db0f-417e-88e2-fabbad65a95b\",\"authority\":\"ba7579fc-ce40-4ade-b704-5f7d033091cc\",\"definition\":\"\u003cp\u003eIn Indian mythology, the garuḍa is an eagle-like bird that is regarded as the king of all birds, normally depicted with a sharp, owl-like beak, often holding a snake, and with large and powerful wings. They are traditionally enemies of the nāgas. In the Vedas, they are said to have brought nectar from the heavens to earth. \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eGaruḍa\u003c/em\u003e can also be used as a proper name for a king of such creatures.\u003c/p\u003e\",\"names\":{\"english\":\"garuḍa\",\"tibetan\":\"ནམ་མཁའ་ལྡིང་།\",\"sanskrit\":\"garuḍa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nam mkha’ lding\"}},{\"uuid\":\"292bd234-d0ca-4097-ab4d-99b6548b74e2\",\"authority\":\"b3269025-dc5d-4e74-aef4-346918e0d8d6\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn area in \u003cspan data-glossary-id=\\\"UT22084-068-021-9398\\\"\u003eKuru\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Gathered\",\"tibetan\":\"ཚོགས་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"tshogs pa\"}},{\"uuid\":\"06065a04-f338-4331-bceb-5fd705891843\",\"authority\":\"ba26b603-eaa9-43b0-bd37-1004d16a0adf\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAppellation for the Buddha, primarily used by \u003cspan data-glossary-id=\\\"UT22084-068-021-8567\\\"\u003enon-Buddhists\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Gautama\",\"tibetan\":\"གཽ་ཏ་མ།\",\"sanskrit\":\"gautama\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gau ta ma\"}},{\"uuid\":\"0b4d17d9-00ba-4362-a099-ba31e8d3fb01\",\"authority\":\"270d430e-3e03-4d5d-9b3d-0794a22e8d59\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA river on \u003cspan data-glossary-id=\\\"UT22084-068-021-9825\\\"\u003eUttara\u003c/span\u003e Mountain.\u003c/p\u003e\",\"names\":{\"english\":\"Giver of Stones\",\"tibetan\":\"རྡོ་སྦྱིན་པར་བྱེད་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rdo sbyin par byed pa\"}},{\"uuid\":\"48c4b503-a64b-4e40-b3af-e7d46b2bce09\",\"authority\":\"7b117350-4cbb-4986-9d34-f231da6ac873\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA mountain range surrounding the hell of \u003cspan data-glossary-id=\\\"UT22084-068-021-9043\\\"\u003eEmbers Within\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Glowing Hot Embers\",\"tibetan\":\"མེ་མདག་ཚ་བ།\",\"sanskrit\":\"rūkṣāṅgāra­nibha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"me mdag tsha ba\"}},{\"uuid\":\"001a0a5f-1d64-4686-98cb-d50f70cca517\",\"authority\":\"87f6ed5d-68a9-4ddd-8744-81855f2d8943\",\"definition\":\"$4b\",\"names\":{\"english\":\"god\",\"tibetan\":\"ལྷ།\",\"sanskrit\":\"deva\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lha\"}},{\"uuid\":\"8b6d8b7b-2b27-4edd-9145-c1acaa70d4aa\",\"authority\":\"25bde7a7-efc5-47e6-a034-bb5d24d69839\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe continent to the west of Mount \u003cspan data-glossary-id=\\\"UT22084-068-021-9739\\\"\u003eSumeru\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Godānīya\",\"tibetan\":\"བ་ལང་སྤྱོད།\",\"sanskrit\":\"godānīya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ba lang spyod\"}},{\"uuid\":\"dad6145c-0143-4fb9-977f-fb00e0377ac7\",\"authority\":\"15c269c1-1be6-4592-953f-f49ff24d1c2f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA river in the south of \u003cspan data-glossary-id=\\\"UT22084-068-021-9338\\\"\u003eJambudv