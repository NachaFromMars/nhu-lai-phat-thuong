rbal misdeeds.\u003c/p\u003e\",\"names\":{\"english\":\"lying\",\"tibetan\":\"རྫུན་དུ་སྨྲ་བ།\",\"sanskrit\":\"mṛṣā­vāda\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rdzun du smra ba\"}},{\"uuid\":\"23211661-2eca-4827-b6a7-6a7af55f7c02\",\"authority\":\"c566f793-4833-4f9c-b2d0-0e1ce155e114\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA land in the south of \u003cspan data-glossary-id=\\\"UT22084-068-021-9338\\\"\u003eJambudvīpa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Madrā\",\"tibetan\":\"མ་དྲཱ།\",\"sanskrit\":\"madrā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ma drA\"}},{\"uuid\":\"cf08ee1f-e77c-4a13-b08a-f040e67b81fb\",\"authority\":\"e11f1f00-f1f1-4768-9f49-fee0c101304e\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA peak upon Mount \u003cspan data-glossary-id=\\\"UT22084-068-021-9739\\\"\u003eSumeru\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Madtakaṭama\",\"tibetan\":\"མད་ཏ་ཀ་ཊ་མ།\",\"sanskrit\":\"madtakaṭama\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mad ta ka Ta ma\"}},{\"uuid\":\"6009bd60-d95a-407a-a59e-f556ec44614f\",\"authority\":\"75a8c2f7-587c-47e2-a290-0f91ef57d6e2\",\"definition\":\"$4f\",\"names\":{\"english\":\"Magadha\",\"tibetan\":\"མ་ག་དྷཱ།\",\"sanskrit\":\"magadha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ma ga dhA\"}},{\"uuid\":\"69f474dd-b4c3-4a71-8bfd-c3d90d47c194\",\"authority\":\"dabd666d-3f65-4af6-877f-3b87108db283\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn epithet of Śiva.\u003c/p\u003e\",\"names\":{\"english\":\"Mahādeva\",\"tibetan\":\"ལྷ་ཆེན་པོ།\",\"sanskrit\":\"mahādeva\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lha chen po\"}},{\"uuid\":\"d77643b2-2f79-4c1c-ab03-9941e6dee0f3\",\"authority\":\"44457ceb-d84a-408e-a9b3-bfc1e99bac24\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eLiterally “lord,” this term is an epithet for the \u003cspan data-glossary-id=\\\"UT22084-068-021-8531\\\"\u003egod\u003c/span\u003e Śiva, but functions more generally in Buddhist texts as a generalized “supreme being” to whom the creation of the universe is attributed.\u003c/p\u003e\",\"names\":{\"english\":\"Maheśvara, Īśvara\",\"tibetan\":\"དབང་ཕྱུག, དབང་ཕྱུག་ཆེན་པོ།\",\"sanskrit\":\"maheśvara, īśvara\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dbang phyug, dbang phyug chen po\"}},{\"uuid\":\"492db183-b469-4056-a2c7-840f2a3b8e1d\",\"authority\":\"44457ceb-d84a-408e-a9b3-bfc1e99bac24\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAnother name for the \u003cspan data-glossary-id=\\\"UT22084-068-021-8531\\\"\u003egod\u003c/span\u003e Śiva.\u003c/p\u003e\",\"names\":{\"english\":\"Maheśvara, Īśvara\",\"tibetan\":\"དབང་ཕྱུག, དབང་ཕྱུག་ཆེན་པོ།\",\"sanskrit\":\"maheśvara, īśvara\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dbang phyug, dbang phyug chen po\"}},{\"uuid\":\"0b1f57e7-ea4c-4276-9feb-ac5f4be0c6aa\",\"authority\":\"264cb1c5-55ba-45d8-bc1d-9fda42330693\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA land to the north of \u003cspan data-glossary-id=\\\"UT22084-068-021-9338\\\"\u003eJambudvīpa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Mahikṣikā\",\"tibetan\":\"མ་ཧི་ཥཱི་ཀཱ།\",\"sanskrit\":\"mahikṣikā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ma hi ShI kA\"}},{\"uuid\":\"1e7a4db5-55f0-4aa5-9687-a6dc58721575\",\"authority\":\"eb1c6fc0-d2f8-4d3e-8fad-825f71769dd7\",\"definition\":\"\u003cp\u003eLiterally “great serpents,” mahoragas are supernatural beings depicted as large, subterranean beings with human torsos and heads and the lower bodies of serpents. Their movements are said to cause earthquakes, and they make up a class of subterranean geomantic spirits whose movement through the seasons and months of the year is deemed significant for construction projects.\u003c/p\u003e\",\"names\":{\"english\":\"mahoraga\",\"tibetan\":\"ལྟོ་འཕྱེ་ཆེན་པོ།\",\"sanskrit\":\"mahoraga\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lto ’phye chen po\"}},{\"uuid\":\"478983bd-1f03-4a1a-a6e0-c5bb1bc8582e\",\"authority\":\"cdfb8e4f-6d68-4c38-a3c5-5bd8897f3897\",\"definition\":\"$50\",\"names\":{\"english\":\"Maitreya\",\"tibetan\":\"བྱམས་པ།\",\"sanskrit\":\"maitreya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"byams pa\"}},{\"uuid\":\"e0133a81-a3ee-412d-b012-b099286c29aa\",\"authority\":\"86cf4810-dfd5-4b50-86bf-3114ddfa7007\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA forest at \u003cspan data-glossary-id=\\\"UT22084-068-021-9673\\\"\u003eShining Jewel Light\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Majestic Trees\",\"tibetan\":\"ཤིང་འགྱིང་བ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shing ’gying ba\"}},{\"uuid\":\"35027c89-a863-4edd-98a6-53d1d1266be7\",\"authority\":\"d4528f8a-6414-403c-bba8-a12ebcc0ad16\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA place in \u003cspan data-glossary-id=\\\"UT22084-068-021-9279\\\"\u003eUltimate Torment\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Making the Hair of All Beings Stand on End\",\"tibetan\":\"སེམས་ཅན་ཐམས་ཅད་སྤུ་ཟིང་།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sems can thams cad spu zing\"}},{\"uuid\":\"a50078ab-0efc-4acd-a012-147dc70d1023\",\"authority\":\"bedd273a-2f9f-4490-beee-ba23696dae85\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA class of \u003cspan data-glossary-id=\\\"UT22084-068-021-8622\\\"\u003evidyādharas\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"mākṣāḍa\",\"tibetan\":\"མཱ་ཥཱ་ཌ།\",\"sanskrit\":\"mākṣāḍa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mA ShA Da\"}},{\"uuid\":\"cdca17d8-1369-4996-8b3f-c306c15af834\",\"authority\":\"3eb31c54-a502-4293-9020-d64e76995d44\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA class of \u003cspan data-glossary-id=\\\"UT22084-068-021-8622\\\"\u003evidyādharas\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Malaya dweller\",\"tibetan\":\"མ་ལ་ཡ་གནས་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ma la ya gnas pa\"}},{\"uuid\":\"fb7c1a26-6346-4bed-b5e6-72a1a878a5d7\",\"authority\":\"b693b673-66cb-43e8-a843-ffeb90866512\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA mountain in the south of \u003cspan data-glossary-id=\\\"UT22084-068-021-9338\\\"\u003eJambudvīpa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Malaya, Malaya Mountains\",\"tibetan\":\"མ་ལ་ཡ།, རི་མ་ལ་ཡ།\",\"sanskrit\":\"malaya, malayagiri\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ma la ya, ri ma la ya\"}},{\"uuid\":\"8f7bff6a-d3c3-4b63-b0f6-059d39acda75\",\"authority\":\"b693b673-66cb-43e8-a843-ffeb90866512\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA mountain range in \u003cspan data-glossary-id=\\\"UT22084-068-021-9338\\\"\u003eJambudvīpa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Malaya, Malaya Mountains\",\"tibetan\":\"མ་ལ་ཡ།, རི་མ་ལ་ཡ།\",\"sanskrit\":\"malaya, malayagiri\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ma la ya, ri ma la ya\"}},{\"uuid\":\"48449b7a-3d1c-4800-8f8d-c0dfd878154f\",\"authority\":\"5185bf23-a137-488a-ae7a-833d7d082bd0\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn island in the vicinity of \u003cspan data-glossary-id=\\\"UT22084-068-021-9338\\\"\u003eJambudvīpa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Mālikā\",\"tibetan\":\"མཱ་ལི་ཀཱ་གླིང་།\",\"sanskrit\":\"mālikā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mA li kA gling\"}},{\"uuid\":\"7acd55f6-3e92-4658-9b8a-23a131ba4255\",\"authority\":\"84813af9-a26f-4b8c-8980-8f24096a1514\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA forest on \u003cspan data-glossary-id=\\\"UT22084-068-021-9241\\\"\u003eGreat Slope\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Mālikagaṅkara Forest\",\"tibetan\":\"མཱ་ལི་ཀ་གངྐ་རའི་ནགས།\",\"sanskrit\":\"mālikagaṅkara\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mA li ka gang+ka ra’i nags\"}},{\"uuid\":\"a2443a26-92ae-4e4f-838c-6619d37bd72e\",\"authority\":\"c0993902-b30e-4ded-91af-41191f34aa2b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-068-021-8581\\\"\u003erākṣasī\u003c/span\u003e living on \u003cspan data-glossary-id=\\\"UT22084-068-021-8813\\\"\u003eArdhamaru\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Mānadehā\",\"tibetan\":\"མཱན་དེ་ཧཱ།\",\"sanskrit\":\"mānadehā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mAn de hA\"}},{\"uuid\":\"8f9565d3-0b26-4df0-b3d5-b30d88392e86\",\"authority\":\"cc6cf88e-b5d4-4cf7-afa5-ba801326c8ea\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eCity in the \u003cspan data-glossary-id=\\\"UT22084-068-021-9269\\\"\u003eHeaven of Joy\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Mānasaṅkalpa\",\"tibetan\":\"ཡིད་ཀྱིས་བརྟགས་པ།\",\"sanskrit\":\"mānasaṅkalpa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yid kyis brtags pa\"}},{\"uuid\":\"bf5ffa70-bca8-4ac1-9f1a-cae886cbd063\",\"authority\":\"10174fa2-c555-44ee-81c3-1a8c498a9fcd\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA lake in \u003cspan data-glossary-id=\\\"UT22084-068-021-9338\\\"\u003eJambudvīpa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Mānasarovara\",\"tibetan\":\"མ་ཕམ།\",\"sanskrit\":\"mānasarovara\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ma pham\"}},{\"uuid\":\"7f1bc107-5ac8-4980-ab0c-7f52f195dd70\",\"authority\":\"60d691b5-d2a9-47ae-815b-e62968b7978e\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA forest on \u003cspan data-glossary-id=\\\"UT22084-068-021-9128\\\"\u003eFlocking Peacocks\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Maṇḍala\",\"tibetan\":\"མཎྜལཾ།\",\"sanskrit\":\"maṇḍala\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"maN+DalaM\"}},{\"uuid\":\"afd80c4d-047d-4ee1-b710-fbe85b6b1761\",\"authority\":\"54e7495d-44dc-464f-b9dd-ea59649da018\",\"definition\":\"\u003cp\u003eOne of the five trees of Indra’s paradise, its heavenly flowers often rain down in salutation of the buddhas and bodhisattvas and are said to be very bright and aromatic, gladdening the hearts of those who see them. In our world, it is a tree native to India, \u003cem class=\\\"foreign\\\"\u003eErythrina indica\u003c/em\u003e or \u003cem class=\\\"foreign\\\"\u003eErythrina variegata\u003c/em\u003e, commonly known as the Indian coral tree, mandarava tree, flame tree, and tiger’s claw. In the early spring, before its leaves grow, the tree is fully covered in large flowers, which are rich in nectar and attract many birds. Although the most widespread coral tree has red crimson flowers, the color of the blossoms is not usually mentioned in the sūtras themselves, and it may refer to some other kinds, like the rarer \u003cem class=\\\"foreign\\\"\u003eErythrina indica alba\u003c/em\u003e, which boasts white flowers.\u003c/p\u003e\",\"names\":{\"english\":\"mandārava\",\"tibetan\":\"མན་དཱ་ར་བ།\",\"sanskrit\":\"mandārava\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"man dA ra ba\"}},{\"uuid\":\"8152559b-d070-40e5-bacd-cfd12f6dc574\",\"authority\":\"1854a2c0-3072-4be8-9670-373d3263af5f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA forest in \u003cspan data-glossary-id=\\\"UT22084-068-021-9513\\\"\u003eMoving Mind\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Mandārava Forest\",\"tibetan\":\"མེ་ཏོག་མན་དཱ་ར་བའི་ཚལ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"me tog man dA ra ba’i tshal\"}},{\"uuid\":\"63721b5d-fdc4-4776-828b-253957e9de62\",\"authority\":\"d2c5fd5e-eeea-4f30-b672-2308ca49e25d\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-068-021-8581\\\"\u003erākṣasī\u003c/span\u003e living in \u003cspan\u003e\u003cspan data-glossary-id=\\\"UT22084-068-021-8862\\\"\u003eBlue Waters\u003c/span\u003e\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Mandehā\",\"tibetan\":\"མན་དེ་ཧ།\",\"sanskrit\":\"mandehā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"man de ha\"}},{\"uuid\":\"6c7892ae-49ba-4028-907e-119344ced8f9\",\"authority\":\"293c3b70-6574-44d4-8f4a-6cef4418e3a5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e(1) A powerful king whose good deeds lent splendor to the \u003cspan data-glossary-id=\\\"UT22084-068-021-9584\\\"\u003ePleasure Grove Park\u003c/span\u003e. (2) A universal monarch.\u003c/p\u003e\",\"names\":{\"english\":\"Māndhāta\",\"tibetan\":\"ང་ལས་ནུ།\",\"sanskrit\":\"māndhāta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nga las nu\"}},{\"uuid\":\"d6f71c61-9391-4d6e-8ffa-c319aec86f6f\",\"authority\":\"25e40c69-7ee8-4035-ab69-416df467f1d4\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA queen of \u003cspan data-glossary-id=\\\"UT22084-068-021-8731\\\"\u003eRāhu\u003c/span\u003e, king of \u003cspan data-glossary-id=\\\"UT22084-068-021-8489\\\"\u003easuras\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Maṅgalā\",\"tibetan\":\"བཀྲ་ཤིས་མ།\",\"sanskrit\":\"maṅgalā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bkra shis ma\"}},{\"uuid\":\"67197407-c29e-43ce-988d-6ea39c66b554\",\"authority\":\"c466f725-d6af-4a57-bfb3-ca5e0c37e98c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA mountain range surrounding the hell of \u003cspan data-glossary-id=\\\"UT22084-068-021-9043\\\"\u003eEmbers Within\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Manifest Karmic Action\",\"tibetan\":\"ལས་མངོན་སུམ།\",\"sanskrit\":\"karmasākṣin\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"las mngon sum\"}},{\"uuid\":\"6643cf9c-da10-4c9b-984a-d6c3a71badae\",\"authority\":\"97aafe8b-3ef1-48ea-a8ec-a2ede6092567\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA forest in \u003cspan data-glossary-id=\\\"UT22084-068-021-9417\\\"\u003eLiving on the Peak\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Manifold Chariots\",\"tibetan\":\"ཤིང་རྟ་སྣ་ཚོགས་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shing rta sna tshogs pa\"}},{\"uuid\":\"b8bb81b5-c0e7-4736-aefa-811ac138394d\",\"authority\":\"320c5523-4cde-4365-aeb1-3e69be9b0e42\",\"definition\":\"\u003cp\u003eMañjuśrī is one of the “eight close sons of the Buddha” and a bodhisattva who embodies wisdom. He is a major figure in the Mahāyāna sūtras, appearing often as an interlocutor of the Buddha. In his most well-known iconographic form, he is portrayed bearing the sword of wisdom in his right hand and a volume of the \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003ePrajñā­pāramitā­sūtra\u003c/cite\u003e in his left. To his name, Mañjuśrī, meaning “Gentle and Glorious One,” is often added the epithet Kumārabhūta, “having a youthful form.” He is also called Mañjughoṣa, Mañjusvara, and Pañcaśikha.\u003c/p\u003e\",\"names\":{\"english\":\"Mañjuśrī\",\"tibetan\":\"འཇམ་དཔལ།\",\"sanskrit\":\"mañjuśrī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’jam dpal\"}},{\"uuid\":\"afc4ebec-4e96-44c8-8ad0-a5a56071db25\",\"authority\":\"896c9325-03fc-43d3-b17f-32e53fe8faf3\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA mansion in \u003cspan data-glossary-id=\\\"UT22084-068-021-9734\\\"\u003eSudharma\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Mansion of Great Joy\",\"tibetan\":\"ཁང་བཟངས་རབ་ཏུ་དགའ་བར་གནས་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"khang bzangs rab tu dga’ bar gnas pa\"}},{\"uuid\":\"2082c93b-a97d-4661-9d3b-aee0ed86447b\",\"authority\":\"e02fc98c-0e0f-4725-b94d-5518b7c1f0c0\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA mansion within one of the trees in \u003cspan data-glossary-id=\\\"UT22084-068-021-9547\\\"\u003ePair of Śāla Trees\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Mansion of the Mirror of Karmic Actions\",\"tibetan\":\"མེ་ལོང་གི་ཁང་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"me long gi khang pa\"}},{\"uuid\":\"be33ec74-6b07-494d-b35c-c7fde200b8ac\",\"authority\":\"1f2c5cff-2505-474f-a76d-38701fb52951\",\"definition\":\"$51\",\"names\":{\"english\":\"māra\",\"tibetan\":\"བདུད།\",\"sanskrit\":\"māra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bdud\"}},{\"uuid\":\"d0dcc2b9-18f5-48c0-b606-6a658208ebae\",\"authority\":\"de5a7181-e25d-415f-82d7-9820f01578e0\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne among the twelve sections of scripture.\u003c/p\u003e\",\"names\":{\"english\":\"marvels\",\"tibetan\":\"རྨད་དུ་བྱུང་བའི་སྡེ།\",\"sanskrit\":\"adbhutadharma\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rmad du byung ba’i sde\"}},{\"uuid\":\"6dbef67d-afe5-443c-9e7c-08386a3c5b2a\",\"authority\":\"1b3bcf87-018b-4386-81ee-7f07ff6836c1\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA river in the realm of the \u003cspan data-glossary-id=\\\"UT22084-068-021-8531\\\"\u003egods\u003c/span\u003e in \u003cspan data-glossary-id=\\\"UT22084-068-021-9035\\\"\u003eDwelling on Summits\u003c/span\u003e within the \u003cspan data-glossary-id=\\\"UT22084-068-021-9276\\\"\u003eHeaven of the Thirty-Three\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Massaged and Touched with the Palm of the Hand\",\"tibetan\":\"ལག་མཐིལ་གྱིས་བྱུག་ཅིང་རེག་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lag mthil gyis byug cing reg pa\"}},{\"uuid\":\"6d10c1c9-c879-41b9-bfb7-524ecb3f6d80\",\"authority\":\"f9dfe605-95d2-4650-bdad-ea80741bb07e\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the sixteen realms that surround the \u003cspan\u003e\u003cspan data-glossary-id=\\\"UT22084-068-021-9277\\\"\u003eHell of Heat\u003c/span\u003e\u003c/span\u003e. \u003c/p\u003e\",\"names\":{\"english\":\"Masses of Vajra-Like Bones\",\"tibetan\":\"རུས་པ་རྡོ་རྗེ་ལྟ་བུ་འབྱུང་།\",\"sanskrit\":\"vajrāsthi­patana­sampāta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rus pa rdo rje lta bu ’byung\"}},{\"uuid\":\"84b76845-d969-4b3b-8875-99ab6c4b157b\",\"authority\":\"7959beb6-ed2d-4c22-be60-cc19949b1d17\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA grove in \u003cspan data-glossary-id=\\\"UT22084-068-021-9752\\\"\u003eSupreme Splendor\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Matala\",\"tibetan\":\"མ་ཏ་ལ།\",\"sanskrit\":\"matala\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ma ta la\"}},{\"uuid\":\"cd15cec2-3d4a-4b5d-b7fa-a985ba4742c7\",\"authority\":\"8d014b13-630b-4d5c-ae2c-0d0926d55175\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-068-021-8738\\\"\u003eŚakra\u003c/span\u003e’s elephant driver.\u003c/p\u003e\",\"names\":{\"english\":\"Mātali\",\"tibetan\":\"མ་ཏ་ལི།\",\"sanskrit\":\"mātali\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ma ta li\"}},{\"uuid\":\"4539b2cd-7eb2-408c-a237-13f851ed7e37\",\"authority\":\"70f822a5-7a1a-4607-a887-56a5db08dc6c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA mountain in \u003cspan data-glossary-id=\\\"UT22084-068-021-9338\\\"\u003eJambudvīpa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Meghalati\",\"tibetan\":\"མེ་གྷ་ལ་ཏི།\",\"sanskrit\":\"meghalati\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"me g+ha la ti\"}},{\"uuid\":\"2fb5c95c-5369-4fbb-9234-026295882568\",\"authority\":\"e1ac575f-dba1-427d-9355-da8d477b0d71\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA virtuous \u003cspan data-glossary-id=\\\"UT22084-068-021-8562\\\"\u003enāga\u003c/span\u003e king. \u003c/p\u003e\",\"names\":{\"english\":\"Meghamālin\",\"tibetan\":\"སྤྲིན་ཕྲེང་།, སྤྲིན་ཕྲེང་ཅན།\",\"sanskrit\":\"meghamālin\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sprin phreng, sprin phreng can\"}},{\"uuid\":\"5115e735-0440-4084-a1b9-75a56a1fe0f2\",\"authority\":\"f8eaf93b-11fb-4729-8050-e8e75e830875\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn island in the vicinity of \u003cspan data-glossary-id=\\\"UT22084-068-021-9338\\\"\u003eJambudvīpa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Mekala Source\",\"tibetan\":\"མེ་ཀ་ལ་འབྱུང་བ།\",\"sanskrit\":\"mekala\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"me ka la ’byung ba\"}},{\"uuid\":\"1e6e9f0e-c465-4016-826e-a39a24df106e\",\"authority\":\"6b41d2d2-5689-4ac5-a560-6d09616a3632\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA land in the south of \u003cspan data-glossary-id=\\\"UT22084-068-021-9338\\\"\u003eJambudvīpa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Melako\",\"tibetan\":\"མེ་ལ་ཀོ\",\"sanskrit\":\"melako\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"me la ko\"}},{\"uuid\":\"a867dd71-2e7d-4fa7-b425-a5ab88c85c7f\",\"authority\":\"12bc0c1d-9915-4dd1-8dcf-0dc0f9b3709c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA river on \u003cspan data-glossary-id=\\\"UT22084-068-021-9657\\\"\u003eSaṅkāśa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Melodious\",\"tibetan\":\"དབྱངས་སྙན་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dbyangs snyan pa\"}},{\"uuid\":\"aca274a6-9baf-4b88-8416-2b5930d2ffbb\",\"authority\":\"ad5b8d6b-1b80-4280-981d-459c00887f51\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA location in \u003cspan data-glossary-id=\\\"UT22084-068-021-9519\\\"\u003eMutual Liking\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Melodious Experience\",\"tibetan\":\"སྙན་པ་སྤྱོད་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"snyan pa spyod pa\"}},{\"uuid\":\"02bd7ac1-47d5-418a-80ad-998f2aa21c76\",\"authority\":\"fd818933-2312-40de-a844-833c9c8df93d\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn ordained Buddhist practitioner. Pairs often with \u003cspan data-glossary-id=\\\"UT22084-068-021-8491\\\"\u003ebrahmin\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"mendicant\",\"tibetan\":\"དགེ་སྦྱོང་།\",\"sanskrit\":\"śramaṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dge sbyong\"}},{\"uuid\":\"23f3da2a-72ec-4ffe-a3f6-0b66dbe9d18f\",\"authority\":\"94abea97-e08e-42b5-8572-1a426431c53e\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe monastic procedure for confession of misdeeds and the restoration of vows.\u003c/p\u003e\",\"names\":{\"english\":\"mending ritual\",\"tibetan\":\"གསོ་སྦྱོང་།\",\"sanskrit\":\"poṣadha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gso sbyong\"}},{\"uuid\":\"e6d35472-9267-48b9-864f-d9312dd65121\",\"authority\":\"bb3ccfb0-101d-40ea-8800-c4f27176fae2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA mountain to the north of \u003cspan data-glossary-id=\\\"UT22084-068-021-9338\\\"\u003eJambudvīpa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Menko\",\"tibetan\":\"མེན་ཀོ\",\"sanskrit\":\"menko\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"men ko\"}},{\"uuid\":\"7b35c64c-1a8a-4ff3-8a8e-62ddd8230adc\",\"authority\":\"0136e0b1-a9e3-4299-ac03-5901991dc0e9\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA land in \u003cspan data-glossary-id=\\\"UT22084-068-021-9209\\\"\u003eGodānīya\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Mental Stain\",\"tibetan\":\"སེམས་ཀྱི་དྲི་མ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sems kyi dri ma\"}},{\"uuid\":\"f00b0ece-b052-4c8e-a9b0-dfd6c372359e\",\"authority\":\"779426cd-002a-43d1-9edc-2c0d17b8084b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA grove in the forest known as \u003cspan\u003e\u003cspan data-glossary-id=\\\"UT22084-068-021-9310\\\"\u003eIncomparable\u003c/span\u003e\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Merging\",\"tibetan\":\"འདྲེས་པའི་ཚལ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’dres pa’i tshal\"}},{\"uuid\":\"badea4b7-0223-4bcd-a5c3-f7872755d6c6\",\"authority\":\"2b9972fd-0a7b-4371-872f-1ac4a537fea2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn area to the west of \u003cspan data-glossary-id=\\\"UT22084-068-021-9338\\\"\u003eJambudvīpa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Merging of the Sindhū and the Sea\",\"tibetan\":\"སིནྡྷུ་དང་རྒྱ་མཚོ་གཉིས་འདྲེ་བ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sin+d+hu dang rgya mtsho gnyis ’dre ba\"}},{\"uuid\":\"eaa9aab0-8f8b-4cc2-8c4d-d8cec3c0ba51\",\"authority\":\"3911d5