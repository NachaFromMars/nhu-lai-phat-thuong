dae-483f-b15b-b44e891d79d7\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA pond in \u003cspan data-glossary-id=\\\"UT22084-068-021-8956\\\"\u003eContinuous Movement\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Water That One Never Tires Of\",\"tibetan\":\"ངོམས་པ་མེད་པའི་ཆུ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ngoms pa med pa’i chu\"}},{\"uuid\":\"5276714e-5708-4cc6-bb8f-e205628b98bd\",\"authority\":\"6a597e57-d09c-4fd0-8947-7e1a8251f433\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA lake on \u003cspan data-glossary-id=\\\"UT22084-068-021-9078\\\"\u003eEqual Peaks\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Waters Always Mingled with the Moon\",\"tibetan\":\"རྟག་ཏུ་ཟླ་བ་དང་འདྲེས་པའི་ཆུ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rtag tu zla ba dang ’dres pa’i chu\"}},{\"uuid\":\"fde8faa8-43b3-4d6e-92de-97f866be0f90\",\"authority\":\"83a9ec9f-2774-4ebe-95ff-b92121765899\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn ocean far off the coast of \u003cspan data-glossary-id=\\\"UT22084-068-021-9338\\\"\u003eJambudvīpa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Waves of the Seas of Jambudvīpa\",\"tibetan\":\"འཛམ་བུའི་གླིང་གི་རྒྱ་མཚོའི་རླབས།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’dzam bu’i gling gi rgya mtsho’i rlabs\"}},{\"uuid\":\"a82dfe9e-1893-433e-8bf5-1674ef2f50ab\",\"authority\":\"93977eab-3edc-4ed2-908e-4d375b6feee5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e(1) A lake on \u003cspan data-glossary-id=\\\"UT22084-068-021-9078\\\"\u003eEqual Peaks\u003c/span\u003e (\u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003erlabs rab tu ’jug pa\u003c/em\u003e). (2) A river to the south of \u003cspan data-glossary-id=\\\"UT22084-068-021-9338\\\"\u003eJambudvīpa\u003c/span\u003e (\u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003erlabs ldan\u003c/em\u003e). (3) A river on \u003cspan data-glossary-id=\\\"UT22084-068-021-9657\\\"\u003eSaṅkāśa\u003c/span\u003e (\u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003erlabs ’byung ba\u003c/em\u003e).\u003c/p\u003e\",\"names\":{\"english\":\"Wavy\",\"tibetan\":\"རླབས་འབྱུང་བ།, རླབས་རབ་ཏུ་འཇུག་པ།, རླབས་ལྡན།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rlabs ldan, rlabs rab tu ’jug pa, rlabs ’byung ba\"}},{\"uuid\":\"d882b417-ed09-40d5-8495-272f37e18892\",\"authority\":\"7c9a35a9-4eb4-4f7a-bac1-4734e8568dbe\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA mountain between \u003cspan data-glossary-id=\\\"UT22084-068-021-9398\\\"\u003eKuru\u003c/span\u003e and \u003cspan data-glossary-id=\\\"UT22084-068-021-9209\\\"\u003eGodānīya\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Well-Consumed\",\"tibetan\":\"ལེགས་པར་ཟོས་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"legs par zos pa\"}},{\"uuid\":\"acdf373f-9e69-4448-b086-15d140b4c33d\",\"authority\":\"f587ae96-d53d-49c4-b280-5980da9456e0\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the seven golden mountains that surround Mount \u003cspan data-glossary-id=\\\"UT22084-068-021-9739\\\"\u003eSumeru\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Well-Endowed\",\"tibetan\":\"རབ་སྦྱོར།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rab sbyor\"}},{\"uuid\":\"5763e542-6c29-456b-b615-8af8550f1dfc\",\"authority\":\"e0c895bf-68db-4a04-be1e-98983ced51ee\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn epithet of the buddhas meaning “one who has gone to bliss.” The Sanskrit term literally means “faring well.”\u003c/p\u003e\",\"names\":{\"english\":\"well-gone one\",\"tibetan\":\"བདེ་བར་གཤེགས་པ།\",\"sanskrit\":\"sugata\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bde bar gshegs pa\"}},{\"uuid\":\"fc27bc24-cdbe-4071-85dd-3f64ce29fc49\",\"authority\":\"7137f9a2-024d-4bde-90a2-a07062fafb40\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA previous ruler of the \u003cspan data-glossary-id=\\\"UT22084-068-021-9276\\\"\u003eHeaven of the Thirty-Three\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"White\",\"tibetan\":\"དཀར་པོ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dkar po\"}},{\"uuid\":\"863f4eaf-9553-4490-aa08-c3c579b9da31\",\"authority\":\"ae0ee761-ea01-4f8c-a842-11d5a53c6b95\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA realm of the \u003cspan data-glossary-id=\\\"UT22084-068-021-8617\\\"\u003etriple-lute-bearer gods\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"White Body\",\"tibetan\":\"ལུས་དཀར།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lus dkar\"}},{\"uuid\":\"adfff97b-888b-48b0-8235-a928e35463dd\",\"authority\":\"9f2d5d16-584d-4bdd-bead-72724d906238\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA forest on \u003cspan data-glossary-id=\\\"UT22084-068-021-9657\\\"\u003eSaṅkāśa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"White Cloud\",\"tibetan\":\"སྤྲིན་དཀར་པོ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sprin dkar po\"}},{\"uuid\":\"c7e56661-2c0e-40c7-9ac0-5f0f252168ca\",\"authority\":\"d7c17fa2-e709-4d34-8ee5-39688e3312e3\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA mountain in \u003cspan data-glossary-id=\\\"UT22084-068-021-9398\\\"\u003eKuru\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"White Cloud Keeper\",\"tibetan\":\"སྤྲིན་དཀར་པོ་འཛིན་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sprin dkar po ’dzin pa\"}},{\"uuid\":\"74002374-68df-4117-a708-c91304ad64cb\",\"authority\":\"1e83326b-0d1e-4b14-8253-7f2c45c97472\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA lake in \u003cspan data-glossary-id=\\\"UT22084-068-021-9209\\\"\u003eGodānīya\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"White Gambhīra\",\"tibetan\":\"གམ་བྷི་རོ་དཀར།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gam bhi ro dkar\"}},{\"uuid\":\"efad7f47-72fe-4d65-a542-3844cd7939bb\",\"authority\":\"f26592d6-19e8-4563-aa87-cc7c3e3ed8c5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA peak on \u003cspan data-glossary-id=\\\"UT22084-068-021-9739\\\"\u003eSumeru\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"White Water\",\"tibetan\":\"ཆུ་དཀར།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chu dkar\"}},{\"uuid\":\"3b3be5b7-c257-4d34-8363-f98d11564ab4\",\"authority\":\"ee8b74d8-4487-4e97-92ba-59a66d071a28\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA river on \u003cspan data-glossary-id=\\\"UT22084-068-021-8989\\\"\u003eDeer Abode\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Wild Water\",\"tibetan\":\"ཤིན་ཏུ་གྲོལ་བར་གྱུར་པའི་ཆུ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shin tu grol bar gyur pa’i chu\"}},{\"uuid\":\"fc8a014a-35db-4927-8cc5-f06aa5f723ed\",\"authority\":\"4bdee805-da9c-4626-a02a-86b5851bae4b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the four \u003cspan data-glossary-id=\\\"UT22084-068-021-9921\\\"\u003eelements\u003c/span\u003e that constitute all matter, or one of the three primary humors (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003edoṣa\u003c/em\u003e) of the body.\u003c/p\u003e\",\"names\":{\"english\":\"wind\",\"tibetan\":\"རླུང་།\",\"sanskrit\":\"prāṇa, vāyu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rlung\"}},{\"uuid\":\"d23c6bcd-6c91-480e-a362-89a3ed8a3ea6\",\"authority\":\"fe1ed905-c01b-4b41-b698-24318c0ad171\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA class of \u003cspan data-glossary-id=\\\"UT22084-068-021-8622\\\"\u003evidyādharas\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"wine drinker\",\"tibetan\":\"ཆང་བ་རྣམས་ཀྱིས་བཏུང་བ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chang ba rnams kyis btung ba\"}},{\"uuid\":\"54c05bad-9582-403a-b922-d9463069f1ce\",\"authority\":\"ce90786f-f3ed-4165-947c-0b799f576ca7\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA river in \u003cspan\u003e\u003cspan data-glossary-id=\\\"UT22084-068-021-9443\\\"\u003eMajestic Trees\u003c/span\u003e\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Wish-Fulfilling Waters\",\"tibetan\":\"ཇི་ལྟར་འདོད་པའི་ཆུ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ji ltar ’dod pa’i chu\"}},{\"uuid\":\"3297ddc1-1e7a-44dc-8453-4d609cb449df\",\"authority\":\"a6906a9b-ef06-490f-b613-7ce1f7b131eb\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA class of \u003cspan data-glossary-id=\\\"UT22084-068-021-8622\\\"\u003evidyādharas\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"woman craver\",\"tibetan\":\"བུད་མེད་ལ་སྲེད་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bud med la sred pa\"}},{\"uuid\":\"b58c9481-32a9-4586-a2e1-b08870bc187f\",\"authority\":\"a8380c12-eac9-413f-854a-84d2c30981a9\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eWhen refering to the human body, these are creatures that inhabit it and may either harm or contribute to its health. Note that this term can also mean insects and \u003cspan class=\\\"ignore\\\"\u003eworm\u003c/span\u003es in general.\u003c/p\u003e\",\"names\":{\"english\":\"worm\",\"tibetan\":\"སྲིན་བུ།\",\"sanskrit\":\"kṛmi\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"srin bu\"}},{\"uuid\":\"314cbb1a-5c42-435d-a3b3-c3cd3d14e01f\",\"authority\":\"23411e32-c90d-4aee-94a1-25595bf4b2a4\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of sixteen realms that surround the \u003cspan data-glossary-id=\\\"UT22084-068-021-9298\\\"\u003eHowling Hell\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Worrisome\",\"tibetan\":\"ཀུན་དུ་རྟོག་བྱེད།\",\"sanskrit\":\"saṅkalpakāraṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kun du rtog byed\"}},{\"uuid\":\"69eec99c-d322-425f-bc83-85bb4b1e65ae\",\"authority\":\"d95e6f28-87de-429e-b185-d12873ac760c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA person who has accomplished the final fruition of the path of the \u003cspan data-glossary-id=\\\"UT22084-068-021-8536\\\"\u003ehearers\u003c/span\u003e and is liberated from \u003cspan data-glossary-id=\\\"UT22084-068-021-9884\\\"\u003esaṃsāra\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"worthy one\",\"tibetan\":\"དགྲ་བཅོམ་པ།\",\"sanskrit\":\"arhat\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dgra bcom pa\"}},{\"uuid\":\"70267edc-1d77-489a-943a-c280d386c636\",\"authority\":\"f575f8e6-3b9b-4952-8821-3d90bf81c89f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of sixteen realms that surround the \u003cspan data-glossary-id=\\\"UT22084-068-021-9279\\\"\u003eHell of Ultimate Torment\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Wrapped in Every Possible Pain\",\"tibetan\":\"སྡུག་བསྔལ་ཀུན་དཀྲིས།\",\"sanskrit\":\"sarvaduḥkhāvarta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sdug bsngal kun dkris\"}},{\"uuid\":\"5b457f37-2050-4b7a-a1bd-a4844678591e\",\"authority\":\"ee603a62-9648-4975-8315-7a9ca9bda392\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe third among the three mental misdeeds.\u003c/p\u003e\",\"names\":{\"english\":\"wrong view\",\"tibetan\":\"ལོག་ལྟ།\",\"sanskrit\":\"mithyā-dṛṣṭi\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"log lta\"}},{\"uuid\":\"9d3bfc42-ac48-41d3-b11a-e2ae12b0ad5c\",\"authority\":\"6bc88464-d01f-41dd-83e3-906807fba845\",\"definition\":\"\u003cp\u003eA class of nonhuman beings who inhabit forests, mountainous areas, and other natural spaces, or serve as guardians of villages and towns, and may be propitiated for health, wealth, protection, and other boons, or controlled through magic. According to tradition, their homeland is in the north, where they live under the rule of the Great King Vaiśravaṇa.\u003c/p\u003e\u003cp\u003e Several members of this class have been deified as gods of wealth (these include the just-mentioned Vaiśravaṇa) or as bodhisattva generals of yakṣa armies, and have entered the Buddhist pantheon in a variety of forms, including, in tantric Buddhism, those of wrathful deities.\u003c/p\u003e\",\"names\":{\"english\":\"yakṣa\",\"tibetan\":\"གནོད་སྦྱིན།\",\"sanskrit\":\"yakṣa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gnod sbyin\"}},{\"uuid\":\"996fe086-2cf2-4228-9cd7-88b80aa7dd10\",\"authority\":\"4be67748-50a0-4804-89b1-dc6814d349dc\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA river in \u003cspan data-glossary-id=\\\"UT22084-068-021-9338\\\"\u003eJambudvīpa\u003c/span\u003e, still called by the same name today.\u003c/p\u003e\",\"names\":{\"english\":\"Yamunā\",\"tibetan\":\"ཡ་མུ་ན།, ཡ་མུ་ནཱ།\",\"sanskrit\":\"yamunā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ya mu nA, ya mu na\"}},{\"uuid\":\"24cee0e6-a6c4-4496-aeb0-bb146ca90f8a\",\"authority\":\"81edfa1c-54ff-4fa3-a088-82df180157ad\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eIndian term used in reference to Greeks, or foreign barbarians in general.\u003c/p\u003e\",\"names\":{\"english\":\"Yavana\",\"tibetan\":\"ཡ་བ་ན།\",\"sanskrit\":\"yavana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ya ba na\"}},{\"uuid\":\"8b82ad5d-96e6-486d-821c-a45620d2464d\",\"authority\":\"33086d7f-5a0a-45e9-a901-da18d83201f5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA park in \u003cspan data-glossary-id=\\\"UT22084-068-021-9757\\\"\u003eSustained by Fruition\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Yielding All Fruits\",\"tibetan\":\"འབྲས་བུ་ཀུན་ཕྱེད།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’bras bu kun phyed\"}},{\"uuid\":\"46ed4626-7a6a-412e-b39a-8d08bc5e6dee\",\"authority\":\"fdb5cf5f-77ea-40d8-b247-e86e4d20032a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA forest on \u003cspan data-glossary-id=\\\"UT22084-068-021-9771\\\"\u003eTamer of Deer Enemies\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Yielding to Pressure and Bouncing Back\",\"tibetan\":\"མནན་ན་ནེམ་ལ་བཏེག་ན་འཕར་བ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mnan na nem la bteg na ’phar ba\"}}]}]\n"])</script><div hidden id="S:5"><div dir="ltr" data-orientation="horizontal" data-slot="tabs" class="flex flex-col w-full gap-0 @container/sidebar"><div class="sticky top-0 pt-1 pb-2 z-10 w-full rounded-t bg-background overflow-x-auto text-center"><div role="tablist" aria-orientation="horizontal" data-slot="tabs-list" class="bg-background gap-1 sm:gap-3 h-10 items-center justify-center sm:p-1 w-fit px-6 inline-flex mx-auto rounded-none" tabindex="-1" data-orientation="horizontal" style="outline:none"><button type="button" role="tab" aria-selected="true" aria-controls="radix-_R_2npftt6btb_-content-endnotes" data-state="active" id="radix-_R_2npftt6btb_-trigger-endnotes" data-slot="tabs-trigger" class="inline-flex items-center justify-center whitespace-nowrap px-1 py-0.75 text-sm data-[state=active]:font-semibold ring-offset-background transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-background text-foreground border-b-2 border-transparent data-[state=active]:border-primary-300 decoration-primary-25 hover:text-primary hover:border-primary/20 hover:cursor-pointer" tabindex="-1" data-orientation="horizontal" data-radix-collection-item="">Notes</button><button type="button" role="tab" aria-selected="false" aria-controls="radix-_R_2npftt6btb_-content-glossary" data-state="inactive" id="radix-_R_2npftt6btb_-trigger-glossary" data-slot="tabs-trigger" class="inline-flex items-center justify-center whitespace-nowrap px-1 py-0.75 text-sm data-[state=active]:font-semibold ring-offset-background transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-background text-foreground border-b-2 border-transparent data-[state=active]:border-primary-300 d