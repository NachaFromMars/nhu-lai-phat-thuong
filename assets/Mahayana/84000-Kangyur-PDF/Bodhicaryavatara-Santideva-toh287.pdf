on\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" who were on the way to the same destination, and together they engaged in a Dharma discussion to everyone’s delight and appreciation.\",\"attrs\":{\"start\":352,\"end\":486}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"b9501750-e955-4e6b-94ad-77339da900d1\",\"sort\":588,\"type\":\"prologue\",\"label\":\"p.3\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1315,\"uuid\":\"b9501750-e955-4e6b-94ad-77339da900d1\"},\"content\":[{\"type\":\"text\",\"text\":\"During their discussions some of the \",\"attrs\":{\"start\":0,\"end\":37}},{\"type\":\"text\",\"text\":\"non-Buddhists\",\"attrs\":{\"start\":37,\"end\":50},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"02f4d334-0e69-4600-a543-0dcea128cf23\",\"uuid\":\"3d1c9db5-f914-4c12-a08d-1e3a53122d3e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" asked, “Ah, you \",\"attrs\":{\"start\":50,\"end\":67}},{\"type\":\"text\",\"text\":\"Śākya followers\",\"attrs\":{\"start\":67,\"end\":82},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"42a1f95e-b362-4157-9e3d-02daeff06b02\",\"uuid\":\"b7fcf0a2-df13-4d0d-aab5-259fe170439e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", does not your \",\"attrs\":{\"start\":82,\"end\":98}},{\"type\":\"text\",\"text\":\"mendicant\",\"attrs\":{\"start\":98,\"end\":107},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"02bd7ac1-47d5-418a-80ad-998f2aa21c76\",\"uuid\":\"35d6ff84-204d-44e4-8a23-1f038d34bc45\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":107,\"end\":108}},{\"type\":\"text\",\"text\":\"Gautama\",\"attrs\":{\"start\":108,\"end\":115},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"06065a04-f338-4331-bceb-5fd705891843\",\"uuid\":\"140942e4-f887-4eb7-8cfb-b58f4940e774\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" teach that misdeeds of the body are unattractive, ugly, and unpleasant, and that one should refrain from rejoicing in them even when they are done by another? We also consider misdeeds of the body to be unattractive, ugly, and unpleasant, and we do not rejoice in them even when done by others. Does not your \",\"attrs\":{\"start\":115,\"end\":425}},{\"type\":\"text\",\"text\":\"mendicant\",\"attrs\":{\"start\":425,\"end\":434},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"02bd7ac1-47d5-418a-80ad-998f2aa21c76\",\"uuid\":\"1cc68303-0307-4e58-8cba-71532366a467\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":434,\"end\":435}},{\"type\":\"text\",\"text\":\"Gautama\",\"attrs\":{\"start\":435,\"end\":442},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"06065a04-f338-4331-bceb-5fd705891843\",\"uuid\":\"0fd9e7a4-212e-4c3a-a096-2a1e98f67b87\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" teach that misdeeds of speech are unattractive, ugly, and unpleasant, and that one should refrain from rejoicing in them even when done by another? We also consider misdeeds of speech to be unattractive, ugly, and unpleasant, and we do not rejoice in them even when done by others. Does not your \",\"attrs\":{\"start\":442,\"end\":739}},{\"type\":\"text\",\"text\":\"mendicant\",\"attrs\":{\"start\":739,\"end\":748},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"02bd7ac1-47d5-418a-80ad-998f2aa21c76\",\"uuid\":\"5546d201-fd98-41b9-9c4a-cfa4cd7ba6ae\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":748,\"end\":749}},{\"type\":\"text\",\"text\":\"Gautama\",\"attrs\":{\"start\":749,\"end\":756},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"06065a04-f338-4331-bceb-5fd705891843\",\"uuid\":\"b3b73993-c1dd-4355-913e-a7148d50f936\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" teach that misdeeds of the mind are unattractive, ugly, and unpleasant, and that one should refrain from rejoicing in them even when done by another? We also consider misdeeds of the mind to be unattractive, ugly, and unpleasant, and we do not rejoice in them even when done by others. What difference is there [F.82.b]\",\"attrs\":{\"start\":756,\"end\":1076},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"b4505e92-9c48-448e-9469-6a1fca02b826\",\"label\":\"16\",\"uuid\":\"7bd85ece-59f8-467b-8bb6-91033a738260\",\"start\":1076,\"end\":1076,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" between your \",\"attrs\":{\"start\":1076,\"end\":1090}},{\"type\":\"text\",\"text\":\"mendicant\",\"attrs\":{\"start\":1090,\"end\":1099},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"02bd7ac1-47d5-418a-80ad-998f2aa21c76\",\"uuid\":\"7170b66b-675a-4977-b3de-0b3e72ac899f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":1099,\"end\":1100}},{\"type\":\"text\",\"text\":\"Gautama\",\"attrs\":{\"start\":1100,\"end\":1107},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"06065a04-f338-4331-bceb-5fd705891843\",\"uuid\":\"e5520841-cff5-4168-b71f-853b018adc1e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s \",\"attrs\":{\"start\":1107,\"end\":1110}},{\"type\":\"text\",\"text\":\"Dharma-Vinaya\",\"attrs\":{\"start\":1110,\"end\":1123},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c8f3d188-2996-4689-9f87-c02f70f2e31e\",\"uuid\":\"d5b49bda-ea6f-4d24-938e-599bbbfef8ae\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and our own? What are the ideas? What are the distinctive points? What makes the \",\"attrs\":{\"start\":1123,\"end\":1205}},{\"type\":\"text\",\"text\":\"Dharma-Vinaya\",\"attrs\":{\"start\":1205,\"end\":1218},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c8f3d188-2996-4689-9f87-c02f70f2e31e\",\"uuid\":\"1c17859e-4524-4ec7-846d-d7ecb959554b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of your \",\"attrs\":{\"start\":1218,\"end\":1227}},{\"type\":\"text\",\"text\":\"mendicant\",\"attrs\":{\"start\":1227,\"end\":1236},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"02bd7ac1-47d5-418a-80ad-998f2aa21c76\",\"uuid\":\"a4ca4bdb-bda5-498f-ac1f-c9a238cceb86\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":1236,\"end\":1237}},{\"type\":\"text\",\"text\":\"Gautama\",\"attrs\":{\"start\":1237,\"end\":1244},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"06065a04-f338-4331-bceb-5fd705891843\",\"uuid\":\"17c804a8-50f5-4a3a-a63b-fc362562aa01\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" superior to ours? The \",\"attrs\":{\"start\":1244,\"end\":1267}},{\"type\":\"text\",\"text\":\"mendicant\",\"attrs\":{\"start\":1267,\"end\":1276},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"02bd7ac1-47d5-418a-80ad-998f2aa21c76\",\"uuid\":\"4397757c-f1cb-488d-b500-67f08124643b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":1276,\"end\":1277}},{\"type\":\"text\",\"text\":\"Gautama\",\"attrs\":{\"start\":1277,\"end\":1284},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"06065a04-f338-4331-bceb-5fd705891843\",\"uuid\":\"df441b90-631b-4175-9add-da25446eccdd\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" claims that he is omniscient.”\",\"attrs\":{\"start\":1284,\"end\":1315}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"7c411ebd-e8c6-4902-a5ce-9fc61091b40b\",\"sort\":627,\"type\":\"prologue\",\"label\":\"p.4\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":370,\"uuid\":\"7c411ebd-e8c6-4902-a5ce-9fc61091b40b\"},\"content\":[{\"type\":\"text\",\"text\":\"When faced with these questions by the wandering \",\"attrs\":{\"start\":0,\"end\":49}},{\"type\":\"text\",\"text\":\"non-Buddhist\",\"attrs\":{\"start\":49,\"end\":61},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"02f4d334-0e69-4600-a543-0dcea128cf23\",\"uuid\":\"5be81fc4-f68b-428e-a97b-abdb5b11b15b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" practitioners, the group of newly ordained monks neither approved nor responded because the venerable \",\"attrs\":{\"start\":61,\"end\":164}},{\"type\":\"text\",\"text\":\"Śāradvatīputra\",\"attrs\":{\"start\":164,\"end\":178},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b34f8e95-5fc9-44c9-8e45-f4587adea677\",\"uuid\":\"6c6f9d0a-f776-4e69-a290-712819e6b4f5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" was absent. Once they had completed their \",\"attrs\":{\"start\":178,\"end\":221}},{\"type\":\"text\",\"text\":\"alms\",\"attrs\":{\"start\":221,\"end\":225},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"04bccafd-3cc4-42b2-a249-07b6649932ba\",\"uuid\":\"84910283-0cc8-465b-97a6-444466f627e9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" round, the large group of monks returned to the town of \",\"attrs\":{\"start\":225,\"end\":282}},{\"type\":\"text\",\"text\":\"Nālati\",\"attrs\":{\"start\":282,\"end\":288},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"47ddecbd-4962-438a-8eec-33c5c48b2fa1\",\"uuid\":\"6071b893-f13d-43d8-b74b-5a3016f8b4e9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" where they had their meal and then took their places amid the gathering of monks.\",\"attrs\":{\"start\":288,\"end\":370}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"2e0e19ed-792a-45e9-b4cb-7798b256dc85\",\"sort\":637,\"type\":\"prologue\",\"label\":\"p.5\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":581,\"uuid\":\"2e0e19ed-792a-45e9-b4cb-7798b256dc85\"},\"content\":[{\"type\":\"text\",\"text\":\"Later, venerable \",\"attrs\":{\"start\":0,\"end\":17}},{\"type\":\"text\",\"text\":\"Śāradvatīputra\",\"attrs\":{\"start\":17,\"end\":31},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b34f8e95-5fc9-44c9-8e45-f4587adea677\",\"uuid\":\"c3ecc187-7596-4b11-bc2e-b0855991f1b7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" also returned to the town of \",\"attrs\":{\"start\":31,\"end\":61}},{\"type\":\"text\",\"text\":\"Nālati\",\"attrs\":{\"start\":61,\"end\":67},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"47ddecbd-4962-438a-8eec-33c5c48b2fa1\",\"uuid\":\"23e4ca4a-a0ef-4043-b427-d4e406623e12\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", having received his \",\"attrs\":{\"start\":67,\"end\":89}},{\"type\":\"text\",\"text\":\"alms\",\"attrs\":{\"start\":89,\"end\":93},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"04bccafd-3cc4-42b2-a249-07b6649932ba\",\"uuid\":\"e925612d-6a80-4407-a74b-593c7028cb6a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". When he arrived, the great gathering of monks went to see him and related to him what had transpired. Venerable \",\"attrs\":{\"start\":93,\"end\":207}},{\"type\":\"text\",\"text\":\"Śāradvatīputra\",\"attrs\":{\"start\":207,\"end\":221},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b34f8e95-5fc9-44c9-8e45-f4587adea677\",\"uuid\":\"d2ed7589-c005-43fd-b307-197ceef154c0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" said, “If I had been traveling with you, venerable ones, and had met those wandering \",\"attrs\":{\"start\":221,\"end\":307}},{\"type\":\"text\",\"text\":\"non-Buddhist\",\"attrs\":{\"start\":307,\"end\":319},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"02f4d334-0e69-4600-a543-0dcea128cf23\",\"uuid\":\"c6667fea-9234-4e76-9a79-e28d78de59a2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" practitioners along the \",\"attrs\":{\"start\":319,\"end\":344}},{\"type\":\"text\",\"text\":\"Rājagṛha\",\"attrs\":{\"start\":344,\"end\":352},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a5d6cdd3-67d3-4718-a63d-0028f40baee2\",\"uuid\":\"ad0d2948-9e46-44a8-b2d4-755e99a44a04\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" highway, at a crossing, or at a fork in the road, I would have defeated them in accordance with the Dharma. But unfortunately, I did not witness what transpired in your discussion with those wandering \",\"attrs\":{\"start\":352,\"end\":554}},{\"type\":\"text\",\"text\":\"non-Buddhist\",\"attrs\":{\"start\":554,\"end\":566},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"02f4d334-0e69-4600-a543-0dcea128cf23\",\"uuid\":\"fdd234e0-4aa9-45d9-b726-4b4fffcc5c91\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" practitioners.\",\"attrs\":{\"start\":566,\"end\":581}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"4cb3b5cd-3e0c-4adb-bfcf-c6e0649b8009\",\"sort\":653,\"type\":\"prologue\",\"label\":\"p.6\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":669,\"uuid\":\"4cb3b5cd-3e0c-4adb-bfcf-c6e0649b8009\"},\"content\":[{\"type\":\"text\",\"text\":\"“Venerable ones, the eyes of the \",\"attrs\":{\"start\":0,\"end\":33}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":33,\"end\":44},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"096407a8-2631-4818-90b7-90d522c2f84b\",\"uuid\":\"5705052e-30a2-411d-a3c0-cccc2a4c1628\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" perceive everything directly. He understands actions, their effects, and their \",\"attrs\":{\"start\":44,\"end\":124}},{\"type\":\"text\",\"text\":\"ripening\",\"attrs\":{\"start\":124,\"end\":132},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e6c5ad9a-9509-4706-9d6f-5fad607030a7\",\"uuid\":\"30b86393-bc14-420f-ae70-d4ae0cf3583d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". At present he is residing not far from here. Subduing all those whose views are extreme, he is teaching the Dharma of actions and their \",\"attrs\":{\"start\":132,\"end\":270}},{\"type\":\"text\",\"text\":\"ripening\",\"attrs\":{\"start\":270,\"end\":278},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e6c5ad9a-9509-4706-9d6f-5fad607030a7\",\"uuid\":\"eb6764ab-5844-499c-bc8d-497af1f6baac\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" results to \",\"attrs\":{\"start\":278,\"end\":290}},{\"type\":\"text\",\"text\":\"hearers\",\"attrs\":{\"start\":290,\"end\":297},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5a90184b-4c5f-424b-8a34-4d859dc83b2f\",\"uuid\":\"19704681-898d-464f-8586-5b7533dae659\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and laypeople, \",\"attrs\":{\"start\":297,\"end\":313}},{\"type\":\"text\",\"text\":\"gods\",\"attrs\":{\"start\":313,\"end\":317},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"001a0a5f-1d64-4686-98cb-d50f70cca517\",\"uuid\":\"e262e429-49c8-4637-bc30-ccf7015fa36e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and humans. You must bring what happened before him. He will teach you everything about actions and their \",\"attrs\":{\"start\":317,\"end\":424}},{\"type\":\"text\",\"text\":\"ripening\",\"attrs\":{\"start\":424,\"end\":432},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e6c5ad9a-9509-4706-9d6f-5fad607030a7\",\"uuid\":\"bb8861bb-e933-4d91-ba9d-e944b0c96b8d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". He will teach you that which is not seen by any \",\"attrs\":{\"start\":432,\"end\":482}},{\"type\":\"text\",\"text\":\"god\",\"attrs\":{\"start\":482,\"end\":485},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"001a0a5f-1d64-4686-98cb-d50f70cca517\",\"uuid\":\"0d7f8796-f5a1-4c2f-8be0-9a6c45da4623\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":485,\"end\":487}},{\"type\":\"text\",\"text\":\"māra\",\"attrs\":{\"start\":487,\"end\":491},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"be33ec74-6b07-494d-b35c-c7fde200b8ac\",\"uuid\":\"673864a7-5f3c-43eb-918d-dec4749f85d2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":491,\"end\":493}},{\"type\":\"text\",\"text\":\"Brahmā\",\"attrs\":{\"start\":493,\"end\":499},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e4d3cd20-fd11-455c-844e-c5bb18b89e36\",\"uuid\":\"16a86831-e8b3-4f21-80ba-9568150471d7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":499,\"end\":501}},{\"type\":\"text\",\"text\":\"mendicant\",\"attrs\":{\"start\":501,\"end\":510},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"02bd7ac1-47d5-418a-80ad-998f2aa21c76\",\"uuid\":\"d365309f-482a-45e3-91ee-f6a66a725c59\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":510,\"end\":512}},{\"type\":\"text\",\"text\":\"brahmin\",\"attrs\":{\"start\":512,\"end\":519},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d2beaf90-2596-4dcc-b765-8064c0cba1f3\",\"uuid\":\"ac47e56b-f647-4a81-8be4-3419140023d0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", or any other being. What we fail to see the \",\"attrs\":{\"start\":519,\"end\":565}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":565,\"end\":576},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"096407a8-2631-4818-90b7-90d522c2f84b\",\"uuid\":\"f69c0c11-cdca-4d0e-b3f0-94a98a4d1af4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" sees directly. With his knowledge of actions and their \",\"attrs\":{\"start\":576,\"end\":632}},{\"type\":\"text\",\"text\":\"ripening\",\"attrs\":{\"start\":632,\"end\":640},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e6c5ad9a-9509-4706-9d6f-5fad607030a7\",\"uuid\":\"dca9caef-ba33-4a90-9fb6-48a0c403aca7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" results, he will teach you.”\",\"attrs\":{\"start\":640,\"end\":669}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"1b63ef0f-dbd7-4a0f-ae8d-e3927c3b6c12\",\"sort\":683,\"type\":\"prologue\",\"label\":\"p.7\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1533,\"uuid\":\"1b63ef0f-dbd7-4a0f-ae8d-e3927c3b6c12\"},\"content\":[{\"type\":\"text\",\"text\":\"The large group of monks then set off to see the \",\"attrs\":{\"start\":0,\"end\":49}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":49,\"end\":60},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"096407a8-2631-4818-90b7-90d522c2f84b\",\"uuid\":\"1bf77c9e-92b8-4c6e-8cc8-118f24f85c92\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and came upon him during his afternoon rest. He was seated like Mount \",\"attrs\":{\"start\":60,\"end\":131}},{\"type\":\"text\",\"text\":\"Sumeru\",\"attrs\":{\"start\":131,\"end\":137},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2014c001-ec4d-45a4-ba8c-d283853d6949\",\"uuid\":\"89eedf77-f64b-48ed-a21c-04ce7d6e3214\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", shining brightly within a sphere of light. The \",\"attrs\":{\"start\":137,\"end\":186}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":186,\"end\":197},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"096407a8-2631-4818-90b7-90d522c2f84b\",\"uuid\":\"ffedb01a-82de-4ffe-8eca-acd513bbe7a3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" was resplendent like the sun at noon, peaceful and soothing like the moon at night. He was clear like a lake, deep like the sea, unshakable like Mount \",\"attrs\":{\"start\":197,\"end\":349}},{\"type\":\"text\",\"text\":\"Sumeru\",\"attrs\":{\"start\":349,\"end\":355},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2014c001-ec4d-45a4-ba8c-d283853d6949\",\"uuid\":\"b51d4e4d-49c7-4211-af0d-af413bf69665\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and dauntless like a lion. Like a parent, he was the refuge for all. With his mind permeated by great compassion, he was the universal friend of all beings. He was an abode of love, compassion, joy, and equanimity. With his body adorned by the thirty-seven great \",\"attrs\":{\"start\":355,\"end\":620}},{\"type\":\"text\",\"text\":\"factors of awakening\",\"attrs\":{\"start\":620,\"end\":640},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4c2d89d4-bb5b-4d6b-8d63-088fb77f86a5\",\"uuid\":\"0c81106a-54b4-4c43-9066-f482c36b9234\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", its radiance delighted the eyes of all who beheld him. Outshining the light of the sun and the moon, the son of the \",\"attrs\":{\"start\":640,\"end\":758}},{\"type\":\"text\",\"text\":\"Śākya\",\"attrs\":{\"start\":758,\"end\":763},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"3ec44d80-00e7-44f6-8e2b-c0a695dbf71e\",\"uuid\":\"3d303be0-222f-4888-900c-4079060dd8fe\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" king was endowed with universal vision, and his eyes were free of the \",\"attrs\":{\"start\":763,\"end\":834}},{\"type\":\"text\",\"text\":\"three stains\",\"attrs\":{\"start\":834,\"end\":846},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"13f5ca5d-5372-4b5c-8e07-c82f44129374\",\"uuid\":\"b4bbbe33-8a2f-49ae-b188-446939eb3ea2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". He had taught the \",\"attrs\":{\"start\":846,\"end\":866}},{\"type\":\"text\",\"text\":\"two truths\",\"attrs\":{\"start\":866,\"end\":876},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ea1f16e6-a979-4f91-99d3-152e71e6d64a\",\"uuid\":\"a1e21e04-f0b8-45b1-9ae3-f6b3500e5ac2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", comprehended the twofold suffering, accomplished and actualized the two cultivations, realized the result of the path, and gained the knowledge of the \",\"attrs\":{\"start\":876,\"end\":1029}},{\"type\":\"text\",\"text\":\"reality\",\"attrs\":{\"start\":1029,\"end\":1036},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"0e1f9b7a-915d-4d6d-8123-4e54f6da60e0\",\"uuid\":\"4108573d-9456-41fb-a2fe-07a21c7c97ba\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of cessation. Endowed with eyes that perceive the \",\"attrs\":{\"start\":1036,\"end\":1087}},{\"type\":\"text\",\"text\":\"three realms\",\"attrs\":{\"start\":1087,\"end\":1099},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"04a1b256-f69d-4139-b693-3692fcc6ed1f\",\"uuid\":\"3930af24-4002-404f-bbf4-7b8cfc713a9a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" directly, he revealed the \",\"attrs\":{\"start\":1099,\"end\":1126}},{\"type\":\"text\",\"text\":\"three realms\",\"attrs\":{\"start\":1126,\"end\":1138},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"04a1b256-f69d-4139-b693-3692fcc6ed1f\",\"uuid\":\"58d7968f-0d3f-4f9f-b53c-b9eb2a048462\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" to others. He had fathomed the real nature of the \",\"attrs\":{\"start\":1138,\"end\":1189}},{\"type\":\"text\",\"text\":\"eighteen elements\",\"attrs\":{\"start\":1189,\"end\":1206},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"979a8df9-464d-4d79-9bda-299dc188c053\",\"uuid\":\"135a8151-ac32-493e-b635-fbe10bceb395\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". He knew the essence of the inspired mind. He was endowed with the \",\"attrs\":{\"start\":1206,\"end\":1274}},{\"type\":\"text\",\"text\":\"eighteen floods of unique qualities\",\"attrs\":{\"start\":1274,\"end\":1309},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"87b038b7-dc28-4897-bc8e-03a757675733\",\"uuid\":\"c5f1870e-d7a0-48c7-a3fd-932e76256886\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", liberated from the bonds of existence, in possession of the \",\"attrs\":{\"start\":1309,\"end\":1371}},{\"type\":\"text\",\"text\":\"ten powers\",\"attrs\":{\"start\":1371,\"end\":1381},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e419cc7e-5be4-4725-ab1c-535706f0cd40\",\"uuid\":\"10591371-6d0b-4d94-90f3-9d026806290e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", fearless with the \",\"attrs\":{\"start\":1381,\"end\":1401}},{\"type\":\"text\",\"text\":\"four types of fearlessness\",\"attrs\":{\"start\":1401,\"end\":1427},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4dd4bbec-82e7-414c-93f0-cac409aed87c\",\"uuid\":\"7431c048-4db7-4cb1-b0c8-7d24a389cc11\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", endowed with great compassion, and constantly in possession of the threefold application of mindfulness.\",\"attrs\":{\"start\":1427,\"end\":1533}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"e48fb59a-979e-4134-ad5e-a41e271eb45e\",\"sort\":717,\"type\":\"prologue\",\"label\":\"p.8\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":742,\"uuid\":\"e48fb59a-979e-4134-ad5e-a41e271eb45e\"},\"content\":[{\"type\":\"text\",\"text\":\"The many monks draped their Dharma robes over their shoulders, knelt on their right knees, and bowed their heads to the \",\"attrs\":{\"start\":0,\"end\":120}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":120,\"end\":131},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"096407a8-2631-4818-90b7-90d522c2f84b\",\"uuid\":\"f18a97e0-07de-4cb1-a184-1926863f7d6e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s feet. Calmly and with heads bowed, they then stood to one side. A monk who had been appointed by the large gathering now stepped forth and approached the \",\"attrs\":{\"start\":131,\"end\":288}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":288,\"end\":299},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"096407a8-2631-4818-90b7-90d522c2f84b\",\"uuid\":\"de478335-8531-4056-b7bf-e3c479d5c361\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". When he was very close to the \",\"attrs\":{\"start\":299,\"end\":331}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":331,\"end\":342},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"096407a8-2631-4818-90b7-90d522c2f84b\",\"uuid\":\"b0b0c3d6-3f2d-4898-bcbc-60df07b06f08\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", he bowed his head to his feet. He then respectfully conveyed to the \",\"attrs\":{\"start\":342,\"end\":412}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":412,\"end\":423},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"096407a8-2631-4818-90b7-90d522c2f84b\",\"uuid\":\"d0464cb8-cbf9-4470-b3f8-34df947cc072\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" how, in the morning, the monks had dressed in their Dharma robes, picked up their \",\"attrs\":{\"start\":423,\"end\":506}},{\"type\":\"text\",\"text\":\"alms\",\"attrs\":{\"start\":506,\"end\":510},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"04bccafd-3cc4-42b2-a249-07b6649932ba\",\"uuid\":\"c4b94ad3-f400-48bd-99c0-426fa4e3eb83\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" bowls, and gone to \",\"attrs\":{\"start\":510,\"end\":530}},{\"type\":\"text\",\"text\":\"Rājagṛha\",\"attrs\":{\"start\":530,\"end\":538},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a5d6cdd3-67d3-4718-a63d-0028f40baee2\",\"uuid\":\"007ca516-b73b-4672-8bd1-50d4cc60a0a9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" to receive \",\"attrs\":{\"start\":538,\"end\":550}},{\"type\":\"text\",\"text\":\"alms\",\"attrs\":{\"start\":550,\"end\":554},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"04bccafd-3cc4-42b2-a249-07b6649932ba\",\"uuid\":\"22a6ec41-a21b-4a42-bca5-795315d32f6e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". He recounted how they had met the wandering \",\"attrs\":{\"start\":554,\"end\":600}},{\"type\":\"text\",\"text\":\"non-Buddhist\",\"attrs\":{\"start\":600,\"end\":612},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"02f4d334-0e69-4600-a543-0dcea128cf23\",\"uuid\":\"03e294d3-32b7-4ae8-9f19-ec8fc7ccca40\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" practitioners, and how the latter had begun to discuss physical, verbal, and mental misdeeds, up to the questions they had asked.\",\"attrs\":{\"start\":612,\"end\":742}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"c0144fd2-35da-4658-acad-efc5518676b7\",\"sort\":735,\"type\":\"prologue\",\"label\":\"p.9\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":535,\"uuid\":\"565110ac-b977-475b-a13e-078df4af775c\"},\"content\":[{\"type\":\"text\",\"text\":\"When the monk had finished his account, the \",\"attrs\":{\"start\":0,\"end\":44}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":44,\"end\":55},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"096407a8-2631-4818-90b7-90d522c2f84b\",\"uuid\":\"8ce0c6a9-8244-4397-bf07-429f587c8df7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" spoke the following words to the monks, as well as to the \",\"attrs\":{\"start\":55,\"end\":114}},{\"type\":\"text\",\"text\":\"brahmins\",\"attrs\":{\"start\":114,\"end\":122},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d2beaf90-2596-4dcc-b765-8064c0cba1f3\",\"uuid\":\"1a3b752f-d583-4d1c-be84-870daf787a98\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of \",\"attrs\":{\"start\":122,\"end\":126}},{\"type\":\"text\",\"text\":\"Nālati\",\"attrs\":{\"start\":126,\"end\":132},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"47ddecbd-4962-438a-8eec-33c5c48b2fa1\",\"uuid\":\"35ce62a6-5829-4620-a181-a232c4a05694\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and the others: “Monks, I shall explain for you a teaching of the Dharma that is known as \",\"attrs\":{\"start\":132,\"end\":224}},{\"type\":\"text\",\"text\":\"Mindfulness of the Sacred Dharma.\",\"attrs\":{\"start\":224,\"end\":257},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"012b6d94-8886-4a6d-b2f8-568286accc79\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" Auspicious in the beginning, the middle, and the end, this teaching is of profound meaning and conveyed in excellent words. Unique, complete, and pure, it explains the perfect training and \",\"attrs\":{\"start\":257,\"end\":447}},{\"type\":\"text\",\"text\":\"pure conduct\",\"attrs\":{\"start\":447,\"end\":459},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7219540f-f47d-40cc-a2b8-cad5b3fe17da\",\"uuid\":\"e6231237-6a7a-48df-b500-2ed1a2165759\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Listen keenly and keep in mind what I say. I shall explain this for you.” \",\"attrs\":{\"start\":459,\"end\":535}}]},{\"type\":\"paragraph\",\"attrs\":{\"start\":535,\"end\":604},\"content\":[{\"type\":\"text\",\"text\":\"“\",\"attrs\":{\"start\":535,\"end\":536}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":536,\"end\":547},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"096407a8-2631-4818-90b7-90d522c2f84b\",\"uuid\":\"03ad75e4-4d25-44cd-a7be-2409c05e1eec\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\",” replied the monks, “we shall do just as you instruct.”\",\"attrs\":{\"start\":547,\"end\":604}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"0ce01e52-fa73-4763-9de2-3a33c5d88e97\",\"sort\":752,\"type\":\"prologue\",\"label\":\"p.10\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":588,\"uuid\":\"0ce01e52-fa73-4763-9de2-3a33c5d88e97\"},\"content\":[{\"type\":\"text\",\"text\":\"As the monks listened, the \",\"attrs\":{\"start\":0,\"end\":27}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":27,\"end\":38},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"096407a8-2631-4818-90b7-90d522c2f84b\",\"uuid\":\"e36a6fd7-b69c-4f51-b41f-1966e8a704f1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" now spoke: “Monks, you may wonder what is meant by the Dharma teaching known as \",\"attrs\":{\"start\":38,\"end\":119}},{\"type\":\"text\",\"text\":\"Mindfulness of the Sacred Dharma.\",\"attrs\":{\"start\":119,\"end\":152},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"a78cde6f-b8c7-4425-a65b-1035d77e6f4a\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" Well, it is to remain constantly mindful of seeing Dharma as Dharma and non-Dharma as non-Dharma, while not having any doubts. It is to delight in listening to the Dharma, and to venerate one’s elders. This yields knowledge of the effects of the karmic actions of body, speech, and mind, and of the \",\"attrs\":{\"start\":152,\"end\":452}},{\"type\":\"text\",\"text\":\"ripening\",\"attrs\":{\"start\":452,\"end\":460},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e6c5ad9a-9509-4706-9d6f-5fad607030a7\",\"uuid\":\"25ece477-20fd-4f5a-b15e-47bbeed25619\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of those actions in terms of death and rebirth. One’s view thereby becomes unmistaken and impervious to being swayed by others.\",\"attrs\":{\"start\":460,\"end\":588}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"d58ca9d4-56f4-42fe-8f1d-ac8245bb641a\",\"sort\":759,\"type\":\"translation\",\"label\":\"1.\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"start\":0,\"end\":10,\"uuid\":\"f51f03c9-3a4c-4e33-b192-6c4bda619fdc\",\"level\":4},\"content\":[{\"type\":\"text\",\"text\":\"Chapter 1 \",\"attrs\":{\"start\":0,\"end\":10}}]},{\"type\":\"heading\",\"attrs\":{\"start\":10,\"end\":44,\"uuid\":\"c8be7c20-73eb-4253-bcb8-76e45db6cfbf\",\"level\":2,\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"The Ten Virtuous Courses of Action\",\"attrs\":{\"start\":10,\"end\":44}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"0a960798-3c83-4053-8147-105125f3d041\",\"sort\":763,\"type\":\"translation\",\"label\":\"1.1\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":514,\"uuid\":\"0a960798-3c83-4053-8147-105125f3d041\"},\"content\":[{\"type\":\"text\",\"text\":\"“Monks, there are three misdeeds of the body: \",\"attrs\":{\"start\":0,\"end\":46}},{\"type\":\"text\",\"text\":\"killing\",\"attrs\":{\"start\":46,\"end\":53},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"765a595f-12c6-4f20-9dfc-8c1d9d2bb9b2\",\"uuid\":\"0ca1e612-d722-409d-8915-466c5e0c9fd0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":53,\"end\":55}},{\"type\":\"text\",\"text\":\"stealing\",\"attrs\":{\"start\":55,\"end\":63},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9ad933f8-ddbc-4390-be33-dfde30d736b8\",\"uuid\":\"bc5e02a9-6d6e-4264-bc21-cc666640d247\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and \",\"attrs\":{\"start\":63,\"end\":69}},{\"type\":\"text\",\"text\":\"sexual misconduct\",\"attrs\":{\"start\":69,\"end\":86},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9db826d-bfc2-49ef-a9b0-bbe70bf16d26\",\"uuid\":\"051fd694-1bf8-476c-b774-1514cd87ced2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". What, then, is \",\"attrs\":{\"start\":86,\"end\":103}},{\"type\":\"text\",\"text\":\"killing\",\"attrs\":{\"start\":103,\"end\":110},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":103,\"end\":110,\"uuid\":\"02000c21-0797-478d-925b-b7203ac0e331\",\"type\":\"span\",\"textStyle\":\"distinct\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"765a595f-12c6-4f20-9dfc-8c1d9d2bb9b2\",\"uuid\":\"2b799fee-791b-4e66-a9cb-65a7c5745e79\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"? To take a life is to recognize another sentient being as a sentient being and knowingly slay it. Such an act may be of a great, intermediate, or minor kind. \",\"attrs\":{\"start\":110,\"end\":269}},{\"type\":\"text\",\"text\":\"Great \",\"attrs\":{\"start\":269,\"end\":275},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":269,\"end\":282,\"uuid\":\"2ef19ed6-226e-4d9d-bddb-19ef43492068\",\"type\":\"span\",\"textStyle\":\"distinct\"}}]},{\"type\":\"text\",\"text\":\"killing\",\"attrs\":{\"start\":275,\"end\":282},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":275,\"end\":282,\"uuid\":\"2ef19ed6-226e-4d9d-bddb-19ef43492068\",\"type\":\"span\",\"textStyle\":\"distinct\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"765a595f-12c6-4f20-9dfc-8c1d9d2bb9b2\",\"uuid\":\"1d0e9fab-084e-4b12-8270-e119cb3dbe8f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is the murder of a \",\"attrs\":{\"start\":282,\"end\":302}},{\"type\":\"text\",\"text\":\"worthy one\",\"attrs\":{\"start\":302,\"end\":312},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"69eec99c-d322-425f-bc83-85bb4b1e65ae\",\"uuid\":\"3228092f-55de-4979-8ff8-67034172985d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" or the like. Such acts lead to the \",\"attrs\":{\"start\":312,\"end\":348}},{\"type\":\"text\",\"text\":\"Hell of Ultimate Torment\",\"attrs\":{\"start\":348,\"end\":372},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8f5efab1-1d55-410b-b89a-af49ca7d6f7d\",\"uuid\":\"a56026df-de81-4cc9-af85-3a5df744f288\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". \",\"attrs\":{\"start\":372,\"end\":374}},{\"type\":\"text\",\"text\":\"Intermediate \",\"attrs\":{\"start\":374,\"end\":387},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":374,\"end\":394,\"uuid\":\"b659d391-fe8c-4f83-8945-18d9974b8ed8\",\"type\":\"span\",\"textStyle\":\"distinct\"}}]},{\"type\":\"text\",\"text\":\"killing\",\"attrs\":{\"start\":387,\"end\":394},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":387,\"end\":394,\"uuid\":\"b659d391-fe8c-4f83-8945-18d9974b8ed8\",\"type\":\"span\",\"textStyle\":\"distinct\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"765a595f-12c6-4f20-9dfc-8c1d9d2bb9b2\",\"uuid\":\"a0a8e446-4902-4a3c-8845-9e323bdb4e89\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" occurs when one murders someone on the path. \",\"attrs\":{\"start\":394,\"end\":440}},{\"type\":\"text\",\"text\":\"Minor \",\"attrs\":{\"start\":440,\"end\":446},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":440,\"end\":453,\"uuid\":\"bee785c5-cc29-498e-86a2-5e10e641fc9b\",\"type\":\"span\",\"textStyle\":\"distinct\"}}]},{\"type\":\"text\",\"text\":\"killing\",\"attrs\":{\"start\":446,\"end\":453},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":446,\"end\":453,\"uuid\":\"bee785c5-cc29-498e-86a2-5e10e641fc9b\",\"type\":\"span\",\"textStyle\":\"distinct\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"765a595f-12c6-4f20-9dfc-8c1d9d2bb9b2\",\"uuid\":\"ab928790-6aff-4d3d-8302-4bfe87fc39cb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is to kill an \",\"attrs\":{\"start\":453,\"end\":468}},{\"type\":\"text\",\"text\":\"animal\",\"attrs\":{\"start\":468,\"end\":474},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"49e78f8f-4702-4a65-846b-a7e3bc5ee165\",\"uuid\":\"d4009818-c303-432f-ba3c-94441246248d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" or someone of degenerate moral conduct.\",\"attrs\":{\"start\":474,\"end\":514}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"e1318ecd-3841-488e-a551-40eae62678d4\",\"sort\":788,\"type\":\"translation\",\"label\":\"1.2\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":543,\"uuid\":\"e1318ecd-3841-488e-a551-40eae62678d4\"},\"content\":[{\"type\":\"text\",\"text\":\"“An act of \",\"attrs\":{\"start\":0,\"end\":11}},{\"type\":\"text\",\"text\":\"killing\",\"attrs\":{\"start\":11,\"end\":18},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"765a595f-12c6-4f20-9dfc-8c1d9d2bb9b2\",\"uuid\":\"ffcd9556-c683-438f-9c39-7b1dc4e4c2be\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" can also be categorized with respect to the past, future, or present, or in terms of whether that act is carried out due to desire, anger, or delusion. Of these latter, \",\"attrs\":{\"start\":18,\"end\":188}},{\"type\":\"text\",\"text\":\"killing\",\"attrs\":{\"start\":188,\"end\":195},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":188,\"end\":209,\"uuid\":\"0ee6cb91-554b-4fbb-a9e8-f1573a88a8c4\",\"type\":\"span\",\"textStyle\":\"distinct\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"765a595f-12c6-4f20-9dfc-8c1d9d2bb9b2\",\"uuid\":\"369a76a4-aec8-4b69-a5e3-67882e37a295\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" out of desire\",\"attrs\":{\"start\":195,\"end\":209},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":195,\"end\":209,\"uuid\":\"0ee6cb91-554b-4fbb-a9e8-f1573a88a8c4\",\"type\":\"span\",\"textStyle\":\"distinct\"}}]},{\"type\":\"text\",\"text\":\" occurs in hunting deer and other game. \",\"attrs\":{\"start\":209,\"end\":249}},{\"type\":\"text\",\"text\":\"Killing\",\"attrs\":{\"start\":249,\"end\":256},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":249,\"end\":270,\"uuid\":\"f349d66d-9684-40ea-8c0c-c3d4902c7417\",\"type\":\"span\",\"textStyle\":\"distinct\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"765a595f-12c6-4f20-9dfc-8c1d9d2bb9b2\",\"uuid\":\"88e21e7e-ecc2-4e18-a166-f189b73baaba\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" out of hatred\",\"attrs\":{\"start\":256,\"end\":270},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":256,\"end\":270,\"uuid\":\"f349d66d-9684-40ea-8c0c-c3d4902c7417\",\"type\":\"span\",\"textStyle\":\"distinct\"}}]},{\"type\":\"text\",\"text\":\" occurs in killing a snake, a mongoose, or the like. \",\"attrs\":{\"start\":270,\"end\":323}},{\"type\":\"text\",\"text\":\"Killing\",\"attrs\":{\"start\":323,\"end\":330},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":323,\"end\":346,\"uuid\":\"719b638c-8a71-4f8d-880f-4431e455f638\",\"type\":\"span\",\"textStyle\":\"distinct\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"765a595f-12c6-4f20-9dfc-8c1d9d2bb9b2\",\"uuid\":\"73d07a71-c28a-413f-992c-739569151f18\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" due to delusion\",\"attrs\":{\"start\":330,\"end\":346},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":330,\"end\":346,\"uuid\":\"719b638c-8a71-4f8d-880f-4431e455f638\",\"type\":\"span\",\"textStyle\":\"distinct\"}}]},{\"type\":\"text\",\"text\":\" occurs in sacrificial \",\"attrs\":{\"start\":346,\"end\":369}},{\"type\":\"text\",\"text\":\"killings\",\"attrs\":{\"start\":369,\"end\":377},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"765a595f-12c6-4f20-9dfc-8c1d9d2bb9b2\",\"uuid\":\"d2db75fd-fef9-4ef0-81df-86ee82da559b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and the like. \",\"attrs\":{\"start\":377,\"end\":392}},{\"type\":\"text\",\"text\":\"Killing\",\"attrs\":{\"start\":392,\"end\":399},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"765a595f-12c6-4f20-9dfc-8c1d9d2bb9b2\",\"uuid\":\"7e74784d-8bae-40d4-bc03-7a07ccf821be\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" can likewise be categorized in terms of acts done by oneself, acts ordered by others, and acts done both by oneself and on the order of others.\",\"attrs\":{\"start\":399,\"end\":543}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"f7ad965d-c23f-4ded-9c58-48fb6a396138\",\"sort\":809,\"type\":\"translation\",\"label\":\"1.3\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":556,\"uuid\":\"a0d73faf-ef19-4fa1-a049-592582c63fc7\"},\"content\":[{\"type\":\"text\",\"text\":\"“In five cases \",\"attrs\":{\"start\":0,\"end\":15}},{\"type\":\"text\",\"text\":\"killing\",\"attrs\":{\"start\":15,\"end\":22},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"765a595f-12c6-4f20-9dfc-8c1d9d2bb9b2\",\"uuid\":\"2300b658-ca10-4b67-a518-9ec489e37ca6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" will not incur any stain of evil: unwittingly killing insects, ants, and so forth that happen to be in one’s a path; unintentionally striking and killing someone with a weapon; dispensing the wrong type of medicine to a sick person, thereby accidently causing the person’s death while trying to help; as a mother, causing the death of one’s child by disciplinary beating; and unintentionally causing living beings to die due to their falling into fire. When \",\"attrs\":{\"start\":22,\"end\":481}},{\"type\":\"text\",\"text\":\"killing\",\"attrs\":{\"start\":481,\"end\":488},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"765a595f-12c6-4f20-9dfc-8c1d9d2bb9b2\",\"uuid\":\"f9be74fb-f678-4d46-817a-a27ce4d935f5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" occurs under these five circumstances there will not be any stain. \",\"attrs\":{\"start\":488,\"end\":556}}]},{\"type\":\"paragraph\",\"attrs\":{\"start\":556,\"end\":703,\"uuid\":\"4ef6de82-b731-4c59-934a-cb72738d9fcf\"},\"content\":[{\"type\":\"text\",\"text\":\"“Further, \",\"attrs\":{\"start\":556,\"end\":566}},{\"type\":\"text\",\"text\":\"killing\",\"attrs\":{\"start\":566,\"end\":573},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"765a595f-12c6-4f20-9dfc-8c1d9d2bb9b2\",\"uuid\":\"b0649d6e-66a5-4aee-a01f-ba7784430d54\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" may take place, again in three ways, by contracting others to do it, by performing the deed oneself, or by both of these methods.\",\"attrs\":{\"start\":573,\"end\":703}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"87fd63ce-ccf1-497a-9a22-35bd717acedc\",\"sort\":822,\"type\":\"translation\",\"label\":\"1.4\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":345,\"uuid\":\"87fd63ce-ccf1-497a-9a22-35bd717acedc\"},\"content\":[{\"type\":\"text\",\"text\":\"“What is understood by a complete act of \",\"attrs\":{\"start\":0,\"end\":41}},{\"type\":\"text\",\"text\":\"stealing\",\"attrs\":{\"start\":41,\"end\":49},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":41,\"end\":49,\"uuid\":\"8e94d662-49d9-40f8-bd39-bbb499ae5bbf\",\"type\":\"span\",\"textStyle\":\"distinct\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9ad933f8-ddbc-4390-be33-dfde30d736b8\",\"uuid\":\"84dd33b3-9231-408c-afb5-38040176e21a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"? A spiritual practitioner, who observes and adheres to the Dharma, may understand this through having received teachings or having seen it to be the case by means of the \",\"attrs\":{\"start\":49,\"end\":220}},{\"type\":\"text\",\"text\":\"divine eye\",\"attrs\":{\"start\":220,\"end\":230},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bfe4d6ca-3e0f-4dde-a8bb-7c5149937f8b\",\"uuid\":\"5400f682-6c0b-4dcd-9b14-69b6d2cc1d7e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". A complete act of \",\"attrs\":{\"start\":230,\"end\":250}},{\"type\":\"text\",\"text\":\"stealing\",\"attrs\":{\"start\":250,\"end\":258},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9ad933f8-ddbc-4390-be33-dfde30d736b8\",\"uuid\":\"2c951067-a5f6-4d89-805b-3bdab7ff30e7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is to rob something that belongs to another with the intention of making it one’s own.\",\"attrs\":{\"start\":258,\"end\":345}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"eee2ce1b-53be-455d-9305-ff91096ea141\",\"sort\":830,\"type\":\"translation\",\"label\":\"1.5\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":983,\"uuid\":\"eee2ce1b-53be-455d-9305-ff91096ea141\"},\"content\":[{\"type\":\"text\",\"text\":\"“Which acts of this kind will have a minor effect? If one takes what was not given due to compliance with a royal decree; or if one takes what was not given for the sake of one’s guru, one’s sick parents, a \",\"attrs\":{\"start\":0,\"end\":207}},{\"type\":\"text\",\"text\":\"solitary buddha\",\"attrs\":{\"start\":207,\"end\":222},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c1a27d3a-9591-4376-8678-41d3848a2125\",\"uuid\":\"ff4f68b8-d739-4511-bfb5-f763e4c479d2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", a \",\"attrs\":{\"start\":222,\"end\":226}},{\"type\":\"text\",\"text\":\"worthy one\",\"attrs\":{\"start\":226,\"end\":236},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"69eec99c-d322-425f-bc83-85bb4b1e65ae\",\"uuid\":\"1502b487-f339-4316-b346-a5b149f0f67b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", a \",\"attrs\":{\"start\":236,\"end\":240}},{\"type\":\"text\",\"text\":\"non-returner\",\"attrs\":{\"start\":240,\"end\":252},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"94d8406a-bac9-4175-907c-5a3a958b0b08\",\"uuid\":\"c626aa1d-db3e-46b4-b54f-7964a333f8b7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", a \",\"attrs\":{\"start\":252,\"end\":256}},{\"type\":\"text\",\"text\":\"stream enterer\",\"attrs\":{\"start\":256,\"end\":270},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"0a98e45a-a574-4af4-ac8b-f1736bbc0687\",\"uuid\":\"74892640-8d39-4762-88ec-e023121d4cd7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", or the like; or if one does so for the sake of the sick or the hungry. In such cases there will be a minor \",\"attrs\":{\"start\":270,\"end\":379}},{\"type\":\"text\",\"text\":\"ripening\",\"attrs\":{\"start\":379,\"end\":387},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e6c5ad9a-9509-4706-9d6f-5fad607030a7\",\"uuid\":\"316a4722-8c2d-43b9-86e1-03187dd14597\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of the act. Such cases of \",\"attrs\":{\"start\":387,\"end\":414}},{\"type\":\"text\",\"text\":\"taking what was not given\",\"attrs\":{\"start\":414,\"end\":439},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7169b9fd-d93b-43b7-af46-5708360b5712\",\"uuid\":\"366eb843-6849-484a-92cf-23f26fe6ea42\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", when performed by someone who has not taken vows to \",\"attrs\":{\"start\":439,\"end\":493}},{\"type\":\"text\",\"text\":\"take what was not given\",\"attrs\":{\"start\":493,\"end\":516},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7169b9fd-d93b-43b7-af46-5708360b5712\",\"uuid\":\"43ac04a0-ffeb-4025-9531-84f277046153\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", also involve only a minor \",\"attrs\":{\"start\":516,\"end\":544}},{\"type\":\"text\",\"text\":\"ripening\",\"attrs\":{\"start\":544,\"end\":552},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e6c5ad9a-9509-4706-9d6f-5fad607030a7\",\"uuid\":\"7f264db4-f928-4a70-82b7-111e30bb14df\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Minor effects will also arise when one takes what was not given, but then mentally confesses, feels remorse, and abstains in the future, and when one prevents others from \",\"attrs\":{\"start\":552,\"end\":725}},{\"type\":\"text\",\"text\":\"taking what was not given\",\"attrs\":{\"start\":725,\"end\":750},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7169b9fd-d93b-43b7-af46-5708360b5712\",\"uuid\":\"a8c7b403-c87c-4c16-91a6-65f6783e5079\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", confers vows upon them, establishes them upon the path, and establishes them in the practice of abstaining from \",\"attrs\":{\"start\":750,\"end\":864}},{\"type\":\"text\",\"text\":\"taking what was not given\",\"attrs\":{\"start\":864,\"end\":889},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7169b9fd-d93b-43b7-af46-5708360b5712\",\"uuid\":\"6c956769-5084-4994-9d0c-b34155a67952\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Similarly, only minor effects occur when the preparations, act, or conclusion is incomplete.\",\"attrs\":{\"start\":889,\"end\":983}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"93991d79-5de4-44d1-8771-1974e7c4cd9f\",\"sort\":854,\"type\":\"translation\",\"label\":\"1.6\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":646,\"uuid\":\"93991d79-5de4-44d1-8771-1974e7c4cd9f\"},\"content\":[{\"type\":\"text\",\"text\":\"“What are the preparations for \",\"attrs\":{\"start\":0,\"end\":31}},{\"type\":\"text\",\"text\":\"stealing\",\"attrs\":{\"start\":31,\"end\":39},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9ad933f8-ddbc-4390-be33-dfde30d736b8\",\"uuid\":\"760e643f-67bd-48ad-a6d7-bcdf02d7800d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"? They involve deceiving the victim, giving secret instructions, engaging in fraud, or some other form of inappropriate activity. What is the act itself? It is to take the possessions of another without them being given. What is the act’s conclusion? This consists in rejoicing in, becoming habituated to, and increasing the act; rejoicing in the act while keeping it hidden; and making other disciplined individuals engage in such an act. When a misdeed of \",\"attrs\":{\"start\":39,\"end\":497}},{\"type\":\"text\",\"text\":\"stealing\",\"attrs\":{\"start\":497,\"end\":505},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9ad933f8-ddbc-4390-be33-dfde30d736b8\",\"uuid\":\"6586d625-0478-41da-b5dd-227ec61d683a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" lacks any of these three aspects, which include preparations and conclusion, its effect will be minor and experienced in indeterminate ways.\",\"attrs\":{\"start\":505,\"end\":646}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"61b574da-daf5-49c3-b6f2-b68883d4d1a7\",\"sort\":860,\"type\":\"translation\",\"label\":\"1.7\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":390,\"uuid\":\"61b574da-daf5-49c3-b6f2-b68883d4d1a7\"},\"content\":[{\"type\":\"text\",\"text\":\"“What is \",\"attrs\":{\"start\":0,\"end\":9}},{\"type\":\"text\",\"text\":\"sexual misconduct\",\"attrs\":{\"start\":9,\"end\":26},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":9,\"end\":26,\"uuid\":\"6fb9be4c-074b-4426-90f8-0e9cbe877b3d\",\"type\":\"span\",\"textStyle\":\"distinct\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9db826d-bfc2-49ef-a9b0-bbe70bf16d26\",\"uuid\":\"1ba97ffa-a6f0-4244-b3e4-545d20906724\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"? This is understood by a spiritual practitioner who observes phenomena. Such a person will see that \",\"attrs\":{\"start\":26,\"end\":127}},{\"type\":\"text\",\"text\":\"sexual misconduct\",\"attrs\":{\"start\":127,\"end\":144},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9db826d-bfc2-49ef-a9b0-bbe70bf16d26\",\"uuid\":\"6dac54bd-9f7f-4e60-817c-e7341b8301a5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" occurs when one penetrates one’s own wife, or another man’s wife, through an opening other than the vagina, or when one rejoices in others performing such an act, or when one makes others engage in it even while refraining from doing so oneself.\",\"attrs\":{\"start\":144,\"end\":390}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"6d79f4c1-b4a3-4b34-8a15-b7e13733f592\",\"sort\":866,\"type\":\"translation\",\"label\":\"1.8\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":527,\"uuid\":\"6d79f4c1-b4a3-4b34-8a15-b7e13733f592\"},\"content\":[{\"type\":\"text\",\"text\":\"“In which cases will the effects of \",\"attrs\":{\"start\":0,\"end\":36}},{\"type\":\"text\",\"text\":\"sexual misconduct\",\"attrs\":{\"start\":36,\"end\":53},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9db826d-bfc2-49ef-a9b0-bbe70bf16d26\",\"uuid\":\"de1285df-f3c1-4827-b6da-a9b50c45058e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" be minor? When the act is regretted and confessed, when one does not rejoice in it, when one discourages others from engaging in \",\"attrs\":{\"start\":53,\"end\":183}},{\"type\":\"text\",\"text\":\"sexual misconduct\",\"attrs\":{\"start\":183,\"end\":200},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9db826d-bfc2-49ef-a9b0-bbe70bf16d26\",\"uuid\":\"bc261537-4a63-448b-8f19-baea55357268\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and establishes them on the path, and when the preparation or conclusion is incomplete. When such factors of intention and discipline are present the effects of an act of \",\"attrs\":{\"start\":200,\"end\":372}},{\"type\":\"text\",\"text\":\"sexual misconduct\",\"attrs\":{\"start\":372,\"end\":389},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9db826d-bfc2-49ef-a9b0-bbe70bf16d26\",\"uuid\":\"b57043d7-6cae-40d2-a898-9bcaed3dc4be\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" will be minor and their experience indeterminate. When the three misdeeds of the body are of this kind their effects are lesser and weak.\",\"attrs\":{\"start\":389,\"end\":527}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"cf0eda16-07df-41c0-983f-0607a1e174ba\",\"sort\":876,\"type\":\"translation\",\"label\":\"1.9\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":441,\"uuid\":\"cf0eda16-07df-41c0-983f-0607a1e174ba\"},\"content\":[{\"type\":\"text\",\"text\":\"“Only those who hear these points from my \",\"attrs\":{\"start\":0,\"end\":42}},{\"type\":\"text\",\"text\":\"hearers\",\"attrs\":{\"start\":42,\"end\":49},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5a90184b-4c5f-424b-8a34-4d859dc83b2f\",\"uuid\":\"0dabcc76-1af8-4187-9da4-08cf0673d86f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" or from myself will understand the whole matter of karmic actions and their \",\"attrs\":{\"start\":49,\"end\":126}},{\"type\":\"text\",\"text\":\"ripening\",\"attrs\":{\"start\":126,\"end\":134},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e6c5ad9a-9509-4706-9d6f-5fad607030a7\",\"uuid\":\"750ccd52-1f57-43d1-917a-0ac78dfa3b25\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" effects. Thus, they will not be swayed by the accounts of others, but become independent. These points are not realized by wandering \",\"attrs\":{\"start\":134,\"end\":268}},{\"type\":\"text\",\"text\":\"non-Buddhist\",\"attrs\":{\"start\":268,\"end\":280},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"02f4d334-0e69-4600-a543-0dcea128cf23\",\"uuid\":\"2a469fb4-f316-4ad7-86ac-aad5f267f26f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" practitioners. Neither are they realized by the world with its \",\"attrs\":{\"start\":280,\"end\":344}},{\"type\":\"text\",\"text\":\"gods\",\"attrs\":{\"start\":344,\"end\":348},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"001a0a5f-1d64-4686-98cb-d50f70cca517\",\"uuid\":\"a064794c-3c45-422d-a8ab-60d925743ab1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"; nor by the \",\"attrs\":{\"start\":348,\"end\":361}},{\"type\":\"text\",\"text\":\"māras\",\"attrs\":{\"start\":361,\"end\":366},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"be33ec74-6b07-494d-b35c-c7fde200b8ac\",\"uuid\":\"6cea6d25-9c12-444b-b893-506f4e101868\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"; nor by \",\"attrs\":{\"start\":366,\"end\":375}},{\"type\":\"text\",\"text\":\"Brahmā\",\"attrs\":{\"start\":375,\"end\":381},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e4d3cd20-fd11-455c-844e-c5bb18b89e36\",\"uuid\":\"ba1513c1-6c80-4228-b8fb-09320897b083\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":381,\"end\":383}},{\"type\":\"text\",\"text\":\"mendicants\",\"attrs\":{\"start\":383,\"end\":393},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"02bd7ac1-47d5-418a-80ad-998f2aa21c76\",\"uuid\":\"0bdf8951-3bab-4625-a2bc-9ced151800f2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and \",\"attrs\":{\"start\":393,\"end\":399}},{\"type\":\"text\",\"text\":\"brahmins\",\"attrs\":{\"start\":399,\"end\":407},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d2beaf90-2596-4dcc-b765-8064c0cba1f3\",\"uuid\":\"51ad8a98-79e0-4dbf-a01e-c54ff11cf976\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"; nor by \",\"attrs\":{\"start\":407,\"end\":416}},{\"type\":\"text\",\"text\":\"gods\",\"attrs\":{\"start\":416,\"end\":420},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"001a0a5f-1d64-4686-98cb-d50f70cca517\",\"uuid\":\"e84b7d43-00a5-4664-a35d-8aa9eebfa930\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", humans, and \",\"attrs\":{\"start\":420,\"end\":434}},{\"type\":\"text\",\"text\":\"asuras\",\"attrs\":{\"start\":434,\"end\":440},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5f1024e5-d735-4094-89c8-9a8baec55fd2\",\"uuid\":\"0278f985-9bb5-49e2-b7d6-4a51d78fce28\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":440,\"end\":441}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"a4498e1b-4e01-412d-924b-d63f29776f62\",\"sort\":898,\"type\":\"translation\",\"label\":\"1.10\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":229,\"uuid\":\"a4498e1b-4e01-412d-924b-d63f29776f62\"},\"content\":[{\"type\":\"text\",\"text\":\"“What are the misdeeds of speech? Spiritual practitioners who understand phenomena, as well as karmic actions and their maturation, will know that there are four misdeeds of speech: \",\"attrs\":{\"start\":0,\"end\":182}},{\"type\":\"text\",\"text\":\"lying\",\"attrs\":{\"start\":182,\"end\":187},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9d9ddb6c-fc25-472b-8d22-bd6defd1b514\",\"uuid\":\"a4c0620c-fadf-491d-a7ae-e507b501b3e1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":187,\"end\":189}},{\"type\":\"text\",\"text\":\"divisive talk\",\"attrs\":{\"start\":189,\"end\":202},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"12b408c6-c323-4da1-b5b2-76d8f03e4237\",\"uuid\":\"d03a70e5-7b19-409e-b287-37c12beee988\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":202,\"end\":204}},{\"type\":\"text\",\"text\":\"harsh words\",\"attrs\":{\"start\":204,\"end\":215},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ec8f7f40-6c08-41c1-abc2-6cce205065e8\",\"uuid\":\"4229a5c6-eb50-40e2-af63-82c942bc3e4f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and \",\"attrs\":{\"start\":215,\"end\":221}},{\"type\":\"text\",\"text\":\"chatter\",\"attrs\":{\"start\":221,\"end\":228},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"aef12735-469a-4df0-8077-5d9f44c812e4\",\"uuid\":\"eab22084-92e5-4b94-9c6d-7b644d98d21f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":228,\"end\":229}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"81133732-93c0-4b6b-bc13-051c5a25f546\",\"sort\":908,\"type\":\"translation\",\"label\":\"1.11\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":284,\"uuid\":\"81133732-93c0-4b6b-bc13-051c5a25f546\"},\"content\":[{\"type\":\"text\",\"text\":\"“What is \",\"attrs\":{\"start\":0,\"end\":9}},{\"type\":\"text\",\"text\":\"lying\",\"attrs\":{\"start\":9,\"end\":14},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":9,\"end\":14,\"uuid\":\"42c39482-b3c9-49e0-ba25-b5977d75d3e4\",\"type\":\"span\",\"textStyle\":\"distinct\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9d9ddb6c-fc25-472b-8d22-bd6defd1b514\",\"uuid\":\"0743b705-48f1-4435-885b-3d1048dd8d6c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"? \",\"attrs\":{\"start\":14,\"end\":16}},{\"type\":\"text\",\"text\":\"Lying\",\"attrs\":{\"start\":16,\"end\":21},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9d9ddb6c-fc25-472b-8d22-bd6defd1b514\",\"uuid\":\"9b49bb7b-7781-4d25-9f99-89952a13091e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is to deceive oneself and others. Thus, when one expresses false complaints before a king or minister and so unjustly brings harm or ruin upon others, that constitutes a complete verbal misdeed of \",\"attrs\":{\"start\":21,\"end\":219}},{\"type\":\"text\",\"text\":\"lying\",\"attrs\":{\"start\":219,\"end\":224},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9d9ddb6c-fc25-472b-8d22-bd6defd1b514\",\"uuid\":\"08eebba9-bf79-4c51-9965-7a359705c721\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Such acts lead sentient beings to experience life in hell.\",\"attrs\":{\"start\":224,\"end\":284}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"b0193d6d-491b-4f9e-a07d-539870fe1412\",\"sort\":916,\"type\":\"translation\",\"label\":\"1.12\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":470,\"uuid\":\"b0193d6d-491b-4f9e-a07d-539870fe1412\"},\"content\":[{\"type\":\"text\",\"text\":\"“What is the misdeed of speech known as \",\"attrs\":{\"start\":0,\"end\":40}},{\"type\":\"text\",\"text\":\"divisive talk\",\"attrs\":{\"start\":40,\"end\":53},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"12b408c6-c323-4da1-b5b2-76d8f03e4237\",\"uuid\":\"df1c0327-7085-47fd-b020-35ec83c54055\",\"toh\":null,\"start\":40,\"end\":0}},{\"type\":\"italic\",\"attrs\":{\"start\":40,\"end\":53,\"uuid\":\"2b744d29-5d83-49cd-a4d9-69d5f7653bcd\",\"type\":\"span\",\"textStyle\":\"distinct\"}}]},{\"type\":\"text\",\"text\":\"? If, with the intention to sow discord, one speaks to a group that is otherwise in agreement on a certain subject, that is a verbal misdeed of \",\"attrs\":{\"start\":53,\"end\":197}},{\"type\":\"text\",\"text\":\"divisive talk\",\"attrs\":{\"start\":197,\"end\":210},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"12b408c6-c323-4da1-b5b2-76d8f03e4237\",\"uuid\":\"dbdc89c2-ba69-4416-838d-375d26e32bb5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". How can the effects of \",\"attrs\":{\"start\":210,\"end\":235}},{\"type\":\"text\",\"text\":\"divisive talk\",\"attrs\":{\"start\":235,\"end\":248},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"12b408c6-c323-4da1-b5b2-76d8f03e4237\",\"uuid\":\"a42d7e54-3377-46c6-b840-ea9789109baf\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" be lessened? By confession, thinking, ‘In my delusion I have done wrong!’; by hindering those who delight in sowing discord and by establishing them on the path; or by refraining from the act’s preparations or conclusion.\",\"attrs\":{\"start\":248,\"end\":470}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"d4c6e582-ed04-44e2-b2ec-862980114c0e\",\"sort\":924,\"type\":\"translation\",\"label\":\"1.13\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":812,\"uuid\":\"d4c6e582-ed04-44e2-b2ec-862980114c0e\"},\"content\":[{\"type\":\"text\",\"text\":\"“What are the preparations for such an act? They consist in speaking to others out of a delight in sowing discord and the \",\"attrs\":{\"start\":0,\"end\":122}},{\"type\":\"text\",\"text\":\"affliction\",\"attrs\":{\"start\":122,\"end\":132},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9a4b2555-d9c2-41b4-a5c0-2a8a0a115fa5\",\"uuid\":\"05d9d8cd-56bd-4d0b-9889-0315ca1d1864\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of haughtiness. What is the course of action in terms of \",\"attrs\":{\"start\":132,\"end\":190}},{\"type\":\"text\",\"text\":\"divisive talk\",\"attrs\":{\"start\":190,\"end\":203},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"12b408c6-c323-4da1-b5b2-76d8f03e4237\",\"uuid\":\"c074e03b-1648-41fa-9c71-f9c28f7968cf\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"? It is to repeatedly rejoice and delight in disharmony based on an aggressive mind. When is the conclusion of such an act complete? It is complete when one rejoices in a performed act of \",\"attrs\":{\"start\":203,\"end\":391}},{\"type\":\"text\",\"text\":\"divisive talk\",\"attrs\":{\"start\":391,\"end\":404},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"12b408c6-c323-4da1-b5b2-76d8f03e4237\",\"uuid\":\"3bee1e75-783f-4002-bd45-7b937de8d4d0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"; when one anticipates further, repeated engagements in such acts with excitement and pleasure; and when one does not wish to rectify this inclination. This mental state is one of aggression. When examined by others, one will be deemed untrustworthy and scorned. Such an act exposes one as being shameless and without any sense of embarrassment or self-criticism. This is the verbal misdeed of \",\"attrs\":{\"start\":404,\"end\":798}},{\"type\":\"text\",\"text\":\"divisive talk\",\"attrs\":{\"start\":798,\"end\":811},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"12b408c6-c323-4da1-b5b2-76d8f03e4237\",\"uuid\":\"984b16df-b150-4d3d-b695-d72ca239c120\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":811,\"end\":812}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"1682aabf-79aa-4c25-9717-66e8f4d3895c\",\"sort\":936,\"type\":\"translation\",\"label\":\"1.14\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":702,\"uuid\":\"1682aabf-79aa-4c25-9717-66e8f4d3895c\"},\"content\":[{\"type\":\"text\",\"text\":\"“What is the misdeed of \",\"attrs\":{\"start\":0,\"end\":24}},{\"type\":\"text\",\"text\":\"harsh words\",\"attrs\":{\"start\":24,\"end\":35},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":24,\"end\":35,\"uuid\":\"c913b441-288e-4786-bd4b-11101004d654\",\"type\":\"span\",\"textStyle\":\"distinct\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ec8f7f40-6c08-41c1-abc2-6cce205065e8\",\"uuid\":\"96ab7ac3-2cdd-457b-8114-1752a4e354bf\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"? Spiritual practitioners who see phenomena, karmic actions, and their origin will understand this by means of knowledge derived from hearing. In this regard, \",\"attrs\":{\"start\":35,\"end\":194}},{\"type\":\"text\",\"text\":\"harsh words\",\"attrs\":{\"start\":194,\"end\":205},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ec8f7f40-6c08-41c1-abc2-6cce205065e8\",\"uuid\":\"939a56b0-0a7e-4228-8afb-44d1acf31381\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" bring harm to oneself and impact others by creating the occasion for them to hear unpleasant words. Such acts ripen in various ways, depending on whether they were concealed or confessed, or whether they were done in a spirit of jest or malice. The severe forms of \",\"attrs\":{\"start\":205,\"end\":471}},{\"type\":\"text\",\"text\":\"harsh words\",\"attrs\":{\"start\":471,\"end\":482},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ec8f7f40-6c08-41c1-abc2-6cce205065e8\",\"uuid\":\"ae7cf95b-6c94-426d-81c8-9083e2230b34\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" cause the experience of life in hell, yet through confession the resultant experience can become indeterminate. This is the third verbal misdeed. The preparations, conclusion, and full possession are as described above.\",\"attrs\":{\"start\":482,\"end\":702}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"7a9954bd-639c-4a55-b69d-0615b59b6b8e\",\"sort\":944,\"type\":\"translation\",\"label\":\"1.15\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":299,\"uuid\":\"7a9954bd-639c-4a55-b69d-0615b59b6b8e\"},\"content\":[{\"type\":\"text\",\"text\":\"“What is the fourth verbal misdeed? Spiritual practitioners who comprehend numerous forms of karmic action, phenomena, and \",\"attrs\":{\"start\":0,\"end\":123}},{\"type\":\"text\",\"text\":\"ripening\",\"attrs\":{\"start\":123,\"end\":131},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e6c5ad9a-9509-4706-9d6f-5fad607030a7\",\"uuid\":\"f9ee76e5-baa6-484b-bfbe-26e165b60bb4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" recognize \",\"attrs\":{\"start\":131,\"end\":142}},{\"type\":\"text\",\"text\":\"chatter\",\"attrs\":{\"start\":142,\"end\":149},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":142,\"end\":149,\"uuid\":\"3c5f7b8b-07ec-4be5-a2a3-a1288717083d\",\"type\":\"span\",\"textStyle\":\"distinct\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"aef12735-469a-4df0-8077-5d9f44c812e4\",\"uuid\":\"d7330259-6aac-48a0-89e0-bd09f0950abb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" to be pointless and unrelated babble. The resultant experiences are indeterminate, and the act involves less evil. Such is the fourth verbal misdeed.\",\"attrs\":{\"start\":149,\"end\":299}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"cf4a8bf7-2b0f-4522-a5d2-f13fbbc44818\",\"sort\":952,\"type\":\"translation\",\"label\":\"1.16\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":451,\"uuid\":\"cf4a8bf7-2b0f-4522-a5d2-f13fbbc44818\"},\"content\":[{\"type\":\"text\",\"text\":\"“What are mental misdeeds, and how many of them are there? Spiritual practitioners who consider karmic action, phenomena, and \",\"attrs\":{\"start\":0,\"end\":126}},{\"type\":\"text\",\"text\":\"ripening\",\"attrs\":{\"start\":126,\"end\":134},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e6c5ad9a-9509-4706-9d6f-5fad607030a7\",\"uuid\":\"efbeb8bf-b812-4d8a-a967-67974f412d35\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" know by means of knowledge derived from hearing that there are three mental misdeeds. They understand that \",\"attrs\":{\"start\":134,\"end\":242}},{\"type\":\"text\",\"text\":\"covetousness\",\"attrs\":{\"start\":242,\"end\":254},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":242,\"end\":254,\"uuid\":\"08077fb3-694d-4582-9dc2-7eb284264d1b\",\"type\":\"span\",\"textStyle\":\"distinct\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8c2659d2-1fca-40d2-bb49-a316cf575e54\",\"uuid\":\"ce73ef6d-0c22-4836-a020-6ae716416a4f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" occurs when one sees the possessions of others, and that gives rise to thinking, craving, and the idea that ‘those things should be mine.’ Such \",\"attrs\":{\"start\":254,\"end\":399}},{\"type\":\"text\",\"text\":\"covetousness\",\"attrs\":{\"start\":399,\"end\":411},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8c2659d2-1fca-40d2-bb49-a316cf575e54\",\"uuid\":\"a045cdfb-d843-485a-8f0c-cdf0f5c95ad3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is the first among the mental misdeeds.\",\"attrs\":{\"start\":411,\"end\":451}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"280eb4dc-459f-4f9a-ba3e-0d8507e1e9ca\",\"sort\":960,\"type\":\"translation\",\"label\":\"1.17\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":168,\"uuid\":\"280eb4dc-459f-4f9a-ba3e-0d8507e1e9ca\"},\"content\":[{\"type\":\"text\",\"text\":\"“There is also \",\"attrs\":{\"start\":0,\"end\":15}},{\"type\":\"text\",\"text\":\"ill will\",\"attrs\":{\"start\":15,\"end\":23},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":15,\"end\":23,\"uuid\":\"37bdccfc-c11c-46d8-9dc2-e21a924d595e\",\"type\":\"span\",\"textStyle\":\"distinct\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"6276adee-879f-4e8b-af6c-c11d910d5aaa\",\"uuid\":\"173be2f0-e241-4f58-8a94-386eb8f979b8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", which is to give rise to a hostile and aggressive state of mind when seeing others’ agreeable circumstances. That is the second mental misdeed.\",\"attrs\":{\"start\":23,\"end\":168}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"737402ab-55bf-4c6d-9b3f-3e0735740362\",\"sort\":964,\"type\":\"translation\",\"label\":\"1.18\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":470,\"uuid\":\"737402ab-55bf-4c6d-9b3f-3e0735740362\"},\"content\":[{\"type\":\"text\",\"text\":\"“The third mental misdeed is \",\"attrs\":{\"start\":0,\"end\":29}},{\"type\":\"text\",\"text\":\"wrong view\",\"attrs\":{\"start\":29,\"end\":39},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":29,\"end\":39,\"uuid\":\"97aafb64-1fc0-44e3-b9b3-1e288b6b9db1\",\"type\":\"span\",\"textStyle\":\"distinct\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5b457f37-2050-4b7a-a1bd-a4844678591e\",\"uuid\":\"54904038-dd94-439e-b1cf-3c68b5caaa22\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", a mistaken perception of things. This has two aspects: denying what is, and misunderstanding. \",\"attrs\":{\"start\":39,\"end\":135}},{\"type\":\"text\",\"text\":\"Denying what is\",\"attrs\":{\"start\":135,\"end\":150},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":135,\"end\":150,\"uuid\":\"651280a0-cffe-4dc7-a300-568901f58209\",\"type\":\"span\",\"textStyle\":\"distinct\"}}]},{\"type\":\"text\",\"text\":\" means to deny the relevance of such things as generosity, fire offerings, and sacrificial worship, or that good and bad deeds will ripen into karmic consequences. \",\"attrs\":{\"start\":150,\"end\":314}},{\"type\":\"text\",\"text\":\"Misunderstanding\",\"attrs\":{\"start\":314,\"end\":330},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":314,\"end\":330,\"uuid\":\"8289799f-adb2-4725-a207-38b0b4bf849b\",\"type\":\"span\",\"textStyle\":\"distinct\"}}]},{\"type\":\"text\",\"text\":\" is the belief that happiness and suffering are bestowed by \",\"attrs\":{\"start\":330,\"end\":390}},{\"type\":\"text\",\"text\":\"gods\",\"attrs\":{\"start\":390,\"end\":394},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"001a0a5f-1d64-4686-98cb-d50f70cca517\",\"uuid\":\"64fd83ad-cdc5-4583-a4c7-1e8c738a6b64\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and not the result of karmic action. That is the second form of \",\"attrs\":{\"start\":394,\"end\":459}},{\"type\":\"text\",\"text\":\"wrong view\",\"attrs\":{\"start\":459,\"end\":469},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5b457f37-2050-4b7a-a1bd-a4844678591e\",\"uuid\":\"6306590f-f208-4805-b86b-5c008bee7dca\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":469,\"end\":470}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"71c0745a-4144-4c83-b079-8dec058c5a4b\",\"sort\":976,\"type\":\"translation\",\"label\":\"1.19\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":591,\"uuid\":\"71c0745a-4144-4c83-b079-8dec058c5a4b\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"29c58044-5d0c-47f2-a9e8-4a55d9767cb2\"},\"content\":[{\"type\":\"text\",\"text\":\"“If one resorts to, becomes habituated to, and increases these ten misdeeds that pertain to body, speech, and mind, their consequences may become certain as they ripen in the present life. The karmic effects may also be experienced in accordance with the causal actions following one’s death and rebirth into another realm, or they may be experienced in various ways following rebirth in this realm. How is that? A spiritual practitioner who considers karmic action, phenomena, and \",\"attrs\":{\"start\":0,\"end\":482}},{\"type\":\"text\",\"text\":\"ripening\",\"attrs\":{\"start\":482,\"end\":490},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e6c5ad9a-9509-4706-9d6f-5fad607030a7\",\"uuid\":\"f4c9a6c2-b81f-49dc-a9e4-8315f6505e56\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" will understand this either through knowledge derived from hearing or by seeing with the \",\"attrs\":{\"start\":490,\"end\":580}},{\"type\":\"text\",\"text\":\"divine eye\",\"attrs\":{\"start\":580,\"end\":590},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bfe4d6ca-3e0f-4dde-a8bb-7c5149937f8b\",\"uuid\":\"dbf2bc8c-886f-47c9-b065-0d32cbe7c2c7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":590,\"end\":591}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"ddd84cc7-1545-4dac-8d34-6ad4e3a91c58\",\"sort\":982,\"type\":\"translation\",\"label\":\"1.20\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":920,\"uuid\":\"ddd84cc7-1545-4dac-8d34-6ad4e3a91c58\"},\"content\":[{\"type\":\"text\",\"text\":\"“\",\"attrs\":{\"start\":0,\"end\":1}},{\"type\":\"text\",\"text\":\"Killing\",\"attrs\":{\"start\":1,\"end\":8},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"765a595f-12c6-4f20-9dfc-8c1d9d2bb9b2\",\"uuid\":\"fba8777d-3358-405c-b6e9-2c04dd383398\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is the first of the misdeeds of the body. If one resorts to, becomes habituated to, and increases the amount of \",\"attrs\":{\"start\":8,\"end\":121}},{\"type\":\"text\",\"text\":\"killing\",\"attrs\":{\"start\":121,\"end\":128},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"765a595f-12c6-4f20-9dfc-8c1d9d2bb9b2\",\"uuid\":\"0fca3868-7500-431e-90b8-c724cccf6c13\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", one will take birth in the realms of \",\"attrs\":{\"start\":128,\"end\":167}},{\"type\":\"text\",\"text\":\"hell beings\",\"attrs\":{\"start\":167,\"end\":178},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"75490385-7dc4-45eb-a8ee-660e965e39a8\",\"uuid\":\"0f581b0e-da96-401d-93d2-a4cd26332a80\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":178,\"end\":180}},{\"type\":\"text\",\"text\":\"animals\",\"attrs\":{\"start\":180,\"end\":187},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"49e78f8f-4702-4a65-846b-a7e3bc5ee165\",\"uuid\":\"6db70d5f-4bb5-455c-8e62-94a3b56e73da\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", or \",\"attrs\":{\"start\":187,\"end\":192}},{\"type\":\"text\",\"text\":\"starving spirits\",\"attrs\":{\"start\":192,\"end\":208},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"84f73a9d-4c5c-400b-a557-976d1d6779b3\",\"uuid\":\"acea3579-931c-4c13-8387-df8cb0c4577e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Even if one is born among humans, sharing in their good fortune, one will have a short life. If, for example, one is a hunter who has killed due to attachment, one will suffer a downfall because of that. Having become a deer, pig, partridge, chicken, pheasant, fish, or the like, one will be killed by a trap or a hook. Such are the causal relationships associated with the acts of \",\"attrs\":{\"start\":208,\"end\":592}},{\"type\":\"text\",\"text\":\"killing\",\"attrs\":{\"start\":592,\"end\":599},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"765a595f-12c6-4f20-9dfc-8c1d9d2bb9b2\",\"uuid\":\"7b9b1cb7-868c-4e89-9d02-11c1e0fd6ca5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in \",\"attrs\":{\"start\":599,\"end\":603}},{\"type\":\"text\",\"text\":\"cyclic existence\",\"attrs\":{\"start\":603,\"end\":619},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7f9b4269-ecf7-4226-9cbd-3ff52a609edb\",\"uuid\":\"06ffffe8-aa39-4698-9b2f-2b55a55a83eb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Even if one is born among humans, sharing in their good fortune, one’s life will be short. One will not be born in a land of wise people and instead one’s birthplace will be plagued by many armed conflicts. There, one will soon be killed. Here is a verse on lesser, intermediate, and severe \",\"attrs\":{\"start\":619,\"end\":912}},{\"type\":\"text\",\"text\":\"killing\",\"attrs\":{\"start\":912,\"end\":919},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"765a595f-12c6-4f20-9dfc-8c1d9d2bb9b2\",\"uuid\":\"f09cb007-6499-426d-aaf2-4b2b07b7f5e7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\":\",\"attrs\":{\"start\":919,\"end\":920}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"90f9b5fa-05a3-40ed-808a-79cdb2383998\",\"sort\":1002,\"type\":\"translation\",\"label\":\"1.21\",\"alignments\":{}},\"content\":[{\"type\":\"lineGroup\",\"attrs\":{\"start\":0,\"end\":134,\"uuid\":\"9d74220e-58dd-4f7c-a1a2-414278425b7b\"},\"content\":[{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"“Some die in the womb, \",\"attrs\":{\"start\":0,\"end\":23}}],\"attrs\":{\"start\":0,\"end\":23,\"uuid\":\"6689b574-3eed-4041-bf74-469b292263bf\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"Others at childbirth, \",\"attrs\":{\"start\":23,\"end\":45}}],\"attrs\":{\"start\":23,\"end\":45,\"uuid\":\"81d70d69-2e34-4d5e-aa0d-4b75d45b3307\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"Others while only being able to crawl, \",\"attrs\":{\"start\":45,\"end\":84}}],\"attrs\":{\"start\":45,\"end\":84,\"uuid\":\"243d5f3a-e09f-4463-ba18-071a320bcfa9\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"And still others who have already learned to walk.\",\"attrs\":{\"start\":84,\"end\":134}}],\"attrs\":{\"start\":84,\"end\":134,\"uuid\":\"65a69a94-a49f-45f9-bcaf-3966b8a0bef4\"}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"071da5e1-6e3d-45b5-95a6-e5356abdd510\",\"sort\":1010,\"type\":\"translation\",\"label\":\"1.22\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":73,\"uuid\":\"071da5e1-6e3d-45b5-95a6-e5356abdd510\"},\"content\":[{\"type\":\"text\",\"text\":\"“Such is the \",\"attrs\":{\"start\":0,\"end\":13}},{\"type\":\"text\",\"text\":\"ripening\",\"attrs\":{\"start\":13,\"end\":21},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e6c5ad9a-9509-4706-9d6f-5fad607030a7\",\"uuid\":\"a87668af-f6c8-4245-bfe4-79da4253e658\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of the act of \",\"attrs\":{\"start\":21,\"end\":36}},{\"type\":\"text\",\"text\":\"killing\",\"attrs\":{\"start\":36,\"end\":43},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"765a595f-12c6-4f20-9dfc-8c1d9d2bb9b2\",\"uuid\":\"dd985730-37b1-43a1-ab57-190d75b1059f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in terms of the present life.\",\"attrs\":{\"start\":43,\"end\":73}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"f6908591-41bd-4639-bf34-19a38449ce50\",\"sort\":1016,\"type\":\"translation\",\"label\":\"1.23\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":866,\"uuid\":\"f6908591-41bd-4639-bf34-19a38449ce50\"},\"content\":[{\"type\":\"text\",\"text\":\"“Resorting to, becoming habituated to, and increasing acts of \",\"attrs\":{\"start\":0,\"end\":62}},{\"type\":\"text\",\"text\":\"stealing\",\"attrs\":{\"start\":62,\"end\":70},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9ad933f8-ddbc-4390-be33-dfde30d736b8\",\"uuid\":\"8e1c3344-331c-437a-b5d3-fd927d8c94a7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" yields three forms of \",\"attrs\":{\"start\":70,\"end\":93}},{\"type\":\"text\",\"text\":\"ripening\",\"attrs\":{\"start\":93,\"end\":101},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e6c5ad9a-9509-4706-9d6f-5fad607030a7\",\"uuid\":\"049f0aa7-d91c-463b-a9de-f6cf5372ed64\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\": the experience of life in hell, present life consequences, and concordant effects in future lives. What are these like? Spiritual practitioners who consider karmic action, phenomena, and \",\"attrs\":{\"start\":101,\"end\":290}},{\"type\":\"text\",\"text\":\"ripening\",\"attrs\":{\"start\":290,\"end\":298},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e6c5ad9a-9509-4706-9d6f-5fad607030a7\",\"uuid\":\"5f9111f4-c369-496d-929f-7c63ed4db743\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" perceive this based on the knowledge derived from hearing. If one resorts to, becomes habituated to, and increases acts of \",\"attrs\":{\"start\":298,\"end\":422}},{\"type\":\"text\",\"text\":\"stealing\",\"attrs\":{\"start\":422,\"end\":430},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9ad933f8-ddbc-4390-be33-dfde30d736b8\",\"uuid\":\"468572a8-d800-40f3-8328-d3992f6699ee\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", one will take birth in the realms of \",\"attrs\":{\"start\":430,\"end\":469}},{\"type\":\"text\",\"text\":\"hell beings\",\"attrs\":{\"start\":469,\"end\":480},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"75490385-7dc4-45eb-a8ee-660e965e39a8\",\"uuid\":\"f95887d0-6cf2-4766-8d43-b7572fc35473\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":480,\"end\":482}},{\"type\":\"text\",\"text\":\"animals\",\"attrs\":{\"start\":482,\"end\":489},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"49e78f8f-4702-4a65-846b-a7e3bc5ee165\",\"uuid\":\"811e2d86-569a-42f2-a72e-c60aa052b76c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", or \",\"attrs\":{\"start\":489,\"end\":494}},{\"type\":\"text\",\"text\":\"starving spirits\",\"attrs\":{\"start\":494,\"end\":510},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"84f73a9d-4c5c-400b-a557-976d1d6779b3\",\"uuid\":\"dffb6c73-b7a3-4bf5-8fb4-abbbab9e7454\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Even if one is born among humans, sharing in their good fortune, one will be destitute. Whatever enjoyable things one might have will be taken by punitive legislation, water, fire, weapons, robbers, or thieves. Thus, whatever one may have gathered will be wasted and what is obtained will not yield any enjoyment. These are the three effects of \",\"attrs\":{\"start\":510,\"end\":857}},{\"type\":\"text\",\"text\":\"stealing\",\"attrs\":{\"start\":857,\"end\":865},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9ad933f8-ddbc-4390-be33-dfde30d736b8\",\"uuid\":\"0a00eced-4649-499f-8938-c1fd0e553502\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":865,\"end\":866}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"a2b722ae-81b1-4b72-b3e8-1f8aea0b884d\",\"sort\":1036,\"type\":\"translation\",\"label\":\"1.24\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":633,\"uuid\":\"a2b722ae-81b1-4b72-b3e8-1f8aea0b884d\"},\"content\":[{\"type\":\"text\",\"text\":\"“What are the three effects of resorting to, becoming habituated to, and increasing acts of \",\"attrs\":{\"start\":0,\"end\":92}},{\"type\":\"text\",\"text\":\"sexual misconduct\",\"attrs\":{\"start\":92,\"end\":109},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9db826d-bfc2-49ef-a9b0-bbe70bf16d26\",\"uuid\":\"80b12aa8-5f9d-41e7-8566-46c9d3ee4b0d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"? Spiritual practitioners who observe karmic action, phenomena, and \",\"attrs\":{\"start\":109,\"end\":177}},{\"type\":\"text\",\"text\":\"ripening\",\"attrs\":{\"start\":177,\"end\":185},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e6c5ad9a-9509-4706-9d6f-5fad607030a7\",\"uuid\":\"0127914c-3c40-4653-8548-d147604afc50\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" will perceive the following either through knowledge derived from hearing or by seeing with the \",\"attrs\":{\"start\":185,\"end\":282}},{\"type\":\"text\",\"text\":\"divine eye\",\"attrs\":{\"start\":282,\"end\":292},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bfe4d6ca-3e0f-4dde-a8bb-7c5149937f8b\",\"uuid\":\"36830c0b-caaa-4b1f-9a4a-6fcbf0bcafb0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". If one resorts to, becomes habituated to, and increases acts of \",\"attrs\":{\"start\":292,\"end\":358}},{\"type\":\"text\",\"text\":\"sexual misconduct\",\"attrs\":{\"start\":358,\"end\":375},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9db826d-bfc2-49ef-a9b0-bbe70bf16d26\",\"uuid\":\"4476ba99-6ffb-4543-a0eb-36900ed6021f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", one will take birth in the realms of \",\"attrs\":{\"start\":375,\"end\":414}},{\"type\":\"text\",\"text\":\"hell beings\",\"attrs\":{\"start\":414,\"end\":425},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"75490385-7dc4-45eb-a8ee-660e965e39a8\",\"uuid\":\"34d021a0-4a6a-4a9a-a0be-94cd61349024\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":425,\"end\":427}},{\"type\":\"text\",\"text\":\"animals\",\"attrs\":{\"start\":427,\"end\":434},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"49e78f8f-4702-4a65-846b-a7e3bc5ee165\",\"uuid\":\"b76017a4-fb62-4ed8-a83d-b53932897cae\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", or \",\"attrs\":{\"start\":434,\"end\":439}},{\"type\":\"text\",\"text\":\"starving spirits\",\"attrs\":{\"start\":439,\"end\":455},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"84f73a9d-4c5c-400b-a557-976d1d6779b3\",\"uuid\":\"59788cc2-146f-40fa-88b2-de19aa5fb149\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". If one is born as a human, the causally concordant effect will be such that one’s spouse is disrespectful, one becomes a hermaphrodite, or one is held in contempt by the world.\",\"attrs\":{\"start\":455,\"end\":633}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"58b45ff9-a636-4a5e-96a8-2e828178e0bb\",\"sort\":1052,\"type\":\"translation\",\"label\":\"1.25\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":417,\"uuid\":\"58b45ff9-a636-4a5e-96a8-2e828178e0bb\"},\"content\":[{\"type\":\"text\",\"text\":\"“Such are the threefold effects of the \",\"attrs\":{\"start\":0,\"end\":39}},{\"type\":\"text\",\"text\":\"ripening\",\"attrs\":{\"start\":39,\"end\":47},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e6c5ad9a-9509-4706-9d6f-5fad607030a7\",\"uuid\":\"c53c1c0a-0210-49c2-838d-0e2ad18d292c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of the three physical misdeeds. However, the wandering \",\"attrs\":{\"start\":47,\"end\":103}},{\"type\":\"text\",\"text\":\"non-Buddhist\",\"attrs\":{\"start\":103,\"end\":115},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"02f4d334-0e69-4600-a543-0dcea128cf23\",\"uuid\":\"fa0615bd-d17a-4fb7-8baf-f905e1b24cbf\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" practitioners do not accept any of this, from the physical misdeeds up to and including their \",\"attrs\":{\"start\":115,\"end\":210}},{\"type\":\"text\",\"text\":\"ripening\",\"attrs\":{\"start\":210,\"end\":218},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e6c5ad9a-9509-4706-9d6f-5fad607030a7\",\"uuid\":\"3945dbd5-21b0-4326-95cd-7d3395cf27f7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Why is that? Because those who develop and cultivate ignorance do not perceive my teaching on karmic action, phenomena, and \",\"attrs\":{\"start\":218,\"end\":344}},{\"type\":\"text\",\"text\":\"ripening\",\"attrs\":{\"start\":344,\"end\":352},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e6c5ad9a-9509-4706-9d6f-5fad607030a7\",\"uuid\":\"304e6aa5-2c04-4747-9e47-85c0a3738a8c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". However, my \",\"attrs\":{\"start\":352,\"end\":366}},{\"type\":\"text\",\"text\":\"hearers\",\"attrs\":{\"start\":366,\"end\":373},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5a90184b-4c5f-424b-8a34-4d859dc83b2f\",\"uuid\":\"9c0d5195-2c17-4bdb-9660-2835927408eb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and my spiritual practitioners do see this.\",\"attrs\":{\"start\":373,\"end\":417}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"94c7f11b-b65a-4e8f-95a2-b773662a9d9c\",\"sort\":1064,\"type\":\"translation\",\"label\":\"1.26\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1119,\"uuid\":\"94c7f11b-b65a-4e8f-95a2-b773662a9d9c\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"877e2a6f-7555-4534-b5df-aea2a2628618\"},\"content\":[{\"type\":\"text\",\"text\":\"“Furthermore, what is meant by a spoken or verbal misdeed? What forms does it assume? Spiritual practitioners who abide by the observation of phenomena perceive four verbal misdeeds by means of knowledge derived from hearing: \",\"attrs\":{\"start\":0,\"end\":226}},{\"type\":\"text\",\"text\":\"lying\",\"attrs\":{\"start\":226,\"end\":231},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9d9ddb6c-fc25-472b-8d22-bd6defd1b514\",\"uuid\":\"0e99e058-acc3-4359-9af6-45138430e90c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":231,\"end\":233}},{\"type\":\"text\",\"text\":\"divisive talk\",\"attrs\":{\"start\":233,\"end\":246},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"12b408c6-c323-4da1-b5b2-76d8f03e4237\",\"uuid\":\"a568248d-7aa9-4406-b456-efc7d34eeca6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":246,\"end\":248}},{\"type\":\"text\",\"text\":\"harsh words\",\"attrs\":{\"start\":248,\"end\":259},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ec8f7f40-6c08-41c1-abc2-6cce205065e8\",\"uuid\":\"caedb866-2780-4c2a-849d-6dfe3b829274\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and \",\"attrs\":{\"start\":259,\"end\":265}},{\"type\":\"text\",\"text\":\"chatter\",\"attrs\":{\"start\":265,\"end\":272},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"aef12735-469a-4df0-8077-5d9f44c812e4\",\"uuid\":\"d597ff69-0749-4a76-828c-7e8b5973176b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". If one resorts to, becomes habituated to, and increases acts of \",\"attrs\":{\"start\":272,\"end\":338}},{\"type\":\"text\",\"text\":\"lying\",\"attrs\":{\"start\":338,\"end\":343},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9d9ddb6c-fc25-472b-8d22-bd6defd1b514\",\"uuid\":\"b5607a84-b9fd-4d25-beec-ae84bab161b2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" one will take birth in the realms of \",\"attrs\":{\"start\":343,\"end\":381}},{\"type\":\"text\",\"text\":\"hell beings\",\"attrs\":{\"start\":381,\"end\":392},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"75490385-7dc4-45eb-a8ee-660e965e39a8\",\"uuid\":\"060fecf6-e069-41ec-a7ad-8b4852888852\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":392,\"end\":394}},{\"type\":\"text\",\"text\":\"animals\",\"attrs\":{\"start\":394,\"end\":401},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"49e78f8f-4702-4a65-846b-a7e3bc5ee165\",\"uuid\":\"d537b426-fba0-47f2-9675-dbbd114cc71d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", or \",\"attrs\":{\"start\":401,\"end\":406}},{\"type\":\"text\",\"text\":\"starving spirits\",\"attrs\":{\"start\":406,\"end\":422},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"84f73a9d-4c5c-400b-a557-976d1d6779b3\",\"uuid\":\"03ae5cda-da03-42ef-8eb0-f92b897c17e0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Even if one is born among humans, sharing in their good fortune, others will disregard what one has to say. Nobody will listen, whether in royal courts, among householders, amid the nobility, or even in the company of one’s own children and spouse. One’s breath will carry a foul odor, and one’s teeth, mouth, complexion, and skin will be unpleasant to behold. Mistreated by all worldly individuals, one will live in perpetual fear. Family, friends, and loved ones will be unreliable. All projects one undertakes will come to naught, and one will instead be driven to pursue all sorts of meaningless activities. Such are the unattractive, ugly, and unpleasant karmic effects of the act of \",\"attrs\":{\"start\":422,\"end\":1113}},{\"type\":\"text\",\"text\":\"lying\",\"attrs\":{\"start\":1113,\"end\":1118},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9d9ddb6c-fc25-472b-8d22-bd6defd1b514\",\"uuid\":\"fb2f4f38-65d2-406b-8900-4c4423939dd2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":1118,\"end\":1119}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"68ddf2b2-7424-4cf1-b716-ea1083b77019\",\"sort\":1086,\"type\":\"translation\",\"label\":\"1.27\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":783,\"uuid\":\"68ddf2b2-7424-4cf1-b716-ea1083b77019\"},\"content\":[{\"type\":\"text\",\"text\":\"“What are the effects of resorting to, becoming habituated to, and increasing the second verbal misdeed? Spiritual practitioners who carefully observe phenomena perceive this either through knowledge derived from hearing or by seeing with the \",\"attrs\":{\"start\":0,\"end\":243}},{\"type\":\"text\",\"text\":\"divine eye\",\"attrs\":{\"start\":243,\"end\":253},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bfe4d6ca-3e0f-4dde-a8bb-7c5149937f8b\",\"uuid\":\"0d8e906c-669a-491c-8c6d-c673ea3a41df\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". If one resorts to, becomes habituated to, and increases \",\"attrs\":{\"start\":253,\"end\":311}},{\"type\":\"text\",\"text\":\"divisive talk\",\"attrs\":{\"start\":311,\"end\":324},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"12b408c6-c323-4da1-b5b2-76d8f03e4237\",\"uuid\":\"42968cfb-4fd8-4a0f-942c-edcce3369c9f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" one will take birth in the realms of \",\"attrs\":{\"start\":324,\"end\":362}},{\"type\":\"text\",\"text\":\"hell beings\",\"attrs\":{\"start\":362,\"end\":373},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"75490385-7dc4-45eb-a8ee-660e965e39a8\",\"uuid\":\"1fe6aafe-a9e4-4b8a-a5bc-af837d0e18f3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":373,\"end\":375}},{\"type\":\"text\",\"text\":\"animals\",\"attrs\":{\"start\":375,\"end\":382},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"49e78f8f-4702-4a65-846b-a7e3bc5ee165\",\"uuid\":\"ad45cd59-4fde-4948-af85-9b3094a4b32b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", or \",\"attrs\":{\"start\":382,\"end\":387}},{\"type\":\"text\",\"text\":\"starving spirits\",\"attrs\":{\"start\":387,\"end\":403},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"84f73a9d-4c5c-400b-a557-976d1d6779b3\",\"uuid\":\"c175d6cc-100a-4cda-9f61-9c3c3c2c65e4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Even if one is born among human beings, sharing in their good fortune, one may be dumb, deaf, or suffer from bad breath. Nobody will trust one’s words and one will become the laughingstock of all. One’s facial complexion will be unattractive. One will be unable to feel at ease at any single location. One’s mind will be restless yet rigid. Such is the misdeed of \",\"attrs\":{\"start\":403,\"end\":769}},{\"type\":\"text\",\"text\":\"divisive talk\",\"attrs\":{\"start\":769,\"end\":782},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"12b408c6-c323-4da1-b5b2-76d8f03e4237\",\"uuid\":\"e0910651-e