46\\\"\u003eBlack Line Hell\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Vulture Terrors\",\"tibetan\":\"བྱ་རྒོད་ཀྱི་འཇིགས་པ།\",\"sanskrit\":\"gṛdhrabhairava\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bya rgod kyi ’jigs pa\"}},{\"uuid\":\"918dd6ec-a05a-42be-b643-4e81d42ade38\",\"authority\":\"da227e27-5711-4328-b7a2-7d1cff1d9697\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of sixteen realms that surround the \u003cspan data-glossary-id=\\\"UT22084-068-021-8975\\\"\u003eCrushing Hell\u003c/span\u003e. Literally, “Cries of Woe” or “Lamenting.”\u003c/p\u003e\",\"names\":{\"english\":\"Wailer\",\"tibetan\":\"ཀྱི་ཧུད་ཟེར་བ།\",\"sanskrit\":\"hāhārava\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kyi hud zer ba\"}},{\"uuid\":\"d26a7ba2-ef7c-4aa2-be38-c70b957da543\",\"authority\":\"41de0789-5ce0-4cf7-b975-7dafa09d7d9b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAlso known as “wisdom,” “gnosis,” or the like. Typically refers to a nonconceptual or unobscured state of knowledge.\u003c/p\u003e\",\"names\":{\"english\":\"wakefulness\",\"tibetan\":\"ཡེ་ཤེས།\",\"sanskrit\":\"jñāna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ye shes\"}},{\"uuid\":\"ee22c650-69cc-4e2e-9d5c-2edc3e08bda8\",\"authority\":\"6d57beca-b466-4caa-b14f-f6b58205c562\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA class of \u003cspan data-glossary-id=\\\"UT22084-068-021-8531\\\"\u003egods\u003c/span\u003e associated with the \u003cspan data-glossary-id=\\\"UT22084-068-021-8526\\\"\u003eFour Great Kings\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"wandering\",\"tibetan\":\"ཀུན་ཏུ་རྒྱུ་བ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kun tu rgyu ba\"}},{\"uuid\":\"c01ba3bd-0eed-4ee6-9e43-5299d6fd0515\",\"authority\":\"3be48333-0041-4e2d-bc96-7dfc121494e5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn ocean between \u003cspan data-glossary-id=\\\"UT22084-068-021-9209\\\"\u003eGodānīya\u003c/span\u003e and \u003cspa