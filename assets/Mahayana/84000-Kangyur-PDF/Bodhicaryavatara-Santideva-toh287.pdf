\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"spos ’byung\"}},{\"uuid\":\"7dd80a92-cd68-4bd6-88e0-c48e4987844f\",\"authority\":\"d4859cd8-06a5-475e-bc72-ec7b1777b455\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA lotus pond on the fifth minor mountain on \u003cspan data-glossary-id=\\\"UT22084-068-021-9423\\\"\u003eLofty Summit\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Fragrant Flowers\",\"tibetan\":\"མེ་ཏོག་དྲི་ཞིམ་པ་འབྱུང་བ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"me tog dri zhim pa ’byung ba\"}},{\"uuid\":\"f62057e5-6956-4ece-bd81-c662febde0fc\",\"authority\":\"cc168bd7-cd44-4ffb-aea4-f5e04c5620dc\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA forest in \u003cspan data-glossary-id=\\\"UT22084-068-021-9513\\\"\u003eMoving Mind\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Fragrant Forest\",\"tibetan\":\"དྲི་ཞིམ་པའི་ཚལ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dri zhim pa’i tshal\"}},{\"uuid\":\"7a579516-5dae-4f01-aff0-ad255a3c415a\",\"authority\":\"669e7fbd-f834-4983-afe2-722b342e0e5d\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn island in the vicinity of \u003cspan data-glossary-id=\\\"UT22084-068-021-9338\\\"\u003eJambudvīpa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Fragrant Garlands\",\"tibetan\":\"དྲིའི་ཕྲེང་བ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dri’i phreng ba\"}},{\"uuid\":\"9d457433-3d01-4891-9dcb-eca73b5e0897\",\"authority\":\"f369d5a5-9768-44f2-b46c-8042b1eb6362\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA river on \u003cspan data-glossary-id=\\\"UT22084-068-021-9657\\\"\u003eSaṅkāśa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Fragrant Stream\",\"tibetan\":\"དྲིའི་ཆུ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dri’i chu\"}},{\"uuid\":\"ee5db1a5-b12f-456f-b6cc-debcd23be175\",\"authority\":\"dfb472b0-ad10-44c8-9403-28574a0203db\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA city in \u003cspan data-glossary-id=\\\"UT22084-068-021-9209\\\"\u003eGodānīya\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Free from Action\",\"tibetan\":\"བྱ་བ་མེད་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bya ba med pa\"}},{\"uuid\":\"597c328e-a689-4959-995a-953932301164\",\"authority\":\"7dc8277c-3667-41d7-ae8d-3f28b894f3d5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-068-021-8562\\\"\u003enāga\u003c/span\u003e who visits \u003cspan data-glossary-id=\\\"UT22084-068-021-9657\\\"\u003eSaṅkāśa\u003c/span\u003e Mountain.\u003c/p\u003e\",\"names\":{\"english\":\"Free from Anger\",\"tibetan\":\"ཁྲོ་བ་བྲལ་བ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"khro ba bral ba\"}},{\"uuid\":\"c7231732-9f18-4551-9b18-0415e0eda326\",\"authority\":\"bda0b4b8-bf95-4743-8d87-52ea16e1f4dd\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA lake on \u003cspan data-glossary-id=\\\"UT22084-068-021-9078\\\"\u003eEqual Peaks\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Free from Sand\",\"tibetan\":\"བྱེ་མས་མ་བཅོམ་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bye mas ma bcom pa\"}},{\"uuid\":\"51ea6bef-2574-4728-a987-a2d2c53e8fd3\",\"authority\":\"b6bae17d-8e1c-4f88-bc1d-49f99038a139\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the six heavens of the desire realm.\u003c/p\u003e\",\"names\":{\"english\":\"Free from Strife, Heaven Free from Strife, Yāma Heaven\",\"tibetan\":\"མཚེ་མ།, འཐབ་བྲལ།\",\"sanskrit\":\"yāma, yāma\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mtshe ma, ’thab bral\"}},{\"uuid\":\"16ff9862-f57c-4f50-a856-4949d24f439a\",\"authority\":\"b6bae17d-8e1c-4f88-bc1d-49f99038a139\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAnother name for the \u003cspan data-glossary-id=\\\"UT22084-068-021-9266\\\"\u003eHeaven Free from Strife\u003c/span\u003e, this is the third of the six heavens of the desire realm. The Tibetan literally means “twins.” The Sanskrit for this heaven is \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eYāma\u003c/em\u003e or \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eSuyāma\u003c/em\u003e, the precise meaning of which is uncertain.\u003c/p\u003e\",\"names\":{\"english\":\"Free from Strife, Heaven Free from Strife, Yāma Heaven\",\"tibetan\":\"མཚེ་མ།, འཐབ་བྲལ།\",\"sanskrit\":\"yāma, yāma\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mtshe ma, ’thab bral\"}},{\"uuid\":\"3cf703fc-46f9-478a-ab11-0cb931dbe0ed\",\"authority\":\"6c9a5605-de55-4fb1-b705-52a622736472\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA pond on \u003cspan data-glossary-id=\\\"UT22084-068-021-9078\\\"\u003eEqual Peaks\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Free from Weeds\",\"tibetan\":\"ཆུ་བལ་དང་རྣམ་པར་བྲལ་བ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chu bal dang rnam par bral ba\"}},{\"uuid\":\"5fee832a-c04b-4e96-8455-721f60cc4eaa\",\"authority\":\"daa845e4-fd9c-4173-8af8-41c7fb0a8e83\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA mansion in the forest \u003cspan data-glossary-id=\\\"UT22084-068-021-9054\\\"\u003eEndowed with Everything\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Freedom from Suffering\",\"tibetan\":\"མྱང་ངན་བྲལ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"myang ngan bral\"}},{\"uuid\":\"001dcbb1-10e2-47f7-81f9-28122eb8e25d\",\"authority\":\"b4b90294-26b5-4abd-bddc-44a2cdd27d0f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA pond on \u003cspan data-glossary-id=\\\"UT22084-068-021-9078\\\"\u003eEqual Peaks\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Frolicking\",\"tibetan\":\"རབ་ཏུ་རྩེ་བར་བྱེད་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rab tu rtse bar byed pa\"}},{\"uuid\":\"7e0609a2-2c35-4cdf-8ee4-bef1107d929d\",\"authori