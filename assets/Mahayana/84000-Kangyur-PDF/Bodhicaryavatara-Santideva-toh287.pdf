1\\\"\u003eDwelling in the Lofty\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"River of Layered Flows\",\"tibetan\":\"ཆུ་བོ་བརྩེགས་འབབ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chu bo brtsegs ’bab\"}},{\"uuid\":\"8a626cd3-0bc7-43b7-b1e6-e3786ae9ab03\",\"authority\":\"b8163262-e366-4397-acb1-a332b41112d5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA river in \u003cspan data-glossary-id=\\\"UT22084-068-021-9031\\\"\u003eDwelling in the Lofty\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"River of Strong Current\",\"tibetan\":\"ཆུ་བོ་ཤུགས་ཆེན་འབབ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chu bo shugs chen ’bab\"}},{\"uuid\":\"46a1cdbe-908f-4716-82c3-906d48ebf117\",\"authority\":\"1590bcfe-ebac-4f9e-b067-dd22092566f9\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA river in \u003cspan data-glossary-id=\\\"UT22084-068-021-9031\\\"\u003eDwelling in the Lofty\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"River of Strong Garlands\",\"tibetan\":\"ཆུ་བོ་ཤུགས་ཕྲེང་།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chu bo shugs phreng\"}},{\"uuid\":\"a1dce162-1b67-4757-a509-528d0845ffd3\",\"authority\":\"8d94816c-fb2d-4bc7-b3a6-96264b3a2db1\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA river in \u003cspan data-glossary-id=\\\"UT22084-068-021-9031\\\"\u003eDwelling in the Lofty\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"River of Sweet Taste\",\"tibetan\":\"ཆུ་བོ་རོ་ཞིམ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chu bo ro zhim\"}},{\"uuid\":\"3d7dabcf-afe2-43f7-9be4-8156245c101e\",\"authority\":\"42a73563-0d91-43b6-a8b1-be76434c6f9c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA river in \u003cspan data-glossary-id=\\\"UT22084-068-021-9072\\\"\u003eEnjoyment of Scents\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"River of Wine\",\"tibetan\":\"ཆང་འབབ་ཆུ་བོ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chang ’bab chu bo\"}},{\"uuid\":\"a1e55db0-4fc0-43b8-9e66-d72aceb3eb75\",\"authority\":\"ce5fb6cf-3836-4dac-b3db-d7a4f25b2ca4\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA peak upon Mount \u003cspan data-glossary-id=\\\"UT22084-068-021-9739\\\"\u003eSumeru\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Rivers and Flatlands\",\"tibetan\":\"ཆུ་བོ་སྨན་ལྗོང་།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chu bo sman ljong\"}},{\"uuid\":\"fe0a864a-50ca-4095-a8ef-d4b7c5fe19a1\",\"authority\":\"43e70e1d-eb7a-4999-8978-edf1f3105871\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn island in the vicinity of \u003cspan data-glossary-id=\\\"UT22084-068-021-9338\\\"\u003eJambudvīpa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Roadless\",\"tibetan\":\"ལམ་མེད་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lam med pa\"}},{\"uuid\":\"23e1e1b4-9143-4b6a-93e7-573584170f6a\",\"authority\":\"9f050b1c-93d2-4079-9839-65b5911752dc\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA class of \u003cspan data-glossary-id=\\\"UT22084-068-021-8489\\\"\u003easuras\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"roamers\",\"tibetan\":\"རབ་ཏུ་རྒྱུག་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rab tu rgyug pa\"}},{\"uuid\":\"e89e642c-711c-4427-8222-b59b4f8124d8\",\"authority\":\"50c9816f-a048-4c58-9871-0daa6e1bca6c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA land in \u003cspan data-glossary-id=\\\"UT22084-068-021-9209\\\"\u003eGodānīya\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Roaming Sumeru\",\"tibetan\":\"རི་རབ་ཏུ་རྒྱུ་བ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ri rab tu rgyu ba\"}},{\"uuid\":\"ae057bd0-ea71-4c06-8f06-84748e84a009\",\"authority\":\"e0085154-6b15-4609-b77c-7bb24a880a29\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA class of \u003cspan data-glossary-id=\\\"UT22084-068-021-8622\\\"\u003evidyādharas\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"roaming the cimiśa cave\",\"tibetan\":\"ཙི་མི་ཤའི་ཕུག་ན་རྒྱུ་བ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"tsi mi sha’i phug na rgyu ba\"}},{\"uuid\":\"c68ca57b-0dbb-4b5e-b448-ec860003b0a4\",\"authority\":\"edfa6f38-0200-48e3-9d8b-13af69b3d744\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA river on \u003cspan data-glossary-id=\\\"UT22084-068-021-9657\\\"\u003eSaṅkāśa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Roaring Flow\",\"tibetan\":\"འུ་རུ་རུའི་སྒྲས་འབབ་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’u ru ru’i sgras ’bab pa\"}},{\"uuid\":\"6bfca0de-d3f4-4120-95bd-6d03ee9356c3\",\"authority\":\"c0309d76-6bdd-4202-923b-0e9c280184af\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA virtuous \u003cspan data-glossary-id=\\\"UT22084-068-021-8562\\\"\u003enāga\u003c/span\u003e king.\u003c/p\u003e\",\"names\":{\"english\":\"Rohina\",\"tibetan\":\"རོ་ཧི་ན།\",\"sanskrit\":\"rohina\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ro hi na\"}},{\"uuid\":\"01a64432-0f60-4635-817c-7dc562ea7336\",\"authority\":\"3d6e9d86-e18c-4cae-82ed-9bea19e13d98\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA forest in \u003cspan data-glossary-id=\\\"UT22084-068-021-9506\\\"\u003eMoving in Mixed Environments\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Ruby Forest\",\"tibetan\":\"པད་མ་རཱ་གའི་ནགས།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"pad ma rA ga’i nags\"}},{\"uuid\":\"608b2867-1c5a-4410-b6f7-796329dea4c3\",\"authority\":\"79b56635-eef7-4605-a9ef-744765d740ea\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA class of \u003cspan data-glossary-id=\\\"UT22084-068-021-8489\\\"\u003easuras\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"runners\",\"tibetan\":\"ཀུན་ཏུ་རྒྱུག་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kun tu rgyug pa\"}},{\"uuid\":\"79dc4f82-a092-4a67-a0e5-1d0d4043e9ae\",\"authority\":\"2beb4e40-f8ff-472a-8747-c27e2ccaf2e2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe wife of \u003cspan data-glossary-id=\\\"UT22084-068-021-8738\\\"\u003eŚakra\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Śaci\",\"tibetan\":\"བདེ་སོགས།\",\"sanskrit\":\"śaci\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bde sogs\"}},{\"uuid\":\"9d0cd01b-53db-406e-ab5b-8a4facf5afd3\",\"authority\":\"97e18157-ca2d-44c4-905f-45bb066725ec\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eIndian \u003cspan class=\\\"ignore\\\"\u003esage\u003c/span\u003e or wise man, often a wandering ascetic or hermit; \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003edrang srong\u003c/em\u003e is literally “the righteous one.” “Great \u003cspan class=\\\"ignore\\\"\u003esage\u003c/span\u003e” is sometimes also used as a specific epithet of the buddhas.\u003c/p\u003e\",\"names\":{\"english\":\"sage\",\"tibetan\":\"དྲང་སྲོང་།\",\"sanskrit\":\"ṛṣi\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"drang srong\"}},{\"uuid\":\"77d5f4a8-d3a2-4bf4-94a8-6cbf8d645d7e\",\"authority\":\"1b695cb4-9707-4df8-a5d7-c8c409e05ef4\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA river on \u003cspan data-glossary-id=\\\"UT22084-068-021-9128\\\"\u003eFlocking Peacocks\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Sagely Joy\",\"tibetan\":\"དྲང་སྲོང་དགའ་བ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"drang srong dga’ ba\"}},{\"uuid\":\"64966d46-03d8-4b8e-959a-b9436ed44e97\",\"authority\":\"3b14de91-9207-4dc0-ac5f-4f9a2bd09036\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA land to the north of \u003cspan data-glossary-id=\\\"UT22084-068-021-9338\\\"\u003eJambudvīpa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Śakā\",\"tibetan\":\"ཤ་ཀཱ།\",\"sanskrit\":\"śakā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sh kA\"}},{\"uuid\":\"c46473a9-c71c-4bc8-afb8-4c7b3d3f7bdb\",\"authority\":\"6fbdb5b0-3b2a-4d90-a1e1-76b9a42657e0\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe lord of the gods in the Heaven of the Thirty-Three (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003etrāyastriṃśa\u003c/em\u003e). Alternatively known as Indra, the deity that is called “lord of the gods” dwells on the summit of Mount Sumeru and wields the thunderbolt. The Tibetan translation \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ebrgya byin\u003c/em\u003e (meaning “one hundred sacrifices”) is based on an etymology that \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eśakra\u003c/em\u003e is an abbreviation of \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eśata-kratu\u003c/em\u003e, one who has performed a hundred sacrifices. Each world with a central Sumeru has a Śakra. Also known by other names such as Kauśika, Devendra, and Śacipati. \u003c/p\u003e\u003cp class=\\\"definition\\\"\u003eAlso mentioned in this text as \u003cspan data-glossary-id=\\\"UT22084-068-021-8697\\\"\u003eKauśika\u003c/span\u003e and as \u003cspan data-glossary-id=\\\"UT22084-068-021-9910\\\"\u003eIndra\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Śakra\",\"tibetan\":\"བརྒྱ་བྱིན།\",\"sanskrit\":\"śakra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"brgya byin\"}},{\"uuid\":\"3ec44d80-00e7-44f6-8e2b-c0a695dbf71e\",\"authority\":\"5639292d-64cd-48c8-b5a4-fcc21d5b497a\",\"definition\":\"\u003cp\u003eName of the ancient tribe in which the Buddha was born as a prince; their kingdom was based to the east of Kośala, in the foothills near the present-day border of India and Nepal, with Kapilavastu as its capital.\u003c/p\u003e\",\"names\":{\"english\":\"Śākya\",\"tibetan\":\"ཤཱཀྱ།\",\"sanskrit\":\"śākya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shAkya\"}},{\"uuid\":\"42a1f95e-b362-4157-9e3d-02daeff06b02\",\"authority\":\"dd7ce730-3ab7-470c-8c36-e2a53686cc39\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eIn the \u003cspan data-glossary-id=\\\"UT22084-068-021-9986\\\"\u003esūtra\u003c/span\u003e this term used by \u003cspan data-glossary-id=\\\"UT22084-068-021-8567\\\"\u003enon-Buddhists\u003c/span\u003e to refer to Buddhists.\u003c/p\u003e\",\"names\":{\"english\":\"Śākya followers\",\"tibetan\":\"ཤཱཀྱ་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shAkya pa\"}},{\"uuid\":\"aafd3f3f-d16d-4507-a177-f9eb18db6838\",\"authority\":\"315d1554-9570-42a2-82a3-36f3790eccc9\",\"definition\":\"\u003cp\u003eAn epithet for the historical Buddha, Siddhārtha Gautama: he was a \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003emuni\u003c/em\u003e (“sage”) from the Śākya clan. He is counted as the fourth of the first four buddhas of the present Good Eon, the other three being Krakucchanda, Kanakamuni, and Kāśyapa. He will be followed by Maitreya, the next buddha in this eon.\u003c/p\u003e\",\"names\":{\"english\":\"Śākyamuni\",\"tibetan\":\"ཤཱཀྱ་ཐུབ་པ།\",\"sanskrit\":\"śākyamuni\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shAkya thub pa\"}},{\"uuid\":\"10359430-2efe-4d8d-b059-ec2dfc31c2d5\",\"authority\":\"9c549fed-f592-4929-8121-05f143a4ef9a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn Indian \u003cspan data-glossary-id=\\\"UT22084-068-021-8569\\\"\u003epaṇḍita\u003c/span\u003e involved in translating this \u003cspan data-glossary-id=\\\"UT22084-068-021-9986\\\"\u003esūtra\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Śakyarakṣita\",\"tibetan\":\"ཤཱཀྱ་རཀྵི་ཏ།\",\"sanskrit\":\"śakyarakṣita\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shAkya rak+Shi ta\"}},{\"uuid\":\"990c20a5-fbc4-4679-b05d-ddf7419a9d05\",\"authority\":\"d1eb27ba-5f71-4e84-8a8e-73f55c521ab4\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA sea between \u003cspan data-glossary-id=\\\"UT22084-068-021-9847\\\"\u003eVideha\u003c/span\u003e and \u003cspan data-glossary-id=\\\"UT22084-068-021-9338\\\"\u003eJambudvīpa\u003c/span\u003e\u003c/p\u003e\",\"names\":{\"english\":\"Salty\",\"tibetan\":\"ལན་ཚྭ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lan tshwa\"}},{\"uuid\":\"f4046269-d811-4c4f-b3c9-e32a991c2b45\",\"authority\":\"c10897ef-9bc1-4a79-ad8c-63a9cc08a0b3\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA river on \u003cspan data-glossary-id=\\\"UT22084-068-021-9241\\\"\u003eGreat Slope\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Sāmreḍā\",\"tibetan\":\"སཱ་མྲེ་ཌཱ།\",\"sanskrit\":\"sāmreḍā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sA mre DA\"}},{\"uuid\":\"fb9dab49-6166-48f2-acd9-5fa54afa2dfe\",\"authority\":\"84dae904-1fed-41be-8192-4c6d219d7045\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn area between \u003cspan data-glossary-id=\\\"UT22084-068-021-9209\\\"\u003eGodānīya\u003c/span\u003e and \u003cspan data-glossary-id=\\\"UT22084-068-021-9847\\\"\u003eVideha\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Sandy Stretch\",\"tibetan\":\"བྱེ་མའི་གནས་སྐབས།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bye ma’i gnas skabs\"}},{\"uuid\":\"33bbef90-36f8-48a5-8674-e0dfe1b55ebe\",\"authority\":\"f79bce64-6cd5-4942-97de-a74e31167bf8\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA mountain in \u003cspan data-glossary-id=\\\"UT22084-068-021-9398\\\"\u003eKuru\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Saṅkāśa\",\"tibetan\":\"སང་ཀཱ་ཤ་ཀཱ།, སང་ཀཱ་ཤ།, སཾ་ཀཱ་ཤ།\",\"sanskrit\":\"saṅkāśa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"saM kA sha, sang kA sha, sang kA sha kA\"}},{\"uuid\":\"30ed045a-ee86-4311-bb33-84f5a2b57370\",\"authority\":\"ffc593dd-9926-4185-a2b4-f841da165547\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn Indian \u003cspan data-glossary-id=\\\"UT22084-068-021-8569\\\"\u003epaṇḍita\u003c/span\u003e involved in translating this \u003cspan data-glossary-id=\\\"UT22084-068-021-9986\\\"\u003esūtra\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Śāntākaragupta\",\"tibetan\":\"ཤཱནྟ་ཨཱ་ཀ་ར་གུཔྟ།\",\"sanskrit\":\"śāntākaragupta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shAn+ta A ka ra gup+ta\"}},{\"uuid\":\"8bd7df56-011b-498d-9923-d82d6d986b03\",\"authority\":\"0f1656e4-2ebf-4545-8b73-6d129652cc6f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA lake on \u003cspan data-glossary-id=\\\"UT22084-068-021-9078\\\"\u003eEqual Peaks\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Sānu\",\"tibetan\":\"སཱ་ནུ།\",\"sanskrit\":\"sānu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sA nu\"}},{\"uuid\":\"90595c27-647b-468e-ba6a-e97b46601b4b\",\"authority\":\"5ce5a62a-7fc3-4c9e-9ff2-51c40f35be51\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA mountain in the sea west of \u003cspan data-glossary-id=\\\"UT22084-068-021-9338\\\"\u003eJambudvīpa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Sāra\",\"tibetan\":\"སཱ་ར།\",\"sanskrit\":\"sāra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sA ra\"}},{\"uuid\":\"b34f8e95-5fc9-44c9-8e45-f4587adea677\",\"authority\":\"c32889b0-83bb-4c7e-8fa5-4bb526bcf3c9\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eMore widely known as Śāriputra‍—the contracted version of his name‍—he was one of the Buddha’s foremost \u003cspan data-glossary-id=\\\"UT22084-068-021-8536\\\"\u003ehearer\u003c/span\u003e disciples. Renowned for his pure discipline and unparalleled knowledge of the teachings.\u003c/p\u003e\",\"names\":{\"english\":\"Śāradvatīputra\",\"tibetan\":\"ཤ་ར་དྭ་ཏིའི་བུ།\",\"sanskrit\":\"śāradvatīputra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sha ra dwa ti’i bu\"}},{\"uuid\":\"274c6c83-54e4-4fda-8b1a-9c8d72bb3d2f\",\"authority\":\"c07f2dfa-168c-4d93-b46b-e36d780e4d7f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA previous ruler of the \u003cspan data-glossary-id=\\\"UT22084-068-021-9266\\\"\u003eHeaven Free from Strife\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Saumya\",\"tibetan\":\"སོའུ་མྱོ།\",\"sanskrit\":\"saumya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"so’u myo\"}},{\"uuid\":\"3171d914-7e8c-4d8c-a95d-519ad15acad6\",\"authority\":\"5eece708-19a1-4eb9-a7d4-e796ea2ba59b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA river on \u003cspan data-glossary-id=\\\"UT22084-068-021-9823\\\"\u003eUpward Ocean\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Scattered Stones\",\"tibetan\":\"རྡོ་བ་འདྲིམ་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rdo ba ’drim pa\"}},{\"uuid\":\"75fbb302-f811-4c27-9aaa-7a6d3ac18465\",\"authority\":\"faec6b03-c908-4599-b450-cf07753549ba\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA class of \u003cspan data-glossary-id=\\\"UT22084-068-021-8622\\\"\u003evidyādharas\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"scent of constant inebriation\",\"tibetan\":\"རྟག་ཏུ་མྱོས་པའི་དྲི།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rtag tu myos pa’i dri\"}},{\"uuid\":\"2b7a536e-1376-4304-bde2-01295654a4cb\",\"authority\":\"a7c50cea-711a-4f48-b745-b2e9856f3a4b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of sixteen realms that surround the \u003cspan data-glossary-id=\\\"UT22084-068-021-9298\\\"\u003eHowling Hell\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Scream\",\"tibetan\":\"སྒྲ་ཆེན་པོ།\",\"sanskrit\":\"mahānināda\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sgra chen po\"}},{\"uuid\":\"5df25171-2a06-475b-ad9a-4715168560e3\",\"authority\":\"37754d43-d008-430e-a968-46dcaf3371be\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of sixteen realms that surround the \u003cspan data-glossary-id=\\\"UT22084-068-021-9298\\\"\u003eHowling Hell\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Screams Everywhere\",\"tibetan\":\"ཐམས་ཅད་སྒྲ་འབྱིན་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"thams cad sgra ’byin pa\"}},{\"uuid\":\"1beb40e8-4aff-4ddd-8569-9281860bd065\",\"authority\":\"b50a1a85-4db7-49bc-8c0d-de101da05c1c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA mountain in \u003cspan data-glossary-id=\\\"UT22084-068-021-9398\\\"\u003eKuru\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Seasonal Joy\",\"tibetan\":\"དུས་ན་དགའ་བ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dus na dga’ ba\"}},{\"uuid\":\"092bc608-d468-45ba-845e-ce30f3367e19\",\"authority\":\"1a82e3a8-1bda-403c-a256-3b6c672d0962\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA land to the north of \u003cspan data-glossary-id=\\\"UT22084-068-021-9338\\\"\u003eJambudvīpa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Second China\",\"tibetan\":\"རྒྱ་ནག་གཞན།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rgya nag gzhan\"}},{\"uuid\":\"7e8f3671-10b8-42cd-9b40-d1701f014516\",\"authority\":\"cb7a698e-4bd6-4eb9-b13a-e696c1335c8f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA river on \u003cspan data-glossary-id=\\\"UT22084-068-021-9657\\\"\u003eSaṅkāśa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Secret Play\",\"tibetan\":\"གསང་བ་རྩེ་དགའ་བ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gsang ba rtse dga’ ba\"}},{\"uuid\":\"55a5cbe4-e7d5-4984-9320-02d75975fbd9\",\"authority\":\"8db9bb3f-c714-41d5-8fad-e0c420d9f636\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA pond on \u003cspan data-glossary-id=\\\"UT22084-068-021-9078\\\"\u003eEqual Peaks\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Seeing the Head\",\"tibetan\":\"མགོ་བོ་མཐོང་བ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mgo bo mthong ba\"}},{\"uuid\":\"c7c2f448-a5d6-464d-bac9-fd6ce4df39bb\",\"authority\":\"74c4c6ca-346f-4413-87c0-4d02bc6dce53\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA lotus pond on \u003cspan data-glossary-id=\\\"UT22084-068-021-9013\\\"\u003eDraped in Light Rays\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Seeing Thousands\",\"tibetan\":\"སྟོང་དུ་མཐོང་བ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"stong du mthong ba\"}},{\"uuid\":\"0e4a9e08-709e-4b7d-add1-f32fe3d31a3f\",\"authority\":\"98a2a6bf-fbf2-44ff-bddd-c53418bf76d5\",\"definition\":\"\u003cp\u003eThese can be listed as twelve or as six sense sources (sometimes also called sense fields, bases of cognition, or simply āyatanas).\u003c/p\u003e\u003cp\u003eIn the context of epistemology, it is one way of describing experience and the world in terms of twelve sense sources, which can be divided into inner and outer sense sources, namely: (1–2) eye and form, (3–4) ear and sound, (5–6) nose and odor, (7–8) tongue and taste, (9–10) body and touch, (11–12) mind and mental phenomena.\u003c/p\u003e\u003cp\u003eIn the context of the twelve links of dependent origination, only six sense sources are mentioned, and they are the inner sense sources (identical to the six faculties) of eye, ear, nose, tongue, body, and mind.\u003c/p\u003e\",\"names\":{\"english\":\"sense source\",\"tibetan\":\"སྐྱེ་མཆེད།\",\"sanskrit\":\"āyatana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"skye mched\"}},{\"uuid\":\"5253918f-78fd-4377-8948-c53814d43175\",\"authority\":\"7663bcf3-9e8f-4e1f-82fb-8864c4fe07fd\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA ruler of the \u003cspan data-glossary-id=\\\"UT22084-068-021-9266\\\"\u003eHeaven Free from Strife\u003c/span\u003e. Also called \u003cspan data-glossary-id=\\\"UT22084-068-021-8744\\\"\u003eSerene Form\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Serene\",\"tibetan\":\"རབ་ཏུ་གཏུམ་པ་མ་ཡིན་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rab tu gtum pa ma yin pa\"}},{\"uuid\":\"bedce585-a139-421e-8abe-18d597a67bf1\",\"authority\":\"cbef6bed-fe3a-4250-89e6-4c8ddc7aacb8\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAlternative name for \u003cspan\u003e\u003cspan data-glossary-id=\\\"UT22084-068-021-8743\\\"\u003eSerene\u003c/span\u003e\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Serene Form\",\"tibetan\":\"རབ་ཏུ་གཏུམ་པ་མ་ཡིན་པའི་གཟུགས།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rab tu gtum pa ma yin pa’i gzugs\"}},{\"uuid\":\"10063a64-77fd-41a9-b9fa-f8620b9d7f70\",\"authority\":\"a6aae578-f7bb-4a4c-8179-060d8728e1b2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe seven factors that constitute the path of seeing, namely: mindfulness, investigation, diligence, joy, agility, absorption, and equanimity. These are further explained in this text; see \u003ca href=\\\"UT22084-068-021-section-6.xhtml#UT22084-068-021-4039\\\" data-pointer-type=\\\"id\\\"\u003e4.B.1097\u003c/a\u003e–\u003ca href=\\\"UT22084-068-021-section-6.xhtml#UT22084-068-021-4043\\\" data-pointer-type=\\\"id\\\"\u003e4.B.1101\u003c/a\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"seven branches of awakening\",\"tibetan\":\"བྱང་ཆུབ་ཀྱི་ཡན་ལག་བདུན།\",\"sanskrit\":\"saptabodhyaṅga\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"byang chub kyi yan lag bdun\"}},{\"uuid\":\"3da99f50-6694-4e86-af93-8ec6dc46b21f\",\"authority\":\"52322944-8a7f-47f2-aff9-48472209b78e\",\"definition\":\"\u003cp\u003eThe set of seven precious materials or substances includes a range of precious metals and gems, but their exact list varies. The set often consists of gold, silver, beryl, crystal, red pearls, emeralds, and white coral, but may also contain lapis lazuli, ruby, sapphire, chrysoberyl, diamonds, etc. The term is frequently used in the sūtras to exemplify preciousness, wealth, and beauty, and can describe treasures, offering materials, or the features of architectural structures such as stūpas, palaces, thrones, etc. The set is also used to describe the beauty and prosperity of buddha realms and the realms of the gods.\u003c/p\u003e\u003cp\u003eIn other contexts, the term \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003esaptaratna\u003c/em\u003e can also refer to the seven precious possessions of a cakravartin or to a set of seven precious moral qualities. \u003c/p\u003e\",\"names\":{\"english\":\"seven precious substances\",\"tibetan\":\"རིན་པོ་ཆེའི་རྫས་བདུན།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rin po che’i rdzas bdun\"}},{\"uuid\":\"2e584dd3-ca07-4474-8fa7-3d18dd382323\",\"authority\":\"3fcd8b9c-fea2-49d6-ab71-7a411df5c01b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eRefers to the seven stars of the Big Dipper, the names of which are derived from the names of the \u003cspan class=\\\"ignore\\\"\u003eseven sages\u003c/span\u003e (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003esaptarṣi\u003c/em\u003e) of the Vedic tradition.\u003c/p\u003e\",\"names\":{\"english\":\"seven sages\",\"tibetan\":\"དྲང་སྲོང་བདུན།\",\"sanskrit\":\"saptarṣi\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"drang srong bdun\"}},{\"uuid\":\"2a14dc53-a31c-4b0a-99d8-368aae405a5a\",\"authority\":\"f73813ef-1115-49f2-ae91-01eabe791292\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSeven possessions of a universal monarch: the precious lady, precious jewel, precious wheel, precious elephant, precious horse, precious minister, and precious general or, as described in this text, precious master of the household. See also the detailed description in \u003ca href=\\\"UT22084-068-021-chapter-1.xhtml#UT22084-068-021-145\\\" data-pointer-type=\\\"id\\\"\u003e1.96\u003c/a\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"seven treasures\",\"tibetan\":\"རིན་པོ་ཆེ་སྣ་བདུན།\",\"sanskrit\":\"saptaratna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rin po che sna bdun\"}},{\"uuid\":\"fc4d8590-0236-437d-96f1-f2dd19ce9784\",\"authority\":\"8f52f619-a9e1-4656-9407-2a5d8919e3ae\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA virtuous \u003cspan data-glossary-id=\\\"UT22084-068-021-8562\\\"\u003enāga\u003c/span\u003e king. \u003c/p\u003e\",\"names\":{\"english\":\"Seven-Headed\",\"tibetan\":\"མགོ་བདུན་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mgo bdun pa\"}},{\"uuid\":\"b9db826d-bfc2-49ef-a9b0-bbe70bf16d26\",\"authority\":\"bf579286-c7ed-4c46-b4df-b06cad2c725a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe third among the three physical misdeeds.\u003c/p\u003e\",\"names\":{\"english\":\"sexual misconduct\",\"tibetan\":\"འདོད་པས་ལོག་པར་གཡེམ་པ།\",\"sanskrit\":\"kāma­mithyā­caryā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’dod pas log par g.yem pa\"}},{\"uuid\":\"959530dc-b2ef-4c40-86d0-fb6988faee7d\",\"authority\":\"3d6c7a87-bcb6-4f08-9462-a4dbf6362307\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA realm in the \u003cspan data-glossary-id=\\\"UT22084-068-021-9276\\\"\u003eHeaven of the Thirty-Three\u003c/span\u003e and the name of a tree that grows there.\u003c/p\u003e\",\"names\":{\"english\":\"Shaded by Garlands\",\"tibetan\":\"འཕྲེང་བའི་གྲིབ་མ།\",\"sanskrit\":\"mālācchāyā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’phreng ba’i grib ma\"}},{\"uuid\":\"2beaf127-2e4b-4d3d-90e8-a926d1724902\",\"authority\":\"a7868e65-65eb-4dad-85d4-a1d00d853ef5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA lake on \u003cspan data-glossary-id=\\\"UT22084-068-021-9078\\\"\u003eEqual Peaks\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Shaded by Trees\",\"tibetan\":\"ཤིང་གིས་གཡོགས་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shing gis g.yogs pa\"}},{\"uuid\":\"c86a8e85-bfc0-450b-97d9-e4a70f31bc7a\",\"authority\":\"e6f57711-8ecf-409b-88c7-e8ea390ee93e\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA type of \u003cspan data-glossary-id=\\\"UT22084-068-021-8581\\\"\u003erākṣasī\u003c/span\u003e living on an island called \u003cspan\u003e\u003cspan data-glossary-id=\\\"UT22084-068-021-9057\\\"\u003eEndowed with Jewels\u003c/span\u003e\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"shadow players\",\"tibetan\":\"གྲིབ་མའི་རྩེ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"grib ma’i rtse\"}},{\"uuid\":\"59c8aaf9-9c7a-4afd-a0cc-366943ae4fda\",\"authority\":\"fac5ae69-43d0-4508-b8d7-ee9a88dd6d88\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA forest in \u003cspan data-glossary-id=\\\"UT22084-068-021-9417\\\"\u003eLiving on the Peak\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Shaken by Fierce Winds\",\"tibetan\":\"རླུང་གཏུམ་པོས་གཡོས་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rlung gtum pos g.yos pa\"}},{\"uuid\":\"8f95e55b-f8a2-4919-b4d8-9d4a2d5a9f29\",\"authority\":\"8f3bfc19-ca3b-4ef2-acb1-37523a0a6e01\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn assistant translator and editor of this scripture.\u003c/p\u003e\",\"names\":{\"english\":\"Shang Buchikpa\",\"tibetan\":\"ཞང་བུ་གཅིག་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"zhang bu gcig pa\"}},{\"uuid\":\"7f5108b5-df91-4b90-840b-cf367de1e97d\",\"authority\":\"141e2e16-0a53-413a-b85a-1e7ed9b6b3f7\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of sixteen realms that surround the \u003cspan data-glossary-id=\\\"UT22084-068-021-9235\\\"\u003eGreat Howling Hell\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Sharp and Unbearable Pain\",\"tibetan\":\"ཚོར་བ་རྩུབ་ཅིང་ཚ་ལ་བཟོད་པ་དཀའ་བ།\",\"sanskrit\":\"khara­kaṭuka­duḥsaha­vedana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"tshor ba rtsub cing tsha la bzod pa dka’ ba\"}},{\"uuid\":\"8a835a20-fe45-4165-af64-50bd9470ae01\",\"authority\":\"dc22e386-5aa5-44dc-a30f-7980c5d870a9\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn assistant translator and editor of this scripture.\u003c/p\u003e\",\"names\":{\"english\":\"Sherap Ö\",\"tibetan\":\"ཤེས་རབ་འོད།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shes rab ’od\"}},{\"uuid\":\"0751fe52-94b8-4a34-a483-cc4cc94af31b\",\"authority\":\"a05b17b0-2a1f-449d-9f84-fe8c61eb07e1\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA virtuous \u003cspan data-glossary-id=\\\"UT22084-068-021-8562\\\"\u003enāga\u003c/span\u003e king.\u003c/p\u003e\",\"names\":{\"english\":\"Shining\",\"tibetan\":\"རབ་སྤྲོ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rab spro\"}},{\"uuid\":\"95ba1c0c-4821-43aa-a89b-3bfd11850170\",\"authority\":\"c10fdc2a-ba4e-47da-9b81-c1bd204c8fe2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the twenty-seven realms of the \u003cspan data-glossary-id=\\\"UT22084-068-021-9266\\\"\u003eHeaven Free from Strife\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Shining in Manifold Ways\",\"tibetan\":\"རྣམ་པ་སྣ་ཚོགས་པར་རྣམ་པར་བཀྲ་བ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rnam pa sna tshogs par rnam par bkra ba\"}},{\"uuid\":\"19a09f62-203a-40ee-adec-771f8c5808d3\",\"authority\":\"5920628a-dbdf-483e-bfc9-3681cf1559c5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA mountain in \u003cspan data-glossary-id=\\\"UT22084-068-021-9511\\\"\u003eMoving in Vast Environments\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Shining Jewel Light\",\"tibetan\":\"ནོར་བུ་འབྱིན།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nor bu ’byin\"}},{\"uuid\":\"cc400022-a69d-43dc-9a96-1f4a71c78a31\",\"authority\":\"8701ffbe-0ee9-4851-a382-0a86f0f48739\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA previous buddha.\u003c/p\u003e\",\"names\":{\"english\":\"Śikhin\",\"tibetan\":\"གཙུག་ཏོར་ཅན།\",\"sanskrit\":\"śikhin\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gtsug tor can\"}},{\"uuid\":\"18d9828d-5bcc-4f36-b5b5-fe5f4b8b0a19\",\"authority\":\"c71c994d-f57a-44f6-bee2-67295a03fe79\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA king in \u003cspan data-glossary-id=\\\"UT22084-068-021-9338\\\"\u003eJambudvīpa\u003c/span\u003e, \u003cspan data-glossary-id=\\\"UT22084-068-021-8720\\\"\u003eMusulundha\u003c/span\u003e’s rebirth.\u003c/p\u003e\",\"names\":{\"english\":\"Śīlabhadra\",\"tibetan\":\"ཚུལ་ཁྲིམས་བཟང་པོ།\",\"sanskrit\":\"śīlabhadra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"tshul khrims bzang po\"}},{\"uuid\":\"88537432-d49d-4a52-b60a-2fe12cc70d25\",\"authority\":\"d1b25ad0-ac2a-4db5-b6e1-7a19c011f107\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA forest in \u003cspan data-glossary-id=\\\"UT22084-068-021-9869\\\"\u003eWhite Body\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Silver Forest\",\"tibetan\":\"དངུལ་གྱི་ཤིང་ལྗོན་པའི་ཚལ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dngul gyi shing ljon pa’i tshal\"}},{\"uuid\":\"857c13b8-42c3-4f10-a348-5a0e8649e823\",\"authority\":\"dee0afa3-1c3f-4e4f-864d-521bc8b85742\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA river on \u003cspan data-glossary-id=\\\"UT22084-068-021-9657\\\"\u003eSaṅkāśa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Silver Hue\",\"tibetan\":\"དངུལ་གྱི་མདོག\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dngul gyi mdog\"}},{\"uuid\":\"ab922da1-27cb-4ef6-bc72-5cc7bfa82833\",\"authority\":\"d9970226-7bf7-4db6-8629-3c93b78b1e26\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn island in the vicinity of \u003cspan data-glossary-id=\\\"UT22084-068-021-9338\\\"\u003eJambudvīpa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Silvery Sands\",\"tibetan\":\"དངུལ་དང་བཅས་པའི་བྱེ་མས་ཡོངས་སུ་བསྐོར་བ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dngul dang bcas pa’i bye mas yongs su bskor ba\"}},{\"uuid\":\"af73b3a0-2f66-4f34-8262-e59c4596f87b\",\"authority\":\"61b2fe33-8f0b-4eaa-8a6c-a40cc1009f60\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe island of Lanka.\u003c/p\u003e\",\"names\":{\"english\":\"Siṃhala\",\"tibetan\":\"སིང་ཧ་ལ།\",\"sanskrit\":\"siṃhala\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sing ha la\"}},{\"uuid\":\"92656fb7-c4f6-45ee-aebe-934fee0ba9fe\",\"authority\":\"6aa28ee4-06e0-4019-87d2-463df59a6e5f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn area located in present day Pakistan.\u003c/p\u003e\",\"na