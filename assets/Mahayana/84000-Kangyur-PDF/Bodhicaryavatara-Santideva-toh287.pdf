:\"1a2689cf-cac3-42f7-a021-9a5165448393\"},\"content\":[{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"Will be happy in this world \",\"attrs\":{\"start\":0,\"end\":28}}],\"attrs\":{\"start\":0,\"end\":28,\"uuid\":\"693140a0-1d38-474f-9572-94ba9d20df4f\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"And proceed to the higher realms thereafter. \",\"attrs\":{\"start\":28,\"end\":73}}],\"attrs\":{\"start\":28,\"end\":73,\"uuid\":\"d2ea3c82-5fb3-4905-9901-d45f6be8a0e9\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"Such people are worthy \",\"attrs\":{\"start\":73,\"end\":96}}],\"attrs\":{\"start\":73,\"end\":96,\"uuid\":\"e9df6f38-0afd-4483-be38-d60653fa0b2a\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"Of the veneration of the wise.\",\"attrs\":{\"start\":96,\"end\":126}}],\"attrs\":{\"start\":96,\"end\":126,\"uuid\":\"0d57e743-f595-4c2e-925e-3bfcc07db48c\"}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"80c85424-5de2-4cec-8498-07bad8b468c0\",\"sort\":1495,\"type\":\"translation\",\"label\":\"1.61\",\"alignments\":{}},\"content\":[{\"type\":\"lineGroup\",\"attrs\":{\"start\":0,\"end\":159,\"uuid\":\"042532ca-8ae3-41b6-bbf2-cfb878fbf758\"},\"content\":[{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"“Those speakers of the truth who are always tranquil, \",\"attrs\":{\"start\":0,\"end\":54}}],\"attrs\":{\"start\":0,\"end\":54,\"uuid\":\"0e2aac5d-4b4e-4228-856f-72db4b689e80\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"Who are sincere, free from deceit, \",\"attrs\":{\"start\":54,\"end\":89}}],\"attrs\":{\"start\":54,\"end\":89,\"uuid\":\"e912cb5c-5961-489f-86d5-24735ae117eb\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"And who refrain from harming others, \",\"attrs\":{\"start\":89,\"end\":126}}],\"attrs\":{\"start\":89,\"end\":126,\"uuid\":\"77161753-2f29-4594-bb47-1e2be849603c\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"