 surrounding country or district. It lies in modern day Uttar Pradesh, India. The name is rendered elsewhere in this translation as its older name, “\u003cspan data-glossary-id=\\\"UT22084-068-021-9378\\\"\u003eKāśī\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"Vārāṇasī\",\"tibetan\":\"བཱ་རཱ་ཎ་སཱི།\",\"sanskrit\":\"vārāṇasī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bA rA Na sI\"}},{\"uuid\":\"e78c83d7-91a4-4f9a-bf70-6a23eec2d04f\",\"authority\":\"a296a29d-39f1-459f-b286-9ea0018e8d9d\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA river in \u003cspan\u003e\u003cspan data-glossary-id=\\\"UT22084-068-021-9443\\\"\u003eMajestic Trees\u003c/span\u003e\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Variation\",\"tibetan\":\"རྣམ་པ་སྣ་ཙོགས།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rnam pa sna tsogs\"}},{\"uuid\":\"8720c5ae-f8fe-4d27-b24d-1ea9962dafb5\",\"authority\":\"1fbfa1fe-cf7f-43cc-a1cb-9478016a6213\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee “\u003cspan data-glossary-id=\\\"UT22084-068-021-9032\\\"\u003eDwelling in Various Chariots\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"Various Chariots\",\"tibetan\":\"ཤིང་རྟ་སྣ་ཚོགས།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shing rta sna tshogs\"}},{\"uuid\":\"e4746ace-483a-438a-9091-40f64fdcd99e\",\"authority\":\"17b7e0ef-90c6-40f4-b127-b82ae187717b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-068-021-8622\\\"\u003evidyādhara\u003c/span\u003e site on \u003cspan data-glossary-id=\\\"UT22084-068-021-9375\\\"\u003eKālaka\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Varitavaṭṭānang\",\"tibetan\":\"བ་རི་ཏ་བཊྚ་ནང་།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ba ri ta baT+Ta nang\"}},{\"uuid\":\"99d42510-9f47-496b-a1a7-5b492c17ac4a\",\"authority\":\"185f105b-bd0d-440a-b522-e86f57f16e47\",\"definition\":\"\u003cp class=\\\"definition\\