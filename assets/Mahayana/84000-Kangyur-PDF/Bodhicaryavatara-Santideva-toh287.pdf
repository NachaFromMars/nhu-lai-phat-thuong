ap-5"><div class="animate-pulse rounded-md bg-foreground/10 h-6 w-6"></div><div class="animate-pulse rounded-md bg-foreground/10 h-32 grow"></div></div></div></div><div data-state="inactive" data-orientation="horizontal" role="tabpanel" aria-labelledby="radix-_R_2npftt6btb_-trigger-glossary" id="radix-_R_2npftt6btb_-content-glossary" tabindex="0" data-slot="tabs-content" class="mt-2 ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 pb-8 data-[state=inactive]:hidden"><div class="flex flex-col w-full"><div id="glossary" class="relative scroll-mt-20"><button type="button" id="radix-_R_2lanpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4 @c/sidebar:mt-5 mt-6">g.</button><div class="passage pl-6 @c/sidebar:pl-4"><h2 class="font-serif font-light text-primary scroll-m-20 text-xl @c/sidebar:mt-4 mt-6 @c/sidebar:pb-2 pb-3 @c/sidebar:text-left text-center section-title">Glossary</h2></div></div><div class="mt-3 flex flex-col gap-6"><div id="4c915ddd-5405-45b1-afdd-85b8638b8488" class="relative scroll-mt-20"><button type="button" id="radix-_R_g0d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.1</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">A Thousand Houses</div><ul class="ml-4 list-disc"><li class="italic">khang bu stong</li><li class="pt-1"><span class="font-tibetan text-base">ཁང་བུ་སྟོང་།</span></li></ul><div class="glossary-instance-definition"><p class="definition">Refers to <span data-glossary-id="UT22084-068-021-9044">Encircled by a Thousand Houses</span> in <span data-glossary-id="UT22084-068-021-9544">Ornament of the Mind</span>.</p></div></div></div></div><div id="7114b873-5be9-4a36-a988-e6af036a6bf2" class="relative scroll-mt-20"><button type="button" id="radix-_R_g0l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.2</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Abhayākaragupta</div><ul class="ml-4 list-disc"><li class="italic">a bha ya ka ra gup+ta</li><li class="pt-1"><span class="font-tibetan text-base">ཨ་བྷ་ཡ་ཀ་ར་གུཔྟ།</span></li><li class="italic">abhayā­kara­gupta</li></ul><div class="glossary-instance-definition"><p class="definition">An Indian <span data-glossary-id="UT22084-068-021-8569">paṇḍita</span> involved in translating this <span data-glossary-id="UT22084-068-021-9986">sūtra</span>.</p></div></div></div></div><div id="3591dede-6897-432f-94e9-ea797987a9bc" class="relative scroll-mt-20"><button type="button" id="radix-_R_g0t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.3</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Abhidharma</div><ul class="ml-4 list-disc"><li class="italic">chos mngon pa</li><li class="pt-1"><span class="font-tibetan text-base">ཆོས་མངོན་པ།</span></li><li class="italic">abhidharma</li></ul><div class="glossary-instance-definition"><p class="definition">The Buddha’s teachings regarding subjects such as wisdom, psychology, metaphysics, and cosmology.</p></div></div></div></div><div id="7d3892fd-428b-4793-80f2-5a946f452090" class="relative scroll-mt-20"><button type="button" id="radix-_R_g155anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.4</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Abhrakrama Summit</div><ul class="ml-4 list-disc"><li class="italic">rtse mo lhang tsher</li><li class="pt-1"><span class="font-tibetan text-base">རྩེ་མོ་ལྷང་ཚེར།</span></li><li class="italic">abhrakrama</li></ul><div class="glossary-instance-definition"><p class="definition">A mountain near the <span data-glossary-id="UT22084-068-021-8489">asura</span> city <span data-glossary-id="UT22084-068-021-9012">Double Pleasure</span>.</p></div></div></div></div><div id="d3a4e122-6eda-43da-8b23-0c200e3cdb34" class="relative scroll-mt-20"><button type="button" id="radix-_R_g1d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.5</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Abhrakūṭa</div><ul class="ml-4 list-disc"><li class="italic">a bhra kU TA</li><li class="pt-1"><span class="font-tibetan text-base">ཨ་བྷྲ་ཀཱུ་ཊཱ།</span></li><li class="italic">abhrakūṭa</li></ul><div class="glossary-instance-definition"><p class="definition">A city in <span data-glossary-id="UT22084-068-021-9209">Godānīya</span>.</p></div></div></div></div><div id="0f4647d9-87a1-42ef-b904-2f27cfa08dc4" class="relative scroll-mt-20"><button type="button" id="radix-_R_g1l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.6</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">able one</div><ul class="ml-4 list-disc"><li class="italic">thub</li><li class="pt-1"><span class="font-tibetan text-base">ཐུབ།</span></li><li class="italic">muni</li></ul><div class="glossary-instance-definition"><p class="definition">An ancient title given to ascetics, monks, hermits, and saints, namely, those who have attained the realization of a truth through their own contemplation and not by divine revelation. </p><p class="definition">Here also used as a specific epithet of the buddhas.</p></div></div></div></div><div id="cbfef027-e86c-4a20-bb28-e2dfb04a3f3a" class="relative scroll-mt-20"><button type="button" id="radix-_R_g1t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.7</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Abode of Water</div><ul class="ml-4 list-disc"><li class="italic">chu gnas pa</li><li class="pt-1"><span class="font-tibetan text-base">ཆུ་གནས་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A pool in <span data-glossary-id="UT22084-068-021-9036">Dwelling on the Disk</span>.</p></div></div></div></div><div id="6684be0d-4a7a-4862-b04b-4160d4aeae60" class="relative scroll-mt-20"><button type="button" id="radix-_R_g255anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.8</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">abodes of Brahmā</div><ul class="ml-4 list-disc"><li class="italic">tshangs pa’i gnas pa</li><li class="pt-1"><span class="font-tibetan text-base">ཚངས་པའི་གནས་པ།</span></li><li class="italic">brahmavihāra</li></ul><div class="glossary-instance-definition"><p class="definition">The four <span class="ignore">abodes of Brahmā</span> are love, compassion, joy, and equanimity.</p></div></div></div></div><div id="2b4fd96b-604d-4913-b81a-9ca7bcbc2306" class="relative scroll-mt-20"><button type="button" id="radix-_R_g2d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.9</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Abounding with Jewels</div><ul class="ml-4 list-disc"><li class="italic">rin po che rnams kyis kun tu gang ba</li><li class="pt-1"><span class="font-tibetan text-base">རིན་པོ་ཆེ་རྣམས་ཀྱིས་ཀུན་ཏུ་གང་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">An ocean far beyond <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="3023de43-79da-4d7f-9a47-65514184056c" class="relative scroll-mt-20"><button type="button" id="radix-_R_g2l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.10</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Abrikṣabho</div><ul class="ml-4 list-disc"><li class="italic">’bri Sha b+ho</li><li class="pt-1"><span class="font-tibetan text-base">འབྲི་ཥ་བྷོ།</span></li><li class="italic">abrikṣabho</li></ul><div class="glossary-instance-definition"><p class="definition">A mountain in the sea south of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="1118ecdd-986d-450c-a7b7-931fbc5bbd01" class="relative scroll-mt-20"><button type="button" id="radix-_R_g2t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.11</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Abundance</div><ul class="ml-4 list-disc"><li class="italic">legs par gang ba</li><li class="pt-1"><span class="font-tibetan text-base">ལེགས་པར་གང་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A mountain between <span data-glossary-id="UT22084-068-021-9209">Godānīya</span> and <span data-glossary-id="UT22084-068-021-9847">Videha</span>.</p></div></div></div></div><div id="7e2b8e3c-f677-4e03-8851-36a52799c8bd" class="relative scroll-mt-20"><button type="button" id="radix-_R_g355anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.12</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Abundant Kūrma Monsters</div><ul class="ml-4 list-disc"><li class="italic">chu srin kU rma mang ba nyid</li><li class="pt-1"><span class="font-tibetan text-base">ཆུ་སྲིན་ཀཱུ་རྨ་མང་བ་ཉིད།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A river on <span data-glossary-id="UT22084-068-021-9657">Saṅkāśa</span>.</p></div></div></div></div><div id="dc73dc0d-f0fc-40fb-a1a0-f9af2af8c352" class="relative scroll-mt-20"><button type="button" id="radix-_R_g3d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.13</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Abundant Lions</div><ul class="ml-4 list-disc"><li class="italic">seng ges kun nes gang ba</li><li class="pt-1"><span class="font-tibetan text-base">སེང་གེས་ཀུན་ནེས་གང་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">An island in the sea west of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="fac3387c-9067-4dfb-85bf-74236be0f60c" class="relative scroll-mt-20"><button type="button" id="radix-_R_g3l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.14</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Acala</div><ul class="ml-4 list-disc"><li class="italic">brtan pa</li><li class="pt-1"><span class="font-tibetan text-base">བརྟན་པ།</span></li><li class="italic">acala</li></ul><div class="glossary-instance-definition"><p class="definition">King at the second level of the <span data-glossary-id="UT22084-068-021-8489">asuras</span>.</p></div></div></div></div><div id="2087a221-01ff-4546-af43-54cc08f2b411" class="relative scroll-mt-20"><button type="button" id="radix-_R_g3t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.15</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">acquisition</div><ul class="ml-4 list-disc"><li class="italic">thob pa</li><li class="pt-1"><span class="font-tibetan text-base">ཐོབ་པ།</span></li><li class="italic">prāpti</li></ul><div class="glossary-instance-definition"><p class="definition">A conditioned factor that according to Sarvāstivāda <span data-glossary-id="UT22084-068-021-9985">Abhidharma</span> is responsible for the <span data-glossary-id="UT22084-068-021-8583">ripening</span> of karmic actions subsequent to their having been performed. See also <a href="end-notes.xhtml#UT22084-068-021-433" data-pointer-type="id">n.35</a>.</p></div></div></div></div><div id="017e281b-0374-44df-b134-8dae8c36c9ea" class="relative scroll-mt-20"><button type="button" id="radix-_R_g455anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.16</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Action</div><ul class="ml-4 list-disc"><li class="italic">kun spyod</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་སྤྱོད།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest in <span data-glossary-id="UT22084-068-021-9026">Dwelling in Forests</span>.</p></div></div></div></div><div id="494d1933-5e79-4bb8-bd99-7a8b24a1cd90" class="relative scroll-mt-20"><button type="button" id="radix-_R_g4d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.17</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Activity</div><ul class="ml-4 list-disc"><li class="italic">rnam spyod</li><li class="pt-1"><span class="font-tibetan text-base">རྣམ་སྤྱོད།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A realm of the <span data-glossary-id="UT22084-068-021-8617">triple-lute-bearer gods</span>.</p></div></div></div></div><div id="b59b805c-4cb5-4883-a807-21fe6012f460" class="relative scroll-mt-20"><button type="button" id="radix-_R_g4l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.18</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Aḍitacandra</div><ul class="ml-4 list-disc"><li class="italic">a Di ta tsan+d+ra</li><li class="pt-1"><span class="font-tibetan text-base">ཨ་ཌི་ཏ་ཙནྡྲ།</span></li><li class="italic">aḍitacandra</li></ul><div class="glossary-instance-definition"><p class="definition">Indian <span data-glossary-id="UT22084-068-021-8569">paṇḍita</span> referred to in the <span data-glossary-id="UT22084-068-021-9986">sūtra</span>’s colophon</p></div></div></div></div><div id="2b221652-979d-481e-b12f-1cca45de85d8" class="relative scroll-mt-20"><button type="button" id="radix-_R_g4t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.19</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Adorned</div><ul class="ml-4 list-disc"><li class="italic">spras pa</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲས་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest of the <span data-glossary-id="UT22084-068-021-8489">asuras</span>.</p></div></div></div></div><div id="9c4c8b61-ab51-4654-8ba9-6db41414ee5b" class="relative scroll-mt-20"><button type="button" id="radix-_R_g555anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.20</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Adorned with Glorious Garlands</div><ul class="ml-4 list-disc"><li class="italic">gzi brjid phreng ldan</li><li class="pt-1"><span class="font-tibetan text-base">གཟི་བརྗིད་ཕྲེང་ལྡན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A previous ruler of the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="3ecf595f-fca5-471d-8237-d39bf02812d7" class="relative scroll-mt-20"><button type="button" id="radix-_R_g5d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.21</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Adorned with Musāragalva</div><ul class="ml-4 list-disc"><li class="italic">mu sa ra galba rgyan du byas pa</li><li class="pt-1"><span class="font-tibetan text-base">མུ་ས་ར་གལྦ་རྒྱན་དུ་བྱས་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A river on <span data-glossary-id="UT22084-068-021-9657">Saṅkāśa</span>.</p></div></div></div></div><div id="976c78d3-1d7d-4170-bc23-0eae01a0f613" class="relative scroll-mt-20"><button type="button" id="radix-_R_g5l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.22</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Adorned with Numerous Cascades</div><ul class="ml-4 list-disc"><li class="italic">’bab chu rnam pa sna tshogs pa dang ldan pa</li><li class="pt-1"><span class="font-tibetan text-base">འབབ་ཆུ་རྣམ་པ་སྣ་ཚོགས་པ་དང་ལྡན་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A mountain in <span data-glossary-id="UT22084-068-021-9672">Shining in Manifold Ways</span>.</p></div></div></div></div><div id="36c8a62f-eb14-4087-9c0f-ab6c97d92bb1" class="relative scroll-mt-20"><button type="button" id="radix-_R_g5t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.23</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Adorned with Springs</div><ul class="ml-4 list-disc"><li class="italic">’byung khungs kyi brgyan pa</li><li class="pt-1"><span class="font-tibetan text-base">འབྱུང་ཁུངས་ཀྱི་བརྒྱན་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">An emanated mountain on the trunk of <span data-glossary-id="UT22084-068-021-8636">Airāvaṇa</span>.</p></div></div></div></div><div id="f8912612-1470-4d65-9008-4c3badb0c43c" class="relative scroll-mt-20"><button type="button" id="radix-_R_g655anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.24</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Adūva</div><ul class="ml-4 list-disc"><li class="italic">a Du bA</li><li class="pt-1"><span class="font-tibetan text-base">ཨ་ཌུ་བཱ།</span></li><li class="italic">adūva</li></ul><div class="glossary-instance-definition"><p class="definition">A river on <span data-glossary-id="UT22084-068-021-9657">Saṅkāśa</span>.</p></div></div></div></div><div id="71008734-7212-40a4-8292-af02beb73b8d" class="relative scroll-mt-20"><button type="button" id="radix-_R_g6d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.25</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Advancing Fire</div><ul class="ml-4 list-disc"><li class="italic">’gro ba mes sreg, ’gro ba mes ’jig</li><li class="pt-1"><span class="font-tibetan text-base">འགྲོ་བ་མེས་འཇིག, འགྲོ་བ་མེས་སྲེག</span></li><li class="italic">caṅkramāṇāgni­dāha</li></ul><div class="glossary-instance-definition"><p class="definition">One of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-9279">Hell of Ultimate Torment</span>.</p></div></div></div></div><div id="9a4b2555-d9c2-41b4-a5c0-2a8a0a115fa5" class="relative scroll-mt-20"><button type="button" id="radix-_R_g6l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.26</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">affliction</div><ul class="ml-4 list-disc"><li class="italic">nyon mongs</li><li class="pt-1"><span class="font-tibetan text-base">ཉོན་མོངས།</span></li><li class="italic">kleśa</li></ul><div class="glossary-instance-definition"><p class="definition">Literally “pain,” “torment,” or “<span class="ignore">affliction</span>.” In Buddhist Hybrid Sanskrit it literally means “impurity” or “depravity.” In its technical use in Buddhism it means any negative quality in the mind that causes continued existence in <span data-glossary-id="UT22084-068-021-9884">saṃsāra</span>. There are the 84,000 variations of mental disturbances for which the 84,000 categories of the Buddha’s teachings serve as the antidote. These mental disturbances can be subsumed into the three or five poisons of attachment, aversion, and ignorance plus arrogance and jealousy.</p></div></div></div></div><div id="85d2e03b-5740-407c-bd6b-39265543ee3b" class="relative scroll-mt-20"><button type="button" id="radix-_R_g6t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.27</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">age of excellence</div><ul class="ml-4 list-disc"><li class="italic">bzang ldan gyi dus</li><li class="pt-1"><span class="font-tibetan text-base">བཟང་ལྡན་གྱི་དུས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">In the context of this <span data-glossary-id="UT22084-068-021-9986">sūtra</span>, this appears to refer to the “<span data-glossary-id="UT22084-068-021-8483">age of perfection</span>.”</p></div></div></div></div><div id="0d768242-00f0-454c-ab1d-bda8b119a81b" class="relative scroll-mt-20"><button type="button" id="radix-_R_g755anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.28</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">age of perfection</div><ul class="ml-4 list-disc"><li class="italic">rdzogs ldan gyi dus</li><li class="pt-1"><span class="font-tibetan text-base">རྫོགས་ལྡན་གྱི་དུས།</span></li><li class="italic">kṛtayuga</li></ul><div class="glossary-instance-definition"><p class="definition">The first of the <span data-glossary-id="UT22084-068-021-10017">four ages</span> of human life in <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>. Humans in this age enjoy good qualities such as long lifespans free from disease (see <a href="UT22084-068-021-chapter-8.xhtml#UT22084-068-021-8228" data-pointer-type="id">5.238</a>). Over the course of the <span data-glossary-id="UT22084-068-021-10017">four ages</span> humans will lose a quarter of these qualities between each age.</p></div></div></div></div><div id="a3701720-b643-4651-b78a-76ec8d56aaf5" class="relative scroll-mt-20"><button type="button" id="radix-_R_g7d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.29</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">age of strife</div><ul class="ml-4 list-disc"><li class="italic">rtsod ldan gyi dus</li><li class="pt-1"><span class="font-tibetan text-base">རྩོད་ལྡན་གྱི་དུས།</span></li><li class="italic">kaliyuga</li></ul><div class="glossary-instance-definition"><p class="definition">The last of the <span data-glossary-id="UT22084-068-021-10017">four ages</span> of human life in <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>. In this age humans are endowed with only one remaining quarter of the good qualities that they had during the <span data-glossary-id="UT22084-068-021-8483">age of perfection</span>.</p></div></div></div></div><div id="76bfadf2-98bf-41e2-a8fa-8f76513d0e47" class="relative scroll-mt-20"><button type="button" id="radix-_R_g7l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.30</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">age of threefold endowment, threefold endowment</div><ul class="ml-4 list-disc"><li class="italic">gsum ldan gyi dus</li><li class="pt-1"><span class="font-tibetan text-base">གསུམ་ལྡན་གྱི་དུས།</span></li><li class="italic">tretayuga</li></ul><div class="glossary-instance-definition"><p class="definition">The second of the <span data-glossary-id="UT22084-068-021-10017">four ages</span> of human life in <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>. In this age humans are endowed with three quarters of the good qualities that they had during the <span data-glossary-id="UT22084-068-021-8483">age of perfection</span>.</p></div></div></div></div><div id="501c9b2d-f935-48bf-8735-d3ea86d126e4" class="relative scroll-mt-20"><button type="button" id="radix-_R_g7t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.31</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">age of twofold endowment, twofold</div><ul class="ml-4 list-disc"><li class="italic">gnyis ldan gyi dus</li><li class="pt-1"><span class="font-tibetan text-base">གཉིས་ལྡན་གྱི་དུས།</span></li><li class="italic">dvāparayuga</li></ul><div class="glossary-instance-definition"><p class="definition">The third of the <span data-glossary-id="UT22084-068-021-10017">four ages</span> of human life in <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>. In this age humans are endowed with two quarters, or half of the good qualities that they had during the <span data-glossary-id="UT22084-068-021-8483">age of perfection</span>. </p></div></div></div></div><div id="b43ca2c1-a3b3-4ed9-b5f9-520b1b5ed114" class="relative scroll-mt-20"><button type="button" id="radix-_R_g855anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.32</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">aggregate</div><ul class="ml-4 list-disc"><li class="italic">phung po</li><li class="pt-1"><span class="font-tibetan text-base">ཕུང་པོ།</span></li><li class="italic">skandha</li></ul><div class="glossary-instance-definition"><p class="definition">The five psycho-physical components of personal experience: form, feeling, perception, formations, and consciousness.</p></div></div></div></div><div id="5015ae4f-98db-492b-b39e-0064362dc4e0" class="relative scroll-mt-20"><button type="button" id="radix-_R_g8d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.33</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">agnicūḍa</div><ul class="ml-4 list-disc"><li class="italic">ag ni tsu Da</li><li class="pt-1"><span class="font-tibetan text-base">ཨག་ནི་ཙུ་ཌ།</span></li><li class="italic">agnicūḍa</li></ul><div class="glossary-instance-definition"><p class="definition">A bird that we have been unable to identify.</p></div></div></div></div><div id="e34669f1-0ab4-4450-9f2a-4f0e1a0e197b" class="relative scroll-mt-20"><button type="button" id="radix-_R_g8l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.34</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ahi</div><ul class="ml-4 list-disc"><li class="italic">kun ’gro</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་འགྲོ།</span></li><li class="italic">ahi</li></ul><div class="glossary-instance-definition"><p class="definition">A righteous <span data-glossary-id="UT22084-068-021-8562">nāga</span> king.</p></div></div></div></div><div id="bfac64f6-47d3-4e7f-93bf-b6a403f30b46" class="relative scroll-mt-20"><button type="button" id="radix-_R_g8t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.35</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Airāvaṇa</div><ul class="ml-4 list-disc"><li class="italic">sa srung gi bu</li><li class="pt-1"><span class="font-tibetan text-base">ས་སྲུང་གི་བུ།</span></li><li class="italic">airāvaṇa</li></ul><div class="glossary-instance-definition"><p class="definition"><span data-glossary-id="UT22084-068-021-8738">Śakra</span>’s elephant.</p></div></div></div></div><div id="054d4525-ad0a-4d70-ab79-01f35bc4c8ac" class="relative scroll-mt-20"><button type="button" id="radix-_R_g955anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.36</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Alala</div><ul class="ml-4 list-disc"><li class="italic">a la la</li><li class="pt-1"><span class="font-tibetan text-base">ཨ་ལ་ལ།</span></li><li class="italic">ṭaṭaṭaṭa</li></ul><div class="glossary-instance-definition"><p class="definition">A realm that neighbors the <span data-glossary-id="UT22084-068-021-9278">Hell of Intense Heat</span>.</p></div></div></div></div><div id="d2c12afc-be10-4612-b98c-53bf5a22bfe5" class="relative scroll-mt-20"><button type="button" id="radix-_R_g9d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.37</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">All Seasons</div><ul class="ml-4 list-disc"><li class="italic">dus tshigs thams cad</li><li class="pt-1"><span class="font-tibetan text-base">དུས་ཚིགས་ཐམས་ཅད།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest upon <span data-glossary-id="UT22084-068-021-9575">Mount Playful</span> in <span data-glossary-id="UT22084-068-021-9734">Sudharma</span>.</p></div></div></div></div><div id="0e76a5bb-9397-4548-a23b-0308b5c69c5f" class="relative scroll-mt-20"><button type="button" id="radix-_R_g9l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.38</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">All the People</div><ul class="ml-4 list-disc"><li class="italic">skye bo thams cad</li><li class="pt-1"><span class="font-tibetan text-base">སྐྱེ་བོ་ཐམས་ཅད།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A town in <span data-glossary-id="UT22084-068-021-9847">Videha</span>.</p></div></div></div></div><div id="e1998ba4-9747-4516-81a0-25485de5d175" class="relative scroll-mt-20"><button type="button" id="radix-_R_g9t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.39</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">All Worlds</div><ul class="ml-4 list-disc"><li class="italic">’jig rten thams cad pa</li><li class="pt-1"><span class="font-tibetan text-base">འཇིག་རྟེན་ཐམས་ཅད་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A summit in <span data-glossary-id="UT22084-068-021-9544">Ornament of the Mind</span>.</p></div></div></div></div><div id="7b357867-d2f5-4ed6-8c3b-3b8ca15e14f8" class="relative scroll-mt-20"><button type="button" id="radix-_R_ga55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.40</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">All-Reaching</div><ul class="ml-4 list-disc"><li class="italic">nye ’khor na khyab pa</li><li class="pt-1"><span class="font-tibetan text-base">ཉེ་འཁོར་ན་ཁྱབ་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A river on <span data-glossary-id="UT22084-068-021-9657">Saṅkāśa</span>.</p></div></div></div></div><div id="04bccafd-3cc4-42b2-a249-07b6649932ba" class="relative scroll-mt-20"><button type="button" id="radix-_R_gad5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.41</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">alms</div><ul class="ml-4 list-disc"><li class="italic">bsod snyoms</li><li class="pt-1"><span class="font-tibetan text-base">བསོད་སྙོམས།</span></li><li class="italic">piṇḍapāta</li></ul><div class="glossary-instance-definition"><p class="definition">The sharing of merit as food, drink, etc. is offered to members of the saṅgha.</p></div></div></div></div><div id="cdbc113a-61da-44e6-98b1-01e57d0c83ad" class="relative scroll-mt-20"><button type="button" id="radix-_R_gal5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.42</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Always Delightful</div><ul class="ml-4 list-disc"><li class="italic">rtag tu nyams dga’</li><li class="pt-1"><span class="font-tibetan text-base">རྟག་ཏུ་ཉམས་དགའ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">(1) A forest of the <span data-glossary-id="UT22084-068-021-8489">asuras</span>. (2) A grove in <span data-glossary-id="UT22084-068-021-9403">Lateral</span>.</p></div></div></div></div><div id="35fc0557-97e2-44f1-b3f9-77a3dae381db" class="relative scroll-mt-20"><button type="button" id="radix-_R_gat5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.43</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Always Joyous</div><ul class="ml-4 list-disc"><li class="italic">rtag tu dga’ ba, rtag tu mngon par dga’ ba, tin di kun dga’</li><li class="pt-1"><span class="font-tibetan text-base">ཏིན་དི་ཀུན་དགའ།, རྟག་ཏུ་དགའ་བ།, རྟག་ཏུ་མངོན་པར་དགའ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">(1) A park in <span data-glossary-id="UT22084-068-021-9757">Sustained by Fruition</span> (<em class="foreign text-wy" lang="bo-LATN">rtag tu dga’ ba</em>). (2) A pleasure grove in <span data-glossary-id="UT22084-068-021-9283">High Conduct</span> (<em class="foreign text-wy" lang="bo-LATN">rtag tu dga’ ba</em>). (3) A pond on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span> (<em class="foreign text-wy" lang="bo-LATN">rtag tu mngon par dga’ ba</em>). (4) A forest of the <span data-glossary-id="UT22084-068-021-8489">asuras</span> (<em class="foreign text-wy" lang="bo-LATN">tin di kun dga’</em>).</p></div></div></div></div><div id="449eedcc-a3e7-49ba-963f-6d7b9a4b6fca" class="relative scroll-mt-20"><button type="button" id="radix-_R_gb55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.44</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ānanda</div><ul class="ml-4 list-disc"><li class="italic">kun dga’ bo</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་དགའ་བོ།</span></li><li class="italic">ānanda</li></ul><div class="glossary-instance-definition"><p>A major śrāvaka disciple and personal attendant of the Buddha Śākyamuni during the last twenty-five years of his life. He was a cousin of the Buddha (according to the <cite class="title break text-sa" lang="sa-LATN">Mahāvastu</cite>, he was a son of Śuklodana, one of the brothers of King Śuddhodana, which means he was a brother of Devadatta; other sources say he was a son of Amṛtodana, another brother of King Śuddhodana, which means he would have been a brother of Aniruddha).</p><p>Ānanda, having always been in the Buddha’s presence, is said to have memorized all the teachings he heard and is celebrated for having recited all the Buddha’s teachings by memory at the first council of the Buddhist saṅgha, thus preserving the teachings after the Buddha’s parinirvāṇa. The phrase “Thus did I hear at one time,” found at the beginning of the sūtras, usually stands for his recitation of the teachings. He became a patriarch after the passing of Mahākāśyapa.</p></div></div></div></div><div id="c1dafb18-55e7-411b-b562-92dce8fc1bc0" class="relative scroll-mt-20"><button type="button" id="radix-_R_gbd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.45</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Anavatapta</div><ul class="ml-4 list-disc"><li class="italic">ma dros pa</li><li class="pt-1"><span class="font-tibetan text-base">མ་དྲོས་པ།</span></li><li class="italic">anavatapta</li></ul><div class="glossary-instance-definition"><p class="definition">A lake near Mount <span data-glossary-id="UT22084-068-021-9739">Sumeru</span>.</p></div></div></div></div><div id="07cf595b-f510-4e65-91fe-6509c1dcb4cf" class="relative scroll-mt-20"><button type="button" id="radix-_R_gbl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.46</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Andhaka</div><ul class="ml-4 list-disc"><li class="italic">an dha ka</li><li class="pt-1"><span class="font-tibetan text-base">ཨན་དྷ་ཀ</span></li><li class="italic">andhaka</li></ul><div class="glossary-instance-definition"><p class="definition">Unidentified region of India.</p></div></div></div></div><div id="735976cb-b5c9-4885-b73d-f5bf6f511794" class="relative scroll-mt-20"><button type="button" id="radix-_R_gbt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.47</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Aṅga</div><ul class="ml-4 list-disc"><li class="italic">ang ga</li><li class="pt-1"><span class="font-tibetan text-base">ཨང་ག</span></li><li class="italic">aṅga</li></ul><div class="glossary-instance-definition"><p class="definition">A land in the east of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="49e78f8f-4702-4a65-846b-a7e3bc5ee165" class="relative scroll-mt-20"><button type="button" id="radix-_R_gc55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.48</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">animal</div><ul class="ml-4 list-disc"><li class="italic">dud ’gro</li><li class="pt-1"><span class="font-tibetan text-base">དུད་འགྲོ།</span></li><li class="italic">tīryak</li></ul><div class="glossary-instance-definition"><p class="definition">One of the five or six classes of sentient beings, who suffer from gross ignorance or bewilderment (<em class="foreign text-wy" lang="bo-LATN">gti mug</em>, <em class="foreign text-wy" lang="bo-LATN">moha</em>). They inhabit the realm of desire along with human beings.</p></div></div></div></div><div id="e3d81638-947d-4188-9fb0-ab85855682c1" class="relative scroll-mt-20"><button type="button" id="radix-_R_gcd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.49</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Aṇira</div><ul class="ml-4 list-disc"><li class="italic">a Ni ra</li><li class="pt-1"><span class="font-tibetan text-base">ཨ་ཎི་ར།</span></li><li class="italic">aṇira</li></ul><div class="glossary-instance-definition"><p class="definition">A city in <span data-glossary-id="UT22084-068-021-9209">Godānīya</span>.</p></div></div></div></div><div id="1a7267b1-d939-421f-9507-9bf6288a9835" class="relative scroll-mt-20"><button type="button" id="radix-_R_gcl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.50</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Antelope Dress</div><ul class="ml-4 list-disc"><li class="italic">rna ba gon pa</li><li class="pt-1"><span class="font-tibetan text-base">རྣ་བ་གོན་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A land in the east of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="f4c608f9-c127-4e00-a800-8ce5f8764db7" class="relative scroll-mt-20"><button type="button" id="radix-_R_gct5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.51</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Anūna</div><ul class="ml-4 list-disc"><li class="italic">a nU na</li><li class="pt-1"><span class="font-tibetan text-base">ཨ་ནཱུ་ན།</span></li><li class="italic">anūna</li></ul><div class="glossary-instance-definition"><p class="definition">A mountain in the east of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="59d43f84-2a07-48ff-9606-bdf201718ef0" class="relative scroll-mt-20"><button type="button" id="radix-_R_gd55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.52</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Any Taste You Like</div><ul class="ml-4 list-disc"><li class="italic">ji ltar ’dod pa’i ro</li><li class="pt-1"><span class="font-tibetan text-base">ཇི་ལྟར་འདོད་པའི་རོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lake on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span>.</p></div></div></div></div><div id="c0be66a6-adef-4076-bfed-1bd31a062e33" class="relative scroll-mt-20"><button type="button" id="radix-_R_gdd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.53</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ardhamaru</div><ul class="ml-4 list-disc"><li class="italic">ar dha ma ru</li><li class="pt-1"><span class="font-tibetan text-base">ཨར་དྷ་མ་རུ།</span></li><li class="italic">ardhamaru</li></ul><div class="glossary-instance-definition"><p class="definition">A mountain in the sea west of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="122343bb-ba85-456e-a6df-169cee92fb80" class="relative scroll-mt-20"><button type="button" id="radix-_R_gdl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.54</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Arjuna</div><ul class="ml-4 list-disc"><li class="italic">ardzu naH</li><li class="pt-1"><span class="font-tibetan text-base">ཨརྫུ་ནཿ།</span></li><li class="italic">arjuna</li></ul><div class="glossary-instance-definition"><p class="definition">A lake on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span>.</p></div></div></div></div><div id="78d9dcf5-719c-4c3b-a32a-789690f496f4" class="relative scroll-mt-20"><button type="button" id="radix-_R_gdt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.55</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Army of Heroes</div><ul class="ml-4 list-disc"><li class="italic">dpa’ bo’i sde</li><li class="pt-1"><span class="font-tibetan text-base">དཔའ་བོའི་སྡེ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A land to the north of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="95f18d83-afa5-4646-80ae-c72d5927b0ab" class="relative scroll-mt-20"><button type="button" id="radix-_R_ge55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.56</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">aśoka</div><ul class="ml-4 list-disc"><li class="italic">mya ngan med</li><li class="pt-1"><span class="font-tibetan text-base">མྱ་ངན་མེད།</span></li><li class="italic">aśoka</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign">Saraca asoca</em>. The aromatic blossoms of this plant are clustered together as orange, yellow, and red bunches of petals.</p></div></div></div></div><div id="f12d9c95-4b6d-442c-ac5b-7fd1c7794f19" class="relative scroll-mt-20"><button type="button" id="radix-_R_ged5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.57</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">aspects of the four truths of noble beings, sixteen aspects, sixteen aspects (of the four truths of noble beings)</div><ul class="ml-4 list-disc"><li class="italic">bden bzhi’i dpyod pa rnam pa bcu drug, bden bzhi’i rnam pa bcu drug</li><li class="pt-1"><span class="font-tibetan text-base">བདེན་བཞིའི་དཔྱོད་པ་རྣམ་པ་བཅུ་དྲུག, བདེན་བཞིའི་རྣམ་པ་བཅུ་དྲུག</span></li><li class="italic">ṣoḍaśākāra</li></ul><div class="glossary-instance-definition"><p class="definition">These are impermanence, suffering, emptiness, absence of self, origination, causality, production, conditionality, cessation, peace, excellence, deliverance, path, reason, practice, and release. See <a href="UT22084-068-021-section-6.xhtml#UT22084-068-021-4133" data-pointer-type="id">4.B.1188</a> for an explanation of these.</p></div></div></div></div><div id="5f1024e5-d735-4094-89c8-9a8baec55fd2" class="relative scroll-mt-20"><button type="button" id="radix-_R_gel5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.58</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">asura</div><ul class="ml-4 list-disc"><li class="italic">lha ma yin</li><li class="pt-1"><span class="font-tibetan text-base">ལྷ་མ་ཡིན།</span></li><li class="italic">asura</li></ul><div class="glossary-instance-definition"><p>A type of nonhuman being whose precise status is subject to different views, but is included as one of the six classes of beings in the sixfold classification of realms of rebirth. In the Buddhist context, asuras are powerful beings said to be dominated by envy, ambition, and hostility. They are also known in the pre-Buddhist and pre-Vedic mythologies of India and Iran, and feature prominently in Vedic and post-Vedic Brahmanical mythology, as well as in the Buddhist tradition. In these traditions, asuras are often described as being engaged in interminable conflict with the devas (gods).</p></div></div></div></div><div id="9ab99c71-ad21-4eb7-9f2b-d5efe40fb64e" class="relative scroll-mt-20"><button type="button" id="radix-_R_get5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.59</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">asurī</div><ul class="ml-4 list-disc"><li class="italic">lha ma yin gyi bu mo</li><li class="pt-1"><span class="font-tibetan text-base">ལྷ་མ་ཡིན་གྱི་བུ་མོ།</span></li><li class="italic">asurī</li></ul><div class="glossary-instance-definition"><p class="definition">A female <span data-glossary-id="UT22084-068-021-8489">asura</span>.</p></div></div></div></div><div id="db390ea4-e611-4052-9e54-cfa2f47b6f1c" class="relative scroll-mt-20"><button type="button" id="radix-_R_gf55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.60</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Aṭopa</div><ul class="ml-4 list-disc"><li class="italic">bsgyings pa</li><li class="pt-1"><span class="font-tibetan text-base">བསྒྱིངས་པ།</span></li><li class="italic">aṭopa</li></ul><div class="glossary-instance-definition"><p class="definition">An unvirtuous <span data-glossary-id="UT22084-068-021-8562">nāga</span> king.</p></div></div></div></div><div id="41933dd3-edec-432a-bdb8-59b69e595161" class="relative scroll-mt-20"><button type="button" id="radix-_R_gfd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.61</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Attached to Objects</div><ul class="ml-4 list-disc"><li class="italic">yul la chags pa</li><li class="pt-1"><span class="font-tibetan text-base">ཡུལ་ལ་ཆགས་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A realm inhabited by <span data-glossary-id="UT22084-068-021-8530">garland-bearer gods</span>.</p></div></div></div></div><div id="5ea36316-13ef-49c8-a58c-b367a13e5452" class="relative scroll-mt-20"><button type="button" id="radix-_R_gfl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.62</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Attached to Pleasures</div><ul class="ml-4 list-disc"><li class="italic">’dod pa la chags pa</li><li class="pt-1"><span class="font-tibetan text-base">འདོད་པ་ལ་ཆགས་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A realm inhabited by <span data-glossary-id="UT22084-068-021-8530">garland-bearer gods</span>.</p></div></div></div></div><div id="c689f598-567d-48db-b270-ac1fd5d68918" class="relative scroll-mt-20"><button type="button" id="radix-_R_gft5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.63</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Attached to Smell</div><ul class="ml-4 list-disc"><li class="italic">dri la chags pa</li><li class="pt-1"><span class="font-tibetan text-base">དྲི་ལ་ཆགས་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A realm of the <span data-glossary-id="UT22084-068-021-8621">vessel-bearer gods</span>.</p></div></div></div></div><div id="64094fd8-df42-4c66-84d1-8bfb06e31e4a" class="relative scroll-mt-20"><button type="button" id="radix-_R_gg55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.64</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Attached to Sound</div><ul class="ml-4 list-disc"><li class="italic">sgra la chags pa</li><li class="pt-1"><span class="font-tibetan text-base">སྒྲ་ལ་ཆགས་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A realm of the <span data-glossary-id="UT22084-068-021-8621">vessel-bearer gods</span>.</p></div></div></div></div><div id="534ca811-b034-4eeb-8c02-5d8341e3855d" class="relative scroll-mt-20"><button type="button" id="radix-_R_ggd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.65</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Attached to That</div><ul class="ml-4 list-disc"><li class="italic">de la chags</li><li class="pt-1"><span class="font-tibetan text-base">དེ་ལ་ཆགས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A realm of the <span data-glossary-id="UT22084-068-021-8617">triple-lute-bearer gods</span>.</p></div></div></div></div><div id="288b51a8-a353-41cf-a0e4-b1275e277d99" class="relative scroll-mt-20"><button type="button" id="radix-_R_ggl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.66</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Attraction</div><ul class="ml-4 list-disc"><li class="italic">sems song ba</li><li class="pt-1"><span class="font-tibetan text-base">སེམས་སོང་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A city in <span data-glossary-id="UT22084-068-021-9209">Godānīya</span>.</p></div></div></div></div><div id="fc8d3385-064e-4534-8bd9-b65b7502e6f3" class="relative scroll-mt-20"><button type="button" id="radix-_R_ggt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.67</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Auspicious Joy of Carefulness</div><ul class="ml-4 list-disc"><li class="italic">bag yod pa la mngon par dga’ ba bkra shis</li><li class="pt-1"><span class="font-tibetan text-base">བག་ཡོད་པ་ལ་མངོན་པར་དགའ་བ་བཀྲ་ཤིས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-068-021-8531">god</span> who taught <span data-glossary-id="UT22084-068-021-8720">Musulundha</span> the Dharma.</p></div></div></div></div><div id="38b288d7-5baf-41cb-9e4c-a862ca98d2c4" class="relative scroll-mt-20"><button type="button" id="radix-_R_gh55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.68</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Auspicious One</div><ul class="ml-4 list-disc"><li class="italic">bkra shis ’dzin</li><li class="pt-1"><span class="font-tibetan text-base">བཀྲ་ཤིས་འཛིན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A previous ruler of the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="5c02e315-fc8b-48ed-859b-d5b0c10d99a2" class="relative scroll-mt-20"><button type="button" id="radix-_R_ghd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.69</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Auspicious Time</div><ul class="ml-4 list-disc"><li class="italic">dus bzangs</li><li class="pt-1"><span class="font-tibetan text-base">དུས་བཟངས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A king of the swans.</p></div></div></div></div><div id="6b4fa849-1b2d-42c8-a44c-a3dcb8abfb49" class="relative scroll-mt-20"><button type="button" id="radix-_R_ghl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.70</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Babbler</div><ul class="ml-4 list-disc"><li class="italic">ca co ba</li><li class="pt-1"><span class="font-tibetan text-base">ཅ་ཅོ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A river on <span data-glossary-id="UT22084-068-021-9823">Upward Ocean</span>.</p></div></div></div></div><div id="1ba7e57f-7c8c-45b2-aed7-c8672dd9447d" class="relative scroll-mt-20"><button type="button" id="radix-_R_ght5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.71</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bādūtam</div><ul class="ml-4 list-disc"><li class="italic">bA dU taM</li><li class="pt-1"><span class="font-tibetan text-base">བཱ་དཱུ་ཏཾ།</span></li><li class="italic">bādūtam</li></ul><div class="glossary-instance-definition"><p class="definition">A town in <span data-glossary-id="UT22084-068-021-9847">Videha</span>.</p></div></div></div></div><div id="dba92358-1b48-479e-9844-39b4308ce9d9" class="relative scroll-mt-20"><button type="button" id="radix-_R_gi55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.72</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bāhiliko</div><ul class="ml-4 list-disc"><li class="italic">ba hi li ko</li><li class="pt-1"><span class="font-tibetan text-base">བ་ཧི་ལི་ཀོ</span></li><li class="italic">bāhiliko</li></ul><div class="glossary-instance-definition"><p class="definition">A land to the north of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="7bf49ebe-6836-4927-b19e-ef0dad14ee12" class="relative scroll-mt-20"><button type="button" id="radix-_R_gid5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.73</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bāhlika</div><ul class="ml-4 list-disc"><li class="italic">ba lhi ka</li><li class="pt-1"><span class="font-tibetan text-base">བ་ལྷི་ཀ</span></li><li class="italic">bāhlika</li></ul><div class="glossary-instance-definition"><p class="definition">The people of the Balkh region, or Bactrians.</p></div></div></div></div><div id="c2cebefd-ebdd-432b-9caf-679c8f530b2d" class="relative scroll-mt-20"><button type="button" id="radix-_R_gil5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.74</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">bakula</div><ul class="ml-4 list-disc"><li class="italic">ba ku la</li><li class="pt-1"><span class="font-tibetan text-base">བ་ཀུ་ལ།</span></li><li class="italic">bakula</li></ul><div class="glossary-instance-definition"><p class="definition">The <em class="foreign">Mimusops elengi</em>, also known as the bulletwood tree.</p></div></div></div></div><div id="851f899e-d37f-4b0b-bfc6-ef2212fb5e27" class="relative scroll-mt-20"><button type="button" id="radix-_R_git5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.75</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bamboo Growth</div><ul class="ml-4 list-disc"><li class="italic">’od mas skyes pa</li><li class="pt-1"><span class="font-tibetan text-base">འོད་མས་སྐྱེས་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lake on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span>.</p></div></div></div></div><div id="3f9b6781-83cd-4646-b292-93066dd16c8c" class="relative scroll-mt-20"><button type="button" id="radix-_R_gj55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.76</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bamboo Water</div><ul class="ml-4 list-disc"><li class="italic">’od ma’i chu</li><li class="pt-1"><span class="font-tibetan text-base">འོད་མའི་ཆུ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lake on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span>.</p></div></div></div></div><div id="526f8dee-bd1c-4a80-a9f3-d7465983d8a8" class="relative scroll-mt-20"><button type="button" id="radix-_R_gjd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.77</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bamboos Everywhere</div><ul class="ml-4 list-disc"><li class="italic">’od mas khyab par gyur pa</li><li class="pt-1"><span class="font-tibetan text-base">འོད་མས་ཁྱབ་པར་གྱུར་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lake on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span>.</p></div></div></div></div><div id="6a988e38-7eb9-42e9-9dcd-9de9e71ade93" class="relative scroll-mt-20"><button type="button" id="radix-_R_gjl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.78</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Barbarā</div><ul class="ml-4 list-disc"><li class="italic">bar ba rA</li><li class="pt-1"><span class="font-tibetan text-base">བར་བ་རཱ།</span></li><li class="italic">barbarā</li></ul><div class="glossary-instance-definition"><p class="definition">A land to the north of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="b72e8b7d-0883-4117-a873-71be88bb8cbc" class="relative scroll-mt-20"><button type="button" id="radix-_R_gjt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.79</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bāsa</div><ul class="ml-4 list-disc"><li class="italic">bA sa’i chu</li><li class="pt-1"><span class="font-tibetan text-base">བཱ་སའི་ཆུ།</span></li><li class="italic">bāsa</li></ul><div class="glossary-instance-definition"><p class="definition">A river in the south of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="fd15e138-dd74-4525-b3c9-2044d8e85094" class="relative scroll-mt-20"><button type="button" id="radix-_R_gk55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.80</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Battered Bodies</div><ul class="ml-4 list-disc"><li class="italic">lus zhum</li><li class="pt-1"><span class="font-tibetan text-base">ལུས་ཞུམ།</span></li><li class="italic">vilīnagātra</li></ul><div class="glossary-instance-definition"><p class="definition">One of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-9279">Hell of Ultimate Torment</span>.</p></div></div></div></div><div id="0af14cd8-00a8-4961-8190-44071f4e6876" class="relative scroll-mt-20"><button type="button" id="radix-_R_gkd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.81</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Beautiful Grove</div><ul class="ml-4 list-disc"><li class="italic">tshal shin tu sdug pa</li><li class="pt-1"><span class="font-tibetan text-base">ཚལ་ཤིན་ཏུ་སྡུག་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A grove in <span data-glossary-id="UT22084-068-021-9036">Dwelling on the Disk</span>.</p></div></div></div></div><div id="c00c2639-c8cc-41f5-95fd-ac5adb5ad4cf" class="relative scroll-mt-20"><button type="button" id="radix-_R_gkl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.82</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Beautiful Nectar</div><ul class="ml-4 list-disc"><li class="italic">bdud rtsis</li><li class="pt-1"><span class="font-tibetan text-base">བདུད་རྩིས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest on <span data-glossary-id="UT22084-068-021-9260">Heap in the Stream</span>.</p></div></div></div></div><div id="824309e9-2994-445b-ac62-b4cf1264e4ad" class="relative scroll-mt-20"><button type="button" id="radix-_R_gkt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.83</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Beautiful Ornament</div><ul class="ml-4 list-disc"><li class="italic">mdzes pa’i rgyan</li><li class="pt-1"><span class="font-tibetan text-base">མཛེས་པའི་རྒྱན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest on <span data-glossary-id="UT22084-068-021-9260">Heap in the Stream</span>.</p></div></div></div></div><div id="d1e97d23-acec-4098-a63e-2b280734fdbc" class="relative scroll-mt-20"><button type="button" id="radix-_R_gl55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.84</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Beautiful Voice</div><ul class="ml-4 list-disc"><li class="italic">grogs pa nyan</li><li class="pt-1"><span class="font-tibetan text-base">གྲོགས་པ་ཉན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">The horse that pulls the chariot of the sun.</p></div></div></div></div><div id="ff010f2c-654a-4f67-b162-f12494a8bf5c" class="relative scroll-mt-20"><button type="button" id="radix-_R_gld5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.85</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Beauty</div><ul class="ml-4 list-disc"><li class="italic">mdzes pa, rnam mdzes, rnam par mdzes pa</li><li class="pt-1"><span class="font-tibetan text-base">མཛེས་པ།, རྣམ་པར་མཛེས་པ།, རྣམ་མཛེས།</span></li><li class="italic">śobhavanā</li></ul><div class="glossary-instance-definition"><p class="definition">(1) A city at the fourth <span data-glossary-id="UT22084-068-021-8489">asura</span> level, <span><span data-glossary-id="UT22084-068-021-9305">Immovable</span></span>. (2) A lake on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span>. (3) A pond on <span data-glossary-id="UT22084-068-021-9420">Lofty Mound</span> (<em class="foreign text-wy" lang="bo-LATN">rnam par mdzes pa</em>). (3) Refers to <span data-glossary-id="UT22084-068-021-9023">Dwelling in Beauty</span> (<em class="foreign text-wy" lang="bo-LATN">rnam mdzes</em>).</p></div></div></div></div><div id="c814969e-1c2b-4d17-ba86-6fedcce76c91" class="relative scroll-mt-20"><button type="button" id="radix-_R_gll5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.86</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bees Everywhere</div><ul class="ml-4 list-disc"><li class="italic">bung bas khyab pa</li><li class="pt-1"><span class="font-tibetan text-base">བུང་བས་ཁྱབ་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A pond on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span>.</p></div></div></div></div><div id="f6125328-03f5-43b9-ac0c-daf754eb0d78" class="relative scroll-mt-20"><button type="button" id="radix-_R_glt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.87</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Beneficial Eyes</div><ul class="ml-4 list-disc"><li class="italic">phan par ’jug pa’i mig</li><li class="pt-1"><span class="font-tibetan text-base">ཕན་པར་འཇུག་པའི་མིག</span></li></ul><div class="glossary-instance-definition"><p class="definition">A town in <span data-glossary-id="UT22084-068-021-9847">Videha</span>.</p></div></div></div></div><div id="d7758801-4849-4a83-aafd-9680e1f32f55" class="relative scroll-mt-20"><button type="button" id="radix-_R_gm55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.88</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Beryl Forest</div><ul class="ml-4 list-disc"><li class="italic">bai DU rya’i tshal</li><li class="pt-1"><span class="font-tibetan text-base">བཻ་ཌཱུ་རྱའི་ཚལ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest in <span data-glossary-id="UT22084-068-021-9869">White Body</span>.</p></div></div></div></div><div id="3a5470b8-3fed-4db2-a508-d4f9db013da0" class="relative scroll-mt-20"><button type="button" id="radix-_R_gmd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.89</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Beryl River</div><ul class="ml-4 list-disc"><li class="italic">bai DUr+ya’i chu</li><li class="pt-1"><span class="font-tibetan text-base">བཻ་ཌཱུརྱའི་ཆུ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A river at <span data-glossary-id="UT22084-068-021-9606">Radiant Streams</span>.</p></div></div></div></div><div id="c8941e81-b7bc-436d-88f4-abcf828e0854" class="relative scroll-mt-20"><button type="button" id="radix-_R_gml5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.90</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bhadraka</div><ul class="ml-4 list-disc"><li class="italic">bzang ldan</li><li class="pt-1"><span class="font-tibetan text-base">བཟང་ལྡན།</span></li><li class="italic">bhadraka</li></ul><div class="glossary-instance-definition"><p class="definition">A virtuous <span data-glossary-id="UT22084-068-021-8562">nāga</span> king. </p></div></div></div></div><div id="7ab4d2b8-f399-4a6a-8d02-16aba5285bc6" class="relative scroll-mt-20"><button type="button" id="radix-_R_gmt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.91</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bhaṇḍanā</div><ul class="ml-4 list-disc"><li class="italic">b+hAN+Da nA</li><li class="pt-1"><span class="font-tibetan text-base">བྷཱཎྜ་ནཱ།</span></li><li class="italic">bhaṇḍanā</li></ul><div class="glossary-instance-definition"><p class="definition">A mountain off <span data-glossary-id="UT22084-068-021-9847">Videha</span>.</p></div></div></div></div><div id="105b9d25-74ad-4d7e-980e-f964856dd16a" class="relative scroll-mt-20"><button type="button" id="radix-_R_gn55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.92</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bharata Abode</div><ul class="ml-4 list-disc"><li class="italic">bha ra ta’i gnas pa</li><li class="pt-1"><span class="font-tibetan text-base">བྷ་ར་ཏའི་གནས་པ།</span></li><li class="italic">bharata</li></ul><div class="glossary-instance-definition"><p class="definition">An island beyond <span data-glossary-id="UT22084-068-021-9847">Videha</span>.</p></div></div></div></div><div id="44a1362c-06da-4d40-8907-85cc10ae765e" class="relative scroll-mt-20"><button type="button" id="radix-_R_gnd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.93</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bhīduram</div><ul class="ml-4 list-disc"><li class="italic">b+hI dU raM</li><li class="pt-1"><span class="font-tibetan text-base">བྷཱི་དཱུ་རཾ།</span></li><li class="italic">bhīduram</li></ul><div class="glossary-instance-definition"><p class="definition">A town in <span data-glossary-id="UT22084-068-021-9847">Videha</span>.</p></div></div></div></div><div id="33712a8e-4e34-47a8-9c6b-9cd8f8644cba" class="relative scroll-mt-20"><button type="button" id="radix-_R_gnl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.94</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Billowing Waters</div><ul class="ml-4 list-disc"><li class="italic">chu g.yo ba</li><li class="pt-1"><span class="font-tibetan text-base">ཆུ་གཡོ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A river on <span data-glossary-id="UT22084-068-021-9241">Great Slope</span>.</p></div></div></div></div><div id="8727ad91-fc76-4547-8b38-b58b87b14d18" class="relative scroll-mt-20"><button type="button" id="radix-_R_gnt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.95</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Billowing Waves</div><ul class="ml-4 list-disc"><li class="italic">rlabs g.yo ba</li><li class="pt-1"><span class="font-tibetan text-base">རླབས་གཡོ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lake on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span>.</p></div></div></div></div><div id="7fad2bc4-7ddf-4ae3-bc80-facf4d526b22" class="relative scroll-mt-20"><button type="button" id="radix-_R_go55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.96</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bilvaka of Sumeru</div><ul class="ml-4 list-disc"><li class="italic">lhun po’i bi lwa kaH</li><li class="pt-1"><span class="font-tibetan text-base">ལྷུན་པོའི་བི་ལྭ་ཀཿ།</span></li><li class="italic">bilvaka</li></ul><div class="glossary-instance-definition"><p class="definition">An island in the vicinity of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="81dafbfd-5b48-4496-bf0e-0832fafc97ab" class="relative scroll-mt-20"><button type="button" id="radix-_R_god5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.97</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Black Belly</div><ul class="ml-4 list-disc"><li class="italic">lto gnag, nag po gsus pa</li><li class="pt-1"><span class="font-tibetan text-base">ནག་པོ་གསུས་པ།, ལྟོ་གནག</span></li><li class="italic">kālodara</li></ul><div class="glossary-instance-definition"><p class="definition">(1) An area in <span data-glossary-id="UT22084-068-021-9398">Kuru</span> (<em class="foreign text-wy" lang="bo-LATN">nag po gsus pa</em>). 2. One of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-9279">Hell of Ultimate Torment</span>. (<em class="foreign text-wy" lang="bo-LATN">lto gnag</em>), also called <span data-glossary-id="UT22084-068-021-9614">Raven’s Belly</span>. </p></div></div></div></div><div id="e32d0e2d-51ab-45c7-ba3b-823b23bc0099" class="relative scroll-mt-20"><button type="button" id="radix-_R_gol5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.98</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Black Line, Black Line Hell</div><ul class="ml-4 list-disc"><li class="italic">thig nag</li><li class="pt-1"><span class="font-tibetan text-base">ཐིག་ནག</span></li><li class="italic">kālasūtra</li></ul><div class="glossary-instance-definition"><p class="definition">One of the eight hot hells.</p></div></div></div></div><div id="981dcaa0-1d74-4da7-87ec-82c616bc1fba" class="relative scroll-mt-20"><button type="button" id="radix-_R_got5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.99</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Black Mongoose-like</div><ul class="ml-4 list-disc"><li class="italic">ne’u le nag po lta bu</li><li class="pt-1"><span class="font-tibetan text-base">ནེའུ་ལེ་ནག་པོ་ལྟ་བུ།</span></li><li class="italic">kālakanakula</li></ul><div class="glossary-instance-definition"><p class="definition">One of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-9630">Reviving Hell</span>.</p></div></div></div></div><div id="0536959f-2f01-4ec4-82ac-39eaa43f1068" class="relative scroll-mt-20"><button type="button" id="radix-_R_gp55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.100</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Black One</div><ul class="ml-4 list-disc"><li class="italic">nag po</li><li class="pt-1"><span class="font-tibetan text-base">ནག་པོ།</span></li><li class="italic">kālikā</li></ul><div class="glossary-instance-definition"><p class="definition">A river in the hell called <span data-glossary-id="UT22084-068-021-9615">Raven Mouths</span>.</p></div></div></div></div><div id="f3dcd840-ff91-4926-a746-ac881642368d" class="relative scroll-mt-20"><button type="button" id="radix-_R_gpd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.101</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Black Swirling</div><ul class="ml-4 list-disc"><li class="italic">nag po ’khyil ba</li><li class="pt-1"><span class="font-tibetan text-base">ནག་པོ་འཁྱིལ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A river to the south of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="d0e5deda-d6ec-444b-a41b-0cd11e48b198" class="relative scroll-mt-20"><button type="button" id="radix-_R_gpl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.102</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Black Waters</div><ul class="ml-4 list-disc"><li class="italic">chu nag po</li><li class="pt-1"><span class="font-tibetan text-base">ཆུ་ནག་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">(1) An ocean far off the coast of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>. (2) A river on <span data-glossary-id="UT22084-068-021-9142">Forest Garlands</span>.</p></div></div></div></div><div id="8cb14e58-d2f4-4d4c-b174-eb99b4651772" class="relative scroll-mt-20"><button type="button" id="radix-_R_gpt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.103</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Blanket of Smell</div><ul class="ml-4 list-disc"><li class="italic">gos dri</li><li class="pt-1"><span class="font-tibetan text-base">གོས་དྲི།</span></li><li class="italic">gandhakambala</li></ul><div class="glossary-instance-definition"><p class="definition">One of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-9279">Hell of Ultimate Torment</span>.</p></div></div></div></div><div id="7206e643-d6f9-4ea2-850f-9a4cdf804b5c" class="relative scroll-mt-20"><button type="button" id="radix-_R_gq55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.104</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Blazing Gold</div><ul class="ml-4 list-disc"><li class="italic">gser ’bar ba</li><li class="pt-1"><span class="font-tibetan text-base">གསེར་འབར་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A mountain in the eastern sea beyond <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="4bfc359a-4ea5-4454-aa07-53fc7b701b76" class="relative scroll-mt-20"><button type="button" id="radix-_R_gqd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.105</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Blazing Splendor</div><ul class="ml-4 list-disc"><li class="italic">gzi brjid ’bar ba</li><li class="pt-1"><span class="font-tibetan text-base">གཟི་བརྗིད་འབར་བ།</span></li><li class="italic">tejomālinī</li></ul><div class="glossary-instance-definition"><p class="definition">A realm in the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="096407a8-2631-4818-90b7-90d522c2f84b" class="relative scroll-mt-20"><button type="button" id="radix-_R_gql5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.106</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Blessed One, blessed</div><ul class="ml-4 list-disc"><li class="italic">bcom ldan ’das</li><li class="pt-1"><span class="font-tibetan text-base">བཅོམ་ལྡན་འདས།</span></li><li class="italic">bhagavān</li></ul><div class="glossary-instance-definition"><p class="definition">In Buddhist literature, this is an epithet applied to buddhas, most often to Śākyamuni. The Sanskrit term generally means “possessing fortune,” but in specifically Buddhist contexts it implies that a buddha is in possession of six auspicious qualities (<em class="foreign break text-sa" lang="sa-LATN">bhaga</em>) associated with complete awakening. The Tibetan term‍—where <em class="foreign break text-sa" lang="sa-LATN">bcom</em> is said to refer to “subduing” the four māras, <em class="foreign break text-sa" lang="sa-LATN">ldan</em> to “possessing” the great qualities of buddhahood, and <em class="foreign break text-sa" lang="sa-LATN">’das</em> to “going beyond” saṃsāra and nirvāṇa‍—possibly reflects the commentarial tradition where the Sanskrit <em class="foreign break text-sa" lang="sa-LATN">bhagavat</em> is interpreted, in addition, as “one who destroys the four māras.” This is achieved either by reading <em class="foreign break text-sa" lang="sa-LATN">bhagavat</em> as <em class="foreign break text-sa" lang="sa-LATN">bhagnavat</em> (“one who broke”), or by tracing the word <em class="foreign break text-sa" lang="sa-LATN">bhaga</em> to the root <em class="foreign break text-sa" lang="sa-LATN">√bhañj</em> (“to break”).</p></div></div></div></div><div id="831a25b5-586f-4161-9e24-a56445dc7418" class="relative scroll-mt-20"><button type="button" id="radix-_R_gqt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.107</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Blinding Smoke</div><ul class="ml-4 list-disc"><li class="italic">mun pa dang dud pa, ’jig rten par gyi du ba</li><li class="pt-1"><span class="font-tibetan text-base">མུན་པ་དང་དུད་པ།, འཇིག་རྟེན་པར་གྱི་དུ་བ།</span></li><li class="italic">lokāndhakārikā­dhūma</li></ul><div class="glossary-instance-definition"><p class="definition">One of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-9235">Great Howling Hell</span>.</p></div></div></div></div><div id="f92c9894-68df-4ed4-aab7-9bda054b2dd2" class="relative scroll-mt-20"><button type="button" id="radix-_R_gr55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.108</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bliss Maker</div><ul class="ml-4 list-disc"><li class="italic">bde byed</li><li class="pt-1"><span class="font-tibetan text-base">བདེ་བྱེད།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A previous ruler of the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="12e8f2c0-68fc-4b53-88c6-7c38a2135c47" class="relative scroll-mt-20"><button type="button" id="radix-_R_grd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.109</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Blissful Water</div><ul class="ml-4 list-disc"><li class="italic">bde ba’i chu</li><li class="pt-1"><span class="font-tibetan text-base">བདེ་བའི་ཆུ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A river on <span data-glossary-id="UT22084-068-021-9657">Saṅkāśa</span>.</p></div></div></div></div><div id="74d35bc3-9b5a-4c35-9f16-dbe7b59222c1" class="relative scroll-mt-20"><button type="button" id="radix-_R_grl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.110</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Blocked Neck</div><ul class="ml-4 list-disc"><li class="italic">mgrin pa ’gag pa</li><li class="pt-1"><span class="font-tibetan text-base">མགྲིན་པ་འགག་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest on <span data-glossary-id="UT22084-068-021-9823">Upward Ocean</span>.</p></div></div></div></div><div id="f5031239-6922-47c2-b411-d67a6d067d1a" class="relative scroll-mt-20"><button type="button" id="radix-_R_grt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.111</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Blooming Park</div><ul class="ml-4 list-disc"><li class="italic">kun dga’ ra ba’i rgyas pa</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་དགའ་ར་བའི་རྒྱས་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lotus pond on the fifth minor mountain on <span data-glossary-id="UT22084-068-021-9423">Lofty Summit</span>.</p></div></div></div></div><div id="c7846a0d-2b6a-46c7-8a79-64d5b544c5ef" class="relative scroll-mt-20"><button type="button" id="radix-_R_gs55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.112</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Blue</div><ul class="ml-4 list-disc"><li class="italic">sngon po</li><li class="pt-1"><span class="font-tibetan text-base">སྔོན་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">An ocean off <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="d8e88524-3006-4951-b059-024d247ed15f" class="relative scroll-mt-20"><button type="button" id="radix-_R_gsd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.113</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Blue Shade</div><ul class="ml-4 list-disc"><li class="italic">grib ma sngon po</li><li class="pt-1"><span class="font-tibetan text-base">གྲིབ་མ་སྔོན་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A mountain by Lake <span><span data-glossary-id="UT22084-068-021-9095">Expansive</span></span>.</p></div></div></div></div><div id="96ad9a28-7cd6-4ad3-a2d0-0519ea4bc51e" class="relative scroll-mt-20"><button type="button" id="radix-_R_gsl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.114</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Blue Shadows</div><ul class="ml-4 list-disc"><li class="italic">grib ma sngon po</li><li class="pt-1"><span class="font-tibetan text-base">གྲིབ་མ་སྔོན་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest on <span data-glossary-id="UT22084-068-021-9657">Saṅkāśa</span>.</p></div></div></div></div><div id="d7681807-6eaa-499c-b0fc-0e829e367142" class="relative scroll-mt-20"><button type="button" id="radix-_R_gst5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.115</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Blue Stream</div><ul class="ml-4 list-disc"><li class="italic">sngon ’bab</li><li class="pt-1"><span class="font-tibetan text-base">སྔོན་འབབ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A river on <span data-glossary-id="UT22084-068-021-9128">Flocking Peacocks</span>.</p></div></div></div></div><div id="04a4f1d5-be1d-4d52-a949-682c273d956d" class="relative scroll-mt-20"><button type="button" id="radix-_R_gt55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.116</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Blue Waters</div><ul class="ml-4 list-disc"><li class="italic">chu sngon po</li><li class="pt-1"><span class="font-tibetan text-base">ཆུ་སྔོན་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">An ocean far off the coast of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="ecc0e325-3842-4497-bf8e-959eb473f738" class="relative scroll-mt-20"><button type="button" id="radix-_R_gtd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.117</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Blue-Colored One</div><ul class="ml-4 list-disc"><li class="italic">mdog sngon</li><li class="pt-1"><span class="font-tibetan text-base">མདོག་སྔོན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A previous ruler of the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="f2a2e5c5-1f7a-4669-9dd7-6c42b6ef3f64" class="relative scroll-mt-20"><button type="button" id="radix-_R_gtl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.118</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Boiling Cauldrons</div><ul class="ml-4 list-disc"><li class="italic">snod du btso ba</li><li class="pt-1"><span class="font-tibetan text-base">སྣོད་དུ་བཙོ་བ།</span></li><li class="italic">kumbhīpāka</li></ul><div class="glossary-instance-definition"><p class="definition">One of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-9630">Reviving Hell</span>.</p></div></div></div></div><div id="46350f28-5c85-46ba-91bd-79168efcc30b" class="relative scroll-mt-20"><button type="button" id="radix-_R_gtt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.119</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Border Mountain</div><ul class="ml-4 list-disc"><li class="italic">mtshams kyi mtha’i ri</li><li class="pt-1"><span class="font-tibetan text-base">མཚམས་ཀྱི་མཐའི་རི།</span></li></ul><div class="glossary-instance-definition"><p class="definition">The mountain between <span data-glossary-id="UT22084-068-021-9847">Videha</span> and <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="b8109fab-b298-4f3b-a6ff-e308d825ebc0" class="relative scroll-mt-20"><button type="button" id="radix-_R_gu55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.120</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Borderlands of the Lord of Death</div><ul class="ml-4 list-disc"><li class="italic">gshin rje’i mtshams kyi dgon pa</li><li class="pt-1"><span class="font-tibetan text-base">གཤིན་རྗེའི་མཚམས་ཀྱི་དགོན་པ།</span></li><li class="italic">yama­sīmākāntāra</li></ul><div class="glossary-instance-definition"><p class="definition">One of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-9298">Howling Hell</span>.</p></div></div></div></div><div id="09ad0b12-5023-4137-a88b-2838e7bca60c" class="relative scroll-mt-20"><button type="button" id="radix-_R_gud5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.121</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Born in a Lap</div><ul class="ml-4 list-disc"><li class="italic">skyil mo krung gi steng du skye ba</li><li class="pt-1"><span class="font-tibetan text-base">སྐྱིལ་མོ་ཀྲུང་གི་སྟེང་དུ་སྐྱེ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A realm of the <span data-glossary-id="UT22084-068-021-8617">triple-lute-bearer gods</span>.</p></div></div></div></div><div id="8a7c4962-a569-451b-a789-0a3168533851" class="relative scroll-mt-20"><button type="button" id="radix-_R_gul5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.122</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Born in a Tank</div><ul class="ml-4 list-disc"><li class="italic">skyor chu skyes</li><li class="pt-1"><span class="font-tibetan text-base">སྐྱོར་ཆུ་སྐྱེས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A realm of the <span data-glossary-id="UT22084-068-021-8617">triple-lute-bearer gods</span>.</p></div></div></div></div><div id="1f8feedb-2537-40b9-a8c6-52aaf91b0433" class="relative scroll-mt-20"><button type="button" id="radix-_R_gut5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.123</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Born Round</div><ul class="ml-4 list-disc"><li class="italic">kun nas zlum par skyes pa</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་ནས་ཟླུམ་པར་སྐྱེས་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">An area in <span data-glossary-id="UT22084-068-021-9398">Kuru</span>.</p></div></div></div></div><div id="71de96cf-2fb8-41d0-964d-b7f33b4dceae" class="relative scroll-mt-20"><button type="button" id="radix-_R_gv55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.124</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Born Triangular</div><ul class="ml-4 list-disc"><li class="italic">gru gsum pa</li><li class="pt-1"><span class="font-tibetan text-base">གྲུ་གསུམ་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">An area in <span data-glossary-id="UT22084-068-021-9398">Kuru</span>.</p></div></div></div></div><div id="9f45e79e-6407-48c1-b4a5-d72e2b1c3011" class="relative scroll-mt-20"><button type="button" id="radix-_R_gvd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.125</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Boundless Torture</div><ul class="ml-4 list-disc"><li class="italic">tshor ba dbag tu med</li><li class="pt-1"><span class="font-tibetan text-base">ཚོར་བ་དབག་ཏུ་མེད།</span></li><li class="italic">aparimita­vedana</li></ul><div class="glossary-instance-definition"><p class="definition">One of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-9235">Great Howling Hell</span>.</p></div></div></div></div><div id="22aacecd-ce8a-432e-af83-30700bb49bcd" class="relative scroll-mt-20"><button type="button" id="radix-_R_gvl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.126</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Brāgajyotiṣa</div><ul class="ml-4 list-disc"><li class="italic">brA ga dz+yo ti Sha</li><li class="pt-1"><span class="font-tibetan text-base">བྲཱ་ག་ཛྱོ་ཏི་ཥ།</span></li><li class="italic">brāgajyotiṣa</li></ul><div class="glossary-instance-definition"><p class="definition">A mountain in the sea west of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="e4d3cd20-fd11-455c-844e-c5bb18b89e36" class="relative scroll-mt-20"><button type="button" id="radix-_R_gvt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.127</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Brahmā</div><ul class="ml-4 list-disc"><li class="italic">tshangs pa</li><li class="pt-1"><span class="font-tibetan text-base">ཚངས་པ།</span></li><li class="italic">brahmā</li></ul><div class="glossary-instance-definition"><p>A high-ranking deity presiding over a divine world; he is also considered to be the lord of the Sahā world (our universe). Though not considered a creator god in Buddhism, Brahmā occupies an important place as one of two gods (the other being Indra/Śakra) said to have first exhorted the Buddha Śākyamuni to teach the Dharma. The particular heavens found in the form realm over which Brahmā rules are often some of the most sought-after realms of higher rebirth in Buddhist literature. Since there are many universes or world systems, there are also multiple Brahmās presiding over them. His most frequent epithets are “Lord of the Sahā World” (<em class="foreign break text-sa" lang="sa-LATN">sahāṃpati</em>) and Great Brahmā (<em class="foreign break text-sa" lang="sa-LATN">mahābrahman</em>).</p></div></div></div></div><div id="fbf14623-8bc4-49b3-82cc-09f81616c9c6" class="relative scroll-mt-20"><button type="button" id="radix-_R_h055anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.128</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Brahmā Realm</div><ul class="ml-4 list-disc"><li class="italic">tshangs ris</li><li class="pt-1"><span class="font-tibetan text-base">ཚངས་རིས།</span></li><li class="italic">brahmakāyika</li></ul><div class="glossary-instance-definition"><p class="definition">The lower realm within the first <span data-glossary-id="UT22084-068-021-9969">concentration</span>.</p></div></div></div></div><div id="d2beaf90-2596-4dcc-b765-8064c0cba1f3" class="relative scroll-mt-20"><button type="button" id="radix-_R_h0d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.129</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">brahmin</div><ul class="ml-4 list-disc"><li class="italic">bram ze</li><li class="pt-1"><span class="font-tibetan text-base">བྲམ་ཟེ།</span></li><li class="italic">brāhmaṇa</li></ul><div class="glossary-instance-definition"><p class="definition">A member of the <span class="ignore">brahmin</span> caste.</p></div></div></div></div><div id="27f641b5-8b75-40a5-92a7-5faaed828004" class="relative scroll-mt-20"><button type="button" id="radix-_R_h0l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.130</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Braided</div><ul class="ml-4 list-disc"><li class="italic">ral pa can</li><li class="pt-1"><span class="font-tibetan text-base">རལ་པ་ཅན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-068-021-8581">rākṣasī</span>.</p></div></div></div></div><div id="20c688fe-b94e-46bd-a727-e6a59aa0bca5" class="relative scroll-mt-20"><button type="button" id="radix-_R_h0t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.131</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Braided Shape</div><ul class="ml-4 list-disc"><li class="italic">ral pa can gyi dbyibs</li><li class="pt-1"><span class="font-tibetan text-base">རལ་པ་ཅན་གྱི་དབྱིབས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-068-021-8622">vidyādhara</span> site on <span data-glossary-id="UT22084-068-021-9375">Kālaka</span>.</p></div></div></div></div><div id="691ce81a-f0fa-4e10-8799-150d05ced9a1" class="relative scroll-mt-20"><button type="button" id="radix-_R_h155anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.132</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bright</div><ul class="ml-4 list-disc"><li class="italic">dang ba</li><li class="pt-1"><span class="font-tibetan text-base">དང་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A pool upon one of <span data-glossary-id="UT22084-068-021-8636">Airāvaṇa</span>’s ears.</p></div></div></div></div><div id="93c2cfe6-ed9e-4361-92c1-963234fe3689" class="relative scroll-mt-20"><button type="button" id="radix-_R_h1d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.133</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bright Jewels</div><ul class="ml-4 list-disc"><li class="italic">nor bu’i cha shas rnam par bkra ba</li><li class="pt-1"><span class="font-tibetan text-base">ནོར་བུའི་ཆ་ཤས་རྣམ་པར་བཀྲ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A mountain in <span data-glossary-id="UT22084-068-021-9796">Total Pleasure</span>.</p></div></div></div></div><div id="399c0a62-655e-41e9-8e2a-fddb73463eef" class="relative scroll-mt-20"><button type="button" id="radix-_R_h1l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.134</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bright River</div><ul class="ml-4 list-disc"><li class="italic">rab tu dang ba’i chu</li><li class="pt-1"><span class="font-tibetan text-base">རབ་ཏུ་དང་བའི་ཆུ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A river on <span data-glossary-id="UT22084-068-021-9657">Saṅkāśa</span>.</p></div></div></div></div><div id="af0bdcf7-fffa-44b4-9196-a83780555c0b" class="relative scroll-mt-20"><button type="button" id="radix-_R_h1t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.135</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bright Waters</div><ul class="ml-4 list-disc"><li class="italic">chu rab tu dang ba</li><li class="pt-1"><span class="font-tibetan text-base">ཆུ་རབ་ཏུ་དང་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">An ocean far off the coast of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="2419b726-14f3-452f-af1a-760e985cf087" class="relative scroll-mt-20"><button type="button" id="radix-_R_h255anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.136</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Broken by Nāgas</div><ul class="ml-4 list-disc"><li class="italic">klus brtol</li><li class="pt-1"><span class="font-tibetan text-base">ཀླུས་བརྟོལ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">One of the seven golden mountains that surround Mount <span data-glossary-id="UT22084-068-021-9739">Sumeru</span>.</p></div></div></div></div><div id="90bdbd6a-4fe2-41c0-9af7-9f9e573f8610" class="relative scroll-mt-20"><button type="button" id="radix-_R_h2d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.137</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bubbles</div><ul class="ml-4 list-disc"><li class="italic">dbu ba’i tshogs</li><li class="pt-1"><span class="font-tibetan text-base">དབུ་བའི་ཚོགས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A town in <span data-glossary-id="UT22084-068-021-9847">Videha</span>.</p></div></div></div></div><div id="2bd86f0c-467c-4677-8477-9e2643472791" class="relative scroll-mt-20"><button type="button" id="radix-_R_h2l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.138</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Buoyancy</div><ul class="ml-4 list-disc"><li class="italic">rab tu dang ba</li><li class="pt-1"><span class="font-tibetan text-base">རབ་ཏུ་དང་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A mountain range in the <span data-glossary-id="UT22084-068-021-9266">Heaven Free from Strife</span>.</p></div></div></div></div><div id="b9155679-3e95-4e35-b0ab-8919257d1722" class="relative scroll-mt-20"><button type="button" id="radix-_R_h2t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.139</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Buoyant Movement</div><ul class="ml-4 list-disc"><li class="italic">rab tu dang bar ’gro ba</li><li class="pt-1"><span class="font-tibetan text-base">རབ་ཏུ་དང་བར་འགྲོ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest in <span data-glossary-id="UT22084-068-021-8956">Continuous Movement</span>.</p></div></div></div></div><div id="e2e187a2-20ae-4121-9260-7ebb73a3fcaf" class="relative scroll-mt-20"><button type="button" id="radix-_R_h355anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.140</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Burning</div><ul class="ml-4 list-disc"><li class="italic">rnam par sreg byed</li><li class="pt-1"><span class="font-tibetan text-base">རྣམ་པར་སྲེག་བྱེད།</span></li></ul><div class="glossary-instance-definition"><p class="definition">(1) A land in the east of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>. (2) A river in the land known as <span data-glossary-id="UT22084-068-021-8808">Aṅga</span>.</p></div></div></div></div><div id="497c322e-1dd0-4737-b53f-e48c8579c63e" class="relative scroll-mt-20"><button type="button" id="radix-_R_h3d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.141</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Burning All</div><ul class="ml-4 list-disc"><li class="italic">kun sreg</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་སྲེག</span></li><li class="italic">sarvadāha</li></ul><div class="glossary-instance-definition"><p class="definition">A mountain range surrounding the hell of <span data-glossary-id="UT22084-068-021-9043">Embers Within</span>.</p></div></div></div></div><div id="0bd2d7e9-03ca-4430-aac2-617f10b6e1c7" class="relative scroll-mt-20"><button type="button" id="radix-_R_h3l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.142</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Burning Everyone</div><ul class="ml-4 list-disc"><li class="italic">skye bo thams cad sreg pa</li><li class="pt-1"><span class="font-tibetan text-base">སྐྱེ་བོ་ཐམས་ཅད་སྲེག་པ།</span></li><li class="italic">sarvajanapāka</li></ul><div class="glossary-instance-definition"><p class="definition">One of the sixteen realms that surround the <span><span data-glossary-id="UT22084-068-021-9277">Hell of Heat</span></span>. </p></div></div></div></div><div id="20117ae3-b3a9-4e05-ab8c-fc87d17e64d1" class="relative scroll-mt-20"><button type="button" id="radix-_R_h3t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.143</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Burning Hair</div><ul class="ml-4 list-disc"><li class="italic">skra me ’bar ba</li><li class="pt-1"><span class="font-tibetan text-base">སྐྲ་མེ་འབར་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">One of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-9298">Howling Hell</span>.</p></div></div></div></div><div id="71dce1d5-f1ee-4351-b00b-e35b89e34a0d" class="relative scroll-mt-20"><button type="button" id="radix-_R_h455anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.144</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Burning Torrent of the Vaitaraṇī</div><ul class="ml-4 list-disc"><li class="italic">chu bo rab med rab tu tsha ba</li><li class="pt-1"><span class="font-tibetan text-base">ཆུ་བོ་རབ་མེད་རབ་ཏུ་ཚ་བ།</span></li><li class="italic">vaitaraṇī­pradāha­pravāha</li></ul><div class="glossary-instance-definition"><p class="definition">A realm that neighbors the <span data-glossary-id="UT22084-068-021-9278">Hell of Intense Heat</span>.</p></div></div></div></div><div id="3ee7812b-15d1-4e03-bde1-7592c77da157" class="relative scroll-mt-20"><button type="button" id="radix-_R_h4d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.145</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bursting Like Great Lotuses</div><ul class="ml-4 list-disc"><li class="italic">pad ma chen po ltar gas pa</li><li class="pt-1"><span class="font-tibetan text-base">པད་མ་ཆེན་པོ་ལྟར་གས་པ།</span></li><li class="italic">mahāpaduma</li></ul><div class="glossary-instance-definition"><p class="definition">One of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-8975">Crushing Hell</span>.</p></div></div></div></div><div id="9fd176e5-1df4-4185-966d-68cf11a819de" class="relative scroll-mt-20"><button type="button" id="radix-_R_h4l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.146</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bursting Like Lotuses</div><ul class="ml-4 list-disc"><li class="italic">pad ma ltar gas pa</li><li class="pt-1"><span class="font-tibetan text-base">པད་མ་ལྟར་གས་པ།</span></li><li class="italic">paduma</li></ul><div class="glossary-instance-definition"><p class="definition">One of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-8975">Crushing Hell</span>.</p></div></div></div></div><div id="fb5c71d3-c33c-4d7a-8c17-3c952d6de664" class="relative scroll-mt-20"><button type="button" id="radix-_R_h4t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.147</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Butön, Butön Rinchen Drup</div><ul class="ml-4 list-disc"><li class="italic">bu ston rin chen grub</li><li class="pt-1"><span class="font-tibetan text-base">བུ་སྟོན་རིན་ཆེན་གྲུབ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">The famous compiler of the Kangyur (1290–1364).</p></div></div></div></div><div id="6e2d39f2-f6dc-440c-87ea-aedbbc3e56c7" class="relative scroll-mt-20"><button type="button" id="radix-_R_h555anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.148</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Caitra­ratha­vana</div><ul class="ml-4 list-disc"><li class="italic">shing rta sna tshogs kyi tshal, shing rta sna tshogs pa’i tshal</li><li class="pt-1"><span class="font-tibetan text-base">ཤིང་རྟ་སྣ་ཚོགས་ཀྱི་ཚལ།, ཤིང་རྟ་སྣ་ཚོགས་པའི་ཚལ།</span></li><li class="italic">caitra­ratha­vana</li></ul><div class="glossary-instance-definition"><p class="definition">(1) A forest on the eastern face of <span data-glossary-id="UT22084-068-021-9739">Sumeru</span>. (2) <span data-glossary-id="UT22084-068-021-8738">Śakra</span>’s arsenal.</p></div></div></div></div><div id="ba435376-584e-42f5-9bbd-16638938d11e" class="relative scroll-mt-20"><button type="button" id="radix-_R_h5d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.149</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Cakravāḍa</div><ul class="ml-4 list-disc"><li class="italic">ri khor yug, tsakra bA Do</li><li class="pt-1"><span class="font-tibetan text-base">ཙཀྲ་བཱ་ཌོ།, རི་ཁོར་ཡུག</span></li><li class="italic">cakravāḍa</li></ul><div class="glossary-instance-definition"><p class="definition">(1) A mountain in the sea west of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span> (<em class="foreign text-wy" lang="bo-LATN">tsakra bA Do</em>). (2) Eight consecutive rings of mountains that surround the world ocean (<em class="foreign text-wy" lang="bo-LATN">ri khor yug</em>).</p></div></div></div></div><div id="dad3844e-02ee-4153-a895-8d937522c6b6" class="relative scroll-mt-20"><button type="button" id="radix-_R_h5l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.150</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Calling Geese</div><ul class="ml-4 list-disc"><li class="italic">ngang ngur rnams kyis rjes su bsgrags par byed pa, ngang pa kun sgra ’byin pa</li><li class="pt-1"><span class="font-tibetan text-base">ངང་ངུར་རྣམས་ཀྱིས་རྗེས་སུ་བསྒྲགས་པར་བྱེད་པ།, ངང་པ་ཀུན་སྒྲ་འབྱིན་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">(1) A forest on <span data-glossary-id="UT22084-068-021-9046">Encircled by White Clouds</span> (<em class="foreign text-wy" lang="bo-LATN">ngang ngur rnams kyis rjes su bsgrags par byed pa</em>). (2) A river on <span data-glossary-id="UT22084-068-021-9657">Saṅkāśa</span> (<em class="foreign text-wy" lang="bo-LATN">ngang pa kun sgra ’byin pa</em>). </p></div></div></div></div><div id="6857822b-45e2-4813-a82c-b2789d9d6ffd" class="relative scroll-mt-20"><button type="button" id="radix-_R_h5t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.151</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">calm abiding</div><ul class="ml-4 list-disc"><li class="italic">zhi gnas</li><li class="pt-1"><span class="font-tibetan text-base">ཞི་གནས།</span></li><li class="italic">śamatha</li></ul><div class="glossary-instance-definition"><p class="definition">Refers to the meditative practice of calming the mind to rest free from the disturbance of thought. One of the two basic forms of Buddhist meditation, the other being <span data-glossary-id="UT22084-068-021-9923">special insight</span> (<em class="foreign break text-sa" lang="sa-LATN">vipaśyanā</em>, <em class="foreign text-wy" lang="bo-LATN">lhag mthong</em>).</p></div></div></div></div><div id="acda2250-5859-4485-b5e2-032f3b06a140" class="relative scroll-mt-20"><button type="button" id="radix-_R_h655anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.152</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Camel Face</div><ul class="ml-4 list-disc"><li class="italic">rnga mo’i bzhin</li><li class="pt-1"><span class="font-tibetan text-base">རྔ་མོའི་བཞིན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A land in the east of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="881b31c8-c966-4d59-aaa7-b7d00a6150c9" class="relative scroll-mt-20"><button type="button" id="radix-_R_h6d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.153</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Captivating the Mind</div><ul class="ml-4 list-disc"><li class="italic">mthong na yid ’phrog pa</li><li class="pt-1"><span class="font-tibetan text-base">མཐོང་ན་ཡིད་འཕྲོག་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A mansion in <span data-glossary-id="UT22084-068-021-9753">Supreme Strength</span>.</p></div></div></div></div><div id="c0de57f1-2113-468d-a401-8be5db256ed5" class="relative scroll-mt-20"><button type="button" id="radix-_R_h6l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.154</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Caraca</div><ul class="ml-4 list-disc"><li class="italic">tsa ra tsa</li><li class="pt-1"><span class="font-tibetan text-base">ཙ་ར་ཙ།</span></li><li class="italic">caraca</li></ul><div class="glossary-instance-definition"><p class="definition">A river on <span data-glossary-id="UT22084-068-021-9241">Great Slope</span>.</p></div></div></div></div><div id="bf3c58f3-fe7c-4be3-bb23-b65273cb537f" class="relative scroll-mt-20"><button type="button" id="radix-_R_h6t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.155</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">carefulness</div><ul class="ml-4 list-disc"><li class="italic">bag yod pa</li><li class="pt-1"><span class="font-tibetan text-base">བག་ཡོད་པ།</span></li><li class="italic">apramāda</li></ul><div class="glossary-instance-definition"><p class="definition">Heedful attention to virtuous qualities.</p></div></div></div></div><div id="83927cb9-3f76-4aae-a5ef-cc3d41359d8c" class="relative scroll-mt-20"><button type="button" id="radix-_R_h755anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.156</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Careless Living</div><ul class="ml-4 list-disc"><li class="italic">bag med pa rnams spyod pa</li><li class="pt-1"><span class="font-tibetan text-base">བག་མེད་པ་རྣམས་སྤྱོད་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest in <span data-glossary-id="UT22084-068-021-9056">Endowed with Increasing Bliss</span>.</p></div></div></div></div><div id="35a76eba-a391-4a52-b446-4c8eb50b577a" class="relative scroll-mt-20"><button type="button" id="radix-_R_h7d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.157</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">carelessness</div><ul class="ml-4 list-disc"><li class="italic">bag med pa</li><li class="pt-1"><span class="font-tibetan text-base">བག་མེད་པ།</span></li><li class="italic">pramāda</li></ul><div class="glossary-instance-definition"><p class="definition">Disregard for virtuous qualities.</p></div></div></div></div><div id="a0e9c91d-4aad-4cf4-8cea-db71e5c30eb3" class="relative scroll-mt-20"><button type="button" id="radix-_R_h7l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.158</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Cascade</div><ul class="ml-4 list-disc"><li class="italic">’bab cu</li><li class="pt-1"><span class="font-tibetan text-base">འབབ་ཅུ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A park in <span data-glossary-id="UT22084-068-021-9000">Delighting in Flower Garlands</span>.</p></div></div></div></div><div id="e8d9905c-aaa9-43df-87bd-08dd9d1eb1f6" class="relative scroll-mt-20"><button type="button" id="radix-_R_h7t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.159</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Cascades of Joy</div><ul class="ml-4 list-disc"><li class="italic">’bab chu rnam kyis mngon par dga’ ba</li><li class="pt-1"><span class="font-tibetan text-base">འབབ་ཆུ་རྣམ་ཀྱིས་མངོན་པར་དགའ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest in <span data-glossary-id="UT22084-068-021-9796">Total Pleasure</span>.</p></div></div></div></div><div id="35594da2-a451-4457-be83-6afdfcdd9728" class="relative scroll-mt-20"><button type="button" id="radix-_R_h855anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.160</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Caturo</div><ul class="ml-4 list-disc"><li class="italic">tsa tu ro</li><li class="pt-1"><span class="font-tibetan text-base">ཙ་ཏུ་རོ།</span></li><li class="italic">caturo</li></ul><div class="glossary-instance-definition"><p class="definition">A land in <span data-glossary-id="UT22084-068-021-9209">Godānīya</span>.</p></div></div></div></div><div id="9e74c63c-ce8d-4dd8-86c7-4de913206d51" class="relative scroll-mt-20"><button type="button" id="radix-_R_h8d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.161</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Caustic River</div><ul class="ml-4 list-disc"><li class="italic">ba tshwa’i chu bo’i rlabs</li><li class="pt-1"><span class="font-tibetan text-base">བ་ཚྭའི་ཆུ་བོའི་རླབས།</span></li><li class="italic">kṣāranadī</li></ul><div class="glossary-instance-definition"><p class="definition">River in the hell known as <span data-glossary-id="UT22084-068-021-8887">Bursting Like Great Lotuses</span>.</p></div></div></div></div><div id="a404c503-98c6-4c76-b978-0ed8e8c6f443" class="relative scroll-mt-20"><button type="button" id="radix-_R_h8l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.162</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Cavern of the Closed Eye</div><ul class="ml-4 list-disc"><li class="italic">mig btsums pa’i phug</li><li class="pt-1"><span class="font-tibetan text-base">མིག་བཙུམས་པའི་ཕུག</span></li></ul><div class="glossary-instance-definition"><p class="definition">A cave on the mountain called <span><span data-glossary-id="UT22084-068-021-8917">Closed Eye</span></span>.</p></div></div></div></div><div id="8606eb79-1fae-42f7-b423-1001888cd274" class="relative scroll-mt-20"><button type="button" id="radix-_R_h8t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.163</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Celebrating Goddesses</div><ul class="ml-4 list-disc"><li class="italic">lha’i bu mo rnams rtse dga’ bar byed pa</li><li class="pt-1"><span class="font-tibetan text-base">ལྷའི་བུ་མོ་རྣམས་རྩེ་དགའ་བར་བྱེད་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A minor mountain on <span><span data-glossary-id="UT22084-068-021-9422">Lofty Peak</span></span>.</p></div></div></div></div><div id="104e0a3b-f87f-4d13-9a38-127b2d967d9a" class="relative scroll-mt-20"><button type="button" id="radix-_R_h955anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.164</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Celebrations throughout the Land</div><ul class="ml-4 list-disc"><li class="italic">nye ’khor na rtse dga’ ba</li><li class="pt-1"><span class="font-tibetan text-base">ཉེ་འཁོར་ན་རྩེ་དགའ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A city in <span data-glossary-id="UT22084-068-021-9847">Videha</span>.</p></div></div></div></div><div id="734c81db-a53a-4ff7-a249-a69d23f3b300" class="relative scroll-mt-20"><button type="button" id="radix-_R_h9d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.165</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Certain Liberation</div><ul class="ml-4 list-disc"><li class="italic">nges par mthar byed</li><li class="pt-1"><span class="font-tibetan text-base">ངེས་པར་མཐར་བྱེད།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A park in <span data-glossary-id="UT22084-068-021-8853">Blazing Splendor</span>.</p></div></div></div></div><div id="5a294a5e-5ce2-426b-a96f-fc6c36d9c03a" class="relative scroll-mt-20"><button type="button" id="radix-_R_h9l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.166</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Cessation of All Faculties</div><ul class="ml-4 list-disc"><li class="italic">dbang po thams cad ’gags pa</li><li class="pt-1"><span class="font-tibetan text-base">དབང་པོ་ཐམས་ཅད་འགགས་པ།</span></li><li class="italic">sarvendriya­nirodha</li></ul><div class="glossary-instance-definition"><p class="definition">One of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-8975">Crushing Hell</span>.</p></div></div></div></div><div id="aef12735-469a-4df0-8077-5d9f44c812e4" class="relative scroll-mt-20"><button type="button" id="radix-_R_h9t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.167</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">chatter</div><ul class="ml-4 list-disc"><li class="italic">ngag kyal</li><li class="pt-1"><span class="font-tibetan text-base">ངག་ཀྱལ།</span></li><li class="italic">saṃbhinna­pralāpa</li></ul><div class="glossary-instance-definition"><p class="definition">The fourth among the four misdeeds of speech.</p></div></div></div></div><div id="a3471be0-42bf-4539-bcf9-ea1e75e97517" class="relative scroll-mt-20"><button type="button" id="radix-_R_ha55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.168</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Chavikaliṅka</div><ul class="ml-4 list-disc"><li class="italic">tsha bi ka ling ka</li><li class="pt-1"><span class="font-tibetan text-base">ཚ་བི་ཀ་ལིང་ཀ</span></li><li class="italic">chavikaliṅka</li></ul><div class="glossary-instance-definition"><p class="definition">A forest in the south of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="049169ff-594a-4a9e-9ab6-456ede873728" class="relative scroll-mt-20"><button type="button" id="radix-_R_had5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.169</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">cheerful</div><ul class="ml-4 list-disc"><li class="italic">kun spro</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་སྤྲོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A class of <span data-glossary-id="UT22084-068-021-8489">asuras</span> ruled by <span><span data-glossary-id="UT22084-068-021-8722">Overjoyed</span></span>.</p></div></div></div></div><div id="1dfd2b40-2041-4f39-a819-bce0a4e68afb" class="relative scroll-mt-20"><button type="button" id="radix-_R_hal5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.170</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">China</div><ul class="ml-4 list-disc"><li class="italic">rgya nag</li><li class="pt-1"><span class="font-tibetan text-base">རྒྱ་ནག</span></li><li class="italic">cīna</li></ul><div class="glossary-instance-definition"><p class="definition">A land to the north of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="cad69213-867b-492a-b700-74289232da39" class="relative scroll-mt-20"><button type="button" id="radix-_R_hat5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.171</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Cilika</div><ul class="ml-4 list-disc"><li class="italic">tsi li ka</li><li class="pt-1"><span class="font-tibetan text-base">ཙི་ལི་ཀ</span></li><li class="italic">cilika</li></ul><div class="glossary-instance-definition"><p class="definition">A forest on <span data-glossary-id="UT22084-068-021-9142">Forest Garlands</span>.</p></div></div></div></div><div id="5531cdaf-e6e3-4e6e-baab-b9b4c8e21def" class="relative scroll-mt-20"><button type="button" id="radix-_R_hb55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.172</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Circle</div><ul class="ml-4 list-disc"><li class="italic">dkyil ’khor</li><li class="pt-1"><span class="font-tibetan text-base">དཀྱིལ་འཁོར།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lake on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span>.</p></div></div></div></div><div id="4cb5d3d6-f69e-4626-aca1-7b9f52c25ce9" class="relative scroll-mt-20"><button type="button" id="radix-_R_hbd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.173</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Circling Fish</div><ul class="ml-4 list-disc"><li class="italic">nya ’khor ba</li><li class="pt-1"><span class="font-tibetan text-base">ཉ་འཁོར་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lake on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span>.</p></div></div></div></div><div id="bf7952a9-8197-47e3-aaed-646d553de480" class="relative scroll-mt-20"><button type="button" id="radix-_R_hbl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.174</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Circling Waves</div><ul class="ml-4 list-disc"><li class="italic">rlabs ’khor bar gyur pa</li><li class="pt-1"><span class="font-tibetan text-base">རླབས་འཁོར་བར་གྱུར་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lake on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span>.</p></div></div></div></div><div id="6c02f40a-bcbc-47e1-9fac-96a30df202a6" class="relative scroll-mt-20"><button type="button" id="radix-_R_hbt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.175</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Circular Design</div><ul class="ml-4 list-disc"><li class="italic">khor yug gi rnam pa</li><li class="pt-1"><span class="font-tibetan text-base">ཁོར་ཡུག་གི་རྣམ་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">An ocean beyond <span data-glossary-id="UT22084-068-021-9847">Videha</span>.</p></div></div></div></div><div id="b424cbb6-1d93-4431-aab1-3137c23ba453" class="relative scroll-mt-20"><button type="button" id="radix-_R_hc55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.176</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">City of Hills</div><ul class="ml-4 list-disc"><li class="italic">phung po’i grong khyer</li><li class="pt-1"><span class="font-tibetan text-base">ཕུང་པོའི་གྲོང་ཁྱེར།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A city in <span data-glossary-id="UT22084-068-021-9847">Videha</span>.</p></div></div></div></div><div id="d3839ef6-bd4b-4311-9b25-a9ee9e7ddaf0" class="relative scroll-mt-20"><button type="button" id="radix-_R_hcd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.177</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Clean Water</div><ul class="ml-4 list-disc"><li class="italic">gtsang ba’i chu</li><li class="pt-1"><span class="font-tibetan text-base">གཙང་བའི་ཆུ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">(1) A lake on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span>. (2) A river on <span data-glossary-id="UT22084-068-021-9657">Saṅkāśa</span>.</p></div></div></div></div><div id="fb59dbe9-45f1-4039-98b6-d0633a6f9f00" class="relative scroll-mt-20"><button type="button" id="radix-_R_hcl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.178</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Clear Appearance</div><ul class="ml-4 list-disc"><li class="italic">gsal bar snang ba</li><li class="pt-1"><span class="font-tibetan text-base">གསལ་བར་སྣང་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lake on <span data-glossary-id="UT22084-068-021-9829">Utterly Delightful to Behold</span>.</p></div></div></div></div><div id="50172747-d6e9-49c0-81e9-330025f3ae3a" class="relative scroll-mt-20"><button type="button" id="radix-_R_hct5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.179</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Clear Forest</div><ul class="ml-4 list-disc"><li class="italic">gsal ba’i tshal</li><li class="pt-1"><span class="font-tibetan text-base">གསལ་བའི་ཚལ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest in <span data-glossary-id="UT22084-068-021-9513">Moving Mind</span>.</p></div></div></div></div><div id="bc1aff9d-4ba6-4d7c-a184-9c68f05367c1" class="relative scroll-mt-20"><button type="button" id="radix-_R_hd55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.180</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Clear Stream of Summer Clouds</div><ul class="ml-4 list-disc"><li class="italic">dbyar sprin rab tu dang ba’i chu ’bab pa</li><li class="pt-1"><span class="font-tibetan text-base">དབྱར་སྤྲིན་རབ་ཏུ་དང་བའི་ཆུ་འབབ་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A river on <span data-glossary-id="UT22084-068-021-9657">Saṅkāśa</span>.</p></div></div></div></div><div id="08644859-bad3-485d-a42a-3dfbc6687c61" class="relative scroll-mt-20"><button type="button" id="radix-_R_hdd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.181</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Clear Water</div><ul class="ml-4 list-disc"><li class="italic">chu dang ba</li><li class="pt-1"><span class="font-tibetan text-base">ཆུ་དང་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A pond in <span data-glossary-id="UT22084-068-021-9033">Dwelling on Forest Riverbanks</span> in the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="c0d4b3d2-03a4-45b4-a571-6bdaf7fc7d60" class="relative scroll-mt-20"><button type="button" id="radix-_R_hdl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.182</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Closed Eye</div><ul class="ml-4 list-disc"><li class="italic">mig btsums</li><li class="pt-1"><span class="font-tibetan text-base">མིག་བཙུམས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A mountain to the north of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="6b1eecca-e553-446a-bb5b-d4f54921550a" class="relative scroll-mt-20"><button type="button" id="radix-_R_hdt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.183</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Cloud</div><ul class="ml-4 list-disc"><li class="italic">sprin</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A mountain on the continent of <span data-glossary-id="UT22084-068-021-9398">Kuru</span>.</p></div></div></div></div><div id="8fa470b5-0ff4-4a05-9617-a66a3ba2fa08" class="relative scroll-mt-20"><button type="button" id="radix-_R_he55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.184</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Cloud Banks</div><ul class="ml-4 list-disc"><li class="italic">sprin brtsegs</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་བརྩེགས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">King <span data-glossary-id="UT22084-068-021-8754">Sudarśana</span>’s elephant.</p></div></div></div></div><div id="bf0f359b-674e-4d36-80ff-1f0f0ffd31ed" class="relative scroll-mt-20"><button type="button" id="radix-_R_hed5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.185</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Cloud below Gold</div><ul class="ml-4 list-disc"><li class="italic">gser gyi ’og phag sprin</li><li class="pt-1"><span class="font-tibetan text-base">གསེར་གྱི་འོག་ཕག་སྤྲིན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest of the <span data-glossary-id="UT22084-068-021-8489">asuras</span>.</p></div></div></div></div><div id="37bf247c-a071-46cc-a535-a78fca66ceef" class="relative scroll-mt-20"><button type="button" id="radix-_R_hel5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.186</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Cloud Companion</div><ul class="ml-4 list-disc"><li class="italic">sprin ’khor ba</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་འཁོར་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A river on <span data-glossary-id="UT22084-068-021-9657">Saṅkāśa</span>.</p></div></div></div></div><div id="6aa4f33e-c0cd-4d02-a327-c2b54099dfb6" class="relative scroll-mt-20"><button type="button" id="radix-_R_het5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.187</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">cloud disperser</div><ul class="ml-4 list-disc"><li class="italic">sprin rab tu ’byed par byed pa</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་རབ་ཏུ་འབྱེད་པར་བྱེད་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A class of <span data-glossary-id="UT22084-068-021-8622">vidyādharas</span>.</p></div></div></div></div><div id="d2e72194-cf68-44f2-911a-c1ee68e86e96" class="relative scroll-mt-20"><button type="button" id="radix-_R_hf55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.188</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Cloud Forest</div><ul class="ml-4 list-disc"><li class="italic">sprin gyi tshal</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་གྱི་ཚལ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">(1) A forest in <span data-glossary-id="UT22084-068-021-9014">Draped with Jewels</span>. (2) A forest on <span data-glossary-id="UT22084-068-021-9128">Flocking Peacocks</span>.</p></div></div></div></div><div id="7da77c2a-bfc1-4b62-a2e3-3ef8d255d001" class="relative scroll-mt-20"><button type="button" id="radix-_R_hfd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.189</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Cloud Garland</div><ul class="ml-4 list-disc"><li class="italic">sprin phreng</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་ཕྲེང་།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lotus pool in <span data-glossary-id="UT22084-068-021-9403">Lateral</span>.</p></div></div></div></div><div id="db6f6e10-2dac-430a-93f4-4639e71c2ccb" class="relative scroll-mt-20"><button type="button" id="radix-_R_hfl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.190</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Cloud Mode</div><ul class="ml-4 list-disc"><li class="italic">sprin gyi ’gros</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་གྱི་འགྲོས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A river on <span data-glossary-id="UT22084-068-021-9657">Saṅkāśa</span>.</p></div></div></div></div><div id="d71bbec4-9a22-4c39-a1d0-c7b27f8291de" class="relative scroll-mt-20"><button type="button" id="radix-_R_hft5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.191</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Cloud-Like White Array</div><ul class="ml-4 list-disc"><li class="italic">sprin ltar dkar brtsegs</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་ལྟར་དཀར་བརྩེགས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest in <span data-glossary-id="UT22084-068-021-9035">Dwelling on Summits</span>.</p></div></div></div></div><div id="b818906c-74db-42af-993a-1fd6148ee3fa" class="relative scroll-mt-20"><button type="button" id="radix-_R_hg55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.192</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Cloudless Heaven</div><ul class="ml-4 list-disc"><li class="italic">sprin med</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་མེད།</span></li><li class="italic">anabhraka</li></ul><div class="glossary-instance-definition"><p class="definition">The first level of the fourth <span data-glossary-id="UT22084-068-021-9969">concentration</span>.</p></div></div></div></div><div id="03d37ee0-aac9-4265-9d27-2ae2edad149c" class="relative scroll-mt-20"><button type="button" id="radix-_R_hgd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.193</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">coarse food</div><ul class="ml-4 list-disc"><li class="italic">kham gyi zas</li><li class="pt-1"><span class="font-tibetan text-base">ཁམ་གྱི་ཟས།</span></li><li class="italic">kavalīkārāhāra</li></ul><div class="glossary-instance-definition"><p class="definition">One of the <span data-glossary-id="UT22084-068-021-9889">four kinds of food</span>.</p></div></div></div></div><div id="11492fe0-c40c-4cff-a752-3c9a66b7be46" class="relative scroll-mt-20"><button type="button" id="radix-_R_hgl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.194</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Colorful</div><ul class="ml-4 list-disc"><li class="italic">bkra ba, sna tshogs</li><li class="pt-1"><span class="font-tibetan text-base">བཀྲ་བ།, སྣ་ཚོགས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">(1) A grove in <span data-glossary-id="UT22084-068-021-9403">Lateral</span> (<em class="foreign text-wy" lang="bo-LATN">sna tshogs</em>). (2) A forest at <span data-glossary-id="UT22084-068-021-9734">Sudharma</span> (<em class="foreign text-wy" lang="bo-LATN">bkra ba</em>).</p></div></div></div></div><div id="ef693371-d77e-4365-9860-2982a7fca3ba" class="relative scroll-mt-20"><button type="button" id="radix-_R_hgt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.195</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Colorful Brightness</div><ul class="ml-4 list-disc"><li class="italic">rnam par sna tshogs par bkra ba</li><li class="pt-1"><span class="font-tibetan text-base">རྣམ་པར་སྣ་ཚོགས་པར་བཀྲ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lotus pond in <span data-glossary-id="UT22084-068-021-9672">Shining in Manifold Ways</span>.</p></div></div></div></div><div id="720e6a5d-615c-4c7c-b367-19e05c342ba0" class="relative scroll-mt-20"><button type="button" id="radix-_R_hh55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.196</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Colorful Waters</div><ul class="ml-4 list-disc"><li class="italic">rnam par bkra ba’i chu</li><li class="pt-1"><span class="font-tibetan text-base">རྣམ་པར་བཀྲ་བའི་ཆུ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A river in <span data-glossary-id="UT22084-068-021-9511">Moving in Vast Environments</span>.</p></div></div></div></div><div id="28497d42-519a-4fae-9a73-8c5c4f1fd44e" class="relative scroll-mt-20"><button type="button" id="radix-_R_hhd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.197</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">concentration</div><ul class="ml-4 list-disc"><li class="italic">bsam gtan</li><li class="pt-1"><span class="font-tibetan text-base">བསམ་གཏན།</span></li><li class="italic">dhyāna</li></ul><div class="glossary-instance-definition"><p class="definition">Generally one of the synonyms for meditation, referring to a state of mental stability. The specific four <span class="ignore">concentration</span>s are four successively subtler states of meditation that are said to lead to rebirth into the corresponding four levels of the form realm. One of the <span data-glossary-id="UT22084-068-021-10035">six perfections</span>.</p></div></div></div></div><div id="a8d463f6-85d4-4057-886b-56d2a1c2b306" class="relative scroll-mt-20"><button type="button" id="radix-_R_hhl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.198</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Conch</div><ul class="ml-4 list-disc"><li class="italic">dung</li><li class="pt-1"><span class="font-tibetan text-base">དུང་།</span></li></ul><div class="glossary-instance-definition"><p class="definition">An island in the vicinity of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="0db3f43c-6787-4ac3-9312-1018a669d166" class="relative scroll-mt-20"><button type="button" id="radix-_R_hht5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.199</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Conch Color</div><ul class="ml-4 list-disc"><li class="italic">dung gi mdog</li><li class="pt-1"><span class="font-tibetan text-base">དུང་གི་མདོག</span></li></ul><div class="glossary-instance-definition"><p class="definition">A pond on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span>.</p></div></div></div></div><div id="b200c533-7ee2-4c84-84c9-84fe5d490470" class="relative scroll-mt-20"><button type="button" id="radix-_R_hi55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.200</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Conch Sound</div><ul class="ml-4 list-disc"><li class="italic">dung gi sgra si mi si mi</li><li class="pt-1"><span class="font-tibetan text-base">དུང་གི་སྒྲ་སི་མི་སི་མི།</span></li></ul><div class="glossary-instance-definition"><p class="definition">An ocean between <span data-glossary-id="UT22084-068-021-9398">Kuru</span> and <span data-glossary-id="UT22084-068-021-9209">Godānīya</span>.</p></div></div></div></div><div id="47e6366e-ff8a-478f-89a8-2b98c1a36cbb" class="relative scroll-mt-20"><button type="button" id="radix-_R_hid5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.201</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Concise</div><ul class="ml-4 list-disc"><li class="italic">mdor bsdus pa</li><li class="pt-1"><span class="font-tibetan text-base">མདོར་བསྡུས་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A town in <span data-glossary-id="UT22084-068-021-9847">Videha</span>.</p></div></div></div></div><div id="c80df183-18eb-4461-b0b3-95b154989737" class="relative scroll-mt-20"><button type="button" id="radix-_R_hil5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.202</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Confluence</div><ul class="ml-4 list-disc"><li class="italic">tshogs pa</li><li class="pt-1"><span class="font-tibetan text-base">ཚོགས་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A river on <span data-glossary-id="UT22084-068-021-8989">Deer Abode</span>.</p></div></div></div></div><div id="da2fdae1-48de-4073-a11d-3fe6f61d4dc4" class="relative scroll-mt-20"><button type="button" id="radix-_R_hit5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.203</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Confused Attachment</div><ul class="ml-4 list-disc"><li class="italic">lhag par chags par rmongs pa</li><li class="pt-1"><span class="font-tibetan text-base">ལྷག་པར་ཆགས་པར་རྨོངས་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A “ruler of the world” who belongs to the class of the <span data-glossary-id="UT22084-068-021-8553">māras</span>.</p></div></div></div></div><div id="5724a013-4f4c-41b3-88d5-d06429c3e4a8" class="relative scroll-mt-20"><button type="button" id="radix-_R_hj55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.204</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Conquered by Kadambas</div><ul class="ml-4 list-disc"><li class="italic">ka dam+ba’i bya rnams kyis bcom pa</li><li class="pt-1"><span class="font-tibetan text-base">ཀ་དམྦའི་བྱ་རྣམས་ཀྱིས་བཅོམ་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lake on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span>.</p></div></div></div></div><div id="9d755801-41c2-493b-aa1b-2aba8d6261a8" class="relative scroll-mt-20"><button type="button" id="radix-_R_hjd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.205</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Conqueror</div><ul class="ml-4 list-disc"><li class="italic">rnam rgyal byed</li><li class="pt-1"><span class="font-tibetan text-base">རྣམ་རྒྱལ་བྱེད།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lake in <span data-glossary-id="UT22084-068-021-9074">Enraptured by and Attached to Song</span>.</p></div></div></div></div><div id="1345dfd4-72fc-4abb-95b1-6d49c9e4e04f" class="relative scroll-mt-20"><button type="button" id="radix-_R_hjl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.206</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Consoler</div><ul class="ml-4 list-disc"><li class="italic">’thun par byed pa</li><li class="pt-1"><span class="font-tibetan text-base">འཐུན་པར་བྱེད་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A previous ruler of the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="00583e90-56c6-416d-92da-51eb2fbbe211" class="relative scroll-mt-20"><button type="button" id="radix-_R_hjt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.207</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Constant Bliss</div><ul class="ml-4 list-disc"><li class="italic">rtag tu bde ba</li><li class="pt-1"><span class="font-tibetan text-base">རྟག་ཏུ་བདེ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">One of the twenty-seven realms of the <span data-glossary-id="UT22084-068-021-9266">Heaven Free from Strife</span>.</p></div></div></div></div><div id="e1201d8c-75c7-4597-9bc6-feac4615c2e5" class="relative scroll-mt-20"><button type="button" id="radix-_R_hk55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.208</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Constant Darkness</div><ul class="ml-4 list-disc"><li class="italic">rtag tu mun pa</li><li class="pt-1"><span class="font-tibetan text-base">རྟག་ཏུ་མུན་པ།</span></li><li class="italic">nirantarāndhakāra</li></ul><div class="glossary-instance-definition"><p class="definition">A realm that neighbors the <span data-glossary-id="UT22084-068-021-9278">Hell of Intense Heat</span>.</p></div></div></div></div><div id="8145e3b0-8ca0-482d-8ca1-a109bcb23113" class="relative scroll-mt-20"><button type="button" id="radix-_R_hkd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.209</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">constant enjoyer</div><ul class="ml-4 list-disc"><li class="italic">rtag tu dga’ ba</li><li class="pt-1"><span class="font-tibetan text-base">རྟག་ཏུ་དགའ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A class of <span data-glossary-id="UT22084-068-021-8622">vidyādharas</span>.</p></div></div></div></div><div id="413d5162-b293-411b-9c2c-0f9b5858e307" class="relative scroll-mt-20"><button type="button" id="radix-_R_hkl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.210</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Constant Enjoyment</div><ul class="ml-4 list-disc"><li class="italic">rtag tu mngon par dga’ ba</li><li class="pt-1"><span class="font-tibetan text-base">རྟག་ཏུ་མངོན་པར་དགའ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest on the lower level of <span data-glossary-id="UT22084-068-021-9417">Living on the Peak</span>.</p></div></div></div></div><div id="da3f9356-9923-4f79-991a-630263a78631" class="relative scroll-mt-20"><button type="button" id="radix-_R_hkt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.211</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Constant Happiness</div><ul class="ml-4 list-disc"><li class="italic">rtag tu mngon par dga’ ba</li><li class="pt-1"><span class="font-tibetan text-base">རྟག་ཏུ་མངོན་པར་དགའ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A pond in <span data-glossary-id="UT22084-068-021-8956">Continuous Movement</span>.</p></div></div></div></div><div id="af82ef4c-cbea-4c7a-bf5c-6712f6e196ec" class="relative scroll-mt-20"><button type="button" id="radix-_R_hl55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.212</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">constant infatuation</div><ul class="ml-4 list-disc"><li class="italic">rtag par rgyags pa</li><li class="pt-1"><span class="font-tibetan text-base">རྟག་པར་རྒྱགས་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bird that lives on the banks of the <span data-glossary-id="UT22084-068-021-9637">River of Carelessness</span>.</p></div></div></div></div><div id="7305a218-276d-4a22-9c0e-74e93497e18d" class="relative scroll-mt-20"><button type="button" id="radix-_R_hld5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.213</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Constant Joy</div><ul class="ml-4 list-disc"><li class="italic">brtan dga’, rtag dga’</li><li class="pt-1"><span class="font-tibetan text-base">བརྟན་དགའ།, རྟག་དགའ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">(1) A peak on <span data-glossary-id="UT22084-068-021-9739">Sumeru</span> (<em class="foreign text-wy" lang="bo-LATN">rtag dga’</em>). (2) A realm of the <span data-glossary-id="UT22084-068-021-8516">ever-infatuated gods</span> (<em class="foreign text-wy" lang="bo-LATN">brtan dga’</em>).</p></div></div></div></div><div id="6d721143-1c8c-4523-b6ed-c453b63bec8a" class="relative scroll-mt-20"><button type="button" id="radix-_R_hll5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.214</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Constant Lightning</div><ul class="ml-4 list-disc"><li class="italic">rtag tu glog ’khyug pa</li><li class="pt-1"><span class="font-tibetan text-base">རྟག་ཏུ་གློག་འཁྱུག་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest on <span data-glossary-id="UT22084-068-021-9128">Flocking Peacocks</span>.</p></div></div></div></div><div id="e8ac0140-0693-4702-b22b-187c49d6a128" class="relative scroll-mt-20"><button type="button" id="radix-_R_hlt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.215</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Constant Lotus Joy</div><ul class="ml-4 list-disc"><li class="italic">rtag tu pad ma rab tu dga’ ba</li><li class="pt-1"><span class="font-tibetan text-base">རྟག་ཏུ་པད་མ་རབ་ཏུ་དགའ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A pond on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span>.</p></div></div></div></div><div id="9d3b78ee-360b-419b-a676-617a015557d9" class="relative scroll-mt-20"><button type="button" id="radix-_R_hm55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.216</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Constant Play</div><ul class="ml-4 list-disc"><li class="italic">rtag tu rtse ba</li><li class="pt-1"><span class="font-tibetan text-base">རྟག་ཏུ་རྩེ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A pleasure garden in <span data-glossary-id="UT22084-068-021-9547">Pair of Śāla Trees</span>.</p></div></div></div></div><div id="110026e6-0a9b-430d-8a3d-39848c26cfed" class="relative scroll-mt-20"><button type="button" id="radix-_R_hmd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.217</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">constant power</div><ul class="ml-4 list-disc"><li class="italic">rtag pa’i shugs</li><li class="pt-1"><span class="font-tibetan text-base">རྟག་པའི་ཤུགས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A class of <span data-glossary-id="UT22084-068-021-8622">vidyādharas</span>.</p></div></div></div></div><div id="ee2fab08-75a7-4f24-a955-d3ec9fe73f7f" class="relative scroll-mt-20"><button type="button" id="radix-_R_hml5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.218</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Constant Rain of Glowing Sand</div><ul class="ml-4 list-disc"><li class="italic">mdag me bye ma lta bu’i char rtag tu ’bab pa</li><li class="pt-1"><span class="font-tibetan text-base">མདག་མེ་བྱེ་མ་ལྟ་བུའི་ཆར་རྟག་ཏུ་འབབ་པ།</span></li><li class="italic">nitya­sikatāṅgāra­varṣa</li></ul><div class="glossary-instance-definition"><p class="definition">A realm that neighbors the <span data-glossary-id="UT22084-068-021-9278">Hell of Intense Heat</span>.</p></div></div></div></div><div id="08c919b7-46dc-4bd2-a132-939225214994" class="relative scroll-mt-20"><button type="button" id="radix-_R_hmt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.219</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Constant Terror</div><ul class="ml-4 list-disc"><li class="italic">rtag tu ’jigs pa</li><li class="pt-1"><span class="font-tibetan text-base">རྟག་ཏུ་འཇིགས་པ།</span></li><li class="italic">sadāpratibhayā</li></ul><div class="glossary-instance-definition"><p class="definition">A river in the hell of the Borderland of the <span data-glossary-id="UT22084-068-021-8707">Lord of Death</span>.</p></div></div></div></div><div id="c9b14788-ba1d-4800-8d6f-79e08ce2bd55" class="relative scroll-mt-20"><button type="button" id="radix-_R_hn55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.220</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Constant True Joy</div><ul class="ml-4 list-disc"><li class="italic">rtag tu mngon dga’</li><li class="pt-1"><span class="font-tibetan text-base">རྟག་ཏུ་མངོན་དགའ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest in <span data-glossary-id="UT22084-068-021-9035">Dwelling on Summits</span>.</p></div></div></div></div><div id="87e1bf1d-a51f-4b90-b390-6faeefb178cb" class="relative scroll-mt-20"><button type="button" id="radix-_R_hnd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.221</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Constant Water</div><ul class="ml-4 list-disc"><li class="italic">brtan pa’i chu, rtag pa’i chu</li><li class="pt-1"><span class="font-tibetan text-base">བརྟན་པའི་ཆུ།, རྟག་པའི་ཆུ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">(1) A lake on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span>. (2) A pond on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span>. (3) A lotus pond on the fifth minor mountain on <span data-glossary-id="UT22084-068-021-9423">Lofty Summit</span> (<em class="foreign text-wy" lang="bo-LATN">brtan pa’i chu</em>).</p></div></div></div></div><div id="1dc8dd55-5942-415d-bf09-1a83c3df931f" class="relative scroll-mt-20"><button type="button" id="radix-_R_hnl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.222</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Constantly Crazed Bees</div><ul class="ml-4 list-disc"><li class="italic">bung ba rtag myos</li><li class="pt-1"><span class="font-tibetan text-base">བུང་བ་རྟག་མྱོས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A park in <span data-glossary-id="UT22084-068-021-9757">Sustained by Fruition</span>.</p></div></div></div></div><div id="cdb62a26-0a76-4843-a77a-92f261cc119f" class="relative scroll-mt-20"><button type="button" id="radix-_R_hnt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.223</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Constantly Ravishing</div><ul class="ml-4 list-disc"><li class="italic">rtag tu rab dga’</li><li class="pt-1"><span class="font-tibetan text-base">རྟག་ཏུ་རབ་དགའ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest in <span data-glossary-id="UT22084-068-021-9035">Dwelling on Summits</span>.</p></div></div></div></div><div id="d3848c3b-9988-4955-bf96-9a9e600c0b6f" class="relative scroll-mt-20"><button type="button" id="radix-_R_ho55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.224</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Consuming Blood and Fat</div><ul class="ml-4 list-disc"><li class="italic">khrag dang zhag za ba</li><li class="pt-1"><span class="font-tibetan text-base">ཁྲག་དང་ཞག་ཟ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">Alternative name for <span data-glossary-id="UT22084-068-021-8953">Consuming Blood and Marrow</span>, which is one of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-9235">Great Howling Hell</span>.</p></div></div></div></div><div id="2a2615ca-91e3-463e-ba9a-ba806705a585" class="relative scroll-mt-20"><button type="button" id="radix-_R_hod5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.225</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Consuming Blood and Marrow</div><ul class="ml-4 list-disc"><li class="italic">khrag dang rkang za ba</li><li class="pt-1"><span class="font-tibetan text-base">ཁྲག་དང་རྐང་ཟ་བ།</span></li><li class="italic">rudhira­majjāhāra</li></ul><div class="glossary-instance-definition"><p class="definition">One of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-9235">Great Howling Hell</span>.</p></div></div></div></div><div id="8955f95c-8296-4dde-a182-88eac8e264ff" class="relative scroll-mt-20"><button type="button" id="radix-_R_hol5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.226</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Continuous</div><ul class="ml-4 list-disc"><li class="italic">bar med</li><li class="pt-1"><span class="font-tibetan text-base">བར་མེད།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lake in <span data-glossary-id="UT22084-068-021-9209">Godānīya</span>.</p></div></div></div></div><div id="cebdca3a-c2e7-4867-9fdb-48a61d619a8d" class="relative scroll-mt-20"><button type="button" id="radix-_R_hot5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.227</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Continuous Abode</div><ul class="ml-4 list-disc"><li class="italic">rgyun gyi gnas</li><li class="pt-1"><span class="font-tibetan text-base">རྒྱུན་གྱི་གནས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest in <span data-glossary-id="UT22084-068-021-9014">Draped with Jewels</span>.</p></div></div></div></div><div id="6f3344d2-5747-4e88-883e-f63f504ac6c6" class="relative scroll-mt-20"><button type="button" id="radix-_R_hp55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.228</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Continuous Movement</div><ul class="ml-4 list-disc"><li class="italic">rgyun gyis rgyu ba</li><li class="pt-1"><span class="font-tibetan text-base">རྒྱུན་གྱིས་རྒྱུ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">One of the twenty-seven realms of the <span data-glossary-id="UT22084-068-021-9266">Heaven Free from Strife</span>, possibly the same as <span data-glossary-id="UT22084-068-021-9506">Moving in Mixed Environments</span> (<em class="foreign text-wy" lang="bo-LATN">rab tu rnam par ’dres pa’i khor yug na rgyu ba</em>).</p></div></div></div></div><div id="e31fcef7-ac60-479e-87ba-bd1c96a18a0e" class="relative scroll-mt-20"><button type="button" id="radix-_R_hpd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.229</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Continuously Cultivated</div><ul class="ml-4 list-disc"><li class="italic">kun nas bsten pa</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་ནས་བསྟེན་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lotus pond in <span data-glossary-id="UT22084-068-021-9000">Delighting in Flower Garlands</span>.</p></div></div></div></div><div id="2cfc121c-24ee-4c77-a8ff-19ad62ff7743" class="relative scroll-mt-20"><button type="button" id="radix-_R_hpl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.230</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Controlled Movement</div><ul class="ml-4 list-disc"><li class="italic">bsdams par rgyu ba</li><li class="pt-1"><span class="font-tibetan text-base">བསྡམས་པར་རྒྱུ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">One of the twenty-seven realms of the <span data-glossary-id="UT22084-068-021-9266">Heaven Free from Strife</span>.</p></div></div></div></div><div id="f902b058-6a31-48d1-b86f-30bd93b060c1" class="relative scroll-mt-20"><button type="button" id="radix-_R_hpt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.231</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Cool Water</div><ul class="ml-4 list-disc"><li class="italic">chu bsil ba</li><li class="pt-1"><span class="font-tibetan text-base">ཆུ་བསིལ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A pond at the forest <span data-ref="UT22084-068-021-9351"><span data-glossary-id="UT22084-068-021-9351">Joyous</span></span> in <span data-glossary-id="UT22084-068-021-9734">Sudharma</span>.</p></div></div></div></div><div id="1a3cce14-79a6-408b-9030-ee0c4502be2e" class="relative scroll-mt-20"><button type="button" id="radix-_R_hq55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.232</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Cool Water Home</div><ul class="ml-4 list-disc"><li class="italic">chu bsil gnas</li><li class="pt-1"><span class="font-tibetan text-base">ཆུ་བསིལ་གནས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A realm of the <span data-glossary-id="UT22084-068-021-8516">ever-infatuated gods</span>.</p></div></div></div></div><div id="ac485db5-4f1d-4854-96da-060f4fd018f3" class="relative scroll-mt-20"><button type="button" id="radix-_R_hqd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.233</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Cool Waters</div><ul class="ml-4 list-disc"><li class="italic">chu bsil</li><li class="pt-1"><span class="font-tibetan text-base">ཆུ་བསིལ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A pool in <span data-glossary-id="UT22084-068-021-9710">Special Joy</span>.</p></div></div></div></div><div id="761850dc-1d10-476f-8b06-f12e2780c010" class="relative scroll-mt-20"><button type="button" id="radix-_R_hql5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.234</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Copious Degeneration</div><ul class="ml-4 list-disc"><li class="italic">nyams pa mang ba</li><li class="pt-1"><span class="font-tibetan text-base">ཉམས་པ་མང་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">One of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-8975">Crushing Hell</span>.</p></div></div></div></div><div id="fcb3d8fb-0c39-45dc-baa1-52861118881a" class="relative scroll-mt-20"><button type="button" id="radix-_R_hqt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.235</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Copious Parasites in Marrow and Bones</div><ul class="ml-4 list-disc"><li class="italic">rkang dang rus pa la srin bu mang ba</li><li class="pt-1"><span class="font-tibetan text-base">རྐང་དང་རུས་པ་ལ་སྲིན་བུ་མང་བ།</span></li><li class="italic">majjāsthi­kṛmi­nikara</li></ul><div class="glossary-instance-definition"><p class="definition">One of the sixteen realms that surround the <span><span data-glossary-id="UT22084-068-021-9277">Hell of Heat</span></span>. </p></div></div></div></div><div id="f1f6dc02-ff8c-4016-aa23-1053d284300d" class="relative scroll-mt-20"><button type="button" id="radix-_R_hr55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.236</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Copper Holder</div><ul class="ml-4 list-disc"><li class="italic">zangs can</li><li class="pt-1"><span class="font-tibetan text-base">ཟངས་ཅན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">An island far off the coast of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="95dea55f-6827-4aab-a04b-9198eaec4903" class="relative scroll-mt-20"><button type="button" id="radix-_R_hrd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.237</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Copper-Colored</div><ul class="ml-4 list-disc"><li class="italic">zangs kyi mdog</li><li class="pt-1"><span class="font-tibetan text-base">ཟངས་ཀྱི་མདོག</span></li></ul><div class="glossary-instance-definition"><p class="definition">A mountain to the north of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="89d1e071-dd13-4187-9e29-4efc668445e8" class="relative scroll-mt-20"><button type="button" id="radix-_R_hrl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.238</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Coppery</div><ul class="ml-4 list-disc"><li class="italic">zangs ma can</li><li class="pt-1"><span class="font-tibetan text-base">ཟངས་མ་ཅན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-068-021-8581">rākṣasī</span> on the island called <span data-glossary-id="UT22084-068-021-8964">Copper Holder</span>. </p></div></div></div></div><div id="94c64e8d-dd89-4d1b-92d7-140baa882c0f" class="relative scroll-mt-20"><button type="button" id="radix-_R_hrt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.239</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Coral Forest</div><ul class="ml-4 list-disc"><li class="italic">byi ru’i tshal</li><li class="pt-1"><span class="font-tibetan text-base">བྱི་རུའི་ཚལ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A pleasure grove in <span data-glossary-id="UT22084-068-021-9869">White Body</span>.</p></div></div></div></div><div id="b106235e-98e5-4021-b3c1-f4448e075653" class="relative scroll-mt-20"><button type="button" id="radix-_R_hs55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.240</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Covered by Hair</div><ul class="ml-4 list-disc"><li class="italic">skras khyab pa</li><li class="pt-1"><span class="font-tibetan text-base">སྐྲས་ཁྱབ་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-068-021-8574">piśāca</span>.</p></div></div></div></div><div id="7d1c1681-254a-4ed3-877d-4f3c5c599868" class="relative scroll-mt-20"><button type="button" id="radix-_R_hsd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.241</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Covered by Palāśas</div><ul class="ml-4 list-disc"><li class="italic">pa la sha yis kun tu khyab pa</li><li class="pt-1"><span class="font-tibetan text-base">པ་ལ་ཤ་ཡིས་ཀུན་ཏུ་ཁྱབ་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">An area in <span data-glossary-id="UT22084-068-021-9398">Kuru</span>.</p></div></div></div></div><div id="1c21fcaf-2213-4cb6-9304-a49af8f93bd0" class="relative scroll-mt-20"><button type="button" id="radix-_R_hsl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.242</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Covered by Puḍi</div><ul class="ml-4 list-disc"><li class="italic">pu Dis g.yogs pa</li><li class="pt-1"><span class="font-tibetan text-base">པུ་ཌིས་གཡོགས་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">An ocean to the south of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="2044b7d7-517b-4305-aace-332a2042bc26" class="relative scroll-mt-20"><button type="button" id="radix-_R_hst5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.243</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Covered by Red Lotuses</div><ul class="ml-4 list-disc"><li class="italic">pad ma dmar pos kun tu khyab pa</li><li class="pt-1"><span class="font-tibetan text-base">པད་མ་དམར་པོས་ཀུན་ཏུ་ཁྱབ་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lotus pond on the fifth minor mountain on <span data-glossary-id="UT22084-068-021-9423">Lofty Summit</span>.</p></div></div></div></div><div id="c267dd61-3596-4929-abec-afba46ff0391" class="relative scroll-mt-20"><button type="button" id="radix-_R_ht55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.244</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Covered by Vines</div><ul class="ml-4 list-disc"><li class="italic">’khri shing gis g.yogs pa</li><li class="pt-1"><span class="font-tibetan text-base">འཁྲི་ཤིང་གིས་གཡོགས་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A river on <span data-glossary-id="UT22084-068-021-9142">Forest Garlands</span>.</p></div></div></div></div><div id="8c2659d2-1fca-40d2-bb49-a316cf575e54" class="relative scroll-mt-20"><button type="button" id="radix-_R_htd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.245</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">covetousness</div><ul class="ml-4 list-disc"><li class="italic">brnab sems</li><li class="pt-1"><span class="font-tibetan text-base">བརྣབ་སེམས།</span></li><li class="italic">abhidhyā</li></ul><div class="glossary-instance-definition"><p class="definition">The first among the three mental misdeeds.</p></div></div></div></div><div id="e3970582-2be1-4a0f-9854-2b81ce220f25" class="relative scroll-mt-20"><button type="button" id="radix-_R_htl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.246</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Crested Ravens</div><ul class="ml-4 list-disc"><li class="italic">skra shad ’dzings pa dang bya khwa yod pa</li><li class="pt-1"><span class="font-tibetan text-base">སྐྲ་ཤད་འཛིངས་པ་དང་བྱ་ཁྭ་ཡོད་པ།</span></li><li class="italic">keśoṇḍūka­vāyasa</li></ul><div class="glossary-instance-definition"><p class="definition">A realm that neighbors the <span data-glossary-id="UT22084-068-021-9278">Hell of Intense Heat</span>.</p></div></div></div></div><div id="298ea33b-ef8e-43a2-9e7d-99f27a405232" class="relative scroll-mt-20"><button type="button" id="radix-_R_htt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.247</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Crier</div><ul class="ml-4 list-disc"><li class="italic">a tsa zer ba</li><li class="pt-1"><span class="font-tibetan text-base">ཨ་ཙ་ཟེར་བ།</span></li><li class="italic">cuṭucuṭu</li></ul><div class="glossary-instance-definition"><p class="definition">One of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-8975">Crushing Hell</span>.</p></div></div></div></div><div id="d2c0b5df-597c-4b9d-8945-48b75f659a51" class="relative scroll-mt-20"><button type="button" id="radix-_R_hu55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.248</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Crown</div><ul class="ml-4 list-disc"><li class="italic">spyi bo</li><li class="pt-1"><span class="font-tibetan text-base">སྤྱི་བོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">Location visited for pleasure by <span data-glossary-id="UT22084-068-021-8738">Śakra</span> and his entourage.</p></div></div></div></div><div id="d4244233-507b-4fdd-a5b0-082e5216bfb6" class="relative scroll-mt-20"><button type="button" id="radix-_R_hud5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.249</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Crown Escape</div><ul class="ml-4 list-disc"><li class="italic">spyi gtsug thar</li><li class="pt-1"><span class="font-tibetan text-base">སྤྱི་གཙུག་ཐར།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A realm of the <span data-glossary-id="UT22084-068-021-8621">vessel-bearer gods</span>.</p></div></div></div></div><div id="ae02cdca-f368-43dd-b100-cc38a694e7a9" class="relative scroll-mt-20"><button type="button" id="radix-_R_hul5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.250</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">cruising the path of the sun</div><ul class="ml-4 list-disc"><li class="italic">nyi ma’i lam du legs par rgyu ba</li><li class="pt-1"><span class="font-tibetan text-base">ཉི་མའི་ལམ་དུ་ལེགས་པར་རྒྱུ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A class of <span data-glossary-id="UT22084-068-021-8622">vidyādharas</span>.</p></div></div></div></div><div id="449f90a0-2a80-480d-b26e-65ae149c98fa" class="relative scroll-mt-20"><button type="button" id="radix-_R_hut5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.251</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Crushing, Crushing Hell</div><ul class="ml-4 list-disc"><li class="italic">bsdus gzhom</li><li class="pt-1"><span class="font-tibetan text-base">བསྡུས་གཞོམ།</span></li><li class="italic">saṃghāta</li></ul><div class="glossary-instance-definition"><p class="definition">One of the eight hot hells.</p></div></div></div></div><div id="ee028a73-59f9-4a7f-b726-bcf757ca0fa5" class="relative scroll-mt-20"><button type="button" id="radix-_R_hv55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.252</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Crystal Encounter</div><ul class="ml-4 list-disc"><li class="italic">shel ’jug pa</li><li class="pt-1"><span class="font-tibetan text-base">ཤེལ་འཇུག་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lake on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span>.</p></div></div></div></div><div id="c1ef7752-0e77-4785-ac29-cb526d389589" class="relative scroll-mt-20"><button type="button" id="radix-_R_hvd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.253</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Crystal Forest</div><ul class="ml-4 list-disc"><li class="italic">shel gi tshal</li><li class="pt-1"><span class="font-tibetan text-base">ཤེལ་གི་ཚལ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest in <span><span data-glossary-id="UT22084-068-021-8791">Activity</span></span>.</p></div></div></div></div><div id="80fa6f62-064b-4e77-9397-e19b8a60159e" class="relative scroll-mt-20"><button type="button" id="radix-_R_hvl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.254</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">crystal holders</div><ul class="ml-4 list-disc"><li class="italic">nor bu’i do shal thogs pa</li><li class="pt-1"><span class="font-tibetan text-base">ནོར་བུའི་དོ་ཤལ་ཐོགས་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A class of <span data-glossary-id="UT22084-068-021-8489">asuras</span>.</p></div></div></div></div><div id="21b16584-28d7-4a39-a437-43fbc34e83c8" class="relative scroll-mt-20"><button type="button" id="radix-_R_hvt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.255</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Culundha Stream</div><ul class="ml-4 list-disc"><li class="italic">tsu lun+da ’bab pa</li><li class="pt-1"><span class="font-tibetan text-base">ཙུ་ལུནྡ་འབབ་པ།</span></li><li class="italic">culundha</li></ul><div class="glossary-instance-definition"><p class="definition">A river on <span data-glossary-id="UT22084-068-021-9657">Saṅkāśa</span>.</p></div></div></div></div><div id="62f23b61-4c92-478f-9413-88072291df9c" class="relative scroll-mt-20"><button type="button" id="radix-_R_i055anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.256</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Cuñcumātī</div><ul class="ml-4 list-disc"><li class="italic">tsun tsum+pa tI</li><li class="pt-1"><span class="font-tibetan text-base">ཙུན་ཙུམྤ་ཏཱི།</span></li><li class="italic">cuñcumātī</li></ul><div class="glossary-instance-definition"><p class="definition">A river in <span data-glossary-id="UT22084-068-021-9209">Godānīya</span>.</p></div></div></div></div><div id="7f9b4269-ecf7-4226-9cbd-3ff52a609edb" class="relative scroll-mt-20"><button type="button" id="radix-_R_i0d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.257</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">cyclic existence, saṃsāra</div><ul class="ml-4 list-disc"><li class="italic">’khor ba, ’khor ba</li><li class="pt-1"><span class="font-tibetan text-base">འཁོར་བ།, འཁོར་བ།</span></li><li class="italic">saṃsāra, saṃsāra</li></ul><div class="glossary-instance-definition"><p class="definition">The cycle of birth and death driven by mental <span data-glossary-id="UT22084-068-021-9942">afflictions</span> and karmic actions.</p></div></div></div></div><div id="35bde4db-33ca-4dba-8414-ff2df3723581" class="relative scroll-mt-20"><button type="button" id="radix-_R_i0l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.258</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">cyclic existence, saṃsāra</div><ul class="ml-4 list-disc"><li class="italic">’khor ba, ’khor ba</li><li class="pt-1"><span class="font-tibetan text-base">འཁོར་བ།, འཁོར་བ།</span></li><li class="italic">saṃsāra, saṃsāra</li></ul><div class="glossary-instance-definition"><p class="definition">See <span data-glossary-id="UT22084-068-021-8589">cyclic existence</span>.</p></div></div></div></div><div id="46f3b9b0-323b-40f6-b771-c8b7c9d3bc54" class="relative scroll-mt-20"><button type="button" id="radix-_R_i0t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.259</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dancing Birds</div><ul class="ml-4 list-disc"><li class="italic">tshal bya bro gar byed pa</li><li class="pt-1"><span class="font-tibetan text-base">ཚལ་བྱ་བྲོ་གར་བྱེད་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A grove in the forest known as <span><span data-glossary-id="UT22084-068-021-9310">Incomparable</span></span>.</p></div></div></div></div><div id="881a4fc4-ddb3-484f-afe9-484b00a23034" class="relative scroll-mt-20"><button type="button" id="radix-_R_i155anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.260</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Daṇḍakāraṇyaṅ</div><ul class="ml-4 list-disc"><li class="italic">daN+Da kA ra N+yang</li><li class="pt-1"><span class="font-tibetan text-base">དཎྜ་ཀཱ་ར་ཎྱང་།</span></li><li class="italic">daṇḍakāraṇyaṅ</li></ul><div class="glossary-instance-definition"><p class="definition">A river in the south of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="60191523-8ec7-403b-89e2-2a4f9f39524e" class="relative scroll-mt-20"><button type="button" id="radix-_R_i1d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.261</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dardo</div><ul class="ml-4 list-disc"><li class="italic">dar do</li><li class="pt-1"><span class="font-tibetan text-base">དར་དོ།</span></li><li class="italic">dardo</li></ul><div class="glossary-instance-definition"><p class="definition">A land to the north of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="6cdf5aab-bb05-4249-b19d-54ee95a1b5d5" class="relative scroll-mt-20"><button type="button" id="radix-_R_i1l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.262</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Darkness</div><ul class="ml-4 list-disc"><li class="italic">mun pa</li><li class="pt-1"><span class="font-tibetan text-base">མུན་པ།</span></li><li class="italic">andhakāra</li></ul><div class="glossary-instance-definition"><p class="definition">One of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-9630">Reviving Hell</span>.</p></div></div></div></div><div id="168ffbb2-2980-4b4e-9a20-7aa9f90fae40" class="relative scroll-mt-20"><button type="button" id="radix-_R_i1t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.263</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">decisive explications</div><ul class="ml-4 list-disc"><li class="italic">rnam par gtan la dbab pa bstan pa’i sde</li><li class="pt-1"><span class="font-tibetan text-base">རྣམ་པར་གཏན་ལ་དབབ་པ་བསྟན་པའི་སྡེ།</span></li><li class="italic">upadeśa</li></ul><div class="glossary-instance-definition"><p class="definition">One among the twelve sections of scripture.</p></div></div></div></div><div id="d624a454-8c04-4743-8c2b-374403245879" class="relative scroll-mt-20"><button type="button" id="radix-_R_i255anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.264</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Decorative Birds and Trees</div><ul class="ml-4 list-disc"><li class="italic">bya dag shing ljon pas brgyan pa</li><li class="pt-1"><span class="font-tibetan text-base">བྱ་དག་ཤིང་ལྗོན་པས་བརྒྱན་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest in <span data-glossary-id="UT22084-068-021-9066">Engaging in Clarification</span>.</p></div></div></div></div><div id="2eeccbbe-339f-4783-8cf4-ec2ecbfaf866" class="relative scroll-mt-20"><button type="button" id="radix-_R_i2d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.265</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Deep</div><ul class="ml-4 list-disc"><li class="italic">zab mo, zab pa</li><li class="pt-1"><span class="font-tibetan text-base">ཟབ་པ།, ཟབ་མོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">(1) A pool upon one of <span data-glossary-id="UT22084-068-021-8636">Airāvaṇa</span>’s ears (<em class="foreign text-wy" lang="bo-LATN">zab pa</em>). (2) A lotus pond on the fifth minor mountain on <span data-glossary-id="UT22084-068-021-9423">Lofty Summit</span> (<em class="foreign text-wy" lang="bo-LATN">zab pa</em>). (3) A forest on <span data-glossary-id="UT22084-068-021-9657">Saṅkāśa</span> (<em class="foreign text-wy" lang="bo-LATN">zab mo</em>).</p></div></div></div></div><div id="41511b69-316c-4264-82f5-d66eed19f692" class="relative scroll-mt-20"><button type="button" id="radix-_R_i2l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.266</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Deep and Joyous for the Moon</div><ul class="ml-4 list-disc"><li class="italic">zab mo dang zla ba dga’ ba</li><li class="pt-1"><span class="font-tibetan text-base">ཟབ་མོ་དང་ཟླ་བ་དགའ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lake on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span>.</p></div></div></div></div><div id="fccea2a9-c741-4c27-8a25-8a5bfbbf5ebc" class="relative scroll-mt-20"><button type="button" id="radix-_R_i2t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.267</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Deep Stream</div><ul class="ml-4 list-disc"><li class="italic">chu klung zab mo’i chu</li><li class="pt-1"><span class="font-tibetan text-base">ཆུ་ཀླུང་ཟབ་མོའི་ཆུ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A river on <span data-glossary-id="UT22084-068-021-9657">Saṅkāśa</span>.</p></div></div></div></div><div id="da168deb-cdd5-4363-9fba-448dbdbd4537" class="relative scroll-mt-20"><button type="button" id="radix-_R_i355anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.268</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Deer Abode</div><ul class="ml-4 list-disc"><li class="italic">ri dags kyi khrod</li><li class="pt-1"><span class="font-tibetan text-base">རི་དགས་ཀྱི་ཁྲོད།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A mountain on <span data-glossary-id="UT22084-068-021-9847">Videha</span>.</p></div></div></div></div><div id="55abbbc5-d9a7-4216-8400-5b317679c976" class="relative scroll-mt-20"><button type="button" id="radix-_R_i3d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.269</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">deer gait</div><ul class="ml-4 list-disc"><li class="italic">ri dags kyi ’gros</li><li class="pt-1"><span class="font-tibetan text-base">རི་དགས་ཀྱི་འགྲོས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A class of <span data-glossary-id="UT22084-068-021-8622">vidyādharas</span>.</p></div></div></div></div><div id="758cb6e8-e4df-492c-8c94-99c76f3da6f5" class="relative scroll-mt-20"><button type="button" id="radix-_R_i3l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.270</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Definite Attainment of Pleasure</div><ul class="ml-4 list-disc"><li class="italic">’dod pa nges par thob</li><li class="pt-1"><span class="font-tibetan text-base">འདོད་པ་ངེས་པར་ཐོབ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A pleasure grove in <span data-glossary-id="UT22084-068-021-9601">Promotion</span></p></div></div></div></div><div id="32b11e2b-78cc-43de-87d4-638256885dcf" class="relative scroll-mt-20"><button type="button" id="radix-_R_i3t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.271</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Delightful</div><ul class="ml-4 list-disc"><li class="italic">yid kyi rjes su ’thun pa</li><li class="pt-1"><span class="font-tibetan text-base">ཡིད་ཀྱི་རྗེས་སུ་འཐུན་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">(1) A forest on <span data-glossary-id="UT22084-068-021-9046">Encircled by White Clouds</span>. (2) A mountain in <span data-glossary-id="UT22084-068-021-9398">Kuru</span>.</p></div></div></div></div><div id="8281d106-4d0d-43f9-846a-60cc5c1fb5c5" class="relative scroll-mt-20"><button type="button" id="radix-_R_i455anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.272</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Delightful Beauty</div><ul class="ml-4 list-disc"><li class="italic">yid bzhin mdzes ’gyur</li><li class="pt-1"><span class="font-tibetan text-base">ཡིད་བཞིན་མཛེས་འགྱུར།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A queen of <span data-glossary-id="UT22084-068-021-8731">Rāhu</span>, king of <span data-glossary-id="UT22084-068-021-8489">asuras</span>.</p></div></div></div></div><div id="b2137826-4ab0-47e7-8a43-45efe8286563" class="relative scroll-mt-20"><button type="button" id="radix-_R_i4d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.273</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Delightful Environs</div><ul class="ml-4 list-disc"><li class="italic">nye ’khor dga’ ba</li><li class="pt-1"><span class="font-tibetan text-base">ཉེ་འཁོར་དགའ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A river on <span data-glossary-id="UT22084-068-021-8989">Deer Abode</span>.</p></div></div></div></div><div id="3ed36bed-8486-463d-b6e0-89b5c3caae66" class="relative scroll-mt-20"><button type="button" id="radix-_R_i4l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.274</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Delightful Ground to Watch</div><ul class="ml-4 list-disc"><li class="italic">sa gzhi blta bar dga’ ba</li><li class="pt-1"><span class="font-tibetan text-base">ས་གཞི་བལྟ་བར་དགའ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A city in <span data-glossary-id="UT22084-068-021-9209">Godānīya</span>.</p></div></div></div></div><div id="f846570d-1cb5-42f2-bc3c-4b48cc6184f1" class="relative scroll-mt-20"><button type="button" id="radix-_R_i4t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.275</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Delightful Rain</div><ul class="ml-4 list-disc"><li class="italic">char dga’</li><li class="pt-1"><span class="font-tibetan text-base">ཆར་དགའ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">One of the seven golden mountains that surround Mount <span data-glossary-id="UT22084-068-021-9739">Sumeru</span>.</p></div></div></div></div><div id="ba8f8b61-1e75-4dec-99c5-48b96251aaed" class="relative scroll-mt-20"><button type="button" id="radix-_R_i555anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.276</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Delightful Retreat</div><ul class="ml-4 list-disc"><li class="italic">dgon pa dga’ ba</li><li class="pt-1"><span class="font-tibetan text-base">དགོན་པ་དགའ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest in <span data-glossary-id="UT22084-068-021-9556">Part of the Assembly</span>.</p></div></div></div></div><div id="d0dd1ea8-3b45-44cf-af65-8fb8354c803a" class="relative scroll-mt-20"><button type="button" id="radix-_R_i5d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.277</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Delightful Sight</div><ul class="ml-4 list-disc"><li class="italic">mthong dga’, rnam par mthong bas dga’ ba</li><li class="pt-1"><span class="font-tibetan text-base">མཐོང་དགའ།, རྣམ་པར་མཐོང་བས་དགའ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">(1) A lotus pool in <span data-glossary-id="UT22084-068-021-9403">Lateral</span>. (2) A pond on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span> (<em class="foreign text-wy" lang="bo-LATN">rnam par mthong bas dga’ ba</em>).</p></div></div></div></div><div id="8f9d23b3-cbd7-41e0-aa21-6b6f22c86aa1" class="relative scroll-mt-20"><button type="button" id="radix-_R_i5l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.278</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Delightful Summit</div><ul class="ml-4 list-disc"><li class="italic">rtse mo dga’ byed</li><li class="pt-1"><span class="font-tibetan text-base">རྩེ་མོ་དགའ་བྱེད།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A mountain near the <span data-glossary-id="UT22084-068-021-8489">asura</span> city <span data-glossary-id="UT22084-068-021-9012">Double Pleasure</span>.</p></div></div></div></div><div id="c8f10e40-1892-43a2-88a2-2b35aae43884" class="relative scroll-mt-20"><button type="button" id="radix-_R_i5t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.279</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Delightful to Behold</div><ul class="ml-4 list-disc"><li class="italic">mthong na dga’ ba</li><li class="pt-1"><span class="font-tibetan text-base">མཐོང་ན་དགའ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">(1) A forest in <span data-glossary-id="UT22084-068-021-9025">Dwelling in Excellent View</span>. (2) A pond in <span data-glossary-id="UT22084-068-021-8956">Continuous Movement</span>.</p></div></div></div></div><div id="c90b8102-87e3-4b8f-8fa6-7cdba019cb44" class="relative scroll-mt-20"><button type="button" id="radix-_R_i655anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.280</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Delightful Waters</div><ul class="ml-4 list-disc"><li class="italic">chu rab tu dga’ ba</li><li class="pt-1"><span class="font-tibetan text-base">ཆུ་རབ་ཏུ་དགའ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lotus pond in <span data-glossary-id="UT22084-068-021-9547">Pair of Śāla Trees</span>.</p></div></div></div></div><div id="79fc3f1d-8c45-4985-a2d7-ed9e4470eeb9" class="relative scroll-mt-20"><button type="button" id="radix-_R_i6d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.281</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Delighting in Emanations, Heaven of Delighting in Emanations</div><ul class="ml-4 list-disc"><li class="italic">’phrul dga’</li><li class="pt-1"><span class="font-tibetan text-base">འཕྲུལ་དགའ།</span></li><li class="italic">nirmāṇarati</li></ul><div class="glossary-instance-definition"><p class="definition">One of the six heavens of the desire realm.</p></div></div></div></div><div id="da32c507-916c-4027-b093-286021b78749" class="relative scroll-mt-20"><button type="button" id="radix-_R_i6l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.282</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Delighting in Flower Garlands</div><ul class="ml-4 list-disc"><li class="italic">me tog phreng dga’</li><li class="pt-1"><span class="font-tibetan text-base">མེ་ཏོག་ཕྲེང་དགའ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A realm of the <span data-glossary-id="UT22084-068-021-8621">vessel-bearer gods</span>.</p></div></div></div></div><div id="fa4e5a30-cd2d-4dfe-b724-8d07a9a9dd19" class="relative scroll-mt-20"><button type="button" id="radix-_R_i6t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.283</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Delighting in Objects</div><ul class="ml-4 list-disc"><li class="italic">yul la ’dod pa</li><li class="pt-1"><span class="font-tibetan text-base">ཡུལ་ལ་འདོད་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A realm of the <span data-glossary-id="UT22084-068-021-8516">ever-infatuated gods</span>.</p></div></div></div></div><div id="8c4df26d-3a5e-4879-a42e-02d77d8a29f6" class="relative scroll-mt-20"><button type="button" id="radix-_R_i755anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.284</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Delighting the People</div><ul class="ml-4 list-disc"><li class="italic">skye bo rnams mngon par dga’ ba</li><li class="pt-1"><span class="font-tibetan text-base">སྐྱེ་བོ་རྣམས་མངོན་པར་དགའ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A pond on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span>.</p></div></div></div></div><div id="391da7bf-5c0b-4dfb-aab1-7dcfc40fe04a" class="relative scroll-mt-20"><button type="button" id="radix-_R_i7d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.285</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Desirable</div><ul class="ml-4 list-disc"><li class="italic">’dod pa</li><li class="pt-1"><span class="font-tibetan text-base">འདོད་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">An emanated forest created upon the shoulders of <span data-glossary-id="UT22084-068-021-8636">Airāvaṇa</span>.</p></div></div></div></div><div id="20bb1d6b-75d3-4021-a466-36269d16ec8c" class="relative scroll-mt-20"><button type="button" id="radix-_R_i7l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.286</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Desired Wind</div><ul class="ml-4 list-disc"><li class="italic">’dod pa’i klung</li><li class="pt-1"><span class="font-tibetan text-base">འདོད་པའི་ཀླུང་།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A city in the <span data-glossary-id="UT22084-068-021-8489">asura</span> realm called <span data-glossary-id="UT22084-068-021-9481">Moon Garland</span>.</p></div></div></div></div><div id="ed04b085-14fb-4ba7-952e-758baccad7d0" class="relative scroll-mt-20"><button type="button" id="radix-_R_i7t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.287</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Devadatta</div><ul class="ml-4 list-disc"><li class="italic">lhas byin</li><li class="pt-1"><span class="font-tibetan text-base">ལྷས་བྱིན།</span></li><li class="italic">devadatta</li></ul><div class="glossary-instance-definition"><p class="definition">A cousin of the Buddha <span data-glossary-id="UT22084-068-021-10026">Śākyamuni</span> who broke with him and established his own community. His tradition was still continuing during the first millennium <span class="small-caps">ᴄᴇ</span>. He is portrayed as engendering evil schemes against the Buddha and even succeeding in wounding him. He is usually identified with wicked beings in accounts of previous lifetimes.</p></div></div></div></div><div id="a40034a3-e020-4c00-b967-5757173a5b0f" class="relative scroll-mt-20"><button type="button" id="radix-_R_i855anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.288</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Devapāla</div><ul class="ml-4 list-disc"><li class="italic">de ba phA la</li><li class="pt-1"><span class="font-tibetan text-base">དེ་བ་ཕཱ་ལ།</span></li><li class="italic">devapāla</li></ul><div class="glossary-instance-definition"><p class="definition">The Indian king who established <span data-glossary-id="UT22084-068-021-9851">Vikramaśīla</span>.</p></div></div></div></div><div id="d82e3613-3ecd-459b-90e4-dff460e353dd" class="relative scroll-mt-20"><button type="button" id="radix-_R_i8d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.289</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Devoid of the Sound of Concentration</div><ul class="ml-4 list-disc"><li class="italic">bsam gtan sgra’i bya bas dben pa</li><li class="pt-1"><span class="font-tibetan text-base">བསམ་གཏན་སྒྲའི་བྱ་བས་དབེན་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">One of the twenty-seven realms in the <span data-glossary-id="UT22084-068-021-9266">Heaven Free from Strife</span>.</p></div></div></div></div><div id="b98e0a0a-e4b2-408a-b1d0-d27d91224b0c" class="relative scroll-mt-20"><button type="button" id="radix-_R_i8l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.290</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dharma Master Surrounded by Clouds</div><ul class="ml-4 list-disc"><li class="italic">sprin gyi nye ’khor chos la dbang ba</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་གྱི་ཉེ་འཁོར་ཆོས་ལ་དབང་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-068-021-8562">nāga</span> who visits <span data-glossary-id="UT22084-068-021-9657">Saṅkāśa</span> Mountain.</p></div></div></div></div><div id="c8f3d188-2996-4689-9f87-c02f70f2e31e" class="relative scroll-mt-20"><button type="button" id="radix-_R_i8t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.291</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dharma-Vinaya</div><ul class="ml-4 list-disc"><li class="italic">chos ’dul ba</li><li class="pt-1"><span class="font-tibetan text-base">ཆོས་འདུལ་བ།</span></li><li class="italic">dharmavinaya</li></ul><div class="glossary-instance-definition"><p class="definition">An early term to denote the Buddha’s teaching. “Dharma” refers to the <span data-glossary-id="UT22084-068-021-9986">sūtras</span> and “<span data-glossary-id="UT22084-068-021-9974">Vinaya</span>” to the rules of discipline.</p></div></div></div></div><div id="51956966-be91-4b65-9d33-f7cf5c25811e" class="relative scroll-mt-20"><button type="button" id="radix-_R_i955anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.292</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dhiriko</div><ul class="ml-4 list-disc"><li class="italic">dhi ri ko</li><li class="pt-1"><span class="font-tibetan text-base">དྷི་རི་ཀོ</span></li><li class="italic">dhiriko</li></ul><div class="glossary-instance-definition"><p class="definition">A mountain in the eastern sea beyond <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="9d2ca8fb-2e60-4709-9745-53737dc6a8ad" class="relative scroll-mt-20"><button type="button" id="radix-_R_i9d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.293</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dhṛtarāṣṭra</div><ul class="ml-4 list-disc"><li class="italic">yul ’khor skyong</li><li class="pt-1"><span class="font-tibetan text-base">ཡུལ་འཁོར་སྐྱོང་།</span></li><li class="italic">dhṛtarāṣṭra</li></ul><div class="glossary-instance-definition"><p class="definition">One among the <span data-glossary-id="UT22084-068-021-8526">Four Great Kings</span>, guardian of the east.</p></div></div></div></div><div id="9b88d71e-8b13-4788-acb4-b0111033853a" class="relative scroll-mt-20"><button type="button" id="radix-_R_i9l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.294</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dhundhumāra</div><ul class="ml-4 list-disc"><li class="italic">dhu na dhu mA rA</li><li class="pt-1"><span class="font-tibetan text-base">དྷུ་ན་དྷུ་མཱ་རཱ།</span></li><li class="italic">dhundhumāra</li></ul><div class="glossary-instance-definition"><p class="definition">A river on <span data-glossary-id="UT22084-068-021-9657">Saṅkāśa</span>.</p></div></div></div></div><div id="9316372a-692f-4893-8d1a-01ba74b647dd" class="relative scroll-mt-20"><button type="button" id="radix-_R_i9t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.295</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Distinct Appearance, Peak of Distinct Appearance</div><ul class="ml-4 list-disc"><li class="italic">lhun po so sor snang ba</li><li class="pt-1"><span class="font-tibetan text-base">ལྷུན་པོ་སོ་སོར་སྣང་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A mountain in <span data-glossary-id="UT22084-068-021-9558">Passionate Conduct</span>.</p></div></div></div></div><div id="03dea05c-b690-4a21-9983-8bccfc985fa9" class="relative scroll-mt-20"><button type="button" id="radix-_R_ia55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.296</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Distinguished in Many Colorful Ways</div><ul class="ml-4 list-disc"><li class="italic">bkra ba sna tshogs kyis phye ba</li><li class="pt-1"><span class="font-tibetan text-base">བཀྲ་བ་སྣ་ཚོགས་ཀྱིས་ཕྱེ་བ།</span></li><li class="italic">nānā­bhakta­vicitrā</li></ul><div class="glossary-instance-definition"><p class="definition">A realm in the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="81691ac9-e2fc-40ff-952a-da75db7bfc9d" class="relative scroll-mt-20"><button type="button" id="radix-_R_iad5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.297</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Distractor</div><ul class="ml-4 list-disc"><li class="italic">g.yeng byed</li><li class="pt-1"><span class="font-tibetan text-base">གཡེང་བྱེད།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A “ruler of the world” who belongs to the class of the <span data-glossary-id="UT22084-068-021-8553">māras</span>.</p></div></div></div></div><div id="bf075ccc-2170-4332-8dec-2d4d7a54782c" class="relative scroll-mt-20"><button type="button" id="radix-_R_ial5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.298</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Diverse Movements</div><ul class="ml-4 list-disc"><li class="italic">rnam pa du mar ’gro ba</li><li class="pt-1"><span class="font-tibetan text-base">རྣམ་པ་དུ་མར་འགྲོ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest in <span data-glossary-id="UT22084-068-021-8956">Continuous Movement</span>.</p></div></div></div></div><div id="1c02219f-0261-48ab-86f3-3a500453c21f" class="relative scroll-mt-20"><button type="button" id="radix-_R_iat5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.299</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Diversity</div><ul class="ml-4 list-disc"><li class="italic">sna tshogs</li><li class="pt-1"><span class="font-tibetan text-base">སྣ་ཚོགས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">(1) A realm of the <span data-glossary-id="UT22084-068-021-8516">ever-infatuated gods</span>. (2) A river in <span data-glossary-id="UT22084-068-021-9035">Dwelling on Summits</span>.</p></div></div></div></div><div id="bfe4d6ca-3e0f-4dde-a8bb-7c5149937f8b" class="relative scroll-mt-20"><button type="button" id="radix-_R_ib55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.300</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">divine eye</div><ul class="ml-4 list-disc"><li class="italic">lha’i mig</li><li class="pt-1"><span class="font-tibetan text-base">ལྷའི་མིག</span></li><li class="italic">divyacakṣus</li></ul><div class="glossary-instance-definition"><p class="definition">Superknowledge achieved by the power of meditative absorption.</p></div></div></div></div><div id="5ad3d03f-0563-479b-b07b-1810c9a0a9cb" class="relative scroll-mt-20"><button type="button" id="radix-_R_ibd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.301</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Divine Trees</div><ul class="ml-4 list-disc"><li class="italic">lha shing gi nags</li><li class="pt-1"><span class="font-tibetan text-base">ལྷ་ཤིང་གི་ནགས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest on <span data-glossary-id="UT22084-068-021-9142">Forest Garlands</span>.</p></div></div></div></div><div id="12b408c6-c323-4da1-b5b2-76d8f03e4237" class="relative scroll-mt-20"><button type="button" id="radix-_R_ibl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.302</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">divisive talk</div><ul class="ml-4 list-disc"><li class="italic">phra ma</li><li class="pt-1"><span class="font-tibetan text-base">ཕྲ་མ།</span></li><li class="italic">piśuna</li></ul><div class="glossary-instance-definition"><p class="definition">The second among the four verbal misdeeds.</p></div></div></div></div><div id="ef2f902b-8e0a-45c3-8b06-186a50578824" class="relative scroll-mt-20"><button type="button" id="radix-_R_ibt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.303</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Double Pleasure</div><ul class="ml-4 list-disc"><li class="italic">gnyis shing rtse ba</li><li class="pt-1"><span class="font-tibetan text-base">གཉིས་ཤིང་རྩེ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">The city of the <span data-glossary-id="UT22084-068-021-8489">asura</span> king <span data-glossary-id="UT22084-068-021-8695">Kaṇṭhamāla</span>.</p></div></div></div></div><div id="333dd94e-4deb-44cf-b66d-575fd2f29637" class="relative scroll-mt-20"><button type="button" id="radix-_R_ic55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.304</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dramiḍa</div><ul class="ml-4 list-disc"><li class="italic">’gro lding ba</li><li class="pt-1"><span class="font-tibetan text-base">འགྲོ་ལྡིང་བ།</span></li><li class="italic">dramiḍa</li></ul><div class="glossary-instance-definition"><p class="definition">(1) A country of the Deccan region of India. (2) A kingdom in southern India.</p></div></div></div></div><div id="05597800-10f6-4624-90cb-eee701b48f54" class="relative scroll-mt-20"><button type="button" id="radix-_R_icd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.305</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Draped in Light Rays</div><ul class="ml-4 list-disc"><li class="italic">’od zer gyi phreng ba can</li><li class="pt-1"><span class="font-tibetan text-base">འོད་ཟེར་གྱི་ཕྲེང་བ་ཅན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A mountain in the eastern sea beyond <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="66dbd75c-9756-4df1-a25d-5b4fef45ac52" class="relative scroll-mt-20"><button type="button" id="radix-_R_icl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.306</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Draped with Jewels</div><ul class="ml-4 list-disc"><li class="italic">nor bu’i phyang</li><li class="pt-1"><span class="font-tibetan text-base">ནོར་བུའི་ཕྱང་།</span></li><li class="italic">maṇicīra</li></ul><div class="glossary-instance-definition"><p class="definition">A realm in the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="a0c12559-b260-4b1a-8faa-b90d190c641b" class="relative scroll-mt-20"><button type="button" id="radix-_R_ict5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.307</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dream Obstructor</div><ul class="ml-4 list-disc"><li class="italic">rmi lam mthong ba’i gegs</li><li class="pt-1"><span class="font-tibetan text-base">རྨི་ལམ་མཐོང་བའི་གེགས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-068-021-8581">rākṣasī</span> on <span data-glossary-id="UT22084-068-021-9740">Sumeru Rival</span>.</p></div></div></div></div><div id="d8aa688e-0104-434a-a98a-c1486994a534" class="relative scroll-mt-20"><button type="button" id="radix-_R_id55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.308</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dropping Dead Like Moths</div><ul class="ml-4 list-disc"><li class="italic">phye ma leb ltar rab tu lhung ba, phye ma leb ltar ’jug pa</li><li class="pt-1"><span class="font-tibetan text-base">ཕྱེ་མ་ལེབ་ལྟར་འཇུག་པ།, ཕྱེ་མ་ལེབ་ལྟར་རབ་ཏུ་ལྷུང་བ།</span></li><li class="italic">pataṅga­prapatana­sama</li></ul><div class="glossary-instance-definition"><p class="definition">One of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-9235">Great Howling Hell</span>.</p></div></div></div></div><div id="e7b71545-0cce-403f-8819-bc55b83d89c6" class="relative scroll-mt-20"><button type="button" id="radix-_R_idd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.309</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Drumbeat Melody</div><ul class="ml-4 list-disc"><li class="italic">rnga’i sgra’i dbyangs can</li><li class="pt-1"><span class="font-tibetan text-base">རྔའི་སྒྲའི་དབྱངས་ཅན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A river on <span data-glossary-id="UT22084-068-021-9657">Saṅkāśa</span>.</p></div></div></div></div><div id="75f0a3ee-dec1-48dd-b429-ab5fcc083403" class="relative scroll-mt-20"><button type="button" id="radix-_R_idl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.310</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Drumbeats</div><ul class="ml-4 list-disc"><li class="italic">rnga sgra ’byin pa’i sgra</li><li class="pt-1"><span class="font-tibetan text-base">རྔ་སྒྲ་འབྱིན་པའི་སྒྲ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest on <span data-glossary-id="UT22084-068-021-9046">Encircled by White Clouds</span>.</p></div></div></div></div><div id="eeaa174d-4de6-494e-a157-b567dec42a6b" class="relative scroll-mt-20"><button type="button" id="radix-_R_idt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.311</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Drunk on Winter Wine</div><ul class="ml-4 list-disc"><li class="italic">rgun chang myos gnas</li><li class="pt-1"><span class="font-tibetan text-base">རྒུན་ཆང་མྱོས་གནས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A realm of the <span data-glossary-id="UT22084-068-021-8516">ever-infatuated gods</span>.</p></div></div></div></div><div id="524eea57-6fa4-45a8-8c19-ca9a692bee3c" class="relative scroll-mt-20"><button type="button" id="radix-_R_ie55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.312</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Duck Lake</div><ul class="ml-4 list-disc"><li class="italic">kA dam+ba’i chu</li><li class="pt-1"><span class="font-tibetan text-base">ཀཱ་དམྦའི་ཆུ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A pond on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span>.</p></div></div></div></div><div id="1265a3a9-993c-4b29-9d13-a6ae90948de5" class="relative scroll-mt-20"><button type="button" id="radix-_R_ied5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.313</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Duck Stream</div><ul class="ml-4 list-disc"><li class="italic">kA raN+Da ba’i klung</li><li class="pt-1"><span class="font-tibetan text-base">ཀཱ་རཎྜ་བའི་ཀླུང་།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lake on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span>.</p></div></div></div></div><div id="eebdb963-eb27-4bd9-bcf8-8973a0b30af4" class="relative scroll-mt-20"><button type="button" id="radix-_R_iel5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.314</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dwelling by the Pārijāta Tree</div><ul class="ml-4 list-disc"><li class="italic">yongs ’du na gnas pa</li><li class="pt-1"><span class="font-tibetan text-base">ཡོངས་འདུ་ན་གནས་པ།</span></li><li class="italic">pāriyātraka­nivāsinī</li></ul><div class="glossary-instance-definition"><p class="definition">A realm in the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="8048c150-f0bb-4626-91b6-825937b45dde" class="relative scroll-mt-20"><button type="button" id="radix-_R_iet5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.315</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dwelling in Beauty</div><ul class="ml-4 list-disc"><li class="italic">rnam mdzes na gnas pa</li><li class="pt-1"><span class="font-tibetan text-base">རྣམ་མཛེས་ན་གནས་པ།</span></li><li class="italic">vaibhrāja­nivāsinī</li></ul><div class="glossary-instance-definition"><p class="definition">A realm in the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="be8006e6-989e-4fa3-8fad-872b75d0b1eb" class="relative scroll-mt-20"><button type="button" id="radix-_R_if55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.316</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dwelling in Enjoyment</div><ul class="ml-4 list-disc"><li class="italic">dga’ byed gnas pa</li><li class="pt-1"><span class="font-tibetan text-base">དགའ་བྱེད་གནས་པ།</span></li><li class="italic">nandana­nivāsinī</li></ul><div class="glossary-instance-definition"><p class="definition">A realm in the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="4ff6e90f-5391-4012-9fa7-280bef91a94b" class="relative scroll-mt-20"><button type="button" id="radix-_R_ifd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.317</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dwelling in Essence of Jewels</div><ul class="ml-4 list-disc"><li class="italic">nor bu’i snying po na gnas pa</li><li class="pt-1"><span class="font-tibetan text-base">ནོར་བུའི་སྙིང་པོ་ན་གནས་པ།</span></li><li class="italic">maṇi­garbhā­nivāsinī</li></ul><div class="glossary-instance-definition"><p class="definition">A realm in the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="ef82de1b-b3c9-4169-ae2d-5374649458e5" class="relative scroll-mt-20"><button type="button" id="radix-_R_ifl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.318</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dwelling in Excellent View</div><ul class="ml-4 list-disc"><li class="italic">legs mthong na gnas pa</li><li class="pt-1"><span class="font-tibetan text-base">ལེགས་མཐོང་ན་གནས་པ།</span></li><li class="italic">sudarśana­nivāsinī</li></ul><div class="glossary-instance-definition"><p class="definition">A realm in the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="bb226429-f10a-407e-b02d-845a7fb97b35" class="relative scroll-mt-20"><button type="button" id="radix-_R_ift5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.319</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dwelling in Forests</div><ul class="ml-4 list-disc"><li class="italic">shing gseb na gnas pa</li><li class="pt-1"><span class="font-tibetan text-base">ཤིང་གསེབ་ན་གནས་པ།</span></li><li class="italic">koṭaranivāsinī</li></ul><div class="glossary-instance-definition"><p class="definition">A realm in the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="ef5188f4-bd42-4688-bb8d-48d57c4479a1" class="relative scroll-mt-20"><button type="button" id="radix-_R_ig55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.320</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dwelling in One Direction</div><ul class="ml-4 list-disc"><li class="italic">phyogs gcig na gnas pa</li><li class="pt-1"><span class="font-tibetan text-base">ཕྱོགས་གཅིག་ན་གནས་པ།</span></li><li class="italic">prastha­nivāsinī</li></ul><div class="glossary-instance-definition"><p class="definition">A realm in the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="2f6c2e8e-308c-428c-8e0c-bdf9a5a6b99c" class="relative scroll-mt-20"><button type="button" id="radix-_R_igd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.321</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dwelling in Sudharma</div><ul class="ml-4 list-disc"><li class="italic">chos bzang na gnas pa</li><li class="pt-1"><span class="font-tibetan text-base">ཆོས་བཟང་ན་གནས་པ།</span></li><li class="italic">sudharma­nivāsinī</li></ul><div class="glossary-instance-definition"><p class="definition">A realm in the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="1f87c0a2-5d9d-4264-a15d-ed08f1de9cf8" class="relative scroll-mt-20"><button type="button" id="radix-_R_igl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.322</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dwelling in the Environment</div><ul class="ml-4 list-disc"><li class="italic">’khor yug la gnas pa</li><li class="pt-1"><span class="font-tibetan text-base">འཁོར་ཡུག་ལ་གནས་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">One of the twenty-seven realms in the <span data-glossary-id="UT22084-068-021-9266">Heaven Free from Strife</span>.</p></div></div></div></div><div id="55803cee-e48c-48c9-aa91-9dc92603f2d0" class="relative scroll-mt-20"><button type="button" id="radix-_R_igt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.323</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dwelling in the Lofty</div><ul class="ml-4 list-disc"><li class="italic">mtho ba na gnas pa</li><li class="pt-1"><span class="font-tibetan text-base">མཐོ་བ་ན་གནས་པ།</span></li><li class="italic">tuṅganivāsinī</li></ul><div class="glossary-instance-definition"><p class="definition">A realm in the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="c97ddbd3-7d1d-492c-9bcb-7ceba0748972" class="relative scroll-mt-20"><button type="button" id="radix-_R_ih55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.324</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dwelling in Various Chariots</div><ul class="ml-4 list-disc"><li class="italic">shing rta sna tshogs na gnas pa</li><li class="pt-1"><span class="font-tibetan text-base">ཤིང་རྟ་སྣ་ཚོགས་ན་གནས་པ།</span></li><li class="italic">caitra­ratha­nivāsinī</li></ul><div class="glossary-instance-definition"><p class="definition">A realm in the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="c8215d18-8ea0-40fa-8f6d-0a1a45487bd8" class="relative scroll-mt-20"><button type="button" id="radix-_R_ihd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.325</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dwelling on Forest Riverbanks</div><ul class="ml-4 list-disc"><li class="italic">tshang tshing gi ’gram na gnas pa</li><li class="pt-1"><span class="font-tibetan text-base">ཚང་ཚིང་གི་འགྲམ་ན་གནས་པ།</span></li><li class="italic">kuñjara­taṭa­nivāsinī</li></ul><div class="glossary-instance-definition"><p class="definition">A realm in the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="b95b3b24-72a3-4e4f-b171-95006ba745ff" class="relative scroll-mt-20"><button type="button" id="radix-_R_ihl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.326</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dwelling on Mixed Riverbanks</div><ul class="ml-4 list-disc"><li class="italic">’dres pa’i ’gram na gnas pa</li><li class="pt-1"><span class="font-tibetan text-base">འདྲེས་པའི་འགྲམ་ན་གནས་པ།</span></li><li class="italic">āmiśra­taṭa­nivāsinī</li></ul><div class="glossary-instance-definition"><p class="definition">A realm in the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="b6a25e7e-d3a2-40eb-b939-91a5f60fbfc4" class="relative scroll-mt-20"><button type="button" id="radix-_R_iht5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.327</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dwelling on Summits</div><ul class="ml-4 list-disc"><li class="italic">ri rtse na gnas pa</li><li class="pt-1"><span class="font-tibetan text-base">རི་རྩེ་ན་གནས་པ།</span></li><li class="italic">śikhara­nivāsinī</li></ul><div class="glossary-instance-definition"><p class="definition">A realm in the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="9c1c6d56-d5e2-471f-9bdc-2cbc9da08c3c" class="relative scroll-mt-20"><button type="button" id="radix-_R_ii55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.328</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dwelling on the Disk</div><ul class="ml-4 list-disc"><li class="italic">’khor na gnas pa</li><li class="pt-1"><span class="font-tibetan text-base">འཁོར་ན་གནས་པ།</span></li><li class="italic">maṇḍala­nivāsinī</li></ul><div class="glossary-instance-definition"><p class="definition">A realm in the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="226454d3-3f0b-44f1-80c3-1ac587e82d86" class="relative scroll-mt-20"><button type="button" id="radix-_R_iid5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.329</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Easy Flow</div><ul class="ml-4 list-disc"><li class="italic">’bab bde</li><li class="pt-1"><span class="font-tibetan text-base">འབབ་བདེ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lotus pool in <span data-glossary-id="UT22084-068-021-9403">Lateral</span>.</p></div></div></div></div><div id="39240765-3433-439a-8996-546a548e1dbb" class="relative scroll-mt-20"><button type="button" id="radix-_R_iil5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.330</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Eaten by Iron Jackals</div><ul class="ml-4 list-disc"><li class="italic">lcags dang ce spyang za, lcags kyi ce spyang gi zas</li><li class="pt-1"><span class="font-tibetan text-base">ལྕགས་ཀྱི་ཅེ་སྤྱང་གི་ཟས།, ལྕགས་དང་ཅེ་སྤྱང་ཟ།</span></li><li class="italic">ayaḥśivāhāra</li></ul><div class="glossary-instance-definition"><p class="definition">One of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-9279">Hell of Ultimate Torment</span>.</p></div></div></div></div><div id="4c333a96-4081-46df-a8f8-e0d50a5daa07" class="relative scroll-mt-20"><button type="button" id="radix-_R_iit5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.331</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">eaters</div><ul class="ml-4 list-disc"><li class="italic">za ba po</li><li class="pt-1"><span class="font-tibetan text-base">ཟ་བ་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A class of <span data-glossary-id="UT22084-068-021-8489">asuras</span>.</p></div></div></div></div><div id="cbc7fa66-921d-48f4-82a9-e65f01e472e7" class="relative scroll-mt-20"><button type="button" id="radix-_R_ij55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.332</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Egg-Born Infatuation</div><ul class="ml-4 list-disc"><li class="italic">myos pa sgo nga las skyes pa</li><li class="pt-1"><span class="font-tibetan text-base">མྱོས་པ་སྒོ་ང་ལས་སྐྱེས་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest on <span data-glossary-id="UT22084-068-021-9771">Tamer of Deer Enemies</span>.</p></div></div></div></div><div id="db9e6de6-2f04-48a1-aba6-52d196525b4e" class="relative scroll-mt-20"><button type="button" id="radix-_R_ijd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.333</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">eight branches of the noble path, eightfold path, eightfold path of the noble ones</div><ul class="ml-4 list-disc"><li class="italic">’phags pa’i lam yan lag brgyad</li><li class="pt-1"><span class="font-tibetan text-base">འཕགས་པའི་ལམ་ཡན་ལག་བརྒྱད།</span></li><li class="italic">āryāṣṭāṅga­mārga</li></ul><div class="glossary-instance-definition"><p class="definition">Eight factors constituting the path of cultivation, namely: right view, right intention, right speech, right activity, right livelihood, right effort, right mindfulness, and right absorption.. These are further explained in this text, see <a href="UT22084-068-021-section-6.xhtml#UT22084-068-021-4043" data-pointer-type="id">4.B.1101</a>–<a href="UT22084-068-021-section-6.xhtml#UT22084-068-021-4044" data-pointer-type="id">4.B.1102</a>.</p></div></div></div></div><div id="e15669a4-c64d-4734-a4df-5f50fe1f2f2e" class="relative scroll-mt-20"><button type="button" id="radix-_R_ijl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.334</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">eight mundane concerns</div><ul class="ml-4 list-disc"><li class="italic">’jig rten gyi chos brgyad</li><li class="pt-1"><span class="font-tibetan text-base">འཇིག་རྟེན་གྱི་ཆོས་བརྒྱད།</span></li><li class="italic">aṣṭa­loka­dharma</li></ul><div class="glossary-instance-definition"><p class="definition">Hoping for happiness, fame, praise and gain and fearing suffering, insignificance, blame and loss.</p></div></div></div></div><div id="898be4c2-0729-4590-8d9e-5040e2552a46" class="relative scroll-mt-20"><button type="button" id="radix-_R_ijt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.335</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">eighteen categories of discernment, eighteen discernments, eighteen forms of discernment, eighteen types of discernment</div><ul class="ml-4 list-disc"><li class="italic">yid kyi dpyod pa bco brgyad</li><li class="pt-1"><span class="font-tibetan text-base">ཡིད་ཀྱི་དཔྱོད་པ་བཅོ་བརྒྱད།</span></li></ul><div class="glossary-instance-definition"><p class="definition">See <a href="UT22084-068-021-chapter-2.xhtml#UT22084-068-021-206" data-pointer-type="id">2.4</a>.</p></div></div></div></div><div id="979a8df9-464d-4d79-9bda-299dc188c053" class="relative scroll-mt-20"><button type="button" id="radix-_R_ik55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.336</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">eighteen elements</div><ul class="ml-4 list-disc"><li class="italic">khams bco brgyad</li><li class="pt-1"><span class="font-tibetan text-base">ཁམས་བཅོ་བརྒྱད།</span></li><li class="italic">aṣṭā­daśa­dhātu</li></ul><div class="glossary-instance-definition"><p class="definition">The objects, sense <span data-glossary-id="UT22084-068-021-9924">faculties</span>, and forms of consciousness that are associated with form, sound, smell, taste, touch, and mental phenomena. See also “<span data-glossary-id="UT22084-068-021-9921">element</span>.”</p></div></div></div></div><div id="87b038b7-dc28-4897-bc8e-03a757675733" class="relative scroll-mt-20"><button type="button" id="radix-_R_ikd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.337</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">eighteen floods of unique qualities</div><ul class="ml-4 list-disc"><li class="italic">yon tan gyi klung rang gi yon tan bco brgyad</li><li class="pt-1"><span class="font-tibetan text-base">ཡོན་ཏན་གྱི་ཀླུང་རང་གི་ཡོན་ཏན་བཅོ་བརྒྱད།</span></li></ul><div class="glossary-instance-definition"><p class="definition">Eighteen special features of a buddha’s behavior, realization, activity, and wisdom that are not shared by other beings.</p></div></div></div></div><div id="b00d6211-3c02-40c0-bd29-4805807c4d34" class="relative scroll-mt-20"><button type="button" id="radix-_R_ikl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.338</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">elaborate teachings</div><ul class="ml-4 list-disc"><li class="italic">shin tu rgyas pa’i sde</li><li class="pt-1"><span class="font-tibetan text-base">ཤིན་ཏུ་རྒྱས་པའི་སྡེ།</span></li><li class="italic">vaipulya</li></ul><div class="glossary-instance-definition"><p class="definition">One among the twelve sections of scripture.</p></div></div></div></div><div id="1364ded3-bd82-4c3b-8f35-1ded727bca81" class="relative scroll-mt-20"><button type="button" id="radix-_R_ikt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.339</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">element</div><ul class="ml-4 list-disc"><li class="italic">khams</li><li class="pt-1"><span class="font-tibetan text-base">ཁམས།</span></li><li class="italic">dhātu</li></ul><div class="glossary-instance-definition"><p class="definition">In the context of Buddhist philosophy, one way to describe experience and the world is in terms of <span class="ignore">eighteen elements</span> (eye, form, and eye consciousness; ear, sound, and ear consciousness; nose, smell, and nose consciousness; tongue, taste, and tongue consciousness; body, touch, and body consciousness; mind, mental phenomena, and mind consciousness).</p><p class="definition">The <span class="ignore">elements</span> also refer to the <span class="ignore">elements</span> of the physical world, which are the four main <span class="ignore">elements</span>: earth, water, fire, and <span data-glossary-id="UT22084-068-021-100021">wind</span>. Sometimes two extra <span class="ignore">elements</span> are added to this list: space and consciousness.</p></div></div></div></div><div id="66f34608-5e08-44d3-9e82-ba8371c66ed0" class="relative scroll-mt-20"><button type="button" id="radix-_R_il55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.340</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">elephant chariot</div><ul class="ml-4 list-disc"><li class="italic">glang po’i shing rta</li><li class="pt-1"><span class="font-tibetan text-base">གླང་པོའི་ཤིང་རྟ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A class of <span data-glossary-id="UT22084-068-021-8622">vidyādharas</span>.</p></div></div></div></div><div id="c8d2d850-bb9c-459b-ba93-07b9084bc015" class="relative scroll-mt-20"><button type="button" id="radix-_R_ild5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.341</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Elevated Sounds</div><ul class="ml-4 list-disc"><li class="italic">sgra ’phang mthon po</li><li class="pt-1"><span class="font-tibetan text-base">སྒྲ་འཕང་མཐོན་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest on <span data-glossary-id="UT22084-068-021-9128">Flocking Peacocks</span>.</p></div></div></div></div><div id="347b557f-1661-4647-bd04-75e0e1980c51" class="relative scroll-mt-20"><button type="button" id="radix-_R_ill5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.342</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Eleven Flames</div><ul class="ml-4 list-disc"><li class="italic">me lce bcu gcig</li><li class="pt-1"><span class="font-tibetan text-base">མེ་ལྕེ་བཅུ་གཅིག</span></li><li class="italic">ekādaśārcis</li></ul><div class="glossary-instance-definition"><p class="definition">One of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-9235">Great Howling Hell</span>.</p></div></div></div></div><div id="54af20b7-0e14-4541-9262-a1271d95c47f" class="relative scroll-mt-20"><button type="button" id="radix-_R_ilt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.343</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Eliminating Ailing Deer</div><ul class="ml-4 list-disc"><li class="italic">sha ba na ’chang ba</li><li class="pt-1"><span class="font-tibetan text-base">ཤ་བ་ན་འཆང་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A land in the east of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="01375a25-c07a-4d07-9428-bf1a1960c1fa" class="relative scroll-mt-20"><button type="button" id="radix-_R_im55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.344</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Emanated Śakra</div><ul class="ml-4 list-disc"><li class="italic">sprul pa’i brgya byin</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲུལ་པའི་བརྒྱ་བྱིན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A previous ruler of the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="521b40c6-eaa8-4a8a-9eee-de3be23a0655" class="relative scroll-mt-20"><button type="button" id="radix-_R_imd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.345</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Emanation of a Hundred Light Rays</div><ul class="ml-4 list-disc"><li class="italic">’od zer brgya ’phro ba can</li><li class="pt-1"><span class="font-tibetan text-base">འོད་ཟེར་བརྒྱ་འཕྲོ་བ་ཅན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">One of the twenty-seven realms of the <span data-glossary-id="UT22084-068-021-9266">Heaven Free from Strife</span>.</p></div></div></div></div><div id="49b25771-246d-415a-809f-5a11b2faed09" class="relative scroll-mt-20"><button type="button" id="radix-_R_iml5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.346</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Emanation of Light Rays</div><ul class="ml-4 list-disc"><li class="italic">’od zer ’phro ba</li><li class="pt-1"><span class="font-tibetan text-base">འོད་ཟེར་འཕྲོ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A realm in the <span data-glossary-id="UT22084-068-021-9266">Heaven Free from Strife</span>.</p></div></div></div></div><div id="a8ff7da0-f8b4-4236-8c36-82874d6348b6" class="relative scroll-mt-20"><button type="button" id="radix-_R_imt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.347</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Embers Within</div><ul class="ml-4 list-disc"><li class="italic">nang na me mdag yod pa</li><li class="pt-1"><span class="font-tibetan text-base">ནང་ན་མེ་མདག་ཡོད་པ།</span></li><li class="italic">antargataparpura</li></ul><div class="glossary-instance-definition"><p class="definition">A realm that neighbors the <span data-glossary-id="UT22084-068-021-9278">Hell of Intense Heat</span>.</p></div></div></div></div><div id="9b100e90-0680-4bab-972f-4eee7b77b0a7" class="relative scroll-mt-20"><button type="button" id="radix-_R_in55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.348</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Emerging at the Summit of the Shadows</div><ul class="ml-4 list-disc"><li class="italic">grib ma’i rtse la ’byung ba</li><li class="pt-1"><span class="font-tibetan text-base">གྲིབ་མའི་རྩེ་ལ་འབྱུང་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-068-021-8581">rākṣasī</span> who lives in <span data-glossary-id="UT22084-068-021-8850">Black Waters</span></p></div></div></div></div><div id="05f17878-88a2-4d07-97f3-14d448b06d12" class="relative scroll-mt-20"><button type="button" id="radix-_R_ind5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.349</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Encircled by a Thousand Houses</div><ul class="ml-4 list-disc"><li class="italic">mtha’ yang gang khang bu stong yod pa</li><li class="pt-1"><span class="font-tibetan text-base">མཐའ་ཡང་གང་ཁང་བུ་སྟོང་ཡོད་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A summit in <span data-glossary-id="UT22084-068-021-9544">Ornament of the Mind</span>.</p></div></div></div></div><div id="d675c5ab-7627-4470-8c43-060072c0206a" class="relative scroll-mt-20"><button type="button" id="radix-_R_inl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.350</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Encircled by Crystal</div><ul class="ml-4 list-disc"><li class="italic">shel ’khor bar byed pa</li><li class="pt-1"><span class="font-tibetan text-base">ཤེལ་འཁོར་བར་བྱེད་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lake on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span>.</p></div></div></div></div><div id="67a0b8b1-d3cd-4170-8591-e37f9b434a06" class="relative scroll-mt-20"><button type="button" id="radix-_R_int5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.351</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Encircled by White Clouds</div><ul class="ml-4 list-disc"><li class="italic">sprin dkar po rgyu ba</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་དཀར་པོ་རྒྱུ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A mountain in <span data-glossary-id="UT22084-068-021-9398">Kuru</span>, the same as <span data-glossary-id="UT22084-068-021-9871">White Cloud Keeper</span>.</p></div></div></div></div><div id="46258693-e31d-49e8-b7ae-5e21b196e965" class="relative scroll-mt-20"><button type="button" id="radix-_R_io55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.352</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Encircling Pool</div><ul class="ml-4 list-disc"><li class="italic">kun nas rdzing kun du bskor ba</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་ནས་རྫིང་ཀུན་དུ་བསྐོར་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A pool in <span data-glossary-id="UT22084-068-021-9668">Shaded by Garlands</span>.</p></div></div></div></div><div id="b80191a7-2aaf-4fe9-85d6-f9a16d57f2b9" class="relative scroll-mt-20"><button type="button" id="radix-_R_iod5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.353</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Endless Agony</div><ul class="ml-4 list-disc"><li class="italic">tshor ba mtha’ med</li><li class="pt-1"><span class="font-tibetan text-base">ཚོར་བ་མཐའ་མེད།</span></li><li class="italic">apāravedana</li></ul><div class="glossary-instance-definition"><p class="definition">One of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-8975">Crushing Hell</span>.</p></div></div></div></div><div id="f3ab7f26-02dd-4289-80e4-ef8b74129b8e" class="relative scroll-mt-20"><button type="button" id="radix-_R_iol5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.354</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Endowed with Cool Water</div><ul class="ml-4 list-disc"><li class="italic">chu bsil ba dang ldan pa</li><li class="pt-1"><span class="font-tibetan text-base">ཆུ་བསིལ་བ་དང་ལྡན་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lotus lake on <span data-glossary-id="UT22084-068-021-9058">Endowed with Lotuses</span>.</p></div></div></div></div><div id="2c383d20-7425-4b4b-9836-bf9a3762ef31" class="relative scroll-mt-20"><button type="button" id="radix-_R_iot5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.355</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Endowed with Cows</div><ul class="ml-4 list-disc"><li class="italic">ba lang can</li><li class="pt-1"><span class="font-tibetan text-base">བ་ལང་ཅན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A river in <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="6a1b882d-f19c-417a-8a0b-062144901e1c" class="relative scroll-mt-20"><button type="button" id="radix-_R_ip55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.356</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Endowed with Crown Ornaments</div><ul class="ml-4 list-disc"><li class="italic">dbu rgyan ’dzin</li><li class="pt-1"><span class="font-tibetan text-base">དབུ་རྒྱན་འཛིན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">An area in <span data-glossary-id="UT22084-068-021-9398">Kuru</span>.</p></div></div></div></div><div id="1ec0ed19-5bd6-4b6b-a2e1-3f8717d5381f" class="relative scroll-mt-20"><button type="button" id="radix-_R_ipd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.357</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Endowed with Elements</div><ul class="ml-4 list-disc"><li class="italic">khams dang ldan pa</li><li class="pt-1"><span class="font-tibetan text-base">ཁམས་དང་ལྡན་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">An island beyond <span data-glossary-id="UT22084-068-021-9847">Videha</span>.</p></div></div></div></div><div id="8ff02e40-e7f3-43b9-bcb3-bd7b8ba81cef" class="relative scroll-mt-20"><button type="button" id="radix-_R_ipl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.358</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Endowed with Enjoyments</div><ul class="ml-4 list-disc"><li class="italic">longs spyod ldan</li><li class="pt-1"><span class="font-tibetan text-base">ལོངས་སྤྱོད་ལྡན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-068-021-8562">nāga</span> realm.</p></div></div></div></div><div id="1700dc37-bfe2-449f-8c21-fc59d31a8605" class="relative scroll-mt-20"><button type="button" id="radix-_R_ipt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.359</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Endowed with Everything</div><ul class="ml-4 list-disc"><li class="italic">thams cad mngon par ’byor ba</li><li class="pt-1"><span class="font-tibetan text-base">ཐམས་ཅད་མངོན་པར་འབྱོར་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">The pleasure garden where <span data-glossary-id="UT22084-068-021-8738">Śakra</span>’s elephant roams.</p></div></div></div></div><div id="009f522b-832d-4ecf-ab54-2901ce0bd6d6" class="relative scroll-mt-20"><button type="button" id="radix-_R_iq55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.360</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Endowed with Glory</div><ul class="ml-4 list-disc"><li class="italic">dpal ’dzin</li><li class="pt-1"><span class="font-tibetan text-base">དཔལ་འཛིན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A previous ruler of the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="083ea253-5a1d-4ea8-9793-474a4fe99a1f" class="relative scroll-mt-20"><button type="button" id="radix-_R_iqd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.361</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Endowed with Gold</div><ul class="ml-4 list-disc"><li class="italic">gser dang ldan pa</li><li class="pt-1"><span class="font-tibetan text-base">གསེར་དང་ལྡན་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest on <span data-glossary-id="UT22084-068-021-9771">Tamer of Deer Enemies</span>.</p></div></div></div></div><div id="889c5c3b-2f2b-4adf-a0b1-ab00971b53ab" class="relative scroll-mt-20"><button type="button" id="radix-_R_iql5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.362</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Endowed with Increasing Bliss</div><ul class="ml-4 list-disc"><li class="italic">bde ba rab tu ’phel ba</li><li class="pt-1"><span class="font-tibetan text-base">བདེ་བ་རབ་ཏུ་འཕེལ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">One of the twenty-seven realms of the <span data-glossary-id="UT22084-068-021-9266">Heaven Free from Strife</span>.</p></div></div></div></div><div id="338d8810-ebe3-4939-9421-f75a5b47ca60" class="relative scroll-mt-20"><button type="button" id="radix-_R_iqt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.363</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Endowed with Jewels</div><ul class="ml-4 list-disc"><li class="italic">rin po che dang ldan pa</li><li class="pt-1"><span class="font-tibetan text-base">རིན་པོ་ཆེ་དང་ལྡན་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A mountain in the eastern sea beyond <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="69c8173c-0adc-4fea-9d83-b50594b63998" class="relative scroll-mt-20"><button type="button" id="radix-_R_ir55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.364</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Endowed with Lotuses</div><ul class="ml-4 list-disc"><li class="italic">pad ma ku she sha ya dang ldan pa</li><li class="pt-1"><span class="font-tibetan text-base">པད་མ་ཀུ་ཤེ་ཤ་ཡ་དང་ལྡན་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A mountain in <span data-glossary-id="UT22084-068-021-9398">Kuru</span>.</p></div></div></div></div><div id="2ec11430-7d7f-45d7-b533-01707d885616" class="relative scroll-mt-20"><button type="button" id="radix-_R_ird5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.365</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Endowed with Migration</div><ul class="ml-4 list-disc"><li class="italic">’gro ba dang yang dag par ldan pa</li><li class="pt-1"><span class="font-tibetan text-base">འགྲོ་བ་དང་ཡང་དག་པར་ལྡན་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">One of the twenty-seven realms in the <span data-glossary-id="UT22084-068-021-9266">Heaven Free from Strife</span>.</p></div></div></div></div><div id="2604e03a-4382-493a-b079-cef414499fa7" class="relative scroll-mt-20"><button type="button" id="radix-_R_irl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.366</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Endowed with Result</div><ul class="ml-4 list-disc"><li class="italic">’bras bu dang ldan pa</li><li class="pt-1"><span class="font-tibetan text-base">འབྲས་བུ་དང་ལྡན་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">One of the twenty-seven realms in the <span data-glossary-id="UT22084-068-021-9266">Heaven Free from Strife</span>.</p></div></div></div></div><div id="58b7473c-b7da-4240-a96d-3569102df6b4" class="relative scroll-mt-20"><button type="button" id="radix-_R_irt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.367</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Endowed with Riverbanks</div><ul class="ml-4 list-disc"><li class="italic">gram can</li><li class="pt-1"><span class="font-tibetan text-base">གྲམ་ཅན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A land in the east of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="dbbf87ba-f510-4ec1-95a5-4b52cc6f49c7" class="relative scroll-mt-20"><button type="button" id="radix-_R_is55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.368</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Endowed with Rivers</div><ul class="ml-4 list-disc"><li class="italic">chu ldan</li><li class="pt-1"><span class="font-tibetan text-base">ཆུ་ལྡན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A land in the south of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="4c293552-dce9-40d7-bd62-cf4cc0e8328a" class="relative scroll-mt-20"><button type="button" id="radix-_R_isd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.369</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Endowed with the Songs of Cuckoo Birds</div><ul class="ml-4 list-disc"><li class="italic">khu byug gis gang ba’i sgra dbyangs dang ldan pa</li><li class="pt-1"><span class="font-tibetan text-base">ཁུ་བྱུག་གིས་གང་བའི་སྒྲ་དབྱངས་དང་ལྡན་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A mountain to the north of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="71893079-aa6f-4835-a83e-3631026bde3c" class="relative scroll-mt-20"><button type="button" id="radix-_R_isl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.370</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Endowment</div><ul class="ml-4 list-disc"><li class="italic">’byor ba</li><li class="pt-1"><span class="font-tibetan text-base">འབྱོར་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A previous ruler of the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>. </p></div></div></div></div><div id="ccf07197-5317-4f5d-9c73-6d4a1e513f1c" class="relative scroll-mt-20"><button type="button" id="radix-_R_ist5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.371</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Engaged Conduct</div><ul class="ml-4 list-disc"><li class="italic">’jug pa’i spyod pa</li><li class="pt-1"><span class="font-tibetan text-base">འཇུག་པའི་སྤྱོད་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">One of the twenty-seven realms in the <span data-glossary-id="UT22084-068-021-9266">Heaven Free from Strife</span>.</p></div></div></div></div><div id="6fc7d7c3-b48d-43bc-9c87-fa2db5d89229" class="relative scroll-mt-20"><button type="button" id="radix-_R_it55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.372</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Engagement with a Retinue</div><ul class="ml-4 list-disc"><li class="italic">’khor dang spyod pa</li><li class="pt-1"><span class="font-tibetan text-base">འཁོར་དང་སྤྱོད་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">Alternative name for the realm of <span><span data-glossary-id="UT22084-068-021-9629">Retinue</span></span>.</p></div></div></div></div><div id="eef9f280-f980-4978-a07e-1aada88ba5d1" class="relative scroll-mt-20"><button type="button" id="radix-_R_itd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.373</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Engaging in Clarification</div><ul class="ml-4 list-disc"><li class="italic">kun du gsal bar spyod pa</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་དུ་གསལ་བར་སྤྱོད་པ།</span></li><li class="italic">āvartacarā</li></ul><div class="glossary-instance-definition"><p class="definition">A realm in the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="f6f4b3a9-d519-4768-99ad-de18f60b2a34" class="relative scroll-mt-20"><button type="button" id="radix-_R_itl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.374</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Enjoyed by Friends</div><ul class="ml-4 list-disc"><li class="italic">grogs po’i longs spyod</li><li class="pt-1"><span class="font-tibetan text-base">གྲོགས་པོའི་ལོངས་སྤྱོད།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A land to the west of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="6d09852c-c596-49bb-9aa6-00971b7e46b9" class="relative scroll-mt-20"><button type="button" id="radix-_R_itt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.375</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Enjoyer of All</div><ul class="ml-4 list-disc"><li class="italic">thams cad dga’</li><li class="pt-1"><span class="font-tibetan text-base">ཐམས་ཅད་དགའ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A previous ruler of the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="a14b073f-8b21-4a9b-81b6-3242b5b05f5e" class="relative scroll-mt-20"><button type="button" id="radix-_R_iu55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.376</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Enjoying the Wind</div><ul class="ml-4 list-disc"><li class="italic">rlung la spyod pa</li><li class="pt-1"><span class="font-tibetan text-base">རླུང་ལ་སྤྱོད་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A realm of the <span data-glossary-id="UT22084-068-021-8621">vessel-bearer gods</span>. Also known as <span data-glossary-id="UT22084-068-021-9501">Movement of Wind</span>.</p></div></div></div></div><div id="536c19f0-6be6-4cae-86e6-e4895aaf1fb7" class="relative scroll-mt-20"><button type="button" id="radix-_R_iud5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.377</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Enjoying White Lotuses</div><ul class="ml-4 list-disc"><li class="italic">pad ma dkar spyod pa</li><li class="pt-1"><span class="font-tibetan text-base">པད་མ་དཀར་སྤྱོད་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A realm of the <span data-glossary-id="UT22084-068-021-8516">ever-infatuated gods</span>.</p></div></div></div></div><div id="b8ffa44b-cf68-47a6-906f-eccf96056a06" class="relative scroll-mt-20"><button type="button" id="radix-_R_iul5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.378</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Enjoyment</div><ul class="ml-4 list-disc"><li class="italic">dga’ ba, longs spyod du gyur ba</li><li class="pt-1"><span class="font-tibetan text-base">དགའ་བ།, ལོངས་སྤྱོད་དུ་གྱུར་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">(1) A lake on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span> (<em class="foreign text-wy" lang="bo-LATN">longs spyod du gyur ba</em>). (2) Refers to <span data-glossary-id="UT22084-068-021-9024">Dwelling in Enjoyment</span> (<em class="foreign text-wy" lang="bo-LATN">dga’ ba</em>).</p></div></div></div></div><div id="54b7a0fd-9ad0-4141-9c08-7b5811cbc181" class="relative scroll-mt-20"><button type="button" id="radix-_R_iut5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.379</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Enjoyment of Drinks</div><ul class="ml-4 list-disc"><li class="italic">btung ba dga’ ba</li><li class="pt-1"><span class="font-tibetan text-base">བཏུང་བ་དགའ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest in <span data-glossary-id="UT22084-068-021-8956">Continuous Movement</span>.</p></div></div></div></div><div id="f3c5b49c-e34b-4d41-8f26-f5ebaafa5f76" class="relative scroll-mt-20"><button type="button" id="radix-_R_iv55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.380</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Enjoyment of Scents</div><ul class="ml-4 list-disc"><li class="italic">dri dga’</li><li class="pt-1"><span class="font-tibetan text-base">དྲི་དགའ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A realm of the <span data-glossary-id="UT22084-068-021-8617">triple-lute-bearer gods</span>.</p></div></div></div></div><div id="620aab64-1b34-4a03-a0ed-631cb9d64bff" class="relative scroll-mt-20"><button type="button" id="radix-_R_ivd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.381</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Enjoyment of Wish-fulfilling Trees</div><ul class="ml-4 list-disc"><li class="italic">dpag bsam gyi shing la spyod pa</li><li class="pt-1"><span class="font-tibetan text-base">དཔག་བསམ་གྱི་ཤིང་ལ་སྤྱོད་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lake near <span data-glossary-id="UT22084-068-021-9734">Sudharma</span>.</p></div></div></div></div><div id="e53e5b13-3527-49f5-b941-3ea9e740f091" class="relative scroll-mt-20"><button type="button" id="radix-_R_ivl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.382</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Enraptured by and Attached to Song</div><ul class="ml-4 list-disc"><li class="italic">glu’i sgra la shin tu dga’ zhing mngon par chags pa</li><li class="pt-1"><span class="font-tibetan text-base">གླུའི་སྒྲ་ལ་ཤིན་ཏུ་དགའ་ཞིང་མངོན་པར་ཆགས་པ།</span></li><li class="italic">saṃhṛṣṭa­gīta­dhvanyabhiratā</li></ul><div class="glossary-instance-definition"><p class="definition">A realm in the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="6bae9e72-1aaa-4345-80e7-279d942e4cd6" class="relative scroll-mt-20"><button type="button" id="radix-_R_ivt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.383</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Enraptured by Smell</div><ul class="ml-4 list-disc"><li class="italic">dris dregs dga’</li><li class="pt-1"><span class="font-tibetan text-base">དྲིས་དྲེགས་དགའ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A realm of the <span data-glossary-id="UT22084-068-021-8621">vessel-bearer gods</span>.</p></div></div></div></div><div id="7a8edfb3-4c59-40e0-be08-f2a0632b3bfb" class="relative scroll-mt-20"><button type="button" id="radix-_R_j055anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.384</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Enticer</div><ul class="ml-4 list-disc"><li class="italic">sems ’gro ba</li><li class="pt-1"><span class="font-tibetan text-base">སེམས་འགྲོ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A river on <span data-glossary-id="UT22084-068-021-9657">Saṅkāśa</span>.</p></div></div></div></div><div id="695c53cd-5d29-4c6b-88ca-21ada6686cd6" class="relative scroll-mt-20"><button type="button" id="radix-_R_j0d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.385</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Entirely Beneath the Earth</div><ul class="ml-4 list-disc"><li class="italic">sa kun gyi ’og, thams cad sa ’og</li><li class="pt-1"><span class="font-tibetan text-base">ཐམས་ཅད་ས་འོག, ས་ཀུན་གྱི་འོག</span></li><li class="italic">sarvādhobhūmi</li></ul><div class="glossary-instance-definition"><p class="definition">One of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-9279">Hell of Ultimate Torment</span>.</p></div></div></div></div><div id="56e7e944-a266-40c3-a58b-82bea05db003" class="relative scroll-mt-20"><button type="button" id="radix-_R_j0l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.386</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Equal Peaks</div><ul class="ml-4 list-disc"><li class="italic">rwa mnyam pa</li><li class="pt-1"><span class="font-tibetan text-base">རྭ་མཉམ་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A mountain in <span data-glossary-id="UT22084-068-021-9398">Kuru</span>.</p></div></div></div></div><div id="da244ecf-a11e-4514-a337-930c440c4d2b" class="relative scroll-mt-20"><button type="button" id="radix-_R_j0t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.387</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Equal to the Wind</div><ul class="ml-4 list-disc"><li class="italic">rlung mtshungs pa</li><li class="pt-1"><span class="font-tibetan text-base">རླུང་མཚུངས་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A river on <span data-glossary-id="UT22084-068-021-9657">Saṅkāśa</span>.</p></div></div></div></div><div id="f1f7bce1-3122-4508-8947-65cabe6c044e" class="relative scroll-mt-20"><button type="button" id="radix-_R_j155anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.388</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Essence of Jewels</div><ul class="ml-4 list-disc"><li class="italic">nor bu’i snying po</li><li class="pt-1"><span class="font-tibetan text-base">ནོར་བུའི་སྙིང་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">Refers to <span data-glossary-id="UT22084-068-021-9030">Dwelling in Essence of Jewels</span>.</p></div></div></div></div><div id="9a4f92e2-d13e-457c-b442-98a788660322" class="relative scroll-mt-20"><button type="button" id="radix-_R_j1d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.389</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">ethical narrations</div><ul class="ml-4 list-disc"><li class="italic">gleng gzhi’i sde</li><li class="pt-1"><span class="font-tibetan text-base">གླེང་གཞིའི་སྡེ།</span></li><li class="italic">nidāna</li></ul><div class="glossary-instance-definition"><p class="definition">One among the twelve sections of scripture.</p></div></div></div></div><div id="8bf9c4d8-04a8-45e8-bd3d-39700d132a6a" class="relative scroll-mt-20"><button type="button" id="radix-_R_j1l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.390</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Even and Smooth Surface</div><ul class="ml-4 list-disc"><li class="italic">mnyam zhing ’jam pa’i ngos</li><li class="pt-1"><span class="font-tibetan text-base">མཉམ་ཞིང་འཇམ་པའི་ངོས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">An emanated city on the back of <span data-glossary-id="UT22084-068-021-8636">Airāvaṇa</span>.</p></div></div></div></div><div id="7e7d41b3-c6d2-4eec-86d3-20d972dc4c63" class="relative scroll-mt-20"><button type="button" id="radix-_R_j1t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.391</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Even Toward All</div><ul class="ml-4 list-disc"><li class="italic">skye bo kun snyoms</li><li class="pt-1"><span class="font-tibetan text-base">སྐྱེ་བོ་ཀུན་སྙོམས།</span></li></ul><div class="glossary-instance-definition"><p class="definition"><span data-glossary-id="UT22084-068-021-8491">Brahmin</span> who was reborn as <span data-glossary-id="UT22084-068-021-8636">Airāvaṇa</span>.</p></div></div></div></div><div id="e9bd8055-29a1-4d81-a967-e9724c77af30" class="relative scroll-mt-20"><button type="button" id="radix-_R_j255anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.392</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Even Waters</div><ul class="ml-4 list-disc"><li class="italic">chu mnyam par gyur pa</li><li class="pt-1"><span class="font-tibetan text-base">ཆུ་མཉམ་པར་གྱུར་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">An ocean between <span data-glossary-id="UT22084-068-021-9209">Godānīya</span> and <span data-glossary-id="UT22084-068-021-9847">Videha</span>.</p></div></div></div></div><div id="85cfa3a7-1893-4425-a547-9e1f269f5351" class="relative scroll-mt-20"><button type="button" id="radix-_R_j2d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.393</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">ever-ecstatic, ever-infatuated, ever-infatuated gods</div><ul class="ml-4 list-disc"><li class="italic">rtag tu myos lha, rtag tu myos pa</li><li class="pt-1"><span class="font-tibetan text-base">རྟག་ཏུ་མྱོས་པ།, རྟག་ཏུ་མྱོས་ལྷ།</span></li><li class="italic">sadāmatta, sadāmāda</li></ul><div class="glossary-instance-definition"><p class="definition">A class of <span data-glossary-id="UT22084-068-021-8531">gods</span> associated with the <span data-glossary-id="UT22084-068-021-8526">Four Great Kings</span>.</p></div></div></div></div><div id="ffbe37f5-41a7-4296-8461-64796c9d7aef" class="relative scroll-mt-20"><button type="button" id="radix-_R_j2l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.394</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">ever-ecstatic, ever-infatuated, ever-infatuated gods</div><ul class="ml-4 list-disc"><li class="italic">rtag tu myos lha, rtag tu myos pa</li><li class="pt-1"><span class="font-tibetan text-base">རྟག་ཏུ་མྱོས་པ།, རྟག་ཏུ་མྱོས་ལྷ།</span></li><li class="italic">sadāmatta, sadāmāda</li></ul><div class="glossary-instance-definition"><p class="definition">A class of <span data-glossary-id="UT22084-068-021-8531">gods</span> associated with the <span data-glossary-id="UT22084-068-021-8526">Four Great Kings</span>.</p></div></div></div></div><div id="5bdbf4c7-8117-4e5b-9a55-05dab9ed2f1b" class="relative scroll-mt-20"><button type="button" id="radix-_R_j2t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.395</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ever-Golden Forest</div><ul class="ml-4 list-disc"><li class="italic">kun nas gser gyi tshal</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་ནས་གསེར་གྱི་ཚལ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest in <span data-glossary-id="UT22084-068-021-9710">Special Joy</span>.</p></div></div></div></div><div id="a3cef0fd-5ad6-46a8-a104-ca3a72167145" class="relative scroll-mt-20"><button type="button" id="radix-_R_j355anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.396</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ever-Joyous</div><ul class="ml-4 list-disc"><li class="italic">kun dga’</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་དགའ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lotus pool in <span data-glossary-id="UT22084-068-021-9403">Lateral</span>.</p></div></div></div></div><div id="a502ff08-bbad-4768-90dd-f5e064efac56" class="relative scroll-mt-20"><button type="button" id="radix-_R_j3d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.397</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ever-Joyous One</div><ul class="ml-4 list-disc"><li class="italic">kun dga’</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་དགའ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A previous ruler of the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="4d6b9496-731b-4e13-94b2-f05e6febb5fe" class="relative scroll-mt-20"><button type="button" id="radix-_R_j3l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.398</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">ever-present</div><ul class="ml-4 list-disc"><li class="italic">kun ’gro</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་འགྲོ།</span></li><li class="italic">sarvasaha</li></ul><div class="glossary-instance-definition"><p class="definition">A class of <span data-glossary-id="UT22084-068-021-8489">asuras</span> that live on the third level, <span data-glossary-id="UT22084-068-021-9087">Excellent Abode</span>.</p></div></div></div></div><div id="34a1d1b9-0900-41cc-881d-10ce4bdb180b" class="relative scroll-mt-20"><button type="button" id="radix-_R_j3t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.399</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ever-Present Chariots</div><ul class="ml-4 list-disc"><li class="italic">shing rta kun ’gro</li><li class="pt-1"><span class="font-tibetan text-base">ཤིང་རྟ་ཀུན་འགྲོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lake near <span data-glossary-id="UT22084-068-021-9734">Sudharma</span>.</p></div></div></div></div><div id="8d4a78ad-a9ff-455f-b55d-524490f9a429" class="relative scroll-mt-20"><button type="button" id="radix-_R_j455anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.400</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">evil Māra</div><ul class="ml-4 list-disc"><li class="italic">bdud sdig can, sdig can</li><li class="pt-1"><span class="font-tibetan text-base">བདུད་སྡིག་ཅན།, སྡིག་ཅན།</span></li><li class="italic">mārapāpīyān, pāpīyān</li></ul><div class="glossary-instance-definition"><p class="definition">See “<span data-glossary-id="UT22084-068-021-8553">Māra</span>.”</p></div></div></div></div><div id="62de1008-5aec-461f-ba38-eb7ce7f05ee3" class="relative scroll-mt-20"><button type="button" id="radix-_R_j4d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.401</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Excellence of Exquisite Intelligence</div><ul class="ml-4 list-disc"><li class="italic">mchog tu bzang po’i blo gros bzang po</li><li class="pt-1"><span class="font-tibetan text-base">མཆོག་ཏུ་བཟང་པོའི་བློ་གྲོས་བཟང་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A mountain to the north of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="7ee1a1ed-1f60-4964-b96e-fa9aa933707f" class="relative scroll-mt-20"><button type="button" id="radix-_R_j4l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.402</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Excellent</div><ul class="ml-4 list-disc"><li class="italic">bzang po</li><li class="pt-1"><span class="font-tibetan text-base">བཟང་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A river on <span data-glossary-id="UT22084-068-021-9128">Flocking Peacocks</span>.</p></div></div></div></div><div id="c4a4e4a1-f58b-4670-9d35-e927e3add780" class="relative scroll-mt-20"><button type="button" id="radix-_R_j4t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.403</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Excellent Abode</div><ul class="ml-4 list-disc"><li class="italic">gnas bzang po</li><li class="pt-1"><span class="font-tibetan text-base">གནས་བཟང་པོ།</span></li><li class="italic">sunābhā</li></ul><div class="glossary-instance-definition"><p class="definition">Third level of the <span data-glossary-id="UT22084-068-021-8489">asuras</span>.</p></div></div></div></div><div id="a65dec74-2dd7-4cc2-a00e-d6a38d969111" class="relative scroll-mt-20"><button type="button" id="radix-_R_j555anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.404</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Excellent Armies</div><ul class="ml-4 list-disc"><li class="italic">sde dpung bzang po</li><li class="pt-1"><span class="font-tibetan text-base">སྡེ་དཔུང་བཟང་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">An island in the vicinity of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="fa0a4ea9-0acd-4c29-8148-3deb406f3baa" class="relative scroll-mt-20"><button type="button" id="radix-_R_j5d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.405</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Excellent Force of Perfection</div><ul class="ml-4 list-disc"><li class="italic">phun sum tshogs par byed pa’i sde bzang po</li><li class="pt-1"><span class="font-tibetan text-base">ཕུན་སུམ་ཚོགས་པར་བྱེད་པའི་སྡེ་བཟང་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A ruler of the <span data-glossary-id="UT22084-068-021-9266">Heaven Free from Strife</span>.</p></div></div></div></div><div id="cb128eab-8623-40d7-9360-7219468f730c" class="relative scroll-mt-20"><button type="button" id="radix-_R_j5l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.406</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Excellent Forest</div><ul class="ml-4 list-disc"><li class="italic">kun tu bzang po’i nags rnam</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་ཏུ་བཟང་པོའི་ནགས་རྣམ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">An island in the vicinity of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="b244353a-0ff9-4dbf-aae6-2b471f90a2ac" class="relative scroll-mt-20"><button type="button" id="radix-_R_j5t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.407</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Excellent Garland</div><ul class="ml-4 list-disc"><li class="italic">phreng bzang</li><li class="pt-1"><span class="font-tibetan text-base">ཕྲེང་བཟང་།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-068-021-8531">god</span> from whom <span data-glossary-id="UT22084-068-021-8738">Śakra</span> heard the Dharma in a previous life.</p></div></div></div></div><div id="ce591dfb-3fa1-41be-8d51-2621258d30dd" class="relative scroll-mt-20"><button type="button" id="radix-_R_j655anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.408</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Excellent Intelligence</div><ul class="ml-4 list-disc"><li class="italic">blo gros bzang</li><li class="pt-1"><span class="font-tibetan text-base">བློ་གྲོས་བཟང་།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A previous ruler of the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="c763289b-2d6b-42ce-8592-357140de14de" class="relative scroll-mt-20"><button type="button" id="radix-_R_j6d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.409</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Excellent Joy</div><ul class="ml-4 list-disc"><li class="italic">dga’ ba bzang po</li><li class="pt-1"><span class="font-tibetan text-base">དགའ་བ་བཟང་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A city in <span data-glossary-id="UT22084-068-021-9847">Videha</span>.</p></div></div></div></div><div id="347289ae-dad3-4f32-a374-51ce1e859a82" class="relative scroll-mt-20"><button type="button" id="radix-_R_j6l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.410</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Excellent Taste</div><ul class="ml-4 list-disc"><li class="italic">ro bzang ba</li><li class="pt-1"><span class="font-tibetan text-base">རོ་བཟང་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lake on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span>.</p></div></div></div></div><div id="49f1a8ad-e257-46b5-b4bf-809884ef16bd" class="relative scroll-mt-20"><button type="button" id="radix-_R_j6t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.411</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Excellent View</div><ul class="ml-4 list-disc"><li class="italic">blta na sdug</li><li class="pt-1"><span class="font-tibetan text-base">བལྟ་ན་སྡུག</span></li></ul><div class="glossary-instance-definition"><p class="definition">A city in the realm <span data-glossary-id="UT22084-068-021-9025">Dwelling in Excellent View</span>.</p></div></div></div></div><div id="801d512e-c772-4730-9191-9019953e50ed" class="relative scroll-mt-20"><button type="button" id="radix-_R_j755anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.412</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Excellent Water</div><ul class="ml-4 list-disc"><li class="italic">chu bzang, shis pa’i chu</li><li class="pt-1"><span class="font-tibetan text-base">ཆུ་བཟང་།, ཤིས་པའི་ཆུ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">(1) A river in the <span data-glossary-id="UT22084-068-021-9764">Swan Forest</span> (<em class="foreign text-wy" lang="bo-LATN">shis pa’i chu</em>). (2) A river in <span data-glossary-id="UT22084-068-021-9209">Godānīya</span> (<em class="foreign text-wy" lang="bo-LATN">chu bzang</em>).</p></div></div></div></div><div id="994bc891-5b91-42a3-bfcf-329a09aa6662" class="relative scroll-mt-20"><button type="button" id="radix-_R_j7d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.413</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Excellent Wealth</div><ul class="ml-4 list-disc"><li class="italic">legs ’byor</li><li class="pt-1"><span class="font-tibetan text-base">ལེགས་འབྱོར།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A previous ruler of the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="8d065f8c-098f-44c8-997f-bef036604331" class="relative scroll-mt-20"><button type="button" id="radix-_R_j7l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.414</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Excruciating Pain</div><ul class="ml-4 list-disc"><li class="italic">tshor ba bdo ba</li><li class="pt-1"><span class="font-tibetan text-base">ཚོར་བ་བདོ་བ།</span></li><li class="italic">tīvravedana</li></ul><div class="glossary-instance-definition"><p class="definition">One of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-9630">Reviving Hell</span>.</p></div></div></div></div><div id="70c020d6-e262-4a43-87ed-d559adae9a0f" class="relative scroll-mt-20"><button type="button" id="radix-_R_j7t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.415</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Excruciating Splitting and Cutting by Means of a Black Iron Thread</div><ul class="ml-4 list-disc"><li class="italic">lcags nag po’i skud pas ’dral zhing gcud pa tsha ba</li><li class="pt-1"><span class="font-tibetan text-base">ལྕགས་ནག་པོའི་སྐུད་པས་འདྲལ་ཞིང་གཅུད་པ་ཚ་བ།</span></li><li class="italic">kālāyasa­sūtra­bhedanacchedana­kaṭuka</li></ul><div class="glossary-instance-definition"><p class="definition">One of the sixteen realms that surround the <span><span data-glossary-id="UT22084-068-021-9277">Hell of Heat</span></span>. </p></div></div></div></div><div id="63339e5e-a3a4-4a19-b0c3-09c5f4ea0796" class="relative scroll-mt-20"><button type="button" id="radix-_R_j855anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.416</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Expanse</div><ul class="ml-4 list-disc"><li class="italic">klong</li><li class="pt-1"><span class="font-tibetan text-base">ཀློང་།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A virtuous <span data-glossary-id="UT22084-068-021-8562">nāga</span> king.</p></div></div></div></div><div id="6220141b-5639-4212-9f6d-40489c6a3cd0" class="relative scroll-mt-20"><button type="button" id="radix-_R_j8d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.417</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Expansive</div><ul class="ml-4 list-disc"><li class="italic">rnam par rgyas pa</li><li class="pt-1"><span class="font-tibetan text-base">རྣམ་པར་རྒྱས་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lake in <span><span data-glossary-id="UT22084-068-021-8938">Constant Bliss</span></span>.</p></div></div></div></div><div id="2d83dff2-eba3-40b8-ba16-e14d67831d5c" class="relative scroll-mt-20"><button type="button" id="radix-_R_j8l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.418</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Experiencing Wholesome Qualities</div><ul class="ml-4 list-disc"><li class="italic">yon tan dkar po spyod pa</li><li class="pt-1"><span class="font-tibetan text-base">ཡོན་ཏན་དཀར་པོ་སྤྱོད་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A realm inhabited by <span data-glossary-id="UT22084-068-021-8530">garland-bearer gods</span>.</p></div></div></div></div><div id="daff297e-06a1-4636-bf72-c134020e2302" class="relative scroll-mt-20"><button type="button" id="radix-_R_j8t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.419</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Extent of Failed Power</div><ul class="ml-4 list-disc"><li class="italic">kun tu nyams pa’i stobs kyi mtha’</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་ཏུ་ཉམས་པའི་སྟོབས་ཀྱི་མཐའ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A city in <span data-glossary-id="UT22084-068-021-9209">Godānīya</span>.</p></div></div></div></div><div id="2aa346b6-bf2f-482d-96c4-e32958f3ae1a" class="relative scroll-mt-20"><button type="button" id="radix-_R_j955anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.420</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">External Shade</div><ul class="ml-4 list-disc"><li class="italic">phyi rol gyi grib ma</li><li class="pt-1"><span class="font-tibetan text-base">ཕྱི་རོལ་གྱི་གྲིབ་མ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A forest in <span data-glossary-id="UT22084-068-021-9117">Fine Complexion and Large Body</span>.</p></div></div></div></div><div id="22e3df1c-ec7c-4aa9-b7ba-14e16d634a0f" class="relative scroll-mt-20"><button type="button" id="radix-_R_j9d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.421</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Extreme Screams</div><ul class="ml-4 list-disc"><li class="italic">sgra ’byin shin tu sgra ’byin</li><li class="pt-1"><span class="font-tibetan text-base">སྒྲ་འབྱིན་ཤིན་ཏུ་སྒྲ་འབྱིན།</span></li><li class="italic">ninādātinināda</li></ul><div class="glossary-instance-definition"><p class="definition">One of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-9235">Great Howling Hell</span>.</p></div></div></div></div><div id="98ff04bb-0f04-4d8f-9a6c-3f61974b4ee4" class="relative scroll-mt-20"><button type="button" id="radix-_R_j9l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.422</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Extremely Exalted</div><ul class="ml-4 list-disc"><li class="italic">shin tu mtho</li><li class="pt-1"><span class="font-tibetan text-base">ཤིན་ཏུ་མཐོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">One of the seven golden mountains that surround Mount <span data-glossary-id="UT22084-068-021-9739">Sumeru</span>.</p></div></div></div></div><div id="1306639b-f683-4065-b7e2-86dd42f2c9ab" class="relative scroll-mt-20"><button type="button" id="radix-_R_j9t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.423</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Eye Garland</div><ul class="ml-4 list-disc"><li class="italic">mig gi phreng ba</li><li class="pt-1"><span class="font-tibetan text-base">མིག་གི་ཕྲེང་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A mountain on <span data-glossary-id="UT22084-068-021-9847">Videha</span>.</p></div></div></div></div><div id="90b70285-1f20-478a-a8a8-b85f76c49fc3" class="relative scroll-mt-20"><button type="button" id="radix-_R_ja55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.424</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Eyes Beyond the World</div><ul class="ml-4 list-disc"><li class="italic">mig ’jig rten las ’das pa</li><li class="pt-1"><span class="font-tibetan text-base">མིག་འཇིག་རྟེན་ལས་འདས་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A land on the northern continent of <span data-glossary-id="UT22084-068-021-9398">Kuru</span>.</p></div></div></div></div><div id="2aa6b755-f454-45ce-a25d-44a58da11c26" class="relative scroll-mt-20"><button type="button" id="radix-_R_jad5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.425</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Eyes of the Environment</div><ul class="ml-4 list-disc"><li class="italic">nye ’khor gyi mig</li><li class="pt-1"><span class="font-tibetan text-base">ཉེ་འཁོར་གྱི་མིག</span></li></ul><div class="glossary-instance-definition"><p class="definition">An ocean between <span data-glossary-id="UT22084-068-021-9398">Kuru</span> and <span data-glossary-id="UT22084-068-021-9209">Godānīya</span>.</p></div></div></div></div><div id="392b849b-8e29-404e-9e54-294cd46f10b1" class="relative scroll-mt-20"><button type="button" id="radix-_R_jal5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.426</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Face of Joy</div><ul class="ml-4 list-disc"><li class="italic">dga’ ba’i bzhin</li><li class="pt-1"><span class="font-tibetan text-base">དགའ་བའི་བཞིན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A land in the east of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="4c2d89d4-bb5b-4d6b-8d63-088fb77f86a5" class="relative scroll-mt-20"><button type="button" id="radix-_R_jat5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.427</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">factors of awakening, thirty-seven factors of awakening</div><ul class="ml-4 list-disc"><li class="italic">byang chub kyi phyogs kyi chos sum cu rtsa bdun</li><li class="pt-1"><span class="font-tibetan text-base">བྱང་ཆུབ་ཀྱི་ཕྱོགས་ཀྱི་ཆོས་སུམ་ཅུ་རྩ་བདུན།</span></li><li class="italic">saptatriṃśa­bodhi­pakṣya­dharma</li></ul><div class="glossary-instance-definition"><p class="definition">Thirty-seven practices that lead the practitioner to the awakened state: the four applications of mindfulness, the four authentic eliminations, the four bases of supernatural power, the five masteries, the five powers, the <span data-glossary-id="UT22084-068-021-8512">eightfold path</span>, and the <span data-glossary-id="UT22084-068-021-8591">seven branches of awakening</span>.</p></div></div></div></div><div id="3fa3f050-4af9-405f-9d21-f34808303e7b" class="relative scroll-mt-20"><button type="button" id="radix-_R_jb55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.428</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">faculties</div><ul class="ml-4 list-disc"><li class="italic">dbang po</li><li class="pt-1"><span class="font-tibetan text-base">དབང་པོ།</span></li><li class="italic">indriya</li></ul><div class="glossary-instance-definition"><p class="definition">The term “<span class="ignore">faculties</span>,” depending on the context, can refer to the five senses (sight, smell, touch, hearing, taste) plus the mental faculty, totaling six, but also to spiritual “<span class="ignore">faculties</span>.” See “<span data-glossary-id="UT22084-068-021-9917">five faculties</span>.”</p></div></div></div></div><div id="f6a876f9-b4a8-43cb-a800-1a03e6ebdc05" class="relative scroll-mt-20"><button type="button" id="radix-_R_jbd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.429</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Falling Like Rain on High Mountains</div><ul class="ml-4 list-disc"><li class="italic">ri brtsegs char ltar ’bab pa, ri brtsegs ’bab</li><li class="pt-1"><span class="font-tibetan text-base">རི་བརྩེགས་ཆར་ལྟར་འབབ་པ།, རི་བརྩེགས་འབབ།</span></li><li class="italic">girikūṭavarṣa</li></ul><div class="glossary-instance-definition"><p class="definition">One of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-9279">Hell of Ultimate Torment</span>.</p></div></div></div></div><div id="029866f2-3bf8-4172-adf0-85ab0b790843" class="relative scroll-mt-20"><button type="button" id="radix-_R_jbl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.430</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">fearless people</div><ul class="ml-4 list-disc"><li class="italic">’jigs pa dang bral ba’i skye bu</li><li class="pt-1"><span class="font-tibetan text-base">འཇིགས་པ་དང་བྲལ་བའི་སྐྱེ་བུ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">Inhabitants of the <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span> mountain in <span data-glossary-id="UT22084-068-021-9398">Kuru</span>. </p></div></div></div></div><div id="89c25dc4-a997-46fb-a5ce-a9c858134448" class="relative scroll-mt-20"><button type="button" id="radix-_R_jbt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.431</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Fearsome Screams</div><ul class="ml-4 list-disc"><li class="italic">sgra ’jigs ston</li><li class="pt-1"><span class="font-tibetan text-base">སྒྲ་འཇིགས་སྟོན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">One of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-9279">Hell of Ultimate Torment</span>.</p></div></div></div></div><div id="a56b4b02-5a66-4a93-86a7-17fc5d07d498" class="relative scroll-mt-20"><button type="button" id="radix-_R_jc55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.432</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Fearsome Waves</div><ul class="ml-4 list-disc"><li class="italic">chu bo’i rlabs ’jigs pa</li><li class="pt-1"><span class="font-tibetan text-base">ཆུ་བོའི་རླབས་འཇིགས་པ།</span></li><li class="italic">pratibhaya­taraṅgā</li></ul><div class="glossary-instance-definition"><p class="definition">A river in the <span data-glossary-id="UT22084-068-021-9278">Hell of Intense Heat</span>.</p></div></div></div></div><div id="08caf9d9-d7b4-4429-a7c2-307914b4a8e0" class="relative scroll-mt-20"><button type="button" id="radix-_R_jcd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.433</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Fed by Billowing Streams</div><ul class="ml-4 list-disc"><li class="italic">rgyab nas klung kun du gang bar ’bab pa</li><li class="pt-1"><span class="font-tibetan text-base">རྒྱབ་ནས་ཀླུང་ཀུན་དུ་གང་བར་འབབ་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A river on <span data-glossary-id="UT22084-068-021-9657">Saṅkāśa</span>.</p></div></div></div></div><div id="fdedff17-0814-4ac1-87aa-516436345abe" class="relative scroll-mt-20"><button type="button" id="radix-_R_jcl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.434</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Female Trees</div><ul class="ml-4 list-disc"><li class="italic">bu mo’i shing gis bskor ba</li><li class="pt-1"><span class="font-tibetan text-base">བུ་མོའི་ཤིང་གིས་བསྐོར་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">An island in the vicinity of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="1a02572a-9583-49fb-a50d-dc7a7bcfd5fc" class="relative scroll-mt-20"><button type="button" id="radix-_R_jct5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.435</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Fence Ring</div><ul class="ml-4 list-disc"><li class="italic">’khor lo khyud mo</li><li class="pt-1"><span class="font-tibetan text-base">འཁོར་ལོ་ཁྱུད་མོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A ring of mountains at the end of the sea.</p></div></div></div></div><div id="70e82b8d-2f04-4084-b4ca-fa88dcb38ecb" class="relative scroll-mt-20"><button type="button" id="radix-_R_jd55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.436</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Festive Words</div><ul class="ml-4 list-disc"><li class="italic">dus ston gyi tshigs</li><li class="pt-1"><span class="font-tibetan text-base">དུས་སྟོན་གྱི་ཚིགས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A mountain in <span data-glossary-id="UT22084-068-021-9510">Moving in the Wink of an Eye</span>.</p></div></div></div></div><div id="e843c74a-1afe-4437-b242-1d0fe966c6d0" class="relative scroll-mt-20"><button type="button" id="radix-_R_jdd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.437</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">field of merit</div><ul class="ml-4 list-disc"><li class="italic">bsod nams kyi zhing</li><li class="pt-1"><span class="font-tibetan text-base">བསོད་ནམས་ཀྱི་ཞིང་།</span></li><li class="italic">puṇyakṣetra</li></ul><div class="glossary-instance-definition"><p class="definition">Factors (such as Buddha, Dharma, Saṅgha, one’s parents, the sick, and the poor) which when treated with due care serve to engender merit. </p></div></div></div></div><div id="16caf262-c580-408b-904b-16072958246a" class="relative scroll-mt-20"><button type="button" id="radix-_R_jdl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.438</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Fierce</div><ul class="ml-4 list-disc"><li class="italic">rtsub pa</li><li class="pt-1"><span class="font-tibetan text-base">རྩུབ་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A mountain in <span data-glossary-id="UT22084-068-021-9209">Godānīya</span>.</p></div></div></div></div><div id="d3ad86aa-7383-4bef-8220-ccfbe57838e3" class="relative scroll-mt-20"><button type="button" id="radix-_R_jdt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.439</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Filled with Stakes</div><ul class="ml-4 list-disc"><li class="italic">phur bus gang ba’i chu bo</li><li class="pt-1"><span class="font-tibetan text-base">ཕུར་བུས་གང་བའི་ཆུ་བོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A river in the <span data-glossary-id="UT22084-068-021-8975">Crushing Hell</span>.</p></div></div></div></div><div id="8db2d4ef-b344-41dc-bf98-d56f91583e76" class="relative scroll-mt-20"><button type="button" id="radix-_R_je55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.440</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Filled with Swans</div><ul class="ml-4 list-disc"><li class="italic">ngang ngur gyis gang ba</li><li class="pt-1"><span class="font-tibetan text-base">ངང་ངུར་གྱིས་གང་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A river on <span data-glossary-id="UT22084-068-021-9657">Saṅkāśa</span>.</p></div></div></div></div><div id="7d99980c-05eb-4f6e-b45a-bd363846a37c" class="relative scroll-mt-20"><button type="button" id="radix-_R_jed5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.441</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Filled with Turtles</div><ul class="ml-4 list-disc"><li class="italic">rus sbal gyis gang ba</li><li class="pt-1"><span class="font-tibetan text-base">རུས་སྦལ་གྱིས་གང་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A river on <span data-glossary-id="UT22084-068-021-9657">Saṅkāśa</span>.</p></div></div></div></div><div id="d048e803-6d87-4958-89d2-c4c8e4a995ad" class="relative scroll-mt-20"><button type="button" id="radix-_R_jel5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.442</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Fine Complexion and Large Body</div><ul class="ml-4 list-disc"><li class="italic">lus kyi mdog bzang zhing che ba</li><li class="pt-1"><span class="font-tibetan text-base">ལུས་ཀྱི་མདོག་བཟང་ཞིང་ཆེ་བ།</span></li><li class="italic">prabalecchāchāyā­śarīra</li></ul><div class="glossary-instance-definition"><p class="definition">A realm in the <span data-glossary-id="UT22084-068-021-9276">Heaven of the Thirty-Three</span>.</p></div></div></div></div><div id="0dff692c-25e1-4c8f-8f5a-f834eb7c0f84" class="relative scroll-mt-20"><button type="button" id="radix-_R_jet5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.443</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Fire Garland</div><ul class="ml-4 list-disc"><li class="italic">me phreng</li><li class="pt-1"><span class="font-tibetan text-base">མེ་ཕྲེང་།</span></li></ul><div class="glossary-instance-definition"><p class="definition">Forest on the third <span data-glossary-id="UT22084-068-021-8489">asura</span> level, <span data-glossary-id="UT22084-068-021-9087">Excellent Abode</span>.</p></div></div></div></div><div id="a92ef815-4885-4c49-b2cb-6c8945a86dd8" class="relative scroll-mt-20"><button type="button" id="radix-_R_jf55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.444</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Fire that Brings Forth a Torrent of Tears</div><ul class="ml-4 list-disc"><li class="italic">mchi ma’i rgyun me lta bur mi chad pa</li><li class="pt-1"><span class="font-tibetan text-base">མཆི་མའི་རྒྱུན་མེ་ལྟ་བུར་མི་ཆད་པ།</span></li><li class="italic">aśrupravāhāgni</li></ul><div class="glossary-instance-definition"><p class="definition">One of sixteen realms that surround the <span data-glossary-id="UT22084-068-021-8975">Crushing Hell</span>.</p></div></div></div></div><div id="98dee245-3899-43f8-8c5b-e800b44802a7" class="relative scroll-mt-20"><button type="button" id="radix-_R_jfd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.445</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Firm</div><ul class="ml-4 list-disc"><li class="italic">brtan pa</li><li class="pt-1"><span class="font-tibetan text-base">བརྟན་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">An <span data-glossary-id="UT22084-068-021-8489">asura</span> king.</p></div></div></div></div><div id="4cc8a77a-6afb-4d1d-8469-0820e45a14d7" class="relative scroll-mt-20"><button type="button" id="radix-_R_jfl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.446</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Fish</div><ul class="ml-4 list-disc"><li class="italic">nya</li><li class="pt-1"><span class="font-tibetan text-base">ཉ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A land to the north of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="049c0502-b770-40dc-8ae1-378c50d92acd" class="relative scroll-mt-20"><button type="button" id="radix-_R_jft5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.447</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Fish Attractor</div><ul class="ml-4 list-disc"><li class="italic">nya dang kun tu ’brel pa</li><li class="pt-1"><span class="font-tibetan text-base">ཉ་དང་ཀུན་ཏུ་འབྲེལ་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lake on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span>.</p></div></div></div></div><div id="a4795ae5-d5e5-4055-a212-9d014e021405" class="relative scroll-mt-20"><button type="button" id="radix-_R_jg55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.448</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">fish faces</div><ul class="ml-4 list-disc"><li class="italic">nya gdong po</li><li class="pt-1"><span class="font-tibetan text-base">ཉ་གདོང་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A class of <span data-glossary-id="UT22084-068-021-8489">asuras</span>.</p></div></div></div></div><div id="45d750ad-b480-4502-9100-6d2265927c64" class="relative scroll-mt-20"><button type="button" id="radix-_R_jgd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.449</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">five bases of training</div><ul class="ml-4 list-disc"><li class="italic">bslab pa’i gzhi lnga</li><li class="pt-1"><span class="font-tibetan text-base">བསླབ་པའི་གཞི་ལྔ།</span></li><li class="italic">pañcaśikṣāpada</li></ul><div class="glossary-instance-definition"><p class="definition">Abstaining from <span data-glossary-id="UT22084-068-021-8545">killing</span>, <span data-glossary-id="UT22084-068-021-9902">stealing</span>, <span data-glossary-id="UT22084-068-021-8593">sexual misconduct</span>, <span data-glossary-id="UT22084-068-021-9903">lying</span>, and intoxication.</p></div></div></div></div><div id="894f633e-28ab-420e-8065-1f4f74e39437" class="relative scroll-mt-20"><button type="button" id="radix-_R_jgl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.450</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">five classes of beings, five realms</div><ul class="ml-4 list-disc"><li class="italic">’gro ba lnga, ’gro ba lnga</li><li class="pt-1"><span class="font-tibetan text-base">འགྲོ་བ་ལྔ།, འགྲོ་བ་ལྔ།</span></li><li class="italic">pañca­gati, pañca­gati</li></ul><div class="glossary-instance-definition"><p class="definition">These comprise <span data-glossary-id="UT22084-068-021-8531">gods</span> and humans of the higher realms within <span data-glossary-id="UT22084-068-021-8589">cyclic existence</span>, along with <span data-glossary-id="UT22084-068-021-9911">animals</span>, <span data-glossary-id="UT22084-068-021-9908">starving spirits</span>, and the hell dwellers, whose abodes are identified with the lower realms. It is also common to divide the <span data-glossary-id="UT22084-068-021-8531">god</span> realm in two, the <span data-glossary-id="UT22084-068-021-8531">gods</span> and the <span data-glossary-id="UT22084-068-021-8489">asuras</span>, making up six realms or classes of beings (<em class="foreign text-wy" lang="bo-LATN">’gro ba drug</em>, <em class="foreign break text-sa" lang="sa-LATN">ṣaḍgati</em> or <em class="foreign text-wy" lang="bo-LATN">rigs drug</em>, <em class="foreign break text-sa" lang="sa-LATN">ṣaṭkula</em>).</p></div></div></div></div><div id="00bd8003-1963-4abd-8655-bf7670dd1adc" class="relative scroll-mt-20"><button type="button" id="radix-_R_jgt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.451</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">five classes of beings, five realms</div><ul class="ml-4 list-disc"><li class="italic">’gro ba lnga, ’gro ba lnga</li><li class="pt-1"><span class="font-tibetan text-base">འགྲོ་བ་ལྔ།, འགྲོ་བ་ལྔ།</span></li><li class="italic">pañca­gati, pañca­gati</li></ul><div class="glossary-instance-definition"><p class="definition">See “<span data-glossary-id="UT22084-068-021-9915">five classes of beings</span>.”</p></div></div></div></div><div id="f5c7f202-0052-4b4a-8896-cd154a945558" class="relative scroll-mt-20"><button type="button" id="radix-_R_jh55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.452</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">five classes of instruments, five classes of musical instruments, five types of instruments, five types of musical instruments</div><ul class="ml-4 list-disc"><li class="italic">rol mo yan lag lnga dang ldan pa, sil snyan rnam pa lnga, sil snyan yan lag lnga, yan lag lnga dang ldan pa’i sil snyan</li><li class="pt-1"><span class="font-tibetan text-base">ཡན་ལག་ལྔ་དང་ལྡན་པའི་སིལ་སྙན།, རོལ་མོ་ཡན་ལག་ལྔ་དང་ལྡན་པ།, སིལ་སྙན་ཡན་ལག་ལྔ།, སིལ་སྙན་རྣམ་པ་ལྔ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A traditional Indian classification of musical instruments enumerates non-membranous percussion, membranous percussion, <span class="ignore">wind</span>-blown, plucked string, and bowed string.</p></div></div></div></div><div id="f89221a7-e978-42fb-91ce-3013c63af2db" class="relative scroll-mt-20"><button type="button" id="radix-_R_jhd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.453</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">five faculties</div><ul class="ml-4 list-disc"><li class="italic">dbang po lnga</li><li class="pt-1"><span class="font-tibetan text-base">དབང་པོ་ལྔ།</span></li><li class="italic">pañcendriya</li></ul><div class="glossary-instance-definition"><p class="definition">(1) The five sense “<span data-glossary-id="UT22084-068-021-9924">faculties</span>” corresponding to the five physical senses. (2) The five spiritual “<span data-glossary-id="UT22084-068-021-9924">faculties</span>” or capacities to be developed: faith (<em class="foreign break text-sa" lang="sa-LATN">śraddhā</em>), diligence (<em class="foreign break text-sa" lang="sa-LATN">vīrya</em>), mindfulness (<em class="foreign break text-sa" lang="sa-LATN">smṛti</em>), absorption (<em class="foreign break text-sa" lang="sa-LATN">samādhi</em>), and <span data-glossary-id="UT22084-068-021-100012">insight</span> (<em class="foreign break text-sa" lang="sa-LATN">prajña</em>). These are included in the <span data-glossary-id="UT22084-068-021-9904">thirty-seven factors of awakening</span>.</p></div></div></div></div><div id="efc4b184-6f36-4126-95f3-3ccd56fefcc8" class="relative scroll-mt-20"><button type="button" id="radix-_R_jhl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.454</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Five Fences of Gold and Other Materials</div><ul class="ml-4 list-disc"><li class="italic">gser la sogs pa’i lcags ri lngas bskor ba</li><li class="pt-1"><span class="font-tibetan text-base">གསེར་ལ་སོགས་པའི་ལྕགས་རི་ལྔས་བསྐོར་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">An island in the vicinity of <span data-glossary-id="UT22084-068-021-9338">Jambudvīpa</span>.</p></div></div></div></div><div id="ab49f28e-9f1c-4564-a4f6-ae464ab53214" class="relative scroll-mt-20"><button type="button" id="radix-_R_jht5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.455</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Five Flowers</div><ul class="ml-4 list-disc"><li class="italic">me tog lnga pa</li><li class="pt-1"><span class="font-tibetan text-base">མེ་ཏོག་ལྔ་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A park in <span data-glossary-id="UT22084-068-021-8867">Born in a Tank</span>.</p></div></div></div></div><div id="83bd907f-ac2a-4b63-9c08-78f8c1c2576f" class="relative scroll-mt-20"><button type="button" id="radix-_R_ji55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.456</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">five heavenly instruments, five heavenly musical instruments, heavenly music from the five types of instruments</div><ul class="ml-4 list-disc"><li class="italic">lha rdzas kyi rnga skad yan lag lnga</li><li class="pt-1"><span class="font-tibetan text-base">ལྷ་རྫས་ཀྱི་རྔ་སྐད་ཡན་ལག་ལྔ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">See “<span data-glossary-id="UT22084-068-021-9951">five types of musical instruments</span>.”</p></div></div></div></div><div id="e8d032fb-dcbb-4487-974d-94b00966a53f" class="relative scroll-mt-20"><button type="button" id="radix-_R_jid5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.457</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Five Trees</div><ul class="ml-4 list-disc"><li class="italic">shing lnga pa</li><li class="pt-1"><span class="font-tibetan text-base">ཤིང་ལྔ་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A lake on <span data-glossary-id="UT22084-068-021-9078">Equal Peaks</span>.</p></div></div></div></div><div id="32ef99d5-387e-4c79-aa7d-57eb2cc12d96" class="relative scroll-mt-20"><button type="button" id="radix-_R_jil5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.458</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Fivefold Joy</div><ul class="ml-4 list-disc"><li class="italic">dga’ ba lnga</li><li class="pt-1"><span class="font-tibetan text-base">དགའ་བ་ལྔ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A pleasure garden in <span data-glossary-id="UT22084-068-021-9512">Moving Like the Moon</span>.</p></div></div></div></div><div id="63b39aca-c340-44ce-880e-443626e91f63" class="relative scroll-mt-20"><button type="button" id="radix-_R_jit5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-