ogs pa\"}},{\"uuid\":\"e500a3ec-a56d-4481-85af-4698f28fc144\",\"authority\":\"02812b0e-fdcb-421c-9c16-cd6358bb8bb3\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the sixteen realms that surround the \u003cspan\u003e\u003cspan data-glossary-id=\\\"UT22084-068-021-9277\\\"\u003eHell of Heat\u003c/span\u003e\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Swimming Like Fish in Molten Copper\",\"tibetan\":\"ཟངས་བཞུས་བར་ཉ་འཁྱུག་པ་ལྟ་བུ།\",\"sanskrit\":\"tāmra­lohita­mīnāvarta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"zangs bzhus bar nya ’khyug pa lta bu\"}},{\"uuid\":\"a6accc2e-e23e-47ff-aa1b-33d886038596\",\"authority\":\"a5b26cd8-ef89-461d-8b87-31c133149f27\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA monster in \u003cspan data-glossary-id=\\\"UT22084-068-021-9812\\\"\u003eUnbearably Terrifying\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"tailed creature\",\"tibetan\":\"ལང་ཀུ་དི་ཀ\",\"sanskrit\":\"lāṅgulika\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lang ku di ka\"}},{\"uuid\":\"33b7e50c-8c3e-48db-875b-2e3f67eb5fce\",\"authority\":\"f5252f76-b49f-4bd3-97aa-dd14039b886e\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA mountain in \u003cspan data-glossary-id=\\\"UT22084-068-021-9338\\\"\u003eJambudvīpa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Ṭakaśobho\",\"tibetan\":\"ཊ་ཀ་ཤོ་བྷོ།\",\"sanskrit\":\"ṭakaśobho\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"Ta ka sho bho\"}},{\"uuid\":\"5925ce89-dce3-4af3-823c-054f414b9438\",\"authority\":\"6240be54-8ff5-4424-96ca-d1092d8372c5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA virtuous \u003cspan data-glossary-id=\\\"UT22084-068-021-8562\\\"\u003enāga\u003c/span\u003e king. \u003c/p\u003e\",\"names\":{\"english\":\"Takṣaka\",\"tibetan\":\"འཇོག་པོ།\",\"sanskrit\":\"takṣaka\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’jog po\"}},{\"uuid\":\"64795d8d-8e2e-462a-9010-004e8868b97f\",\"authority\":\"b1efe3ee-36be-467d-8ce5-a152a65b0b68\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA mountain in \u003cspan data-glossary-id=\\\"UT22084-068-021-9398\\\"\u003eKuru\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Tamer of Deer Enemies\",\"tibetan\":\"རི་དགས་ཀྱི་དགྲ་དུལ་བ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ri dags kyi dgra dul ba\"}},{\"uuid\":\"37261716-d4fb-4915-bc80-5bdee6dbb1f8\",\"authority\":\"cd272975-568a-4502-8164-1eab5cc2d644\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA pleasure garden in \u003cspan data-glossary-id=\\\"UT22084-068-021-9074\\\"\u003eEnraptured by and Attached to Song\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Tamer of Madness\",\"tibetan\":\"མྱོས་འགྲོ་འདུལ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"myos ’gro ’dul\"}},{\"uuid\":\"84a1e89f-256e-4326-a327-15193cb00c08\",\"authority\":\"3c628c72-2601-41e3-b8eb-27cd9a1105b5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA forest on \u003cspan data-glossary-id=\\\"UT22084-068-021-8989\\\"\u003eDeer Abode\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Tangled Forest\",\"tibetan\":\"རལ་པ་ཅན།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ral pa can\"}},{\"uuid\":\"7b66bf3c-1d0a-4628-a5e9-d19a16462412\",\"authority\":\"6f63ad77-60bd-4894-af34-b85d787ee5f5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the sixteen realms that surround the \u003cspan\u003e\u003cspan data-glossary-id=\\\"UT22084-068-021-9277\\\"\u003eHell of Heat\u003c/span\u003e\u003c/span\u003e. \u003c/p\u003e\",\"names\":{\"english\":\"Teeming with Snakes\",\"tibetan\":\"སྦྲུལ་འཁྱིལ་བ་ལྟ་བུ།\",\"sanskrit\":\"nāgāvarta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sbrul ’khyil ba lta bu\"}},{\"uuid\":\"e419cc7e-5be4-4725-ab1c-535706f0cd40\",\"authority\":\"50455ffe-57ed-4802-83d7-95c67b3ab35e\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eTen wisdom powers unique to a tathāgata: (1) the knowledge of what is possible and not possible, (2) the knowledge of the \u003cspan data-glossary-id=\\\"UT22084-068-021-8583\\\"\u003eripening\u003c/span\u003e of karma, (3) the knowledge of the variety of aspirations, (4) the knowledge of the variety of natures, (5) the knowledge of the different levels of capabilities, (6) the knowledge of the destinations of all paths, (7) the knowledge of various states of meditation, (8) the knowledge of remembering previous lives, (9) the knowledge of deaths and rebirths, and (10) the knowledge of the cessation of defilements.\u003c/p\u003e\",\"names\":{\"english\":\"ten powers\",\"tibetan\":\"སྟོབས་བཅུ།\",\"sanskrit\":\"daśabala\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"stobs bcu\"}},{\"uuid\":\"2685de11-0a58-401f-b1dd-5bf713c9ac7d\",\"authority\":\"5829cbde-4acd-426a-abfe-837963bdda67\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAbstaining from \u003cspan data-glossary-id=\\\"UT22084-068-021-8545\\\"\u003ekilling\u003c/span\u003e, \u003cspan data-glossary-id=\\\"UT22084-068-021-8605\\\"\u003etaking what is not given\u003c/span\u003e, \u003cspan data-glossary-id=\\\"UT22084-068-021-8593\\\"\u003esexual misconduct\u003c/span\u003e, \u003cspan data-glossary-id=\\\"UT22084-068-021-9903\\\"\u003elying\u003c/span\u003e, uttering \u003cspan data-glossary-id=\\\"UT22084-068-021-8508\\\"\u003edivisive talk\u003c/span\u003e, speaking \u003cspan data-glossary-id=\\\"UT22084-068-021-8535\\\"\u003eharsh words\u003c/span\u003e, \u003cspan data-glossary-id=\\\"UT22084-068-021-8494\\\"\u003echatter\u003c/span\u003e, \u003cspan data-glossary-id=\\\"UT22084-068-021-8501\\\"\u003ecovetousness\u003c/span\u003e, \u003cspan data-glossary-id=\\\"UT22084-068-021-8539\\\"\u003eill will\u003c/span\u003e, and \u003cspan data-glossary-id=\\\"UT22084-068-021-8628\\\"\u003ewrong views\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"ten virtues, ten virtuous actions\",\"tibetan\":\"དགེ་བ་བཅུ།\",\"sanskrit\":\"daśakuśala\",\"pali\":\"\",\"chinese\":\"\