་སྤྱན་རས་གཟིགས་དབང་ཕྱུག་ལ་འདི་སྐད་ཅེས་སྨྲས་སོ། །རིགས་ཀྱི་བུའམ་རིགས་ཀྱི་བུ་མོ་གང་ལ་ལ་ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ་ཟབ་མོ་སྤྱོད་པ་སྤྱད་པར་འདོད་པ་དེས་ཇི་ལྟར་བསླབ་པར་བྱ། དེ་སྐད་ཅེས་སྨྲས་པ་དང་། \\n\",\"folioNumber\":94,\"volumeNumber\":88},\"toh21\":{\"folioUuid\":\"1e784f79-2f7c-4f40-bbbb-32e8525bf481\",\"toh\":\"toh21\",\"tibetan\":\"དེ་ནས་སངས་རྒྱས་ཀྱི་མཐུས། ཚེ་དང་ལྡན་པ་ཤཱ་རིའི་བུས་བྱང་ཆུབ་སེམས་དཔའ་སེམས་དཔའ་ཆེན་པོ་འཕགས་པ་སྤྱན་རས་གཟིགས་དབང་ཕྱུག་ལ་འདི་\\nསྐད་ཅེས་སྨྲས་སོ། །རིགས་ཀྱི་བུའམ། རིགས་ཀྱི་བུ་མོ་གང་ལ་ལ་ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ་ཟབ་མོ་སྤྱོད་པ་སྤྱད་པར་འདོད་པ་དེས་ཇི་ལྟར་བསླབ་པར་བྱ། དེ་སྐད་ཅེས་སྨྲས་པ་དང་། \",\"folioNumber\":145,\"volumeNumber\":34}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":255,\"uuid\":\"95957669-a242-4f8d-a465-d771d99d1865\"},\"content\":[{\"type\":\"text\",\"text\":\"Then, due to the Buddha’s power, venerable \",\"attrs\":{\"start\":0,\"end\":43}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":43,\"end\":52},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"34b48087-ac26-49a1-8f0e-71b760f25b7e\",\"uuid\":\"a04072fe-2912-4df5-b225-5446d0f88c39\",\"toh\":null}},{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"05912d8d-f6a8-40cf-bb4d-fc2d8008c191\",\"label\":\"39\",\"uuid\":\"6ecfe25f-10c5-454f-ae5e-796cd9e72f15\",\"start\":52,\"end\":52,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" asked the bodhisattva great being, noble \",\"attrs\":{\"start\":52,\"end\":94}},{\"type\":\"text\",\"text\":\"Avalokiteśvara\",\"attrs\":{\"start\":94,\"end\":108},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"15f3a5cf-5d86-4439-b06f-5909aae6a9d2\",\"uuid\":\"f46d7f90-e254-4af2-bc98-b2c246360b5a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", “How should sons of noble family or daughters of noble family\",\"attrs\":{\"start\":108,\"end\":171},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"e6651694-a300-4892-b24a-100258083023\",\"label\":\"40\",\"uuid\":\"4ce502e4-3666-4de8-bf37-3a13219d829c\",\"start\":171,\"end\":171,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" train if they wish to engage in the practice of the profound perfection of wisdom?”\",\"attrs\":{\"start\":171,\"end\":255}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"ce892908-7d78-47bc-98f6-15ca9c5062dd\",\"sort\":285,\"type\":\"translation\",\"label\":\"1.5\",\"alignments\":{\"toh531\":{\"folioUuid\":\"35919386-b6cc-4b65-9eca-560424ebe9d2\",\"toh\":\"toh531\",\"tibetan\":\"བྱང་ཆུབ་སེམས་དཔའ་སེམས་དཔའ་ཆེན་པོ་འཕགས་པ་སྤྱན་རས་གཟིགས་དབང་ཕྱུག་གིས་ཚེ་དང་ལྡན་པ་ཤ་ར་དྭ་ཏིའི་བུ་ལ་འདི་སྐད་ཅེས་སྨྲས་སོ། །ཤཱ་རིའི་བུ་རིགས་ཀྱི་བུའམ་རིགས་ཀྱི་བུ་མོ་གང་ལ་ལ་ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ་ཟབ་མོ་སྤྱོད་པ་སྤྱད་པར་འདོད་པ་དེས་འདི་ལྟར་རྣམ་པར་\\nབལྟ་བར་བྱ་སྟེ། ཕུང་པོ་ལྔ་པོ་དེ་དག་ཀྱང་རང་བཞིན་གྱིས་སྟོང་པར་རྣམ་པར་ཡང་དག་པར་རྗེས་སུ་བལྟའོ། \",\"folioNumber\":94,\"volumeNumber\":88},\"toh21\":{\"folioUuid\":\"1e784f79-2f7c-4f40-bbbb-32e8525bf481\",\"toh\":\"toh21\",\"tibetan\":\"བྱང་ཆུབ་སེམས་དཔའ་སེམས་དཔའ་ཆེན་པོ་འཕགས་པ་སྤྱན་རས་གཟིགས་དབང་\\nཕྱུག་གིས་ཚེ་དང་ལྡན་པ་ཤ་ར་དྭ་ཏིའི་བུ་ལ་འདི་སྐད་ཅེས་སྨྲས་སོ། །ཤཱ་རིའི་བུ་རིགས་ཀྱི་བུའམ། རིགས་ཀྱི་བུ་མོ་གང་ལ་ལ་ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ་ཟབ་མོ་སྤྱོད་པ་སྤྱད་པར་འདོད་པ་དེས་འདི་ལྟར་རྣམ་པར་བལྟ་བར་བྱ་སྟེ། ཕུང་པོ་ལྔ་པོ་དེ་དག་ཀྱང་རང་བཞིན་གྱིས་སྟོང་\\nཔར་རྣམ་པར་ཡང་དག་པར་རྗེས་སུ་བལྟའོ། །\",\"folioNumber\":145,\"volumeNumber\":34}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":338,\"uuid\":\"ce892908-7d78-47bc-98f6-15ca9c5062dd\"},\"content\":[{\"type\":\"text\",\"text\":\"The bodhisattva great being, noble \",\"attrs\":{\"start\":0,\"end\":35}},{\"type\":\"text\",\"text\":\"Avalokiteśvara\",\"attrs\":{\"start\":35,\"end\":49},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"15f3a5cf-5d86-4439-b06f-5909aae6a9d2\",\"uuid\":\"c993fc9b-8f56-469b-84dc-dd8b404cd468\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", replied to venerable \",\"attrs\":{\"start\":49,\"end\":72}},{\"type\":\"text\",\"text\":\"Śāradvatīputra\",\"attrs\":{\"start\":72,\"end\":86},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9998ea3b-be7b-4ae9-abd9-6be2a6958171\",\"uuid\":\"cfe43123-2a27-428e-b5d2-d5e5d5b720ad\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\",\",\"attrs\":{\"start\":86,\"end\":87},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"fb289d4f-3ec0-4b47-bc7f-b1fc7aed6652\",\"label\":\"41\",\"uuid\":\"bdf6e56c-8463-45b9-9d66-323562050cd3\",\"start\":87,\"end\":87,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" “\",\"attrs\":{\"start\":87,\"end\":89}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":89,\"end\":98},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"34b48087-ac26-49a1-8f0e-71b760f25b7e\",\"uuid\":\"aeffa90a-a59f-4da2-b6f0-078b29afb227\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", sons of noble family or daughters of noble family who wish to engage in the practice of the profound perfection of wisdom should see things in this way: they should correctly observe the five \",\"attrs\":{\"start\":98,\"end\":292}},{\"type\":\"text\",\"text\":\"aggregates\",\"attrs\":{\"start\":292,\"end\":302},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9a2298bf-1466-4e8f-9bbb-82d588aff4a3\",\"uuid\":\"e2d3e262-d4d8-4f53-870a-28ae62c4981c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" to be empty of an intrinsic nature.\",\"attrs\":{\"start\":302,\"end\":338},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"565899fd-b08a-4b36-a7d6-f4b338b709be\",\"label\":\"42\",\"uuid\":\"32c45978-1049-42db-8c46-3d015e92659e\",\"start\":338,\"end\":338,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"eb757806-fcfd-4a92-9cc4-321d0322921d\",\"sort\":298,\"type\":\"translation\",\"label\":\"1.6\",\"alignments\":{\"toh531\":{\"folioUuid\":\"35919386-b6cc-4b65-9eca-560424ebe9d2\",\"toh\":\"toh531\",\"tibetan\":\"གཟུགས་སྟོང་པའོ། །སྟོང་པ་ཉིད་གཟུགས་སོ། །གཟུགས་ལས་སྟོང་པ་ཉིད་གཞན་མ་ཡིན། སྟོང་པ་ཉིད་ལས་ཀྱང་གཟུགས་གཞན་མ་ཡིན་ནོ། དེ་བཞིན་དུ་ཚོར་བ་དང་། འདུ་\\nཤེས་དང་། འདུ་བྱེད་དང་། རྣམ་པར་ཤེས་པ་རྣམས་སྟོང་པའོ། །\",\"folioNumber\":94,\"volumeNumber\":88},\"toh21\":{\"folioUuid\":\"1e784f79-2f7c-4f40-bbbb-32e8525bf481\",\"toh\":\"toh21\",\"tibetan\":\"གཟུགས་སྟོང་པའོ། །སྟོང་པ་ཉིད་གཟུགས་སོ། །གཟུགས་ལས་སྟོང་པ་ཉིད་གཞན་མ་ཡིན། སྟོང་པ་ཉིད་ལས་ཀྱང་གཟུགས་གཞན་མ་ཡིན་ནོ། །དེ་བཞིན་དུ་ཚོར་བ་དང་། འདུ་ཤེས་དང་། འདུ་བྱེད་དང་། རྣམ་པར་ཤེས་\\nཔ་རྣམས་སྟོང་པའོ། །\",\"folioNumber\":145,\"volumeNumber\":34}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":189,\"uuid\":\"eb757806-fcfd-4a92-9cc4-321d0322921d\"},\"content\":[{\"type\":\"text\",\"text\":\"“Form is empty.\",\"attrs\":{\"start\":0,\"end\":15},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"34bc3db5-e384-4b4b-8b05-dd795a4d2a77\",\"label\":\"43\",\"uuid\":\"013cfeef-b171-4da2-9294-534767ef76a5\",\"start\":15,\"end\":15,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":15,\"end\":16}},{\"type\":\"text\",\"text\":\"Emptiness\",\"attrs\":{\"start\":16,\"end\":25},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c5fa93ab-c81f-4ae8-b5d6-ee67312e9a72\",\"uuid\":\"76d1bedd-503e-40d5-a2a3-784fc1b0b7c8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is form. \",\"attrs\":{\"start\":25,\"end\":35}},{\"type\":\"text\",\"text\":\"Emptiness\",\"attrs\":{\"start\":35,\"end\":44},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c5fa93ab-c81f-4ae8-b5d6-ee67312e9a72\",\"uuid\":\"7406caa8-fb27-4726-a7b2-06b02ae716ea\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is not other than form, and form is also not other than \",\"attrs\":{\"start\":44,\"end\":101}},{\"type\":\"text\",\"text\":\"emptiness\",\"attrs\":{\"start\":101,\"end\":110},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c5fa93ab-c81f-4