7e\",\"uuid\":\"fe6147f6-e59d-497f-b0b2-50855f267ecd\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", therefore, all phenomena are \",\"attrs\":{\"start\":10,\"end\":41}},{\"type\":\"text\",\"text\":\"emptiness\",\"attrs\":{\"start\":41,\"end\":50},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c5fa93ab-c81f-4ae8-b5d6-ee67312e9a72\",\"uuid\":\"ea1c05b6-afcb-429a-b840-5abc342ae013\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"; they are without characteristics, unborn, unceasing, without stains, without absence of stains,\",\"attrs\":{\"start\":50,\"end\":147},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"9354294e-9ee9-4926-bd53-8a97f19e97e4\",\"label\":\"46\",\"uuid\":\"6afa0f01-36ed-4617-8b54-9571b3ef343b\",\"start\":147,\"end\":147,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" not deficient, and not complete.\",\"attrs\":{\"start\":147,\"end\":180}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"536ff42e-f443-4322-9b5b-1a920fbf00ba\",\"sort\":320,\"type\":\"translation\",\"label\":\"1.8\",\"alignments\":{\"toh531\":{\"folioUuid\":\"35919386-b6cc-4b65-9eca-560424ebe9d2\",\"toh\":\"toh531\",\"tibetan\":\"ཤཱ་རིའི་བུ་དེ་ལྟ་བས་ན་སྟོང་པ་ཉིད་ལ་[F.95.a]གཟུགས་མེད། ཚོར་བ་མེད། འདུ་ཤེས་མེད། འདུ་བྱེད་རྣམས་མེད། རྣམ་པར་ཤེས་པ་མེད། མིག་མེད། རྣ་བ་མེད། སྣ་མེད། ལྕེ་མེད། ལུས་མེད། ཡིད་མེད། གཟུགས་མེད། སྒྲ་མེད། དྲི་མེད། རོ་མེད། རེག་བྱ་མེད། ཆོས་མེད་དོ། །\",\"folioNumber\":94,\"volumeNumber\":88},\"toh21\":{\"folioUuid\":\"1e784f79-2f7c-4f40-bbbb-32e8525bf481\",\"toh\":\"toh21\",\"tibetan\":\"ཤཱ་རིའི་བུ་དེ་ལྟ་བས་ན་སྟོང་པ་ཉིད་ལ་གཟུགས་\\nམེད། ཚོར་བ་མེད། འདུ་ཤེས་མེད། འདུ་བྱེད་རྣམས་མེད། རྣམ་པར་ཤེས་པ་མེད། མིག་མེད། རྣ་བ་མེད། སྣ་མེད། ལྕེ་མེད། ལུས་མེད། ཡིད་མེད། གཟུགས་མེད། སྒྲ་མེད། དྲི་མེད། རོ་མེད། རེག་བྱ་མེད། ཆོས་མེད་དོ། །\",\"folioNumber\":145,\"volumeNumber\":34}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":240,\"uuid\":\"536ff42e-f443-4322-9b5b-1a920fbf00ba\"},\"content\":[{\"type\":\"text\",\"text\":\"“\",\"attrs\":{\"start\":0,\"end\":1}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":1,\"end\":10},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"34b48087-ac26-49a1-8f0e-71b760f25b7e\",\"uuid\":\"a7e292b7-d141-4a8b-b96d-49724e409a81\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", therefore, in \",\"attrs\":{\"start\":10,\"end\":26}},{\"type\":\"text\",\"text\":\"emptiness\",\"attrs\":{\"start\":26,\"end\":35},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c5fa93ab-c81f-4ae8-b5d6-ee67312e9a72\",\"uuid\":\"612d1324-0f8d-407b-b0e6-c97eff711baf\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" there is no form, no feeling, no perception, no formations, no consciousness, no eye, no ear, no nose, no tongue, no body, no mind, no form, no sound, no smell, no taste, no texture, and no mental object.\",\"attrs\":{\"start\":35,\"end\":240}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"2bc29a07-d54f-4df1-9847-682d5a2aa5ac\",\"sort\":326,\"type\":\"translation\",\"label\":\"1.9\",\"alignments\":{\"toh531\":{\"folioUuid\":\"43cd2451-ba91-4ade-8277-3d0078b4da7a\",\"toh\":\"toh531\",\"tibetan\":\"མིག་གི་ཁམས་\\nམེད་པ་ནས་ཡིད་ཀྱི་ཁམས་མེད། ཡིད་ཀྱི་རྣམ་པར་ཤེས་པའི་ཁམས་ཀྱི་བར་དུ་ཡང་མེད་དོ། །\",\"folioNumber\":95,\"volumeNumber\":88},\"toh21\":{\"folioUuid\":\"1e784f79-2f7c-4f40-bbbb-32e8525bf481\",\"toh\":\"toh21\",\"tibetan\":\"མིག་གི་ཁམས་མེད་[F.145.b]པ་ནས་ཡིད་ཀྱི་ཁམས་མེད་ཡིད་ཀྱི་རྣམ་པར་ཤེས་པའི་ཁམས་ཀྱི་བར་དུ་ཡང་མེད་དོ། །\",\"folioNumber\":145,\"volumeNumber\":34}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":118,\"uuid\":\"2bc29a07-d54f-4df1-9847-682d5a2aa5ac\"},\"content\":[{\"type\":\"text\",\"text\":\"“There is no \",\"attrs\":{\"start\":0,\"end\":13}},{\"type\":\"text\",\"text\":\"element\",\"attrs\":{\"start\":13,\"end\":20},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4c329be4-54f3-4631-adba-c73348323413\",\"uuid\":\"a2538c78-5d10-47da-9456-6d4f73adc1e3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of the eye, up to no \",\"attrs\":{\"start\":20,\"end\":42}},{\"type\":\"text\",\"text\":\"element\",\"attrs\":{\"start\":42,\"end\":49},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4c329be4-54f3-4631-adba-c73348323413\",\"uuid\":\"0aaf6be5-955a-4305-912c-8fea31298094\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of the mind, and further up to no \",\"attrs\":{\"start\":49,\"end\":84}},{\"type\":\"text\",\"text\":\"element\",\"attrs\":{\"start\":84,\"end\":91},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4c329be4-54f3-4631-adba-c73348323413\",\"uuid\":\"1286a015-a430-4873-a790-b95659c4974d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of the mind consciousness.\",\"attrs\":{\"start\":91,\"end\":118},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"75b57a5e-61cf-4ffb-bebe-53bdb52e3194\",\"label\":\"47\",\"uuid\":\"a1b5d73e-8aaf-4656-aaaa-33fc7bc91659\",\"start\":118,\"end\":118,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"c1079ce6-f471-41dd-8f20-b8839839728e\",\"sort\":337,\"type\":\"translation\",\"label\":\"1.10\",\"alignments\":{\"toh531\":{\"folioUuid\":\"43cd2451-ba91-4ade-8277-3d0078b4da7a\",\"toh\":\"toh531\",\"tibetan\":\"མ་རིག་པ་མེད། མ་རིག་པ་ཟད་པ་མེད་པ་ནས་རྒ་ཤི་མེད། རྒ་ཤི་ཟད་པའི་བར་དུ་ཡང་མེད་དོ། །\",\"folioNumber\":95,\"volumeNumber\":88},\"toh21\":{\"folioUuid\":\"4b82b514-9242-4641-8b24-f1677dd52c59\",\"toh\":\"toh21\",\"tibetan\":\"མ་རིག་པ་མེད། མ་རིག་པ་ཟད་པ་མེད་པ་ནས་རྒ་ཤི་མེད། རྒ་ཤི་ཟད་པའི་བར་དུ་ཡང་མེད་དོ། །\",\"folioNumber\":145,\"volumeNumber\":34}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":117,\"uuid\":\"c1079ce6-f471-41dd-8f20-b8839839728e\"},\"content\":[{\"type\":\"text\",\"text\":\"“There is no ignorance and no exhaustion of ignorance, up to no aging and death and no exhaustion of aging and death.\",\"attrs\":{\"start\":0,\"end\":117}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"c8dc6454-a277-4416-befe-f986df4ee096\",\"sort\":339,\"type\":\"translation\",\"label\":\"1.11\",\"alignments\":{\"toh531\":{\"folioUuid\":\"43cd2451-ba91-4ade-8277-3d0078b4da7a\",\"toh\":\"toh531\",\"tibetan\":\"སྡུག་བསྔལ་བ་དང་། ཀུན་འབྱུང་བ་དང་། འགོག་པ་དང་། ལམ་མེད། ཡེ་ཤེས་མེད། \\nཐོབ་པ་མེད། མ་ཐོབ་པ་ཡང་མེད་དོ། །\",\"folioNumber\":95,\"volumeNumber\":88},\"toh21\":{\"folioUuid\":\"4b82b514-9242-4641-8b24-f1677dd52c59\",\"toh\":\"toh21\",\"tibetan\":\"སྡུག་བསྔལ་བ་དང་། ཀུན་འབྱུང་བ་དང་། འགོག་པ་དང་། ལམ་མེད། ཡེ་ཤེས་མེད། \\nཐོབ་པ་མེད། མ་ཐོབ་པ་ཡང་མེད་དོ། །\",\"folioNumber\":145,\"volumeNumber\":34}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":131,\"uuid\":\"c8dc6454-a277-4416-befe-f986df4ee096\"},\"content\":[{\"type\":\"text\",\"text\":\"“There is no suffering, no origin of suffering, no cessation of suffering, no path, no wisdom,\",\"attrs\":{\"start\":0,\"end\":94},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"5b7db543-5f2e-4b1b-a9c7-be364b887a66\",\"label\":\"48\",\"uuid\":\"75f7946c-bacf-4ab9-8a88-b4b9e0a56fe5\",\"start\":94,\"end\":94,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" no attainment, and no nonattainment.\",\"attrs\":{\"start\":94,\"end\":131},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"c06efba5-a82c-424f-9440-addf2bc9de86\",\"label\":\"49\",\"uuid\":\"4b7cde5e-2380-4977-a3d1-a2f9f6a87dfa\",\"start\":131,\"end\":131,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"68dbe41a-5817-4160-ba54-68f8fd696570\",\"sort\":344,\"type\":\"translation\",\"label\":\"1.12\",\"alignments\":{\"toh531\":{\"folioUuid\":\"43cd2451-ba91-4ade-8277-3d0078b4da7a\",\"toh\":\"toh531\",\"tibetan\":\"ཤཱ་རིའི་བུ་དེ་ལྟ་བས་ན་བྱང་ཆུབ་སེམས་དཔའ་རྣམས་ཐོབ་པ་མེད་པའི་ཕྱིར། ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ་ལ་བརྟེན་ཅིང་གནས་ཏེ། སེམས་ལ་སྒྲིབ་པ་མེད་པས་སྐྲག་པ་མེད་དེ། ཕྱིན་ཅི་ལོག་ལས་ཤིན་ཏུ་འདས་ནས་མྱ་ངན་ལས་འདས་པའི་\\nམཐར་ཕྱིན་ཏོ། །\",\"folioNumber\":95,\"volumeNumber\":88},\"toh21\":{\"folioUuid\":\"4b82b514-9242-4641-8b24-f1677dd52c59\",\"toh\":\"toh21\",\"tibetan\":\"ཤཱ་རིའི་བུ་དེ་ལྟ་བས་ན་བྱང་ཆུབ་སེམས་དཔའ་རྣམས་ཐོབ་པ་མེད་པའི་ཕྱིར། ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ་ལ་བརྟེན་ཅིང་གནས་ཏེ། སེམས་ལ་སྒྲིབ་པ་མེད་པས་སྐྲག་པ་མེད་དེ། ཕྱིན་ཅི་ལོག་ལས་ཤིན་ཏུ་འདས་ནས་མྱ་ངན་ལས་\\nའདས་པའི་མཐར་ཕྱིན་ཏོ། །\",\"folioNumber\":145,\"volumeNumber\":34}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":242,\"uuid\":\"68dbe41a-5817-4160-ba54-68f8fd696570\"},\"content\":[{\"type\":\"text\",\"text\":\"“\",\"attrs\":{\"start\":0,\"end\":1}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":1,\"end\":10},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"34b48087-ac26-49a1-8f0e-71b760f25b7e\",\"uuid\":\"c8ce8c78-3528-462f-8e09-27d2588a733f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", therefore, since bodhisattvas have no attainment, they rely upon and dwell in the perfection of wisdom.\",\"attrs\":{\"start\":10,\"end\":115},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"76271c11-98e2-4862-927c-7b4427cd7e5f\",\"label\":\"50\",\"uuid\":\"2078c390-8379-4fd7-8d57-c7c6e4525f2e\",\"start\":115,\"end\":115,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" Because their minds have no veils, they have no fear. Having utterly\",\"attrs\":{\"start\":115,\"end\":184},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"675263fc-d1c8-48e3-bc14-5c92df414eb5\",\"label\":\"51\",\"uuid\":\"3370744b-e54c-467b-ad05-bb8fa3cd98f2\",\"start\":184,\"end\":184,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" gone beyond error, they reach the culmination of nirvāṇa.\",\"attrs\":{\"start\":184,\"end\":242}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"b44340ae-3c0e-407d-951d-40177123409f\",\"sort\":352,\"type\":\"translation\",\"label\":\"1.13\",\"alignments\":{\"toh531\":{\"folioUuid\":\"43cd2451-ba91-4ade-8277-3d0078b4da7a\",\"toh\":\"toh531\",\"tibetan\":\"དུས་གསུམ་དུ་རྣམ་པར་བཞུགས་པའི་སངས་རྒྱས་ཐམས་ཅད་ཀྱང་ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ་ལ་བརྟེན་ནས། བླ་ན་མེད་པ་ཡང་དག་པར་རྫོགས་པའི་བྱང་ཆུབ་ཏུ་མངོན་པར་རྫོགས་པར་སངས་རྒྱས་སོ། །\",\"folioNumber\":95,\"volumeNumber\":88},\"toh21\":{\"folioUuid\":\"4b82b514-9242-4641-8b24-f1677dd52c59\",\"toh\":\"toh21\",\"tibetan\":\"དུས་གསུམ་དུ་རྣམ་པར་བཞུགས་པའི་སངས་རྒྱས་ཐམས་ཅད་ཀྱང་། ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ་ལ་བརྟེན་ནས། བླ་ན་མེད་པ་ཡང་དག་པར་རྫོགས་པའི་བྱང་ཆུབ་ཏུ་མངོན་པར་རྫོགས་པར་སངས་རྒྱས་སོ། །\",\"folioNumber\":145,\"volumeNumber\":34}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":154,\"uuid\":\"b44340ae-3c0e-407d-951d-40177123409f\"},\"content\":[{\"type\":\"text\",\"text\":\"“All the buddhas who reside in the three times have likewise fully awakened to unsurpassed and perfect awakening by relying upon the perfection of wisdom.\",\"attrs\":{\"start\":0,\"end\":154}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"e351e324-217d-4bd9-9aa3-129b29839640\",\"sort\":354,\"type\":\"translation\",\"label\":\"1.14\",\"alignments\":{\"toh531\":{\"folioUuid\":\"43cd2451-ba91-4ade-8277-3d0078b4da7a\",\"toh\":\"toh531\",\"tibetan\":\"དེ་ལྟ་བས་ན་ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པའི་སྔགས། རིག་\\nཔ་ཆེན་པོའི་སྔགས། བླ་ན་མེད་པའི་སྔགས། མི་མཉམ་པ་དང་མཉམ་པའི་སྔགས། སྡུག་བསྔལ་ཐམས་ཅད་རབ་ཏུ་ཞི་བར་བྱེད་པའི་སྔགས། མི་བརྫུན་པས་ན་བདེན་པར་ཤེས་པར་བྱ་སྟེ། \",\"folioNumber\":95,\"volumeNumber\":88},\"toh21\":{\"folioUuid\":\"4b82b514-9242-4641-8b24-f1677dd52c59\",\"toh\":\"toh21\",\"tibetan\":\"དེ་ལྟ་བས་ན་ཤེས་རབ་ཀྱི་\\nཕ་རོལ་ཏུ་ཕྱིན་པའི་སྔགས། རིག་པ་ཆེན་པོའི་སྔགས། བླ་ན་མེད་པའི་སྔགས། མི་མཉམ་པ་དང་མཉམ་པའི་སྔགས། སྡུག་བསྔལ་ཐམས་ཅད་རབ་ཏུ་ཞི་བར་བྱེད་པའི་སྔགས། མི་རྫུན་པས་ན་བདེན་པར་ཤེས་པར་བྱ་སྟེ། \",\"folioNumber\":145,\"volumeNumber\":34}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":257,\"uuid\":\"e351e324-217d-4bd9-9aa3-129b29839640\"},\"content\":[{\"type\":\"text\",\"text\":\"“Therefore,\",\"attrs\":{\"start\":0,\"end\":11},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"0c3e7a50-33b1-4ff6-95b4-4b88172b7982\",\"label\":\"52\",\"uuid\":\"2aa681d9-0853-43bb-8e63-5b8ee80960b5\",\"start\":11,\"end\":11,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" the mantra\",\"attrs\":{\"start\":11,\"end\":22},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"9a522107-27ec-4868-8bdc-b624abf3c462\",\"label\":\"53\",\"uuid\":\"3bad42c2-cecc-4afb-9845-235d4ccadf09\",\"start\":22,\"end\":22,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" of the perfection of wisdom is the mantra of great knowledge, the unsurpassed mantra, the mantra that is equal to the unequaled, and the mantra that utterly pacifies all suffering. Since it is not false, it should be known to be true.\",\"attrs\":{\"start\":22,\"end\":257}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"ff35fd29-08f8-47c5-b129-f6c90c6a734f\",\"sort\":360,\"type\":\"translation\",\"label\":\"1.15\",\"alignments\":{\"toh531\":{\"folioUuid\":\"43cd2451-ba91-4ade-8277-3d0078b4da7a\",\"toh\":\"toh531\",\"tibetan\":\"ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པའི་སྔགས་སྨྲས་པ། ཏདྱ་ཐཱ། ག་ཏེ་ག་ཏེ་པཱ་ར་ག་ཏེ། པཱ་ར་སཾ་ག་\\nཏེ། བོ་དྷི་སྭཱ་ཧཱ། \",\"folioNumber\":95,\"volumeNumber\":88},\"toh21\":{\"folioUuid\":\"4b82b514-9242-4641-8b24-f1677dd52c59\",\"toh\":\"toh21\",\"tibetan\":\"ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པའི་སྔགས་\\nསྨྲས་པ། ཏདྱ་ཐཱ། ག་ཏེ་ག་ཏེ་པཱ་ར་ག་ཏེ། པཱ་ར་སཾ་ག་ཏེ། བོ་དྷི་སྭཱ་ཧཱ། \",\"folioNumber\":145,\"volumeNumber\":34}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":56,\"uuid\":\"ab55294d-29de-4fde-9760-cd12b628076b\"},\"content\":[{\"type\":\"text\",\"text\":\"“The mantra of the perfection of wisdom is stated thus:\",\"attrs\":{\"start\":0,\"end\":55},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"61caee6c-81ff-45eb-b5be-ed61d424afaa\",\"label\":\"54\",\"uuid\":\"af12c80b-b974-416e-9d7e-5d36bf6e59c0\",\"start\":55,\"end\":55,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":55,\"end\":56}}]},{\"type\":\"paragraph\",\"attrs\":{\"start\":56,\"end\":107,\"hasIndent\":true,\"indentUuid\":\"b8902f2e-717c-4baa-9266-82c08511dc7d\"},\"content\":[{\"type\":\"text\",\"text\":\"tadyathā\",\"attrs\":{\"start\":56,\"end\":64},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":56,\"end\":64,\"uuid\":\"af1ba666-410d-494f-ae78-f38e7e0a2238\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}},{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"6527bb40-f128-450a-a3be-933a63434947\",\"label\":\"55\",\"uuid\":\"1f67f4ba-add9-4ba0-ac80-f2d00bccb7c7\",\"start\":64,\"end\":64,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":64,\"end\":65}},{\"type\":\"text\",\"text\":\"gate gate pāragate pārasaṃgate bodhi svāhā\",\"attrs\":{\"start\":65,\"end\":107},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":65,\"end\":107,\"uuid\":\"b97944e6-6651-4f01-9577-80af11309768\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}},{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"942aca84-15a7-4f68-a94e-e207c74c516c\",\"label\":\"56\",\"uuid\":\"e1ca589a-67b4-418b-a8eb-bc96155ee694\",\"start\":107,\"end\":107,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"b6a7c517-5651-41b9-a14f-b6f9d2b43ee7\",\"sort\":368,\"type\":\"translation\",\"label\":\"1.16\",\"alignments\":{\"toh531\":{\"folioUuid\":\"43cd2451-ba91-4ade-8277-3d0078b4da7a\",\"toh\":\"toh531\",\"tibetan\":\"ཤཱ་རིའི་བུ་བྱང་ཆུབ་སེམས་དཔའ་སེམས་དཔའ་ཆེན་པོས་དེ་ལྟར་ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ་ཟབ་མོ་ལ་བསླབ་པར་བྱའོ། །\",\"folioNumber\":95,\"volumeNumber\":88},\"toh21\":{\"folioUuid\":\"4b82b514-9242-4641-8b24-f1677dd52c59\",\"toh\":\"toh21\",\"tibetan\":\"ཤཱ་རིའི་བུ་བྱང་ཆུབ་སེམས་དཔའ་སེམས་དཔའ་ཆེན་པོས་དེ་ལྟར་ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ་ཟབ་མོ་ལ་བསླབ་པར་བྱའོ། །\",\"folioNumber\":145,\"volumeNumber\":34}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":105,\"uuid\":\"b6a7c517-5651-41b9-a14f-b6f9d2b43ee7\"},\"content\":[{\"type\":\"text\",\"text\":\"“\",\"attrs\":{\"start\":0,\"end\":1}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":1,\"end\":10},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"34b48087-ac26-49a1-8f0e-71b760f25b7e\",\"uuid\":\"5d59b28f-4e5f-4564-8599-016645723d28\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", this is the way a bodhisattva great being should train in the profound perfection of wisdom.”\",\"attrs\":{\"start\":10,\"end\":105}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"78e150b0-117a-4392-b695-e68dfe649560\",\"sort\":372,\"type\":\"translation\",\"label\":\"1.17\",\"alignments\":{\"toh531\":{\"folioUuid\":\"43cd2451-ba91-4ade-8277-3d0078b4da7a\",\"toh\":\"toh531\",\"tibetan\":\"དེ་ནས་བཅོམ་ལྡན་འདས་ཏིང་ངེ་འཛིན་དེ་ལས་བཞེངས་ཏེ། བྱང་ཆུབ་སེམས་དཔའ་སེམས་དཔའ་ཆེན་པོ་འཕགས་པ་སྤྱན་རས་གཟིགས་དབང་\\nཕྱུག་ལ་ལེགས་སོ་ཞེས་བྱ་བ་བྱིན་ནས། ལེགས་སོ་ལེགས་སོ། །རིགས་ཀྱི་བུ་དེ་དེ་བཞིན་ནོ། །རིགས་ཀྱི་བུ་དེ་དེ་བཞིན་ཏེ། ཇི་ལྟར་ཁྱོད་ཀྱིས་བསྟན་པ་དེ་བཞིན་དུ་ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ་ཟབ་མོ་ལ་སྤྱད་པར་བྱ་སྟེ། དེ་བཞིན་གཤེགས་པ་རྣམས་ཀྱང་རྗེས་སུ་ཡི་རང་ངོ་། །\",\"folioNumber\":95,\"volumeNumber\":88},\"toh21\":{\"folioUuid\":\"4b82b514-9242-4641-8b24-f1677dd52c59\",\"toh\":\"toh21\",\"tibetan\":\"དེ་ནས་བཅོམ་ལྡན་འདས་ཏིང་ངེ་འཛིན་དེ་ལས་བཞེངས་ཏེ། བྱང་ཆུབ་\\nསེམས་དཔའ་སེམས་དཔའ་ཆེན་པོ་འཕགས་པ་སྤྱན་རས་གཟིགས་དབང་ཕྱུག་ལ་ལེགས་སོ་ཞེས་བྱ་བ་བྱིན་ནས། ལེགས་སོ་ལེགས་སོ། །རིགས་ཀྱི་བུ་དེ་དེ་བཞིན་ནོ། །རིགས་ཀྱི་བུ་དེ་དེ་བཞིན་ཏེ། ཇི་ལྟར་ཁྱོད་ཀྱིས་བསྟན་པ་དེ་བཞིན་དུ་ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་\\nཔ་ཟབ་མོ་ལ་སྤྱད་པར་བྱ་སྟེ། དེ་བཞིན་གཤེགས་པ་རྣམས་ཀྱང་རྗེས་སུ་ཡི་རང་ངོ་། །\",\"folioNumber\":145,\"volumeNumber\":34}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":352,\"uuid\":\"78e150b0-117a-4392-b695-e68dfe649560\"},\"content\":[{\"type\":\"text\",\"text\":\"Then the Blessed One arose from that absorption and gave his approval to the bodhisattva great being, noble \",\"attrs\":{\"start\":0,\"end\":108}},{\"type\":\"text\",\"text\":\"Avalokiteśvara\",\"attrs\":{\"start\":108,\"end\":122},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"15f3a5cf-5d86-4439-b06f-5909aae6a9d2\",\"uuid\":\"13394a73-2097-4ca9-aa59-c879fd2452d0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", saying, “Excellent!\",\"attrs\":{\"start\":122,\"end\":143},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"4f03546e-bfcc-42c6-82bd-0c71ba145968\",\"label\":\"57\",\"uuid\":\"dcda47fe-d402-4bf1-9b60-0243f85a1ce5\",\"start\":143,\"end\":143,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" Excellent! Son of noble family, it is like that. Son of noble family, it is like that. The profound perfection of wisdom should be practiced just as you have taught, and even the thus-gone ones will rejoice.”\",\"attrs\":{\"start\":143,\"end\":352}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"c5f37d38-04fd-4dee-bd78-dcc1339ac3f2\",\"sort\":378,\"type\":\"translation\",\"label\":\"1.18\",\"alignments\":{\"toh531\":{\"folioUuid\":\"43cd2451-ba91-4ade-8277-3d0078b4da7a\",\"toh\":\"toh531\",\"tibetan\":\"བཅོམ་ལྡན་[F.95.b]འདས་ཀྱིས་དེ་སྐད་ཅེས་བཀའ་སྩལ་ནས། ཚེ་དང་ལྡན་པ་ཤ་ར་དྭ་ཏིའི་བུ་དང་། བྱང་ཆུབ་སེམས་དཔའ་སེམས་དཔའ་ཆེན་པོ་འཕགས་པ་སྤྱན་རས་གཟིགས་དབང་ཕྱུག་དང་། ཐམས་ཅད་དང་ལྡན་པའི་འཁོར་དེ་དང་། ལྷ་དང་། མི་དང་། ལྷ་མ་ཡིན་དང་། དྲི་ཟར་བཅས་པའི་འཇིག་རྟེན་ཡི་\\nརངས་ཏེ། བཅོམ་ལྡན་འདས་ཀྱིས་གསུངས་པ་ལ་མངོན་པར་བསྟོད་དོ། །\",\"folioNumber\":95,\"volumeNumber\":88},\"toh21\":{\"folioUuid\":\"4b82b514-9242-4641-8b24-f1677dd52c59\",\"toh\":\"toh21\",\"tibetan\":\"བཅོམ་ལྡན་འདས་ཀྱིས་དེ་སྐད་ཅེས་བཀའ་སྩལ་ནས། ཚེ་དང་ལྡན་པ་ཤ་ར་དྭ་ཏིའི་བུ་དང་། བྱང་ཆུབ་སེམས་དཔའ་སེམས་དཔའ་ཆེན་པོ་འཕགས་པ་སྤྱན་རས་གཟིགས་དབང་ཕྱུག་དང་།[F.146.a]ཐམས་ཅད་དང་ལྡན་པའི་འཁོར་དེ་དང་། ལྷ་དང་། མི་དང་། ལྷ་མ་ཡིན་དང་། དྲི་ཟར་བཅས་པའི་འཇིག་རྟེན་ཡི་རངས་ཏེ། བཅོམ་ལྡན་འདས་ཀྱིས་གསུངས་པ་ལ་མངོན་པར་བསྟོད་དོ། །\",\"folioNumber\":145,\"volumeNumber\":34}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":258,\"uuid\":\"c5f37d38-04fd-4dee-bd78-dcc1339ac3f2\"},\"content\":[{\"type\":\"text\",\"text\":\"When the Blessed One had said this, venerable \",\"attrs\":{\"start\":0,\"end\":46}},{\"type\":\"text\",\"text\":\"Śāradvatīputra\",\"attrs\":{\"start\":46,\"end\":60},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9998ea3b-be7b-4ae9-abd9-6be2a6958171\",\"uuid\":\"aa026e66-185c-4aee-872f-7cef06f4465c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\",\",\"attrs\":{\"start\":60,\"end\":61},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"05fd95a6-6a77-4e6d-8fba-4c45817e16e6\",\"label\":\"58\",\"uuid\":\"927a9ac2-9cd4-41bb-a259-b6cfd97e3bef\",\"start\":61,\"end\":61,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" the bodhisattva great being, noble \",\"attrs\":{\"start\":61,\"end\":97}},{\"type\":\"text\",\"text\":\"Avalokiteśvara\",\"attrs\":{\"start\":97,\"end\":111},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"15f3a5cf-5d86-4439-b06f-5909aae6a9d2\",\"uuid\":\"11e26396-2435-4af6-a99c-0821826ea21c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and the entire assembly, as well as the world with its devas, humans, asuras, and gandharvas, rejoiced and praised what the Blessed One had said.\",\"attrs\":{\"start\":111,\"end\":258}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"6292c0ac-9f94-4474-aae5-090bc1c7a625\",\"sort\":388,\"type\":\"translation\",\"label\":\"1.19\",\"alignments\":{\"toh531\":{\"folioUuid\":\"e7c08a25-48d7-4d3d-a8d6-28e182852d73\",\"toh\":\"toh531\",\"tibetan\":\"བཅོམ་ལྡན་འདས་མ་ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པའི་སྙིང་པོ་ཞེས་བྱ་བ་ཐེག་པ་ཆེན་པོའི་མདོ་རྫོགས་སོ།། །།\",\"folioNumber\":95,\"volumeNumber\":88},\"toh21\":{\"folioUuid\":\"7eb0b6f5-54d3-485e-a7e3-29504a56857b\",\"toh\":\"toh21\",\"tibetan\":\"བཅོམ་ལྡན་འདས་མ་ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པའི་སྙིང་པོ་ཞེས་བྱ་བ་ཐེག་པ་ཆེན་པོའི་\\nམདོ་རྫོགས་སོ།། །།\",\"folioNumber\":146,\"volumeNumber\":34}}},\"content\":[{\"type\":\"trailer\",\"attrs\":{\"start\":0,\"end\":99,\"uuid\":\"9ebff716-106e-4794-aba7-58b1f08b8ad8\"},\"content\":[{\"type\":\"text\",\"text\":\"This completes \",\"attrs\":{\"start\":0,\"end\":15}},{\"type\":\"text\",\"text\":\"The Great Vehicle Sūtra “The Heart of the Perfection of Wisdom, the Blessed Mother.\",\"attrs\":{\"start\":15,\"end\":98},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"eeb1f147-ad76-4bc7-8ed0-b8e02a64be89\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"”\",\"attrs\":{\"start\":98,\"end\":99}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"c97adcbd-6108-49aa-9001-7bd215017377\",\"sort\":391,\"type\":\"colophonHeader\",\"label\":\"c.\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":2,\"start\":0,\"end\":8,\"uuid\":\"c0c453aa-e53a-4464-a94f-4c3fe39f2ce8\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"Colophon\",\"attrs\":{\"start\":0,\"end\":8}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"3556ba50-15cd-4c99-9e63-e0e1176e2f69\",\"sort\":393,\"type\":\"colophon\",\"label\":\"c.1\",\"alignments\":{\"toh531\":{\"folioUuid\":\"e7c08a25-48d7-4d3d-a8d6-28e182852d73\",\"toh\":\"toh531\",\"tibetan\":\"རྒྱ་གར་གྱི་མཁན་པོ་བི་མ་ལ་མི་ཏྲ་དང་། ལོ་ཙྪ་བ་དགེ་སློང་རིན་ཆེན་སྡེས་བསྒྱུར་\\nཅིང་། ཞུ་ཆེན་གྱི་ལོ་ཙྪ་བ་དགེ་བློ་དང་ནམ་མཁའ་ལ་སོགས་པས་ཞུས་ཏེ་གཏན་ལ་ཕབ་པ་ལ།། །།དཔལ་བསམ་ཡས་ལྷུན་གྱིས་གྲུབ་པའི་གཙུག་ལག་གི་དགེ་རྒྱས་བྱེ་མ་གླིང་གི་རྩིག་ངོས་ལ་བྲིས་པ་དང་ཞུ་དག་ལེགས་པར་བགྱིས་སོ།། །།\",\"folioNumber\":95,\"volumeNumber\":88},\"toh21\":{\"folioUuid\":\"7eb0b6f5-54d3-485e-a7e3-29504a56857b\",\"toh\":\"toh21\",\"tibetan\":\"རྒྱ་གར་གྱི་མཁན་པོ་བི་མ་ལ་མི་ཏྲ་དང་། ལོཙྪ་བ་དགེ་སློང་རིན་ཆེན་སྡེས་བསྒྱུར་ཅིང་། ཞུ་ཆེན་གྱི་ལོ་ཙྪ་བ་དགེ་བློ་དང་ནམ་མཁའ་ལ་སོགས་པས་ཞུས་ཏེ་གཏན་ལ་ཕབ་པ།། །།དཔལ་བསམ་ཡས་ལྷུན་གྱིས་གྲུབ་པའི་གཙུག་ལག་གི་དགེ་རྒྱས་བྱེ་མ་གླིང་གི་རྩིག་ངོས་ལ་བྲིས་པ་\\nདང་ཞུ་དག་ལེགས་པར་བགྱིས་སོ།། \",\"folioNumber\":146,\"volumeNumber\":34}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":323,\"uuid\":\"3556ba50-15cd-4c99-9e63-e0e1176e2f69\"},\"content\":[{\"type\":\"text\",\"text\":\"This was translated by the Indian preceptor \",\"attrs\":{\"start\":0,\"end\":44}},{\"type\":\"text\",\"text\":\"Vimalamitra\",\"attrs\":{\"start\":44,\"end\":55},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2e715653-ecf6-4079-9c15-46e71fdc107a\",\"uuid\":\"bee30ec9-28c7-45dc-9239-2aba9a4ffe8e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and the translator monk \",\"attrs\":{\"start\":55,\"end\":80}},{\"type\":\"text\",\"text\":\"Rinchen Dé\",\"attrs\":{\"start\":80,\"end\":90},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b3a43e78-559c-44a4-a203-e14d6ee55eac\",\"uuid\":\"50fdda23-6396-4be1-b3be-d3c1e594334b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and then edited and finalized by the editor-translators \",\"attrs\":{\"start\":90,\"end\":148}},{\"type\":\"text\",\"text\":\"Gelo\",\"attrs\":{\"start\":148,\"end\":152},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c958e40c-5676-47df-9050-f81e78568049\",\"uuid\":\"ef80b090-4505-4d21-96a2-4825c4714018\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":152,\"end\":154}},{\"type\":\"text\",\"text\":\"Namkha\",\"attrs\":{\"start\":154,\"end\":160},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"12e65098-d92a-4c4e-880b-af900b9b8f3a\",\"uuid\":\"09ba13bb-b28a-45be-aebb-1cf7d5e30c43\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and others. It was then carefully proofed against the writing on the wall of the Gegye Jema Ling Temple\",\"attrs\":{\"start\":160,\"end\":265},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"c5ad6e00-1386-40fa-9964-be828c055e4d\",\"label\":\"59\",\"uuid\":\"ab76976a-fe26-49d3-a604-b2da9d8dd1fd\",\"start\":265,\"end\":265,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" at glorious Samye‍—the spontaneously accomplished temple.\",\"attrs\":{\"start\":265,\"end\":323},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"0de07b43-cd8e-4501-bc2e-f6e08f863ada\",\"label\":\"60\",\"uuid\":\"e6f573d5-86ec-4020-90e1-eb91a408601e\",\"start\":323,\"end\":323,\"location\":\"end\",\"toh\":null}]}}]}]}]}]}]\n"])</script><div hidden id="S:2"><div dir="ltr" data-orientation="horizontal" data-slot="tabs" class="flex flex-col gap-2 px-12 w-full"><div class="sticky top-0.75 -mt-28 z-10 w-full overflow-x-auto text-center"><div role="tablist" aria-orientation="horizontal" data-slot="tabs-list" class="bg-background gap-1 sm:gap-3 h-10 items-center justify-center sm:p-1 w-fit inline-flex" tabindex="-1" data-orientation="horizontal" style="outline:none"><button type="button" role="tab" aria-selected="false" aria-controls="radix-_R_2npfqb6btb_-content-front" data-state="inactive" id="radix-_R_2npfqb6btb_-trigger-front" data-slot="tabs-trigger" class="inline-flex items-center justify-center whitespace-nowrap px-1 py-0.75 text-sm data-[state=active]:font-semibold ring-offset-background transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-background text-foreground border-b-2 border-transparent data-[state=active]:border-primary-300 decoration-primary-25 hover:text-primary hover:border-primary/20 hover:cursor-pointer" tabindex="-1" data-orientation="horizontal" data-radix-collection-item="">Front</button><button type="button" role="tab" aria-selected="true" aria-controls="radix-_R_2npfqb6btb_-content-translation" data-state="active" id="radix-_R_2npfqb6btb_-trigger-translation" data-slot="tabs-trigger" class="inline-flex items-center justify-center whitespace-nowrap px-1 py-0.75 text-sm data-[state=active]:font-semibold ring-offset-background transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:point