lse" aria-controls="radix-_R_2npftt6btb_-content-abbreviations" data-state="inactive" id="radix-_R_2npftt6btb_-trigger-abbreviations" data-slot="tabs-trigger" class="inline-flex items-center justify-center whitespace-nowrap px-1 py-0.75 text-sm data-[state=active]:font-semibold ring-offset-background transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-background text-foreground border-b-2 border-transparent data-[state=active]:border-primary-300 decoration-primary-25 hover:text-primary hover:border-primary/20 hover:cursor-pointer" tabindex="-1" data-orientation="horizontal" data-radix-collection-item="">Abbr</button></div></div><div class="px-2"><div class="overflow-auto md:h-[calc(100vh-8.5rem)] h-[calc(100vh-4rem)] rounded bg-surface"><div class="rounded ps-10 pe-4 max-w-readable mx-auto"><div data-state="active" data-orientation="horizontal" role="tabpanel" aria-labelledby="radix-_R_2npftt6btb_-trigger-endnotes" id="radix-_R_2npftt6btb_-content-endnotes" tabindex="0" data-slot="tabs-content" class="mt-2 ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 data-[state=inactive]:hidden" style="animation-duration:0s"><div class="h-0"></div><div></div><div class="h-0"></div><div class="flex flex-col gap-4 pb-8"><div class="flex gap-5"><div class="animate-pulse rounded-md bg-foreground/10 h-6 w-6"></div><div class="animate-pulse rounded-md bg-foreground/10 h-32 grow"></div></div><div class="flex gap-5"><div class="animate-pulse rounded-md bg-foreground/10 h-6 w-6"></div><div class="animate-pulse rounded-md bg-foreground/10 h-32 grow"></div></div><div class="flex gap-5"><div class="animate-pulse rounded-md bg-foreground/10 h-6 w-6"></div><div class="animate-pulse rounded-md bg-foreground/10 h-32 grow"></div></div></div></div><div data-state="inactive" data-orientation="horizontal" role="tabpanel" aria-labelledby="radix-_R_2npftt6btb_-trigger-glossary" id="radix-_R_2npftt6btb_-content-glossary" tabindex="0" data-slot="tabs-content" class="mt-2 ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 pb-8 data-[state=inactive]:hidden"><div class="flex flex-col w-full"><div id="glossary" class="relative scroll-mt-20"><button type="button" id="radix-_R_2lanpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4 @c/sidebar:mt-5 mt-6">g.</button><div class="passage pl-6 @c/sidebar:pl-4"><h2 class="font-serif font-light text-primary scroll-m-20 text-xl @c/sidebar:mt-4 mt-6 @c/sidebar:pb-2 pb-3 @c/sidebar:text-left text-center section-title">Glossary</h2></div></div><div class="mt-3 flex flex-col gap-6"><div id="7b4e3b42-8510-401e-9185-c65cc0c09cc5" class="relative scroll-mt-20"><button type="button" id="radix-_R_20d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.1</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">acquaintance</div><ul class="ml-4 list-disc"><li class="italic">nye du</li><li class="pt-1"><span class="font-tibetan text-base">ཉེ་དུ།</span></li><li class="italic">jñāti</li></ul></div></div></div><div id="ca4d29f6-0a4e-44fe-bd3b-094638f2ef92" class="relative scroll-mt-20"><button type="button" id="radix-_R_20l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.2</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">aid</div><ul class="ml-4 list-disc"><li class="italic">sman pa</li><li class="pt-1"><span class="font-tibetan text-base">སྨན་པ།</span></li><li class="italic">hita</li></ul></div></div></div><div id="7d8e26c4-d00a-499a-990a-e09d92900f70" class="relative scroll-mt-20"><button type="button" id="radix-_R_20t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.3</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Amitāyus</div><ul class="ml-4 list-disc"><li class="italic">tshe dpag med</li><li class="pt-1"><span class="font-tibetan text-base">ཚེ་དཔག་མེད།</span></li><li class="italic">amitāyus</li></ul><div class="glossary-instance-definition"><p class="definition">The buddha who presides over the buddhafield <span data-glossary-id="UT22084-087-009-265">Sukhāvatī</span>; also known as Amitābha.</p></div></div></div></div><div id="b35041f2-96b8-4d55-b39a-9d0653dffcd6" class="relative scroll-mt-20"><button type="button" id="radix-_R_2155anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.4</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ānanda</div><ul class="ml-4 list-disc"><li class="italic">kun dga’ bo</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་དགའ་བོ།</span></li><li class="italic">ānanda</li></ul><div class="glossary-instance-definition"><p class="definition">The Buddha Śākyamuni’s attendant who is celebrated for having recited all the Buddha’s teachings by memory at the first council of the Buddhist saṅgha, thus preserving the Buddha’s teachings after his parinirvāṇa. </p></div></div></div></div><div id="11128676-99d3-4fdb-b630-fb00bd5c832a" class="relative scroll-mt-20"><button type="button" id="radix-_R_21d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.5</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Anila</div><ul class="ml-4 list-disc"><li class="italic">rlung</li><li class="pt-1"><span class="font-tibetan text-base">རླུང་།</span></li><li class="italic">anila</li></ul><div class="glossary-instance-definition"><p class="definition">One of the twelve <span data-glossary-id="UT22084-087-009-164">great yakṣa generals</span> who protect and serve those who bear, read, recite, copy, or commission a copy of the <cite class="title break text-sa" lang="sa-LATN">Bhaiṣajya­guru­vaiḍūrya­prabha­rāja­sūtra</cite>.</p></div></div></div></div><div id="0e6c3f4b-cbdc-48fe-a677-a38c8e2f68a7" class="relative scroll-mt-20"><button type="button" id="radix-_R_21l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.6</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Antila</div><ul class="ml-4 list-disc"><li class="italic">gza’ ’dzin</li><li class="pt-1"><span class="font-tibetan text-base">གཟའ་འཛིན།</span></li><li class="italic">antila</li></ul><div class="glossary-instance-definition"><p class="definition">One of the twelve <span data-glossary-id="UT22084-087-009-164">great yakṣa generals</span> who protect and serve those who bear, read, recite, copy, or commission a copy of the <cite class="title break text-sa" lang="sa-LATN">Bhaiṣajya­guru­vaiḍūrya­prabha­rāja­sūtra</cite>.</p></div></div></div></div><div id="447fc7a7-051b-4fc0-b42f-c565f67f73d1" class="relative scroll-mt-20"><button type="button" id="radix-_R_21t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.7</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">asura</div><ul class="ml-4 list-disc"><li class="italic">lha ma yin</li><li class="pt-1"><span class="font-tibetan text-base">ལྷ་མ་ཡིན།</span></li><li class="italic">asura</li></ul><div class="glossary-instance-definition"><p>A type of nonhuman being whose precise status is subject to different views, but is included as one of the six classes of beings in the sixfold classification of realms of rebirth. In the Buddhist context, asuras are powerful beings said to be dominated by envy, ambition, and hostility. They are also known in the pre-Buddhist and pre-Vedic mythologies of India and Iran, and feature prominently in Vedic and post-Vedic Brahmanical mythology, as well as in the Buddhist tradition. In these traditions, asuras are often described as being engaged in interminable conflict with the devas (gods).</p></div></div></div></div><div id="715734e9-5f03-4a3e-8bce-d76f45d1b1f2" class="relative scroll-mt-20"><button type="button" id="radix-_R_2255anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.8</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bandé Yeshé Dé</div><ul class="ml-4 list-disc"><li class="italic">ban+de ye shes sde</li><li class="pt-1"><span class="font-tibetan text-base">བནྡེ་ཡེ་ཤེས་སྡེ།</span></li></ul><div class="glossary-instance-definition"><p>Yeshé Dé (late eighth to early ninth century) was the most prolific translator of sūtras into Tibetan. Altogether he is credited with the translation of more than one hundred sixty sūtra translations and more than one hundred additional translations, mostly on tantric topics. In spite of Yeshé Dé’s great importance for the propagation of Buddhism in Tibet during the imperial era, only a few biographical details about this figure are known. Later sources describe him as a student of the Indian teacher Padmasambhava, and he is also credited with teaching both sūtra and tantra widely to students of his own. He was also known as Nanam Yeshé Dé, from the Nanam (<em class="foreign">sna nam</em>) clan.</p></div></div></div></div><div id="4adc3878-7b91-4698-a68b-8b62781a6adc" class="relative scroll-mt-20"><button type="button" id="radix-_R_22d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.9</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">be restored</div><ul class="ml-4 list-disc"><li class="italic">mngon par skye</li><li class="pt-1"><span class="font-tibetan text-base">མངོན་པར་སྐྱེ།</span></li><li class="italic">abhivivardhate</li></ul></div></div></div><div id="b38cc372-b545-4778-b427-798edb1137f7" class="relative scroll-mt-20"><button type="button" id="radix-_R_22l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.10</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">beaten</div><ul class="ml-4 list-disc"><li class="italic">brdeg pa</li><li class="pt-1"><span class="font-tibetan text-base">བརྡེག་པ།</span></li><li class="italic">prahāra</li></ul></div></div></div><div id="3ffc011e-faa9-469d-86fa-ce559364f6ca" class="relative scroll-mt-20"><button type="button" id="radix-_R_22t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.11</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">benevolent</div><ul class="ml-4 list-disc"><li class="italic">byams pa la gnas pa</li><li class="pt-1"><span class="font-tibetan text-base">བྱམས་པ་ལ་གནས་པ།</span></li><li class="italic">maitrīvihāra</li></ul></div></div></div><div id="86c2c568-8ea3-4b91-881b-8d2fe6023691" class="relative scroll-mt-20"><button type="button" id="radix-_R_2355anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.12</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bhaiṣajya­guru</div><ul class="ml-4 list-disc"><li class="italic">sman gyi lha</li><li class="pt-1"><span class="font-tibetan text-base">སྨན་གྱི་ལྷ།</span></li><li class="italic">bhaiṣajya­guru</li></ul><div class="glossary-instance-definition"><p class="definition">A short form of the name of <span data-glossary-id="UT22084-087-009-237">Bhaiṣajya­guru­vaiḍūrya­prabha</span>, the Medicine Buddha.</p></div></div></div></div><div id="496408c1-e2d7-4787-acaf-cf6b194d9722" class="relative scroll-mt-20"><button type="button" id="radix-_R_23d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.13</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bhaiṣajya­guru­vaiḍūrya­prabha</div><ul class="ml-4 list-disc"><li class="italic">sman gyi lha bai DUr+ya’i ’od</li><li class="pt-1"><span class="font-tibetan text-base">སྨན་གྱི་ལྷ་བཻ་ཌཱུརྱའི་འོད།</span></li><li class="italic">bhaiṣajya­guru­vaiḍūrya­prabha</li></ul><div class="glossary-instance-definition"><p class="definition">The Medicine Buddha, the <span data-glossary-id="UT22084-087-009-213">thus-gone one</span> residing in the buddhafield <span data-glossary-id="UT22084-087-009-269">Vaiḍūrya­nirbhāsa</span>. Also called <span data-glossary-id="UT22084-087-009-238">Bhaiṣajya­guru­vaiḍūrya­prabha­rāja</span>.</p></div></div></div></div><div id="42700cf7-b80f-42be-89b1-6b4b26f2b60a" class="relative scroll-mt-20"><button type="button" id="radix-_R_23l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.14</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bhaiṣajya­guru­vaiḍūrya­prabha­rāja</div><ul class="ml-4 list-disc"><li class="italic">sman gyi lha bai DUr+ya’i ’od kyi rgyal po</li><li class="pt-1"><span class="font-tibetan text-base">སྨན་གྱི་ལྷ་བཻ་ཌཱུརྱའི་འོད་ཀྱི་རྒྱལ་པོ།</span></li><li class="italic">bhaiṣajya­guru­vaiḍūrya­prabha­rāja</li></ul><div class="glossary-instance-definition"><p class="definition">The Medicine Buddha, the <span data-glossary-id="UT22084-087-009-213">thus-gone one</span> residing in the buddhafield <span data-glossary-id="UT22084-087-009-269">Vaiḍūrya­nirbhāsa</span>. Also called <span data-glossary-id="UT22084-087-009-237">Bhaiṣajya­guru­vaiḍūrya­prabha</span>.</p></div></div></div></div><div id="298aea65-db33-4768-b6eb-6be995b4d287" class="relative scroll-mt-20"><button type="button" id="radix-_R_23t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.15</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">bhūta</div><ul class="ml-4 list-disc"><li class="italic">’byung po</li><li class="pt-1"><span class="font-tibetan text-base">འབྱུང་པོ།</span></li><li class="italic">bhūta</li></ul><div class="glossary-instance-definition"><p>This term in its broadest sense can refer to any being, whether human, animal, or nonhuman. However, it is often used to refer to a specific class of nonhuman beings, especially when bhūtas are mentioned alongside rākṣasas, piśācas, or pretas. In common with these other kinds of nonhumans, bhūtas are usually depicted with unattractive and misshapen bodies. Like several other classes of nonhuman beings, bhūtas take spontaneous birth. As their leader is traditionally regarded to be Rudra-Śiva (also known by the name Bhūta), with whom they haunt dangerous and wild places, bhūtas are especially prominent in Śaivism, where large sections of certain tantras concentrate on them.</p></div></div></div></div><div id="8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0" class="relative scroll-mt-20"><button type="button" id="radix-_R_2455anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.16</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">blessed, blessed one</div><ul class="ml-4 list-disc"><li class="italic">bcom ldan ’das</li><li class="pt-1"><span class="font-tibetan text-base">བཅོམ་ལྡན་འདས།</span></li><li class="italic">bhagavat, bhagavān</li></ul><div class="glossary-instance-definition"><p>In Buddhist literature, this is an epithet applied to buddhas, most often to Śākyamuni. The Sanskrit term generally means “possessing fortune,” but in specifically Buddhist contexts it implies that a buddha is in possession of six auspicious qualities (<em class="foreign break text-sa" lang="sa-LATN">bhaga</em>) associated with complete awakening. The Tibetan term‍—where <em class="foreign break text-sa" lang="sa-LATN">bcom</em> is said to refer to “subduing” the four māras, <em class="foreign break text-sa" lang="sa-LATN">ldan</em> to “possessing” the great qualities of buddhahood, and <em class="foreign break text-sa" lang="sa-LATN">’das</em> to “going beyond” saṃsāra and nirvāṇa‍—possibly reflects the commentarial tradition where the Sanskrit <em class="foreign break text-sa" lang="sa-LATN">bhagavat</em> is interpreted, in addition, as “one who destroys the four māras.” This is achieved either by reading <em class="foreign break text-sa" lang="sa-LATN">bhagavat</em> as <em class="foreign break text-sa" lang="sa-LATN">bhagnavat</em> (“one who broke”), or by tracing the word <em class="foreign break text-sa" lang="sa-LATN">bhaga</em> to the root <em class="foreign break text-sa" lang="sa-LATN">√bhañj</em> (“to break”).</p></div></div></div></div><div id="38e053c9-0710-491c-aa43-54407747fbed" class="relative scroll-mt-20"><button type="button" id="radix-_R_24d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.17</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">blind</div><ul class="ml-4 list-disc"><li class="italic">long ba</li><li class="pt-1"><span class="font-tibetan text-base">ལོང་བ།</span></li><li class="italic">andha</li></ul></div></div></div><div id="10c7e31c-8ab9-4465-a8ba-3027ff390cc4" class="relative scroll-mt-20"><button type="button" id="radix-_R_24l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.18</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">blue beryl</div><ul class="ml-4 list-disc"><li class="italic">bai DUr+ya</li><li class="pt-1"><span class="font-tibetan text-base">བཻ་ཌཱུརྱ།</span></li><li class="italic">vaiḍūrya</li></ul><div class="glossary-instance-definition"><p class="definition">Although <em class="foreign break text-sa" lang="sa-LATN">vaiḍūrya</em>‍—particularly in the context of <span data-glossary-id="UT22084-087-009-236">Bhaiṣajya­guru</span>‍—has often been translated as lapis lazuli, blue beryl is overall a better match for the descriptions and references in the Sanskrit and Tibetan literature. The equivalent Pāli form of <em class="foreign break text-sa" lang="sa-LATN">vaiḍūrya</em> is <em class="foreign text-pi" lang="pi-LATN">veḷuriya</em>. The Prākrit form <em class="foreign">verulia</em> is the source for the English word “beryl.” There are white, yellow, and green beryls (green beryl is generally called “emerald”), but in this case blue beryl needs to be specified to match traditional descriptions. <em class="foreign break text-sa" lang="sa-LATN">Vaiḍūrya</em> may nevertheless have been taken to designate different gems at different times and places, and no single equivalent in English is entirely satisfactory.</p></div></div></div></div><div id="29c40432-a61e-422b-abdf-65eb303e5623" class="relative scroll-mt-20"><button type="button" id="radix-_R_24t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.19</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">body</div><ul class="ml-4 list-disc"><li class="italic">kho lag, sku</li><li class="pt-1"><span class="font-tibetan text-base">ཁོ་ལག, སྐུ།</span></li><li class="italic">kāya</li></ul></div></div></div><div id="1f20fd9f-f11b-41ed-a739-56ca809859d3" class="relative scroll-mt-20"><button type="button" id="radix-_R_2555anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.20</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">bound</div><ul class="ml-4 list-disc"><li class="italic">bcing ba</li><li class="pt-1"><span class="font-tibetan text-base">བཅིང་བ།</span></li><li class="italic">baddha</li></ul></div></div></div><div id="29f993af-be3f-4744-bb27-4dc0a9e891cc" class="relative scroll-mt-20"><button type="button" id="radix-_R_25d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.21</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">buddha domain</div><ul class="ml-4 list-disc"><li class="italic">sangs rgyas kyi spyod yul</li><li class="pt-1"><span class="font-tibetan text-base">སངས་རྒྱས་ཀྱི་སྤྱོད་ཡུལ།</span></li><li class="italic">buddhagocara</li></ul></div></div></div><div id="6034a49d-847e-41ad-aae1-7a995b361ec8" class="relative scroll-mt-20"><button type="button" id="radix-_R_25l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.22</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Candra­vairocana</div><ul class="ml-4 list-disc"><li class="italic">zla ba lter rnam par snang ba</li><li class="pt-1"><span class="font-tibetan text-base">ཟླ་བ་ལྟེར་རྣམ་པར་སྣང་བ།</span></li><li class="italic">candra­vairocana</li></ul><div class="glossary-instance-definition"><p class="definition">One of the two primary bodhisattvas who accompany the <span data-glossary-id="UT22084-087-009-213">Thus-Gone One</span> <span data-glossary-id="UT22084-087-009-238">Bhaiṣajya­guru­vaiḍūrya­prabha­rāja</span> in the buddhafield <span data-glossary-id="UT22084-087-009-269">Vaiḍūrya­nirbhāsa</span>.</p></div></div></div></div><div id="48c4e892-0a3a-468c-a5d5-b7f3dcdd2895" class="relative scroll-mt-20"><button type="button" id="radix-_R_25t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.23</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Caundhula</div><ul class="ml-4 list-disc"><li class="italic">g.yo ba ’dzin</li><li class="pt-1"><span class="font-tibetan text-base">གཡོ་བ་འཛིན།</span></li><li class="italic">caundhula</li></ul><div class="glossary-instance-definition"><p class="definition">One of the twelve <span data-glossary-id="UT22084-087-009-164">great yakṣa generals</span> who protect and serve those who bear, read, recite, copy, or commission a copy of the <cite class="title break text-sa" lang="sa-LATN">Bhaiṣajya­guru­vaiḍūrya­prabha­rāja­sūtra</cite>.</p></div></div></div></div><div id="148f89d5-5342-4a4d-ab54-14b440d585be" class="relative scroll-mt-20"><button type="button" id="radix-_R_2655anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.24</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">centipede</div><ul class="ml-4 list-disc"><li class="italic">rkang lag brgya pa</li><li class="pt-1"><span class="font-tibetan text-base">རྐང་ལག་བརྒྱ་པ།</span></li></ul></div></div></div><div id="b401f8fc-2c49-41d1-8878-e66c0a63dabc" class="relative scroll-mt-20"><button type="button" id="radix-_R_26d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.25</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Cidāla</div><ul class="ml-4 list-disc"><li class="italic">bsam ’dzin</li><li class="pt-1"><span class="font-tibetan text-base">བསམ་འཛིན།</span></li><li class="italic">cidāla</li></ul><div class="glossary-instance-definition"><p class="definition">One of the twelve <span data-glossary-id="UT22084-087-009-164">great yakṣa generals</span> who protect and serve those who bear, read, recite, copy, or commission a copy of the <cite class="title break text-sa" lang="sa-LATN">Bhaiṣajya­guru­vaiḍūrya­prabha­rāja­sūtra</cite>.</p></div></div></div></div><div id="610e43db-e971-495d-ad77-263b0c9b5d6b" class="relative scroll-mt-20"><button type="button" id="radix-_R_26l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.26</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">crops will be good</div><ul class="ml-4 list-disc"><li class="italic">lo legs par ’gyur</li><li class="pt-1"><span class="font-tibetan text-base">ལོ་ལེགས་པར་འགྱུར།</span></li><li class="italic">subhikṣa</li></ul></div></div></div><div id="4b9d0013-a2c6-4bd3-aa1e-602a5297627d" class="relative scroll-mt-20"><button type="button" id="radix-_R_26t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.27</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dānaśīla</div><ul class="ml-4 list-disc"><li class="italic">dA na shI la</li><li class="pt-1"><span class="font-tibetan text-base">དཱ་ན་ཤཱི་ལ།</span></li><li class="italic">dānaśīla</li></ul><div class="glossary-instance-definition"><p class="definition">An Indian preceptor and translator who lived in the ninth century.</p></div></div></div></div><div id="d022c947-1f15-4a5c-a30e-5e5ff55acaad" class="relative scroll-mt-20"><button type="button" id="radix-_R_2755anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.28</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">deaf</div><ul class="ml-4 list-disc"><li class="italic">’on pa</li><li class="pt-1"><span class="font-tibetan text-base">འོན་པ།</span></li><li class="italic">badhira</li></ul></div></div></div><div id="ab2e041a-4033-4bfa-8d05-9b343f2ac529" class="relative scroll-mt-20"><button type="button" id="radix-_R_27d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.29</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">death occurring before it is time, untimely death</div><ul class="ml-4 list-disc"><li class="italic">dus ma yin par ’chi ba</li><li class="pt-1"><span class="font-tibetan text-base">དུས་མ་ཡིན་པར་འཆི་བ།</span></li><li class="italic">akālamaraṇa</li></ul></div></div></div><div id="54c235ea-276c-48dd-ae08-eae32314a7a1" class="relative scroll-mt-20"><button type="button" id="radix-_R_27l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.30</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">desire</div><ul class="ml-4 list-disc"><li class="italic">’dod chags</li><li class="pt-1"><span class="font-tibetan text-base">འདོད་ཆགས།</span></li><li class="italic">rāga</li></ul><div class="glossary-instance-definition"><p class="definition">One of the three root afflictions that bind beings to cyclic existence. </p></div></div></div></div><div id="f2ab8b11-0a86-4371-8a2b-e128f5cd5c89" class="relative scroll-mt-20"><button type="button" id="radix-_R_27t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.31</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">dishonored</div><ul class="ml-4 list-disc"><li class="italic">nga rgyal dang bral ba</li><li class="pt-1"><span class="font-tibetan text-base">ང་རྒྱལ་དང་བྲལ་བ།</span></li><li class="italic">vimānita</li></ul></div></div></div><div id="de2f3c99-801f-408f-9132-c76849331414" class="relative scroll-mt-20"><button type="button" id="radix-_R_2855anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.32</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">dumb</div><ul class="ml-4 list-disc"><li class="italic">bems po</li><li class="pt-1"><span class="font-tibetan text-base">བེམས་པོ།</span></li><li class="italic">jaḍa</li></ul></div></div></div><div id="dad2dff9-0c7e-4968-9332-94d4434d4b8e" class="relative scroll-mt-20"><button type="button" id="radix-_R_28d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.33</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">eight bodhisattvas</div><ul class="ml-4 list-disc"><li class="italic">byang chub sems dpa’ brgyad</li><li class="pt-1"><span class="font-tibetan text-base">བྱང་ཆུབ་སེམས་དཔའ་བརྒྱད།</span></li><li class="italic">aṣṭabodhisattva</li></ul></div></div></div><div id="5e2c147b-8fd1-47ec-85fd-32a254a33661" class="relative scroll-mt-20"><button type="button" id="radix-_R_28l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.34</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">eightfold precepts</div><ul class="ml-4 list-disc"><li class="italic">yan lag brgyad pa’i bsnyen gnas</li><li class="pt-1"><span class="font-tibetan text-base">ཡན་ལག་བརྒྱད་པའི་བསྙེན་གནས།</span></li></ul><div class="glossary-instance-definition"><p>To refrain from (1) killing, (2) stealing, (3) sexual activity, (4) false speech, (5) intoxication, (6) singing, dancing, music, and beautifying oneself with adornments or cosmetics, (7) using a high or large bed, and (8) eating at improper times. Typically, this observance is maintained by lay people for twenty-four hours on new moon and full moon days, as well as other special days in the lunar calendar.</p></div></div></div></div><div id="fe7448d9-9209-432f-8696-143f0a36d9cf" class="relative scroll-mt-20"><button type="button" id="radix-_R_28t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.35</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">eighty minor marks</div><ul class="ml-4 list-disc"><li class="italic">dpe byad bzang po brgyad cu</li><li class="pt-1"><span class="font-tibetan text-base">དཔེ་བྱད་བཟང་པོ་བརྒྱད་ཅུ།</span></li><li class="italic">aśītyanuvyañjana</li></ul><div class="glossary-instance-definition"><p class="definition">A set of eighty bodily characteristics and insignia borne by both buddhas and <span data-glossary-id="UT22084-087-009-221">universal emperors</span>. They are considered “minor” in terms of being secondary to the <span data-glossary-id="UT22084-087-009-211">thirty-two marks of a great person</span>.</p></div></div></div></div><div id="60722a01-b9ed-4f9a-81b0-1c8aaea06b3f" class="relative scroll-mt-20"><button type="button" id="radix-_R_2955anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.36</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">five precepts</div><ul class="ml-4 list-disc"><li class="italic">bslab pa’i gzhi lnga po</li><li class="pt-1"><span class="font-tibetan text-base">བསླབ་པའི་གཞི་ལྔ་པོ།</span></li><li class="italic">pañcaśikṣāpada</li></ul><div class="glossary-instance-definition"><p class="definition">Five fundamental <span data-glossary-id="UT22084-087-009-194">precepts</span> of abstaining from (1) killing, (2) stealing, (3) sexual misconduct, (4) lying, and (5) intoxication.</p></div></div></div></div><div id="3c859288-df02-440f-b02c-ccdb20807dcc" class="relative scroll-mt-20"><button type="button" id="radix-_R_29d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.37</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">forest deity</div><ul class="ml-4 list-disc"><li class="italic">nags tshal gyi lha</li><li class="pt-1"><span class="font-tibetan text-base">ནགས་ཚལ་གྱི་ལྷ།</span></li><li class="italic">vanadevatā</li></ul><div class="glossary-instance-definition"><p class="definition">A class of spirit being.</p></div></div></div></div><div id="6d3981fe-2fad-444e-8a5a-b21926433e03" class="relative scroll-mt-20"><button type="button" id="radix-_R_29l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.38</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Four Great Kings</div><ul class="ml-4 list-disc"><li class="italic">rgyal po chen po bzhi</li><li class="pt-1"><span class="font-tibetan text-base">རྒྱལ་པོ་ཆེན་པོ་བཞི།</span></li><li class="italic">caturmahārāja</li></ul><div class="glossary-instance-definition"><p>Four gods who live on the lower slopes (fourth level) of Mount Meru in the eponymous Heaven of the Four Great Kings (<em class="foreign break text-sa" lang="sa-LATN">Cāturmahā­rājika</em>, <em class="foreign text-wy" lang="bo-LATN">rgyal chen bzhi’i ris</em>) and guard the four cardinal directions. Each is the leader of a nonhuman class of beings living in his realm. They are Dhṛtarāṣṭra, ruling the gandharvas in the east; Virūḍhaka, ruling over the kumbhāṇḍas in the south; Virūpākṣa, ruling the nāgas in the west; and Vaiśravaṇa (also known as Kubera) ruling the yakṣas in the north. Also referred to as Guardians of the World or World Protectors (<em class="foreign break text-sa" lang="sa-LATN">lokapāla</em>, <em class="foreign break text-sa" lang="sa-LATN">’jig rten skyong ba</em>).</p></div></div></div></div><div id="5498fc5d-cc02-4013-a3af-2e93940bc8f6" class="relative scroll-mt-20"><button type="button" id="radix-_R_29t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.39</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">gandharva</div><ul class="ml-4 list-disc"><li class="italic">dri za</li><li class="pt-1"><span class="font-tibetan text-base">དྲི་ཟ།</span></li><li class="italic">gandharva</li></ul><div class="glossary-instance-definition"><p>A class of generally benevolent nonhuman beings who inhabit the skies, sometimes said to inhabit fantastic cities in the clouds, and more specifically to dwell on the eastern slopes of Mount Meru, where they are ruled by the Great King Dhṛtarāṣṭra. They are most renowned as celestial musicians who serve the gods. In the Abhidharma, the term is also used to refer to the mental body assumed by sentient beings during the intermediate state between death and rebirth. Gandharvas are said to live on fragrances (<em class="foreign break text-sa" lang="sa-LATN">gandha</em>) in the desire realm, hence the Tibetan translation <em class="foreign text-wy" lang="bo-LATN">dri za</em>, meaning “scent eater.”</p></div></div></div></div><div id="b4d79f26-3f86-4e27-9bc5-a20b80a606a4" class="relative scroll-mt-20"><button type="button" id="radix-_R_2a55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.40</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Gaṅgā</div><ul class="ml-4 list-disc"><li class="italic">gang gA</li><li class="pt-1"><span class="font-tibetan text-base">གང་གཱ།</span></li><li class="italic">gaṅgā</li></ul><div class="glossary-instance-definition"><p>The Gaṅgā, or Ganges in English, is considered to be the most sacred river of India, particularly within the Hindu tradition. It starts in the Himalayas, flows through the northern plains of India, bathing the holy city of Vārāṇasī, and meets the sea at the Bay of Bengal, in Bangladesh. In the sūtras, however, this river is mostly mentioned not for its sacredness but for its abundant sands‍—noticeable still today on its many sandy banks and at its delta‍—which serve as a common metaphor for infinitely large numbers.</p><p>According to Buddhist cosmology, as explained in the <cite class="title text-en" lang="en">Abhidharmakośa</cite>, it is one of the four rivers that flow from Lake Anavatapta and cross the southern continent of Jambudvīpa‍—the known human world or more specifically the Indian subcontinent. </p></div></div></div></div><div id="7f1d9443-e4d8-4521-b596-af0fdd883164" class="relative scroll-mt-20"><button type="button" id="radix-_R_2ad5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.41</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">garuḍa</div><ul class="ml-4 list-disc"><li class="italic">nam mkha’ lding</li><li class="pt-1"><span class="font-tibetan text-base">ནམ་མཁའ་ལྡིང་།</span></li><li class="italic">garuḍa</li></ul><div class="glossary-instance-definition"><p>In Indian mythology, the garuḍa is an eagle-like bird that is regarded as the king of all birds, normally depicted with a sharp, owl-like beak, often holding a snake, and with large and powerful wings. They are traditionally enemies of the nāgas. In the Vedas, they are said to have brought nectar from the heavens to earth. <em class="foreign break text-sa" lang="sa-LATN">Garuḍa</em> can also be used as a proper name for a king of such creatures.</p></div></div></div></div><div id="c974a79c-3c91-40fa-8a22-695c74a98754" class="relative scroll-mt-20"><button type="button" id="radix-_R_2al5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.42</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">giving birth</div><ul class="ml-4 list-disc"><li class="italic">bu btsa’ ba’i dus na</li><li class="pt-1"><span class="font-tibetan text-base">བུ་བཙའ་བའི་དུས་ན།</span></li><li class="italic">prasavanakāla</li></ul></div></div></div><div id="743aac3d-15fc-4192-be69-b05c5584d4ea" class="relative scroll-mt-20"><button type="button" id="radix-_R_2at5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.43</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">god</div><ul class="ml-4 list-disc"><li class="italic">lha</li><li class="pt-1"><span class="font-tibetan text-base">ལྷ།</span></li><li class="italic">deva</li></ul><div class="glossary-instance-definition"><p>In the most general sense the devas‍—the term is cognate with the English <em class="emph">divine</em>‍—are a class of celestial beings who frequently appear in Buddhist texts, often at the head of the assemblies of nonhuman beings who attend and celebrate the teachings of the Buddha Śākyamuni and other buddhas and bodhisattvas. In Buddhist cosmology the devas occupy the highest of the five or six “destinies” (<em class="foreign break text-sa" lang="sa-LATN">gati</em>) of saṃsāra among which beings take rebirth. The devas reside in the <em class="foreign break text-sa" lang="sa-LATN">devalokas</em>, “heavens” that traditionally number between twenty-six and twenty-eight and are divided between the desire realm (<em class="foreign break text-sa" lang="sa-LATN">kāmadhātu</em>), form realm (<em class="foreign break text-sa" lang="sa-LATN">rūpadhātu</em>), and formless realm (<em class="foreign break text-sa" lang="sa-LATN">ārūpyadhātu</em>). A being attains rebirth among the devas either through meritorious deeds (in the desire realm) or the attainment of subtle meditative states (in the form and formless realms). While rebirth among the devas is considered favorable, it is ultimately a transitory state from which beings will fall when the conditions that lead to rebirth there are exhausted. Thus, rebirth in the god realms is regarded as a diversion from the spiritual path. </p></div></div></div></div><div id="a1044c3f-9cda-456d-9df9-65f615aa22f7" class="relative scroll-mt-20"><button type="button" id="radix-_R_2b55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.44</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">god who was born with that person</div><ul class="ml-4 list-disc"><li class="italic">mi de dang lhan cig skyes pa’i lha</li><li class="pt-1"><span class="font-tibetan text-base">མི་དེ་དང་ལྷན་ཅིག་སྐྱེས་པའི་ལྷ།</span></li><li class="italic">puruṣasya sahajā pṛṣṭhānubaddhā devatā</li></ul><div class="glossary-instance-definition"><p class="definition">The deity who is born alongside and accompanies a being and is responsible for recording good and bad deeds to present before the Lord of Death <span data-glossary-id="UT22084-087-009-262">Yama</span> when that being dies.</p></div></div></div></div><div id="3ba5ea94-9e41-499a-bdfd-74e6f2650b7f" class="relative scroll-mt-20"><button type="button" id="radix-_R_2bd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.45</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">grain</div><ul class="ml-4 list-disc"><li class="italic">’bru</li><li class="pt-1"><span class="font-tibetan text-base">འབྲུ།</span></li><li class="italic">sasya, śasya</li></ul></div></div></div><div id="2c78f096-4bf1-473f-8fc4-372315f0f7a1" class="relative scroll-mt-20"><button type="button" id="radix-_R_2bl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.46</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">great aspiration</div><ul class="ml-4 list-disc"><li class="italic">smon lam chen po</li><li class="pt-1"><span class="font-tibetan text-base">སྨོན་ལམ་ཆེན་པོ།</span></li><li class="italic">mahāpraṇidhāna</li></ul><div class="glossary-instance-definition"><p class="definition">The term for aspirations such as helping all beings, generating a buddhafield, bringing all beings to perfect awakening, and so forth that a bodhisattva makes while practicing bodhisattva conduct.</p></div></div></div></div><div id="774fb7f2-7ff9-4d51-aa10-ed8bc69573a4" class="relative scroll-mt-20"><button type="button" id="radix-_R_2bt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.47</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">great household, household</div><ul class="ml-4 list-disc"><li class="italic">shing sA la chen po</li><li class="pt-1"><span class="font-tibetan text-base">ཤིང་སཱ་ལ་ཆེན་པོ།</span></li><li class="italic">mahāśāla</li></ul></div></div></div><div id="d09252d2-d990-4e23-8cfe-5e673de4aa9f" class="relative scroll-mt-20"><button type="button" id="radix-_R_2c55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.48</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">great yakṣa general</div><ul class="ml-4 list-disc"><li class="italic">gnos sbyin gyi sde dpon chen po</li><li class="pt-1"><span class="font-tibetan text-base">གནོས་སྦྱིན་གྱི་སྡེ་དཔོན་ཆེན་པོ།</span></li><li class="italic">mahā­yakṣa­senāpati</li></ul></div></div></div><div id="f48ae7a4-b1f3-49dc-9ccd-6019bb70351b" class="relative scroll-mt-20"><button type="button" id="radix-_R_2cd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.49</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">have only one eye</div><ul class="ml-4 list-disc"><li class="italic">zhar ba</li><li class="pt-1"><span class="font-tibetan text-base">ཞར་བ།</span></li><li class="italic">kāṇa</li></ul></div></div></div><div id="8b8f498c-e758-4bad-8642-f9055d61409e" class="relative scroll-mt-20"><button type="button" id="radix-_R_2cl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.50</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">hunchbacked</div><ul class="ml-4 list-disc"><li class="italic">sgur po</li><li class="pt-1"><span class="font-tibetan text-base">སྒུར་པོ།</span></li><li class="italic">kubja</li></ul></div></div></div><div id="1fb3df06-5971-4968-a4b4-1ba24293e727" class="relative scroll-mt-20"><button type="button" id="radix-_R_2ct5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.51</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">hungry ghost realm</div><ul class="ml-4 list-disc"><li class="italic">yi dags kyi ’jig rten</li><li class="pt-1"><span class="font-tibetan text-base">ཡི་དགས་ཀྱི་འཇིག་རྟེན།</span></li><li class="italic">pretaloka</li></ul></div></div></div><div id="8c676742-3af6-4860-98dd-7cfb3f89f721" class="relative scroll-mt-20"><button type="button" id="radix-_R_2d55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.52</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">hyena</div><ul class="ml-4 list-disc"><li class="italic">dred</li><li class="pt-1"><span class="font-tibetan text-base">དྲེད།</span></li><li class="italic">tarakṣu</li></ul></div></div></div><div id="564d8ea9-dfb7-42ae-b9b9-c4b03389d607" class="relative scroll-mt-20"><button type="button" id="radix-_R_2dd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.53</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">illness, illnesses</div><ul class="ml-4 list-disc"><li class="italic">bro nad</li><li class="pt-1"><span class="font-tibetan text-base">བྲོ་ནད།</span></li><li class="italic">vyādhi</li></ul></div></div></div><div id="62f33895-4037-4996-9cc5-124db625d5c8" class="relative scroll-mt-20"><button type="button" id="radix-_R_2dl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.54</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">illuminate</div><ul class="ml-4 list-disc"><li class="italic">lham me gyur</li><li class="pt-1"><span class="font-tibetan text-base">ལྷམ་མེ་གྱུར།</span></li><li class="italic">bhrājeran</li></ul></div></div></div><div id="6b20c315-faf7-4e18-a9df-6e2db860e228" class="relative scroll-mt-20"><button type="button" id="radix-_R_2dt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.55</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">impaired faculties</div><ul class="ml-4 list-disc"><li class="italic">dbang po ma tshang ba</li><li class="pt-1"><span class="font-tibetan text-base">དབང་པོ་མ་ཚང་བ།</span></li><li class="italic">vikalendriya</li></ul></div></div></div><div id="e2075711-98f5-47bf-a7d6-24b24b5a1755" class="relative scroll-mt-20"><button type="button" id="radix-_R_2e55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.56</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">incorrect discipline</div><ul class="ml-4 list-disc"><li class="italic">tshul khrims log par zhugs</li><li class="pt-1"><span class="font-tibetan text-base">ཚུལ་ཁྲིམས་ལོག་པར་ཞུགས།</span></li><li class="italic">śīlavipanna</li></ul></div></div></div><div id="86cc91e1-b07e-470a-8443-ec8e77613db2" class="relative scroll-mt-20"><button type="button" id="radix-_R_2ed5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.57</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Indala</div><ul class="ml-4 list-disc"><li class="italic">dbang ’dzin</li><li class="pt-1"><span class="font-tibetan text-base">དབང་འཛིན།</span></li><li class="italic">indala</li></ul><div class="glossary-instance-definition"><p class="definition">One of the twelve <span data-glossary-id="UT22084-087-009-164">great yakṣa generals</span> who protect and serve those who bear, read, recite, copy, or commission a copy of the <cite class="title break text-sa" lang="sa-LATN">Bhaiṣajya­guru­vaiḍūrya­prabha­rāja­sūtra</cite>.</p></div></div></div></div><div id="42c66fa6-6c95-4dd8-916d-b35febda3db4" class="relative scroll-mt-20"><button type="button" id="radix-_R_2el5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.58</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Jinamitra</div><ul class="ml-4 list-disc"><li class="italic">dzi na mi tra</li><li class="pt-1"><span class="font-tibetan text-base">ཛི་ན་མི་ཏྲ།</span></li><li class="italic">jinamitra</li></ul><div class="glossary-instance-definition"><p>Jinamitra was invited to Tibet during the reign of King Tri Songdetsen (<em class="foreign text-wy" lang="bo-LATN">khri srong lde btsan</em>, r. 742–98 <span class="small-caps">ᴄᴇ</span>) and was involved with the translation of nearly two hundred texts, continuing into the reign of King Ralpachen (<em class="foreign text-wy" lang="bo-LATN">ral pa can</em>, r. 815–38 <span class="small-caps">ᴄᴇ</span>). He was one of the small group of paṇḍitas responsible for the <cite class="title break text-sa" lang="sa-LATN">Mahāvyutpatti</cite> Sanskrit–Tibetan dictionary.</p></div></div></div></div><div id="852d055a-c616-46a5-919b-e510b44302ee" class="relative scroll-mt-20"><button type="button" id="radix-_R_2et5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.59</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">kākhorda</div><ul class="ml-4 list-disc"><li class="italic">byad</li><li class="pt-1"><span class="font-tibetan text-base">བྱད།</span></li><li class="italic">kākhorda</li></ul><div class="glossary-instance-definition"><p class="definition">A class of spirit beings typically associated with violent sorcery rites.</p></div></div></div></div><div id="57349933-7c73-4afc-be37-dc4942be0146" class="relative scroll-mt-20"><button type="button" id="radix-_R_2f55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.60</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">karmic obscuration</div><ul class="ml-4 list-disc"><li class="italic">las kyi sgrib pa</li><li class="pt-1"><span class="font-tibetan text-base">ལས་ཀྱི་སྒྲིབ་པ།</span></li><li class="italic">karmāvaraṇa</li></ul><div class="glossary-instance-definition"><p class="definition">The emotional and cognitive veils that create impediments in one’s life and prevent one from seeing the nature of reality.</p></div></div></div></div><div id="4fd75d88-000b-411e-95b1-ef38e2b6dacf" class="relative scroll-mt-20"><button type="button" id="radix-_R_2fd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.61</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Kiṃbhīra</div><ul class="ml-4 list-disc"><li class="italic">ci ’jigs</li><li class="pt-1"><span class="font-tibetan text-base">ཅི་འཇིགས།</span></li><li class="italic">kiṃbhīra</li></ul><div class="glossary-instance-definition"><p class="definition">One of the twelve <span data-glossary-id="UT22084-087-009-164">great yakṣa generals</span> who protect and serve those who bear, read, recite, copy, or commission a copy of the <cite class="title break text-sa" lang="sa-LATN">Bhaiṣajya­guru­vaiḍūrya­prabha­rāja­sūtra</cite>.</p></div></div></div></div><div id="454cf445-d5ac-4097-abe0-57f0069431f2" class="relative scroll-mt-20"><button type="button" id="radix-_R_2fl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.62</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">kinnara</div><ul class="ml-4 list-disc"><li class="italic">mi’am ci</li><li class="pt-1"><span class="font-tibetan text-base">མིའམ་ཅི།</span></li><li class="italic">kinnara</li></ul><div class="glossary-instance-definition"><p class="definition">A class of shapeshifting beings. </p></div></div></div></div><div id="d64414dc-ad29-4e9d-99b1-d700901d25ab" class="relative scroll-mt-20"><button type="button" id="radix-_R_2ft5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.63</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">kṣatriya</div><ul class="ml-4 list-disc"><li class="italic">rgyal rigs</li><li class="pt-1"><span class="font-tibetan text-base">རྒྱལ་རིགས།</span></li><li class="italic">kṣatriya</li></ul><div class="glossary-instance-definition"><p>The ruling caste in the traditional four-caste hierarchy of India, associated with warriors, the aristocracy, and kings.</p></div></div></div></div><div id="27fdcc40-002b-47b9-99ce-4f06b47bd269" class="relative scroll-mt-20"><button type="button" id="radix-_R_2g55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.64</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">lame</div><ul class="ml-4 list-disc"><li class="italic">yan lag skyon can</li><li class="pt-1"><span class="font-tibetan text-base">ཡན་ལག་སྐྱོན་ཅན།</span></li><li class="italic">laṅga</li></ul></div></div></div><div id="0e34a071-0c6d-4dab-abb9-d75191f75e4d" class="relative scroll-mt-20"><button type="button" id="radix-_R_2gd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.65</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">lunar eclipse</div><ul class="ml-4 list-disc"><li class="italic">gza’ zla ba</li><li class="pt-1"><span class="font-tibetan text-base">གཟའ་ཟླ་བ།</span></li><li class="italic">candragraha</li></ul></div></div></div><div id="110d8c9f-c4f8-4791-8f72-5f2534c607d9" class="relative scroll-mt-20"><button type="button" id="radix-_R_2gl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.66</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahāla</div><ul class="ml-4 list-disc"><li class="italic">smra ’dzin</li><li class="pt-1"><span class="font-tibetan text-base">སྨྲ་འཛིན།</span></li><li class="italic">mahāla</li></ul><div class="glossary-instance-definition"><p class="definition">One of the twelve <span data-glossary-id="UT22084-087-009-164">great yakṣa generals</span> who protect and serve those who bear, read, recite, copy, or commission a copy of the <cite class="title break text-sa" lang="sa-LATN">Bhaiṣajya­guru­vaiḍūrya­prabha­rāja­sūtra</cite>.</p></div></div></div></div><div id="cfdda550-0a13-4865-9d54-4a8ac3e430bd" class="relative scroll-mt-20"><button type="button" id="radix-_R_2gt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.67</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">mahoraga</div><ul class="ml-4 list-disc"><li class="italic">lto ’phye chen</li><li class="pt-1"><span class="font-tibetan text-base">ལྟོ་འཕྱེ་ཆེན།</span></li><li class="italic">mahoraga</li></ul><div class="glossary-instance-definition"><p>Literally “great serpents,” mahoragas are supernatural beings depicted as large, subterranean beings with human torsos and heads and the lower bodies of serpents. Their movements are said to cause earthquakes, and they make up a class of subterranean geomantic spirits whose movement through the seasons and months of the year is deemed significant for construction projects.</p></div></div></div></div><div id="abe20072-53d9-4db9-a153-41172c50a57e" class="relative scroll-mt-20"><button type="button" id="radix-_R_2h55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.68</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">make them shine, to make shine</div><ul class="ml-4 list-disc"><li class="italic">lhang nger gyur</li><li class="pt-1"><span class="font-tibetan text-base">ལྷང་ངེར་གྱུར།</span></li><li class="italic">viroceran</li></ul></div></div></div><div id="bd416713-18e1-4bcd-aa37-1255f4489642" class="relative scroll-mt-20"><button type="button" id="radix-_R_2hd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.69</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">manifest, manifested</div><ul class="ml-4 list-disc"><li class="italic">legs par gnas pa</li><li class="pt-1"><span class="font-tibetan text-base">ལེགས་པར་གནས་པ།</span></li><li class="italic">pratyupasthita</li></ul></div></div></div><div id="445d93f2-7d72-4338-8d0d-41391ddd697a" class="relative scroll-mt-20"><button type="button" id="radix-_R_2hl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.70</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mañjuśrī, Mañjuśrīkumārabhūta</div><ul class="ml-4 list-disc"><li class="italic">’jam dpal, ’jam dpal gzhon nur gyur pa</li><li class="pt-1"><span class="font-tibetan text-base">འཇམ་དཔལ་གཞོན་ནུར་གྱུར་པ།, འཇམ་དཔལ།</span></li><li class="italic">mañjuśrī, mañjuśrī­kumāra­bhūta</li></ul><div class="glossary-instance-definition"><p class="definition">See “<span data-glossary-id="UT22084-087-009-248">Mañjuśrī</span>.”</p></div></div></div></div><div id="a9d821a9-3cc6-4f11-94b6-c36ad0b6a6cb" class="relative scroll-mt-20"><button type="button" id="radix-_R_2ht5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.71</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mañjuśrī, Mañjuśrīkumārabhūta</div><ul class="ml-4 list-disc"><li class="italic">’jam dpal, ’jam dpal gzhon nur gyur pa</li><li class="pt-1"><span class="font-tibetan text-base">འཇམ་དཔལ་གཞོན་ནུར་གྱུར་པ།, འཇམ་དཔལ།</span></li><li class="italic">mañjuśrī, mañjuśrī­kumāra­bhūta</li></ul><div class="glossary-instance-definition"><p class="definition">Mañjuśrī is one of the “eight close sons of the Buddha” and a bodhisattva who embodies wisdom. He is a major figure in the Mahāyāna sūtras, appearing often as an interlocutor of the Buddha. In his most well-known iconographic form, he is portrayed bearing the sword of wisdom in his right hand and a volume of the <cite class="title break text-sa" lang="sa-LATN">Prajñā­pāramitā­sūtra</cite> in his left. To his name, Mañjuśrī, meaning “Gentle and Glorious One,” is often added the epithet Kumārabhūta, “having a youthful form.” He is also called Mañjughoṣa, Mañjusvara, and Pañcaśikha.</p><p class="definition">Also known here as <span data-glossary-id="UT22084-087-009-249">Mañjuśrīkumārabhūta</span>.</p></div></div></div></div><div id="30fce34c-e31e-4279-8a5c-69f1c3ca2f2f" class="relative scroll-mt-20"><button type="button" id="radix-_R_2i55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.72</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Māra</div><ul class="ml-4 list-disc"><li class="italic">bdud</li><li class="pt-1"><span class="font-tibetan text-base">བདུད།</span></li><li class="italic">māra</li></ul><div class="glossary-instance-definition"><p class="definition">The being who orchestrates and perpetuates the illusion of cyclic existence. </p></div></div></div></div><div id="9d24c363-a19b-400e-af97-1e8b193f95d4" class="relative scroll-mt-20"><button type="button" id="radix-_R_2id5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.73</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mekhila</div><ul class="ml-4 list-disc"><li class="italic">rgyan ’dzin</li><li class="pt-1"><span class="font-tibetan text-base">རྒྱན་འཛིན།</span></li><li class="italic">mekhila</li></ul><div class="glossary-instance-definition"><p class="definition">One of the twelve <span data-glossary-id="UT22084-087-009-164">great yakṣa generals</span> who protect and serve those who bear, read, recite, copy, or commission a copy of the <cite class="title break text-sa" lang="sa-LATN">Bhaiṣajya­guru­vaiḍūrya­prabha­rāja­sūtra</cite>.</p></div></div></div></div><div id="af444519-c053-4ef2-8495-5747d94de944" class="relative scroll-mt-20"><button type="button" id="radix-_R_2il5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.74</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">mentally ill</div><ul class="ml-4 list-disc"><li class="italic">smyon pa</li><li class="pt-1"><span class="font-tibetan text-base">སྨྱོན་པ།</span></li><li class="italic">unmatta</li></ul></div></div></div><div id="a3efffd6-869a-4db9-82c5-eb27587847c2" class="relative scroll-mt-20"><button type="button" id="radix-_R_2it5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.75</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">moon</div><ul class="ml-4 list-disc"><li class="italic">gdung zla</li><li class="pt-1"><span class="font-tibetan text-base">གདུང་ཟླ།</span></li><li class="italic">candra</li></ul></div></div></div><div id="fa5cf5ef-0351-47e4-805f-80836b5b9e51" class="relative scroll-mt-20"><button type="button" id="radix-_R_2j55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.76</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">mountain deity</div><ul class="ml-4 list-disc"><li class="italic">ri’i lha</li><li class="pt-1"><span class="font-tibetan text-base">རིའི་ལྷ།</span></li><li class="italic">giridevatā</li></ul><div class="glossary-instance-definition"><p class="definition">A class of spirit being.</p></div></div></div></div><div id="a5150d0b-1631-40bb-9954-e296550132fa" class="relative scroll-mt-20"><button type="button" id="radix-_R_2jd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.77</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">musical tree</div><ul class="ml-4 list-disc"><li class="italic">rol mo’i sgra can gyi shing ljon pa</li><li class="pt-1"><span class="font-tibetan text-base">རོལ་མོའི་སྒྲ་ཅན་གྱི་ཤིང་ལྗོན་པ།</span></li><li class="italic">vādya­svara­vṛkṣa</li></ul><div class="glossary-instance-definition"><p class="definition">A tree in <span data-glossary-id="UT22084-087-009-270">Vaiśālī</span> at whose base the Buddha Śākyamuni taught <cite class="title text-en" lang="en">The Detailed Account of the Previous Aspirations of the Blessed Bhaiṣajya­guru­vaiḍūrya­prabha</cite>.</p></div></div></div></div><div id="686d6042-1ae0-48bc-8b45-c65e4d770560" class="relative scroll-mt-20"><button type="button" id="radix-_R_2jl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.78</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">necessities, provisions</div><ul class="ml-4 list-disc"><li class="italic">yo byad</li><li class="pt-1"><span class="font-tibetan text-base">ཡོ་བྱད།</span></li><li class="italic">upakaraṇa</li></ul></div></div></div><div id="92d18cd0-9466-4cbb-b56a-f9024cf037aa" class="relative scroll-mt-20"><button type="button" id="radix-_R_2jt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.79</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">nurse</div><ul class="ml-4 list-disc"><li class="italic">rim gro byed pa</li><li class="pt-1"><span class="font-tibetan text-base">རིམ་གྲོ་བྱེད་པ།</span></li><li class="italic">upastāpaka</li></ul></div></div></div><div id="b6a88625-3190-47ab-ac85-1e7efddabef3" class="relative scroll-mt-20"><button type="button" id="radix-_R_2k55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.80</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">one hundred inauspicious things</div><ul class="ml-4 list-disc"><li class="italic">bkra mi shis pa brgya</li><li class="pt-1"><span class="font-tibetan text-base">བཀྲ་མི་ཤིས་པ་བརྒྱ།</span></li><li class="italic">amaṅgalaśata, śatam alakṣmīṇām</li></ul></div></div></div><div id="facdabe4-db2f-4a2a-b57f-3af989136f31" class="relative scroll-mt-20"><button type="button" id="radix-_R_2kd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.81</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">overcome by greed</div><ul class="ml-4 list-disc"><li class="italic">chags pas zil gyis non pa</li><li class="pt-1"><span class="font-tibetan text-base">ཆགས་པས་ཟིལ་གྱིས་ནོན་པ།</span></li><li class="italic">lobhābhibhūta</li></ul></div></div></div><div id="5030ca25-2021-4c21-99f8-1b68d07379f0" class="relative scroll-mt-20"><button type="button" id="radix-_R_2kl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.82</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">overcome by pride, overcome by their pride</div><ul class="ml-4 list-disc"><li class="italic">nga rgyal gyis non pa</li><li class="pt-1"><span class="font-tibetan text-base">ང་རྒྱལ་གྱིས་ནོན་པ།</span></li><li class="italic">mānastabdha</li></ul></div></div></div><div id="358e5588-9c32-470d-94b9-7e777ada653d" class="relative scroll-mt-20"><button type="button" id="radix-_R_2kt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.83</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Pāyila</div><ul class="ml-4 list-disc"><li class="italic">btung ’dzin</li><li class="pt-1"><span class="font-tibetan text-base">བཏུང་འཛིན།</span></li><li class="italic">pāyila</li></ul><div class="glossary-instance-definition"><p class="definition">One of the twelve <span data-glossary-id="UT22084-087-009-164">great yakṣa generals</span> who protect and serve those who bear, read, recite, copy, or commission a copy of the <cite class="title break text-sa" lang="sa-LATN">Bhaiṣajya­guru­vaiḍūrya­prabha­rāja­sūtra</cite>.</p></div></div></div></div><div id="d6f93d29-178b-4a14-ba1a-eb22ecdbb656" class="relative scroll-mt-20"><button type="button" id="radix-_R_2l55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.84</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">persecuted by many acts of treachery</div><ul class="ml-4 list-disc"><li class="italic">sgyu du mas kun du btses pa</li><li class="pt-1"><span class="font-tibetan text-base">སྒྱུ་དུ་མས་ཀུན་དུ་བཙེས་པ།</span></li><li class="italic">anekamāyābhir upadrutaḥ</li></ul></div></div></div><div id="8d4ef3a7-2978-4621-82de-11366f4c2bda" class="relative scroll-mt-20"><button type="button" id="radix-_R_2ld5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.85</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">piśāca</div><ul class="ml-4 list-disc"><li class="italic">sha za</li><li class="pt-1"><span class="font-tibetan text-base">ཤ་ཟ།</span></li><li class="italic">piśāca</li></ul><div class="glossary-instance-definition"><p>A class of nonhuman beings that, like several other classes of nonhuman beings, take spontaneous birth. Ranking below rākṣasas, they are less powerful and more akin to pretas. They are said to dwell in impure and perilous places, where they feed on impure things, including flesh. This could account for the name <em class="foreign break text-sa" lang="sa-LATN">piśāca</em>, which possibly derives from <em class="foreign break text-sa" lang="sa-LATN">√piś</em>, to carve or chop meat, as reflected also in the Tibetan <em class="foreign break text-sa" lang="sa-LATN">sha za</em>, “meat eater.” They are often described as having an unpleasant appearance, and at times they appear with animal bodies. Some possess the ability to enter the dead bodies of humans, thereby becoming so-called <em class="foreign break text-sa" lang="sa-LATN">vetāla</em>, to touch whom is fatal.</p></div></div></div></div><div id="6cd0f088-644b-42e1-b97d-fb9926358f45" class="relative scroll-mt-20"><button type="button" id="radix-_R_2ll5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.86</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">poor complexion</div><ul class="ml-4 list-disc"><li class="italic">mdog mi sdug pa, mdog ngan pa</li><li class="pt-1"><span class="font-tibetan text-base">མདོག་ངན་པ།, མདོག་མི་སྡུག་པ།</span></li><li class="italic">durvarṇa</li></ul></div></div></div><div id="89913917-2506-4297-9321-91c13315a95d" class="relative scroll-mt-20"><button type="button" id="radix-_R_2lt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.87</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">practice pure conduct</div><ul class="ml-4 list-disc"><li class="italic">tshangs par spyad pa</li><li class="pt-1"><span class="font-tibetan text-base">ཚངས་པར་སྤྱད་པ།</span></li><li class="italic">brahmacarya</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign break text-sa" lang="sa-LATN">Brahman</em> is a Sanskrit term referring to what is highest (<em class="foreign break text-sa" lang="sa-LATN">parama</em>) and most important (<em class="foreign break text-sa" lang="sa-LATN">pradhāna</em>); the <cite class="title break text-sa" lang="sa-LATN">Nibandhana</cite> commentary explains <em class="foreign break text-sa" lang="sa-LATN">brahman</em> as meaning here <em class="distinct">nirvāṇa</em>, and thus the brahman conduct is the “conduct toward brahman,” the conduct that leads to the highest liberation, i.e., nirvāṇa. This is explained as “the path without outflows,” which is the “truth of the path” among the four truths of the noble ones. Other explanations (found in the Pāli tradition) take “brahman conduct” to mean the “best conduct,” and also the “conduct of the best,” i.e., the buddhas. In some contexts, “brahman conduct” refers more specifically to celibacy, but the specific referents of this expression are many.</p></div></div></div></div><div id="e1894c5d-a0ba-4881-b9aa-06595e73a72a" class="relative scroll-mt-20"><button type="button" id="radix-_R_2m55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.88</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">precept</div><ul class="ml-4 list-disc"><li class="italic">bslab pa’i gnas, bslab pa’i gzhi</li><li class="pt-1"><span class="font-tibetan text-base">བསླབ་པའི་གནས།, བསླབ་པའི་གཞི།</span></li><li class="italic">śikṣāpada</li></ul><div class="glossary-instance-definition"><p class="definition">These basic precepts are five in number for the laity: (1) not killing, (2) not stealing, (3) chastity, (4) not lying, and (5) avoiding intoxicants. For monks, there are three or five more; avoidance of such things as perfumes, makeup, ointments, garlands, high beds, and afternoon meals. (<em class="distinct">Provisional 84000 definition. New definition forthcoming.</em>)</p></div></div></div></div><div id="61341a33-bb84-4c65-8382-d6f5bebc078b" class="relative scroll-mt-20"><button type="button" id="radix-_R_2md5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.89</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">province</div><ul class="ml-4 list-disc"><li class="italic">grong rdal</li><li class="pt-1"><span class="font-tibetan text-base">གྲོང་རྡལ།</span></li><li class="italic">janapada</li></ul></div></div></div><div id="cf691324-2de5-4910-a68b-c593bd039986" class="relative scroll-mt-20"><button type="button" id="radix-_R_2ml5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.90</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">prudent</div><ul class="ml-4 list-disc"><li class="italic">yid bzhungs pa</li><li class="pt-1"><span class="font-tibetan text-base">ཡིད་བཞུངས་པ།</span></li><li class="italic">medhāvin</li></ul><div class="glossary-instance-definition"><p class="definition">A term describing the quality of a being’s intellect. </p></div></div></div></div><div id="a92c6bc2-f95b-4cbf-a5a1-f9852990aa52" class="relative scroll-mt-20"><button type="button" id="radix-_R_2mt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.91</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Purifying All Karmic Obscurations and Fulfilling All Hopes</div><ul class="ml-4 list-disc"><li class="italic">las kyi sgrub pa thams cad rnam par sbyong zhing re ba thams cad yongs su skong ba</li><li class="pt-1"><span class="font-tibetan text-base">ལས་ཀྱི་སྒྲུབ་པ་ཐམས་ཅད་རྣམ་པར་སྦྱོང་ཞིང་རེ་བ་ཐམས་ཅད་ཡོངས་སུ་སྐོང་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">An alternate title for <cite class="title text-en" lang="en">The Detailed Account of the Previous Aspirations of the Thus-Gone Bhaiṣajya­guru­vaiḍūrya­prabha</cite>.</p></div></div></div></div><div id="a8eda40a-7fdf-45b4-9578-016ac782cdfb" class="relative scroll-mt-20"><button type="button" id="radix-_R_2n55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.92</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">rākṣasa</div><ul class="ml-4 list-disc"><li class="italic">srin po</li><li class="pt-1"><span class="font-tibetan text-base">སྲིན་པོ།</span></li><li class="italic">rākṣasa</li></ul><div class="glossary-instance-definition"><p>A class of nonhuman beings that are often, but certainly not always, considered demonic in the Buddhist tradition. They are often depicted as flesh-eating monsters who haunt frightening places and are ugly and evil-natured with a yearning for human flesh, and who additionally have miraculous powers, such as being able to change their appearance.</p></div></div></div></div><div id="010afd3a-1318-4adf-b782-5f146d3b3864" class="relative scroll-mt-20"><button type="button" id="radix-_R_2nd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.93</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">riches</div><ul class="ml-4 list-disc"><li class="italic">dbyig</li><li class="pt-1"><span class="font-tibetan text-base">དབྱིག</span></li><li class="italic">vasu</li></ul></div></div></div><div id="1c539450-6a9f-4fab-ad3d-03ec7d50e2f7" class="relative scroll-mt-20"><button type="button" id="radix-_R_2nl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.94</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sangyé Menla</div><ul class="ml-4 list-disc"><li class="italic">sangs rgyas sman bla</li><li class="pt-1"><span class="font-tibetan text-base">སངས་རྒྱས་སྨན་བླ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">Tibetan short form of <span data-glossary-id="UT22084-087-009-237">Bhaiṣajya­guru­vaiḍūrya­prabha</span>, also known as the Medicine Buddha.</p></div></div></div></div><div id="06f133d6-c3b0-4015-b926-2127cecd545b" class="relative scroll-mt-20"><button type="button" id="radix-_R_2nt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.95</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Saṇṭhila</div><ul class="ml-4 list-disc"><li class="italic">gnas bcas</li><li class="pt-1"><span class="font-tibetan text-base">གནས་བཅས།</span></li><li class="italic">saṇṭhila</li></ul><div class="glossary-instance-definition"><p class="definition">One of the twelve <span data-glossary-id="UT22084-087-009-164">great yakṣa generals</span> who protect and serve those who bear, read, recite, copy, or commission a copy of the <cite class="title break text-sa" lang="sa-LATN">Bhaiṣajya­guru­vaiḍūrya­prabha­rāja­sūtra</cite>.</p></div></div></div></div><div id="3b187882-e6cb-4302-af05-5ee65dbe3225" class="relative scroll-mt-20"><button type="button" id="radix-_R_2o55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.96</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Śāntideva</div><ul class="ml-4 list-disc"><li class="italic">zhi ba lha, zhi ba’i lha</li><li class="pt-1"><span class="font-tibetan text-base">ཞི་བ་ལྷ།, ཞི་བའི་ལྷ།</span></li><li class="italic">śāntideva</li></ul><div class="glossary-instance-definition"><p class="definition">Indian commentator from the eighth century (685–783 <span class="small-caps">ᴄᴇ</span>) renowned for his work <cite class="title text-en" lang="en">The Way of the Bodhisattva</cite> (<cite class="title break text-sa" lang="sa-LATN">Bodhi­caryāvatāra</cite>).</p></div></div></div></div><div id="db7650ff-bc0e-471e-be3c-1eecbf646266" class="relative scroll-mt-20"><button type="button" id="radix-_R_2od5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.97</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">scorpion</div><ul class="ml-4 list-disc"><li class="italic">sdig</li><li class="pt-1"><span class="font-tibetan text-base">སྡིག</span></li><li class="italic">vṛścika</li></ul></div></div></div><div id="07e61ab3-fa98-4b8c-9c5c-daeb0e0e41e3" class="relative scroll-mt-20"><button type="button" id="radix-_R_2ol5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.98</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">sense pleasures</div><ul class="ml-4 list-disc"><li class="italic">’dod pa’i yon tan</li><li class="pt-1"><span class="font-tibetan text-base">འདོད་པའི་ཡོན་ཏན།</span></li><li class="italic">kāmaguṇa</li></ul></div></div></div><div id="7fe482cf-d978-4cbb-ab88-49d8247867f7" class="relative scroll-mt-20"><button type="button" id="radix-_R_2ot5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.99</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">sentenced to death</div><ul class="ml-4 list-disc"><li class="italic">gsad par ’os pa</li><li class="pt-1"><span class="font-tibetan text-base">གསད་པར་འོས་པ།</span></li><li class="italic">vadhārha</li></ul></div></div></div><div id="2940c04f-befa-42ef-b5bf-3e8d49cd973e" class="relative scroll-mt-20"><button type="button" id="radix-_R_2p55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.100</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">seven precious substances</div><ul class="ml-4 list-disc"><li class="italic">rin po che sna bdun</li><li class="pt-1"><span class="font-tibetan text-base">རིན་པོ་ཆེ་སྣ་བདུན།</span></li><li class="italic">saptaratna</li></ul><div class="glossary-instance-definition"><p>The set of seven precious materials or substances includes a range of precious metals and gems, but their exact list varies. The set often consists of gold, silver, beryl, crystal, red pearls, emeralds, and white coral, but may also contain lapis lazuli, ruby, sapphire, chrysoberyl, diamonds, etc. The term is frequently used in the sūtras to exemplify preciousness, wealth, and beauty, and can describe treasures, offering materials, or the features of architectural structures such as stūpas, palaces, thrones, etc. The set is also used to describe the beauty and prosperity of buddha realms and the realms of the gods.</p><p>In other contexts, the term <em class="foreign break text-sa" lang="sa-LATN">saptaratna</em> can also refer to the seven precious possessions of a cakravartin or to a set of seven precious moral qualities. </p></div></div></div></div><div id="e027cc95-c6fb-48fa-ae75-2c7be803ad4b" class="relative scroll-mt-20"><button type="button" id="radix-_R_2pd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.101</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">skillful means</div><ul class="ml-4 list-disc"><li class="italic">thabs mkhas</li><li class="pt-1"><span class="font-tibetan text-base">ཐབས་མཁས།</span></li><li class="italic">upāyakauśalya</li></ul><div class="glossary-instance-definition"><p class="definition">The special methods that enlightened beings use to lead other beings to awakening. </p></div></div></div></div><div id="37132f8a-2d9a-405d-8b6a-c899623077bd" class="relative scroll-mt-20"><button type="button" id="radix-_R_2pl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.102</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">solar eclipse</div><ul class="ml-4 list-disc"><li class="italic">gza’ nyi ma</li><li class="pt-1"><span class="font-tibetan text-base">གཟའ་ཉི་མ།</span></li><li class="italic">sūryagraha</li></ul></div></div></div><div id="1dc4c134-d9bb-4617-ad63-e08428e8d369" class="relative scroll-mt-20"><button type="button" id="radix-_R_2pt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.103</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Spaces between worlds</div><ul class="ml-4 list-disc"><li class="italic">’jig rten gyi bar</li><li class="pt-1"><span class="font-tibetan text-base">འཇིག་རྟེན་གྱི་བར།</span></li><li class="italic">lokāntarikā</li></ul><div class="glossary-instance-definition"><p class="definition">The places between adjacent world systems, outside their defining ring of mountains, that are said to be miserable and in utter darkness as the <span data-glossary-id="UT22084-087-009-208">suns</span> and <span data-glossary-id="UT22084-087-009-182">moons</span> of the world systems can shed no light there. They are nevertheless said to be inhabited by numerous beings and are sometimes counted among the hell realms.</p></div></div></div></div><div id="09958f58-ba6d-4995-a901-ce2cb255aa36" class="relative scroll-mt-20"><button type="button" id="radix-_R_2q55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.104</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Śrīmitra</div><ul class="ml-4 list-disc"><li class="italic">śrīmitra</li></ul><div class="glossary-instance-definition"><p class="definition">Śrīmitra (d. 343), a prince from Kucha (<em class="foreign text-zh" lang="zh">龜茲</em>, Qiuci, in the Tarim Basin on the Silk Road, present-day Kuqa in Xinjiang), who lived one generation before the other famous Kuchean translator, Kumārajīva. Kucha at the time was a culturally Indic, Tocharian-speaking kingdom. Śrīmitra abdicated the throne in favor of his younger brother and became a monk and translator, traveling to China. He spent 307–312 in Luoyang (<em class="foreign text-zh" lang="zh">洛陽</em>) where he translated Taishō 1331 mentioned here, later moving to Jiankang (<em class="foreign text-zh" lang="zh">建康</em>). He was responsible for introducing a number of other Buddhist texts and dhāraṇīs to China. </p></div></div></div></div><div id="beb14c8c-22c9-4cbb-b14c-392f2edf214b" class="relative scroll-mt-20"><button type="button" id="radix-_R_2qd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.105</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">statue</div><ul class="ml-4 list-disc"><li class="italic">sku gzugs</li><li class="pt-1"><span class="font-tibetan text-base">སྐུ་གཟུགས།</span></li><li class="italic">pratimā</li></ul></div></div></div><div id="8552f074-9293-4a88-b611-021b0144e664" class="relative scroll-mt-20"><button type="button" id="radix-_R_2ql5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.106</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">strength of a great champion</div><ul class="ml-4 list-disc"><li class="italic">tshan po che chen po’i stobs</li><li class="pt-1"><span class="font-tibetan text-base">ཚན་པོ་ཆེ་ཆེན་པོའི་སྟོབས།</span></li><li class="italic">mahā­nagnabala</li></ul></div></div></div><div id="041e2923-fe02-4270-a362-a95100f2fb76" class="relative scroll-mt-20"><button type="button" id="radix-_R_2qt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.107</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sukhāvatī</div><ul class="ml-4 list-disc"><li class="italic">bde ba can</li><li class="pt-1"><span class="font-tibetan text-base">བདེ་བ་ཅན།</span></li><li class="italic">sukhāvatī</li></ul><div class="glossary-instance-definition"><p class="definition">The buddhafield of the <span data-glossary-id="UT22084-087-009-213">Thus-Gone</span> Amitābha.</p></div></div></div></div><div id="4748cce8-fecc-4fe4-a21d-dc3701240e0a" class="relative scroll-mt-20"><button type="button" id="radix-_R_2r55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.108</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sumeru</div><ul class="ml-4 list-disc"><li class="italic">ri rab</li><li class="pt-1"><span class="font-tibetan text-base">རི་རབ།</span></li><li class="italic">sumeru</li></ul><div class="glossary-instance-definition"><p>According to ancient Buddhist cosmology, this is the great mountain forming the axis of the universe. At its summit is Sudarśana, home of Śakra and his thirty-two gods, and on its flanks live the asuras. The mount has four sides facing the cardinal directions, each of which is made of a different precious stone. Surrounding it are several mountain ranges and the great ocean where the four principal island continents lie: in the south, Jambudvīpa (our world); in the west, Godānīya; in the north, Uttarakuru; and in the east, Pūrvavideha. Above it are the abodes of the desire realm gods. It is variously referred to as Meru, Mount Meru, Sumeru, and Mount Sumeru.</p></div></div></div></div><div id="2a81074e-debf-4316-bb23-3177c8323be0" class="relative scroll-mt-20"><button type="button" id="radix-_R_2rd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.109</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">sun</div><ul class="ml-4 list-disc"><li class="italic">gdugs, nyi ma</li><li class="pt-1"><span class="font-tibetan text-base">གདུགས།, ཉི་མ།</span></li><li class="italic">sūrya</li></ul></div></div></div><div id="529e1b37-d121-4652-87c7-d7915abc2d68" class="relative scroll-mt-20"><button type="button" id="radix-_R_2rl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.110</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sūrya­vairocana</div><ul class="ml-4 list-disc"><li class="italic">nyi ma ltar rnam par snang byed</li><li class="pt-1"><span class="font-tibetan text-base">ཉི་མ་ལྟར་རྣམ་པར་སྣང་བྱེད།</span></li><li class="italic">sūrya­vairocana</li></ul><div class="glossary-instance-definition"><p class="definition">One of the two primary bodhisattvas who accompany the <span data-glossary-id="UT22084-087-009-213">Thus-Gone One</span> <span data-glossary-id="UT22084-087-009-238">Bhaiṣajya­guru­vaiḍūrya­prabha­rāja</span> in the buddhafield <span data-glossary-id="UT22084-087-009-269">Vaiḍūrya­nirbhāsa</span>.</p></div></div></div></div><div id="de5e647c-c6c1-4234-a117-24bf05b39370" class="relative scroll-mt-20"><button type="button" id="radix-_R_2rt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.111</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">ten precepts</div><ul class="ml-4 list-disc"><li class="italic">bslab pa’i gzhi bcu po</li><li class="pt-1"><span class="font-tibetan text-base">བསླབ་པའི་གཞི་བཅུ་པོ།</span></li><li class="italic">daśaśikṣāpada</li></ul><div class="glossary-instance-definition"><p class="definition">In addition to the <span data-glossary-id="UT22084-087-009-154">five precepts</span> of abstaining from (1) killing, (2) stealing, (3) sexual misconduct, (4) lying, and (5) intoxication, the <span class="ignore">ten precepts</span> often include (the list varies) abstaining from (6) eating after the midday meal, (7) dancing, singing, or engaging in other forms of entertainments, (8) wearing jewelry or adorning oneself with cosmetics, (9) using high or luxurious beds or seats, and (10) handling money.</p></div></div></div></div><div id="eb8e546c-1abf-4180-a5a9-35e9e80bbc92" class="relative scroll-mt-20"><button type="button" id="radix-_R_2s55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.112</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">ten virtuous actions</div><ul class="ml-4 list-disc"><li class="italic">dge ba bcu</li><li class="pt-1"><span class="font-tibetan text-base">དགེ་བ་བཅུ།</span></li><li class="italic">daśakuśala</li></ul><div class="glossary-instance-definition"><p class="definition">Abstaining from killing, taking what is not given, sexual misconduct, lying, uttering divisive talk, speaking harsh words, gossiping, covetousness, ill will, and wrong views.</p></div></div></div></div><div id="39a596fd-ae1e-4ea2-a33a-142455b04d46" class="relative scroll-mt-20"><button type="button" id="radix-_R_2sd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.113</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">The Bodhisattva Vajrapāṇi’s Vow</div><ul class="ml-4 list-disc"><li class="italic">byang chub sems dpa’ lag na rdo rjes dam bcas pa</li><li class="pt-1"><span class="font-tibetan text-base">བྱང་ཆུབ་སེམས་དཔའ་ལག་ན་རྡོ་རྗེས་དམ་བཅས་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">An alternate title for <cite class="title text-en" lang="en">The Detailed Account of the Previous Aspirations of the Thus-Gone Bhaiṣajya­guru­vaiḍūrya­prabha</cite>.</p></div></div></div></div><div id="525e4fe0-4211-4001-be3b-71be5fc642d5" class="relative scroll-mt-20"><button type="button" id="radix-_R_2sl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.114</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">The Vows of the Twelve Great Yakṣa Generals</div><ul class="ml-4 list-disc"><li class="italic">gnod sbyin gyi sde dpon chen po bcu gnyis kyis dam bcas pa</li><li class="pt-1"><span class="font-tibetan text-base">གནོད་སྦྱིན་གྱི་སྡེ་དཔོན་ཆེན་པོ་བཅུ་གཉིས་ཀྱིས་དམ་བཅས་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">An alternate title for <cite class="title text-en" lang="en">The Detailed Account of the Previous Aspirations of the Thus-Gone Bhaiṣajya­guru­vaiḍūrya­prabha</cite>.</p></div></div></div></div><div id="392ef282-a172-45b8-a156-169992eaa417" class="relative scroll-mt-20"><button type="button" id="radix-_R_2st5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.115</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">thirty-two marks of a great person</div><ul class="ml-4 list-disc"><li class="italic">skyes bu chen po’i mtshan sum cu rtsa gnyis</li><li class="pt-1"><span class="font-tibetan text-base">སྐྱེས་བུ་ཆེན་པོའི་མཚན་སུམ་ཅུ་རྩ་གཉིས།</span></li><li class="italic">dvātriṃśanmahā­puruṣa­lakṣaṇa</li></ul><div class="glossary-instance-definition"><p class="definition">Thirty-two of the 112 identifying physical characteristics of both buddhas and <span data-glossary-id="UT22084-087-009-221">universal emperors</span>, in addition to the <span data-glossary-id="UT22084-087-009-153">eighty minor marks</span>.</p></div></div></div></div><div id="fc87d09b-c219-4d0b-b7d9-e0a5b9b08fa3" class="relative scroll-mt-20"><button type="button" id="radix-_R_2t55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.116</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">three vows</div><ul class="ml-4 list-disc"><li class="italic">sdom pa gsum</li><li class="pt-1"><span class="font-tibetan text-base">སྡོམ་པ་གསུམ།</span></li><li class="italic">trisaṃvara</li></ul><div class="glossary-instance-definition"><p class="definition">There are two common sets of “the <span class="ignore">three vows</span>.” The first set refers to the pratimokṣa, bodhicitta, and mantra vows, and this schema was perhaps most famously promoted in Tibet by the thirteenth-century Tibetan polymath Sakya Paṇḍita. The second set, which is likely the set of <span class="ignore">three vows</span> referred to here, consists of (1) the pratimokṣa vows (Tib. <em class="foreign text-wy" lang="bo-LATN">so thar gyi sdom pa</em>) of the <span data-glossary-id="UT22084-087-009-148">desire</span> realm, (2) the <em class="foreign break text-sa" lang="sa-LATN">dhyāna</em> vows (Tib. <em class="foreign text-wy" lang="bo-LATN">sam gtan gyi sdom pa</em>) of the form realm, and (3) the uncontaminated vows (Tib. <em class="foreign text-wy" lang="bo-LATN">zag med kyi sdom pa</em>) maintained by those who have transcended the three realms and are at the level of a noble being. </p></div></div></div></div><div id="d5b4d6b9-6850-42c5-81c8-ea781b61a47b" class="relative scroll-mt-20"><button type="button" id="radix-_R_2td5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.117</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">thus-gone, thus-gone one</div><ul class="ml-4 list-disc"><li class="italic">de bzhin gshegs pa</li><li class="pt-1"><span class="font-tibetan text-base">དེ་བཞིན་གཤེགས་པ།</span></li><li class="italic">tathāgata</li></ul><div class="glossary-instance-definition"><p>A frequently used synonym for <em class="emph">buddha</em>. According to different explanations, it can be read as <em class="foreign break text-sa" lang="sa-LATN">tathā-gata</em>, literally meaning “one who has thus gone,” or as <em class="foreign break text-sa" lang="sa-LATN">tathā-āgata</em>, “one who has thus come.” <em class="foreign break text-sa" lang="sa-LATN">Gata</em>, though literally meaning “gone,” is a past passive participle used to describe a state or condition of existence. <em class="foreign break text-sa" lang="sa-LATN">Tatha­(tā)</em>, often rendered as “suchness” or “thusness,” is the quality or condition of things as they really are, which cannot be conveyed in conceptual, dualistic terms. Therefore, this epithet is interpreted in different ways, but in general it implies one who has departed in the wake of the buddhas of the past, or one who has manifested the supreme awakening dependent on the reality that does not abide in the two extremes of existence and quiescence. It is also often used as a specific epithet of the Buddha Śākyamuni.</p></div></div></div></div><div id="7ffcb8b3-8a44-4a6d-b2b0-2a6a468bb773" class="relative scroll-mt-20"><button type="button" id="radix-_R_2tl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.118</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">to warm, warm them</div><ul class="ml-4 list-disc"><li class="italic">lhan ner gyur</li><li class="pt-1"><span class="font-tibetan text-base">ལྷན་ནེར་གྱུར།</span></li><li class="italic">tapyeran</li></ul></div></div></div><div id="5bd3e979-9d9a-4c4d-bb03-6ccdf1e97b0f" class="relative scroll-mt-20"><button type="button" id="radix-_R_2tt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.119</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">tortured</div><ul class="ml-4 list-disc"><li class="italic">go rar gzhug pa</li><li class="pt-1"><span class="font-tibetan text-base">གོ་རར་གཞུག་པ།</span></li><li class="italic">avaruddha</li></ul></div></div></div><div id="d815746b-a5c7-43a9-9413-36e91607242f" class="relative scroll-mt-20"><button type="button" id="radix-_R_2u55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.120</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">town</div><ul class="ml-4 list-disc"><li class="italic">grong khyer</li><li class="pt-1"><span class="font-tibetan text-base">གྲོང་ཁྱེར།</span></li><li class="italic">nagara</li></ul></div></div></div><div id="e395621c-5852-46eb-a457-65b28596d6db" class="relative scroll-mt-20"><button type="button" id="radix-_R_2ud5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.121</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Trāṇamukta</div><ul class="ml-4 list-disc"><li class="italic">skyabs grol</li><li class="pt-1"><span class="font-tibetan text-base">སྐྱབས་གྲོལ།</span></li><li class="italic">trāṇamukta</li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva. </p></div></div></div></div><div id="a7b884d2-a341-46dc-9ca7-bd5a6a73eaa3" class="relative scroll-mt-20"><button type="button" id="radix-_R_2ul5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.122</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">tree deity</div><ul class="ml-4 list-disc"><li class="italic">shing gi lha</li><li class="pt-1"><span class="font-tibetan text-base">ཤིང་གི་ལྷ།</span></li><li class="italic">vṛkṣadevatā</li></ul><div class="glossary-instance-definition"><p class="definition">A class of spirit being.</p></div></div></div></div><div id="7d39cc5d-256c-4e30-9eb9-c28731cd772c" class="relative scroll-mt-20"><button type="button" id="radix-_R_2ut5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.123</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">turret</div><ul class="ml-4 list-disc"><li class="italic">ba gam</li><li class="pt-1"><span class="font-tibetan text-base">བ་གམ།</span></li><li class="italic">niryūha</li></ul></div></div></div><div id="7f20ccc0-0a8d-4dec-950e-cd7f6b8a868b" class="relative scroll-mt-20"><button type="button" id="radix-_R_2v55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.124</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">uncorrupted discipline</div><ul class="ml-4 list-disc"><li class="italic">tshul khrims nyams pa med pa</li><li class="pt-1"><span class="font-tibetan text-base">ཚུལ་ཁྲིམས་ཉམས་པ་མེད་པ།</span></li><li class="italic">akhaṇḍaśīla</li></ul></div></div></div><div id="faed50ce-2e2a-4b67-8628-9d65feeacf17" class="relative scroll-mt-20"><button type="button" id="radix-_R_2vd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.125</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">universal emperor</div><ul class="ml-4 list-disc"><li class="italic">’khor los sgyur ba’i rgyal po</li><li class="pt-1"><span class="font-tibetan text-base">འཁོར་ལོས་སྒྱུར་བའི་རྒྱལ་པོ།</span></li><li class="italic">cakravartin</li></ul><div class="glossary-instance-definition"><p class="definition">An ideal monarch or emperor who, as the result of the merit accumulated in previous lifetimes, rules over a vast realm in accordance with the Dharma. Such a monarch is called a <em class="foreign break text-sa" lang="sa-LATN">cakravartin</em> because he bears a wheel (<em class="foreign break text-sa" lang="sa-LATN">cakra</em>) that rolls (<em class="foreign break text-sa" lang="sa-LATN">vartate</em>) across the earth, bringing all lands and kingdoms under his power. The cakravartin conquers his territory without causing harm, and his activity causes beings to enter the path of wholesome actions. According to Vasubandhu’s <cite class="title break text-sa" lang="sa-LATN">Abhidharmakośa</cite>, just as with the buddhas, only one cakravartin appears in a world system at any given time. They are likewise endowed with the thirty-two major marks of a great being (<em class="foreign break text-sa" lang="sa-LATN">mahāpuruṣalakṣaṇa</em>), but a cakravartin’s marks are outshined by those of a buddha. They possess seven precious objects: the wheel, the elephant, the horse, the wish-fulfilling gem, the queen, the general, and the minister. An illustrative passage about the cakravartin and his possessions can be found in <cite class="title text-en" lang="en">The Play in Full</cite> (Toh 95), <a target="_blank" href="https://read.84000.co/translation/toh95.html#UT22084-046-001-94" title="3.3">3.3</a>–<a target="_blank" href="https://read.84000.co/translation/toh95.html#UT22084-046-001-104" title="3.13">3.13</a>. </p><p class="definition">Vasubandhu lists four types of cakravartins: (1) the cakravartin with a golden wheel (<em class="foreign break text-sa" lang="sa-LATN">suvarṇacakravartin</em>) rules over four continents and is invited by lesser kings to be their ruler; (2) the cakravartin with a silver wheel (<em class="foreign break text-sa" lang="sa-LATN">rūpyacakravartin</em>) rules over three continents and his opponents submit to him as he approaches; (3) the cakravartin with a copper wheel (<em class="foreign break text-sa" lang="sa-LATN">tāmracakravartin</em>) rules over two continents and his opponents submit themselves after preparing for battle; and (4) the cakravartin with an iron wheel (<em class="foreign break text-sa" lang="sa-LATN">ayaścakravartin</em>) rules over one continent and his opponents submit themselves after brandishing weapons. </p></div></div></div></div><div id="4606878a-3e90-40c6-97cb-1c3fd3ed91b8" class="relative scroll-mt-20"><button type="button" id="radix-_R_2vl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.126</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vaiḍūrya­nirbhāsa</div><ul class="ml-4 list-disc"><li class="italic">bai DUr+ya ra snang ba, bai DUr+ya snang ba</li><li class="pt-1"><span class="font-tibetan text-base">བཻ་ཌཱུརྱ་ར་སྣང་བ།, བཻ་ཌཱུརྱ་སྣང་བ།</span></li><li class="italic">vaiḍūrya­nirbhāsa</li></ul><div class="glossary-instance-definition"><p class="definition">The buddhafield of the <span data-glossary-id="UT22084-087-009-213">Thus-Gone</span> <span data-glossary-id="UT22084-087-009-238">Bhaiṣajya­guru­vaiḍūrya­prabha­rāja</span>.</p></div></div></div></div><div id="87030664-4985-441c-8cbd-801b543ca41e" class="relative scroll-mt-20"><button type="button" id="radix-_R_2vt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.127</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vaiśālī</div><ul class="ml-4 list-disc"><li class="italic">yangs pa can</li><li class="pt-1"><span class="font-tibetan text-base">ཡངས་པ་ཅན།</span></li><li class="italic">vaiśālī</li></ul><div class="glossary-instance-definition"><p class="definition">One of a number of <span class="ignore">towns</span> where the Buddha Śākyamuni is said to have taught.</p></div></div></div></div><div id="a1fa155f-36e0-401d-a60d-712b3fabb65a" class="relative scroll-mt-20"><button type="button" id="radix-_R_3055anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.128</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vajra</div><ul class="ml-4 list-disc"><li class="italic">rdo rje</li><li class="pt-1"><span class="font-tibetan text-base">རྡོ་རྗེ།</span></li><li class="italic">vajra</li></ul><div class="glossary-instance-definition"><p class="definition">One of the twelve <span data-glossary-id="UT22084-087-009-164">great yakṣa generals</span> who protect and serve those who bear, read, recite, copy, or commission a copy of the <cite class="title break text-sa" lang="sa-LATN">Bhaiṣajya­guru­vaiḍūrya­prabha­rāja­sūtra</cite>.</p></div></div></div></div><div id="d9a23ad2-63f7-4616-88b3-31158ce56f97" class="relative scroll-mt-20"><button type="button" id="radix-_R_30d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.129</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vajrapāṇi</div><ul class="ml-4 list-disc"><li class="italic">lag na rdo rje</li><li class="pt-1"><span class="font-tibetan text-base">ལག་ན་རྡོ་རྗེ།</span></li><li class="italic">vajrapāṇi</li></ul><div class="glossary-instance-definition"><p>Vajrapāṇi means “Wielder of the Vajra.” In the Pali canon, he appears as a yakṣa guardian in the retinue of the Buddha. In the Mahāyāna scriptures he is a bodhisattva and one of the “eight close sons of the Buddha.” In the tantras, he is also regarded as an important Buddhist deity and instrumental in the transmission of tantric scriptures. </p></div></div></div></div><div id="c055f6d1-0659-4747-9503-bc39840c812f" class="relative scroll-mt-20"><button type="button" id="radix-_R_30l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.130</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">vetāla</div><ul class="ml-4 list-disc"><li class="italic">ro langs</li><li class="pt-1"><span class="font-tibetan text-base">རོ་ལངས།</span></li><li class="italic">vetāla</li></ul><div class="glossary-instance-definition"><p class="definition">A class of spirit beings typically associated with violent sorcery rites, the <span class="ignore">vetāla</span> is most often described as a reanimated corpse or zombie. </p></div></div></div></div><div id="b7c0a199-3d98-48e5-b26b-d7bd4160c4f2" class="relative scroll-mt-20"><button type="button" id="radix-_R_30t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.131</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vikala</div><ul class="ml-4 list-disc"><li class="italic">rdzogs byed</li><li class="pt-1"><span class="font-tibetan text-base">རྫོགས་བྱེད།</span></li><li class="italic">vikala</li></ul><div class="glossary-instance-definition"><p class="definition">One of the twelve <span data-glossary-id="UT22084-087-009-164">great yakṣa generals</span> who protect and serve those who bear, read, recite, copy, or commission a copy of the <cite class="title break text-sa" lang="sa-LATN">Bhaiṣajya­guru­vaiḍūrya­prabha­rāja­sūtra</cite>.</p></div></div></div></div><div id="44261343-92a8-413c-b583-04ba1878db62" class="relative scroll-mt-20"><button type="button" id="radix-_R_3155anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.132</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">village</div><ul class="ml-4 list-disc"><li class="italic">grong</li><li class="pt-1"><span class="font-tibetan text-base">གྲོང་།</span></li><li class="italic">grāma</li></ul></div></div></div><div id="eacc31bd-07db-41db-92db-0e8df3e6355d" class="relative scroll-mt-20"><button type="button" id="radix-_R_31d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.133</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">vital energy</div><ul class="ml-4 list-disc"><li class="italic">mdangs</li><li class="pt-1"><span class="font-tibetan text-base">མདངས།</span></li><li class="italic">ojas</li></ul><div class="glossary-instance-definition"><p class="definition">The principle of vital warmth and action throughout the body.</p></div></div></div></div><div id="60745c47-72d0-4e49-a4af-57aecdb4b9e6" class="relative scroll-mt-20"><button type="button" id="radix-_R_31l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.134</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">vitiligo</div><ul class="ml-4 list-disc"><li class="italic">sha bkra</li><li class="pt-1"><span class="font-tibetan text-base">ཤ་བཀྲ།</span></li><li class="italic">śvitra</li></ul></div></div></div><div id="1fb8ada2-2a72-4c2d-9dda-1c75c27fc89f" class="relative scroll-mt-20"><button type="button" id="radix-_R_31t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.135</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">weak constitution</div><ul class="ml-4 list-disc"><li class="italic">lus ngan pa</li><li class="pt-1"><span class="font-tibetan text-base">ལུས་ངན་པ།</span></li><li class="italic">hīnakāya</li></ul></div></div></div><div id="7592fd85-fafc-42db-a077-641db438c9e7" class="relative scroll-mt-20"><button type="button" id="radix-_R_3255anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.136</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">wealth</div><ul class="ml-4 list-disc"><li class="italic">longs spyod</li><li class="pt-1"><span class="font-tibetan text-base">ལོངས་སྤྱོད།</span></li><li class="italic">bhoga</li></ul></div></div></div><div id="b342c5a1-c902-458a-8eff-a8142a795d0b" class="relative scroll-mt-20"><button type="button" id="radix-_R_32d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.137</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">world of Yama</div><ul class="ml-4 list-disc"><li class="italic">gshin rje’i ’jig rten</li><li class="pt-1"><span class="font-tibetan text-base">གཤིན་རྗེའི་འཇིག་རྟེན།</span></li><li class="italic">yamaloka</li></ul><div class="glossary-instance-definition"><p class="definition">The world of the Lord of Death.</p></div></div></div></div><div id="5d1d861a-9a7d-45ee-9d4e-a843c5698e55" class="relative scroll-mt-20"><button type="button" id="radix-_R_32l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.138</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">yakṣa</div><ul class="ml-4 list-disc"><li class="italic">gnod sbyin</li><li class="pt-1"><span class="font-tibetan text-base">གནོད་སྦྱིན།</span></li><li class="italic">yakṣa</li></ul><div class="glossary-instance-definition"><p>A class of nonhuman beings who inhabit forests, mountainous areas, and other natural spaces, or serve as guardians of villages and towns, and may be propitiated for health, wealth, protection, and other boons, or controlled through magic. According to tradition, their homeland is in the north, where they live under the rule of the Great King Vaiśravaṇa.</p><p> Several members of this class have been deified as gods of wealth (these include the just-mentioned Vaiśravaṇa) or as bodhisattva generals of yakṣa armies, and have entered the Buddhist pantheon in a variety of forms, including, in tantric Buddhism, those of wrathful deities.</p></div></div></div></div><div id="33413e9d-f28e-40a7-8f31-b28134daf81b" class="relative scroll-mt-20"><button type="button" id="radix-_R_32t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.139</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Yama</div><ul class="ml-4 list-disc"><li class="italic">gshin rje</li><li class="pt-1"><span class="font-tibetan text-base">གཤིན་རྗེ།</span></li><li class="italic">yama</li></ul><div class="glossary-instance-definition"><p class="definition">The Lord of Death. </p></div></div></div></div></div></div></div><div data-state="inactive" data-orientation="horizontal" role="tabpanel" aria-labelledby="radix-_R_2npftt6btb_-trigger-bibliography" id="radix-_R_2npftt6btb_-content-bibliography" tabindex="0" data-slot="tabs-content" class="mt-2 ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 pb-8 data-[state=inactive]:hidden"><div class="flex flex-col w-full"><div id="bibliography" class="relative scroll-mt-20"><button type="button" id="radix-_R_2nanpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4 @c/sidebar:mt-5 mt-6">b.</button><div class="passage pl-6 @c/sidebar:pl-4"><h2 class="font-serif font-light text-primary scroll-m-20 text-xl @c/sidebar:mt-4 mt-6 @c/sidebar:pb-2 pb-3 @c/sidebar:text-left text-center section-title">Bibliography</h2></div></div><div class="mt-3 flex flex-col gap-6"><div class="flex flex-col gap-4"><div id="Tibetan Sources-0" class="relative scroll-mt-20"><button type="button" id="radix-_R_ad7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4 @c/sidebar:mt-0.5 mt-4">b.1</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="text-secondary font-sans text-base font-bold">Tibetan Sources</div></div></div><div id="c39078eb-5995-4e1e-a5d3-a78be259d767" class="relative scroll-mt-20"><button type="button" id="radix-_R_4cd7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.1.1</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p><em>’phags pa bcom ldan ’das sman gyi bla bai Dur+ya’i ’od gyi smon lam gyi khyad par rgyas pa zhes bya ba theg pa chen po’i mdo</em> (<em>Ārya­bhagavān­bhaiṣajya­guru­vaiḍūrya­prabhasya­ pūrva­praṇidhāna­viśeṣa­vistāra­nāma­mahāyāna­sūtra</em>). Toh 504, Degé Kangyur vol. 87 (rgyud ’bum, da), folios 274.a–283.b.</p></div></div></div><div id="4ac6bbba-f088-4e9a-8de3-6818a74dde0f" class="relative scroll-mt-20"><button type="button" id="radix-_R_4kd7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.1.2</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p><em>’phags pa bcom ldan ’das sman gyi bla bai Dur+ya’i ’od gyi smon lam gyi khyad par rgyas pa zhes bya ba theg pa chen po’i mdo</em> (<em>Ārya­bhagavān­bhaiṣajya­guru­vaiḍūrya­prabhasya­ pūrva­praṇidhāna­viśeṣa­vistāra­nāma­mahāyāna­sūtra</em>). bka’ ’gyur (dpe bsdur ma) [Comparative Edition of the Kangyur], krung go’i bod rig pa zhib ’jug ste gnas kyi bka’ bstan dpe sdur khang (The Tibetan Tripitaka Collation Bureau of the China Tibetology Research Center). 108 volumes. Beijing: krung go’i bod rig pa dpe skrun khang (China Tibetology Publishing House) 2006–9, vol. 87, pp. 814–36.</p></div></div></div><div id="9af4575c-1ccb-406b-b64f-92ae337ba802" class="relative scroll-mt-20"><button type="button" id="radix-_R_4sd7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.1.3</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p><em>’phags pa bcom ldan ’das sman gyi bla bai Dur+ya’i ’od gyi smon lam gyi khyad par rgyas pa zhes bya ba theg pa chen po’i mdo</em> (<em>Ārya­bhagavān­bhaiṣajya­guru­vaiḍūrya­prabhasya ­pūrva­praṇidhāna­viśeṣa­vistāra­nāma­mahāyāna­sūtra</em>). Stok Palace Kangyur vol. 72 (mdo, zha), folios 268.a–282.a. </p></div></div></div><div id="fd79a63c-60c4-4a2f-ae51-eafa86c0af33" class="relative scroll-mt-20"><button type="button" id="radix-_R_54d7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.1.4</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p><em>’phags pa de bzhin gshegs pa bdun gyi sngon gyi smon lam gyi khyad par rgyas pa zhes bya ba theg pa chen po’i mdo</em> (<em>Ārya­sapta­tathāgata­pūrva­praṇidhāna­viśeṣa­vistāra­nāma­mahāyāna­sūtra</em>) [<em>The Detailed Account of the Previous Aspirations of the Seven Thus-Gone Ones</em>]. Toh 503, Degé Kangyur vol. 87 (rgyud ’bum, da), folios 248.b–273.b. English translation in Dharmachakra Translations Committee (2021).</p></div></div></div><div id="4030dbf2-375d-4b46-9741-d1cd43945f8f" class="relative scroll-mt-20"><button type="button" id="radix-_R_5cd7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.1.5</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p><em>’phags pa de bzhin gshegs pa’i ting nge ’dzin gyi stobs bskyed pa bai DUr+ya’i ’od ces bya ba’i gzungs</em> (<em>Ārya­tathāgata­vaiḍūrya­prabha­nāma­balādhāna­samādhi­dhāraṇī</em>) [<em>The Dhāraṇī of the Tathāgata Vaiḍūryaprabha</em>]. Toh 505, Degé Kangyur vol. 87 (rgyud ’bum, da), folios 284.a–286.a. English translation in <a href="https://read.84000.co/translation/toh505.html">84000 Translation Team 2024</a>.</p></div></div></div><div id="74ed467e-4134-4b42-b24c-1fa8f5e64cf5" class="relative scroll-mt-20"><button type="button" id="radix-_R_5kd7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.1.6</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p><em>pho brang stod thang ldan dkar gyi chos kyi ’gyur ro cog gi dkar chag</em> [Denkarma]. Toh 4364, Degé Tengyur vol. 206 (sna tshogs, jo), folios 294.b–310.a.</p></div></div></div><div id="f64f5152-007f-4801-ada1-5d2e93b8c76e" class="relative scroll-mt-20"><button type="button" id="radix-_R_5sd7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.1.7</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Śāntideva. <em>bslab pa kun las btus pa’i mngon par rtogs pa</em> (<em>Śikṣāsamuccaya</em>). Toh 3940, Degé Tengyur vol. 111 (dbu ma, khi), folios 3.a–194.b.</p></div></div></div><div id="fd851dc5-2135-45a2-868e-82c10ec7f0c5" class="relative scroll-mt-20"><button type="button" id="radix-_R_64d7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.1.8</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p><em>sman gtong ba’i tshe sman la sngags kyis gdab pa</em>. Toh 505a, Degé Kangyur vol. 87 (rgyud ’bum, da), folio 286.a. English translation in <a href="https://read.84000.co/translation/toh505a.html">Dalton 2023</a>.</p></div></div></div></div><div class="flex flex-col gap-4"><div id="Sanskrit Sources-1" class="relative scroll-mt-20"><button type="button" id="radix-_R_al7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4 @c/sidebar:mt-0.5 mt-4">b.2</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="text-secondary font-sans text-base font-bold">Sanskrit Sources</div></div></div><div id="a49a0a3f-6c51-4b3d-bac3-caef4e493a2f" class="relative scroll-mt-20"><button type="button" id="radix-_R_2cl7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.2.1</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Bendall, Cecil, ed. <em>Çikshāsamuccaya: A Compendium of Buddhistic Teaching Compiled by Çāntideva, Chiefly from Earlier Mahāyāna-Sūtras</em>. Bibliotheca Buddhica 1. St. Petersburg: Académie Impériale des Sciences, 1902.</p></div></div></div><div id="59cca878-8b99-4f6f-91fa-bce8c35c9331" class="relative scroll-mt-20"><button type="button" id="radix-_R_2kl7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.2.2</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Dutt, Nalinaksha, D. M. Bhattacharya, and Vidyavaridhi Shiv Nath Sharma, eds. “Bhaiṣajya­guru-sūtram.” In <em>Gilgit Manuscripts Vol. I</em>, 1–32. Calcutta: Calcutta Oriental Press, 1939. </p></div></div></div><div id="7a328042-8a34-462c-a548-064907b20028" class="relative scroll-mt-20"><button type="button" id="radix-_R_2sl7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.2.3</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Schopen, Gregory. “The <em>Bhaiṣajya­guru-Sūtra</em> and the Buddhism of Gilgit.” PhD diss., Australian National University, 1978. </p></div></div></div><div id="45cd117f-7621-4a86-941b-4ee1f8a9f238" class="relative scroll-mt-20"><button type="button" id="radix-_R_34l7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.2.4</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Vaidya, P. L., ed. <em>Mahāyāna-sūtra-saṁgraha: Part I</em>. Buddhist Sanskrit Texts 17. Darbhanga: Mithila Institute, 1961.</p></div></div></div></div><div class="flex flex-col gap-4"><div id="Reference Works-2" class="relative scroll-mt-20"><button type="button" id="radix-_R_at7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4 @c/sidebar:mt-0.5 mt-4">b.3</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="text-secondary font-sans text-base font-bold">Reference Works</div></div></div><div id="88292ab1-55b8-4b4f-b165-87cf3f421fa7" class="relative scroll-mt-20"><button type="button" id="radix-_R_2ct7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.1</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Butön Rinchen Drup (bu ston rin chen grub). <em>chos ’byung</em> (<em>bde bar gshegs pa’i bstan pa’i gsal byed chos kyi ’byung gnas gsung rab rin po che’i gter mdzod</em>). In <em>gsung ’bum/ rin chen grub/ zhol par ma/ ldi lir bskyar par brgyab pa/</em>, vol. 24 (ya), pp. 633–1055. New Delhi: International Academy of Indian Culture, 1965–71.</p></div></div></div><div id="4a194bf7-43de-4e1f-9daa-ade57d360e0d" class="relative scroll-mt-20"><button type="button" id="radix-_R_2kt7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.2</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p><em>dkar chag ’phang thang ma</em>. Beijing: mi rigs dpe skrun khang, 2003.</p></div></div></div><div id="7a0e3048-773c-4037-bb80-c7651451041d" class="relative scroll-mt-20"><button type="button" id="radix-_R_2st7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.3</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Eimer, Helmut. <em>Der Tantra-Katalog des Bu ston im Vergleich mit der Abteilung Tantra des tibetischen Kanjur: Studie, Textausgabe, Konkordanzen und Indices</em>. Bonn: Indica et Tibetica Verlag, 1989.</p></div></div></div><div id="da27eb8f-1e7c-4ff8-adec-599fc61ea3a8" class="relative scroll-mt-20"><button type="button" id="radix-_R_34t7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.4</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Lancaster, Lewis R. <em><a href="http://www.acmuller.net/descriptive_catalogue/index.html">The Korean Buddhist Canon</a></em>. Accessed April 23, 2019.</p></div></div></div><div id="03601313-6748-48d3-b7cc-a88884016aaf" class="relative scroll-mt-20"><button type="button" id="radix-_R_3ct7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.5</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Yoshimura, Shyuki. <em>The Denkar-Ma: An Oldest Catalogue of the Tibetan Buddhist Canons</em>. Kyoto: Ryukoku University, 1950.</p></div></div></div></div><div class="flex flex-col gap-4"><div id="Secondary Sources-3" class="relative scroll-mt-20"><button type="button" id="radix-_R_b57anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4 @c/sidebar:mt-0.5 mt-4">b.4</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="text-secondary font-sans text-base font-bold">Secondary Sources</div></div></div><div id="5674c733-cab3-4973-8f9c-586e3b40bee1" class="relative scroll-mt-20"><button type="button" id="radix-_R_1d57anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.4.1</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>84000 Translation Team, trans. <em><a href="https://read.84000.co/translation/toh505.html">The Vaiḍūryaprabha Dhāraṇī</a></em> (<em>Vaiḍūrya­prabha­dharaṇī</em>, Toh 505). 84000: Translating the Words of the Buddha, 2024.</p></div></div></div><div id="3966e84b-2cc0-4cb4-8e1c-fecd7af13337" class="relative scroll-mt-20"><button type="button" id="radix-_R_1l57anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.4.2</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Dalton, Catherine. trans. <em><a href="https://read.84000.co/translation/toh505a.html">A Mantra for Incanting Medicines When Administering Them</a></em> (<em>sman gtong ba’i tshe sman la sngags kyi gdab pa</em>, Toh 505a). 84000: Translating the Words of the Buddha, 2023.</p></div></div></div><div id="6a72ac5d-33d5-42b2-9ae2-5367bd715d1c" class="relative scroll-mt-20"><button type="button" id="radix-_R_1t57anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.4.3</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Dharmachakra Translations Committee, trans. <em><a href="https://read.84000.co/translation/toh503.html">The Detailed Account of the Previous Aspirations of the Seven Thus-Gone Ones</a></em> (<em>Sapta­tathāgata­pūrva­praṇidhāna­viśeṣa­vistāra</em>, Toh 503). 84000: Translating the Words of the Buddha, 2021.</p></div></div></div></div></div></div></div><div data-state="inactive" data-orientation="horizontal" role="tabpanel" aria-labelledby="radix-_R_2npftt6btb_-trigger-abbreviations" id="radix-_R_2npftt6btb_-content-abbreviations" tabindex="0" data-slot="tabs-content" class="mt-2 ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 data-[state=inactive]:hidden"><div class="h-0"></div><div></div><div class="h-0"></div><div class="flex flex-col gap-4 pb-8"><div class="flex gap-5"><div class="animate-pulse rounded-md bg-foreground/10 h-6 w-6"></div><div class="animate-pulse rounded-md bg-foreground/10 h-32 grow"></div></div><div class="flex gap-5"><div class="animate-pulse rounded-md bg-foreground/10 h-6 w-6"></div><div class="animate-pulse rounded-md bg-foreground/10 h-32 grow"></div></div><div class="flex gap-5"><div class="animate-pulse rounded-md bg-foreground/10 h-6 w-6"></div><div class="animate-pulse rounded-md bg-foreground/10 h-32 grow"></div></div></div></div></div></div></div></div></div><script>$RS("S:5","P:5")</script><script>self.__next_f.push([1,"2d:I[916077,[\"/_next/static/chunks/2fb4b456dae69409.js?dpl=dpl_C4kSSWFdt51TZQpmuYtxXgHAunY1\",\"/_next/static/chunks/6165fecb8e0eae36.js?dpl=dpl_C4kSSWFdt51TZQpmuYtxXgHAunY1\",\"/_next/static/chunks/1cfd6a6ab8fe5d2f.js?dpl=dpl_C4kSSWFdt51TZQpmuYtxXgHAunY1\",\"/_next/static/chunks/15d7387d42764915.js?dpl=dpl_C4kSSWFdt51TZQpmuYtxXgHAunY1\"],\"ReaderBodyPanel\"]\n2e:Td5a,བཙུན་པ་ཀུན་དགའ་བོ་གཞན་ཡང་རྒྱལ་པོ་རྒྱལ་རིགས་སྤྱི་བོ་ནས་དབང་བསྐུར་བ་རྣམས་ལ། ནད་ཀྱི་གནོད་པའམ། རང་གི་དམག་ཚོགས་སམ། ཕ་རོལ་གྱི་དམག་ཚོགས་ཀྱི་གནོད་པའམ། རྒྱུ་སྐར་གྱི་གནོད་པའམ། གཟའ་\nཟླ་བའི་གནོད་པའམ། གཟའ་ཉི་མའི་གནོད་པའམ། དུས་མ་ཡིན་པའི་རླུང་དང་ཆར་གྱི་གནོད་པའམ། ཐན་པའི་གནོད་པ་ཡང་རུང་སྟེ། གནོད་པ་དང་། ནད་འགོ་བ་དང་། འཁྲུག་པ་ཞིག་ཉེ་བར་གནས་པར་གྱུར་ན། རྒྱལ་པོ་རྒྱལ་རིགས་སྤྱི་བོ་\nནས་དབང་བསྐུར་བ་དེས། སེམས་ཅན་ཐམས་ཅད་ལ་བྱམས་པའི་སེམས་སུ་བྱ། བཙོན་དུ་བཟུང་བ་རྣམས་གཏང་བར་བྱ་ཞིང་གོང་དུ་སྨོས་པ་བཞིན་དུ་བཅོམ་ལྡན་འདས་དེ་བཞིན་གཤེགས་པ་སྨན་གྱི་བླ་བཻ་ཌཱུརྱའི་འོད་དེ་ལ་དེ་ལྟ་བུར་མཆོད་པ་བྱས་ན། རྒྱལ་པོ་རྒྱལ་རིགས་\nསྤྱི་བོ་ནས་དབང་བསྐུར་བ་དེའི་དགེ་བའི་རྩ་བ་དེ་དང་། བཅོམ་ལྡན་འདས་དེ་བཞིན་གཤེགས་པ་སྨན་གྱི་བླ་བཻ་ཌཱུརྱའི་འོད་དེའི་སྔོན་གྱི་སྨོན་ལམ་གྱི་ཁྱད་པར་གྱིས་ཡུལ་བདེ་བ་དང་། ལོ་ལེགས་པར་འགྱུར། རླུང་དང་ཆར་དུས་སུ་ལྡང་ཞིང་ལོ་ཏོག་འགྲུབ་པར་འགྱུར། \nཡུལ་དེ་ན་གནས་པའི་སེམས་ཅན་ཐམས་ཅད་ཀྱང་ནད་མེད་པ་དང་། བདེ་བ་དང་། མཆོག་ཏུ་དགའ་བ་མང་བར་འགྱུར་རོ། །ཡུལ་དེར་གནོད་སྦྱིན་དང་། སྲིན་པོ་དང་། འབྱུང་པོ་དང་། ཤ་ཟ་མ་རུངས་པས་སེམས་ཅན་རྣམས་ལ་གཙེ་བར་མི་འགྱུར་རོ། །ལྟས་\nངན་པ་ཐམས་ཅད་མཐོང་བར་མི་འགྱུར་རོ། །རྒྱལ་པོ་རྒྱལ་རིགས་སྤྱི་བོ་ནས་དབང་བསྐུར་བ་དེའི་ཚེ་དང་། མདོག་དང་། སྟོབས་དང་། ནད་མེད་པ་དང་། དབང་ཕྱུག་རྣམས་མངོན་པར་འཕེལ་བར་འགྱུར་རོ། །2f:Td1c,བྱང་ཆུབ་སེམས་དཔའ་སྐྱབས་གྲོལ་གྱིས་སྨྲས་པ། བཙུན་པ་ཀུན་དགའ་བོ་དུས་མ་ཡིན་པར་འཆི་བ་དགུ་ཡོད་པར། ཁྱོད་ཀྱིས་དེ་བ"])</script><script>self.__next_f.push([1,"ཞིན་གཤེགས་པ་ལས་[F.282.b]མ་ཐོས་སམ། དེའི་ཕྱིར། སྔགས་དང་སྨན་གྱི་སྦྱོར་བ་རྣམས་བསྟན་ཏོ། །སེམས་ཅན་ནད་ཀྱིས་བཏབ་ལ། དེ་ནད་ཚབས་མི་ཆེས་ཀྱང་སྨན་དང་རིམ་གྲོ་བྱེད་པ་དང་མི་ལྡན་ནམ། ཡང་ན་སྨན་པ་སྨན་མ་ཡིན་པ་བྱེད་པ་ཡང་ཡོད་དེ། འདི་\nནི་དུས་མ་ཡིན་པར་འཆི་བ་དང་པོའོ། །དུས་མ་ཡིན་པར་འཆི་བ་གཉིས་པ་ནི། གང་དག་རྒྱལ་པོའི་ཆད་པས་འཆི་བའི་དུས་བྱེད་པའོ། །དུས་མ་ཡིན་པར་འཆི་བ་གསུམ་པ་ནི། གང་དག་ཧ་ཅང་བག་མེད་དེ་བག་མེད་པར་གནས་པ་དེ་དག་ལ་\nམི་མ་ཡིན་པ་དག་གིས་མདངས་འཕྲོག་པའོ། །དུས་མ་ཡིན་པར་འཆི་བ་བཞི་པ་ནི། གང་དག་མེས་ཚིག་སྟེ། འཆི་བའི་དུས་བྱེད་པའོ། །དུས་མ་ཡིན་པར་འཆི་བ་ལྔ་པ་ནི། གང་དག་ཆུས་འཆི་བའོ། །དུས་མ་ཡིན་པར་འཆི་བ་དྲུག་པ་ནི། \nགང་དག་སེང་གེ་དང་། སྟག་དང་། ཝ་དང་། སྦྲུལ་དང་། གཅན་གཟན་ཁྲོ་བོའི་ནང་དུ་ཆུད་དེ་འཆི་བའོ། །དུས་མ་ཡིན་པར་འཆི་བ་བདུན་པ་ནི། གང་དག་རི་ཁ་ནས་གཡང་དུ་ལྷུང་བའོ། །དུས་མ་ཡིན་པར་འཆི་བ་བརྒྱད་པ་ནི། གང་དག་དུག་\nདང་། བྱད་དང་། རོ་ལངས་ཀྱི་སྦྱོར་བས་གསོད་པའོ། །དུས་མ་ཡིན་པར་འཆི་བ་དགུ་པ་ནི། གང་དག་ཟས་དང་སྐོམ་མ་རྙེད་ནས་བཀྲེས་པ་དང་། སྐོམ་པས་ཉེན་ཏེ་འཆི་བའི་དུས་བྱེད་པའོ། །མདོར་ན་འདི་དག་ནི། དེ་བཞིན་གཤེགས་པས་\nདུས་མ་ཡིན་པར་འཆི་བ་ཆེན་པོར་བསྟན་པ་སྟེ། གཞན་ཡང་དུས་མ་ཡིན་པར་འཆི་བ་ནི་གྲངས་མེད་དཔག་ཏུ་མེད་དོ། །"])</script><script>self.__next_f.push([1,"17:[\"$\",\"$L2d\",null,{\"titles\":[{\"uuid\":\"9bf59a9c-baf1-49e3-989e-7cff597a37f0\",\"title\":\"The Detailed Account of the Previous Aspirations of the Blessed Bhaiṣajya­guru­vaiḍūrya­prabha\",\"language\":\"en\",\"type\":\"mainTitle\"},{\"uuid\":\"17746335-8e3f-44af-9533-923b5e319d84\",\"title\":\"Bhagavān­bhaiṣajya­guru­vaiḍūrya­prabhasya pūrva­praṇidhāna­viśeṣa­vistāra\",\"language\":\"Sa-Ltn\",\"type\":\"mainTitle\"},{\"uuid\":\"e23d1f55-06da-4713-900a-fad56b00884e\",\"title\":\"bcom ldan ’das sman gyi bla bai Dur+ya’i ’od gyi smon lam gyi khyad par rgyas pa\",\"language\":\"Bo-Ltn\",\"type\":\"mainTitle\"},{\"uuid\":\"aa6b49e4-7c8b-4b16-97a2-a2f5a4d9bc6b\",\"title\":\"བཅོམ་ལྡན་འདས་སྨན་གྱི་བླ་བཻ་ཌུརྱའི་འོད་གྱི་སྨོན་ལམ་གྱི་ཁྱད་པར་རྒྱས་པ།\",\"language\":\"bo\",\"type\":\"mainTitle\"},{\"uuid\":\"9e2f0f23-fd78-4b14-9498-4fa910882935\",\"title\":\"The Shorter Medicine Buddha Sūtra\",\"language\":\"en\",\"type\":\"otherTitle\"},{\"uuid\":\"12939ec1-2688-490a-9ee6-92187d49e326\",\"title\":\"《藥師琉璃光如來本願功德經》\",\"language\":\"zh\",\"type\":\"otherTitle\"},{\"uuid\":\"d8bbeecd-8ade-4265-b824-e1ff0ede3079\",\"title\":\"sman mdo chung ba/\",\"language\":\"Bo-Ltn\",\"type\":\"otherTitle\"},{\"uuid\":\"663901a9-3a43-4a25-845a-44aab3d0c46a\",\"title\":\"The Noble Great Vehicle Sūtra “The Detailed Account of the Previous Aspirations of the Blessed Bhaiṣajya­guru­vaiḍūrya­prabha”\",\"language\":\"en\",\"type\":\"longTitle\"},{\"uuid\":\"07eaadd9-b6de-4e66-887d-25978342ab9a\",\"title\":\"Ārya­bhagavān­bhaiṣajya­guru­vaiḍūrya­prabhasya pūrva­praṇidhāna­viśeṣa­vistāra­nāma­mahāyāna­sūtra\",\"language\":\"Sa-Ltn\",\"type\":\"longTitle\"},{\"uuid\":\"d4e3ea6a-6279-4e43-8d13-912f99d7ede7\",\"title\":\"’phags pa bcom ldan ’das sman gyi bla bai Dur+ya’i ’od gyi smon lam gyi khyad par rgyas pa zhes bya ba theg pa chen po’i mdo\",\"language\":\"Bo-Ltn\",\"type\":\"longTitle\"},{\"uuid\":\"8b791dff-34fc-4233-9504-6ddff312dfe9\",\"title\":\"འཕགས་པ་བཅོམ་ལྡན་འདས་སྨན་གྱི་བླ་བཻ་ཌུརྱའི་འོད་གྱི་སྨོན་ལམ་གྱི་ཁྱད་པར་རྒྱས་པ་ཞེས་བྱ་བ་ཐེག་པ་ཆེན་པོའི་མདོ།\",\"language\":\"bo\",\"type\":\"longTitle\"},{\"uuid\":\"2f8a96eb-85e9-4a93-94ef-0cf517726235\",\"title\":\"Toh 504\",\"language\":\"en\",\"type\":\"toh\"}],\"frontMatter\":[{\"type\":\"passage\",\"attrs\":{\"uuid\":\"b4f3f5f1-9116-4d5b-839f-a6af8847199f\",\"sort\":2,\"type\":\"summaryHeader\",\"label\":\"s.\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":2,\"start\":0,\"end\":7,\"uuid\":\"f234475e-72e1-4ac6-92f9-fb914f1ee492\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"Summary\",\"attrs\":{\"start\":0,\"end\":7}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"bc31cfc8-536c-4c75-9605-1e629f9e0515\",\"sort\":4,\"type\":\"summary\",\"label\":\"s.1\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":673,\"uuid\":\"bc31cfc8-536c-4c75-9605-1e629f9e0515\"},\"content\":[{\"type\":\"text\",\"text\":\"The Detailed Account of the Previous Aspirations of the Blessed Bhaiṣajya­guru­vaiḍūrya­prabha \",\"attrs\":{\"start\":0,\"end\":95},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"f1b7b9ce-2bb9-4676-a55c-019ba6df91aa\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"centers on the figure commonly known as the Medicine Buddha. The text opens in \",\"attrs\":{\"start\":95,\"end\":174}},{\"type\":\"text\",\"text\":\"Vaiśālī\",\"attrs\":{\"start\":174,\"end\":181},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"87030664-4985-441c-8cbd-801b543ca41e\",\"uuid\":\"779ed480-a8c9-4c53-aab6-a625a98c0595\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", where the Buddha Śākyamuni is seated with a large retinue of human and divine beings. The bodhisattva \",\"attrs\":{\"start\":181,\"end\":285}},{\"type\":\"text\",\"text\":\"Mañjuśrī\",\"attrs\":{\"start\":285,\"end\":293},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a9d821a9-3cc6-4f11-94b6-c36ad0b6a6cb\",\"uuid\":\"37a9b64f-d523-4f8d-9c91-31ff65067f89\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" asks Śākyamuni to teach the names and previous aspirations of the buddhas, along with the benefit that buddhas can bring during future times when the Dharma has nearly disappeared. The Buddha gives a teaching on the name and previous aspirations of the Buddha \",\"attrs\":{\"start\":293,\"end\":554}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha\",\"attrs\":{\"start\":554,\"end\":584},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"496408c1-e2d7-4787-acaf-cf6b194d9722\",\"uuid\":\"27256ea4-14b6-474d-877f-381e8e957253\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and then details the benefits that arise from hearing and retaining this buddha’s name.\",\"attrs\":{\"start\":584,\"end\":673}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"120f6725-48e0-46ef-9bd7-09d8d37d2b93\",\"sort\":13,\"type\":\"acknowledgmentHeader\",\"label\":\"ac.\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":2,\"start\":0,\"end\":16,\"uuid\":\"a1e81eb9-8291-4e22-bc05-9238a54924ca\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"Acknowledgements\",\"attrs\":{\"start\":0,\"end\":16}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"0b8bbcf6-9d56-40af-8432-ef937b8a02fd\",\"sort\":15,\"type\":\"acknowledgment\",\"label\":\"ac.1\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":140,\"uuid\":\"cdfb38b9-8ca1-4951-b623-12001a97cfa1\"},\"content\":[{\"type\":\"text\",\"text\":\"This text was translated by the Dharmachakra Translation Committee. The translation was produced by Adam Krug and edited by Andreas Doctor. \",\"attrs\":{\"start\":0,\"end\":140}}]},{\"type\":\"paragraph\",\"attrs\":{\"start\":140,\"end\":252,\"uuid\":\"a1e3e758-62b7-4ace-857d-1b739f2eab1d\"},\"content\":[{\"type\":\"text\",\"text\":\"The translation was completed under the patronage and supervision of 84000: Translating the Words of the Buddha.\",\"attrs\":{\"start\":140,\"end\":252}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"20b5bc39-98d9-4598-9927-7df3144a5dc2\",\"sort\":18,\"type\":\"acknowledgment\",\"label\":\"ac.2\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":153,\"uuid\":\"20b5bc39-98d9-4598-9927-7df3144a5dc2\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"efb22f57-ad7e-40a7-a712-6d862ec0234b\"},\"content\":[{\"type\":\"text\",\"text\":\"The generous sponsorship of May, George, Likai, and Lillian Gu, which helped make the work on this translation possible, is most gratefully acknowledged.\",\"attrs\":{\"start\":0,\"end\":153}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"dca7c944-4e66-428d-a179-71e5a48c6fee\",\"sort\":20,\"type\":\"introductionHeader\",\"label\":\"i.\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":2,\"start\":0,\"end\":12,\"uuid\":\"22e7209e-15e8-46af-b088-0985d4221d5e\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"Introduction\",\"attrs\":{\"start\":0,\"end\":12}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"b20b0ccc-ed4f-4fba-9974-7ccd4baa1e8e\",\"sort\":22,\"type\":\"introduction\",\"label\":\"i.1\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":739,\"uuid\":\"b20b0ccc-ed4f-4fba-9974-7ccd4baa1e8e\"},\"content\":[{\"type\":\"text\",\"text\":\"The Detailed Account of the Previous Aspirations of the Blessed Bhaiṣajya­guru­vaiḍūrya­prabha \",\"attrs\":{\"start\":0,\"end\":95},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"e89d489f-f7c8-44d0-b8f1-bb5a63f92ff1\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"opens in \",\"attrs\":{\"start\":95,\"end\":104}},{\"type\":\"text\",\"text\":\"Vaiśālī\",\"attrs\":{\"start\":104,\"end\":111},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"87030664-4985-441c-8cbd-801b543ca41e\",\"uuid\":\"6d5fbbd2-89eb-47a0-a575-af82b18e19bc\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", where the Buddha Śākyamuni is seated with a saṅgha of eight thousand monks, thirty-six thousand bodhisattvas, and a large gathering of \",\"attrs\":{\"start\":111,\"end\":248}},{\"type\":\"text\",\"text\":\"gods\",\"attrs\":{\"start\":248,\"end\":252},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"743aac3d-15fc-4192-be69-b05c5584d4ea\",\"uuid\":\"38558e12-83e1-4c44-bcab-b64c67bef0d7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", spirit beings, and humans. The bodhisattva \",\"attrs\":{\"start\":252,\"end\":297}},{\"type\":\"text\",\"text\":\"Mañjuśrī\",\"attrs\":{\"start\":297,\"end\":305},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a9d821a9-3cc6-4f11-94b6-c36ad0b6a6cb\",\"uuid\":\"838dc5fe-b61f-4525-9bee-2e8498ce00fb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" rises from his seat and asks the Buddha to give a Dharma teaching about the names and previous aspirations of the buddhas, and to describe the benefits that buddhas can bring to those who live in future times when the Dharma has nearly vanished. In response, Śākyamuni discusses the twelve aspirations of the Buddha \",\"attrs\":{\"start\":305,\"end\":622}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha\",\"attrs\":{\"start\":622,\"end\":652},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"496408c1-e2d7-4787-acaf-cf6b194d9722\",\"uuid\":\"7cd7a151-da65-41d9-a48d-0c3234a9c3b1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", his buddhafield, and the benefits to be gained by those who hear and retain his name.\",\"attrs\":{\"start\":652,\"end\":739}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"c8f935fd-c3f6-4e59-9792-796622e3ae95\",\"sort\":33,\"type\":\"introduction\",\"label\":\"i.2\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":941,\"uuid\":\"c8f935fd-c3f6-4e59-9792-796622e3ae95\"},\"content\":[{\"type\":\"text\",\"text\":\"The aspirations of \",\"attrs\":{\"start\":0,\"end\":19}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha\",\"attrs\":{\"start\":19,\"end\":49},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"496408c1-e2d7-4787-acaf-cf6b194d9722\",\"uuid\":\"1d6e8870-5f8f-4598-a9b5-3fe0c412039d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" center on bringing benefit to others. The sūtra relays that, first and foremost, \",\"attrs\":{\"start\":49,\"end\":131}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha\",\"attrs\":{\"start\":131,\"end\":161},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"496408c1-e2d7-4787-acaf-cf6b194d9722\",\"uuid\":\"841c1cf1-598e-4802-a5e0-3b307a3b9686\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" seeks to elevate all beings to the same level of realization that he has achieved, and to illuminate the world with light capable of dispelling the darkness that hinders spiritual progress. He aims to use his wisdom and \",\"attrs\":{\"start\":161,\"end\":382}},{\"type\":\"text\",\"text\":\"skillful means\",\"attrs\":{\"start\":382,\"end\":396},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e027cc95-c6fb-48fa-ae75-2c7be803ad4b\",\"uuid\":\"27845c92-7058-448f-92f3-b92e220da65c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" to bring immeasurable wealth to beings, and to steer them away from mistaken paths, thus leading them to the Mahāyāna and ensuring their ability to \",\"attrs\":{\"start\":396,\"end\":545}},{\"type\":\"text\",\"text\":\"practice pure conduct\",\"attrs\":{\"start\":545,\"end\":566},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"89913917-2506-4297-9321-91c13315a95d\",\"uuid\":\"abb3bf19-af60-4353-985f-7ccc44d3bd78\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and discipline. He aspires also to cure beings of any ailments they may face, including the diseases that may afflict them, promising good health so they can devote themselves to spiritual practice. In short, he aims to assist all beings facing unfortunate circumstances by freeing them from ailments, ultimately leading them to liberation from the cycle of birth and death.\",\"attrs\":{\"start\":566,\"end\":941}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"8c99cef3-8e72-4f6a-bf54-2c99e4a9afc2\",\"sort\":47,\"type\":\"introduction\",\"label\":\"i.3\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":331,\"uuid\":\"8c99cef3-8e72-4f6a-bf54-2c99e4a9afc2\"},\"content\":[{\"type\":\"text\",\"text\":\"Having detailed these aspirations, Śākyamuni next turns to \",\"attrs\":{\"start\":0,\"end\":59}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha\",\"attrs\":{\"start\":59,\"end\":89},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"496408c1-e2d7-4787-acaf-cf6b194d9722\",\"uuid\":\"65e766d4-bc98-4a2d-b8a6-8c376c087d46\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s buddhafield, explaining that it is completely pure and encouraging all Mahāyāna practitioners to make the aspiration to be born in that realm. He then lists the benefits associated with simply hearing \",\"attrs\":{\"start\":89,\"end\":293}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha\",\"attrs\":{\"start\":293,\"end\":323},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"496408c1-e2d7-4787-acaf-cf6b194d9722\",\"uuid\":\"97f0922d-a574-4e34-b925-9bc33c8e3dcf\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s name.\",\"attrs\":{\"start\":323,\"end\":331}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"e78902e6-cabb-46d2-b142-27f2d3ff1bd9\",\"sort\":53,\"type\":\"introduction\",\"label\":\"i.4\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":586,\"uuid\":\"e78902e6-cabb-46d2-b142-27f2d3ff1bd9\"},\"content\":[{\"type\":\"text\",\"text\":\"Mañjuśrī\",\"attrs\":{\"start\":0,\"end\":8},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a9d821a9-3cc6-4f11-94b6-c36ad0b6a6cb\",\"uuid\":\"bcf68ef2-c1b0-48ca-8bd6-78499e387a22\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" responds by vowing to teach this sūtra in the future and provides a short set of instructions on how to worship it as a written work. Śākyamuni then turns to his disciple \",\"attrs\":{\"start\":8,\"end\":180}},{\"type\":\"text\",\"text\":\"Ānanda\",\"attrs\":{\"start\":180,\"end\":186},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b35041f2-96b8-4d55-b39a-9d0653dffcd6\",\"uuid\":\"19d09b15-cb70-47cd-a9c9-0cd95776cfe4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and asks if he has any doubts or reservations about what has just been taught. \",\"attrs\":{\"start\":186,\"end\":266}},{\"type\":\"text\",\"text\":\"Ānanda\",\"attrs\":{\"start\":266,\"end\":272},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b35041f2-96b8-4d55-b39a-9d0653dffcd6\",\"uuid\":\"9f5d61f0-cf2a-4fed-8443-a3abe1a6822c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" assures Śākyamuni that he does not doubt what he has heard, but then suggests that other beings might have doubts. The Buddha assures \",\"attrs\":{\"start\":272,\"end\":407}},{\"type\":\"text\",\"text\":\"Ānanda\",\"attrs\":{\"start\":407,\"end\":413},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b35041f2-96b8-4d55-b39a-9d0653dffcd6\",\"uuid\":\"b30d8830-7ca9-4782-bea3-c9e9685c6a6e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and by extension anyone who might read this sūtra, that it is impossible for anyone who has heard the name \",\"attrs\":{\"start\":413,\"end\":522}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha\",\"attrs\":{\"start\":522,\"end\":552},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"496408c1-e2d7-4787-acaf-cf6b194d9722\",\"uuid\":\"782ce6ef-9e5a-40e2-98fb-ff47ffc4b376\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" to be reborn in the lower realms.\",\"attrs\":{\"start\":552,\"end\":586}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"ee1b42d9-c836-4b41-8056-2377afa845f8\",\"sort\":64,\"type\":\"introduction\",\"label\":\"i.5\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1220,\"uuid\":\"ee1b42d9-c836-4b41-8056-2377afa845f8\"},\"content\":[{\"type\":\"text\",\"text\":\"The text continues with a set of instructions from the bodhisattva \",\"attrs\":{\"start\":0,\"end\":67}},{\"type\":\"text\",\"text\":\"Trāṇamukta\",\"attrs\":{\"start\":67,\"end\":77},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e395621c-5852-46eb-a457-65b28596d6db\",\"uuid\":\"55e9ef21-6d81-43e5-a111-a010855625cf\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" about how making offerings to \",\"attrs\":{\"start\":77,\"end\":108}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha\",\"attrs\":{\"start\":108,\"end\":138},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"496408c1-e2d7-4787-acaf-cf6b194d9722\",\"uuid\":\"037566a2-bd13-4e56-86dd-776030e5f02c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" can reverse the process of dying and call a dying or dead person’s consciousness back to the body. \",\"attrs\":{\"start\":138,\"end\":238}},{\"type\":\"text\",\"text\":\"Trāṇamukta\",\"attrs\":{\"start\":238,\"end\":248},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e395621c-5852-46eb-a457-65b28596d6db\",\"uuid\":\"30e31876-5745-4269-bc28-568b08868039\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" outlines a ritual that is performed over a forty-nine-day period and that begins with observing the eightfold purification vows, providing support for the offering rite to the monastic saṅgha, and contemplating \",\"attrs\":{\"start\":248,\"end\":460}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru\",\"attrs\":{\"start\":460,\"end\":474},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"86c2c568-8ea3-4b91-881b-8d2fe6023691\",\"uuid\":\"5e2e69a3-a0a0-4239-ad6d-b6ca97f6e677\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s name three times each day and three times each night. Then saṅgha members recite the text forty-nine times and offer oil lamps to seven \",\"attrs\":{\"start\":474,\"end\":613}},{\"type\":\"text\",\"text\":\"statues\",\"attrs\":{\"start\":613,\"end\":620},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"beb14c8c-22c9-4cbb-b14c-392f2edf214b\",\"uuid\":\"e2801aff-4469-4ce5-844b-f476dea8e7d0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of \",\"attrs\":{\"start\":620,\"end\":624}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru\",\"attrs\":{\"start\":624,\"end\":638},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"86c2c568-8ea3-4b91-881b-8d2fe6023691\",\"uuid\":\"e067e1e0-76e4-4639-ade5-665da2c11d19\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" for a forty-nine-day period. \",\"attrs\":{\"start\":638,\"end\":668}},{\"type\":\"text\",\"text\":\"Trāṇamukta\",\"attrs\":{\"start\":668,\"end\":678},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e395621c-5852-46eb-a457-65b28596d6db\",\"uuid\":\"424e7be1-b8b7-4e68-863f-f41dbd9b6f8d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" states that kings can also perform this rite to avoid disaster and ensure the happiness of the kingdom. He concludes his instructions with a brief enumeration of nine types of \",\"attrs\":{\"start\":678,\"end\":855}},{\"type\":\"text\",\"text\":\"untimely death\",\"attrs\":{\"start\":855,\"end\":869},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ab2e041a-4033-4bfa-8d05-9b343f2ac529\",\"uuid\":\"6ee5c81d-53a4-4f38-817a-0f4309fca027\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", telling \",\"attrs\":{\"start\":869,\"end\":879}},{\"type\":\"text\",\"text\":\"Ānanda\",\"attrs\":{\"start\":879,\"end\":885},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b35041f2-96b8-4d55-b39a-9d0653dffcd6\",\"uuid\":\"222afa2a-9e63-45cf-95cd-2bccea2acb01\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" that the problem of \",\"attrs\":{\"start\":885,\"end\":906}},{\"type\":\"text\",\"text\":\"untimely death\",\"attrs\":{\"start\":906,\"end\":920},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ab2e041a-4033-4bfa-8d05-9b343f2ac529\",\"uuid\":\"d9b34cce-54cd-45f7-827e-983f5e71d6d6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is the reason why Śākyamuni has taught the use of mantras and medicines. The sūtra concludes with \",\"attrs\":{\"start\":920,\"end\":1019}},{\"type\":\"text\",\"text\":\"Mañjuśrīkumārabhūta\",\"attrs\":{\"start\":1019,\"end\":1038},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"445d93f2-7d72-4338-8d0d-41391ddd697a\",\"uuid\":\"970680db-cf7f-4340-9d85-c637c65ae3a3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the bodhisattvas, the Lord of Secrets \",\"attrs\":{\"start\":1038,\"end\":1078}},{\"type\":\"text\",\"text\":\"Vajrapāṇi\",\"attrs\":{\"start\":1078,\"end\":1087},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d9a23ad2-63f7-4616-88b3-31158ce56f97\",\"uuid\":\"5d0790fd-b067-4f63-bd9a-627c54814a55\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and indeed the entire world including its \",\"attrs\":{\"start\":1087,\"end\":1131}},{\"type\":\"text\",\"text\":\"gods\",\"attrs\":{\"start\":1131,\"end\":1135},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"743aac3d-15fc-4192-be69-b05c5584d4ea\",\"uuid\":\"9b2dc2d2-9562-41b6-898b-ba02eebadf29\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", humans, \",\"attrs\":{\"start\":1135,\"end\":1145}},{\"type\":\"text\",\"text\":\"asuras\",\"attrs\":{\"start\":1145,\"end\":1151},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"447fc7a7-051b-4fc0-b42f-c565f67f73d1\",\"uuid\":\"6788009e-7b5d-427f-b026-4cc47bead059\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and \",\"attrs\":{\"start\":1151,\"end\":1157}},{\"type\":\"text\",\"text\":\"gandharvas\",\"attrs\":{\"start\":1157,\"end\":1167},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5498fc5d-cc02-4013-a3af-2e93940bc8f6\",\"uuid\":\"4b968e17-4cff-4d55-a84f-d850b86b49aa\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" rejoicing and praising what the \",\"attrs\":{\"start\":1167,\"end\":1200}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":1200,\"end\":1211},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"598cdbaa-0ed1-4a09-8b0d-9f347b10fe66\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" had said\",\"attrs\":{\"start\":1211,\"end\":1220}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"d32721b2-eb27-4f32-b023-fae16259e4e1\",\"sort\":98,\"type\":\"introduction\",\"label\":\"i.6\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":732,\"uuid\":\"d32721b2-eb27-4f32-b023-fae16259e4e1\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"c95c0e0f-c036-4d52-bc8b-1bfa7091e770\"},\"content\":[{\"type\":\"text\",\"text\":\"This sūtra survives in Sanskrit, Chinese, and Tibetan. In Sanskrit, there are three available editions, compiled and edited from the cache of Buddhist Sanskrit manuscripts excavated from a stūpa in Gilgit in the early twentieth century. Gregory Schopen notes that at least five manuscripts of this text were found among the Gilgit collection,\",\"attrs\":{\"start\":0,\"end\":342},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"8d2fcc1c-7299-4849-873a-6072a418d633\",\"label\":\"1\",\"uuid\":\"7c45c305-ced1-45a7-84fe-950ef0440c05\",\"start\":342,\"end\":342,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" and his analysis of them shows that there were at least two distinct recensions of the text circulating in Gilgit during the fifth and sixth centuries \",\"attrs\":{\"start\":342,\"end\":494}},{\"type\":\"text\",\"text\":\"ᴄᴇ\",\"attrs\":{\"start\":494,\"end\":496},\"marks\":[{\"type\":\"smallCaps\",\"attrs\":{\"start\":494,\"end\":496,\"uuid\":\"9f1e9f61-071e-43ac-83b1-cff3ac32f060\",\"type\":\"span\",\"textStyle\":\"small-caps\"}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":496,\"end\":497},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"c3f13690-ab6b-4aa2-bde7-2cd06e7a9446\",\"label\":\"2\",\"uuid\":\"9c8b46df-8656-40c5-931a-5b0178e0bc97\",\"start\":497,\"end\":497,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" Some substantial passages in Sanskrit have also survived as several citations in \",\"attrs\":{\"start\":497,\"end\":579}},{\"type\":\"text\",\"text\":\"Śāntideva\",\"attrs\":{\"start\":579,\"end\":588},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"3b187882-e6cb-4302-af05-5ee65dbe3225\",\"uuid\":\"cafb8503-ceac-4996-bcd3-d7f3f398956a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s (685–783 \",\"attrs\":{\"start\":588,\"end\":600}},{\"type\":\"text\",\"text\":\"ᴄᴇ\",\"attrs\":{\"start\":600,\"end\":602},\"marks\":[{\"type\":\"smallCaps\",\"attrs\":{\"start\":600,\"end\":602,\"uuid\":\"4df6a765-2c81-42ef-9c8a-6930e9277468\",\"type\":\"span\",\"textStyle\":\"small-caps\"}}]},{\"type\":\"text\",\"text\":\") \",\"attrs\":{\"start\":602,\"end\":604}},{\"type\":\"text\",\"text\":\"Śikṣāsamuccaya,\",\"attrs\":{\"start\":604,\"end\":619},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"9152f128-36c0-46e7-a41f-8b6b82e5d765\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}},{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"aedf591b-688f-4673-8b78-95d8c5ff2fe0\",\"label\":\"3\",\"uuid\":\"78f24a2b-845b-4e62-ba00-b59919553226\",\"start\":619,\"end\":619,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" indicating that the text continued to be well known in the Buddhist heartland of India in the eighth century \",\"attrs\":{\"start\":619,\"end\":729}},{\"type\":\"text\",\"text\":\"ᴄᴇ\",\"attrs\":{\"start\":729,\"end\":731},\"marks\":[{\"type\":\"smallCaps\",\"attrs\":{\"start\":729,\"end\":731,\"uuid\":\"ec147bcc-db80-4cd4-ae3e-9eeebdc7ec8a\",\"type\":\"span\",\"textStyle\":\"small-caps\"}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":731,\"end\":732}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"9d46234f-6007-492c-b8a4-e34dd7568bd1\",\"sort\":116,\"type\":\"introduction\",\"label\":\"i.7\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":438,\"uuid\":\"9d46234f-6007-492c-b8a4-e34dd7568bd1\"},\"content\":[{\"type\":\"text\",\"text\":\"Considerably earlier even than the Sanskrit manuscripts of Gilgit, however, a Chinese translation very similar to the later versions of the text was included as the twelfth and final fascicle of a longer work (Taishō 1331) translated by \",\"attrs\":{\"start\":0,\"end\":237}},{\"type\":\"text\",\"text\":\"Śrīmitra\",\"attrs\":{\"start\":237,\"end\":245},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"09958f58-ba6d-4995-a901-ce2cb255aa36\",\"uuid\":\"7c438e4d-9a05-4ab8-b58a-38dc7da819f7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in the early fourth century \",\"attrs\":{\"start\":245,\"end\":274}},{\"type\":\"text\",\"text\":\"ᴄᴇ\",\"attrs\":{\"start\":274,\"end\":276},\"marks\":[{\"type\":\"smallCaps\",\"attrs\":{\"start\":274,\"end\":276,\"uuid\":\"b5ba08c7-861a-4eb8-a318-d4a6ce962fca\",\"type\":\"span\",\"textStyle\":\"small-caps\"}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":276,\"end\":277},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"26a444a7-34fb-450d-b533-7cdaf8649719\",\"label\":\"4\",\"uuid\":\"4e72ad00-afa8-4504-9a23-3c97aeee9532\",\"start\":277,\"end\":277,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" In the seventh century, two new standalone Chinese translations were made, one in 616 \",\"attrs\":{\"start\":277,\"end\":364}},{\"type\":\"text\",\"text\":\"ᴄᴇ\",\"attrs\":{\"start\":364,\"end\":366},\"marks\":[{\"type\":\"smallCaps\",\"attrs\":{\"start\":364,\"end\":366,\"uuid\":\"3772c8fd-3c41-4172-a9a9-82129eb7331a\",\"type\":\"span\",\"textStyle\":\"small-caps\"}}]},{\"type\":\"text\",\"text\":\" by Dharmagupta (Taishō 449) and one in 650 \",\"attrs\":{\"start\":366,\"end\":410}},{\"type\":\"text\",\"text\":\"ᴄᴇ\",\"attrs\":{\"start\":410,\"end\":412},\"marks\":[{\"type\":\"smallCaps\",\"attrs\":{\"start\":410,\"end\":412,\"uuid\":\"239af5aa-6bd9-45f2-ab61-14feefa3a46f\",\"type\":\"span\",\"textStyle\":\"small-caps\"}}]},{\"type\":\"text\",\"text\":\" by Xuanzang (Taishō 450).\",\"attrs\":{\"start\":412,\"end\":438},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"d5075fb7-80e1-4a33-bd0e-a204fe72eb28\",\"label\":\"5\",\"uuid\":\"8fd7fc01-c41d-42b6-a665-9b01f8c2fc97\",\"start\":438,\"end\":438,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"18ad46b6-2ed3-4f76-bc94-cc14f99d50f2\",\"sort\":129,\"type\":\"introduction\",\"label\":\"i.8\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1808,\"uuid\":\"18ad46b6-2ed3-4f76-bc94-cc14f99d50f2\"},\"content\":[{\"type\":\"text\",\"text\":\"The Tibetan translation has a colophon telling us that it was made by two ninth-century Indian preceptors‍—\",\"attrs\":{\"start\":0,\"end\":107}},{\"type\":\"text\",\"text\":\"Jinamitra\",\"attrs\":{\"start\":107,\"end\":116},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"42c66fa6-6c95-4dd8-916d-b35febda3db4\",\"uuid\":\"8d27453c-1726-425d-b170-6b3bad483430\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and \",\"attrs\":{\"start\":116,\"end\":121}},{\"type\":\"text\",\"text\":\"Dānaśīla\",\"attrs\":{\"start\":121,\"end\":129},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4b9d0013-a2c6-4bd3-aa1e-602a5297627d\",\"uuid\":\"78ad3586-90c7-4659-87a6-804a59b1b385\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"‍—in conjunction with \",\"attrs\":{\"start\":129,\"end\":151}},{\"type\":\"text\",\"text\":\"Bandé Yeshé Dé\",\"attrs\":{\"start\":151,\"end\":165},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"715734e9-5f03-4a3e-8bce-d76f45d1b1f2\",\"uuid\":\"3e3c0715-ae8b-40ba-9868-d654f137b0a9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (mid-eighth to early ninth century),\",\"attrs\":{\"start\":165,\"end\":202},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"a84cc84a-8eb2-42bd-ab57-7c8db17aab93\",\"label\":\"6\",\"uuid\":\"ce095574-7ab4-4771-9bec-22f5e3e7cbbf\",\"start\":202,\"end\":202,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" placing the date for its initial translation from Sanskrit into Tibetan in the early ninth century. This date is confirmed by the text’s appearance in both the Denkarma\",\"attrs\":{\"start\":202,\"end\":371},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"bf105cac-1915-4a72-9fd8-cf0e2b77482f\",\"label\":\"7\",\"uuid\":\"411df23e-fb93-4ec9-89ed-ef2e98409b55\",\"start\":371,\"end\":371,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" and Phangthangma\",\"attrs\":{\"start\":371,\"end\":388},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"9ed1e74c-9752-4d91-90d2-1cd8e24b057f\",\"label\":\"8\",\"uuid\":\"9dbd5af1-796b-4524-99b7-5a8839832813\",\"start\":388,\"end\":388,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" royal Tibetan catalogs of translated works. Although both royal Tibetan catalogs indicate that this text was originally classified as a sūtra, Butön listed it in different works as both a sūtra and a tantra,\",\"attrs\":{\"start\":388,\"end\":596},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"7b0371ab-a2dc-431b-9660-e8e752f67a09\",\"label\":\"9\",\"uuid\":\"36c293db-d689-4c4f-9175-4106275b16bd\",\"start\":596,\"end\":596,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" and in all Kangyurs it is placed with the tantras of the Action (\",\"attrs\":{\"start\":596,\"end\":662}},{\"type\":\"text\",\"text\":\"kriyā\",\"attrs\":{\"start\":662,\"end\":667},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":662,\"end\":667,\"uuid\":\"7cead0f7-1f2f-472a-a930-6d6f669839de\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\") class. In the Degé Kangyur it is presented among the texts of this category related to the principal figure of the tathāgata family (\",\"attrs\":{\"start\":667,\"end\":802}},{\"type\":\"text\",\"text\":\"de bzhin gshegs pa’i rigs kyi gtso bo\",\"attrs\":{\"start\":802,\"end\":839},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":802,\"end\":839,\"uuid\":\"08df1903-f3b2-4ac9-a9e8-ff671e0494be\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\") as one work in a cycle of four that relate to the Buddha \",\"attrs\":{\"start\":839,\"end\":898}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha\",\"attrs\":{\"start\":898,\"end\":928},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"496408c1-e2d7-4787-acaf-cf6b194d9722\",\"uuid\":\"9b3ff87d-3e13-4145-bed5-ee0e4bd7ac65\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". The first of the texts in this cycle, \",\"attrs\":{\"start\":928,\"end\":968}},{\"type\":\"text\",\"text\":\"The Detailed Account of the Previous Aspirations of the Seven Thus-Gone Ones \",\"attrs\":{\"start\":968,\"end\":1045},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"f261804e-f17d-4759-bc42-3a96ed9f7ad0\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"(Toh 503),\",\"attrs\":{\"start\":1045,\"end\":1055},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"4d572cc8-c0c4-4070-bf14-1304471a04b7\",\"label\":\"10\",\"uuid\":\"230435df-83f8-45b0-904f-cde4dbbb724e\",\"start\":1055,\"end\":1055,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" first describes the aspirations of six other tathāgatas, and then reproduces almost verbatim the content of the present text centered on \",\"attrs\":{\"start\":1055,\"end\":1193}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha\",\"attrs\":{\"start\":1193,\"end\":1223},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"496408c1-e2d7-4787-acaf-cf6b194d9722\",\"uuid\":\"7a6c809f-177a-4543-bde3-271f5d7dde70\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", a passage that takes up half the length of the text. The historical relationship of these two texts remains to be investigated, but the existence of fourth and seventh century \",\"attrs\":{\"start\":1223,\"end\":1401}},{\"type\":\"text\",\"text\":\"ᴄᴇ\",\"attrs\":{\"start\":1401,\"end\":1403},\"marks\":[{\"type\":\"smallCaps\",\"attrs\":{\"start\":1401,\"end\":1403,\"uuid\":\"19041994-6332-4913-b46b-964ccb077191\",\"type\":\"span\",\"textStyle\":\"small-caps\"}}]},{\"type\":\"text\",\"text\":\" Chinese translations, as well as of fifth to sixth century Sanskrit manuscripts, of the present work\",\"attrs\":{\"start\":1403,\"end\":1504},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"d69e5090-094f-488a-b290-53c33367d6db\",\"label\":\"11\",\"uuid\":\"d10baf77-b588-46ee-9a57-8aec708c4e5f\",\"start\":1504,\"end\":1504,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\"‍—while the longer text only appeared in China in the eighth century‍—strongly suggests that the present work was the first to exist. It has no obvious tantric characteristics and it is perhaps surprising that it is not at least duplicated in the General Sūtra section, like many other works of its kind.\",\"attrs\":{\"start\":1504,\"end\":1808}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"e187c876-f33b-41c6-a494-50c6ecb8e9fa\",\"sort\":161,\"type\":\"introduction\",\"label\":\"i.9\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1301,\"uuid\":\"e187c876-f33b-41c6-a494-50c6ecb8e9fa\"},\"content\":[{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha\",\"attrs\":{\"start\":0,\"end\":30},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"496408c1-e2d7-4787-acaf-cf6b194d9722\",\"uuid\":\"51837b05-3428-4cf4-92be-67f43a1d1d5f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is a widely known figure of the Buddhist pantheon in all countries where the Mahāyāna is practiced, and he is familiarly known as the Medicine Buddha or the Buddha of Healing, the short form of his name in Tibetan being \",\"attrs\":{\"start\":30,\"end\":251}},{\"type\":\"text\",\"text\":\"Sangyé Menla\",\"attrs\":{\"start\":251,\"end\":263},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1c539450-6a9f-4fab-ad3d-03ec7d50e2f7\",\"uuid\":\"84eecf46-d429-4de8-9121-e6df9e1c6de7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":263,\"end\":265}},{\"type\":\"text\",\"text\":\"sangs rgyas sman bla\",\"attrs\":{\"start\":265,\"end\":285},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":265,\"end\":285,\"uuid\":\"3a4e77d9-361a-4d41-a70a-a7a2139d29b0\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"). As this text demonstrates, his aspirations and activity are by no means confined to the relief of suffering caused by illness, but his popularity stems no doubt from this universally experienced need. A large number of liturgies in the Tibetan Buddhist tradition were written for the purpose of invoking, visualizing, and praying to him, and in these texts as well as in many paintings and murals he is depicted as a blue-colored buddha, holding in his alms bowl a sprig of myrobalan to represent medicinal plants. He is often visualized or depicted surrounded by the other six tathāgatas with which he is associated, accompanied by the two bodhisattvas mentioned in \",\"attrs\":{\"start\":285,\"end\":955}},{\"type\":\"text\",\"text\":\"1.22,\",\"attrs\":{\"start\":955,\"end\":960},\"marks\":[{\"type\":\"internalLink\",\"attrs\":{\"uuid\":\"7978ea29-dfbb-4f7e-b591-4108d9831a35\",\"href\":\"/entity/passage/c8927dce-85d1-4b8e-aca7-ad2c039afee3\",\"entity\":\"c8927dce-85d1-4b8e-aca7-ad2c039afee3\",\"type\":\"passage\",\"toh\":null,\"isSameWork\":true,\"subtype\":\"translation\"}}]},{\"type\":\"text\",\"text\":\" and sometimes by the twelve \",\"attrs\":{\"start\":960,\"end\":989}},{\"type\":\"text\",\"text\":\"great yakṣa generals\",\"attrs\":{\"start\":989,\"end\":1009},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d09252d2-d990-4e23-8cfe-5e673de4aa9f\",\"uuid\":\"2ee93f3c-7b8c-448d-8e1b-aecd3950bfb5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" mentioned in \",\"attrs\":{\"start\":1009,\"end\":1023}},{\"type\":\"text\",\"text\":\"1.53.\",\"attrs\":{\"start\":1023,\"end\":1028},\"marks\":[{\"type\":\"internalLink\",\"attrs\":{\"uuid\":\"8f8ee6d0-dfbc-4d78-8e6c-5a6ec2996558\",\"href\":\"/entity/passage/a93cf62f-2513-4adf-9c3b-ac637cc973c5\",\"entity\":\"a93cf62f-2513-4adf-9c3b-ac637cc973c5\",\"type\":\"passage\",\"toh\":null,\"isSameWork\":true,\"subtype\":\"translation\"}}]},{\"type\":\"text\",\"text\":\" Practices dedicated to him often involve the recitation of the dhāraṇī included in the third text of the cycle, \",\"attrs\":{\"start\":1028,\"end\":1141}},{\"type\":\"text\",\"text\":\"The Dhāraṇī of the Tathāgata Vaiḍūryaprabha \",\"attrs\":{\"start\":1141,\"end\":1185},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"1c19efc3-5c3b-46d6-a742-ed5e3c420125\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"(Toh 505),\",\"attrs\":{\"start\":1185,\"end\":1195},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"099c87e9-9a7c-4388-9a82-552efdfbf7a3\",\"label\":\"12\",\"uuid\":\"0cd177e5-ae8b-4808-8f55-757d24787296\",\"start\":1195,\"end\":1195,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" and of the homage and short mantra that compose the fourth, untitled text that we have numbered Toh 505a.\",\"attrs\":{\"start\":1195,\"end\":1301},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"9f928597-f0c9-44ef-9eb7-ef43ab6f9fc8\",\"label\":\"13\",\"uuid\":\"53c3833f-f354-4567-b8d4-c0c8a41ed79d\",\"start\":1301,\"end\":1301,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"d9f5a8db-0b67-4cd6-890a-aa99e8165d3e\",\"sort\":181,\"type\":\"introduction\",\"label\":\"i.10\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":329,\"uuid\":\"d9f5a8db-0b67-4cd6-890a-aa99e8165d3e\"},\"content\":[{\"type\":\"text\",\"text\":\"This translation is based on the Tibetan translation from the Tantra Section in the Degé Kangyur, in consultation with the Tibetan translations in the Stok Palace Kangyur and the Comparative Kangyur (Tib. \",\"attrs\":{\"start\":0,\"end\":205}},{\"type\":\"text\",\"text\":\"dpe bsdur ma\",\"attrs\":{\"start\":205,\"end\":217},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":205,\"end\":217,\"uuid\":\"9c0a59c8-6db9-4bc4-89b6-96107382d4c6\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"). It was checked against the Sanskrit editions of the Gilgit manuscripts prepared by Dutt, Vaidya, and Schopen.\",\"attrs\":{\"start\":217,\"end\":329}}]}]}],\"body\":[{\"type\":\"passage\",\"attrs\":{\"uuid\":\"d1556aa4-ab4d-484d-8d15-e4d85f3d9057\",\"sort\":188,\"type\":\"translationHeader\",\"label\":\"1.\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":2,\"start\":0,\"end\":15,\"uuid\":\"326aa977-6123-4329-8683-eff98e8a2a50\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"The Translation\",\"attrs\":{\"start\":0,\"end\":15}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"c4c62b21-4ab5-4e0b-a8b6-1af8cdfa9575\",\"sort\":189,\"type\":\"translation\",\"label\":\"tr.\",\"alignments\":{\"toh504\":{\"folioUuid\":\"c7a18703-6890-4a39-b8eb-eec64506f243\",\"toh\":\"toh504\",\"tibetan\":\"༄༅། །རྒྱ་གར་སྐད་དུ། ཨཱརྱ་བྷ་ག་བཱན་བྷཻ་ཥ་ཛྱེ་གུ་རུ་བཻ་ཌཱུརྱ་པྲ་བྷསྱ་པཱུརྦྦ་པྲ་ཎི་དྷཱ་ན་བི་ཤེ་ཥ་བི་སྟཱ་ར་ནཱ་མ་མ་ཧཱ་ཡཱ་ན་སཱུ་ཏྲ། བོད་སྐད་དུ། འཕགས་པ་བཅོམ་ལྡན་འདས་སྨན་གྱི་བླ་བཻ་ཌཱུརྱའི་འོད་ཀྱི་སྔོན་གྱི་སྨོན་ལམ་གྱི་ཁྱད་པར་རྒྱས་པ་ཞེས་བྱ་བ་ཐེག་པ་ཆེན་པོའི་མདོ། \\n\",\"folioNumber\":274,\"volumeNumber\":87}}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"start\":0,\"end\":30,\"uuid\":\"09bc949c-f163-4b7a-b89e-a7793a7babe4\",\"level\":2,\"class\":\"body-title-honorific\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"c2bd8f1a-1e2e-4538-8039-e9d99d444797\"},\"content\":[{\"type\":\"text\",\"text\":\"The Noble Great Vehicle Sūtra \",\"attrs\":{\"start\":0,\"end\":30}}]},{\"type\":\"heading\",\"attrs\":{\"start\":30,\"end\":124,\"uuid\":\"c744692d-16a7-4f29-b03b-9ec245da32c4\",\"level\":2,\"class\":\"body-title-main\"},\"content\":[{\"type\":\"text\",\"text\":\"The Detailed Account of the Previous Aspirations of the Blessed Bhaiṣajya­guru­vaiḍūrya­prabha\",\"attrs\":{\"start\":30,\"end\":124}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"9cba1cf7-4958-4705-b20e-bb5655a79176\",\"sort\":191,\"type\":\"translation\",\"label\":\"1.1\",\"alignments\":{\"toh504\":{\"folioUuid\":\"c7a18703-6890-4a39-b8eb-eec64506f243\",\"toh\":\"toh504\",\"tibetan\":\"སངས་རྒྱས་དང་བྱང་ཆུབ་སེམས་དཔའ་ཐམས་ཅད་ལ་ཕྱག་འཚལ་ལོ། །\",\"folioNumber\":274,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":39,\"uuid\":\"9cba1cf7-4958-4705-b20e-bb5655a79176\"},\"content\":[{\"type\":\"text\",\"text\":\"Homage to all buddhas and bodhisattvas.\",\"attrs\":{\"start\":0,\"end\":39}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"b4168cba-4b75-48cd-bf42-97c3c0dc677d\",\"sort\":193,\"type\":\"translation\",\"label\":\"1.2\",\"alignments\":{\"toh504\":{\"folioUuid\":\"c7a18703-6890-4a39-b8eb-eec64506f243\",\"toh\":\"toh504\",\"tibetan\":\"འདི་སྐད་བདག་གིས་ཐོས་པ་དུས་གཅིག་ན། བཅོམ་ལྡན་འདས་ཡུལ་རྒྱུ་བ་རྒྱུ་ཞིང་ཡངས་པ་ཅན་དུ་བྱོན་ཏེ། ཡངས་པ་ཅན་ན་རོལ་མོའི་སྒྲ་ཅན་གྱི་ཤིང་ལྗོན་པའི་དྲུང་ན་དགེ་སློང་བརྒྱད་སྟོང་གི་དགེ་\\nསློང་གི་དགེ་འདུན་ཆེན་པོ་དང་། ཐབས་ཅིག་ཏུ་བཞུགས་ཏེ། བྱང་ཆུབ་སེམས་དཔའ་སུམ་ཁྲི་དྲུག་སྟོང་དང་ཡང་ཐབས་ཅིག་ཏུ་རྒྱལ་པོ་དང་། བློན་པོ་དང་། བྲམ་ཟེ་དང་། ཁྱིམ་བདག་རྣམས་དང་། ལྷ་དང་། ལྷ་མ་ཡིན་དང་། ནམ་མཁའ་ལྡིང་དང་། མིའམ་\\nཅི་དང་། ལྟོ་འཕྱེ་ཆེན་པོ་རྣམས་ཀྱིས་ཡོངས་སུ་བསྐོར་ཅིང་མདུན་གྱིས་བལྟས་ཏེ་ཆོས་སྟོན་ཏོ། །\",\"folioNumber\":274,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":444,\"uuid\":\"b4168cba-4b75-48cd-bf42-97c3c0dc677d\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"6d8db6c7-1a9f-494c-abd2-70ec68efddba\"},\"content\":[{\"type\":\"text\",\"text\":\"Thus did I hear at one time. The \",\"attrs\":{\"start\":0,\"end\":33}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":33,\"end\":44},\"marks