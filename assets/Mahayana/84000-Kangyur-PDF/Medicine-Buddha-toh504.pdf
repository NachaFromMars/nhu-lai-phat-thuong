\"text\",\"text\":\" \",\"attrs\":{\"start\":701,\"end\":702}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha­rāja\",\"attrs\":{\"start\":702,\"end\":737},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"42700cf7-b80f-42be-89b1-6b4b26f2b60a\",\"uuid\":\"698b59ce-83d1-4a7e-83ec-aa8704d93edf\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", makes offerings to him, and serves him. They will be under our protection, they will be under our care, they will be free from all manner of misfortunes, and we will fulfill their every wish.”\",\"attrs\":{\"start\":737,\"end\":931}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"2bd895fc-eaeb-455f-affe-4ae6cf32cfa5\",\"sort\":1129,\"type\":\"translation\",\"label\":\"1.55\",\"alignments\":{\"toh504\":{\"folioUuid\":\"c91275a3-05ef-4801-9606-8e20fbfba093\",\"toh\":\"toh504\",\"tibetan\":\"དེ་ནས་བཅོམ་ལྡན་འདས་ཀྱིས་གནོད་སྦྱིན་\\nགྱི་སྡེ་དཔོན་ཆེན་པོ་དེ་དག་ལ། ལེགས་སོ་ཞེས་བྱ་བ་བྱིན་ཏེ། གནོད་སྦྱིན་གྱི་སྡེ་དཔོན་ཆེན་པོ་དག་གང་གི་ཕྱིར་ཁྱེད། བཅོམ་ལྡན་འདས་དེ་བཞིན་གཤེགས་པ་སྨན་གྱི་བླ་བཻ་ཌཱུརྱའི་འོད་དེ་ལ་བྱས་པ་གཟོ་ཞིང་རྗེས་སུ་དྲན་ལ། སེམས་ཅན་ཐམས་ཅད་ལ་ཕན་[F.283.b]པའི་ཕྱིར་ཞུགས་པ་ལེགས་སོ་ལེགས་སོ། །\",\"folioNumber\":283,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":308,\"uuid\":\"2bd895fc-eaeb-455f-affe-4ae6cf32cfa5\"},\"content\":[{\"type\":\"text\",\"text\":\"“Very good, very good,” the \",\"attrs\":{\"start\":0,\"end\":28}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":28,\"end\":39},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"1ef33c78-83ff-4ee8-bfd3-56e99877160c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" said in response to the \",\"attrs\":{\"start\":39,\"end\":64}},{\"type\":\"text\",\"text\":\"great yakṣa generals\",\"attrs\":{\"start\":64,\"end\":84},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d09252d2-d990-4e23-8cfe-5e673de4aa9f\",\"uuid\":\"924348d4-5bf9-420b-8b88-7621981fe99c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". “It is excellent that you \",\"attrs\":{\"start\":84,\"end\":112}},{\"type\":\"text\",\"text\":\"great yakṣa generals\",\"attrs\":{\"start\":112,\"end\":132},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d09252d2-d990-4e23-8cfe-5e673de4aa9f\",\"uuid\":\"64b432ed-5502-4854-9d66-99c68dc8175b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" are so grateful toward the \",\"attrs\":{\"start\":132,\"end\":160}},{\"type\":\"text\",\"text\":\"blessed\",\"attrs\":{\"start\":160,\"end\":167},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"254f77f3-73a3-4e74-8aa3-41c1f76e346f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":167,\"end\":168}},{\"type\":\"text\",\"text\":\"Thus-Gone\",\"attrs\":{\"start\":168,\"end\":177},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"78ed6576-10c2-4f66-958e-9aa5116d7143\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":177,\"end\":178}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha­rāja\",\"attrs\":{\"start\":178,\"end\":213},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"42700cf7-b80f-42be-89b1-6b4b26f2b60a\",\"uuid\":\"739cf3ce-0a67-47fd-9c50-dc3c50347326\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and that you are so committed to recollecting him and working for the benefit of all beings.”\",\"attrs\":{\"start\":213,\"end\":308},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"dc0a6493-d00c-42c7-924c-ea8efc3c63e7\",\"label\":\"30\",\"uuid\":\"fca61e9c-db90-4319-8103-2a647f95509e\",\"start\":308,\"end\":308,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"3fff746e-ad30-47b3-91ec-bf99ecbd94ee\",\"sort\":1146,\"type\":\"translation\",\"label\":\"1.56\",\"alignments\":{\"toh504\":{\"folioUuid\":\"a87c72a8-d32e-4c8a-b076-280cbdded95e\",\"toh\":\"toh504\",\"tibetan\":\"དེ་ནས་ཚེ་དང་ལྡན་པ་ཀུན་དགའ་བོ་སྟན་ལས་ལངས་ཏེ། བླ་གོས་ཕྲག་པ་གཅིག་ཏུ་གཟར་ནས། པུས་མོ་གཡས་པའི་ལྷ་ངས་ལ་བཙུགས་ཏེ། བཅོམ་ལྡན་འདས་ག་ལ་བ་དེ་ལོགས་སུ་ཐལ་མོ་སྦྱར་བ་\\nབཏུད་ནས། བཅོམ་ལྡན་འདས་ལ་འདི་སྐད་ཅེས་གསོལ་ཏོ། །བཅོམ་ལྡན་འདས་ཆོས་ཀྱི་རྣམ་གྲངས་འདིའི་མིང་ཅི་ལགས། འདི་ཇི་ལྟར་གཟུང་བར་བགྱི། \",\"folioNumber\":283,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":271,\"uuid\":\"3fff746e-ad30-47b3-91ec-bf99ecbd94ee\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"c17b5ad2-463e-4af8-8f90-46b2e45341ad\"},\"content\":[{\"type\":\"text\",\"text\":\"Then Venerable \",\"attrs\":{\"start\":0,\"end\":15}},{\"type\":\"text\",\"text\":\"Ānanda\",\"attrs\":{\"start\":15,\"end\":21},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b35041f2-96b8-4d55-b39a-9d0653dffcd6\",\"uuid\":\"7b61b9bd-7822-4f52-a7e6-40e3aff72d97\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" rose from his seat, adjusted his upper robe on one shoulder, knelt with his right knee on the ground, bowed to the \",\"attrs\":{\"start\":21,\"end\":137}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":137,\"end\":148},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"ab49395b-fdc3-4c4b-b5b9-96dab9b0e4bd\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" with his palms together, and asked, “\",\"attrs\":{\"start\":148,\"end\":186}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":186,\"end\":197},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"d245125f-7419-412c-b2ed-7ceba2b62eea\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", what is the name of this Dharma discourse? How should it be remembered?”\",\"attrs\":{\"start\":197,\"end\":271}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"8540b461-2c6f-43a9-84c3-e956d966ae7a\",\"sort\":1154,\"type\":\"translation\",\"label\":\"1.57\",\"alignments\":{\"toh504\":{\"folioUuid\":\"a87c72a8-d32e-4c8a-b076-280cbdded95e\",\"toh\":\"toh504\",\"tibetan\":\"བཅོམ་ལྡན་འདས་ཀྱིས་བཀའ་སྩལ་པ། ཀུན་དགའ་བོ་དེའི་ཕྱིར། ཆོས་ཀྱི་རྣམ་\\nགྲངས་འདི་དེ་བཞིན་གཤེགས་པ་སྨན་གྱི་བླ་བཻ་ཌཱུརྱའི་འོད་ཀྱི་སྔོན་གྱི་སྨོན་ལམ་གྱི་ཁྱད་པར་རྒྱས་པ་ཞེས་བྱ་བར་ཡང་ཟུང་ཤིག །བྱང་ཆུབ་སེམས་དཔའ་ལག་ན་རྡོ་རྗེས་དམ་བཅས་པ་ཞེས་བྱ་བར་ཡང་ཟུང་ཤིག །ལས་ཀྱི་སྒྲིབ་པ་ཐམས་ཅད་རྣམ་པར་སྦྱོང་ཞིང་། རེ་བ་\\nཐམས་ཅད་ཡོངས་སུ་སྐོང་བ་ཞེས་བྱ་བར་ཡང་ཟུང་ཤིག །གནོད་སྦྱིན་གྱི་སྡེ་དཔོན་ཆེན་པོ་བཅུ་གཉིས་ཀྱིས་དམ་བཅས་པ་ཞེས་བྱ་བར་ཡང་ཟུང་ཤིག །\",\"folioNumber\":283,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":416,\"uuid\":\"8540b461-2c6f-43a9-84c3-e956d966ae7a\"},\"content\":[{\"type\":\"text\",\"text\":\"The \",\"attrs\":{\"start\":0,\"end\":4}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":4,\"end\":15},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"098aa683-a937-469a-b8f7-dc85ff51d44e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" replied, “\",\"attrs\":{\"start\":15,\"end\":26}},{\"type\":\"text\",\"text\":\"Ānanda\",\"attrs\":{\"start\":26,\"end\":32},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b35041f2-96b8-4d55-b39a-9d0653dffcd6\",\"uuid\":\"42cedff9-ddd0-4dff-a198-5cdadd668934\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", this Dharma discourse should be remembered as \",\"attrs\":{\"start\":32,\"end\":80}},{\"type\":\"text\",\"text\":\"The Detailed Account of the Previous Aspirations of the Thus-Gone Bhaiṣajya­guru­vaiḍūrya­prabha.\",\"attrs\":{\"start\":80,\"end\":177},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"f9b5e217-f391-46af-a1ce-cec8d774b5ad\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" It should also be remembered as \",\"attrs\":{\"start\":177,\"end\":210}},{\"type\":\