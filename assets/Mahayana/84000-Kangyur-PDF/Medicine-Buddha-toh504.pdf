\",\"tibetan\":\"གང་ཐོས་པས་སེམས་ཅན་རྣམས་ཀྱི་ལས་ཀྱི་སྒྲིབ་པ་ཡོངས་སུ་བྱང་བར་འགྱུར་བ་དང་། སླད་མའི་ཚེ་སླད་མའི་དུས་སུ་དམ་པའི་ཆོས་ལྟར་\\nབཅོས་པ་འབྱུང་བ་ན། སེམས་ཅན་དེ་དག་རྗེས་སུ་གཟུང་བའི་སླད་དུ་དེ་བཞིན་གཤེགས་པ་དེ་དག་གི་མཚན་དང་། སྔོན་གྱི་སྨོན་ལམ་གྱི་ཁྱད་པར་རྒྱས་པ་བཅོམ་ལྡན་འདས་ཀྱིས་བསྟན་དུ་གསོལ། དེ་ནས་བཅོམ་ལྡན་འདས་ཀྱིས་འཇམ་དཔལ་གཞོན་ནུར་གྱུར་པ་\\nལ་ལེགས་སོ་ཞེས་བྱ་བ་བྱིན་ཏེ། \",\"folioNumber\":274,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":276,\"uuid\":\"d238ae70-f15b-4554-a7c2-c7a2de99d9a3\"},\"content\":[{\"type\":\"text\",\"text\":\"“May the \",\"attrs\":{\"start\":0,\"end\":9}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":9,\"end\":20},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"e8893213-cb43-49d2-926e-0d04b1d1e004\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" please teach a detailed account of the names and previous aspirations of the \",\"attrs\":{\"start\":20,\"end\":98}},{\"type\":\"text\",\"text\":\"thus-gone ones\",\"attrs\":{\"start\":98,\"end\":112},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"6abdc8dc-c890-4ebb-8c99-a880aed82eea\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", so that beings who hear them\",\"attrs\":{\"start\":112,\"end\":142},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"bede20da-070a-4b5e-89b4-2d48d3f9bf31\",\"label\":\"15\",\"uuid\":\"8b7e9ba8-6c4e-4732-81ff-171416c4ef08\",\"start\":142,\"end\":142,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" may be purified of their \",\"attrs\":{\"start\":142,\"end\":168}},{\"type\":\"text\",\"text\":\"karmic obscurations\",\"attrs\":{\"start\":168,\"end\":187},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"57349933-7c73-4afc-be37-dc4942be0146\",\"uuid\":\"875ae27e-aaa9-4d75-b705-c3dfc463c082\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and be guided, later in future times when only an imitation of the holy Dharma remains.”\",\"attrs\":{\"start\":187,\"end\":276}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"7402cc47-7f5d-49eb-a0a5-b27f03bce922\",\"sort\":235,\"type\":\"translation\",\"label\":\"1.5\",\"alignments\":{\"toh504\":{\"folioUuid\":\"c7a18703-6890-4a39-b8eb-eec64506f243\",\"toh\":\"toh504\",\"tibetan\":\"འཇམ་དཔལ་ལེགས་སོ་ལེགས་སོ། །འཇམ་དཔལ་ཁྱོད་ཀྱིས་སྙིང་རྗེ་དཔག་ཏུ་མེད་པ་བསྐྱེད་ནས་སེམས་ཅན་ལས་ཀྱི་སྒྲིབ་པ་སྣ་ཚོགས་ཀྱིས་བསྒྲིབས་པ་རྣམས་དང་། ལྷ་དང་མི་རྣམས་ཀྱི་དོན་དང་། ཕན་པ་དང་བདེ་བའི་[F.274.b]ཕྱིར་གསོལ་བ་འདེབས་པ་ནི་ལེགས་སོ། །འཇམ་དཔལ་དེའི་ཕྱིར་ལེགས་པར་རབ་ཏུ་ཉོན་ལ་ཡིད་ལ་ཟུང་ཤིག་དང་བཤད་དོ། །འཇམ་དཔལ་གཞོན་ནུར་གྱུར་པས་བཅོམ་ལྡན་འདས་དེ་བཞིན་ནོ་ཞེས་གསོལ་ནས། བཅོམ་ལྡན་འདས་ཀྱི་ལྟར་ཉན་པ་དང་། བཅོམ་ལྡན་\\nའདས་ཀྱིས་དེ་ལ་འདི་སྐད་ཅེས་བཀའ་སྩལ་ཏོ། །\",\"folioNumber\":274,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":386,\"uuid\":\"7402cc47-7f5d-49eb-a0a5-b27f03bce922\"},\"content\":[{\"type\":\"text\",\"text\":\"“Very well, \",\"attrs\":{\"start\":0,\"end\":12}},{\"type\":\"text\",\"text\":\"Mañjuśrī\",\"attrs\":{\"start\":12,\"end\":20},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a9d821a9-3cc6-4f11-94b6-c36ad0b6a6cb\",\"uuid\":\"55797504-ca04-40ac-b10a-c6656be23772\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", very well,” the \",\"attrs\":{\"start\":20,\"end\":38}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":38,\"end\":49},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"8eeeccd9-612a-4508-821a-ef730ac07297\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" replied to \",\"attrs\":{\"start\":49,\"end\":61}},{\"type\":\"text\",\"text\":\"Mañjuśrīkumārabhūta\",\"attrs\":{\"start\":61,\"end\":80},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"445d93f2-7d72-4338-8d0d-41391ddd697a\",\"uuid\":\"a3110b50-5628-4ad