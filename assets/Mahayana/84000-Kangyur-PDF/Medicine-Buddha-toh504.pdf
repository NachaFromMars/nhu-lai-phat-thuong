ype\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":528,\"uuid\":\"6e09b36c-257e-41b0-844c-109c5852d40d\"},\"content\":[{\"type\":\"text\",\"text\":\"“For his seventh \",\"attrs\":{\"start\":0,\"end\":17}},{\"type\":\"text\",\"text\":\"great aspiration\",\"attrs\":{\"start\":17,\"end\":33},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2c78f096-4bf1-473f-8fc4-372315f0f7a1\",\"uuid\":\"c6384c38-861a-43f4-be97-763ce208eee6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", he proclaimed, ‘In the future, when I have attained awakening as a perfect buddha who has \",\"attrs\":{\"start\":33,\"end\":125}},{\"type\":\"text\",\"text\":\"manifested\",\"attrs\":{\"start\":125,\"end\":135},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bd416713-18e1-4bcd-aa37-1255f4489642\",\"uuid\":\"ea9e992d-02c4-43e1-89e0-df28fb356909\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" unsurpassed and perfect awakening, may beings whose bodies are afflicted by various types of \",\"attrs\":{\"start\":135,\"end\":229}},{\"type\":\"text\",\"text\":\"illnesses\",\"attrs\":{\"start\":229,\"end\":238},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"564d8ea9-dfb7-42ae-b9b9-c4b03389d607\",\"uuid\":\"5d836e3c-d80d-48f9-a710-54c0619621bf\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", who are vulnerable, who are defenseless, who lack \",\"attrs\":{\"start\":238,\"end\":290}},{\"type\":\"text\",\"text\":\"necessities\",\"attrs\":{\"start\":290,\"end\":301},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"686d6042-1ae0-48bc-8b45-c65e4d770560\",\"uuid\":\"24397872-fd34-4d80-b403-a86edd53af4a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and medicines, who have no one to care for them, who are poor, and who suffer hear my name, and may all their \",\"attrs\":{\"start\":301,\"end\":412}},{\"type\":\"text\",\"text\":\"illnesses\",\"attrs\":{\"start\":412,\"end\":421},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"564d8ea9-dfb7-42ae-b9b9-c4b03389d607\",\"uuid\":\"f9c3fa8b-e1fe-47c6-ae1b-7e14fc9e61b7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" be quelled. May they be healthy and live free from harm for as long as it takes them to attain awakening.’\",\"attrs\":{\"start\":421,\"end\":528}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"67e82db1-f82c-4e93-a1fa-8a1eb411bcd7\",\"sort\":395,\"type\":\"translation\",\"label\":\"1.15\",\"alignments\":{\"toh504\":{\"folioUuid\":\"5cf7f8cd-4ab5-43c7-b435-9b3b880bff3e\",\"toh\":\"toh504\",\"tibetan\":\"དེའི་སྨོན་ལམ་ཆེན་པོ་\\nབརྒྱད་པ་ནི་གང་གི་ཚེ་བདག་མ་འོངས་པའི་དུས་ན། བླ་ན་མེད་པ་ཡང་དག་པར་རྫོགས་པའི་བྱང་ཆུབ་མངོན་པར་རྫོགས་པར་སངས་རྒྱས་པ་དེའི་ཚེ་བདག་བྱང་ཆུབ་ཐོབ་པ་ན། བུད་མེད་གང་ལ་ལ་བུད་མེད་ཀྱི་སྐྱོན་བརྒྱ་དག་གིས་ཀུན་ནས་ཉོན་མོངས་པར་གྱུར་པ། བུད་མེད་ཀྱི་\\nདངོས་པོ་ལ་སྨོད་པ། བུད་མེད་ཀྱི་སྐྱེ་གནས་ལས་ཡོངས་སུ་ཐར་བར་འདོད་པ་དེ་དག་བུད་མེད་ཀྱི་དངོས་པོ་ལས་ལོག་པར་གྱུར་ཅིག །བྱང་ཆུབ་ཀྱི་མཐར་ཐུག་གི་བར་སྐྱེས་པའི་དབང་པོ་བྱུང་བར་གྱུར་ཅིག་ཅེས་བཏབ་བོ། །\",\"folioNumber\":275,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":458,\"uuid\":\"67e82db1-f82c-4e93-a1fa-8a1eb411bcd7\"},\"content\":[{\"type\":\"text\",\"text\":\"“For his eighth \",\"attrs\":{\"start\":0,\"end\":16}},{\"type\":\"text\",\"text\":\"great aspiration\",\"attrs\":{\"start\":16,\"end\":32},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2c78f096-4bf1-473f-8fc4-372315f0f7a1\",\"uuid\":\"070627f7-a625-43e4-ae2f-d705bddffbb1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", he proclaimed, ‘In the future, when I have attained awakening as a perfect buddha who has \",\"attrs\":{\"start\":32,\"end\":124}},{\"type\":\"text\",\"text\":\"manifested\",\"attrs\":{\"start\":124,\"end\":134},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bd416713-18e1-4bcd-aa37-1255f4489642\",\"uuid\":\"36bfee3b-c0a2-47e9-8bea-18e86d8dcd22\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" unsurpassed and perfect awakening, may any women who are afflicted by the hundreds of disadvantages of being a woman, who dislike being of the female gender, and who want to be free from the condition of being a woman, leave behind their female gender and be born as a man for as long as it takes them to attain awakening.’\",\"attrs\":{\"start\":134,\"end\":458}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"1a42d093-83c7-4af7-99ef-bb624bfbe091\",\"sort\":401,\"type\":\"translation\",\"label\":\"1.16\",\"alignments\":{\"toh504\":{\"folioUuid\":\"5cf7f8cd-4ab5-43c7-b435-9b3b880bff3e\",\"toh\":\"toh504\",\"tibetan\":\"དེའི་སྨོན་ལམ་ཆེན་པོ་དགུ་པ་ནི་གང་གི་ཚེ་བདག་[F.276.a]མ་འོངས་པའི་དུས་ན། བླ་ན་མེད་པ་ཡང་དག་པར་རྫོགས་པའི་བྱང་ཆུབ་མངོན་པར་རྫོགས་པར་སངས་རྒྱས་པ་དེའི་ཚེ་བདག་བྱང་ཆུབ་ཐོབ་པ་ན། སེམས་ཅན་ཐམས་ཅད་བདུད་ཀྱི་ཞགས་པ་རྣམས་ལས་ཡོངས་སུ་ཐར་བར་བྱའོ། །ལྟ་བ་ཐ་དད་པ་མི་མཐུན་\\nཔ་ཟིང་ཟིང་བས་མི་མཐུན་པར་གྱུར་པ་དག་ཡང་དག་པའི་ལྟ་བ་ལ་དགོད་པར་བྱའོ། །མཐར་གྱིས་བྱང་ཆུབ་སེམས་དཔའི་སྤྱོད་པ་བསྟན་པར་བྱའོ་ཞེས་བཏབ་བོ། །\",\"folioNumber\":275,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":396,\"uuid\":\"1a42d093-83c7-4af7-99ef-bb624bfbe091\"},\"content\":[{\"type\":\"text\",\"text\":\"“For his ninth \",\"attrs\":{\"start\":0,\"end\":15}},{\"type\":\"text\",\"text\":\"great aspiration\",\"attrs\":{\"start\":15,\"end\":31},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2c78f096-4bf1-473f-8fc4-372315f0f7a1\",\"uuid\":\"865c9c10-2e8c-4085-a227-bd96a7497b37\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", he proclaimed, ‘In the future, when I have attained awakening as a perfect buddha who has \",\"attrs\":{\"start\":31,\"end\":123}},{\"type\":\"text\",\"text\":\"manifested\",\"attrs\":{\"start\":123,\"end\":133},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bd416713-18e1-4bcd-aa37-1255f4489642\",\"uuid\":\"ab3c7608-77a7-4b6c-a8a5-df054e61e633\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" unsurpassed and perfect awakening, may I release all beings from \",\"attrs\":{\"start\":133,\"end\":199}},{\"type\":\"text\",\"text\":\"Māra\",\"attrs\":{\"start\":199,\"end\":203},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"30fce34c-e31e-4279-8a5c-69f1c3ca2f2f\",\"uuid\":\"ebc173ca-7942-49cc-8b1d-36b0e9364993\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s bonds. May I establish in the correct view those who are in opposition due to their divergent, contrasting, and disturbed views. In due order, may I teach them the conduct of a bodhisattva.’\",\"attrs\":{\"start\":203,\"end\":396}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"da7e6cb5-557f-4695-b64b-b628088a011d\",\"sort\":411,\"type\":\"translation\",\"label\":\"1.17\",\"alignments\":{\"toh504\":{\"folioUuid\":\"441c4dde-3b12-4669-bcd5-a7f3e300765b\",\"toh\":\"toh504\",\"tibetan\":\"དེའི་སྨོན་ལམ་ཆེན་པོ་བཅུ་པ་ནི་གང་གི་ཚེ་བདག་མ་འོངས་པའི་དུས་ན། བླ་ན་མེད་པ་ཡང་དག་པར་རྫོགས་\\nཔའི་བྱང་ཆུབ་མངོན་པར་རྫོགས་པར་སངས་རྒྱས་པ་དེའི་ཚེ། བདག་བྱང་ཆུབ་ཐོབ་པ་ན་སེམས་ཅན་གང་སུ་དག་རྒྱལ་པོའི་འཇིགས་པས་སྐྲག་པ་དང་། གང་དག་བཅིང་བ་དང་། བརྡེག་པ་དང་། གོ་རར་གཞུག་པ་དང་། གསད་པར་འོས་པ། སྒྱུ་དུ་མས་ཀུན་ཏུ་གཙེས་\\nཔ། ང་རྒྱལ་དང་བྲལ་བ་ལུས་དང་ངག་དང་སེམས་སྡུག་བསྔལ་གྱིས་ཉེན་པ་དེ་དག་བདག་གི་བསོད་ནམས་ཀྱི་མཐུས་གནོད་པ་ཐམས་ཅད་ལས་ཡོངས་སུ་ཐར་བར་གྱུར་ཅིག་ཅེས་བཏབ་བོ། །\",\"folioNumber\":276,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":441,\"uuid\":\"da7e6cb5-557f-4695-b64b-b628088a011d\"},\"content\":[{\"type\":\"text\",\"text\":\"“For his tenth \",\"attrs\":{\"start\":0,\"end\":15}},{\"type\":\"text\",\"text\":\"great aspiration\",\"attrs\":{\"start\":15,\"end\":31},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2c78f096-4bf1-473f-8fc4-372315f0f7a1\",\"uuid\":\"1f270d82-feae-416b-a88b-52d3128caf76\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", he proclaimed, ‘In the future, when I have attained awakening as a perfect buddha who has \",\"attrs\":{\"start\":31,\"end\":123}},{\"type\":\"text\",\"text\":\"manifested\",\"attrs\":{\"start\":123,\"end\":133},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bd416713-18e1-4bcd-aa37-1255f4489642\",\"uuid\":\"f42f7bf4-010d-4524-a864-f831c5417db7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" unsurpassed and perfect awakening, may the power of my merit free from all manner of harm any beings who are terrified because they fear their king, and who are \",\"attrs\":{\"start\":133,\"end\":295}},{\"type\":\"text\",\"text\":\"bound\",\"attrs\":{\"start\":295,\"end\":300},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1f20fd9f-f11b-41ed-a739-56ca809859d3\",\"uuid\":\"94f009de-b1fc-4f8b-8126-456be65af05d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":300,\"end\":302}},{\"type\":\"text\",\"text\":\"beaten\",\"attrs\":{\"start\":302,\"end\":308},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b38cc372-b545-4778-b427-798edb1137f7\",\"uuid\":\"53a0a0c1-71aa-4a94-b66a-94e2a4508724\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":308,\"end\":310}},{\"type\":\"text\",\"text\":\"tortured\",\"attrs\":{\"start\":310,\"end\":318},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5bd3e979-9d9a-4c4d-bb03-6ccdf1e97b0f\",\"uuid\":\"84a62879-d0fb-4063-b825-220aeaa4e350\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":318,\"end\":320}},{\"type\":\"text\",\"text\":\"sentenced to death\",\"attrs\":{\"start\":320,\"end\":338},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7fe482cf-d978-4cbb-ab88-49d8247867f7\",\"uuid\":\"f86ca20b-e99b-4444-bad7-53e5ce7e6df6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":338,\"end\":340}},{\"type\":\"text\",\"text\":\"persecuted by many acts of treachery\",\"attrs\":{\"start\":340,\"end\":376},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d6f93d29-178b-4a14-ba1a-eb22ecdbb656\",\"uuid\":\"b48a6c28-a19c-410a-aab3-502510c95ce7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":376,\"end\":378}},{\"type\":\"text\",\"text\":\"dishonored\",\"attrs\":{\"start\":378,\"end\":388},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f2ab8b11-0a86-4371-8a2b-e128f5cd5c89\",\"uuid\":\"eeeba870-1fff-448a-b85a-1daf57fbacdb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and pained by bodily, verbal, or mental suffering.’\",\"attrs\":{\"start\":388,\"end\":441}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"84af41ce-a24f-452c-ab1f-174dab6c7fb0\",\"sort\":429,\"type\":\"translation\",\"label\":\"1.18\",\"alignments\":{\"toh504\":{\"folioUuid\":\"441c4dde-3b12-4669-bcd5-a7f3e300765b\",\"toh\":\"toh504\",\"tibetan\":\"དེའི་སྨོན་ལམ་ཆེན་པོ་བཅུ་གཅིག་པ་ནི། གང་གི་ཚེ་བདག་མ་འོངས་པའི་དུས་ན་བླ་ན་མེད་\\nཔ་ཡང་དག་པར་རྫོགས་པའི་བྱང་ཆུབ་མངོན་པར་རྫོགས་པར་སངས་རྒྱས་པ་དེའི་ཚེ། བདག་བྱང་ཆུབ་ཐོབ་པ་ན་སེམས་ཅན་གང་སུ་དག་བཀྲེས་པ་དང་། སྐོམ་པའི་མེ་རབ་ཏུ་འབར་བ། ཁ་ཟས་ཚོལ་བ་ལ་རབ་ཏུ་བརྩོན་པ། སྡིག་པའི་ལས་བྱེད་པ་དེ་དག་བདག་གིས་ཁ་\\nདོག་དང་། དྲི་དང་། རོར་ལྡན་པའི་ཁ་ཟས་ཀྱིས་ལུས་ཚིམ་པར་བྱས་ཏེ། ཕྱིས་ཆོས་ཀྱི་རོས་ཤིན་ཏུ་བདེ་བ་ལ་དགོད་པར་བྱའོ་ཞེས་བཏབ་བོ། །\",\"folioNumber\":276,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":466,\"uuid\":\"84af41ce-a24f-452c-ab1f-174dab6c7fb0\"},\"content\":[{\"type\":\"text\",\"text\":\"“For his eleventh \",\"attrs\":{\"start\":0,\"end\":18}},{\"type\":\"text\",\"text\":\"great aspiration\",\"attrs\":{\"start\":18,\"end\":34},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2c78f096-4bf1-473f-8fc4-372315f0f7a1\",\"uuid\":\"39f44c43-2736-4bc1-8d29-eae79489afdb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", he proclaimed, ‘In the future, when I have attained awakening as a perfect buddha who has \",\"attrs\":{\"start\":34,\"end\":126}},{\"type\":\"text\",\"text\":\"manifested\",\"attrs\":{\"start\":126,\"end\":136},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bd416713-18e1-4bcd-aa37-1255f4489642\",\"uuid\":\"3194a2cb-ab90-4712-9805-ae93da24df8c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" unsurpassed and perfect awakening, may I provide food that is vibrant, aromatic, and savory, in order to satiate the bodies of any beings who are scorched by the fire of hunger and thirst, who expend great effort searching for food, and who commit sinful actions. Then, may I make them even happier with the taste of the Dharma.’\",\"attrs\":{\"start\":136,\"end\":466}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"ad0173d4-86ae-47ef-8e11-a5f5343654f1\",\"sort\":435,\"type\":\"translation\",\"label\":\"1.19\",\"alignments\":{\"toh504\":{\"folioUuid\":\"441c4dde-3b12-4669-bcd5-a7f3e300765b\",\"toh\":\"toh504\",\"tibetan\":\"དེ་བཞིན་གཤེགས་པ་དེའི་སྨོན་ལམ་ཆེན་པོ་བཅུ་གཉིས་པ་ནི་གང་གི་ཚེ་བདག་མ་འོངས་པའི་དུས་ན། བླ་ན་མེད་པ་ཡང་\\nདག་པར་རྫོགས་པའི་བྱང་ཆུབ་མངོན་པར་རྫོགས་པར་སངས་རྒྱས་པ་དེའི་ཚེ། སེམས་ཅན་གང་སུ་དག་སྒྲེན་མོ་བགོ་བ་མེད་པ་དབུལ་བ། སྡུག་བསྔལ་བ། གྲང་བ་དང་། ཚ་བ་དང་། སྦྲང་བུ་དང་། ཤ་སྦྲང་དག་གིས་ཉིན་མཚན་དུ་སྡུག་བསྔལ་གྱི་ཚོར་བ་མྱོང་བ་དག་ལ་[F.276.b]བདག་གིས་གོས་ཡོངས་སུ་སྤྱད་པར་འོས་པ་ཚོན་སྣ་ཚོགས་སུ་ཁ་བསྒྱུར་བ་དག་སྦྱིན་པར་བྱའོ། །ཇི་ལྟར་འདོད་པ་བཞིན་དུ་རིན་པོ་ཆེའི་རྒྱན་སྣ་ཚོགས་དང་། སྤུད་པ་དང་། ཕྲེང་བ་དང་། སྤོས་དང་། བྱུག་པ་དང་། རོལ་མོའི་སྒྲ་དང་། སིལ་སྙན་དང་། ཕེག་རྡོབ་པ་\\nརྣམས་ཀྱིས་སེམས་ཅན་རྣམས་ཀྱི་བསམ་པ་ཐམས་ཅད་ཡོངས་སུ་རྫོགས་པར་གྱུར་ཅིག་ཅེས་བཏབ་བོ། །\",\"folioNumber\":276,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":581,\"uuid\":\"ad0173d4-86ae-47ef-8e11-a5f5343654f1\"},\"content\":[{\"type\":\"text\",\"text\":\"“That \",\"attrs\":{\"start\":0,\"end\":6}},{\"type\":\"text\",\"text\":\"thus-gone one\",\"attrs\":{\"start\":6,\"end\":19},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"53b03c4e-4e55-4700-9662-93d7705cbc37\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s twelfth \",\"attrs\":{\"start\":19,\"end\":30}},{\"type\":\"text\",\"text\":\"great aspiration\",\"attrs\":{\"start\":30,\"end\":46},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2c78f096-4bf1-473f-8fc4-372315f0f7a1\",\"uuid\":\"a46c4397-091a-4e10-a7d8-234804f6bb76\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" was, ‘In the future, when I have attained awakening as a perfect buddha who has \",\"attrs\":{\"start\":46,\"end\":127}},{\"type\":\"text\",\"text\":\"manifested\",\"attrs\":{\"start\":127,\"end\":137},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bd416713-18e1-4bcd-aa37-1255f4489642\",\"uuid\":\"04646ac7-fe34-4086-a6b6-22cad177445c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" unsurpassed and perfect awakening, may I provide with clothes that suit their needs and are dyed in bright colors those sentient beings who are naked, who have no clothes, who are poor, who are suffering, and who are miserable day and night due to cold, heat, flies, and biting insects. May I fulfill all the wishes of beings with whatever types of jewelry, ornaments, garlands, perfumes, ointments, music, instruments, and drums they desire.’\",\"attrs\":{\"start\":137,\"end\":581}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"c19344ea-bba5-4696-ba49-eefab00f0611\",\"sort\":447,\"type\":\"translation\",\"label\":\"1.20\",\"alignments\":{\"toh504\":{\"folioUuid\":\"61ad8162-f9ad-4c9e-aad7-975ac174ed89\",\"toh\":\"toh504\",\"tibetan\":\"འཇམ་དཔལ་བཅོམ་ལྡན་འདས་དེ་བཞིན་གཤེགས་པ་དགྲ་བཅོམ་པ་ཡང་དག་པར་རྫོགས་པའི་སངས་རྒྱས་སྨན་གྱི་བླ་བཻ་ཌཱུརྱའི་འོད་དེ་སྔོན་བྱང་ཆུབ་སེམས་དཔའི་\\nསྤྱད་པ་སྤྱོད་པ་ན་སྨོན་ལམ་ཆེན་པོ་བཅུ་གཉིས་པོ་དེ་དག་བཏབ་པར་གྱུར་ཏོ། །\",\"folioNumber\":276,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":201,\"uuid\":\"c19344ea-bba5-4696-ba49-eefab00f0611\"},\"content\":[{\"type\":\"text\",\"text\":\"“\",\"attrs\":{\"start\":0,\"end\":1}},{\"type\":\"text\",\"text\":\"Mañjuśrī\",\"attrs\":{\"start\":1,\"end\":9},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a9d821a9-3cc6-4f11-94b6-c36ad0b6a6cb\",\"uuid\":\"d0e3f1ce-0ed1-4db0-99fd-eacef5ba60cb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", those are the twelve \",\"attrs\":{\"start\":9,\"end\":32}},{\"type\":\"text\",\"text\":\"great aspirations\",\"attrs\":{\"start\":32,\"end\":49},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2c78f096-4bf1-473f-8fc4-372315f0f7a1\",\"uuid\":\"1a5bbbd2-3f29-4504-a1b6-9ad7bd7a2015\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" that the \",\"attrs\":{\"start\":49,\"end\":59}},{\"type\":\"text\",\"text\":\"blessed\",\"attrs\":{\"start\":59,\"end\":66},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"da833d08-a19b-4907-9b3f-75a1029af647\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":66,\"end\":68}},{\"type\":\"text\",\"text\":\"thus-gone\",\"attrs\":{\"start\":68,\"end\":77},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"2fb95c2b-bf15-406b-87c1-a93ee0a0a558\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", worthy, and perfect Buddha \",\"attrs\":{\"start\":77,\"end\":106}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha\",\"attrs\":{\"start\":106,\"end\":136},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"496408c1-e2d7-4787-acaf-cf6b194d9722\",\"uuid\":\"1147db69-4d4e-4125-a757-d338e9d0798f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" proclaimed long ago, when he was practicing bodhisattva conduct.\",\"attrs\":{\"start\":136,\"end\":201}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"4825063f-70e5-47c2-ae65-7a822adf028c\",\"sort\":459,\"type\":\"translation\",\"label\":\"1.21\",\"alignments\":{\"toh504\":{\"folioUuid\":\"61ad8162-f9ad-4c9e-aad7-975ac174ed89\",\"toh\":\"toh504\",\"tibetan\":\"འཇམ་དཔལ་དེ་བཞིན་གཤེགས་པ་སྨན་གྱི་བླ་བཻ་ཌཱུརྱའི་འོད་དེའི་སྨོན་ལམ་གང་ཡིན་པ་དང་། སངས་རྒྱས་ཀྱི་ཞིང་གི་ཡོན་ཏན་བཀོད་པ་གང་ཡིན་པ་དེ་ནི་བསྐལ་པའམ། བསྐལ་པ་ལས་\\nལྷག་པར་ཡང་ཟད་པར་བྱར་མི་ནུས་སོ། །སངས་རྒྱས་ཀྱི་ཞིང་དེ་ནི་ཤིན་ཏུ་ཡོངས་སུ་དག་པ་སྟེ། རྡོ་དང་། གསེག་མ་དང་། གྱོ་མོ་མེད་པ། འདོད་པའི་སྐྱོན་མེད་པ། ངན་སོང་དང་སྡུག་བསྔལ་གྱི་སྒྲ་མེད་པ། བུད་མེད་ཀྱི་དངོས་པོ་མེད་པ། ས་དང་། རྩིག་པ་དང་། ར་བ་\\nདང་། རྟ་བབས་དང་། སྐར་ཁུང་གི་དྲ་བ་དང་། བ་གམ་ནི་བཻ་ཌཱུརྱའི་རང་བཞིན་ཅན། པུ་ཤུ་ནི་རིན་པོ་ཆེ་སྣ་བདུན་གྱི་རང་བཞིན་ཅན་ཏེ། འཇིག་རྟེན་གྱི་ཁམས་བདེ་བ་ཅན་ཅི་འདྲ་བ་དེ་བཞིན་དུ། འཇིག་རྟེན་གྱི་ཁམས་བཻ་ཌཱུརྱ་ར་སྣང་བའི་སངས་རྒྱས་ཀྱི་ཞིང་གི་ཡོན་ཏན་བཀོད་\\nཔ་ཡང་དེ་དང་འདྲའོ། །\",\"folioNumber\":276,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":678,\"uuid\":\"4825063f-70e5-47c2-ae65-7a822adf028c\"},\"content\":[{\"type\":\"text\",\"text\":\"“\",\"attrs\":{\"start\":0,\"end\":1}},{\"type\":\"text\",\"text\":\"Mañjuśrī\",\"attrs\":{\"start\":1,\"end\":9},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a9d821a9-3cc6-4f11-94b6-c36ad0b6a6cb\",\"uuid\":\"029b7898-ff29-4e10-bbed-9cd492325767\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the aspirations of the \",\"attrs\":{\"start\":9,\"end\":34}},{\"type\":\"text\",\"text\":\"Thus-Gone\",\"attrs\":{\"start\":34,\"end\":43},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"963cb9c1-a2e5-41ac-8adb-fb186ffe980e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":43,\"end\":44}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha­rāja\",\"attrs\":{\"start\":44,\"end\":79},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"42700cf7-b80f-42be-89b1-6b4b26f2b60a\",\"uuid\":\"547e5d9f-8d9d-42f0-8923-3170f53c8517\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and the array of good qualities of his buddhafield cannot be exhausted over the course of an eon or even longer than an eon. His buddhafield is utterly pure. There are no stones, pebbles, or gravel; there are no faults related to \",\"attrs\":{\"start\":79,\"end\":310}},{\"type\":\"text\",\"text\":\"desire\",\"attrs\":{\"start\":310,\"end\":316},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"54c235ea-276c-48dd-ae08-eae32314a7a1\",\"uuid\":\"b95639b4-10bb-4961-8a4e-15950a261ba7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"; there are no cries of suffering and the lower realms; and there is no such thing as the female gender. The foundation, walls, fences, archways, latticework windows, and \",\"attrs\":{\"start\":316,\"end\":487}},{\"type\":\"text\",\"text\":\"turrets\",\"attrs\":{\"start\":487,\"end\":494},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7d39cc5d-256c-4e30-9eb9-c28731cd772c\",\"uuid\":\"5c6e8e07-f68f-495a-9ff3-e3a1015ac6ba\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" are made of \",\"attrs\":{\"start\":494,\"end\":507}},{\"type\":\"text\",\"text\":\"blue beryl\",\"attrs\":{\"start\":507,\"end\":517},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"10c7e31c-8ab9-4465-a8ba-3027ff390cc4\",\"uuid\":\"85cdebdc-14b0-482c-ac26-1de2ba4db38e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and the parapets are made of the \",\"attrs\":{\"start\":517,\"end\":552}},{\"type\":\"text\",\"text\":\"seven precious substances\",\"attrs\":{\"start\":552,\"end\":577},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2940c04f-befa-42ef-b5bf-3e8d49cd973e\",\"uuid\":\"1ebf265d-5a68-49f3-83fe-f2b612657d16\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". The array of good qualities of the world \",\"attrs\":{\"start\":577,\"end\":620}},{\"type\":\"text\",\"text\":\"Vaiḍūrya­nirbhāsa\",\"attrs\":{\"start\":620,\"end\":637},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4606878a-3e90-40c6-97cb-1c3fd3ed91b8\",\"uuid\":\"bed8a002-0b37-4ccb-81b6-4d3293be5b04\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is equal to that of the world \",\"attrs\":{\"start\":637,\"end\":668}},{\"type\":\"text\",\"text\":\"Sukhāvatī\",\"attrs\":{\"start\":668,\"end\":677},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"041e2923-fe02-4270-a362-a95100f2fb76\",\"uuid\":\"151b4176-be7b-48de-9a09-4f45b233794c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":677,\"end\":678}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"c8927dce-85d1-4b8e-aca7-ad2c039afee3\",\"sort\":479,\"type\":\"translation\",\"label\":\"1.22\",\"alignments\":{\"toh504\":{\"folioUuid\":\"61ad8162-f9ad-4c9e-aad7-975ac174ed89\",\"toh\":\"toh504\",\"tibetan\":\"འཇིག་རྟེན་གྱི་ཁམས་དེ་ན་བྱང་ཆུབ་སེམས་དཔའ་གྲངས་མེད་དཔག་ཏུ་མེད་པ་དེ་དག་གི་ནང་ན། བྱང་ཆུབ་སེམས་དཔའ་སེམས་དཔའ་ཆེན་པོ་གཙོ་བོ་གཉིས་ཡོད་དེ། གཅིག་གི་མིང་ནི་ཉི་མ་ལྟར་རྣམ་པར་སྣང་བྱེད་ཅེས་བྱ། གཉིས་པའི་མིང་ནི་\\nཟླ་བ་ལྟར་རྣམ་པར་སྣང་བྱེད་ཅེས་བྱ་སྟེ། དེ་དག་ནི་བཅོམ་ལྡན་འདས་དེ་བཞིན་གཤེགས་པ་སྨན་གྱི་བླ་བཻ་ཌཱུརྱའི་འོད་དེའི་དམ་པའི་ཆོས་ཀྱི་མཛོད་འཛིན་པའོ། །འཇམ་དཔལ་དེ་ལྟ་བས་ན་དད་པའི་རིགས་ཀྱི་བུ་འམ། རིགས་ཀྱི་བུ་མོས་སངས་རྒྱས་ཀྱི་ཞིང་དེར་སྐྱེ་བར་སྨོན་[F.277.a]ལམ་ཐོབ་ཅིག །\",\"folioNumber\":276,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":433,\"uuid\":\"c8927dce-85d1-4b8e-aca7-ad2c039afee3\"},\"content\":[{\"type\":\"text\",\"text\":\"“There are two bodhisattva great beings who are foremost among the immeasurable and innumerable bodhisattvas in that world. The first is named \",\"attrs\":{\"start\":0,\"end\":143}},{\"type\":\"text\",\"text\":\"Sūrya­vairocana\",\"attrs\":{\"start\":143,\"end\":158},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"529e1b37-d121-4652-87c7-d7915abc2d68\",\"uuid\":\"eccaea20-a5bf-416b-a487-652f5ec3706b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and the second is named \",\"attrs\":{\"start\":158,\"end\":184}},{\"type\":\"text\",\"text\":\"Candra­vairocana\",\"attrs\":{\"start\":184,\"end\":200},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"6034a49d-847e-41ad-aae1-7a995b361ec8\",\"uuid\":\"f0a51870-5d7d-4ceb-9e21-fb86e06eecc1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". These two maintain the treasury of the holy Dharma of the \",\"attrs\":{\"start\":200,\"end\":260}},{\"type\":\"text\",\"text\":\"blessed\",\"attrs\":{\"start\":260,\"end\":267},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"6ea182a0-85bc-44a4-9219-7e228f87f76f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":267,\"end\":268}},{\"type\":\"text\",\"text\":\"Thus-Gone\",\"attrs\":{\"start\":268,\"end\":277},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"34f5a989-cb5c-4377-9f74-337294673bb2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":277,\"end\":278}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha\",\"attrs\":{\"start\":278,\"end\":308},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"496408c1-e2d7-4787-acaf-cf6b194d9722\",\"uuid\":\"071116d7-448a-44f3-89c3-b09a6a3e8db4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". \",\"attrs\":{\"start\":308,\"end\":310}},{\"type\":\"text\",\"text\":\"Mañjuśrī\",\"attrs\":{\"start\":310,\"end\":318},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a9d821a9-3cc6-4f11-94b6-c36ad0b6a6cb\",\"uuid\":\"586bc9d8-c4dc-4900-b46c-5d6fdad42fb8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", that is why a faithful son or daughter of good family should make the aspiration to be born in that buddhafield.”\",\"attrs\":{\"start\":318,\"end\":433}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"72d7eb1d-0202-4cb5-9ca0-0ac4eb60d5da\",\"sort\":495,\"type\":\"translation\",\"label\":\"1.23\",\"alignments\":{\"toh504\":{\"folioUuid\":\"f7a9b98f-950f-43b1-805b-694e0a1b3524\",\"toh\":\"toh504\",\"tibetan\":\"ཡང་བཅོམ་ལྡན་འདས་ཀྱིས་འཇམ་དཔལ་གཞོན་ནུར་གྱུར་པ་ལ་བཀའ་སྩལ་པ། འཇམ་དཔལ་སེམས་ཅན་སོ་སོའི་སྐྱེ་བོ་གང་དག་དགེ་བ་དང་མི་དགེ་བ་མི་ཤེས་པ་དག་ཡོད་དེ། དེ་དག་ནི་ཆགས་པའི་ཟིལ་གྱིས་ནོན་པ། སྦྱིན་\\nཔ་དང་སྦྱིན་པའི་འབྲས་བུ་རྣམ་པར་སྨིན་པ་མི་ཤེས་པའོ། །དེ་དག་ནི་བྱིས་པ། གླེན་པ། དད་པའི་དབང་པོ་དང་བྲལ་བ། ནོར་སོག་ཅིང་། སྲུང་བ་ལ་མངོན་པར་བརྩོན་གྱི། སྦྱིན་པ་ཡང་དག་པར་འགྱེད་པ་ལ་དེ་དག་གི་སེམས་མི་འགྲོ་བ་སྟེ། སྦྱིན་པའི་དུས་ཉེ་\\nབར་གནས་པ་ན་རང་གི་ལུས་ཀྱི་ཤ་ལས་བཅད་པ་བཞིན་དུ་ཡིད་མི་དགའ་བར་འགྱུར་རོ། །སེམས་ཅན་དེ་དག་ནི་བདག་ཉིད་ཀྱང་དུ་མ་ཡོངས་སུ་མི་སྤྱོད་ན་ཕ་མ་དང་། ཆུང་མ་དང་། བུ་དང་། བུ་མོ་ལ་མི་སྟེར་བ་ལྟ་སྨོས་ཀྱང་ཅི་དགོས། བྲན་ཕོ་དང་། བྲན་མོ་དང་། ལས་བྱེད་\\nཔ་རྣམས་ལ་ལྟ་སྨོས་ཀྱང་ཅི་དགོས། གཞན་སློང་བ་རྣམས་ལ་ལྟ་སྨོས་ཀྱང་ཅི་དགོས། \",\"folioNumber\":277,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":735,\"uuid\":\"72d7eb1d-0202-4cb5-9ca0-0ac4eb60d5da\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"722ef5d6-a7d6-4681-b204-6b3cbb6dc876\"},\"content\":[{\"type\":\"text\",\"text\":\"The \",\"attrs\":{\"start\":0,\"end\":4}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":4,\"end\":15},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"1970c183-8430-4dd7-b723-1fbcd03b70a5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" continued to address \",\"attrs\":{\"start\":15,\"end\":37}},{\"type\":\"text\",\"text\":\"Mañjuśrīkumārabhūta\",\"attrs\":{\"start\":37,\"end\":56},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"445d93f2-7d72-4338-8d0d-41391ddd697a\",\"uuid\":\"33e35828-8462-4a4e-8184-7800893813fb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", saying, “\",\"attrs\":{\"start\":56,\"end\":67}},{\"type\":\"text\",\"text\":\"Mañjuśrī\",\"attrs\":{\"start\":67,\"end\":75},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a9d821a9-3cc6-4f11-94b6-c36ad0b6a6cb\",\"uuid\":\"5861ddd5-df1f-48cb-910d-33c53e8eb3aa\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", there are ordinary beings who do not know about virtue and nonvirtue. They are \",\"attrs\":{\"start\":75,\"end\":156}},{\"type\":\"text\",\"text\":\"overcome by greed\",\"attrs\":{\"start\":156,\"end\":173},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"facdabe4-db2f-4a2a-b57f-3af989136f31\",\"uuid\":\"530c349e-1d02-4fff-9c59-b6a1bad9cbbc\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and do not understand generosity and the ripened result of generosity. They are childish and foolish, lacking the capacity for faith. As they strive to accumulate and maintain \",\"attrs\":{\"start\":173,\"end\":350}},{\"type\":\"text\",\"text\":\"wealth\",\"attrs\":{\"start\":350,\"end\":356},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7592fd85-fafc-42db-a077-641db438c9e7\",\"uuid\":\"30039476-bbdc-4020-a0b4-0d99b2cccb09\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", their minds are not disposed toward generosity and sharing. When it is time to give a gift, they become dejected as if they were cutting the flesh from their own bodies. Many of those beings do not even allow themselves to enjoy material \",\"attrs\":{\"start\":356,\"end\":596}},{\"type\":\"text\",\"text\":\"wealth\",\"attrs\":{\"start\":596,\"end\":602},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7592fd85-fafc-42db-a077-641db438c9e7\",\"uuid\":\"32cda0ed-47fe-4a0c-949b-bd53c544f443\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\",\",\"attrs\":{\"start\":602,\"end\":603},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"9a67c48d-ef45-4231-b6a2-535266959f4d\",\"label\":\"16\",\"uuid\":\"5f4b863f-0264-48d7-bc12-f47dfdcef549\",\"start\":603,\"end\":603,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" let alone provide for their parents, wives, sons, and daughters, for their male and female servants and employees, and for beggars.\",\"attrs\":{\"start\":603,\"end\":735}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"c9ee30b3-a29f-4f0f-8e90-ea9fce7d4017\",\"sort\":511,\"type\":\"translation\",\"label\":\"1.24\",\"alignments\":{\"toh504\":{\"folioUuid\":\"f7a9b98f-950f-43b1-805b-694e0a1b3524\",\"toh\":\"toh504\",\"tibetan\":\"སེམས་ཅན་དེ་ལྟ་བུ་དེ་དག་ནི་འདི་ནས་ཤི་འཕོས་ནས་ཡི་དགས་ཀྱི་འཇིག་རྟེན་དུ་སྐྱེ་བར་འགྱུར། ཡང་ན་དུད་འགྲོའི་སྐྱེ་གནས་སུ་སྐྱེ་བར་འགྱུར་རོ། །དེ་ལ་གང་དག་སྔོན་མིར་གྱུར་པ་ན། \\nབཅོམ་ལྡན་འདས་དེ་བཞིན་གཤེགས་པ་སྨན་གྱི་བླ་བཻ་ཌཱུརྱའི་འོད་དེའི་མཚན་ཐོས་པར་གྱུར་པ་དེ་དག་ནི་གཤིན་རྗེའི་འཇིག་རྟེན་ན་གནས་ཀྱང་རུང་། དུད་འགྲོའི་སྐྱེ་གནས་ན་གནས་ཀྱང་རུང་སྟེ། དེར་དེ་བཞིན་གཤེགས་པ་དེའི་མཚན་མངོན་དུ་འགྱུར་ཞིང་དྲན་མ་ཐག་པ་ཙམ་གྱིས་\\nདེ་ནས་ཤི་འཕོས་ནས་ཡང་མིའི་འཇིག་རྟེན་དུ་སྐྱེ་བར་འགྱུར་ཚེ་རབས་དྲན་པར་འགྱུར་རོ། །ངན་འགྲོའི་འཇིགས་པས་སྐྲག་ནས་ཡང་འདོད་པའི་ཡོན་ཏན་དག་དོན་དུ་མི་གཉེར་བ་དང་། སྦྱིན་པ་ལ་མངོན་པར་དགའ་བ་དང་། སྦྱིན་པའི་བསྔགས་པ་བརྗོད་པ་དང་། བདོག་པ་\\nཐམས་ཅད་ཡོངས་སུ་གཏོང་བར་གྱུར་ཏེ། རིམ་གྱིས་རང་གི་མགོ་དང་། ལག་པ་དང་། རྐང་པ་དང་། མིག་དང་། ཤ་དང་། ཁྲག་ཀྱང་སློང་བ་རྣམས་ལ་རབ་ཏུ་སྦྱིན་པར་འགྱུར་ན། ནོར་གྱི་ཕུང་པོ་གཞན་ལྟ་སྨོས་ཀྱང་ཅི་དགོས། \",\"folioNumber\":277,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":845,\"uuid\":\"c9ee30b3-a29f-4f0f-8e90-ea9fce7d4017\"},\"content\":[{\"type\":\"text\",\"text\":\"“When such beings pass away, they are reborn in the \",\"attrs\":{\"start\":0,\"end\":52}},{\"type\":\"text\",\"text\":\"hungry ghost realm\",\"attrs\":{\"start\":52,\"end\":70},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1fb3df06-5971-4968-a4b4-1ba24293e727\",\"uuid\":\"96faff26-63a2-4ccf-bf96-e30e217cbf3c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" or as animals. For those among them who have heard the name of the \",\"attrs\":{\"start\":70,\"end\":138}},{\"type\":\"text\",\"text\":\"blessed\",\"attrs\":{\"start\":138,\"end\":145},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"9defee8d-4475-4d86-8df0-3bf526cf6b3f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":145,\"end\":146}},{\"type\":\"text\",\"text\":\"Thus-Gone\",\"attrs\":{\"start\":146,\"end\":155},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"e7611b69-fec6-47fd-9bd0-16b31bf54360\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":155,\"end\":156}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha\",\"attrs\":{\"start\":156,\"end\":186},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"496408c1-e2d7-4787-acaf-cf6b194d9722\",\"uuid\":\"6151199f-5e1f-44c6-8667-9b4a18bae7e3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in their previous lives as humans‍—whether they find themselves in the \",\"attrs\":{\"start\":186,\"end\":258}},{\"type\":\"text\",\"text\":\"world of Yama\",\"attrs\":{\"start\":258,\"end\":271},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b342c5a1-c902-458a-8eff-a8142a795d0b\",\"uuid\":\"9eb06fae-f290-4904-bdb1-1664b15f9cef\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" or in the animal realm‍—that \",\"attrs\":{\"start\":271,\"end\":301}},{\"type\":\"text\",\"text\":\"Thus-gone One\",\"attrs\":{\"start\":301,\"end\":314},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"c9b1792b-20b0-4233-9cf9-b317dc7504a8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s name will appear there before them. Simply by recollecting it, after they eventually pass away, they will once again be born in the human realm. They will remember their former lifetimes, grow anxious out of fear of the lower realms, and no longer concern themselves with \",\"attrs\":{\"start\":314,\"end\":589}},{\"type\":\"text\",\"text\":\"sense pleasures\",\"attrs\":{\"start\":589,\"end\":604},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"07e61ab3-fa98-4b8c-9c5c-daeb0e0e41e3\",\"uuid\":\"e2d64586-f4d6-4cd9-93ef-ef83cd701d30\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". They will delight in generosity, promote generosity, and give away everything they own. Eventually, they will even give their own head, hands, feet, eyes, flesh, and blood to anyone who asks, let alone other things like accumulated \",\"attrs\":{\"start\":604,\"end\":838}},{\"type\":\"text\",\"text\":\"wealth\",\"attrs\":{\"start\":838,\"end\":844},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7592fd85-fafc-42db-a077-641db438c9e7\",\"uuid\":\"aa5258db-b312-40a6-944c-45b5f0f5cc4c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":844,\"end\":845}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"7b7cbdcf-2792-415c-b157-96dd2fd6cb6c\",\"sort\":529,\"type\":\"translation\",\"label\":\"1.25\",\"alignments\":{\"toh504\":{\"folioUuid\":\"f7a9b98f-950f-43b1-805b-694e0a1b3524\",\"toh\":\"toh504\",\"tibetan\":\"འཇམ་དཔལ་གཞན་ཡང་སེམས་ཅན་གང་[F.277.b]དག་དེ་བཞིན་གཤེགས་པ་རྣམས་ཀྱི་བསླབ་པའི་གནས་འཇིག་པ་དག་ཡོད་དེ། དེ་དག་ཚུལ་ཁྲིམས་ལོག་པར་ཞུགས་ཤིང་ལྟ་བ་ལོག་པར་ཞུགས་ནས། གང་དག་ཚུལ་ཁྲིམས་དང་ལྡན་པ་དེ་དག་ནི་ཚུལ་ཁྲིམས་སྲུང་གི་མང་དུ་ཐོས་པ་ཡོངས་སུ་མི་ཚོལ་ཏེ། དེ་བཞིན་གཤེགས་\\nཔས་གསུངས་པའི་མདོ་སྡེ་རྣམས་ཀྱི་དོན་ཟབ་མོ་མི་ཤེས། གང་དག་མང་དུ་ཐོས་པ་དེ་དག་ནི་ལྷག་པའི་ང་རྒྱལ་ཅན་དུ་གྱུར་ཏེ། ང་རྒྱལ་གྱིས་ནོན་པས་གཞན་དག་ལ་ཕྲག་དོག་བྱེད་ཅིང་དམ་པའི་ཆོས་ལ་དབང་ཟ་བར་འགྱུར། སྤོང་བར་འགྱུར་རོ། །མི་བླུན་པོ་དེ་ལྟ་བུ་དེ་དག་ནི་\\nབདུད་ཀྱི་ཕྱོགས་པ་སྟེ། བདག་ཀྱང་ལམ་ངན་པར་ཞུགས་ལ་སེམས་ཅན་གཞན་བྱེ་བ་ཁྲག་ཁྲིག་བརྒྱ་སྟོང་དུ་མ་དག་ཀྱང་གཡང་ས་ཆེན་པོར་ལྷུང་བར་བྱེད་པའོ། །སེམས་ཅན་དེ་ལྟ་བུ་དེ་དག་ནི་སེམས་ཅན་དམྱལ་བ་མི་བཟད་པར་འགྲོ་བར་འགྱུར་རོ། །\",\"folioNumber\":277,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":714,\"uuid\":\"7b7cbdcf-2792-415c-b157-96dd2fd6cb6c\"},\"content\":[{\"type\":\"text\",\"text\":\"“Moreover, \",\"attrs\":{\"start\":0,\"end\":11}},{\"type\":\"text\",\"text\":\"Mañjuśrī\",\"attrs\":{\"start\":11,\"end\":19},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a9d821a9-3cc6-4f11-94b6-c36ad0b6a6cb\",\"uuid\":\"882d5350-ce80-412a-96f7-f355bb870ff5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", there are beings who undermine the \",\"attrs\":{\"start\":19,\"end\":56}},{\"type\":\"text\",\"text\":\"precepts\",\"attrs\":{\"start\":56,\"end\":64},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e1894c5d-a0ba-4881-b9aa-06595e73a72a\",\"uuid\":\"662e9dd2-7871-44a5-8872-457a6bdeebf8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of the \",\"attrs\":{\"start\":64,\"end\":72}},{\"type\":\"text\",\"text\":\"thus-gone ones\",\"attrs\":{\"start\":72,\"end\":86},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"46a670f2-9618-48c3-aa7d-a2d98f5f1f18\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\",\",\"attrs\":{\"start\":86,\"end\":87},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"b1606971-b954-46c6-aebb-44cfb3d53775\",\"label\":\"17\",\"uuid\":\"84f353c4-2514-4178-bed6-f0c877206639\",\"start\":87,\"end\":87,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" violating discipline and engaging in wrong views. There are those who are disciplined and may maintain their discipline, but do not seek erudition, and so do not understand the profound meaning of the discourses that the \",\"attrs\":{\"start\":87,\"end\":309}},{\"type\":\"text\",\"text\":\"Thus-Gone One\",\"attrs\":{\"start\":309,\"end\":322},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"176eca66-a5be-4632-9226-c00274373dc1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" has taught. There are those who do become erudite but develop excessive pride, and because they are \",\"attrs\":{\"start\":322,\"end\":423}},{\"type\":\"text\",\"text\":\"overcome by their pride\",\"attrs\":{\"start\":423,\"end\":446},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5030ca25-2021-4c21-99f8-1b68d07379f0\",\"uuid\":\"c845b4fe-a1cd-4a6a-8200-64eb5bfafb5d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", they act with jealousy toward others and misuse and forsake the holy Dharma. Such foolish people who side with \",\"attrs\":{\"start\":446,\"end\":559}},{\"type\":\"text\",\"text\":\"Māra\",\"attrs\":{\"start\":559,\"end\":563},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"30fce34c-e31e-4279-8a5c-69f1c3ca2f2f\",\"uuid\":\"69cbb3d2-5a3b-4022-8be3-15108828f153\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" pursue a bad path themselves and cause many billions of other beings to fall into the great abyss. Those beings are reborn amidst the horrors of hell.\",\"attrs\":{\"start\":563,\"end\":714}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"60e093eb-ae6c-47ad-8eaf-72375cc9d1af\",\"sort\":547,\"type\":\"translation\",\"label\":\"1.26\",\"alignments\":{\"toh504\":{\"folioUuid\":\"9796fb67-62fb-4e74-b917-781771ec2993\",\"toh\":\"toh504\",\"tibetan\":\"གང་དག་སྔོན་མིར་གྱུར་\\nཔ་ན་བཅོམ་ལྡན་འདས་དེ་བཞིན་གཤེགས་པ་སྨན་གྱི་བླ་བཻ་ཌཱུརྱའི་འོད་དེའི་མཚན་ཐོས་པར་གྱུར་པ་དེ་དག་ནི་སེམས་ཅན་དམྱལ་བ་ན་གནས་ཀྱང་དེར་སངས་རྒྱས་ཀྱི་མཐུས་དེ་བཞིན་གཤེགས་པ་དེའི་མཚན་མངོན་དུ་འགྱུར་ཏེ། དེ་དག་དེ་ནས་ཤི་འཕོས་ནས་ཡང་མིའི་འཇིག་རྟེན་དུ་སྐྱེ་\\nབར་འགྱུར། ཡང་དག་པའི་ལྟ་བ་ཅན་དང་། བརྩོན་འགྲུས་དང་ལྡན་པ་དང་། དགེ་བའི་བསམ་པ་ཅན་དུ་འགྱུར་རོ། །དེ་དག་ཁྱིམ་སྤངས་ཏེ་དེ་བཞིན་གཤེགས་པའི་བསྟན་པ་ལ་རབ་ཏུ་བྱུང་ནས་མཐར་གྱིས་བྱང་ཆུབ་སེམས་དཔའི་སྤྱད་པ་སྤྱོད་པར་འགྱུར་རོ། །\",\"folioNumber\":277,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":545,\"uuid\":\"60e093eb-ae6c-47ad-8eaf-72375cc9d1af\"},\"content\":[{\"type\":\"text\",\"text\":\"“For those who have heard the name of the \",\"attrs\":{\"start\":0,\"end\":42}},{\"type\":\"text\",\"text\":\"blessed\",\"attrs\":{\"start\":42,\"end\":49},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"d1c967a3-7263-4a97-9f4f-98f96fbf86d8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":49,\"end\":50}},{\"type\":\"text\",\"text\":\"Thus-Gone\",\"attrs\":{\"start\":50,\"end\":59},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"893cef00-e0a7-4786-9c4a-323e3f4921d3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":59,\"end\":60}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha\",\"attrs\":{\"start\":60,\"end\":90},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"496408c1-e2d7-4787-acaf-cf6b194d9722\",\"uuid\":\"da6f7c7f-4bc0-4cf6-93fe-298e07570132\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in a previous life as a human being, even those who live in the hell realms, the power of the Buddha will cause the name of that \",\"attrs\":{\"start\":90,\"end\":220}},{\"type\":\"text\",\"text\":\"thus-gone one\",\"attrs\":{\"start\":220,\"end\":233},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"f89eef16-e710-47f3-aa46-aa2c042cb157\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" to appear before them. Then, when they pass away, they will be reborn in the human realm. They will maintain the correct view, they will be diligent, and their minds will be predisposed toward virtue. They will leave home, go forth in the teaching of the \",\"attrs\":{\"start\":233,\"end\":489}},{\"type\":\"text\",\"text\":\"Thus-Gone One\",\"attrs\":{\"start\":489,\"end\":502},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"47134021-21f3-4d87-b0d1-b9d340456d70\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and finally practice bodhisattva conduct.\",\"attrs\":{\"start\":502,\"end\":545}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"65102952-7f7c-41ad-a3ef-35a2842787b1\",\"sort\":559,\"type\":\"translation\",\"label\":\"1.27\",\"alignments\":{\"toh504\":{\"folioUuid\":\"9796fb67-62fb-4e74-b917-781771ec2993\",\"toh\":\"toh504\",\"tibetan\":\"འཇམ་དཔལ་\\nགཞན་ཡང་སེམས་ཅན་གང་དག་བདག་གི་བསྔགས་པ་བརྗོད་ཅིང་ཕྲག་དོག་གིས་གཞན་དག་ལ་མི་སྙན་པར་རྗོད་པ་ཡོད་དེ། བདག་ལ་བསྟོད་ཅིང་གཞན་ལ་སྨོད་པའི་སེམས་ཅན་དེ་དག་ངན་སོང་གསུམ་པོ་དག་ཏུ་ལོ་སྟོང་ཕྲག་མང་པོར་སྡུག་བསྔལ་མྱོང་བར་འགྱུར་རོ། །དེ་དག་\\nལོ་སྟོང་ཕྲག་དུ་མ་འདས་ནས་དེ་ནས་ཤི་འཕོས་ནས་བ་ལང་དང་། རྟ་དང་། རྔ་མོ་དང་། བོང་བུ་ལ་སོགས་པ་དུད་འགྲོའི་སྐྱེ་གནས་རྣམས་སུ་སྐྱེ་བར་འགྱུར། ལྕུག་ལྕག་དང་། དབྱུག་ལྕག་རྣམས་ཀྱིས་བརྡེག་པ་དང་། བཀྲེས་པ་དང་། སྐོམ་པས་ལུས་ཉེན་པ་དང་།[F.278.a]ཁལ་ཆེན་པོ་བཀལ་ཏེ་ལམ་དུ་འགྲོ་བར་འགྱུར་རོ། །གལ་ཏེ་བརྒྱ་ལ་མིའི་སྐྱེ་བ་རྙེད་ན་ཡང་རྟག་ཏུ་རིགས་དམའ་བ་རྣམས་ཀྱི་ནང་དུ་སྐྱེ་བར་འགྱུར་རོ། །བྲན་དུ་འགྱུར་ཞིང་གཞན་གྱི་དབང་དུ་འགྱུར་རོ། །\",\"folioNumber\":277,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":669,\"uuid\":\"65102952-7f7c-41ad-a3ef-35a2842787b1\"},\"content\":[{\"type\":\"text\",\"text\":\"“Moreover, \",\"attrs\":{\"start\":0,\"end\":11}},{\"type\":\"text\",\"text\":\"Mañjuśrī\",\"attrs\":{\"start\":11,\"end\":19},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a9d821a9-3cc6-4f11-94b6-c36ad0b6a6cb\",\"uuid\":\"bfee8c8d-1f1e-4d98-bea2-6ffb7c351e3c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", there are beings who praise themselves and denigrate others out of jealousy. Beings who sing their own praises and denigrate others will suffer in the three lower realms for many thousands of years. After many thousands of years have passed, they will pass away and be reborn in the animal realm as cows, horses, camels, donkeys, and so forth. They will be \",\"attrs\":{\"start\":19,\"end\":378}},{\"type\":\"text\",\"text\":\"beaten\",\"attrs\":{\"start\":378,\"end\":384},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b38cc372-b545-4778-b427-798edb1137f7\",\"uuid\":\"a7614841-a176-46cf-afa8-1d43fa08f123\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" with whips and rods, their bodies will be afflicted by hunger and thirst, and they will have to carry great loads as they move along the road. Even if they do attain human birth, they will always be born into families of low standing, be servants, and be under other people’s control.\",\"attrs\":{\"start\":384,\"end\":669}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"defa47ce-9eeb-447a-8dad-4e92e87d230a\",\"sort\":567,\"type\":\"translation\",\"label\":\"1.28\",\"alignments\":{\"toh504\":{\"folioUuid\":\"bfbb0313-8b50-44a3-beab-599a3d9bb04c\",\"toh\":\"toh504\",\"tibetan\":\"གང་དག་སྔོན་མིར་གྱུར་པ་ན་བཅོམ་ལྡན་འདས་\\nདེ་བཞིན་གཤེགས་པ་སྨན་གྱི་བླ་བཻ་ཌཱུརྱའི་འོད་དེའི་མཚན་ཐོས་པར་གྱུར་པ། དེ་དག་ནི་དགེ་བའི་རྩ་བ་དེས་སྡུག་བསྔལ་ཐམས་ཅད་ལས་ཡོངས་སུ་ཐར་བར་འགྱུར། དབང་པོ་རྣོ་བར་འགྱུར། མཁས་པ་དང་། གསལ་བ་དང་། ཡིད་གཞུངས་པ་དང་། དགེ་བ་ཡོངས་\\nསུ་བཙལ་བ་ལ་མངོན་པར་བརྩོན་པ་དང་། རྟག་ཏུ་དགེ་བའི་བཤེས་གཉེན་དང་འགྲོགས་པ་རྙེད་པར་འགྱུར། བདུད་ཀྱི་ཞགས་པ་གཅོད་པ་དང་། མ་རིག་པའི་སྒོ་ངའི་སྦུབས་གཅོག་པ་དང་། ཉོན་མོངས་པའི་ཆུ་ཀླུང་སྐེམས་པར་འགྱུར། སྐྱེ་བ་དང་། རྒ་ཤི་\\nདང་། མྱ་ངན་དང་། སྨྲེ་སྔགས་འདོན་པ་དང་། སྡུག་བསྔལ་བ་དང་། ཡིད་མི་བདེ་བ་དང་། འཁྲུག་པ་རྣམས་ལས་ཡོངས་སུ་ཐར་བར་འགྱུར་རོ། །\",\"folioNumber\":278,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":583,\"uuid\":\"defa47ce-9eeb-447a-8dad-4e92e87d230a\"},\"content\":[{\"type\":\"text\",\"text\":\"“Those who have heard the name of the \",\"attrs\":{\"start\":0,\"end\":38}},{\"type\":\"text\",\"text\":\"blessed\",\"attrs\":{\"start\":38,\"end\":45},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"3c244261-ee12-43ab-adaf-bbda31114017\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":45,\"end\":47}},{\"type\":\"text\",\"text\":\"thus-gone\",\"attrs\":{\"start\":47,\"end\":56},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"8383f1a8-1e0f-40a7-8536-5ebfed8ed761\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", worthy, and perfect Buddha \",\"attrs\":{\"start\":56,\"end\":85}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha\",\"attrs\":{\"start\":85,\"end\":115},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"496408c1-e2d7-4787-acaf-cf6b194d9722\",\"uuid\":\"b9018fd7-645a-48a6-9ae7-95b42f659868\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in a previous life as a human being will be liberated from all manner of suffering due to that root of virtue. They will be intelligent, learned, bright,\",\"attrs\":{\"start\":115,\"end\":269},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"f586d37e-6bcb-467d-ba43-a537890390aa\",\"label\":\"18\",\"uuid\":\"16d9bea6-d264-4115-994d-00ddd26845b7\",\"start\":269,\"end\":269,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":269,\"end\":270}},{\"type\":\"text\",\"text\":\"prudent\",\"attrs\":{\"start\":270,\"end\":277},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cf691324-2de5-4910-a68b-c593bd039986\",\"uuid\":\"6e457a30-69e7-44f1-8a6f-57cff41dbab0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and focused on pursuing virtue, and they will always find company with a spiritual teacher. They will cut \",\"attrs\":{\"start\":277,\"end\":385}},{\"type\":\"text\",\"text\":\"Māra\",\"attrs\":{\"start\":385,\"end\":389},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"30fce34c-e31e-4279-8a5c-69f1c3ca2f2f\",\"uuid\":\"38675fb9-883a-4c7a-97a1-da60f5fef5a4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s bonds, crush the eggshell of ignorance, and dry up the river of the afflictions. They will be liberated from birth, old age, death, anguish, lamentation, suffering, unhappiness, and conflict.\",\"attrs\":{\"start\":389,\"end\":583}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"7961ce17-f30f-47f1-b284-f403a6be440a\",\"sort\":581,\"type\":\"translation\",\"label\":\"1.29\",\"alignments\":{\"toh504\":{\"folioUuid\":\"bfbb0313-8b50-44a3-beab-599a3d9bb04c\",\"toh\":\"toh504\",\"tibetan\":\"འཇམ་དཔལ་གཞན་ཡང་སེམས་ཅན་གང་དག་ཕྲ་མ་ལ་མངོན་པར་དགའ་ཞིང་སེམས་ཅན་གང་དག་ཕན་ཚུན་འཐབ་\\nཔ་དང་། རྩོད་པ་དང་། འགྱེད་པར་བྱེད་དུ་འཇུག་པ་དག་ཡོད་དེ། སེམས་ཅན་དེ་དག་རྣམ་པར་རྩོད་པའི་སེམས་སུ་གྱུར་པས་ལུས་དང་ངག་དང་། ཡིད་ཀྱིས་མི་དགེ་བ་རྣམ་པ་སྣ་ཚོགས་མངོན་པར་འདུ་བྱེད་དོ། །གཅིག་ལ་གཅིག་ཕན་པ་མ་ཡིན་པ་འདོད་ཅིང་རྟག་ཏུ་ཕན་\\nཚུན་གནོད་པར་བྱ་བའི་ཕྱིར་བརྩོན་ཏེ། དེ་དག་ནགས་ཚལ་གྱི་ལྷ་དང་། ཤིང་གི་ལྷ་དང་། རིའི་ལྷ་འགུགས་པར་བྱེད། དུར་ཁྲོད་རྣམས་སུ་འབྱུང་པོ་ཐ་དད་པ་དག་འགུགས་པར་བྱེད། དུད་འགྲོའི་སྐྱེ་གནས་སུ་སོང་བའི་སྲོག་ཆགས་རྣམས་ཀྱི་སྲོག་གཅོད་ཅིང་ཤ་དང་\\nཁྲག་ཟ་བའི་གནོད་སྦྱིན་དང་། སྲིན་པོ་རྣམས་མཆོད་པར་བྱེད་དེ། དགྲ་བོ་དེའི་མིང་ནས་བརྗོད་པའམ། གཟུགས་བྱས་ནས་དེར་རིག་སྔགས་དྲག་པོ་སྒྲུབ་ཅིང་། བྱད་སྟེམས་དང་། རོ་ལངས་ཀྱི་སྦྱོར་བས་སྲོག་གི་བར་ཆད་བྱ་བ་དང་། ལུས་རྣམ་པར་གཞིག་པར་[F.278.b]འདོད་པ་ལ་གང་དག་གིས་བཅོམ་ལྡན་འདས་དེ་བཞིན་གཤེགས་པ་སྨན་གྱི་བླ་བཻ་ཌཱུརྱའི་འོད་ཀྱི་རྒྱལ་པོ་དེའི་མཚན་ཐོས་པར་གྱུར་པ་དེ་དག་ལ་གང་གིས་ཀྱང་བར་ཆད་བྱ་བར་མི་ནུས་ཏེ། དེ་དག་ཕན་ཚུན་བྱམས་པའི་སེམས་དང་། ཕན་པའི་སེམས་དང་། གནོད་པའི་སེམས་\\nམེད་པའི་སེམས་སུ་གནས་པར་འགྱུར། རང་རང་གི་བདོག་པས་ཆོག་ཤེས་པར་འགྱུར་རོ། །\",\"folioNumber\":278,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1003,\"uuid\":\"7961ce17-f30f-47f1-b284-f403a6be440a\"},\"content\":[{\"type\":\"text\",\"text\":\"“\",\"attrs\":{\"start\":0,\"end\":1}},{\"type\":\"text\",\"text\":\"Mañjuśrī\",\"attrs\":{\"start\":1,\"end\":9},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a9d821a9-3cc6-4f11-94b6-c36ad0b6a6cb\",\"uuid\":\"2d7b8978-21f9-4a1d-8bb6-aa0457769396\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", there are also those beings who delight in slander and beings who instigate fights, arguments, and disputes with one another. Such contentious beings commit various types of nonvirtuous actions with their body, speech, and mind. They do not wish to benefit one another and constantly try to harm one another. They summon a \",\"attrs\":{\"start\":9,\"end\":334}},{\"type\":\"text\",\"text\":\"forest deity\",\"attrs\":{\"start\":334,\"end\":346},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"3c859288-df02-440f-b02c-ccdb20807dcc\",\"uuid\":\"4071adbb-78c4-45ec-a27d-468d1150ea5e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":346,\"end\":348}},{\"type\":\"text\",\"text\":\"tree deity\",\"attrs\":{\"start\":348,\"end\":358},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a7b884d2-a341-46dc-9ca7-bd5a6a73eaa3\",\"uuid\":\"8f3a7df3-b6c7-48e7-adac-a7dbc0155dce\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", or \",\"attrs\":{\"start\":358,\"end\":363}},{\"type\":\"text\",\"text\":\"mountain deity\",\"attrs\":{\"start\":363,\"end\":377},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"fa5cf5ef-0351-47e4-805f-80836b5b9e51\",\"uuid\":\"537742b5-71eb-47d1-9d6e-b38d1e0a12ff\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", or they summon the various spirits in the charnel grounds. They kill beings who have taken birth as animals and offer them to the \",\"attrs\":{\"start\":377,\"end\":509}},{\"type\":\"text\",\"text\":\"yakṣas\",\"attrs\":{\"start\":509,\"end\":515},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5d1d861a-9a7d-45ee-9d4e-a843c5698e55\",\"uuid\":\"75bfc64e-180c-4dbc-98d1-e8571e71b0e4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and \",\"attrs\":{\"start\":515,\"end\":520}},{\"type\":\"text\",\"text\":\"rākṣasas\",\"attrs\":{\"start\":520,\"end\":528},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a8eda40a-7fdf-45b4-9578-016ac782cdfb\",\"uuid\":\"4f9fcb4b-b61b-4119-99e6-91523568d516\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" who eat flesh and blood. They utter the name of their enemy or create an effigy, cast a violent spell at them, and enlist a \",\"attrs\":{\"start\":528,\"end\":653}},{\"type\":\"text\",\"text\":\"kākhorda\",\"attrs\":{\"start\":653,\"end\":661},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"852d055a-c616-46a5-919b-e510b44302ee\",\"uuid\":\"51b812d2-64ad-4bd4-96e5-ddbf6e1b8fa7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" or \",\"attrs\":{\"start\":661,\"end\":665}},{\"type\":\"text\",\"text\":\"vetāla\",\"attrs\":{\"start\":665,\"end\":671},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c055f6d1-0659-4747-9503-bc39840c812f\",\"uuid\":\"dafddabd-0b38-4458-a08c-bbf8096b9ab0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" to create obstacles in their life with the hope that they will destroy their enemy’s body. However, no one can create obstacles for those who have heard the name of the \",\"attrs\":{\"start\":671,\"end\":841}},{\"type\":\"text\",\"text\":\"blessed\",\"attrs\":{\"start\":841,\"end\":848},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"6ca81a14-e2bb-4c66-9a46-1551d5dbb365\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":848,\"end\":849}},{\"type\":\"text\",\"text\":\"Thus-Gone\",\"attrs\":{\"start\":849,\"end\":858},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"c96a30da-b81a-4f35-baa7-8d2d334de545\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":858,\"end\":859}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha\",\"attrs\":{\"start\":859,\"end\":889},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"496408c1-e2d7-4787-acaf-cf6b194d9722\",\"uuid\":\"dbaf8af7-23da-445e-993b-fac75278f8f5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Such people are loving to one another, beneficent, free from ill will, and satisfied with their own possessions.\",\"attrs\":{\"start\":889,\"end\":1003}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"9f82a64e-0ed7-45c0-9adb-42ca8ca712f5\",\"sort\":607,\"type\":\"translation\",\"label\":\"1.30\",\"alignments\":{\"toh504\":{\"folioUuid\":\"87ea2f80-14e3-4499-90ad-9c71a2499076\",\"toh\":\"toh504\",\"tibetan\":\"འཇམ་དཔལ་གཞན་ཡང་འཁོར་བཞི་པོ་དགེ་སློང་དང་། དགེ་སློང་མ་དང་། དགེ་བསྙེན་མ་དེ་དག་དང་། གཞན་ཡང་དད་པའི་རིགས་ཀྱི་བུའམ། \\nརིགས་ཀྱི་བུ་མོ་གང་དག་ཡན་ལག་བརྒྱད་དང་ལྡན་པའི་བསྙེན་གནས་ལ་ཉེ་བར་གནས་ཏེ། ལོ་གཅིག་གམ། ཟླ་བ་གསུམ་དུ་བསླབ་པའི་གཞི་རྣམས་འཛིན་ཅིང་གང་དག་གིས་བསམ་པས་བདག་གི་དགེ་བའི་རྩ་བ་འདིས་ནུབ་ཕྱོགས་གང་ན་དེ་བཞིན་གཤེགས་པ་ཚེ་དཔག་མེད་\\nབཞུགས་པའི་འཇིག་རྟེན་གྱི་ཁམས་བདེ་བ་ཅན་དུ་སྐྱེ་བར་ཤོག་ཤིག་ཅེས་སྨོན་ལམ་དེ་ལྟ་བུ་བཏབ་པ་དག་ལས། གང་དག་གིས་བཅོམ་ལྡན་འདས་དེ་བཞིན་གཤེགས་པ་སྨན་གྱི་བླ་བཻ་ཌཱུརྱའི་འོད་དེའི་མཚན་ཐོས་པར་གྱུར་པ་དེ་དག་འཆི་བའི་དུས་ཀྱི་ཚེ་བྱང་ཆུབ་སེམས་དཔའ་བརྒྱད་རྫུ་\\nའཕྲུལ་གྱིས་ལྷགས་ནས་ལམ་སྟོན་པར་འགྱུར་ཏེ། དེ་དག་དེར་པདྨ་ཚོན་ཁ་དོག་སྣ་ཚོགས་རྣམས་ལས་རྫུས་ཏེ་སྐྱེ་བར་འགྱུར་རོ། །\",\"folioNumber\":278,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":702,\"uuid\":\"9f82a64e-0ed7-45c0-9adb-42ca8ca712f5\"},\"content\":[{\"type\":\"text\",\"text\":\"“Moreover, \",\"attrs\":{\"start\":0,\"end\":11}},{\"type\":\"text\",\"text\":\"Mañjuśrī\",\"attrs\":{\"start\":11,\"end\":19},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a9d821a9-3cc6-4f11-94b6-c36ad0b6a6cb\",\"uuid\":\"6fac2537-06be-4d37-83d9-7088e2d066b2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", among the fourfold assembly of monks, nuns, male lay practitioners, and female lay practitioners, as well as among other faithful sons or daughters of good family who observe the \",\"attrs\":{\"start\":19,\"end\":200}},{\"type\":\"text\",\"text\":\"eightfold precepts\",\"attrs\":{\"start\":200,\"end\":218},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5e2c147b-8fd1-47ec-85fd-32a254a33661\",\"uuid\":\"733264a2-0a42-4cc6-96f7-edc2698b04e2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", there are some who maintain the \",\"attrs\":{\"start\":218,\"end\":252}},{\"type\":\"text\",\"text\":\"precepts\",\"attrs\":{\"start\":252,\"end\":260},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e1894c5d-a0ba-4881-b9aa-06595e73a72a\",\"uuid\":\"cca4e1a5-5e95-467b-9ed2-8d06437e54b9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" for one year or three months. If they develop an aspiration, saying, ‘Due to my root of virtue, may I be reborn in the west in \",\"attrs\":{\"start\":260,\"end\":388}},{\"type\":\"text\",\"text\":\"Sukhāvatī\",\"attrs\":{\"start\":388,\"end\":397},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"041e2923-fe02-4270-a362-a95100f2fb76\",\"uuid\":\"0f085104-a11c-41e2-8750-64c6d73b515e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the world where the \",\"attrs\":{\"start\":397,\"end\":419}},{\"type\":\"text\",\"text\":\"Thus-Gone\",\"attrs\":{\"start\":419,\"end\":428},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"9f9ffdd5-2937-465e-a054-b7f933343c5b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":428,\"end\":429}},{\"type\":\"text\",\"text\":\"Amitāyus\",\"attrs\":{\"start\":429,\"end\":437},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7d8e26c4-d00a-499a-990a-e09d92900f70\",\"uuid\":\"b39440ad-4fb2-44ff-91cc-897e7dad2dfd\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" resides,’ they will hear the name of the \",\"attrs\":{\"start\":437,\"end\":479}},{\"type\":\"text\",\"text\":\"blessed\",\"attrs\":{\"start\":479,\"end\":486},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"94059dae-f81e-4f42-8f7a-bbc67f1d4a35\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":486,\"end\":487}},{\"type\":\"text\",\"text\":\"Thus-Gone\",\"attrs\":{\"start\":487,\"end\":496},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"42a4cc6b-689a-4894-83cb-00ff550b5f9b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":496,\"end\":497}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha\",\"attrs\":{\"start\":497,\"end\":527},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"496408c1-e2d7-4787-acaf-cf6b194d9722\",\"uuid\":\"cf56094b-b0fe-4e2b-88f6-337c0cc56726\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Then, at the moment of death, the \",\"attrs\":{\"start\":527,\"end\":563}},{\"type\":\"text\",\"text\":\"eight bodhisattvas\",\"attrs\":{\"start\":563,\"end\":581},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"dad2dff9-0c7e-4968-9332-94d4434d4b8e\",\"uuid\":\"7fa050f1-ecd7-4224-979f-1431796f4e13\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" will miraculously appear and show them the way, and they will take miraculous birth there upon brightly colored lotuses.\",\"attrs\":{\"start\":581,\"end\":702}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"955c1292-525f-449a-8b4f-f0aeeb51271e\",\"sort\":629,\"type\":\"translation\",\"label\":\"1.31\",\"alignments\":{\"toh504\":{\"folioUuid\":\"87ea2f80-14e3-4499-90ad-9c71a2499076\",\"toh\":\"toh504\",\"tibetan\":\"གང་ལ་ལ་དག་ལྷའི་འཇིག་རྟེན་དུ་སྐྱེ་བར་འགྱུར་བ་དེ་དག་ནི་དེར་སྐྱེས་ནས་སྔོན་གྱི་དགེ་བའི་རྩ་བ་དེ་ཟད་པར་མི་འགྱུར་ཞིང་ངན་འགྲོར་འགྲོ་བར་མི་\\nའགྱུར་རོ། །དེ་ནས་ཤི་འཕོས་ནས་ཀྱང་མིའི་འཇིག་རྟེན་འདིར་གླིང་བཞི་པའི་དབང་ཕྱུག་འཁོར་ལོས་སྒྱུར་བའི་རྒྱལ་པོར་གྱུར་ཏེ། སེམས་ཅན་བྱེ་བ་ཁྲག་ཁྲིག་བརྒྱ་སྟོང་དུ་མ་དགེ་བ་བཅུའི་ལས་ཀྱི་ལམ་ལ་འགོད་པར་འགྱུར་རོ། །\",\"folioNumber\":278,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":378,\"uuid\":\"955c1292-525f-449a-8b4f-f0aeeb51271e\"},\"content\":[{\"type\":\"text\",\"text\":\"“Some will be born in the \",\"attrs\":{\"start\":0,\"end\":26}},{\"type\":\"text\",\"text\":\"god\",\"attrs\":{\"start\":26,\"end\":29},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"743aac3d-15fc-4192-be69-b05c5584d4ea\",\"uuid\":\"e9ff2a45-35a2-4d22-901a-0ea7584f075a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" realms, and after they are born there, their previous roots of virtue will never be exhausted, and they will not proceed to the lower realms. After they pass away, they will become \",\"attrs\":{\"start\":29,\"end\":211}},{\"type\":\"text\",\"text\":\"universal emperors\",\"attrs\":{\"start\":211,\"end\":229},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"faed50ce-2e2a-4b67-8628-9d65feeacf17\",\"uuid\":\"25b4ff48-00c7-45ba-b4ce-18c98c66fe81\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" with dominion over the four continents in this human realm, and they will establish many billions of beings on the path of the \",\"attrs\":{\"start\":229,\"end\":357}},{\"type\":\"text\",\"text\":\"ten virtuous actions\",\"attrs\":{\"start\":357,\"end\":377},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"eb8e546c-1abf-4180-a5a9-35e9e80bbc92\",\"uuid\":\"51a60e61-03fe-4749-bf39-c1c814e4bd31\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":377,\"end\":378}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"e096316c-b8ba-4d35-8c1d-b6823578cebc\",\"sort\":637,\"type\":\"translation\",\"label\":\"1.32\",\"alignments\":{\"toh504\":{\"folioUuid\":\"87ea2f80-14e3-4499-90ad-9c71a2499076\",\"toh\":\"toh504\",\"tibetan\":\"གཞན་དུ་ན་ཡང་རྒྱལ་རིགས་ཤིང་སཱ་ལ་ཆེན་པོ་ལྟ་བུའི་\\nཁྱིམ་དག་ཏུ་སྐྱེ་བར་འགྱུར། བྲམ་ཟེ་ཤིང་སཱ་ལ་ཆེན་པོ་ལྟ་བུའི་ཁྱིམ་དག་དང་། ཁྱིམ་བདག་ཤིང་སཱ་ལ་ཆེན་པོ་ལྟ་བུའི་ཁྱིམ་དག་དང་། ནོར་དང་། འབྲུ་དང་། མཛོད་དང་། བང་བ་མང་པོ་འབྱོར་པའི་ཁྱིམ་དག་ཏུ་སྐྱེ་བར་འགྱུར་ཏེ། གཟུགས་ཕུན་སུམ་ཚོགས་པ་དང་། དབང་[F.279.a]ཕྱུག་ཕུན་སུམ་ཚོགས་པ་དང་། གཡོག་ཕུན་སུམ་ཚོགས་པ་དང་། དཔའ་བ་དང་། རྟུལ་ཕོད་པ་དང་། ཚན་པོ་ཆེ་ཆེན་པོའི་སྟོབས་ཀྱི་ཤུགས་དང་ལྡན་པར་འགྱུར་རོ། །བུད་མེད་གང་གིས་དེ་བཞིན་གཤེགས་པ་དེའི་མཚན་ཐོས་ཤིང་བཟུང་བ་དེའི་བུད་\\nམེད་ཀྱི་དངོས་པོ་དེ་ཐ་མ་ཡིན་པར་ཤེས་པར་བྱའོ། །\",\"folioNumber\":278,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":497,\"uuid\":\"e096316c-b8ba-4d35-8c1d-b6823578cebc\"},\"content\":[{\"type\":\"text\",\"text\":\"“Others will be born in great \",\"attrs\":{\"start\":0,\"end\":30}},{\"type\":\"text\",\"text\":\"kṣatriya\",\"attrs\":{\"start\":30,\"end\":38},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d64414dc-ad29-4e9d-99b1-d700901d25ab\",\"uuid\":\"8acd6867-ac5d-414f-9963-8e10344a7e16\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":38,\"end\":39}},{\"type\":\"text\",\"text\":\"households\",\"attrs\":{\"start\":39,\"end\":49},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"774fb7f2-7ff9-4d51-aa10-ed8bc69573a4\",\"uuid\":\"883fa763-2f88-41d8-935e-31867e6ad336\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", born in great brahmin \",\"attrs\":{\"start\":49,\"end\":73}},{\"type\":\"text\",\"text\":\"households\",\"attrs\":{\"start\":73,\"end\":83},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"774fb7f2-7ff9-4d51-aa10-ed8bc69573a4\",\"uuid\":\"7cd35f7e-743e-4bd9-bb3d-7419fec0c823\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", born in great landowning \",\"attrs\":{\"start\":83,\"end\":110}},{\"type\":\"text\",\"text\":\"households\",\"attrs\":{\"start\":110,\"end\":120},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"774fb7f2-7ff9-4d51-aa10-ed8bc69573a4\",\"uuid\":\"3741bf71-acd8-40a5-b62f-8eac3ebd5a65\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and born in households whose treasuries and storehouses contain an abundance of \",\"attrs\":{\"start\":120,\"end\":202}},{\"type\":\"text\",\"text\":\"riches\",\"attrs\":{\"start\":202,\"end\":208},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"010afd3a-1318-4adf-b782-5f146d3b3864\",\"uuid\":\"917ec599-272e-43e5-a2f8-069adc3f59a9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and \",\"attrs\":{\"start\":208,\"end\":213}},{\"type\":\"text\",\"text\":\"grain\",\"attrs\":{\"start\":213,\"end\":218},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"3ba5ea94-9e41-499a-bdfd-74e6f2650b7f\",\"uuid\":\"1a67602f-d286-40d7-8268-819cc14a9ac2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". They will have excellent physiques, be powerful, have attendants, be courageous and heroic, and have the \",\"attrs\":{\"start\":218,\"end\":325}},{\"type\":\"text\",\"text\":\"strength of a great champion\",\"attrs\":{\"start\":325,\"end\":353},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8552f074-9293-4a88-b611-021b0144e664\",\"uuid\":\"3f3d4f88-3a5a-4b81-b812-a3b18c656165\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Any woman who should hear the \",\"attrs\":{\"start\":353,\"end\":385}},{\"type\":\"text\",\"text\":\"Thus-Gone One\",\"attrs\":{\"start\":385,\"end\":398},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"c1be8563-a379-41ee-bc6d-dfe002b3944a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s name and bear it in mind should know that it is the last time she will be of the female gender.”\",\"attrs\":{\"start\":398,\"end\":497},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"8670d6af-5681-4b5c-bc48-174bfa649595\",\"label\":\"19\",\"uuid\":\"625dc24a-3e7e-4521-a9f7-5caf54cd6e6f\",\"start\":497,\"end\":497,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"080eb55a-6ca8-4c8b-8e67-8c582f66eb95\",\"sort\":658,\"type\":\"translation\",\"label\":\"1.33\",\"alignments\":{\"toh504\":{\"folioUuid\":\"f24fcd39-a0bb-4e50-9dcc-8457dcc3b40b\",\"toh\":\"toh504\",\"tibetan\":\"དེ་ནས་བཅོམ་ལྡན་འདས་ལ་འཇམ་དཔལ་གཞོན་ནུར་གྱུར་པས་འདི་སྐད་ཅེས་གསོལ་ཏོ། །བཅོམ་ལྡན་འདས་སླད་མའི་ཚེ་སླད་མའི་དུས་ན། གང་དག་མདོ་འདི་འཆང་བ་དང་། ཀློག་པ་དང་། འཆད་པ་དང་། གཞན་\\nདག་ལ་རྒྱ་ཆེར་ཡང་དག་པར་སྟོན་པ་དང་། ཡི་གེར་འདྲི་བ་དང་། ཡི་གེར་འདྲིར་སྩོལ་བ་དང་། གླེགས་བམ་ལ་བྲིས་ཏེ་མེ་ཏོག་དང་། བདུག་པ་དང་། སྤོས་དང་། ཕྲེང་བ་དང་། བྱུག་པ་དང་། གདུགས་དང་། རྒྱལ་མཚན་རྣམས་ཀྱིས་བཀུར་སྟི་བགྱིད་པའི་དད་པའི་རིགས་\\nཀྱི་བུའམ། རིགས་ཀྱི་བུ་མོ་དེ་དག་ལ་བདག་གིས་བཅོམ་ལྡན་འདས་དེ་བཞིན་གཤེགས་པ་སྨན་གྱི་བླ་བཻ་ཌཱུརྱའི་འོད་དེའི་མཚན་རྣམ་པ་སྣ་ཚོགས་སུ་བསྒྲག་པར་བགྱིའོ། །ཐ་ན་རྨི་ལམ་དུ་ཡངས་ངས་རྒྱས་ཀྱི་མཚན་རྣ་ལམ་དུ་ཉེ་བར་བསྒྲག་པར་བགྱིའོ། །\",\"folioNumber\":279,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":555,\"uuid\":\"080eb55a-6ca8-4c8b-8e67-8c582f66eb95\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"7fd7a573-6994-4b45-b99f-e5a273649672\"},\"content\":[{\"type\":\"text\",\"text\":\"At that point \",\"attrs\":{\"start\":0,\"end\":14}},{\"type\":\"text\",\"text\":\"Mañjuśrīkumārabhūta\",\"attrs\":{\"start\":14,\"end\":33},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"445d93f2-7d72-4338-8d0d-41391ddd697a\",\"uuid\":\"4e36ca5c-324d-4e6a-b6d8-c3cf7d1b6c2c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" told the \",\"attrs\":{\"start\":33,\"end\":43}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":43,\"end\":54},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"a2720d6d-f549-4e84-95ab-188c775e9168\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", “\",\"attrs\":{\"start\":54,\"end\":57}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":57,\"end\":68},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"2b97d346-9510-4aee-b3c7-a0247031cd45\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", in the future I will proclaim the name of the \",\"attrs\":{\"start\":68,\"end\":116}},{\"type\":\"text\",\"text\":\"blessed\",\"attrs\":{\"start\":116,\"end\":123},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"48bd4043-ab1d-45cb-9f67-939478278f9c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":123,\"end\":124}},{\"type\":\"text\",\"text\":\"Thus-Gone\",\"attrs\":{\"start\":124,\"end\":133},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"ae9449d8-e717-4a08-980c-388b5fbbdb93\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":133,\"end\":134}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha\",\"attrs\":{\"start\":134,\"end\":164},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"496408c1-e2d7-4787-acaf-cf6b194d9722\",\"uuid\":\"4e923acd-7cc6-481f-98b8-498df10acaf3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in various ways to those faithful sons and daughters of good family who hold this discourse, recite it, explain it, teach it correctly and in detail to others, copy it, commission it to be copied, write it in a book, and venerate it with flowers, incense, garlands, ointments, parasols, and victory banners. I will proclaim it so that they will even hear that buddha’s name in their dreams.\",\"attrs\":{\"start\":164,\"end\":555}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"bcfeef30-6416-40b8-ab55-5ffdb5f31569\",\"sort\":672,\"type\":\"translation\",\"label\":\"1.34\",\"alignments\":{\"toh504\":{\"folioUuid\":\"f24fcd39-a0bb-4e50-9dcc-8457dcc3b40b\",\"toh\":\"toh504\",\"tibetan\":\"ཚོན་སྣ་ལྔ་པའི་\\nགོས་རྣམས་ཀྱིས་དཀྲིས་ཏེ་ཕྱོགས་གཙང་མར་བཞག་ན། གང་ན་མདོ་སྡེ་འདི་གནས་པ་དེར་རྒྱལ་པོ་ཆེན་པོ་བཞི་འཁོར་དང་བཅས་པ་དང་། ལྷ་བྱེ་བ་ཁྲག་ཁྲིག་བརྒྱ་སྟོང་གཞན་ཡང་མཆི་བར་འགྱུར་རོ། །གང་དག་བཅོམ་ལྡན་འདས་དེ་བཞིན་གཤེགས་པ་སྨན་གྱི་བླ་བཻ་ཌཱུརྱའི་འོད་\\nདེའི་མཚན་དང་། སྔོན་གྱི་སྨོན་ལམ་གྱི་ཁྱད་པར་རྒྱས་པའི་མདོ་འདི་འཛིན་པ་དེ་དག་དུས་མ་ལགས་པར་འགུམ་པར་མི་འགྱུར། སུས་ཀྱང་མདངས་འཕྲོག་པར་མི་ནུས་ཏེ། ཕྲོགས་ན་ཡང་སླར་འཕྲོག་པར་འགྱུར་རོ། །\",\"folioNumber\":279,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":500,\"uuid\":\"bcfeef30-6416-40b8-ab55-5ffdb5f31569\"},\"content\":[{\"type\":\"text\",\"text\":\"“They will wrap this discourse with cloths of the five different colors and place it in a clean area. The \",\"attrs\":{\"start\":0,\"end\":106}},{\"type\":\"text\",\"text\":\"Four Great Kings\",\"attrs\":{\"start\":106,\"end\":122},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"6d3981fe-2fad-444e-8a5a-b21926433e03\",\"uuid\":\"90fbd7ae-7ee7-4f9f-855e-c7bbe549e40d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" with their retinues and billions of deities will gather wherever this discourse is located. Those who retain the name of the \",\"attrs\":{\"start\":122,\"end\":248}},{\"type\":\"text\",\"text\":\"blessed\",\"attrs\":{\"start\":248,\"end\":255},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"2494c546-9d2d-46c6-a401-aac92b644da0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":255,\"end\":256}},{\"type\":\"text\",\"text\":\"Thus-Gone\",\"attrs\":{\"start\":256,\"end\":265},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"2fdf3fef-c21b-4c31-a821-204cbc106902\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":265,\"end\":266}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha\",\"attrs\":{\"start\":266,\"end\":296},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"496408c1-e2d7-4787-acaf-cf6b194d9722\",\"uuid\":\"1417f4f4-0526-4959-a877-35e9983d14f8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and this discourse on the detailed account of his previous aspirations will not suffer \",\"attrs\":{\"start\":296,\"end\":384}},{\"type\":\"text\",\"text\":\"untimely death\",\"attrs\":{\"start\":384,\"end\":398},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ab2e041a-4033-4bfa-8d05-9b343f2ac529\",\"uuid\":\"1d2be348-c101-4cc3-bb14-0e9b466c95d2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". No one will be able to steal their \",\"attrs\":{\"start\":398,\"end\":435}},{\"type\":\"text\",\"text\":\"vital energy\",\"attrs\":{\"start\":435,\"end\":447},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"eacc31bd-07db-41db-92db-0e8df3e6355d\",\"uuid\":\"b006e190-5ffc-40b7-b035-c46bbb5cdc70\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and if it has been stolen, they will take it back.”\",\"attrs\":{\"start\":447,\"end\":500}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"6777fb3b-7111-4440-9727-3657b65e26e9\",\"sort\":686,\"type\":\"translation\",\"label\":\"1.35\",\"alignments\":{\"toh504\":{\"folioUuid\":\"f24fcd39-a0bb-4e50-9dcc-8457dcc3b40b\",\"toh\":\"toh504\",\"tibetan\":\"བཅོམ་ལྡན་འདས་ཀྱིས་བཀའ་སྩལ་པ། འཇམ་དཔལ་\\nདེ་དེ་བཞིན་ཏེ། ཇི་སྐད་སྨྲས་པ་བཞིན་ནོ། །འཇམ་དཔལ་དད་པའི་རིགས་ཀྱི་བུའམ། རིགས་ཀྱི་བུ་མོ་གང་དག་དེ་བཞིན་གཤེགས་པ་དེ་ལ་མཆོད་པ་བྱེད་པ་དེ་དག་གིས་དེ་བཞིན་གཤེགས་པ་དེའི་སྐུ་གཟུགས་བྱ། ཉིན་ཞག་བདུན་དུ་འཕགས་པའི་ཡན་ལག་བརྒྱད་དང་ལྡན་པའི་[F.279.b]བསྙེན་གནས་ལ་ཉེ་བར་གནས་པར་བྱ། ཁ་ཟས་གཙང་མ་བཟའ་ཞིང་ལུས་ལེགས་པར་བཀྲུས་ཏེ། གོས་བཟང་པོ་དྲི་མ་མེད་པ་བགོ་ཞིང་ཕྱོགས་གཙང་མར་མེ་ཏོག་སྣ་ཚོགས་སིལ་མ་བཀྲམ་པ། སྤོས་སྣ་ཚོགས་ཀྱིས་བདུགས་པ། རས་དང་། གདུགས་དང་། རྒྱལ་མཚན་\\nསྣ་ཚོགས་ཀྱིས་ལེགས་པར་བརྒྱན་པའི་ས་ཕྱོགས་སུ་དྲི་མ་མེད་པའི་སེམས་དང་། རྙོག་པ་མེད་པའི་སེམས་དང་། གནོད་སེམས་མེད་པའི་སེམས་དང་། བྱམས་པའི་སེམས་དང་། བཏང་སྙོམས་ཀྱི་སེམས་དང་། མཉམ་པའི་སེམས་སུ་བྱ། རོལ་མོའི་སྒྲ་དང་། སིལ་\\nསྙན་དང་། གླུ་དབྱངས་བླང་ཞིང་དེ་བཞིན་གཤེགས་པའི་སྐུ་གཟུགས་དེ་ལ་བསྐོར་བ་བྱས་ཏེ། \",\"folioNumber\":279,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":879,\"uuid\":\"6777fb3b-7111-4440-9727-3657b65e26e9\"},\"content\":[{\"type\":\"text\",\"text\":\"The \",\"attrs\":{\"start\":0,\"end\":4}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":4,\"end\":15},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"0bff7b03-86f1-4b43-be27-38618857dc74\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" replied, “It is so, \",\"attrs\":{\"start\":15,\"end\":36}},{\"type\":\"text\",\"text\":\"Mañjuśrī\",\"attrs\":{\"start\":36,\"end\":44},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a9d821a9-3cc6-4f11-94b6-c36ad0b6a6cb\",\"uuid\":\"445c4725-3aca-4090-95cc-98a19eeea730\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". What you say is true. \",\"attrs\":{\"start\":44,\"end\":68}},{\"type\":\"text\",\"text\":\"Mañjuśrī\",\"attrs\":{\"start\":68,\"end\":76},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a9d821a9-3cc6-4f11-94b6-c36ad0b6a6cb\",\"uuid\":\"e4db488a-a8a4-48ca-9597-5ac1df5cbc4b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", a faithful son or daughter of good family who makes offerings to that \",\"attrs\":{\"start\":76,\"end\":148}},{\"type\":\"text\",\"text\":\"thus-gone one\",\"attrs\":{\"start\":148,\"end\":161},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"39fb8eb0-d986-4c80-b482-14fdffc66d2b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" should make a \",\"attrs\":{\"start\":161,\"end\":176}},{\"type\":\"text\",\"text\":\"statue\",\"attrs\":{\"start\":176,\"end\":182},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"beb14c8c-22c9-4cbb-b14c-392f2edf214b\",\"uuid\":\"9b6ec141-0426-4685-8b3d-9592531917de\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of that \",\"attrs\":{\"start\":182,\"end\":191}},{\"type\":\"text\",\"text\":\"thus-gone one\",\"attrs\":{\"start\":191,\"end\":204},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"9fbc2cc5-d425-41a6-9dd5-9c1ec33100cd\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and observe the fast associated with the noble \",\"attrs\":{\"start\":204,\"end\":252}},{\"type\":\"text\",\"text\":\"eightfold precepts\",\"attrs\":{\"start\":252,\"end\":270},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5e2c147b-8fd1-47ec-85fd-32a254a33661\",\"uuid\":\"c23eb785-817d-494a-8be5-1e9be199557f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" for seven days and seven nights. They should eat pure food and thoroughly wash their body. They should wear fine, clean clothes. Then, in a clean area, they should scatter the petals of various flowers and perfume the area with various fragrances. They should then decorate the place with various cloths, parasols, and banners. There, they should then cultivate a stainless mind, an untainted mind, a mind free from ill intent, a \",\"attrs\":{\"start\":270,\"end\":701}},{\"type\":\"text\",\"text\":\"benevolent\",\"attrs\":{\"start\":701,\"end\":711},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"3ffc011e-faa9-469d-86fa-ce559364f6ca\",\"uuid\":\"dbb9e65e-6ad1-4f65-8391-8ba43e731e56\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" mind, an impartial mind, and an equanimous mind. They should then play music, play instruments, and sing songs as they circumambulate the \",\"attrs\":{\"start\":711,\"end\":850}},{\"type\":\"text\",\"text\":\"statue\",\"attrs\":{\"start\":850,\"end\":856},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"beb14c8c-22c9-4cbb-b14c-392f2edf214b\",\"uuid\":\"e029465a-e5b2-4f6b-b6f2-1eadf3b4b811\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of that \",\"attrs\":{\"start\":856,\"end\":865}},{\"type\":\"text\",\"text\":\"thus-gone one\",\"attrs\":{\"start\":865,\"end\":878},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"e85267dd-04ef-44d0-8cc6-fafec796b74a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":878,\"end\":879}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"a1845288-37a9-4514-b661-7660b6b8882b\",\"sort\":710,\"type\":\"translation\",\"label\":\"1.36\",\"alignments\":{\"toh504\":{\"folioUuid\":\"b84fe020-1760-4d82-aec1-caa728c1a001\",\"toh\":\"toh504\",\"tibetan\":\"དེའི་སྔོན་གྱི་སྨོན་ལམ་ཡང་ཡིད་ལ་བྱ་ཞིང་མདོ་འདི་ཡང་བསྟན་ན་གང་བསམས་པ་དང་། གང་སྨོན་པའི་བསམ་པ་དེ་ཐམས་ཅད་ཡོངས་སུ་རྫོགས་པར་འགྱུར་ཏེ། གལ་ཏེ་ཚེ་རིང་\\nབར་སྨོན་ན་ནི་ཚེ་རིང་པོར་འགྱུར་རོ། །གལ་ཏེ་ལོངས་སྤྱོད་དང་ལྡན་པར་སྨོན་ན་ནི་ལོངས་སྤྱོད་འབྱོར་པར་འགྱུར་རོ། །གལ་ཏེ་དབང་ཕྱུག་དང་ལྡན་པར་སྨོན་ན་ནི་ཚེགས་ཆུང་དུས་རྙེད་པར་འགྱུར་རོ། །གལ་ཏེ་བུ་འདོད་ན་ན་ནི་བུ་རྙིད་པར་འགྱུར་རོ། །\",\"folioNumber\":279,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":361,\"uuid\":\"a1845288-37a9-4514-b661-7660b6b8882b\"},\"content\":[{\"type\":\"text\",\"text\":\"“If they contemplate his previous aspirations and teach this discourse, all their wishes and aspirations will be fulfilled. If they aspire to a long life, they will have a long life. If they pray for \",\"attrs\":{\"start\":0,\"end\":200}},{\"type\":\"text\",\"text\":\"wealth\",\"attrs\":{\"start\":200,\"end\":206},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7592fd85-fafc-42db-a077-641db438c9e7\",\"uuid\":\"ca1cf355-31b7-4f0f-ba74-f68ffb839151\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", they will have \",\"attrs\":{\"start\":206,\"end\":223}},{\"type\":\"text\",\"text\":\"wealth\",\"attrs\":{\"start\":223,\"end\":229},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7592fd85-fafc-42db-a077-641db438c9e7\",\"uuid\":\"c8b7e71a-c5af-47b7-9995-2b7d28108460\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". If they pray to become a powerful ruler, they will achieve that with little trouble. If they wish for a son, they will have a son.\",\"attrs\":{\"start\":229,\"end\":361}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"5c2a7d52-2a07-4ecc-83bd-b2b8cf13dd7a\",\"sort\":716,\"type\":\"translation\",\"label\":\"1.37\",\"alignments\":{\"toh504\":{\"folioUuid\":\"b84fe020-1760-4d82-aec1-caa728c1a001\",\"toh\":\"toh504\",\"tibetan\":\"གང་དག་སྡིག་པ་ཅན་གྱི་རྨི་\\nལམ་རྨིས་སམ། གང་དུ་བྱ་ཁྭ་ཏ་དང་། ལྟས་ངན་པ་མཐོང་ངམ། གནས་གང་དུ་བཀྲ་མི་ཤིས་པ་བརྒྱ་དག་གནས་པར་གྱུར་པ་ལ། གང་དག་བཅོམ་ལྡན་འདས་དེ་བཞིན་གཤེགས་པ་སྨན་གྱི་བླ་བཻ་ཌཱུརྱའི་འོད་དེ་ལ་མཆོད་པ་རྣམ་པ་སྣ་ཚོགས་ཀྱིས་བཀུར་སྟི་བྱེད་ན་རྨི་ལམ་ངན་\\nཔ་དང་། ལྟས་ངན་པ་དང་། བཀྲ་མི་ཤིས་པའི་དངོས་པོ་ཐམས་ཅད་མཐོང་བར་མི་འགྱུར་རོ། །\",\"folioNumber\":279,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":340,\"uuid\":\"5c2a7d52-2a07-4ecc-83bd-b2b8cf13dd7a\"},\"content\":[{\"type\":\"text\",\"text\":\"“When someone has a bad dream, sees a crow or a bad omen somewhere, or dwells in a location where the \",\"attrs\":{\"start\":0,\"end\":102}},{\"type\":\"text\",\"text\":\"one hundred inauspicious things\",\"attrs\":{\"start\":102,\"end\":133},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b6a88625-3190-47ab-ac85-1e7efddabef3\",\"uuid\":\"f623efd8-3fcc-484c-903c-4b683f5ab07c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" are present, if that person venerates the \",\"attrs\":{\"start\":133,\"end\":176}},{\"type\":\"text\",\"text\":\"blessed\",\"attrs\":{\"start\":176,\"end\":183},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"ac17c8f0-eea5-45cb-b114-fb799001a68d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":183,\"end\":184}},{\"type\":\"text\",\"text\":\"Thus-Gone\",\"attrs\":{\"start\":184,\"end\":193},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"3679450b-0df0-4521-84d5-808d21ee2dd5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":193,\"end\":194}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha\",\"attrs\":{\"start\":194,\"end\":224},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"496408c1-e2d7-4787-acaf-cf6b194d9722\",\"uuid\":\"c6a9aa6c-e518-42c2-8868-9d6ef6f677b1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" with the various types of offerings, then the bad dreams, bad omens, and inauspicious things will no longer appear.\",\"attrs\":{\"start\":224,\"end\":340}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"7f535eaf-9af0-43dd-a4db-cc06495ec0f9\",\"sort\":726,\"type\":\"translation\",\"label\":\"1.38\",\"alignments\":{\"toh504\":{\"folioUuid\":\"b84fe020-1760-4d82-aec1-caa728c1a001\",\"toh\":\"toh504\",\"tibetan\":\"གང་དག་མེས་འཇིགས་པ་དང་། ཆུས་འཇིགས་པ་དང་། མཚོན་གྱིས་འཇིགས་པ་དང་། དུག་གིས་འཇིགས་པ་དང་། གཡང་སས་འཇིགས་པ་དང་། གླང་པོ་ཆེ་གཏུམ་པོས་\\nའཇིགས་པ་དང་། སེང་གེས་འཇིགས་པ་དང་། སྟག་གིས་འཇིགས་པ་དང་། དོམ་དང་། དྲེད་དང་། སྦྲུལ་གདུག་པས་འཇིགས་པ་དང་། སྦྲུལ་དང་། སྡིག་པ་དང་། རྐང་ལག་བརྒྱ་པས་འཇིགས་པ་དེ་དག་གིས་དེ་བཞིན་གཤེགས་པ་དེ་ལ་མཆོད་པ་བྱས་ན་འཇིགས་པ་[F.280.a]ཐམས་ཅད་ལས་ཡོངས་སུ་ཐར་བར་འགྱུར་རོ། །གང་དག་ཕ་རོལ་གྱི་དམག་ཚོགས་ཀྱིས་འཇིགས་པ་དང་། རྐུན་པོས་འཇིགས་པ་དང་། ཆོམ་པོས་འཇིགས་པ་དེ་དག་གིས་ཀྱང་དེ་བཞིན་གཤེགས་པ་དེ་ལ་མཆོད་པ་བྱའོ། །\",\"folioNumber\":279,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":530,\"uuid\":\"7f535eaf-9af0-43dd-a4db-cc06495ec0f9\"},\"content\":[{\"type\":\"text\",\"text\":\"“If those who face dangers from fire, dangers from water, dangers from weapons, dangers from poison, dangers from steep cliffs, dangers from raging elephants, dangers from lions, dangers from tigers, dangers from bears, \",\"attrs\":{\"start\":0,\"end\":220}},{\"type\":\"text\",\"text\":\"hyenas\",\"attrs\":{\"start\":220,\"end\":226},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8c676742-3af6-4860-98dd-7cfb3f89f721\",\"uuid\":\"96a08724-6344-40a2-b607-52bee7163deb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and poisonous snakes, and dangers from snakes, \",\"attrs\":{\"start\":226,\"end\":275}},{\"type\":\"text\",\"text\":\"scorpions\",\"attrs\":{\"start\":275,\"end\":284},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"db7650ff-bc0e-471e-be3c-1eecbf646266\",\"uuid\":\"5ae18b9c-1774-419b-9a9b-84ef9a48b736\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and \",\"attrs\":{\"start\":284,\"end\":290}},{\"type\":\"text\",\"text\":\"centipedes\",\"attrs\":{\"start\":290,\"end\":300},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"148f89d5-5342-4a4d-ab54-14b440d585be\",\"uuid\":\"9a4857df-d855-4fad-bd4f-561cf51a4087\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", have made offerings\",\"attrs\":{\"start\":300,\"end\":321},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"32a15946-a6a2-408a-9cbf-96baca4328a4\",\"label\":\"20\",\"uuid\":\"5bfe39d6-5703-4ceb-91a7-98c41b1f27b0\",\"start\":321,\"end\":321,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" to that \",\"attrs\":{\"start\":321,\"end\":330}},{\"type\":\"text\",\"text\":\"thus-gone one\",\"attrs\":{\"start\":330,\"end\":343},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"c9ed057d-3f04-40e7-8fce-77da0ab37513\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", they will be freed from all manner of dangers. Those who face dangers from enemy armies, dangers from thieves, and dangers from bandits should also make offerings to that \",\"attrs\":{\"start\":343,\"end\":516}},{\"type\":\"text\",\"text\":\"thus-gone one\",\"attrs\":{\"start\":516,\"end\":529},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"31a4b2ea-9084-4d51-bb33-67dd660f03d2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":529,\"end\":530}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"8d07f68b-9351-49ca-8936-72f30cb06097\",\"sort\":742,\"type\":\"translation\",\"label\":\"1.39\",\"alignments\":{\"toh504\":{\"folioUuid\":\"89846d90-7e3b-46b0-8cd9-d2597a496ee4\",\"toh\":\"toh504\",\"tibetan\":\"འཇམ་དཔལ་\\nགཞན་ཡང་དད་པའི་རིགས་ཀྱི་བུའམ། རིགས་ཀྱི་བུ་མོ་གང་དག་ཇི་སྲིད་འཚོའི་བར་དུ་དཀོན་མཆོག་གསུམ་ལ་སྐྱབས་སུ་འཛིན་ཅིང་། ལྷ་གཞན་མི་འཛིན་པ་དང་། གང་དག་ཡང་བསླབ་པའི་གཞི་ལྔ་པོ་དག་འཛིན་པ་དང་། གང་དག་བསླབ་པའི་གཞི་བཅུ་པོ་དག་འཛིན་\\nཔ་དང་། གང་དག་བྱང་ཆུབ་སེམས་དཔའི་སྡོམ་པ་བསླབ་པའི་གཞི་བཞི་བརྒྱ་པོ་དག་འཛིན་པ་དང་། ཁྱིམ་གྱི་གནས་ནས་བྱུང་བའི་དགེ་སློང་གང་དག་བསླབ་པའི་གཞི་ཉིས་བརྒྱ་ལྔ་བཅུ་པོ་དག་འཛིན་པ་དང་། དགེ་སློང་མ་གང་དག་བསླབ་པའི་གཞི་ལྔ་བརྒྱ་པོ་དག་འཛིན་པ་དང་། \\nགང་དག་ཇི་ལྟར་ཡོངས་སུ་བཟུང་བའི་བསླབ་པའི་སྡོམ་པ་དེ་དག་གི་ནང་ནས་བསླབ་པའི་གཞི་གང་ཡང་རུང་བ་ཞིག་ལས་ཉམས་པར་གྱུར་ཏེ། ངན་འགྲོ་ངན་སོང་གིས་འཇིགས་སྐྲག་པ་གང་དག་བཅོམ་ལྡན་འདས་དེ་བཞིན་གཤེགས་པ་སྨན་གྱི་བླ་བཻ་ཌཱུརྱའི་འོད་དེ་ལ་མཆོད་པ་རྣམ་པ་སྣ་\\nཚོགས་བྱེད་ན། དེ་དག་ལ་ངན་སོང་གསུམ་གྱི་སྡུག་བསྔལ་མེད་པར་ཤེས་པར་བྱའོ། །\",\"folioNumber\":280,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":732,\"uuid\":\"8d07f68b-9351-49ca-8936-72f30cb06097\"},\"content\":[{\"type\":\"text\",\"text\":\"“Moreover, \",\"attrs\":{\"start\":0,\"end\":11}},{\"type\":\"text\",\"text\":\"Mañjuśrī\",\"attrs\":{\"start\":11,\"end\":19},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a9d821a9-3cc6-4f11-94b6-c36ad0b6a6cb\",\"uuid\":\"874849c6-6cdd-4c46-be7f-9de7d9b1a36a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", if any faithful sons or daughters of good family who maintain taking refuge in the Three Jewels for as long as they live and have no other tutelary deity, maintain the \",\"attrs\":{\"start\":19,\"end\":189}},{\"type\":\"text\",\"text\":\"five precepts\",\"attrs\":{\"start\":189,\"end\":202},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"60722a01-b9ed-4f9a-81b0-1c8aaea06b3f\",\"uuid\":\"000687b0-387d-45a5-a2a9-fbc0c4d27473\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", maintain the \",\"attrs\":{\"start\":202,\"end\":217}},{\"type\":\"text\",\"text\":\"ten precepts\",\"attrs\":{\"start\":217,\"end\":229},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"de5e647c-c6c1-4234-a117-24bf05b39370\",\"uuid\":\"6e0c4c15-d3f5-4360-895a-2061ef4ddd0f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", maintain the four hundred vows and \",\"attrs\":{\"start\":229,\"end\":266}},{\"type\":\"text\",\"text\":\"precepts\",\"attrs\":{\"start\":266,\"end\":274},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e1894c5d-a0ba-4881-b9aa-06595e73a72a\",\"uuid\":\"1cd75c51-d35b-4710-bb4e-d2b2af09b563\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of a bodhisattva, are monks who have left home and maintain the two hundred and fifty \",\"attrs\":{\"start\":274,\"end\":361}},{\"type\":\"text\",\"text\":\"precepts\",\"attrs\":{\"start\":361,\"end\":369},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e1894c5d-a0ba-4881-b9aa-06595e73a72a\",\"uuid\":\"4a9b06c5-77cf-4301-b3de-4f05b3517052\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", or are nuns who maintain the five hundred \",\"attrs\":{\"start\":369,\"end\":413}},{\"type\":\"text\",\"text\":\"precepts\",\"attrs\":{\"start\":413,\"end\":421},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e1894c5d-a0ba-4881-b9aa-06595e73a72a\",\"uuid\":\"879c15e8-a161-42c9-a71e-5fc8aa75ffe8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", should break any one of the \",\"attrs\":{\"start\":421,\"end\":451}},{\"type\":\"text\",\"text\":\"precepts\",\"attrs\":{\"start\":451,\"end\":459},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e1894c5d-a0ba-4881-b9aa-06595e73a72a\",\"uuid\":\"da686761-2fd9-4620-a4b1-4c791cd3cf74\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" among the vows and \",\"attrs\":{\"start\":459,\"end\":479}},{\"type\":\"text\",\"text\":\"precepts\",\"attrs\":{\"start\":479,\"end\":487},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e1894c5d-a0ba-4881-b9aa-06595e73a72a\",\"uuid\":\"7f8a52e6-78f3-42d7-afba-0001e6cb5ee4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" they have taken and fear they are in danger of falling into the lower realms, if they then make offerings to the \",\"attrs\":{\"start\":487,\"end\":601}},{\"type\":\"text\",\"text\":\"blessed\",\"attrs\":{\"start\":601,\"end\":608},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"f10c0c55-c9c3-4ec5-bc4f-9d86140fe62b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":608,\"end\":609}},{\"type\":\"text\",\"text\":\"Thus-Gone One\",\"attrs\":{\"start\":609,\"end\":622},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"b6cf94eb-fd83-491d-9ce9-a9fb839d0f1c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":622,\"end\":623}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha\",\"attrs\":{\"start\":623,\"end\":653},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"496408c1-e2d7-4787-acaf-cf6b194d9722\",\"uuid\":\"5dae2e88-d620-4d9d-8ff1-ff022f2a1c68\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", they should know that they will not suffer rebirth in the three lower realms.\",\"attrs\":{\"start\":653,\"end\":732},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"7da88841-dbf6-4a6d-aa91-d5688fb9f912\",\"label\":\"21\",\"uuid\":\"da46b647-1503-412f-afd6-cd7698a2f3d0\",\"start\":732,\"end\":732,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"cfd36766-60c9-4f16-8f33-bdae1c80461f\",\"sort\":767,\"type\":\"translation\",\"label\":\"1.40\",\"alignments\":{\"toh504\":{\"folioUuid\":\"89846d90-7e3b-46b0-8cd9-d2597a496ee4\",\"toh\":\"toh504\",\"tibetan\":\"བུད་མེད་གང་ལ་ལ་བུ་བཙའ་བའི་དུས་ན་སྡུག་བསྔལ་མ་རུངས་པ་དྲག་པོ་མི་བཟད་པ་མྱོང་བ་དེས། བཅོམ་ལྡན་འདས་དེ་བཞིན་གཤེགས་པ་སྨན་གྱི་བླ་བཻ་ཌཱུརྱའི་འོད་དེ་ལ་མཆོད་ན། དེ་མྱུར་དུ་\\nཡོངས་སུ་ཐར་བར་འགྱུར། བུ་ཡང་ཡན་ལག་ཡོངས་སུ་ཚང་བར་བཙའ་ཞིང་གཟུགས་བཟང་བ་དང་། མཛེས་པ་དང་། བལྟ་ན་སྡུག་པ་དང་། དབང་པོ་རྣོ་བ་དང་། བློ་དང་ལྡན་པ་དང་། ནད་མེད་ཅིང་གནོད་པ་ཉུང་བར་འགྱུར་རོ། །དེ་ལ་མི་མ་ཡིན་པས་མདངས་འཕྲོག་པར་\\nམི་ནུས་སོ། །\",\"folioNumber\":280,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":464,\"uuid\":\"cfd36766-60c9-4f16-8f33-bdae1c80461f\"},\"content\":[{\"type\":\"text\",\"text\":\"“If any woman \",\"attrs\":{\"start\":0,\"end\":14}},{\"type\":\"text\",\"text\":\"giving birth\",\"attrs\":{\"start\":14,\"end\":26},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c974a79c-3c91-40fa-8a22-695c74a98754\",\"uuid\":\"81d956ab-ffc5-443f-bf00-6f3b49c721e8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" who experiences intense, fierce, and unbearable suffering makes offerings to the \",\"attrs\":{\"start\":26,\"end\":108}},{\"type\":\"text\",\"text\":\"blessed\",\"attrs\":{\"start\":108,\"end\":115},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"9e3568a0-ff5f-4210-a7b4-a0065d2312c2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":115,\"end\":116}},{\"type\":\"text\",\"text\":\"Thus-Gone\",\"attrs\":{\"start\":116,\"end\":125},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"b2d8cbce-3d50-4774-be2d-863ebd24be85\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":125,\"end\":126}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha\",\"attrs\":{\"start\":126,\"end\":156},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"496408c1-e2d7-4787-acaf-cf6b194d9722\",\"uuid\":\"cbf95721-7bae-42f7-b071-1d5f973eec94\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", she will immediately be liberated from that suffering. The child will be born with all its limbs intact, and it will have a good physique, be handsome and good looking, have sharp faculties, be intelligent and healthy, and have few difficulties. Nonhuman beings will not be able to steal its \",\"attrs\":{\"start\":156,\"end\":450}},{\"type\":\"text\",\"text\":\"vital energy\",\"attrs\":{\"start\":450,\"end\":462},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"eacc31bd-07db-41db-92db-0e8df3e6355d\",\"uuid\":\"9a8bd845-04f9-4acf-8933-51a92e0d639e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".”\",\"attrs\":{\"start\":462,\"end\":464}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"c9a28608-9463-49f4-a039-c78e23f36377\",\"sort\":779,\"type\":\"translation\",\"label\":\"1.41\",\"alignments\":{\"toh504\":{\"folioUuid\":\"89846d90-7e3b-46b0-8cd9-d2597a496ee4\",\"toh\":\"toh504\",\"tibetan\":\"དེ་ནས་བཅོམ་ལྡན་འདས་ཀྱིས་ཚེ་དང་ལྡན་པ་ཀུན་དགའ་བོ་ལ་བཀའ་སྩལ་པ། ཀུན་དགའ་བོ་གང་གི་ཕྱིར་ང་བཅོམ་ལྡན་འདས་དེ་བཞིན་གཤེགས་པ་སྨན་གྱི་བླ་བཻ་ཌཱུརྱའི་འོད་དེའི་ཡོན་ཏན་བརྗོད་པར་ཁྱོད་དད་དམ་ཡིད་ཆེས་སམ། ཡང་ན་ཁྱོད་སངས་རྒྱས་ཀྱི་སྤྱོད་[F.280.b]ཡུལ་ཟབ་མོ་འདི་ལ་ཡིད་གཉིས་སམ། སོམ་ཉི་འམ། ཐེ་ཚོམ་ཟ་བ་མེད་དམ། \",\"folioNumber\":280,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":290,\"uuid\":\"c9a28608-9463-49f4-a039-c78e23f36377\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"bbf36fa0-9538-4f43-b5b4-c1a11fefa7dd\"},\"content\":[{\"type\":\"text\",\"text\":\"At that point the \",\"attrs\":{\"start\":0,\"end\":18}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":18,\"end\":29},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"1f4ed1cb-fcfd-4d7e-9c10-f9bc5ae066f9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" asked Venerable \",\"attrs\":{\"start\":29,\"end\":46}},{\"type\":\"text\",\"text\":\"Ānanda\",\"attrs\":{\"start\":46,\"end\":52},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b35041f2-96b8-4d55-b39a-9d0653dffcd6\",\"uuid\":\"535856d2-8ca8-446e-816f-ff1678f8352a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", “\",\"attrs\":{\"start\":52,\"end\":55}},{\"type\":\"text\",\"text\":\"Ānanda\",\"attrs\":{\"start\":55,\"end\":61},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b35041f2-96b8-4d55-b39a-9d0653dffcd6\",\"uuid\":\"fb1344dc-9f6d-474f-80bb-44fa57866140\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", do you trust and believe in the good qualities of the \",\"attrs\":{\"start\":61,\"end\":117}},{\"type\":\"text\",\"text\":\"blessed\",\"attrs\":{\"start\":117,\"end\":124},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"6ed23ca6-d734-4184-906a-51b72ba38a4e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":124,\"end\":125}},{\"type\":\"text\",\"text\":\"Thus-Gone\",\"attrs\":{\"start\":125,\"end\":134},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"7d0f0d3d-3c43-4b73-87f4-f121b55a3bf5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":134,\"end\":135}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha­rāja\",\"attrs\":{\"start\":135,\"end\":170},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"42700cf7-b80f-42be-89b1-6b4b26f2b60a\",\"uuid\":\"509f0d9c-39f8-4d46-a18c-f4199b154d5e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" that I have described? Are you uncertain, or do you have any reservations or doubts about this profound \",\"attrs\":{\"start\":170,\"end\":275}},{\"type\":\"text\",\"text\":\"buddha domain\",\"attrs\":{\"start\":275,\"end\":288},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"29f993af-be3f-4744-bb27-4dc0a9e891cc\",\"uuid\":\"30fcb7e2-511b-40d0-a395-5770e9266688\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"?”\",\"attrs\":{\"start\":288,\"end\":290}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"9da693e5-9e9b-415f-ad90-d4289a5b32b5\",\"sort\":796,\"type\":\"translation\",\"label\":\"1.42\",\"alignments\":{\"toh504\":{\"folioUuid\":\"9f34710f-61b2-41e7-ac90-588579848b4a\",\"toh\":\"toh504\",\"tibetan\":\"དེ་སྐད་ཅེས་བཀའ་སྩལ་པ་དང་། དེ་ནས་བཅོམ་ལྡན་འདས་ལ་ཚེ་དང་ལྡན་པ་ཀུན་དགའ་བོས་འདི་སྐད་ཅེས་གསོལ་ཏོ། །བཙུན་པ་བཅོམ་ལྡན་འདས་བདག་དེ་བཞིན་གཤེགས་པས་\\nགསུངས་པའི་ཆོས་རྣམས་ལ་ཡིད་གཉིས་སམ། སོམ་ཉི་འམ། ཐེ་ཙོམ་འཚལ་བ་མ་མཆིས་སོ། །དེ་ཅིའི་སླད་དུ་ཞེ་ན། དེ་བཞིན་གཤེགས་པ་རྣམས་ལ་སྐུ་དང་། གསུང་དང་། ཐུགས་ཀྱི་ཀུན་ཏུ་སྤྱོད་པ་ཡོངས་སུ་མ་དག་པ་མི་མངའ་བའི་སླད་དུའོ། བཅོམ་ལྡན་འདས་\\nགདུགས་དང་དགུང་ཟླ་འདི་ལྟར་རྫུ་འཕྲུལ་ཆེ་ཞིང་། འདི་ལྟར་མཐུ་ཆེ་བ་འདི་གཉིས་ནི་དོགས་ལ་ལྟུང་ཡང་གདའ། རིའི་རྒྱལ་པོ་རི་རབ་ནི་གནས་ནས་འཕོ་ཡང་གདའི། སངས་རྒྱས་རྣམས་ཀྱི་བཀའ་ནི་གཞན་དུ་མི་འགྱུར་ལགས་སོ། །བཙུན་པ་བཅོམ་ལྡན་འདས་དེ་ལྟ་ལགས་\\nཀྱིས་ཀྱང་སེམས་ཅན་དད་པའི་དབང་པོ་དང་བྲལ་བ་དག་མཆིས་ཏེ། སངས་རྒྱས་རྣམས་ཀྱི་སངས་རྒྱས་ཀྱི་སྤྱོད་ཡུལ་འདི་ཐོས་ནས། དེ་དག་འདི་སྙམ་དུ་སེམས་པར་འགྱུར་ཏེ། དེ་བཞིན་གཤེགས་པ་དེའི་མཚན་འདི་དྲན་པ་ཙམ་གྱིས་ཇི་ལྟར་ཤིན་ཏུ་ཡོན་ཏན་དང་། ཕན་ཡོན་དུ་\\nའགྱུར་སྙམ་ནས་དེ་དག་མི་དད་ཅིང་ཡིད་མི་ཆེས་ཏེ། སྤོང་བས་ཡུན་རིང་པོར་གནོད་པ་དང་། མི་སྨན་པ་དང་། མི་བདེ་བ་དང་། ལོག་པར་ལྟུང་བར་འགྱུར་རོ། །\",\"folioNumber\":280,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":899,\"uuid\":\"9da693e5-9e9b-415f-ad90-d4289a5b32b5\"},\"content\":[{\"type\":\"text\",\"text\":\"“Respected \",\"attrs\":{\"start\":0,\"end\":11}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":11,\"end\":22},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"e6199f83-c18f-4251-907a-28944d0c2bc5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\",” Venerable \",\"attrs\":{\"start\":22,\"end\":35}},{\"type\":\"text\",\"text\":\"Ānanda\",\"attrs\":{\"start\":35,\"end\":41},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b35041f2-96b8-4d55-b39a-9d0653dffcd6\",\"uuid\":\"b03b4bbe-0384-4798-98d6-0cdb83ca430a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" replied, “I am not uncertain, nor do I have any reservations or doubts about the qualities that the \",\"attrs\":{\"start\":41,\"end\":142}},{\"type\":\"text\",\"text\":\"Thus-Gone One\",\"attrs\":{\"start\":142,\"end\":155},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"ffca4f75-652b-46bd-971d-ba24a21d3c62\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" has described, because the \",\"attrs\":{\"start\":155,\"end\":183}},{\"type\":\"text\",\"text\":\"thus-gone ones\",\"attrs\":{\"start\":183,\"end\":197},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"91672159-eb8d-4748-b1b7-b62baf709892\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" have no impure conduct of \",\"attrs\":{\"start\":197,\"end\":224}},{\"type\":\"text\",\"text\":\"body\",\"attrs\":{\"start\":224,\"end\":228},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"29c40432-a61e-422b-abdf-65eb303e5623\",\"uuid\":\"f849e1b2-f832-4d31-97a8-7179fb6f4cfc\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", speech, and mind. \",\"attrs\":{\"start\":228,\"end\":248}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":248,\"end\":259},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"58bcb6a7-a1b8-4474-b05c-319e1afcdcad\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", even such miraculous and powerful beings as the \",\"attrs\":{\"start\":259,\"end\":309}},{\"type\":\"text\",\"text\":\"sun\",\"attrs\":{\"start\":309,\"end\":312},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2a81074e-debf-4316-bb23-3177c8323be0\",\"uuid\":\"28f4b697-e225-4aa6-86a9-492f69216796\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and the \",\"attrs\":{\"start\":312,\"end\":321}},{\"type\":\"text\",\"text\":\"moon\",\"attrs\":{\"start\":321,\"end\":325},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a3efffd6-869a-4db9-82c5-eb27587847c2\",\"uuid\":\"dbea1c38-129c-4147-890a-7d5644e4f557\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" might fall to the earth, and even \",\"attrs\":{\"start\":325,\"end\":360}},{\"type\":\"text\",\"text\":\"Sumeru\",\"attrs\":{\"start\":360,\"end\":366},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4748cce8-fecc-4fe4-a21d-dc3701240e0a\",\"uuid\":\"d171b453-e56c-4cac-88b5-1c9307da71c1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the king of mountains, might move from its base, but the word of the buddhas is never incorrect. Yet still, respected \",\"attrs\":{\"start\":366,\"end\":486}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":486,\"end\":497},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"40e5eed9-7509-45bb-9ab6-3929731887a9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", there are beings who lack the capacity for faith, and when they hear about this \",\"attrs\":{\"start\":497,\"end\":579}},{\"type\":\"text\",\"text\":\"buddha domain\",\"attrs\":{\"start\":579,\"end\":592},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"29f993af-be3f-4744-bb27-4dc0a9e891cc\",\"uuid\":\"546fe5d7-ada2-4b20-bea1-51fa01cb2f46\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of the buddhas\",\"attrs\":{\"start\":592,\"end\":607},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"2cb6d8da-147e-4384-9913-9a92f6300dc8\",\"label\":\"22\",\"uuid\":\"80a5b8c3-3121-42cb-82bb-5734d6056561\",\"start\":607,\"end\":607,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" they will wonder, ‘How can such good qualities and benefits come about by merely recollecting the name of that \",\"attrs\":{\"start\":607,\"end\":719}},{\"type\":\"text\",\"text\":\"thus-gone one\",\"attrs\":{\"start\":719,\"end\":732},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"ddc25ed9-b03a-40e7-ba94-94359301fd7b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"?’ Because they have no faith, do not believe, and reject this, for a long time they will suffer injuries, lack medicines, be unhappy, and fall into the lower realms.”\",\"attrs\":{\"start\":732,\"end\":899}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"30ab4572-741d-4da5-941c-3480f97f731d\",\"sort\":824,\"type\":\"translation\",\"label\":\"1.43\",\"alignments\":{\"toh504\":{\"folioUuid\":\"9f34710f-61b2-41e7-ac90-588579848b4a\",\"toh\":\"toh504\",\"tibetan\":\"བཅོམ་ལྡན་འདས་ཀྱིས་བཀའ་སྩལ་པ། ཀུན་དགའ་བོ་དེ་བཞིན་གཤེགས་པ་དེའི་མཚན་སུའི་རྣ་ལམ་དུ་\\nགྲག་པར་གྱུར་པ་དེ་ངན་འགྲོ་ངན་སོང་དུ་འགྲོ་བར་འགྱུར་བ་ནི་གནས་མེད་དེ་གོ་སྐབས་མ་ཡིན་ནོ། །ཀུན་དགའ་བོ་སངས་རྒྱས་རྣམས་ཀྱི་སངས་རྒྱས་ཀྱི་སྤྱོད་ཡུལ་ནི་ཡིད་ཆེས་པར་དཀའ་བའོ། །ཀུན་དགའ་བོ་ཁྱོད་དད་ཅིང་ཡིད་ཆེས་པ་གང་ཡིན་པ་དེ་ནི་དེ་བཞིན་གཤེགས་པའི་མཐུ་\\nཡིན་པར་བལྟའོ། །བྱང་ཆུབ་སེམས་དཔའ་སེམས་དཔའ་ཆེན་པོ་སྐྱེ་བ་གཅིག་གིས་ཐོགས་པ་རྣམས་མ་གཏོགས་པར་འདི་ནི་ཉན་ཐོས་དང་། རང་སངས་རྒྱས་ཐམས་ཅད་ཀྱིས་མ་ཡིན་ནོ། །\",\"folioNumber\":280,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":459,\"uuid\":\"30ab4572-741d-4da5-941c-3480f97f731d\"},\"content\":[{\"type\":\"text\",\"text\":\"The \",\"attrs\":{\"start\":0,\"end\":4}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":4,\"end\":15},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"8e75a5e3-c895-40c9-80ca-4a735f6475ca\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" replied, “\",\"attrs\":{\"start\":15,\"end\":26}},{\"type\":\"text\",\"text\":\"Ānanda\",\"attrs\":{\"start\":26,\"end\":32},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b35041f2-96b8-4d55-b39a-9d0653dffcd6\",\"uuid\":\"10ad81ef-083d-4518-a567-4a8a5ff6c8cb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", it is untenable and impossible for someone who has had the name of that \",\"attrs\":{\"start\":32,\"end\":106}},{\"type\":\"text\",\"text\":\"thus-gone one\",\"attrs\":{\"start\":106,\"end\":119},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"c2244806-f6f5-458f-8346-17b16681ab15\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" resound in their ears to be reborn in the lower realms. \",\"attrs\":{\"start\":119,\"end\":176}},{\"type\":\"text\",\"text\":\"Ānanda\",\"attrs\":{\"start\":176,\"end\":182},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b35041f2-96b8-4d55-b39a-9d0653dffcd6\",\"uuid\":\"ffa627dc-4420-449d-8d09-9c6678e7a707\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the domain of the buddhas is difficult to believe. \",\"attrs\":{\"start\":182,\"end\":235}},{\"type\":\"text\",\"text\":\"Ānanda\",\"attrs\":{\"start\":235,\"end\":241},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b35041f2-96b8-4d55-b39a-9d0653dffcd6\",\"uuid\":\"6f45d9ed-a875-4659-a47f-dd514872bf14\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the faith and belief you have should be seen as the power of the \",\"attrs\":{\"start\":241,\"end\":308}},{\"type\":\"text\",\"text\":\"Thus-Gone One\",\"attrs\":{\"start\":308,\"end\":321},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"1e1660e6-346e-4f64-a6e3-4cf45ce8c958\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":321,\"end\":322},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"4456bc11-be25-43db-921a-dce52bae1b05\",\"label\":\"23\",\"uuid\":\"9bb7cb59-8dd8-4732-9c52-b17041369b72\",\"start\":322,\"end\":322,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" This is something possessed only by bodhisattva great beings who are one birth away from awakening‍—not by hearers and solitary buddhas.\",\"attrs\":{\"start\":322,\"end\":459},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"6c5bfd5c-7350-40c3-8ecc-de8568616b8b\",\"label\":\"24\",\"uuid\":\"e9da1c6d-b559-4116-afa5-44d933e641a9\",\"start\":459,\"end\":459,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"a342ff84-4adf-40f2-87df-2c0af5d8c5df\",\"sort\":841,\"type\":\"translation\",\"label\":\"1.44\",\"alignments\":{\"toh504\":{\"folioUuid\":\"9f34710f-61b2-41e7-ac90-588579848b4a\",\"toh\":\"toh504\",\"tibetan\":\"ཀུན་དགའ་བོ་མིར་འགྱུར་བ་རྙེད་པ་ནི་རྙེད་པར་དཀའོ། །དཀོན་མཆོག་གསུམ་ལ་[F.281.a]དད་ཅིང་གུས་པ་ཡང་རྙེད་པར་དཀའོ། །དེ་བཞིན་གཤེགས་པ་དེའི་མཚན་ཐོས་པ་ཡང་རྙེད་པར་ཤིན་ཏུ་དཀའོ། །ཀུན་དགའ་བོ་བཅོམ་ལྡན་འདས་དེ་བཞིན་གཤེགས་པ་སྨན་གྱི་བླ་བཻ་ཌཱུརྱའི་འོད་དེའི་བྱང་ཆུབ་སེམས་དཔའི་སྤྱོད་པ་ཡང་ཚད་མེད་དོ། །ཐབས་\\nམཁས་པ་ཡང་ཚད་མེད་དོ། །སྨོན་ལམ་གྱི་ཁྱད་པར་རྒྱས་པ་ཡང་ཚད་མེད་དོ། །ང་དེ་བཞིན་གཤེགས་པ་དེའི་བྱང་ཆུབ་སེམས་དཔའི་སྤྱོད་པ་བསྐལ་པའམ། བསྐལ་པ་ལས་ལྷག་པར་རྒྱ་ཆེར་ཡང་དག་པར་བཤད་པར་འདོད་ཀྱང་བསྐལ་པ་ཟད་པར་འགྱུར་གྱི། བཅོམ་\\nལྡན་འདས་དེ་བཞིན་གཤེགས་པ་སྨན་གྱི་བླ་བཻ་ཌཱུརྱའི་འོད་དེའི་སྔོན་གྱི་སྨོན་ལམ་གྱི་ཁྱད་པར་རྒྱས་པའི་མཐའ་རྟོགས་པར་ནི་མི་འགྱུར་རོ། །\",\"folioNumber\":280,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":651,\"uuid\":\"a342ff84-4adf-40f2-87df-2c0af5d8c5df\"},\"content\":[{\"type\":\"text\",\"text\":\"“\",\"attrs\":{\"start\":0,\"end\":1}},{\"type\":\"text\",\"text\":\"Ānanda\",\"attrs\":{\"start\":1,\"end\":7},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b35041f2-96b8-4d55-b39a-9d0653dffcd6\",\"uuid\":\"b5ded4c1-d3bb-402c-bc7d-9ab9577c35b7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", attaining a human life is rare, and faith and devotion toward the Three Jewels is rare, but hearing the name of that \",\"attrs\":{\"start\":7,\"end\":126}},{\"type\":\"text\",\"text\":\"thus-gone one\",\"attrs\":{\"start\":126,\"end\":139},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"e7180ca7-d772-407a-a0ae-2f6758d1da30\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is even more rare. \",\"attrs\":{\"start\":139,\"end\":159}},{\"type\":\"text\",\"text\":\"Ānanda\",\"attrs\":{\"start\":159,\"end\":165},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b35041f2-96b8-4d55-b39a-9d0653dffcd6\",\"uuid\":\"79d6ca91-2ae5-4f02-b0c2-fc96a5a91e53\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the bodhisattva conduct of the \",\"attrs\":{\"start\":165,\"end\":198}},{\"type\":\"text\",\"text\":\"blessed\",\"attrs\":{\"start\":198,\"end\":205},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"7f7c6b73-a183-4ee0-8758-731dcb2ac2df