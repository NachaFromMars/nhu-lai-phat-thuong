ྱི་ཞིང་གང་གཱའི་ཀླུང་བཅུའི་བྱེ་མ་སྙེད་འདས་པ་ན་འཇིག་རྟེན་གྱི་ཁམས་བཻ་ཌཱུརྱར་སྣང་བ་ཞེས་བྱ་བ་ཡོད་དེ། དེ་ན་དེ་བཞིན་གཤེགས་པ་དགྲ་\\nབཅོམ་པ་ཡང་དག་པར་རྫོགས་པའི་སངས་རྒྱས་རིག་པ་དང་ཞབས་སུ་ལྡན་པ། བདེ་བར་གཤེགས་པ། འཇིག་རྟེན་མཁྱེན་པ། སྐྱེས་བུ་འདུལ་བའི་ཁ་ལོ་སྒྱུར་བ། བླ་ན་མེད་པ། ལྷ་དང་མི་རྣམས་ཀྱི་སྟོན་པ། སངས་རྒྱས་བཅོམ་ལྡན་འདས་སྨན་གྱི་བླ་\\nབཻ་ཌཱུརྱའི་འོད་ཅེས་བྱ་བ་བཞུགས་སོ། །\",\"folioNumber\":274,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":422,\"uuid\":\"733f29ea-dadd-4f74-a812-84ccceef0de1\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"85db0b66-bb7d-4446-bdd3-7073cb47d492\"},\"content\":[{\"type\":\"text\",\"text\":\"“\",\"attrs\":{\"start\":0,\"end\":1}},{\"type\":\"text\",\"text\":\"Mañjuśrī\",\"attrs\":{\"start\":1,\"end\":9},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a9d821a9-3cc6-4f11-94b6-c36ad0b6a6cb\",\"uuid\":\"96613377-bde1-4864-afa5-ad5a18ad1f59\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", to the east of this buddhafield, past as many buddhafields as there are grain s of sand in ten \",\"attrs\":{\"start\":9,\"end\":106}},{\"type\":\"text\",\"text\":\"Gaṅgā\",\"attrs\":{\"start\":106,\"end\":111},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b4d79f26-3f86-4e27-9bc5-a20b80a606a4\",\"uuid\":\"22e3222c-c035-447d-ad94-4ae8b0b33db1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" rivers, lives the \",\"attrs\":{\"start\":111,\"end\":130}},{\"type\":\"text\",\"text\":\"blessed\",\"attrs\":{\"start\":130,\"end\":137},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"9781c050-9304-479d-bd29-47f81463e4d9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" Buddha \",\"attrs\":{\"start\":137,\"end\":145}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha\",\"attrs\":{\"start\":145,\"end\":175},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"496408c1-e2d7-4787-acaf-cf6b194d9722\",\"uuid\