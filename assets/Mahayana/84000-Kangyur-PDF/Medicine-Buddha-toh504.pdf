"text\":\" \",\"attrs\":{\"start\":580,\"end\":581}},{\"type\":\"text\",\"text\":\"Thus-Gone\",\"attrs\":{\"start\":581,\"end\":590},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"84ff4d20-4475-48cf-889f-4761890bfa94\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":590,\"end\":591}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha­rāja\",\"attrs\":{\"start\":591,\"end\":626},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"42700cf7-b80f-42be-89b1-6b4b26f2b60a\",\"uuid\":\"f3931576-272b-47ee-9eed-87aa2b4193f7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s previous aspirations.”\",\"attrs\":{\"start\":626,\"end\":651}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"326a8db9-aa13-404a-9965-f75cae85c07a\",\"sort\":867,\"type\":\"translation\",\"label\":\"1.45\",\"alignments\":{\"toh504\":{\"folioUuid\":\"b3d61d6f-ed5d-43d0-b1f3-74f4e781128a\",\"toh\":\"toh504\",\"tibetan\":\"ཡང་དེའི་ཚེ་འཁོར་དེའི་ནང་ནས་བྱང་ཆུབ་སེམས་དཔའ་སེམས་དཔའ་ཆེན་པོ་སྐྱབས་གྲོལ་ཞེས་བྱ་བ་སྟན་ལས་ལངས་ཏེ། བླ་གོས་ཕྲག་པ་\\nགཅིག་ཏུ་གཟར་ནས་པུས་མོ་གཡས་པའི་ལྷ་ངས་ལ་བཙུགས་ཏེ། བཅོམ་ལྡན་འདས་ག་ལ་བ་དེ་ལོགས་སུ་ཐལ་མོ་སྦྱར་བ་བཏུད་ནས། བཅོམ་ལྡན་འདས་ལ་འདི་སྐད་ཅེས་གསོལ་ཏོ། །བཙུན་པ་བཅོམ་ལྡན་འདས་སླད་མའི་ཚེ། སླད་མའི་དུས་ན། སེམས་\\nཅན་བྲོ་ནད་སྣ་ཚོགས་ཀྱིས་ཡོངས་སུ་གཟིར་ཏེ། ཡུན་རིང་པོའི་བྲོ་ནད་ཀྱིས་ལུས་ཀྱི་ཤ་བས་ཤིང་། བཀྲེས་པ་དང་སྐོམ་པས་གྲེ་བ་དང་། མཆུ་ནི་སྐམས། འགུམ་པ་ལ་ནི་མངོན་དུ་ཕྱོགས། མཛའ་བཤེས་དང་། ཉེ་དུ་དང་། སྣག་གི་གཉེན་མཚམས་\\nདུ་བ་རྣམས་ཀྱིས་ནི་བསྐོར། ཕྱོགས་རྣམས་ནི་མུན་པར་མཐོང་། གཤིན་རྗེའི་མི་རྣམས་ཀྱིས་ནི་དྲངས་ཏེ། \",\"folioNumber\":281,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":667,\"uuid\":\"326a8db9-aa13-404a-9965-f75cae85c07a\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"02fc10fd-701a-4ecf-96af-04c44b62339f\"},\"content\":[{\"type\":\"text\",\"text\":\"At that point, from among the gathering a bodhisattva great being named \",\"attrs\":{\"start\":0,\"end\":72}},{\"type\":\"text\",\"text\":\"Trāṇamukta\",\"attrs\":{\"start\":72,\"end\":82},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e395621c-5852-46eb-a457-65b28596d6db\",\"uuid\":\"26bb0c78-7822-4f0f-a434-b4272f62785f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" rose from his seat, adjusted his upper robe on one shoulder, knelt with his right knee on the ground, bowed to the \",\"attrs\":{\"start\":82,\"end\":198}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":198,\"end\":209},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"060fb3db-f903-47b6-b3a7-83fe38b23b2f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" with his palms together, and said to the \",\"attrs\":{\"start\":209,\"end\":251}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":251,\"end\":262},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"f76a0c7e-3baf-4bd0-ae7d-f2be1b073e35\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", “Respected \",\"attrs\":{\"start\":262,\"end\":275}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":275,\"end\":286},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"d6fc898e-01e2-4a64-9428-3fd104fd0c1d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", in the future there will be beings whose bodies are tormented by various types of \",\"attrs\":{\"start\":286,\"end\":370}},{\"type\":\"text\",\"text\":\"illnesses\",\"attrs\":{\"start\":370,\"end\":379},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"564d8ea9-dfb7-42ae-b9b9-c4b03389d607\",\"uuid\":\"a7af45ad-eeae-4226-9e8b-c1f20b8e4d83\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Their limbs will atrophy due to chronic \",\"attrs\":{\"start\":379,\"end\":421}},{\"type\":\"text\",\"text\":\"illness\",\"attrs\":{\"start\":421,\"end\":428},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"564d8ea9-dfb7-42ae-b9b9-c4b03389d607\",\"uuid\":\"f3b8d3d0-59aa-4c89-8c2a-5c4d6a265eaf\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and their lips and throats will be parched from hunger and thirst. They will be heading for their demise surrounded by weeping friends, \",\"attrs\":{\"start\":428,\"end\":566}},{\"type\":\"text\",\"text\":\"acquaintances\",\"attrs\":{\"start\":566,\"end\":579},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7b4e3b42-8510-401e-9185-c65cc0c09cc5\",\"uuid\":\"63144108-bb3f-4513-a77a-ad60f8de4eae\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and relatives. They will see darkness in all directions and be led by \",\"attrs\":{\"start\":579,\"end\":651}},{\"type\":\"text\",\"text\":\"Yama\",\"attrs\":{\"start\":651,\"end\":655},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"33413e9d-f28e-40a7-8f31-b28134daf81b\",\"uuid\":\"abd6f2a1-6edc-4416-aa4f-647f88098d40\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s servants.\",\"attrs\":{\"start\":655,\"end\":667}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"3f5abdf1-2564-43dd-91a9-39782b8c32af\",\"sort\":885,\"type\":\"translation\",\"label\":\"1.46\",\"alignments\":{\"toh504\":{\"folioUuid\":\"b3d61d6f-ed5d-43d0-b1f3-74f4e781128a\",\"toh\":\"toh504\",\"tibetan\":\"དེའི་ལུས་འདི་ན་ཉལ་ཡང་རྣམ་པར་ཤེས་པ་ཆོས་ཀྱི་རྒྱལ་པོ་གཤིན་རྗེའི་མདུན་དུ་ཁྲིད་ཅིང་། མི་དེ་དང་ལྷན་ཅིག་སྐྱེས་པའི་ལྷ་སླད་བཞིན་འབྲང་བ་གང་\\nལགས་པ་དེས་ནི་དེས་དགེ་བ་དང་། མི་དགེ་བ་བགྱིས་པ་དེ་ཐམས་ཅད་ལེགས་པར་ཡི་གེར་བྲིས་ནས་ཆོས་ཀྱི་རྒྱལ་པོ་གཤིན་རྗེ་ལ་ཕུལ་བ་དང་། ཆོས་ཀྱི་རྒྱལ་པོ་གཤིན་རྗེས་དེ་ལ་དྲིས་ཤིང་བརྟགས་ནས་དགེ་བའམ། མི་དགེ་བ་ཇི་ལྟར་བགྱིས་པ་དེ་བཞིན་དུ་བསྒོ་[F.281.b]བ་ལས། \",\"folioNumber\":281,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":454,\"uuid\":\"3f5abdf1-2564-43dd-91a9-39782b8c32af\"},\"content\":[{\"type\":\"text\",\"text\":\"“While such a person’s body is still lying there, the consciousness will be brought before the Dharma King \",\"attrs\":{\"start\":0,\"end\":107}},{\"type\":\"text\",\"text\":\"Yama\",\"attrs\":{\"start\":107,\"end\":111},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"33413e9d-f28e-40a7-8f31-b28134daf81b\",\"uuid\":\"3f570ebc-a093-483f-b4ec-3db770e66d55\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". The \",\"attrs\":{\"start\":111,\"end\":117}},{\"type\":\"text\",\"text\":\"god who was born with that person\",\"attrs\":{\"start\":117,\"end\":150},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a1044c3f-9cda-456d-9df9-65f615aa22f7\",\"uuid\":\"758b7e00-9c34-4cca-b349-c651aafd1bc2\",\"toh\":null}},{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"ff9df9e9-ac3b-4a2a-a453-e64cefc0a735\",\"label\":\"25\",\"uuid\":\"593dfeb2-86f5-455d-8282-95c48e251dbb\",\"start\":150,\"end\":150,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" and who has recorded all of that person’s virtuous and nonvirtuous actions in writing will then present them to the Dharma King \",\"attrs\":{\"start\":150,\"end\":279}},{\"type\":\"text\",\"text\":\"Yama\",\"attrs\":{\"start\":279,\"end\":283},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"33413e9d-f28e-40a7-8f31-b28134daf81b\",\"uuid\":\"4de80bbe-a6f2-49d9-ac8f-b33cc4675834\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". The Dharma King \",\"attrs\":{\"start\":283,\"end\":301}},{\"type\":\"text\",\"text\":\"Yama\",\"attrs\":{\"start\":301,\"end\":305},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"33413e9d-f28e-40a7-8f31-b28134daf81b\",\"uuid\":\"d86e4bdc-8e07-48d3-b5c0-bb889e5a30c8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" will then question and interrogate the person and issue his judgment based on how many of their actions were virtuous and how many were nonvirtuous.\",\"attrs\":{\"start\":305,\"end\":454}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"c646609e-5679-4e14-a4f3-a69cad97af6d\",\"sort\":898,\"type\":\"translation\",\"label\":\"1.47\",\"alignments\":{\"toh504\":{\"folioUuid\":\"5a5e1663-cfd3-4656-bd91-d29e6c4a1b22\",\"toh\":\"toh504\",\"tibetan\":\"གང་དག་ནད་པ་དེའི་དོན་དུ་བཅོམ་ལྡན་འདས་དེ་བཞིན་གཤེགས་པ་སྨན་གྱི་བླ་བཻ་ཌཱུརྱའི་འོད་དེ་ལ་སྐྱབས་སུ་མཆི་ཞིང་འདི་འདྲ་བའི་སྦྱོར་བས་མཆོད་པ་བགྱིད་ན། དེའི་རྣམ་པར་ཤེས་པ་སླར་ལྡོག་ཅིང་རྨི་ལམ་རྨིས་པ་བཞིན་དུ་བདག་ཉིད་ཀྱིས་འཚལ་བའི་གནས་\\nདེར་མཆིས་ཏེ། ཡང་ན་ནི་གདུགས་བདུན། ཡང་ན་ནི་གདུགས་ཉི་ཤུ་རྩ་གཅིག །ཡང་ན་ནི་གདུགས་སུམ་ཅུ་རྩ་ལྔ། ཡང་ན་ནི་གདུགས་བཞི་བཅུ་རྩ་དགུ་ལ། དེའི་རྣམ་པར་ཤེས་པ་སླར་ལྡོག་ཅིང་དྲན་པ་རྙེད་ལ། དེ་དགེ་བ་དང་། མི་དགེ་བའི་ལས་ཀྱི་\\nརྣམ་པར་སྨིན་པ་བདག་ཉིད་ཀྱི་མངོན་སུམ་དུ་འགྱུར་ཏེ་སྲོག་གི་སླད་དུ་ཡང་། སྡིག་པའི་ལས་མི་བགྱིད་དོ། །དེ་ལྟ་ལགས་པས་དད་པའི་རིགས་ཀྱི་བུའམ། རིགས་ཀྱི་བུ་མོས་དེ་བཞིན་གཤེགས་པ་དེ་ལ་མཆོད་པར་བགྱིའོ། །\",\"folioNumber\":281,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":746,\"uuid\":\"c646609e-5679-4e14-a4f3-a69cad97af6d\"},\"content\":[{\"type\":\"text\",\"text\":\"“If the friends, \",\"attrs\":{\"start\":0,\"end\":17}},{\"type\":\"text\",\"text\":\"acquaintances\",\"attrs\":{\"start\":17,\"end\":30},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7b4e3b42-8510-401e-9185-c65cc0c09cc5\",\"uuid\":\"2ad8b51b-f6b4-4d58-8bd1-e6fdc3d2784c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and relatives\",\"attrs\":{\"start\":30,\"end\":45},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"a19214cb-2621-4a22-a161-60a6ab348119\",\"label\":\"26\",\"uuid\":\"39142616-b8b6-4819-8806-47ef5305b6d8\",\"start\":45,\"end\":45,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" of those who are ill take refuge in the \",\"attrs\":{\"start\":45,\"end\":86}},{\"type\":\"text\",\"text\":\"blessed\",\"attrs\":{\"start\":86,\"end\":93},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"f3592c93-882b-4799-8486-96d7c077d2ac\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":93,\"end\":94}},{\"type\":\"text\",\"text\":\"Thus-Gone\",\"attrs\":{\"start\":94,\"end\":103},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"2c880e9b-0c97-4632-ad67-6f4d6e45863e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":103,\"end\":104}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha­rāja\",\"attrs\":{\"start\":104,\"end\":139},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"42700cf7-b80f-42be-89b1-6b4b26f2b60a\",\"uuid\":\"ca6b59c4-b9de-4f80-a95c-6410c8fea948\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and perform the offering in this way to benefit them, their consciousness will turn back and make its way, just as if they had been dreaming, to the place where they had been. For some the consciousness will return on the seventh day, for some on the twenty-first, thirty-fifth, or forty-ninth day, and they will remember what happened to them. The ripening of virtuous and nonvirtuous actions will now be clear to them, and they will no longer commit unwholesome actions, even at the expense of their life. Therefore, faithful sons or daughters of good family should make offerings to that \",\"attrs\":{\"start\":139,\"end\":731}},{\"type\":\"text\",\"text\":\"thus-gone one\",\"attrs\":{\"start\":731,\"end\":744},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"704cbad3-4b4a-4e2a-bef5-7c50e2873b51\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".”\",\"attrs\":{\"start\":744,\"end\":746},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"1346a21b-1809-4e65-9e44-c30bb690d455\",\"label\":\"27\",\"uuid\":\"4941e546-7e56-4bfb-814f-3df26f73c253\",\"start\":746,\"end\":746,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"b8c1f893-9773-4c04-b218-a726a5327e27\",\"sort\":913,\"type\":\"translation\",\"label\":\"1.48\",\"alignments\":{\"toh504\":{\"folioUuid\":\"5a5e1663-cfd3-4656-bd91-d29e6c4a1b22\",\"toh\":\"toh504\",\"tibetan\":\"དེ་ནས་ཚེ་དང་ལྡན་པ་ཀུན་དགའ་བོས། བྱང་\\nཆུབ་སེམས་དཔའ་སྐྱབས་གྲོལ་ལ་འདི་སྐད་ཅེས་སྨྲས་སོ། །རིགས་ཀྱི་བུ། བཅོམ་ལྡན་འདས་དེ་བཞིན་གཤེགས་པ་སྨན་གྱི་བླ་བཻ་ཌཱུརྱའི་འོད་དེ་ལ། ཇི་ལྟར་མཆོད་པར་བྱ། \",\"folioNumber\":281,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":179,\"uuid\":\"b8c1f893-9773-4c04-b218-a726a5327e27\"},\"content\":[{\"type\":\"text\",\"text\":\"Venerable \",\"attrs\":{\"start\":0,\"end\":10}},{\"type\":\"text\",\"text\":\"Ānanda\",\"attrs\":{\"start\":10,\"end\":16},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b35041f2-96b8-4d55-b39a-9d0653dffcd6\",\"uuid\":\"c0632067-1a88-4e7d-a17f-6e99d7d0d291\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" then asked the bodhisattva \",\"attrs\":{\"start\":16,\"end\":44}},{\"type\":\"text\",\"text\":\"Trāṇamukta\",\"attrs\":{\"start\":44,\"end\":54},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e395621c-5852-46eb-a457-65b28596d6db\",\"uuid\":\"95fe88d6-4b8a-4636-bf76-896fd77e432a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", “Son of good family, how should one perform such an offering to the \",\"attrs\":{\"start\":54,\"end\":124}},{\"type\":\"text\",\"text\":\"blessed\",\"attrs\":{\"start\":124,\"end\":131},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"8b5f22cf-c6c0-41ca-af7e-f10dcd287c93\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":131,\"end\":132}},{\"type\":\"text\",\"text\":\"Thus-Gone\",\"attrs\":{\"start\":132,\"end\":141},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"a97ff7ee-c423-48d8-afd4-16edded357b1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":141,\"end\":142}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha­rāja\",\"attrs\":{\"start\":142,\"end\":177},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"42700cf7-b80f-42be-89b1-6b4b26f2b60a\",\"uuid\":\"7b889437-6378-41c6-8d54-8fbf7d57880b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"?”\",\"attrs\":{\"start\":177,\"end\":179}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"14e919fe-0055-4b83-9ed9-4a72a424b85e\",\"sort\":925,\"type\":\"translation\",\"label\":\"1.49\",\"alignments\":{\"toh504\":{\"folioUuid\":\"5a5e1663-cfd3-4656-bd91-d29e6c4a1b22\",\"toh\":\"toh504\",\"tibetan\":\"བྱང་ཆུབ་སེམས་དཔའ་སྐྱབས་གྲོལ་གྱིས་སྨྲས་པ། བཙུན་པ་ཀུན་དགའ་བོ་གང་དག་ནད་ཆེན་\\nཔོ་ལས་ཡོངས་སུ་ཐར་བར་འདོད་པ་དེ་དག་གིས་ནད་པ་དེའི་དོན་དུ། ཉིན་བདུན་མཚན་བདུན་དུ་ཡན་ལག་བརྒྱད་དང་ལྡན་པའི་གསོ་སྦྱོང་གི་སྡོམ་པ་བླང་བར་བྱའོ། །དགེ་སློང་གི་དགེ་འདུན་ལ་ཟས་དང་། སྐོམ་རྣམས་དང་། ཡོ་བྱད་ཐམས་ཅད་ཀྱིས་ཅི་ནུས་སུ་མཆོད་པ་དང་། \\nརིམ་གྲོ་བྱའོ། །ཉིན་ལན་གསུམ་མཚན་ལན་གསུམ་དུ། བཅོམ་ལྡན་འདས་དེ་བཞིན་གཤེགས་པ་སྨན་གྱི་བླ་བཻ་ཌཱུརྱའི་འོད་དེའི་མཚན་ཡིད་ལ་བྱའོ། །མདོ་འདི་ལན་བཞི་བཅུ་རྩ་དགུ་གདོན་པར་བྱའོ། །ཞག་བཞི་བཅུ་རྩ་དགུར་མར་མེ་བུད་པར་བྱའོ། །སྐུ་གཟུགས་\\nབདུན་བྱའོ། །སྐུ་གཟུགས་རེ་རེའི་སྤྱན་སྔར་ཡང་མར་མེ་བདུན་བདུན་གཞག་གོ། །མར་མེ་རེ་རེའི་ཚད་ཀྱང་ཤིང་རྟའི་འཕང་ལོ་ཙམ་དུ་བྱས་ཏེ། ཅི་ནས་ཀྱང་ཞག་བཞི་བཅུ་རྩ་དགུར་མར་མེ་མི་ཟད་པར་བྱའོ། །ཚོན་སྣ་ལྔ་པའི་བ་དན་བཞི་བཅུ་རྩ་དགུ་ལས་ལྷག་པར་བྱའོ། །[F.282.a]བ\",\"folioNumber\":281,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":841,\"uuid\":\"14e919fe-0055-4b83-9ed9-4a72a424b85e\"},\"content\":[{\"type\":\"text\",\"text\":\"The bodhisattva \",\"attrs\":{\"start\":0,\"end\":16}},{\"type\":\"text\",\"text\":\"Trāṇamukta\",\"attrs\":{\"start\":16,\"end\":26},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e395621c-5852-46eb-a457-65b28596d6db\",\"uuid\":\"5e7216ff-6ba9-4937-99ac-ff642a0a335a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" replied, “Venerable \",\"attrs\":{\"start\":26,\"end\":47}},{\"type\":\"text\",\"text\":\"Ānanda\",\"attrs\":{\"start\":47,\"end\":53},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b35041f2-96b8-4d55-b39a-9d0653dffcd6\",\"uuid\":\"923732c0-6148-4878-8546-4f97629d77c6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", those who want to free someone from a grave \",\"attrs\":{\"start\":53,\"end\":99}},{\"type\":\"text\",\"text\":\"illness\",\"attrs\":{\"start\":99,\"end\":106},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"564d8ea9-dfb7-42ae-b9b9-c4b03389d607\",\"uuid\":\"d1993f7c-4c84-4d54-9a77-c8ee9b4c1868\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" should observe the eightfold purification vows for seven days and seven nights to benefit the sick person. They should make as many offerings as possible to the monastic saṅgha of food, drink, and \",\"attrs\":{\"start\":106,\"end\":304}},{\"type\":\"text\",\"text\":\"provisions\",\"attrs\":{\"start\":304,\"end\":314},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"686d6042-1ae0-48bc-8b45-c65e4d770560\",\"uuid\":\"ddd05091-f739-481d-aa04-631a3af9fdf2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and offer service. They should focus on the name of the \",\"attrs\":{\"start\":314,\"end\":372}},{\"type\":\"text\",\"text\":\"blessed\",\"attrs\":{\"start\":372,\"end\":379},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"f3b0bfbe-b505-4868-9d3b-a0f73e62e915\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":379,\"end\":380}},{\"type\":\"text\",\"text\":\"Thus-Gone\",\"attrs\":{\"start\":380,\"end\":389},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"c2d4efab-2cb4-427c-b867-9c5929987bdd\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":389,\"end\":390}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha­rāja\",\"attrs\":{\"start\":390,\"end\":425},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"42700cf7-b80f-42be-89b1-6b4b26f2b60a\",\"uuid\":\"49ecae9c-edee-4808-8bf9-1c1981269fb3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" three times each day and three times each night. They should recite this discourse forty-nine times, offer oil lamps for forty-nine days, and make seven \",\"attrs\":{\"start\":425,\"end\":579}},{\"type\":\"text\",\"text\":\"statues\",\"attrs\":{\"start\":579,\"end\":586},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"beb14c8c-22c9-4cbb-b14c-392f2edf214b\",\"uuid\":\"5a3b9dec-0f53-4f39-8aa2-c7fe1e17d722\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". They should place seven oil lamps in front of each \",\"attrs\":{\"start\":586,\"end\":639}},{\"type\":\"text\",\"text\":\"statue\",\"attrs\":{\"start\":639,\"end\":645},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"beb14c8c-22c9-4cbb-b14c-392f2edf214b\",\"uuid\":\"55c56f39-2c0f-461d-88da-16ae2f56c0ec\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and each of the oil lamps should be as large as a chariot wheel to ensure that the oil lamps will not go out during the forty-nine days. They should make more than forty-nine five-colored flags.\",\"attrs\":{\"start\":645,\"end\":841}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"9a6b4173-d6c4-44ed-afda-7da7526c76ee\",\"sort\":946,\"type\":\"translation\",\"label\":\"1.50\",\"alignments\":{\"toh504\":{\"folioUuid\":\"20b50b36-f14c-43fb-ae57-243e8f109133\",\"toh\":\"toh504\",\"tibetan\":\"$2e\",\"folioNumber\":282,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1092,\"uuid\":\"9a6b4173-d6c4-44ed-afda-7da7526c76ee\"},\"content\":[{\"type\":\"text\",\"text\":\"“Respected \",\"attrs\":{\"start\":0,\"end\":11}},{\"type\":\"text\",\"text\":\"Ānanda\",\"attrs\":{\"start\":11,\"end\":17},\"marks\":[{\"type\":\"glossaryInstance\",\"attr