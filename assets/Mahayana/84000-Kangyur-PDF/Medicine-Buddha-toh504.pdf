:\"དེའི་སྨོན་ལམ་ཆེན་\\nཔོ་དང་པོ་ནི་གང་གི་ཚེ་བདག་མ་འོངས་པའི་དུས་ན་བླ་ན་མེད་པ་ཡང་དག་པར་རྫོགས་པའི་བྱང་ཆུབ་མངོན་པར་རྫོགས་པར་སངས་རྒྱས་པ་དེའི་ཚེ། བདག་གི་ལུས་ཀྱི་འོད་ཀྱིས་འཇིག་རྟེན་གྱི་ཁམས་གྲངས་མེད་དཔག་ཏུ་མེད་ཅིང་དཔག་གིས་མི་ལང་བ་དག་ལྷམ་མེ་ལྷན་ནེ་ལྷང་ངེར་\\nགྱུར་ཅིག །སེམས་ཅན་ཐམས་ཅད་སྐྱེས་བུ་ཆེན་པོའི་མཚན་སུམ་ཅུ་རྩ་གཉིས་དང་། དཔེ་བྱད་བཟང་པོ་བརྒྱད་ཅུས་ལེགས་པར་བརྒྱན་པར་གྱུར་ཏེ། བདག་ཅི་འདྲ་བ་དེ་བཞིན་དུ་སེམས་ཅན་ཐམས་ཅད་ཀྱང་དེ་འདྲ་བར་གྱུར་ཅིག་ཅེས་བཏབ་བོ། །\",\"folioNumber\":274,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":396,\"uuid\":\"021b3b24-f50c-4c80-85a6-99372db2c29c\"},\"content\":[{\"type\":\"text\",\"text\":\"“For his first \",\"attrs\":{\"start\":0,\"end\":15}},{\"type\":\"text\",\"text\":\"great aspiration\",\"attrs\":{\"start\":15,\"end\":31},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2c78f096-4bf1-473f-8fc4-372315f0f7a1\",\"uuid\":\"af793cca-b477-4091-85ad-aa8df5b2cf6e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", he proclaimed, ‘In the future, when I have attained awakening as a perfect buddha who has \",\"attrs\":{\"start\":31,\"end\":123}},{\"type\":\"text\",\"text\":\"manifested\",\"attrs\":{\"start\":123,\"end\":133},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bd416713-18e1-4bcd-aa37-1255f4489642\",\"uuid\":\"14e0bf48-c701-4928-91a2-9d8bda99451a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" unsurpassed and perfect awakening, may my body’s radiance \",\"attrs\":{\"start\":133,\"end\":192}},{\"type\":\"text\",\"text\":\"illuminate\",\"attrs\":{\"start\":192,\"end\":202},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"62f33895-4037-4996-9cc5-124db625d5c8\",\"uuid\":\"2e4d909d-cb4c-4f66-8bb9-ed80a4ea6d5d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" innumerable, limitless, and immeasurable worlds, \",\"attrs\":{\"start\":202,\"end\":252}},{\"type\":\"text\",\"text\":\"warm them\",\"attrs\":{\"start\":252,\"end\":261},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7ffcb8b3-8a44-4a6d-b2b0-2a6a468bb773\",\"uuid\":\"19270e33-f6f6-48b5-b865-2779db34c33f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and \",\"attrs\":{\"start\":261,\"end\":267}},{\"type\":\"text\",\"text\":\"make them shine\",\"attrs\":{\"start\":267,\"end\":282},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"abe20072-53d9-4db9-a153-41172c50a57e\",\"uuid\":\"971e7fef-9ede-4095-9d34-9f746f95e22a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". May all beings be adorned with the \",\"attrs\":{\"start\":282,\"end\":319}},{\"type\":\"text\",\"text\":\"thirty-two marks of a great person\",\"attrs\":{\"start\":319,\"end\":353},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"392ef282-a172-45b8-a156-169992eaa417\",\"uuid\":\"3dfb0371-dff4-45fa-a4b7-6488e94b1677\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and the \",\"attrs\":{\"start\":353,\"end\":362}},{\"type\":\"text\",\"text\":\"eighty minor marks\",\"attrs\":{\"start\":362,\"end\":380},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"fe7448d9-9209-432f-8696-143f0a36d9cf\",\"uuid\":\"4764c2b1-9a20-4cce-9c9b-54a160122569\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", just as I am.’\",\"attrs\":{\"start\":380,\"end\":396}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"57f01e7a-2b80-492f-9dd4-6665e2de00a9\",\"sort\":299,\"type\":\"translation\",\"label\":\"1.9\",\"alignments\":{\"toh504\":{\"folioUuid\":\"caac1a0a-a66b-4801-bb82-2bd36e42deff\",\"toh\":\"toh504\",\"tibetan\":\"དེའི་སྨོན་ལམ་ཆེན་\\nཔོ་གཉིས་པ་ནི་གང་གི་ཚེ་བདག་མ་འོངས་པའི་དུས་ན། བླ་ན་མེད་པ་ཡང་དག་པར་རྫོགས་པའི་བྱང་ཆུབ་མངོན་པར་རྫོགས་པར་སངས་རྒྱས་པ་དེའི་ཚེ་བདག་བྱང་ཆུབ་ཐོབ་པ་ན། ལུས་ནོར་བུ་རིན་པོ་ཆེ་བཻ་ཌཱུརྱ་ཅི་འདྲ་བ་དེ་འདྲ་བར་ཕྱི་ནང་ཤིན་ཏུ་ཡོངས་སུ་དག་པ་དང་། དྲི་མ་[F.275.a]མེད་ལ་འོད་གསལ་བ་དང་། ཁོ་ལག་ཡངས་ཤིང་ཆེ་བ་དང་། དཔལ་དང་གཟི་བརྗིད་འབར་བ་དང་། ལེགས་པར་གནས་པ་དང་། ཉི་མ་དང་ཟླ་བ་བས་ལྷག་པའི་འོད་ཟེར་གྱི་དྲ་བ་རྣམས་ཀྱིས་ལེགས་པར་བརྒྱན་པར་གྱུར་ཅིག །དེ་ན་སེམས་ཅན་\\nགང་དག་འཇིག་རྟེན་གྱི་བར་དུ་སྐྱེས་པ་དག་དང་། གང་དག་ཡང་མིའི་འཇིག་རྟེན་འདི་ན་མཚན་མོ་མུན་པ་མུན་ནག་གི་ནང་ན་ཕྱོགས་ཐ་དད་པར་འགྲོ་བ་དེ་དག་བདག་གི་འོད་ཀྱིས་ཕྱོགས་དགའ་མགུར་འགྲོ་བར་གྱུར་ཅིག །ལས་རྣམས་ཀྱང་བྱེད་པར་གྱུར་ཅིག་ཅེས་བཏབ་བོ། །\\n\",\"folioNumber\":274,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":667,\"uuid\":\"57f01e7a-2b80-492f-9dd4-6665e2de00a9\"},\"content\":[{\"type\":\"text\",\"text\":\"“For his second \",\"attrs\":{\"start\":0,\"end\":16}},{\"type\":\"text\",\"text\":\"great aspiration\",\"attrs\":{\"start\":16,\"end\":32},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2c78f096-4bf1-473f-8fc4-372315f0f7a1\",\"uuid\":\"dbfb4cb7-8605-4fb4-9834-7ba5fcc2ec26\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", he proclaimed, ‘In the future, when I have attained awakening as a perfect buddha who has \",\"attrs\":{\"start\":32,\"end\":124}},{\"type\":\"text\",\"text\":\"manifested\",\"attrs\":{\"start\":124,\"end\":134},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bd416713-18e1-4bcd-aa37-1255f4489642\",\"uuid\":\"b3ce5d52-dc20-4862-85b0-1223d97e6a5d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" unsurpassed and perfect awakening, may my body be like a precious \",\"attrs\":{\"start\":134,\"end\":201}},{\"type\":\"text\",\"text\":\"blue beryl\",\"attrs\":{\"start\":201,\"end\":211},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"10c7e31c-8ab9-4465-a8ba-3027ff390cc4\",\"uuid\":\"bcb6eda2-ff3c-465f-a52a-27827affa506\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" gem‍—pure inside and out and radiating a stainless light. May I \",\"attrs\":{\"start\":211,\"end\":276}},{\"type\":\"text\",\"text\":\"manifest\",\"attrs\":{\"start\":276,\"end\":284},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bd416713-18e1-4bcd-aa37-1255f4489642\",\"uuid\":\"192b9f7b-d03f-4907-979b-7490d56158c2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" a broad and tall \",\"attrs\":{\"start\":284,\"end\":302}},{\"type\":\"text\",\"text\":\"body\",\"attrs\":{\"start\":302,\"end\":306},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"29c40432-a61e-422b-abdf-65eb303e5623\",\"uuid\":\"ec2befaf-3c62-4ca4-8412-b804e95e0148\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" that stands firm, is ablaze with glory and splendor, and is adorned with a halo of light so bright that it outshines the \",\"attrs\":{\"start\":306,\"end\":428}},{\"type\":\"text\",\"text\":\"sun\",\"attrs\":{\"start\":428,\"end\":431},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2a81074e-debf-4316-bb23-3177c8323be0\",\"uuid\":\"7217d054-42e3-40c8-87d7-5ee690e798c4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and \",\"attrs\":{\"start\":431,\"end\":436}},{\"type\":\"text\",\"text\":\"moon\",\"attrs\":{\"start\":436,\"end\":440},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a3efffd6-869a-4db9-82c5-eb27587847c2\",\"uuid\":\"27b505a3-699e-47d9-976b-10b59dc83794\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". May my light allow any beings who are born in the dark \",\"attrs\":{\"start\":440,\"end\":497}},{\"type\":\"text\",\"text\":\"spaces between worlds\",\"attrs\":{\"start\":497,\"end\":518},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1dc4c134-d9bb-4617-ad63-e08428e8d369\",\"uuid\":\"18205268-d9ec-464a-8e64-b76b48bc3601\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and those here in the human world who travel to various places during the dark of night, to proceed joyfully, and may they perform virtuous deeds.’\",\"attrs\":{\"start\":518,\"end\":667}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"d22cacaf-0930-4725-8dea-8693f3afe069\",\"sort\":319,\"type\":\"translation\",\"label\":\"1.10\",\"alignments\":{\"toh504\":{\"folioUuid\":\"be83a204-aff5-49ac-84cb-6406fc4837e7\",\"toh\":\"toh504\",\"tibetan\":\"དེའི་སྨོན་ལམ་ཆེན་པོ་གསུམ་པ་ནི་གང་གི་ཚེ་བདག་མ་འོངས་པའི་དུས་ན། བླ་ན་མེད་པ་ཡང་དག་པར་རྫོགས་པའི་བྱང་ཆུབ་མངོན་པར་རྫོགས་པར་སངས་རྒྱས་པ་དེའི་ཚེ་བདག་བྱང་ཆུབ་ཐོབ་པ་ན། བདག་གི་ཤེས་རབ་དང་ཐབས་དཔག་ཏུ་མེད་པས་སེམས་ཅན་གྱི་ཁམས་\\nདཔག་གིས་མི་ལང་བ་དག་ལོངས་སྤྱོད་མི་ཟད་པ་དང་ལྡན་པར་གྱུར་ཏེ། སུ་ཡང་ཅིས་ཀྱང་བྲེལ་བ་མེད་པར་གྱུར་ཅིག་ཅེས་བཏབ་བོ། །\",\"folioNumber\":275,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":307,\"uuid\":\"d22cacaf-0930-4725-8dea-8693f3afe069\"},\"content\":[{\"type\":\"text\",\"text\":\"“For his third \",\"attrs\":{\"start\":0,\"end\":15}},{\"type\":\"text\",\"text\":\"great aspiration\",\"attrs\":{\"start\":15,\"end\":31},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2c78f096-4bf1-473f-8fc4-372315f0f7a1\",\"uuid\":\"4d4f6261-0061-41a5-bf89-0d1a5a4d84b3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", he proclaimed, ‘In the future, when I have attained awakening as a perfect buddha who has \",\"attrs\":{\"start\":31,\"end\":123}},{\"type\":\"text\",\"text\":\"manifested\",\"attrs\":{\"start\":123,\"end\":133},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bd416713-18e1-4bcd-aa37-1255f4489642\",\"uuid\":\"b6a4e3e0-0207-4ea0-8c42-3f8c564b3b7d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" unsurpassed and perfect awakening, may my boundless wisdom and \",\"attrs\":{\"start\":133,\"end\":197}},{\"type\":\"text\",\"text\":\"skillful means\",\"attrs\":{\"start\":197,\"end\":211},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e027cc95-c6fb-48fa-ae75-2c7be803ad4b\",\"uuid\":\"66473a03-cd19-4d15-8760-7e48a17c77bc\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" furnish immeasurable realms of beings with inexhaustible \",\"attrs\":{\"start\":211,\"end\":269}},{\"type\":\"text\",\"text\":\"wealth\",\"attrs\":{\"start\":269,\"end\":275},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7592fd85-fafc-42db-a077-641db438c9e7\",\"uuid\":\"83b0a956-4605-4103-a038-249e4a4fc11f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and may no one lack anything.’\",\"attrs\":{\"start\":275,\"end\":307}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"82751df6-a0aa-4d09-ba7e-ce08cdc5d8a8\",\"sort\":329,\"type\":\"translation\",\"label\":\"1.11\",\"alignments\":{\"toh504\":{\"folioUuid\":\"be83a204-aff5-49ac-84cb-6406fc4837e7\",\"toh\":\"toh504\",\"tibetan\":\"དེའི་སྨོན་ལམ་ཆེན་པོ་གཉིས་པ་ནི་གང་གི་ཚེ་བདག་མ་འོངས་པའི་དུས་ན། བླ་ན་མེད་པ་ཡང་དག་པར་རྫོགས་པའི་བྱང་ཆུབ་མངོན་པར་\\nརྫོགས་པར་སངས་རྒྱས་པ་དེའི་ཚེ་བདག་བྱང་ཆུབ་ཐོབ་པ་ན། སེམས་ཅན་གང་དག་ལམ་ངན་པར་ཞུགས་པ་དེ་དག་བྱང་ཆུབ་ཀྱི་ལམ་ལ་དགོད་པར་བྱའོ། །ཉན་ཐོས་ཀྱི་ལམ་དུ་ཞུགས་པ་དང་། རང་སངས་རྒྱས་ཀྱི་ལམ་དུ་ཞུགས་པ་དེ་དག་ཐམས་ཅད་ནི་ཐེག་པ་ཆེན་པོ་ལ་\\nགཟུད་པར་སྤྱད་པར་བྱའོ་ཞེས་བཏབ་བོ། །\",\"folioNumber\":275,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":393,\"uuid\":\"82751df6-a0aa-4d09-ba7e-ce08cdc5d8a8\"},\"content\":[{\"type\":\"text\",\"text\":\"“For his fourth \",\"attrs\":{\"start\":0,\"end\":16}},{\"type\":\"text\",\"text\":\"great aspiration\",\"attrs\":{\"start\":16,\"end\":32},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2c78f096-4bf1-473f-8fc4-372315f0f7a1\",\"uuid\":\"75ba71f9-c997-4da9-a69f-ec56ea84131c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", he proclaimed, ‘In the future, when I have attained awakening as a perfect buddha who has \",\"attrs\":{\"start\":32,\"end\":124}},{\"type\":\"text\",\"text\":\"manifested\",\"attrs\":{\"start\":124,\"end\":134},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bd416713-18e1-4bcd-aa37-1255f4489642\",\"uuid\":\"bc6b1f73-d9d8-4381-9896-a94a190d5ddf\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" unsurpassed and perfect awakening, may any beings who have set out on the wrong path be set upon the path to awakening. May all those who have entered the path of the hearers and who have entered the path of the solitary buddhas be led to the Great Vehicle.’\",\"attrs\":{\"start\":134,\"end\":393}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"7ab41660-9a48-4a87-b15a-82975b1cae62\",\"sort\":335,\"type\":\"translation\",\"label\":\"1.12\",\"alignments\":{\"toh504\":{\"folioUuid\":\"be83a204-aff5-49ac-84cb-6406fc4837e7\",\"toh\":\"toh504\",\"tibetan\":\"དེའི་སྨོན་ལམ་ཆེན་པོ་ལྔ་པ་ནི་གང་གི་ཚེ་བདག་མ་འོངས་པའི་དུས་ན། བླ་ན་མེད་པ་ཡང་དག་པར་རྫོགས་པའི་བྱང་ཆུབ་མངོན་པར་རྫོགས་པར་སངས་རྒྱས་པ་དེའི་ཚེ་བདག་བྱང་ཆུབ་ཐོབ་པ་ན། སེམས་ཅན་གང་དག་བདག་གི་གནན་\\nཚངས་པར་སྤྱད་པ་སྤྱོད་པ་དང་། དེ་བཞིན་དུ་སེམས་ཅན་གཞན་དཔག་ཏུ་མེད་ཅིང་དཔག་གིས་མི་ལང་བ་དེ་དག་ཐམས་ཅད་ཀྱང་བདག་གི་མིང་ཐོས་ནས། བདག་གི་མཐུས་སྡོམ་པ་གསུམ་གྱིས་བསྡམས་པ་དང་། ཚུལ་ཁྲིམས་ཉམས་པ་མེད་པར་གྱུར་ཅིག །སུ་ཡང་[F.275.b]ཚུལ་ཁྲིམས་ལོག་པར་ཞུགས་ཏེ། ངན་འགྲོར་འགྲོ་བར་མ་གྱུར་ཅིག་ཅེས་བཏབ་བོ། །\",\"folioNumber\":275,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":470,\"uuid\":\"7ab41660-9a48-4a87-b15a-82975b1cae62\"},\"content\":[{\"type\":\"text\",\"text\":\"“For his fifth \",\"attrs\":{\"start\":0,\"end\":15}},{\"type\":\"text\",\"text\":\"great aspiration\",\"attrs\":{\"start\":15,\"end\":31},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2c78f096-4bf1-473f-8fc4-372315f0f7a1\",\"uuid\":\"20ed69ea-5c59-4995-9fde-57dc2d40b615\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", he proclaimed, ‘In the future, when I have attained awakening as a perfect buddha who has \",\"attrs\":{\"start\":31,\"end\":123}},{\"type\":\"text\",\"text\":\"manifested\",\"attrs\":{\"start\":123,\"end\":133},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bd416713-18e1-4bcd-aa37-1255f4489642\",\"uuid\":\"d9fcb81e-483f-4365-b153-26673f36896d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" unsurpassed and perfect awakening, may any beings who are close to me \",\"attrs\":{\"start\":133,\"end\":204}},{\"type\":\"text\",\"text\":\"practice pure conduct\",\"attrs\":{\"start\":204,\"end\":225},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"89913917-2506-4297-9321-91c13315a95d\",\"uuid\":\"3e23d961-d330-4482-8123-ca7dc7eca339\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Likewise, may a limitless and boundless number of other beings hear my name, and may my power cause them to be bound by the \",\"attrs\":{\"start\":225,\"end\":351}},{\"type\":\"text\",\"text\":\"three vows\",\"attrs\":{\"start\":351,\"end\":361},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"fc87d09b-c219-4d0b-b7d9-e0a5b9b08fa3\",\"uuid\":\"98fa2154-8e1c-4982-98f7-a08d02f3f791\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and have \",\"attrs\":{\"start\":361,\"end\":371}},{\"type\":\"text\",\"text\":\"uncorrupted discipline\",\"attrs\":{\"start\":371,\"end\":393},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7f20ccc0-0a8d-4dec-950e-cd7f6b8a868b\",\"uuid\":\"467b1960-7dd5-449e-8d7a-654eb41569be\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". May no one engage in \",\"attrs\":{\"start\":393,\"end\":416}},{\"type\":\"text\",\"text\":\"incorrect discipline\",\"attrs\":{\"start\":416,\"end\":436},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e2075711-98f5-47bf-a7d6-24b24b5a1755\",\"uuid\":\"2b85097c-a4ac-42cd-bc4c-82961eb4997c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and proceed to the lower realms.’\",\"attrs\":{\"start\":436,\"end\":470}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"47e02a4c-148c-4902-b4c3-16a9848e6d41\",\"sort\":353,\"type\":\"translation\",\"label\":\"1.13\",\"alignments\":{\"toh504\":{\"folioUuid\":\"5cf7f8cd-4ab5-43c7-b435-9b3b880bff3e\",\"toh\":\"toh504\",\"tibetan\":\"དེའི་སྨོན་ལམ་ཆེན་པོ་དྲུག་པ་ནི་གང་གི་ཚེ་བདག་མ་འོངས་པའི་དུས་ན། བླ་ན་མེད་པ་ཡང་དག་པར་རྫོགས་པའི་བྱང་ཆུབ་མངོན་པར་རྫོགས་པར་སངས་རྒྱས་པ་དེའི་ཚེ་བདག་\\nབྱང་ཆུབ་ཐོབ་པ་ན། སེམས་ཅན་གང་སུ་དག་ལུས་ངན་པ་དང་། དབང་པོ་མ་ཚང་བ་དང་། མདོག་མི་སྡུག་པ་དང་། བེམས་པོ་དང་། ཡན་ལག་སྐྱོན་ཅན་དང་། སྒུར་པོ་དང་། ཤ་བཀྲ་ཅན་དང་། ཞར་བ་དང་། ལོང་བ་དང་། འོན་པ་དང་། སྨྱོན་པར་\\nགྱུར་པ་དང་། གཞན་ཡང་གང་སུ་དག་ལུས་ལ་ནད་ཀྱིས་བཏབ་པ་དེ་དག་གིས་བདག་གི་མིང་ཐོས་ནས་ཐམས་ཅད་དབང་པོ་ཚང་ཞིང་ཡན་ལག་ཡོ