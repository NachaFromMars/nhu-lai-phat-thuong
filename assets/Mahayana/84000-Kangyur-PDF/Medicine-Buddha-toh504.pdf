ext\",\"text\":\" is when someone is burned by fire and dies. The fifth type of \",\"attrs\":{\"start\":704,\"end\":767}},{\"type\":\"text\",\"text\":\"untimely death\",\"attrs\":{\"start\":767,\"end\":781},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ab2e041a-4033-4bfa-8d05-9b343f2ac529\",\"uuid\":\"c2640d6e-84a1-40c5-a4fd-6aea6ff3a576\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is when someone dies by drowning. The sixth type of \",\"attrs\":{\"start\":781,\"end\":834}},{\"type\":\"text\",\"text\":\"untimely death\",\"attrs\":{\"start\":834,\"end\":848},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ab2e041a-4033-4bfa-8d05-9b343f2ac529\",\"uuid\":\"b9c91755-d6da-43f5-a2fd-3c57e84fe724\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is when someone dies upon encountering a ferocious predator such as a lion, tiger, jackal, or snake. The seventh type of \",\"attrs\":{\"start\":848,\"end\":970}},{\"type\":\"text\",\"text\":\"untimely death\",\"attrs\":{\"start\":970,\"end\":984},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ab2e041a-4033-4bfa-8d05-9b343f2ac529\",\"uuid\":\"e4b5e3ac-a1c2-4757-b6fe-16fb3dca0b31\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is when someone falls off a mountainside into an abyss. The eighth type of \",\"attrs\":{\"start\":984,\"end\":1060}},{\"type\":\"text\",\"text\":\"untimely death\",\"attrs\":{\"start\":1060,\"end\":1074},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ab2e041a-4033-4bfa-8d05-9b343f2ac529\",\"uuid\":\"810ae82c-20e6-472e-9fdd-fe27730e69c8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is when someone is killed by poison, a \",\"attrs\":{\"start\":1074,\"end\":1114}},{\"type\":\"text\",\"text\":\"kākhorda\",\"attrs\":{\"start\":1114,\"end\":1122},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"852d055a-c616-46a5-919b-e510b44302ee\",\"uuid\":\"465aac86-0028-4820-83b1-e149e48ec42d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", or a \",\"attrs\":{\"start\":1122,\"end\":1129}},{\"type\":\"text\",\"text\":\"vetāla\",\"attrs\":{\"start\":1129,\"end\":1135},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c055f6d1-0659-4747-9503-bc39840c812f\",\"uuid\":\"c431208e-35d8-46ab-b9f9-9a3292424ded\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". The ninth type of \",\"attrs\":{\"start\":1135,\"end\":1155}},{\"type\":\"text\",\"text\":\"untimely death\",\"attrs\":{\"start\":1155,\"end\":1169},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ab2e041a-4033-4bfa-8d05-9b343f2ac529\",\"uuid\":\"48f2a858-11b8-4159-af9c-68bab84ba816\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is when someone cannot find food and drink and dies of starvation and thirst. This is a brief account of the major types of \",\"attrs\":{\"start\":1169,\"end\":1294}},{\"type\":\"text\",\"text\":\"untimely death\",\"attrs\":{\"start\":1294,\"end\":1308},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ab2e041a-4033-4bfa-8d05-9b343f2ac529\",\"uuid\":\"99e646f9-a67d-4294-96e4-c60cc7fc553f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" that the \",\"attrs\":{\"start\":1308,\"end\":1318}},{\"type\":\"text\",\"text\":\"Thus-Gone One\",\"attrs\":{\"start\":1318,\"end\":1331},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"1b8d1f36-b0eb-4fe7-ab4a-9a8661e54726\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" has taught, but there are an innumerable and incalculable number of other kinds of \",\"attrs\":{\"start\":1331,\"end\":1415}},{\"type\":\"text\",\"text\":\"untimely death\",\"attrs\":{\"start\":1415,\"end\":1429},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ab2e041a-4033-4bfa-8d05-9b343f2ac529\",\"uuid\":\"4173e222-5279-4cc0-a7f1-e81ac7891389\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".”\",\"attrs\":{\"start\":1429,\"end\":1431}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"a93cf62f-2513-4adf-9c3b-ac637cc973c5\",\"sort\":1044,\"type\":\"translation\",\"label\":\"1.53\",\"alignments\":{\"toh504\":{\"folioUuid\":\"624fbb47-91ee-4736-9231-893d6baa4380\",\"toh\":\"toh504\",\"tibetan\":\"དེ་ནས་འཁོར་དེར་གནོད་སྦྱིན་གྱི་སྡེ་དཔོན་ཆེན་པོ་བཅུ་གཉིས་འདུས་པར་གྱུར་ཏེ། གནོད་སྦྱིན་གྱི་སྡེ་དཔོན་ཆེན་པོ་ཇི་འཇིགས་དང་། གནོད་\\nསྦྱིན་གྱི་སྡེ་དཔོན་ཆེན་པོ་རྡོ་རྗེ་དང་། གནོད་སྦྱིན་གྱི་སྡེ་དཔོན་ཆེན་པོ་རྒྱན་འཛིན་དང་། གནོད་སྦྱིན་གྱི་སྡེ་དཔོན་ཆེན་པོ་གཟའ་འཛིན་དང་། གནོད་སྦྱིན་གྱི་སྡེ་དཔོན་ཆེན་པོ་རླུང་དང་། གནོད་སྦྱིན་གྱི་སྡེ་དཔོན་ཆེན་པོ་གནས་བཅས་དང་། གནོད་སྦྱིན་གྱི་སྡེ་[F.283.a]དཔོན་ཆེན་པོ་དབང་འཛིན་དང་། གནོད་སྦྱིན་གྱི་སྡེ་དཔོན་ཆེན་པོ་བཏུང་འཛིན་དང་། གནོད་སྦྱིན་གྱི་སྡེ་དཔོན་ཆེན་པོ་སྨྲ་འཛིན་དང་། གནོད་སྦྱིན་གྱི་སྡེ་དཔོན་ཆེན་པོ་བསམ་འཛིན་དང་། གནོད་སྦྱིན་གྱི་སྡེ་དཔོན་ཆེན་པོ་གཡོ་བ་འཛིན་\\nདང་། གནོད་སྦྱིན་གྱི་སྡེ་དཔོན་ཆེན་པོ་རྫོགས་བྱེད་དེ། གནོད་སྦྱིན་གྱི་སྡེ་དཔོན་ཆེན་པོ་བཅུ་གཉིས་པོ་དེ་དག་གོ། །\",\"folioNumber\":282,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":459,\"uuid\":\"a93cf62f-2513-4adf-9c3b-ac637cc973c5\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"c5500634-c2ee-4b2c-9622-bc22957df72c\"},\"content\":[{\"type\":\"text\",\"text\":\"There were twelve \",\"attrs\":{\"start\":0,\"end\":18}},{\"type\":\"text\",\"text\":\"great yakṣa generals\",\"attrs\":{\"start\":18,\"end\":38},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d09252d2-d990-4e23-8cfe-5e673de4aa9f\",\"uuid\":\"8760e880-e20f-4193-96b9-322ae183e973\",\"toh\":null}},{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"cbbf0433-7d8c-402c-bdf1-96051c2aad18\",\"label\":\"29\",\"uuid\":\"fdf57170-9df6-4a65-8b77-cae6cd707ce2\",\"start\":38,\"end\":38,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" gathered in that assembly‍—the \",\"attrs\":{\"start\":38,\"end\":70}},{\"type\":\"text\",\"text\":\"great yakṣa general\",\"attrs\":{\"start\":70,\"end\":89},\"marks\":[{\"type\":\"glossaryIns