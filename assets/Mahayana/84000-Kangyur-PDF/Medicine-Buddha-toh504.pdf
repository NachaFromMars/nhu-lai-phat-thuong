l\":\"1.54\",\"alignments\":{\"toh504\":{\"folioUuid\":\"c91275a3-05ef-4801-9606-8e20fbfba093\",\"toh\":\"toh504\",\"tibetan\":\"གནོད་སྦྱིན་གྱི་སྡེ་དཔོན་ཆེན་པོ་རེ་རེ་ལ་ཡང་། གཡོག་གནོད་སྦྱིན་བདུན་འབུམ་བདུན་འབུམ་ཡོད་པ་སྟེ། དེ་དག་གིས་ཚིག་གཅིག་ཏུ་\\nབཅོམ་ལྡན་འདས་ལ་འདི་སྐད་ཅེས་གསོལ་ཏོ། །སངས་རྒྱས་ཀྱི་མཐུས་བདག་ཅག་གིས། བཅོམ་ལྡན་འདས་དེ་བཞིན་གཤེགས་པ་སྨན་གྱི་བླ་བཻ་ཌཱུརྱའི་འོད་དེའི་མཚན་ཐོས་ཏེ། བདག་ཅག་ལ་ཡང་ངན་འགྲོར་མཆི་བའི་འཇིགས་པ་འབྱུང་བར་མི་འགྱུར་རོ། །\\nདེས་ན་བདག་ཅག་ལྷན་ཅིག་ཏུ་མཐུན་པར་ཇི་སྲིད་འཚོའི་བར་དུ། སངས་རྒྱས་ལ་སྐྱབས་སུ་མཆིའོ། །ཆོས་ལ་སྐྱབས་སུ་མཆིའོ། །དགེ་འདུན་ལ་སྐྱབས་སུ་མཆིའོ། །སེམས་ཅན་ཐམས་ཅད་ཀྱི་དོན་དང་། སྨན་པ་དང་། བདེ་བའི་སླད་དུ་སྤྲོ་\\nབར་བགྱིའོ། །བྱེ་བྲག་ཏུ་ནི་གྲོང་ངམ། གྲོང་ཁྱེར་རམ། གྲོང་རྡལ་ལམ། དགོན་པའི་གནས་གང་ན་མདོ་སྡེ་འདི་སྤྱོད་པ་དང་། གང་ན་བཅོམ་ལྡན་འདས་དེ་བཞིན་གཤེགས་པ་སྨན་གྱི་བླ་བཻ་ཌཱུརྱའི་འོད་དེའི་མཚན་འཆང་བ་དང་། མཆོད་པ་དང་། རིམ་\\nགྲོ་བགྱིད་པའི་སེམས་ཅན་དེ་དག་ལ་བདག་ཅག་གིས་བསྲུང་བར་བགྱི། ཡོངས་སུ་བསྐྱང་བར་བགྱི། གནོད་པ་ཐམས་ཅད་ལས་ཡོངས་སུ་ཐར་བར་བགྱི། བསམ་པ་ཐམས་ཅད་ཡོངས་སུ་རྫོགས་པར་བགྱིའོ། །\",\"folioNumber\":283,\"volumeNumber\":87}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":931,\"uuid\":\"8a640f52-da31-453c-ae1e-0f2559a0a50e\"},\"content\":[{\"type\":\"text\",\"text\":\"Each \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"great yakṣa general\",\"attrs\":{\"start\":5,\"end\":24},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d09252d2-d990-4e23-8cfe-5e673de4aa9f\",\"uuid\":\"be42ad8c-a603-4f6d-b551-fffc498e5b39\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" had seven hundred thousand \",\"attrs\":{\"start\":24,\"end\":52}},{\"type\":\"text\",\"text\":\"yakṣa\",\"attrs\":{\"start\":52,\"end\":57},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5d1d861a-9a7d-45ee-9d4e-a843c5698e55\",\"uuid\":\"fbae644e-3d3f-422c-a4e4-d45f94a24a88\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" attendants, and they all told the \",\"attrs\":{\"start\":57,\"end\":92}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":92,\"end\":103},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"57d215cf-425d-46df-9147-ff6ca8fa8032\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" with a single voice, “\",\"attrs\":{\"start\":103,\"end\":126}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":126,\"end\":137},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"3de7faad-5f8f-4786-bce1-78be12dcecbc\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", due to the Buddha’s power, we have heard the name of the \",\"attrs\":{\"start\":137,\"end\":196}},{\"type\":\"text\",\"text\":\"blessed\",\"attrs\":{\"start\":196,\"end\":203},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8dca4b02-7b6d-4b86-a1fa-672fa5f90cd0\",\"uuid\":\"6da6c361-7319-4152-8016-ceff601abe14\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":203,\"end\":204}},{\"type\":\"text\",\"text\":\"Thus-Gone One\",\"attrs\":{\"start\":204,\"end\":217},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d5b4d6b9-6850-42c5-81c8-ea781b61a47b\",\"uuid\":\"877e5fa4-f774-4bb7-8d18-0f4f6e26e009\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":217,\"end\":218}},{\"type\":\"text\",\"text\":\"Bhaiṣajya­guru­vaiḍūrya­prabha­rāja\",\"attrs\":{\"start\":218,\"end\":253},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"42700cf7-b80f-42be-89b1-6b4b26f2b60a\",\"uuid\":\"8df301b5-0842-4ec0-8a31-045b8955a80a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and we will no longer have any fear of proceeding to the lower realms. All of us together, for as long as we live, take refuge in the Buddha, we take refuge in the Dharma, and we take refuge in the Saṅgha. We will diligently work for the benefit, \",\"attrs\":{\"start\":253,\"end\":502}},{\"type\":\"text\",\"text\":\"aid\",\"a