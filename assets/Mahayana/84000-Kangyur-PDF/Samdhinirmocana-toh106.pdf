start\":3434,\"end\":3567,\"uuid\":\"4f86f2df-e5bc-4ea5-aca0-23886c3b8f36\"}}],\"attrs\":{\"start\":3434,\"end\":3567,\"uuid\":\"4f86f2df-e5bc-4ea5-aca0-23886c3b8f36\"}}],\"attrs\":{\"start\":3434,\"end\":3567,\"uuid\":\"10592ce8-9ee7-4093-ae40-bcdbd8fa9ced\",\"nesting\":1,\"spacing\":\"horizontal\"}}],\"attrs\":{\"start\":3410,\"end\":3567,\"uuid\":\"402b3a41-bbeb-420f-b8d9-e0eec5e6acf4\"}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"0a177da6-28a3-4974-a130-ac06bdf5cda6\",\"sort\":1562,\"type\":\"introduction\",\"label\":\"i.27\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":80,\"uuid\":\"f854c1ac-8a45-4c80-b1d5-f6adcb7b0f12\"},\"content\":[{\"type\":\"text\",\"text\":\"In addition, five commentaries have been composed on the \",\"attrs\":{\"start\":0,\"end\":57}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana­sūtra\",\"attrs\":{\"start\":57,\"end\":79},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"193e31f9-637a-4705-a961-6a39af56fbc5\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\":\",\"attrs\":{\"start\":79,\"end\":80}}]},{\"type\":\"bulletList\",\"attrs\":{\"start\":80,\"end\":873,\"uuid\":\"ab289d06-210a-4653-9c3b-bc72af2cb7a9\",\"spacing\":\"horizontal\"},\"content\":[{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"• Asaṅga’s \",\"attrs\":{\"start\":80,\"end\":91}},{\"type\":\"text\",\"text\":\"Āryasaṃdhi­nirmocanabhāṣya\",\"attrs\":{\"start\":91,\"end\":117},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"761b3297-b8f6-497f-a700-5086a070e9be\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":117,\"end\":119}},{\"type\":\"text\",\"text\":\"dgongs pa nges par ’grel pa’i rnam par bshad pa\",\"attrs\":{\"start\":119,\"end\":166},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"64215efa-8b80-4877-b374-9927ebe3caca\",\"lang\":\"Bo-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\") D3981 mdo ’grel (mdo), ngi 1b–11b \",\"attrs\":{\"start\":166,\"end\":202}}],\"attrs\":{\"start\":80,\"end\":202,\"uuid\":\"42279431-63a0-46c0-8a0c-01903125f8a2\"}}],\"attrs\":{\"start\":80,\"end\":202,\"uuid\":\"42279431-63a0-46c0-8a0c-01903125f8a2\"}},{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"• \",\"attrs\":{\"start\":202,\"end\":204}},{\"type\":\"text\",\"text\":\"Wonch’uk’s *\",\"attrs\":{\"start\":204,\"end\":216},\"marks\":[{\"type\":\"bold\",\"attrs\":{\"start\":204,\"end\":353,\"uuid\":\"f9fa2b63-f20f-4f0d-b85a-ce62ba295519\",\"type\":\"span\",\"textStyle\":\"text-bold\"}}]},{\"type\":\"text\",\"text\":\"Āryagambhīrasaṃdhi­nirmocana­sūtraṭīkā\",\"attrs\":{\"start\":216,\"end\":254},\"marks\":[{\"type\":\"bold\",\"attrs\":{\"start\":204,\"end\":353,\"uuid\":\"f9fa2b63-f20f-4f0d-b85a-ce62ba295519\",\"type\":\"span\",\"textStyle\":\"text-bold\"}},{\"type\":\"italic\",\"attrs\":{\"uuid\":\"dca3d8e7-b1f2-4a70-9e6a-024d1afe56cf\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":254,\"end\":256},\"marks\":[{\"type\":\"bold\",\"attrs\":{\"start\":254,\"end\":353,\"uuid\":\"f9fa2b63-f20f-4f0d-b85a-ce62ba295519\",\"type\":\"span\",\"textStyle\":\"text-bold\"}}]},{\"type\":\"text\",\"text\":\"dgongs pa zab mo nges par ’grel pa’i mdo rgya cher ’grel pa\",\"attrs\":{\"start\":256,\"end\":315},\"marks\":[{\"type\":\"bold\",\"attrs\":{\"start\":254,\"end\":353,\"uuid\":\"f9fa2b63-f20f-4f0d-b85a-ce62ba295519\",\"type\":\"span\",\"textStyle\":\"text-bold\"}},{\"type\":\"italic\",\"attrs\":{\"uuid\":\"b7fd0f8f-318d-4a04-85b2-38a09404e8db\",\"lang\":\"Bo-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\") D4016 mdo ’grel (mdo), ti 1b–di 175a\",\"attrs\":{\"start\":315,\"end\":353},\"marks\":[{\"type\":\"bold\",\"attrs\":{\"start\":315,\"end\":353,\"uuid\":\"f9fa2b63-f20f-4f0d-b85a-ce62ba295519\",\"type\":\"span\",\"textStyle\":\"text-bold\"}},{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"efdfff56-ad51-4dd9-8b40-ac164ab00a99\",\"label\":\"9\",\"uuid\":\"a488a65e-7bc7-4f2e-9d3d-a104b854cc88\",\"start\":353,\"end\":353,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":353,\"end\":354}}],\"attrs\":{\"start\":202,\"end\":354,\"uuid\":\"427b608e-0b9f-4468-a495-08cfd59a2e96\"}}],\"attrs\":{\"start\":202,\"end\":354,\"uuid\":\"427b608e-0b9f-4468-a495-08cfd59a2e96\"}},{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"• Jñāṇagarbha’s \",\"attrs\":{\"start\":354,\"end\":370}},{\"type\":\"text\",\"text\":\"Āryasaṃdhi­nirmocanasūtre ārya­maitreya­kevala­parivarta­bhāṣya\",\"attrs\":{\"start\":370,\"end\":433},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"16369c2f-030b-4f0f-98c4-fd7df81e59a3\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":433,\"end\":435}},{\"type\":\"text\",\"text\":\"dgongs pa nges par ’grel pa’i mdo las ’phags pa byams pa’i le’u nyi tshe bshad pa\",\"attrs\":{\"start\":435,\"end\":516},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"a7e60b27-369f-4efc-9786-c7e0a81e5e87\",\"lang\":\"Bo-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\") D4033 mdo ’grel (sems tsam), bi 318b–345a \",\"attrs\":{\"start\":516,\"end\":560}}],\"attrs\":{\"start\":354,\"end\":560,\"uuid\":\"48b94bec-de56-4842-82ad-6968d750932d\"}}],\"attrs\":{\"start\":354,\"end\":560,\"uuid\":\"48b94bec-de56-4842-82ad-6968d750932d\"}},{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"• Changchup Dzutrül (\",\"attrs\":{\"start\":560,\"end\":581}},{\"type\":\"text\",\"text\":\"byang chub rdzu ’phrul\",\"attrs\":{\"start\":581,\"end\":603},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":581,\"end\":603,\"uuid\":\"051fb717-08db-4720-a727-38241055f3d2\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\")’s *\",\"attrs\":{\"start\":603,\"end\":608}},{\"type\":\"text\",\"text\":\"Āryasaṃdhi­nirmocana­sūtravyākhyāna\",\"attrs\":{\"start\":608,\"end\":643},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"a456fa97-fb8d-49a4-91b7-300029e9d626\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":643,\"end\":645}},{\"type\":\"text\",\"text\":\"bstan bcos sna tshogs\",\"attrs\":{\"start\":645,\"end\":666},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"f02a58fc-60f3-4368-b042-c6aea4588327\",\"lang\":\"Bo-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"), D4358 mdo ’grel, co 1b–jo 183b \",\"attrs\":{\"start\":666,\"end\":700}}],\"attrs\":{\"start\":560,\"end\":700,\"uuid\":\"d4f494d9-1595-4532-97e1-34b4cf3ff954\"}}],\"attrs\":{\"start\":560,\"end\":700,\"uuid\":\"d4f494d9-1595-4532-97e1-34b4cf3ff954\"}},{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"• Trisong Detsen (\",\"attrs\":{\"start\":700,\"end\":718}},{\"type\":\"text\",\"text\":\"khri srong lde brtsan\",\"attrs\":{\"start\":718,\"end\":739},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":718,\"end\":739,\"uuid\":\"893daf00-0741-4204-bf62-399751c21464\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\")’s *\",\"attrs\":{\"start\":739,\"end\":744}},{\"type\":\"text\",\"text\":\"Samyagvāk­pramāṇoddhṛta­sūtra\",\"attrs\":{\"start\":744,\"end\":773},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"1c4b4f9c-47e5-42c5-b5a6-71a95484e804\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":773,\"end\":775}},{\"type\":\"text\",\"text\":\"bka’ yang dag pa’i tshad ma las mdo btus pa\",\"attrs\":{\"start\":775,\"end\":818},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"ac229760-6bcf-49e5-a8fc-5a3948b2322d\",\"lang\":\"Bo-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\") D4352 mdo ’grel (bstan bcos sna tshogs), co 173a–205b\",\"attrs\":{\"start\":818,\"end\":873}}],\"attrs\":{\"start\":700,\"end\":873,\"uuid\":\"4cbb9c36-4d74-4b7d-8db4-7e3298c6823c\"}}],\"attrs\":{\"start\":700,\"end\":873,\"uuid\":\"4cbb9c36-4d74-4b7d-8db4-7e3298c6823c\"}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"35d1c403-a69d-41f3-8fc1-30e2a674c66d\",\"sort\":1600,\"type\":\"introductionHeader\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":3,\"start\":0,\"end\":40,\"uuid\":\"94da5d69-a3a3-43d7-8696-8c2a35535f67\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"Translation Issues and Academic Research\",\"attrs\":{\"start\":0,\"end\":40}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"4b5a7f02-42af-4651-92a1-c767c0f68e37\",\"sort\":1602,\"type\":\"introduction\",\"label\":\"i.28\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":135,\"uuid\":\"4b5a7f02-42af-4651-92a1-c767c0f68e37\"},\"content\":[{\"type\":\"text\",\"text\":\"I applied various methods and followed a series of steps during the process of translating the \",\"attrs\":{\"start\":0,\"end\":95}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana­sūtra\",\"attrs\":{\"start\":95,\"end\":117},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"5e302630-d490-461f-9abd-631b62dc3a94\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" from the Tibetan:\",\"attrs\":{\"start\":117,\"end\":135}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"387ad345-59ab-4975-8ef8-143de45a6f61\",\"sort\":1605,\"type\":\"introductionHeader\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":4,\"start\":0,\"end\":43,\"uuid\":\"5f384487-e9d6-48f2-9b77-44acd073dd48\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"1. Identifying and organizing source texts \",\"attrs\":{\"start\":0,\"end\":43}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"011356ac-2d68-40f8-8b24-0a3717f5c44c\",\"sort\":1607,\"type\":\"introduction\",\"label\":\"i.29\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":2398,\"uuid\":\"011356ac-2d68-40f8-8b24-0a3717f5c44c\"},\"content\":[{\"type\":\"text\",\"text\":\"I first collated all the available Tibetan editions of \",\"attrs\":{\"start\":0,\"end\":55}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana\",\"attrs\":{\"start\":55,\"end\":71},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"19d2b87b-49bc-4afd-8877-ff9fcb8df102\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\": Bd, C, D, Dunhuang (Hakayama 1984–87), Do, F, H, L, N, S, K\",\"attrs\":{\"start\":71,\"end\":132}},{\"type\":\"text\",\"text\":\"ǫ\",\"attrs\":{\"start\":132,\"end\":133},\"marks\":[{\"type\":\"smallCaps\",\"attrs\":{\"start\":132,\"end\":133,\"uuid\":\"55a397a7-ff55-48f8-abd6-124f45af084d\",\"type\":\"span\",\"textStyle\":\"small-caps\"}}]},{\"type\":\"text\",\"text\":\", U, VD, X, and Z, as well as the various extant Sanskrit fragments found in Buescher (2007), Levi (1925), Matsuda (1995, 2013), Nagao (1964), and Tucci (1971). For the Chinese, we used Xuanzang’s translation.\",\"attrs\":{\"start\":133,\"end\":342},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"53459703-d98d-4a0e-b4fe-572848edca3d\",\"label\":\"10\",\"uuid\":\"0e66c9fd-a076-4a49-b56c-45995091c08d\",\"start\":342,\"end\":342,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" I then produced a critical edition of the text prologue (\",\"attrs\":{\"start\":342,\"end\":400}},{\"type\":\"text\",\"text\":\"nidāna\",\"attrs\":{\"start\":400,\"end\":406},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"72f80123-e9e7-421f-a43f-59ce107c9879\",\"uuid\":\"c907e830-44f0-4957-8c92-6101254f8ea9\",\"toh\":null,\"start\":400,\"end\":0}},{\"type\":\"italic\",\"attrs\":{\"start\":400,\"end\":406,\"uuid\":\"1ced5a12-5d70-4fa7-abba-c54a2665f4b2\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\") to get a sense of the textual variations across major available editions of the Tshalpa (\",\"attrs\":{\"start\":406,\"end\":497}},{\"type\":\"text\",\"text\":\"tshal pa\",\"attrs\":{\"start\":497,\"end\":505},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":497,\"end\":505,\"uuid\":\"a9c65f76-7aa8-4737-abde-096735553693\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"), Thempangma (\",\"attrs\":{\"start\":505,\"end\":520}},{\"type\":\"text\",\"text\":\"them spangs ma\",\"attrs\":{\"start\":520,\"end\":534},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":520,\"end\":534,\"uuid\":\"a26999cb-dd41-46c9-be32-be87fb371f6f\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"), mixed Kangyurs, and independent Kangyur groups. In addition, Dr. Kojirō Katō (Tokyo University), who is editing the \",\"attrs\":{\"start\":534,\"end\":653}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana­sūtra\",\"attrs\":{\"start\":653,\"end\":675},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"095689c0-7abf-46e3-9cbc-6f3aa6c21325\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\", kindly sent me his critical edition of the seventh chapter.\",\"attrs\":{\"start\":675,\"end\":736},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"5f0ec2e8-9633-4de1-adca-ca46946d317a\",\"label\":\"11\",\"uuid\":\"9dabbfc1-0384-4cb6-b186-040376c9002b\",\"start\":736,\"end\":736,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" His work has proved invaluable to confirming the findings of my own work on the prologue. The editions belonging to the Thempangma differ significantly from those included in the Tshalpa line of transmission. As an independent Kangyur close to the Thempangma line, the Phukdrak (\",\"attrs\":{\"start\":736,\"end\":1016}},{\"type\":\"text\",\"text\":\"phug brag\",\"attrs\":{\"start\":1016,\"end\":1025},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":1016,\"end\":1025,\"uuid\":\"479bd9ee-30b3-4602-84f8-42c9034cdd8f\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\") edition offers very interesting readings on the level of syntax and lexicography compared to the editions of the Tshalpa group. It also diverges from the Thempangma witnesses in many locations. In the absence of colophons mentioning the translators’ and editors’ names across the available editions, it remains difficult to understand the history of these witnesses from the perspective of the underlying translation and editing process. As a consequence of its palatable variant readings compared to the Tshalpa and Thempangma editions, I used the Phukdrak witness quite extensively while translating the Degé edition, as well as the Stok edition and the Degé version of the \",\"attrs\":{\"start\":1025,\"end\":1703}},{\"type\":\"text\",\"text\":\"Viniścaya­saṃ­grahaṇī\",\"attrs\":{\"start\":1703,\"end\":1724},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"b7d8038d-6ac7-4057-aaf4-4621a82ab965\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\", to examine more thoroughly difficult passages. The available Sanskrit fragments were on occasion also useful to determine the Sanskrit equivalent of a Tibetan technical term. They, however, did not reveal major variations from the Tibetan texts. I referred to the Dunhuang recension sporadically, as Schmithausen warned us not to follow it blindly.\",\"attrs\":{\"start\":1724,\"end\":2074},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"d787562e-67c7-4869-9aa8-5165aa266db6\",\"label\":\"12\",\"uuid\":\"5786258b-20cc-4a23-8aef-065e49a1b610\",\"start\":2074,\"end\":2074,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" I also referred to Xuanzang’s translation regarding a few difficult passages of the text. This translation is similar to those of the Tshalpa group and might have been carried out on the basis of a Sanskrit manuscript similar to the one (or those) used for the translation upon which the Tibetan Tshalpa editions are based.\",\"attrs\":{\"start\":2074,\"end\":2398}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"dd10ac01-fbed-49e8-8c80-f45df2ce5853\",\"sort\":1632,\"type\":\"introductionHeader\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":4,\"start\":0,\"end\":40,\"uuid\":\"e0718ffe-93c2-484a-887f-52d056760bda\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"2. Evaluating the available translations\",\"attrs\":{\"start\":0,\"end\":40}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"ddd03bb4-68be-427b-a2ea-d25d5d74a5c9\",\"sort\":1634,\"type\":\"introduction\",\"label\":\"i.30\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1613,\"uuid\":\"ddd03bb4-68be-427b-a2ea-d25d5d74a5c9\"},\"content\":[{\"type\":\"text\",\"text\":\"The \",\"attrs\":{\"start\":0,\"end\":4}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana­sūtra\",\"attrs\":{\"start\":4,\"end\":26},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"3ab2b4fc-26c9-4020-89d3-b5d2c58ad476\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" is a major text of Indian Buddhism that has early on attracted the attention of Buddhist Studies scholars. It has been translated into French, English, and German (partially). Lamotte (1935) provided a critical edition of \",\"attrs\":{\"start\":26,\"end\":249}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana\",\"attrs\":{\"start\":249,\"end\":265},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"556139a7-f0b7-4158-8bc6-93825fe52324\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" and a translation from Tibetan (N) and Chinese (Taishō 676) into French. He also attempted to reconstruct or identify technical terms in Sanskrit, which have for the most part been confirmed by subsequent finds of Sanskrit fragments.\",\"attrs\":{\"start\":265,\"end\":499},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"4c2ecce6-13bd-4a93-8c06-b3742cd3b7a3\",\"label\":\"13\",\"uuid\":\"e642ba86-ce61-47df-9023-be9fa237a982\",\"start\":499,\"end\":499,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" Lamotte’s work is a major resource for the study of \",\"attrs\":{\"start\":499,\"end\":552}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana\",\"attrs\":{\"start\":552,\"end\":568},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"134f5665-659c-4dd9-a68a-a7b493cdbe0f\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\". It has been until now the standard edition and translation of this text on account of its accuracy and methodological academic approach. As a side note, I followed Lamotte’s segmentation of the text into paragraphs. His French translation is generally reliable, although some technical passages can be significantly improved, particularly in the case of chapter 8 on meditation and chapter 10 on the result of the path. Frauwallner (1969) gives a partial translation of \",\"attrs\":{\"start\":568,\"end\":1040}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana\",\"attrs\":{\"start\":1040,\"end\":1056},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"ac9ff13a-e347-4a49-82a0-2fe243774577\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" (i.e., chapters 6 and 7) from Tibetan into German. As one would expect, Frauwallner’s academic translation of these two chapters aims at accuracy over readability. Kawasaki 1976 is also a partial translation of chapter 8 into English (§6.1–9). This translation does not improve Lamotte’s. Powers’ (1995) translation from Tibetan (D) into English, in spite of its merit, could be widely improved upon in terms of methodology, accuracy, and readability.\",\"attrs\":{\"start\":1056,\"end\":1508},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"f28ad666-e1bd-4d3a-9104-f89ab7496941\",\"label\":\"14\",\"uuid\":\"962d27ce-f54b-4316-8f03-d036200abe8a\",\"start\":1508,\"end\":1508,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" Brunnhölzl 2018 offers a partial translation of chapter 7, as well as a few key passages from chapter 5.\",\"attrs\":{\"start\":1508,\"end\":1613}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"7eac3997-ba27-466c-b288-602986ac0a3a\",\"sort\":1648,\"type\":\"introduction\",\"label\":\"i.31\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1021,\"uuid\":\"7eac3997-ba27-466c-b288-602986ac0a3a\"},\"content\":[{\"type\":\"text\",\"text\":\"Translations by Cleary (1999) and Keenan (2000) are from the Chinese (Taishō 676) into English. I used Keenan’s work to get a sense of the Chinese text while translating the Degé edition but only referred to Cleary occasionally. Keenan’s work seems to me more accurate than Cleary’s, although the latter was useful for unraveling difficult passages, since his style is more free and primarily intends to communicate the meaning of the text. Cornu (2005) has provided a translation of the text from Tibetan (D) into French that mainly follows Powers 1995, a somewhat regrettable fact since Lamotte’s (1935) is more accurate. Schmithausen’s (2014) work contains numerous difficult passages of \",\"attrs\":{\"start\":0,\"end\":691}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana\",\"attrs\":{\"start\":691,\"end\":707},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"f071df85-604b-49f1-a79f-2e5e3e5c5ad0\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" translated from various Tibetan and Chinese editions into English. It is an invaluable resource for the study of \",\"attrs\":{\"start\":707,\"end\":821}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana\",\"attrs\":{\"start\":821,\"end\":837},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"b4209f12-13fa-4aa8-84a6-d65f7bffc99f\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\". In addition, it offers useful Sanskrit reconstructions of important technical terms. Together with Lamotte’s translation, it has been a constant companion while translating the text.\",\"attrs\":{\"start\":837,\"end\":1021}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"b8fea6c9-362a-49a0-9bc2-e4fb01ed0cb7\",\"sort\":1655,\"type\":\"introductionHeader\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":4,\"start\":0,\"end\":78,\"uuid\":\"a7a98120-374c-4692-b9dc-f7b6d9713edc\",\"class\":\"section-title\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"9be03bb9-6e02-4f4b-a7ec-2059b156332a\"},\"content\":[{\"type\":\"text\",\"text\":\"3. Checking intertextual patterns and delineating the scope of primary sources\",\"attrs\":{\"start\":0,\"end\":78}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"bf28395f-249e-400b-aa1f-3843fb1c2199\",\"sort\":1657,\"type\":\"introduction\",\"label\":\"i.32\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":101,\"uuid\":\"bf28395f-249e-400b-aa1f-3843fb1c2199\"},\"content\":[{\"type\":\"text\",\"text\":\"The \",\"attrs\":{\"start\":0,\"end\":4}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana­sūtra\",\"attrs\":{\"start\":4,\"end\":26},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"c52b053f-fa67-492e-97e3-ddc69651bcd2\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" is part of a larger network of texts, both in the Kangyur and the Tengyur:\",\"attrs\":{\"start\":26,\"end\":101}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"9bf13061-050b-45f8-b9d8-674474c97246\",\"sort\":1661,\"type\":\"introduction\",\"label\":\"i.33\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":439,\"uuid\":\"9bf13061-050b-45f8-b9d8-674474c97246\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"ead29f4e-1a35-4483-958f-9cedf44254ef\"},\"content\":[{\"type\":\"text\",\"text\":\"1. The \",\"attrs\":{\"start\":0,\"end\":7}},{\"type\":\"text\",\"text\":\"nidāna\",\"attrs\":{\"start\":7,\"end\":13},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"72f80123-e9e7-421f-a43f-59ce107c9879\",\"uuid\":\"cb34742c-850f-43df-9ecc-64443623ee96\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of \",\"attrs\":{\"start\":13,\"end\":17}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana\",\"attrs\":{\"start\":17,\"end\":33},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"f1d28086-9162-4295-bd91-7aa0fbc22710\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" almost exactly matches those of the \",\"attrs\":{\"start\":33,\"end\":70}},{\"type\":\"text\",\"text\":\"Buddha­bhūmi­sūtra\",\"attrs\":{\"start\":70,\"end\":88},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"ccbecb05-e8d3-44f7-b57f-509310c1ec98\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" (D275) and the \",\"attrs\":{\"start\":88,\"end\":104}},{\"type\":\"text\",\"text\":\"Tathāgata­guṇa­jñānā­cintyaviṣayāva­tāra­nirdeśa­sūtra\",\"attrs\":{\"start\":104,\"end\":158},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"a572a3da-436e-40f8-80b4-1d6551f7d9c6\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" (D185). The \",\"attrs\":{\"start\":158,\"end\":171}},{\"type\":\"text\",\"text\":\"Buddha­bhūmi­sūtra\",\"attrs\":{\"start\":171,\"end\":189},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"5474b536-5f1c-4921-8f89-96671e461ca8\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" is a very short text that was also translated into Chinese by Xuanzang in 646 (see Keenan 1980, p. 336ff.). Textual parallelisms of this kind are useful to double checking some passages or gathering more background information about the source text.\",\"attrs\":{\"start\":189,\"end\":439}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"9e623e83-79d9-4269-bd12-c350f4c96a5a\",\"sort\":1673,\"type\":\"introduction\",\"label\":\"i.34\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":923,\"uuid\":\"9e623e83-79d9-4269-bd12-c350f4c96a5a\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"a54f2958-3048-4fda-9e05-ee55acf81df0\"},\"content\":[{\"type\":\"text\",\"text\":\"2. As mentioned above, \",\"attrs\":{\"start\":0,\"end\":23}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana\",\"attrs\":{\"start\":23,\"end\":39},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"e2819ad2-b9e2-4756-a1f4-a435fda3629a\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" is also found \",\"attrs\":{\"start\":39,\"end\":54}},{\"type\":\"text\",\"text\":\"in extenso\",\"attrs\":{\"start\":54,\"end\":64},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":54,\"end\":64,\"uuid\":\"81087c34-2ae8-4981-b7bb-81ae4f587a04\",\"type\":\"span\",\"textStyle\":\"distinct\"}}]},{\"type\":\"text\",\"text\":\" in the \",\"attrs\":{\"start\":64,\"end\":72}},{\"type\":\"text\",\"text\":\"Viniścaya­saṃ­grahaṇī\",\"attrs\":{\"start\":72,\"end\":93},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"02779fd8-74f7-47c2-b80e-0d4cd82cdff8\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" of the \",\"attrs\":{\"start\":93,\"end\":101}},{\"type\":\"text\",\"text\":\"Yogācāra­bhūmi\",\"attrs\":{\"start\":101,\"end\":115},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"b00ff18e-77ad-4991-af43-242ae26d72b1\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" and is therefore part of a tradition of texts sharing common ideas.\",\"attrs\":{\"start\":115,\"end\":183},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"dddaaf62-52dd-4e7f-bc3b-e5bd3b633e6d\",\"label\":\"15\",\"uuid\":\"b6c9179f-94b3-4f13-8fce-0340a09b63bb\",\"start\":183,\"end\":183,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" This point should be kept in \",\"attrs\":{\"start\":183,\"end\":213}},{\"type\":\"text\",\"text\":\"mind\",\"attrs\":{\"start\":213,\"end\":217},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b667709c-9e2a-4877-96d5-8b056867ac96\",\"uuid\":\"1ad0c98d-1d52-4dad-a7ce-10a1320d4aaf\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" while translating, particularly when one has to evaluate the potential impact of terminological choices from the perspective of a more philosophical approach to the text, which, in the case of \",\"attrs\":{\"start\":217,\"end\":411}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana\",\"attrs\":{\"start\":411,\"end\":427},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"6c880f83-bda7-4c0f-9b82-7198202312a3\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\", should be a major concern. For example, one should pay attention to the fact that interpreting “representation-only” (\",\"attrs\":{\"start\":427,\"end\":547}},{\"type\":\"text\",\"text\":\"vijñaptimātra\",\"attrs\":{\"start\":547,\"end\":560},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":547,\"end\":560,\"uuid\":\"d7d7727c-1597-4f7b-9045-d282aceff015\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8fe6483c-7a2f-4114-886e-1185bf09c76d\",\"uuid\":\"771c023c-710a-4bd4-8379-5561228981dc\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\") as a strong form of idealism essentializing \",\"attrs\":{\"start\":560,\"end\":606}},{\"type\":\"text\",\"text\":\"mind\",\"attrs\":{\"start\":606,\"end\":610},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b667709c-9e2a-4877-96d5-8b056867ac96\",\"uuid\":\"3b336ce7-ffc8-4aec-9d28-aabf88ad1e84\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" could be misleading from the perspective of a cultural translation of the worldview propounded in \",\"attrs\":{\"start\":610,\"end\":709}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana\",\"attrs\":{\"start\":709,\"end\":725},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"c01f8e65-4bb8-4b89-9a1d-1e1c46473960\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" since \",\"attrs\":{\"start\":725,\"end\":732}},{\"type\":\"text\",\"text\":\"mind\",\"attrs\":{\"start\":732,\"end\":736},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b667709c-9e2a-4877-96d5-8b056867ac96\",\"uuid\":\"377ecac6-6454-418a-880e-18cbb7f6c017\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", just as much as the external \",\"attrs\":{\"start\":736,\"end\":767}},{\"type\":\"text\",\"text\":\"object\",\"attrs\":{\"start\":767,\"end\":773},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cf9988ae-d23d-4a8e-a24a-2f5503ee7f00\",\"uuid\":\"db0b759f-7250-40d0-b363-121ca881a7f8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", is explicitly declared to be empty of any own-being, \",\"attrs\":{\"start\":773,\"end\":828}},{\"type\":\"text\",\"text\":\"essence\",\"attrs\":{\"start\":828,\"end\":835},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"47c8923c-56be-43d8-b398-ff4290cece41\",\"uuid\":\"ca3a78ed-beb4-4d37-bc67-1d106f1cf3b1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", or intrinsic nature (see chapter 8 on the three kinds of \",\"attrs\":{\"start\":835,\"end\":894}},{\"type\":\"text\",\"text\":\"niḥsva­bhāvatā\",\"attrs\":{\"start\":894,\"end\":908},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":894,\"end\":908,\"uuid\":\"2d3fa509-98fd-4405-bc2f-0f82bfa1b630\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"511f85e3-f5bd-4380-81c7-87048ba56676\",\"uuid\":\"68e3bb89-9c38-41a5-9746-8fc49e67884d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\") in this text.\",\"attrs\":{\"start\":908,\"end\":923},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"8279c9d8-09d6-43d8-af20-a74391550fd5\",\"label\":\"16\",\"uuid\":\"1e66a9fd-178c-4417-b8af-df556d1bdb0f\",\"start\":923,\"end\":923,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"f725177d-0c33-45d0-9b63-80b626cf2c60\",\"sort\":1704,\"type\":\"introduction\",\"label\":\"i.35\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":585,\"uuid\":\"f725177d-0c33-45d0-9b63-80b626cf2c60\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"877a85d1-78f8-4324-87a7-9898227fbcdc\"},\"content\":[{\"type\":\"text\",\"text\":\"3. Another important point is the presence of the aforementioned five commentaries on \",\"attrs\":{\"start\":0,\"end\":86}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana\",\"attrs\":{\"start\":86,\"end\":102},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"6791114d-c627-4678-a4e1-1b93b3584fed\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" found in the Tengyur (D).\",\"attrs\":{\"start\":102,\"end\":128},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"5cce3953-6e87-4749-80cf-cfa7a1fba899\",\"label\":\"17\",\"uuid\":\"9d24ef25-f27f-450f-8eb7-d29b184d6739\",\"start\":128,\"end\":128,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" I occasionally referred to these works while finalizing the final draft of the translation. However, I first focused on the available editions of \",\"attrs\":{\"start\":128,\"end\":275}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana\",\"attrs\":{\"start\":275,\"end\":291},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"2d81b153-d638-493e-95bb-a656f8bf84a8\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" itself as I did not want to be influenced by the interpretations of later authors. Instead, I attempted to go through all possible logically meaningful readings according to the Tibetan and Sanskrit sources without any preconceptions resulting from my reading of later commentarial traditions.\",\"attrs\":{\"start\":291,\"end\":585}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"23f343be-f960-465b-a03f-b4c19b7c2dd0\",\"sort\":1712,\"type\":\"introduction\",\"label\":\"i.36\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":614,\"uuid\":\"23f343be-f960-465b-a03f-b4c19b7c2dd0\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"9655f8ec-d84e-4144-87dc-0a1acee5e534\"},\"content\":[{\"type\":\"text\",\"text\":\"4. In the same vein, one should note that \",\"attrs\":{\"start\":0,\"end\":42}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana\",\"attrs\":{\"start\":42,\"end\":58},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"998b56c9-14f7-4361-8ebf-6dbd4abd6b53\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" has played a major role in Tibetan hermeneutical debates. For centuries, it has been considered a central scripture referred to extensively in the writings of Tibet’s great luminaries, such as Jé Tsongkhapa (\",\"attrs\":{\"start\":58,\"end\":267}},{\"type\":\"text\",\"text\":\"rje tsong kha pa\",\"attrs\":{\"start\":267,\"end\":283},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":267,\"end\":283,\"uuid\":\"754cee68-119a-44bf-9466-769cec085bc6\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", 1357–1419) or Jamgön Mipham Gyatso (\",\"attrs\":{\"start\":283,\"end\":321}},{\"type\":\"text\",\"text\":\"’jam mgon mi pham rgya mtsho\",\"attrs\":{\"start\":321,\"end\":349},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":321,\"end\":349,\"uuid\":\"4df6329b-8319-42de-899e-c5fdceebb677\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", 1846–1912). While it would certainly be fascinating to study the impact of \",\"attrs\":{\"start\":349,\"end\":426}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana\",\"attrs\":{\"start\":426,\"end\":442},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"34eb06ce-529b-4506-a494-f63b894cf132\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" in the context of Tibetan Madhyamaka,\",\"attrs\":{\"start\":442,\"end\":480},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"d82aa9bc-f62f-4e92-addc-802edbed7752\",\"label\":\"18\",\"uuid\":\"4879fda6-2119-4cff-bb2f-b6580fc53f9c\",\"start\":480,\"end\":480,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" I chose not to take into account Indian or Tibetan commentaries or exegeses of the sūtra in order to focus on the source text itself.\",\"attrs\":{\"start\":480,\"end\":614}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"75133e4d-62b8-4609-b698-e7a815ebd745\",\"sort\":1723,\"type\":\"introductionHeader\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":4,\"start\":0,\"end\":30,\"uuid\":\"e845b707-53e1-4c28-82a1-49c38cd556f5\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"4. Collating academic research\",\"attrs\":{\"start\":0,\"end\":30}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"87651cba-7737-4477-bcac-8a05d9372204\",\"sort\":1725,\"type\":\"introduction\",\"label\":\"i.37\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":586,\"uuid\":\"87651cba-7737-4477-bcac-8a05d9372204\"},\"content\":[{\"type\":\"text\",\"text\":\"I proceeded to search all articles and monographs referring to \",\"attrs\":{\"start\":0,\"end\":63}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana\",\"attrs\":{\"start\":63,\"end\":79},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"a588d0a5-938c-4fc0-8157-192d659f5518\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" I could find at the very beginning of this translation project. In this quest for relevant academic research, I benefited from the excellent bibliography found in Delhey 2013 regarding research done on the \",\"attrs\":{\"start\":79,\"end\":286}},{\"type\":\"text\",\"text\":\"Viniścaya­saṃ­grahaṇī\",\"attrs\":{\"start\":286,\"end\":307},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"cd0a15c1-9147-45ca-9197-6b21b8c28347\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" of the \",\"attrs\":{\"start\":307,\"end\":315}},{\"type\":\"text\",\"text\":\"Yogācāra­bhūmi\",\"attrs\":{\"start\":315,\"end\":329},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"bc7103fe-10b1-4a6f-ae0a-de9d2360b195\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\", which I expanded with a list of complementary reference works (see the bibliography). Among the existing academic literature on \",\"attrs\":{\"start\":329,\"end\":459}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana\",\"attrs\":{\"start\":459,\"end\":475},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"04225fd8-b0d9-415d-91a5-beda0f280115\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\", Schmithausen 2014 stands out and, unsurprisingly, proved to be a major resource for this translation project.\",\"attrs\":{\"start\":475,\"end\":586}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"8e20fba4-b262-4883-b52a-cc35f9aba6b3\",\"sort\":1734,\"type\":\"introductionHeader\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":4,\"start\":0,\"end\":96,\"uuid\":\"ffa3089f-83c9-4244-b89e-df9a06fa75cc\",\"class\":\"section-title\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"5d89f46f-1b20-4c65-bd6e-d3e20d33a7d1\"},\"content\":[{\"type\":\"text\",\"text\":\"5. Organizing academic resources according to the text structure and specific translation issues\",\"attrs\":{\"start\":0,\"end\":96}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"e960a63b-3657-4798-b6ff-6deaadfc1904\",\"sort\":1736,\"type\":\"introduction\",\"label\":\"i.38\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":652,\"uuid\":\"e960a63b-3657-4798-b6ff-6deaadfc1904\"},\"content\":[{\"type\":\"text\",\"text\":\"1. The translation of the title of the text became the object of several discussions among scholars regarding the meaning of the Sanskrit words \",\"attrs\":{\"start\":0,\"end\":144}},{\"type\":\"text\",\"text\":\"saṃdhi\",\"attrs\":{\"start\":144,\"end\":150},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":144,\"end\":150,\"uuid\":\"678186e5-cc68-40a7-8497-21a287cdbdf7\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" and \",\"attrs\":{\"start\":150,\"end\":155}},{\"type\":\"text\",\"text\":\"nirmocana\",\"attrs\":{\"start\":155,\"end\":164},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":155,\"end\":164,\"uuid\":\"0d264a08-1fbf-4128-a72a-3155d889d445\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" as a consequence of Lamotte’s first complete translation of the text.\",\"attrs\":{\"start\":164,\"end\":234},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"97d3940d-5b4a-43ef-a00b-eee1ec1f21a3\",\"label\":\"19\",\"uuid\":\"39545e7b-1d0c-40c8-95ec-acaf04d71640\",\"start\":234,\"end\":234,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" Among the various available options, I opted for simplicity and translated the Sanskrit \",\"attrs\":{\"start\":234,\"end\":323}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana­sūtra\",\"attrs\":{\"start\":323,\"end\":345},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":323,\"end\":345,\"uuid\":\"266df5da-6217-4ef8-914e-ae7a6c3ecf95\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" with “The Sūtra Unraveling the Intent,” which I believe renders accurately the meaning and structure of the text. Various interlocutors indeed ask the Buddha repeatedly to explain difficult points in order to clarify the purpose of his seemingly contradictory or complex doctrines on the nature of reality.\",\"attrs\":{\"start\":345,\"end\":652}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"0cb0abe3-eec7-4b25-a13a-8d3c1d497969\",\"sort\":1750,\"type\":\"introduction\",\"label\":\"i.39\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":532,\"uuid\":\"0cb0abe3-eec7-4b25-a13a-8d3c1d497969\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"bd134d61-96f2-47aa-9bca-b4417429c93b\"},\"content\":[{\"type\":\"text\",\"text\":\"2. Regarding the content of the sūtra itself, I proceeded to organize secondary sources by chapter and referenced this research in the notes accompanying my translation.\",\"attrs\":{\"start\":0,\"end\":169},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"0fc6b001-2f38-41c8-b9f0-f83ebb9d6554\",\"label\":\"20\",\"uuid\":\"cff7fd95-2da8-462f-9d95-90a6c9710017\",\"start\":169,\"end\":169,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" The last chapter of \",\"attrs\":{\"start\":169,\"end\":190}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana\",\"attrs\":{\"start\":190,\"end\":206},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"804d2aaa-26a0-4eb4-afbd-4e8d1cc63d51\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" includes a very technical passage on \",\"attrs\":{\"start\":206,\"end\":244}},{\"type\":\"text\",\"text\":\"valid cognition\",\"attrs\":{\"start\":244,\"end\":259},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e3a57f81-276c-45e4-ac8c-fbf09cd85d41\",\"uuid\":\"6e8dfe0e-d73a-4634-86f1-901a60f36877\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":259,\"end\":261}},{\"type\":\"text\",\"text\":\"pramāṇa\",\"attrs\":{\"start\":261,\"end\":268},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":261,\"end\":268,\"uuid\":\"2a4f2afc-fecd-45f6-8233-9fe519782df0\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\") whose definitions predate Dignāga’s system of logic. Translating Trisong Detsen’s *\",\"attrs\":{\"start\":268,\"end\":353}},{\"type\":\"text\",\"text\":\"Samyagvāk­pramāṇoddhṛta­sūtra\",\"attrs\":{\"start\":353,\"end\":382},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"01855c24-90dc-4246-a409-6cf917f42d3e\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\", which is a commentary on the teaching on the four \",\"attrs\":{\"start\":382,\"end\":434}},{\"type\":\"text\",\"text\":\"principles of reason\",\"attrs\":{\"start\":434,\"end\":454},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"465226ef-0ce7-4dc6-ab88-5bc18ee29c4b\",\"uuid\":\"6093112d-9cfe-47b1-863b-26aec62b43ac\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":454,\"end\":456}},{\"type\":\"text\",\"text\":\"rigs pa bzhi\",\"attrs\":{\"start\":456,\"end\":468},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":456,\"end\":468,\"uuid\":\"9d53be22-7b3a-4fed-bc92-120ca8a88eb3\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"), would help us better understand pre-Dignāgean Buddhist logic.\",\"attrs\":{\"start\":468,\"end\":532},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"1d8a8abb-6d13-4a9a-b134-d70e1168def2\",\"label\":\"21\",\"uuid\":\"1fdd6697-8678-457e-ad0e-09c381a083d5\",\"start\":532,\"end\":532,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"33f1bcae-b04a-41b0-a5de-db735b288513\",\"sort\":1766,\"type\":\"introductionHeader\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":5,\"start\":0,\"end\":20,\"uuid\":\"c6041e67-89ee-416f-8143-6ca958f10106\",\"class\":\"section-title\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"51486b56-a8ce-4d09-a669-531021075412\"},\"content\":[{\"type\":\"text\",\"text\":\"Translating the text\",\"attrs\":{\"start\":0,\"end\":20}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"fa9932a4-f575-44b8-bd1a-0f1affe54ec4\",\"sort\":1768,\"type\":\"introduction\",\"label\":\"i.40\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":182,\"uuid\":\"fa9932a4-f575-44b8-bd1a-0f1affe54ec4\"},\"content\":[{\"type\":\"text\",\"text\":\"In this \",\"attrs\":{\"start\":0,\"end\":8}},{\"type\":\"text\",\"text\":\"stage\",\"attrs\":{\"start\":8,\"end\":13},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4e64e8cc-e904-47f6-8554-e8273dd3587a\",\"uuid\":\"d863c854-167c-45ab-977b-cf683d97a04c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of the overall process, I followed Jean-François Billeter’s pragmatic approach to the translation of classical Chinese texts. This approach consists in five operations:\",\"attrs\":{\"start\":13,\"end\":182},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"ef23f519-a216-44d7-81be-ae28c8875753\",\"label\":\"22\",\"uuid\":\"6e3b0520-6cb0-45d9-92bd-764bbeb3eb07\",\"start\":182,\"end\":182,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"6c72038a-3262-4d5d-9bee-60d1dc1a95b7\",\"sort\":1773,\"type\":\"introduction\",\"label\":\"i.41\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":623,\"uuid\":\"6c72038a-3262-4d5d-9bee-60d1dc1a95b7\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"ea7110e4-ec2b-4604-bf79-cf29edd59705\"},\"content\":[{\"type\":\"text\",\"text\":\"1. The first \",\"attrs\":{\"start\":0,\"end\":13}},{\"type\":\"text\",\"text\":\"stage\",\"attrs\":{\"start\":13,\"end\":18},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4e64e8cc-e904-47f6-8554-e8273dd3587a\",\"uuid\":\"1aedd645-2cc7-42c4-990a-e5f1f35ce2a9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of the translation process is purely analytical. A passage is translated on the basis of lexicographical resources (e.g., dictionaries) and syntactic rules (e.g., grammars). During this operation, it is important to \",\"attrs\":{\"start\":18,\"end\":235}},{\"type\":\"text\",\"text\":\"distinguish\",\"attrs\":{\"start\":235,\"end\":246},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bddb0c1a-c339-4394-8d79-bb80288cd87e\",\"uuid\":\"b8fb97a1-dfe3-4629-a0de-8f86f6ea6d9d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" what is understood and what still remains problematic. All options should be kept open. Interpretations or eisegetical readings should be rejected. From a practical perspective, I systematically used the \",\"attrs\":{\"start\":246,\"end\":451}},{\"type\":\"text\",\"text\":\"Mahāvyutpatti\",\"attrs\":{\"start\":451,\"end\":464},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"f1e066bf-3fd9-46e4-840f-3482362796b8\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" to find the Sanskrit terms behind general Tibetan expressions. For technical terms, I relied on Schmithausen (2014) and the academic research mentioned above.\",\"attrs\":{\"start\":464,\"end\":623}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"c8fd513b-08cb-4c6f-adc9-7d989c34979f\",\"sort\":1781,\"type\":\"introduction\",\"label\":\"i.42\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1180,\"uuid\":\"c8fd513b-08cb-4c6f-adc9-7d989c34979f\"},\"content\":[{\"type\":\"text\",\"text\":\"Our Tibetan text is itself a translation. This somewhat complicates our task since we have to decipher the Sanskrit behind the Tibetan in order to make sense of some difficult sentences or passages. However, this approach is necessary on a lexicographical and syntactic level as can be seen in the following examples: One should read the Tibetan \",\"attrs\":{\"start\":0,\"end\":346}},{\"type\":\"text\",\"text\":\"brtsams pa\",\"attrs\":{\"start\":346,\"end\":356},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":346,\"end\":356,\"uuid\":\"51e0949e-6d48-4f2a-9008-bebfb1b22699\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" as \",\"attrs\":{\"start\":356,\"end\":360}},{\"type\":\"text\",\"text\":\"ārabhya\",\"attrs\":{\"start\":360,\"end\":367},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":360,\"end\":367,\"uuid\":\"a4743c76-909f-47a7-b20d-feb30e510364\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", a Buddhist hybrid Sanskrit expression that has the meaning of “referring to/having to do with” and not “beginning with.”\",\"attrs\":{\"start\":367,\"end\":489},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"f1ff6d47-61fb-475c-85ba-6ce8ebb7cac7\",\"label\":\"23\",\"uuid\":\"53f3cefc-1c69-44de-bafb-d65975bd3522\",\"start\":489,\"end\":489,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" Likewise, \",\"attrs\":{\"start\":489,\"end\":500}},{\"type\":\"text\",\"text\":\"rab tu phye ba\",\"attrs\":{\"start\":500,\"end\":514},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":500,\"end\":514,\"uuid\":\"14afbc2b-a10e-4776-8ace-ff6507063447\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" stands for \",\"attrs\":{\"start\":514,\"end\":526}},{\"type\":\"text\",\"text\":\"prabhāvita\",\"attrs\":{\"start\":526,\"end\":536},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":526,\"end\":536,\"uuid\":\"a4ccd31d-06fd-4f70-8003-55f14ff3d5b5\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", which in the \",\"attrs\":{\"start\":536,\"end\":551}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana\",\"attrs\":{\"start\":551,\"end\":567},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"d9ca5fa2-6712-4855-9cca-4c7fab920355\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" means “\",\"attrs\":{\"start\":567,\"end\":575}},{\"type\":\"text\",\"text\":\"consisting in\",\"attrs\":{\"start\":575,\"end\":588},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"afc53781-0387-4f04-916f-8cd48b06c476\",\"uuid\":\"e7c58ead-06dd-4935-b2e5-a689e0963cfc\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"/\",\"attrs\":{\"start\":588,\"end\":589}},{\"type\":\"text\",\"text\":\"characterized as\",\"attrs\":{\"start\":589,\"end\":605},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bec5686e-d233-4767-9078-f8c7919dc20d\",\"uuid\":\"4216ce91-f6cf-486b-8832-d9f470f9a321\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"/characterized by” and not “distinguished.”\",\"attrs\":{\"start\":605,\"end\":648},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"22cbb211-7192-4c7b-bb28-109c35198347\",\"label\":\"24\",\"uuid\":\"7523935d-f2ea-4bba-8a2f-f5754c027fcc\",\"start\":648,\"end\":648,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" The problem is even more acute in the case of Sanskrit compounds that have been translated into Tibetan according to the way they were formulated in Sanskrit. As an illustration of this, compounds ending with \",\"attrs\":{\"start\":648,\"end\":858}},{\"type\":\"text\",\"text\":\"lakṣaṇa\",\"attrs\":{\"start\":858,\"end\":865},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":858,\"end\":865,\"uuid\":\"e84b23b9-a39c-417b-b67e-8d9e05d6d1f8\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e6185c2c-6566-40d4-a854-a5c1ae649cf9\",\"uuid\":\"510398bf-0dd0-4ec0-8b2b-f453d7bf1bab\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (Tib. \",\"attrs\":{\"start\":865,\"end\":872}},{\"type\":\"text\",\"text\":\"mtshan nyid\",\"attrs\":{\"start\":872,\"end\":883},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":872,\"end\":883,\"uuid\":\"01547ac2-1a84-403a-b78a-d8e557dc8315\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\") often make more sense in \",\"attrs\":{\"start\":883,\"end\":910}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana\",\"attrs\":{\"start\":910,\"end\":926},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"71f6db38-b09a-4993-9a8b-37d0dc7814a0\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" as \",\"attrs\":{\"start\":926,\"end\":930}},{\"type\":\"text\",\"text\":\"bahuvrīhi\",\"attrs\":{\"start\":930,\"end\":939},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2283dbd7-1426-4735-a42e-fa3085c70c20\",\"uuid\":\"0d9ff9ac-43e6-4c78-a961-8ba646ac2970\",\"toh\":null,\"start\":930,\"end\":0}},{\"type\":\"italic\",\"attrs\":{\"start\":930,\"end\":939,\"uuid\":\"e3b792d5-edf8-4bd6-8b2f-94c1f420332e\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" s than \",\"attrs\":{\"start\":939,\"end\":947}},{\"type\":\"text\",\"text\":\"karmadhāraya\",\"attrs\":{\"start\":947,\"end\":959},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b0ac2880-07b9-42f3-b9af-99161d3032ab\",\"uuid\":\"dad09df8-ef32-4dab-b179-d87d62e7a9cb\",\"toh\":null,\"start\":947,\"end\":0}},{\"type\":\"italic\",\"attrs\":{\"start\":947,\"end\":959,\"uuid\":\"7cbc7554-fb31-4caa-9032-cb10f785ef6f\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" s or \",\"attrs\":{\"start\":959,\"end\":965}},{\"type\":\"text\",\"text\":\"tatpuruṣa\",\"attrs\":{\"start\":965,\"end\":974},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9bd9c153-adda-44e8-a777-c891f1060bba\",\"uuid\":\"8a360adc-b88e-4d24-a6a3-c9ba3cf13287\",\"toh\":null,\"start\":965,\"end\":0}},{\"type\":\"italic\",\"attrs\":{\"start\":965,\"end\":974,\"uuid\":\"cecf714b-f42e-4205-8de4-a4489d52b148\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" s, not to mention \",\"attrs\":{\"start\":974,\"end\":993}},{\"type\":\"text\",\"text\":\"dvandva\",\"attrs\":{\"start\":993,\"end\":1000},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"af32ecfa-1b74-4d47-a27a-d2ab3965f2ac\",\"uuid\":\"5e7b3343-a93d-4500-9def-eb2088236acb\",\"toh\":null,\"start\":993,\"end\":0}},{\"type\":\"italic\",\"attrs\":{\"start\":993,\"end\":1000,\"uuid\":\"4b2ade1b-f925-4823-964a-e3b088946ec2\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" s. Lamotte thus reads \",\"attrs\":{\"start\":1000,\"end\":1023}},{\"type\":\"text\",\"text\":\"rtog ge kun las ’das mtshan nyid\",\"attrs\":{\"start\":1023,\"end\":1055},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":1023,\"end\":1055,\"uuid\":\"0e68c36c-f599-4bcd-9f92-54d26e3adb3e\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":1055,\"end\":1057}},{\"type\":\"text\",\"text\":\"sarva­tarka­samati­krāntalakṣaṇa\",\"attrs\":{\"start\":1057,\"end\":1089},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":1057,\"end\":1089,\"uuid\":\"7b2fc4a7-4ffc-4624-8c1d-ff73c556c630\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\") as a \",\"attrs\":{\"start\":1089,\"end\":1096}},{\"type\":\"text\",\"text\":\"bahuvrīhi\",\"attrs\":{\"start\":1096,\"end\":1105},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2283dbd7-1426-4735-a42e-fa3085c70c20\",\"uuid\":\"ba6d1d51-1b95-47b5-bf9b-29100eefba78\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\",\",\"attrs\":{\"start\":1105,\"end\":1106},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"61a2d6ad-c032-4745-806d-48e793d9a0dd\",\"label\":\"25\",\"uuid\":\"cf750f1f-d6b2-4c7f-b130-5e72c58530e6\",\"start\":1106,\"end\":1106,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" which I believe is appropriate in the context of the passage in question.\",\"attrs\":{\"start\":1106,\"end\":1180}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"1340376e-98a0-4ecd-9abe-7b2404d8e0ac\",\"sort\":1823,\"type\":\"introduction\",\"label\":\"i.43\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":707,\"uuid\":\"1340376e-98a0-4ecd-9abe-7b2404d8e0ac\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"b0560bc1-8719-474f-bb95-67eef74d3f28\"},\"content\":[{\"type\":\"text\",\"text\":\"2. Once a “technically correct” translation of the source text has been produced, Billeter advises us to \",\"attrs\":{\"start\":0,\"end\":105}},{\"type\":\"text\",\"text\":\"bring together\",\"attrs\":{\"start\":105,\"end\":119},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"6ffb5915-a151-47df-97a7-db6ca506d632\",\"uuid\":\"e1203e05-faac-4979-9ad2-856e112092df\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" the various elements of a sentence or a passage until we obtain a clear picture of what is said in the source text. This step therefore consists in understanding the meaning of the translated passage by literally \",\"attrs\":{\"start\":119,\"end\":333}},{\"type\":\"text\",\"text\":\"seeing\",\"attrs\":{\"start\":333,\"end\":339},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":333,\"end\":339,\"uuid\":\"318da1c2-af9f-4ac8-99be-cd129b220139\",\"type\":\"span\",\"textStyle\":\"emphasis\"}}]},{\"type\":\"text\",\"text\":\" (or visualizing) its meaning. In a way, the first operation is about \",\"attrs\":{\"start\":339,\"end\":409}},{\"type\":\"text\",\"text\":\"das Erklären\",\"attrs\":{\"start\":409,\"end\":421},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":409,\"end\":421,\"uuid\":\"60983ddf-d7c3-4f49-af85-54f38cc82d8e\",\"type\":\"span\",\"lang\":\"Zh-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" (“explanation”), while the second concerns \",\"attrs\":{\"start\":421,\"end\":465}},{\"type\":\"text\",\"text\":\"das Verstehen\",\"attrs\":{\"start\":465,\"end\":478},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":465,\"end\":478,\"uuid\":\"c3d6a1a5-8ffc-4ed0-92d9-4ea6b5e2f63f\",\"type\":\"span\",\"lang\":\"Zh-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" (“understanding”). In this sense, the latter uses the resources of one’s imagination and metalinguistic knowledge to establish connections with a web of meaning that is not restricted to the translated sentence or passage alone.\",\"attrs\":{\"start\":478,\"end\":707}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"f091dc64-00f6-441f-b465-a94f6dbed718\",\"sort\":1835,\"type\":\"introduction\",\"label\":\"i.44\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1471,\"uuid\":\"f091dc64-00f6-441f-b465-a94f6dbed718\"},\"content\":[{\"type\":\"text\",\"text\":\"The second operation is therefore a synthesis, a recognition of relations between meaning units of various orders (one would think here of the idea conveyed by \",\"attrs\":{\"start\":0,\"end\":160}},{\"type\":\"text\",\"text\":\"saṃjñā\",\"attrs\":{\"start\":160,\"end\":166},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a3757d91-e567-4ade-97ce-e3d6488dcec6\",\"uuid\":\"6916ea08-ab13-4b4b-8f79-26b713b37c9b\",\"toh\":null,\"start\":160,\"end\":0}},{\"type\":\"italic\",\"attrs\":{\"start\":160,\"end\":166,\"uuid\":\"da08f26e-09b4-42bd-90d8-6d1df4244755\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" and similar terms in which the \",\"attrs\":{\"start\":166,\"end\":198}},{\"type\":\"text\",\"text\":\"upasarga\",\"attrs\":{\"start\":198,\"end\":206},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":198,\"end\":206,\"uuid\":\"b70d4b29-f2a4-49e0-a6b1-31337ad52725\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":206,\"end\":207}},{\"type\":\"text\",\"text\":\"sam\",\"attrs\":{\"start\":207,\"end\":210},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":207,\"end\":210,\"uuid\":\"c5c43339-160d-446e-beac-7603af923da6\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"- plays a central role), whereas the first phase is analytical (in the sense of \",\"attrs\":{\"start\":210,\"end\":290}},{\"type\":\"text\",\"text\":\"vicāra\",\"attrs\":{\"start\":290,\"end\":296},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":290,\"end\":296,\"uuid\":\"f6ba43c4-b9ae-4eed-a9c5-f3c6ab6a7e04\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":296,\"end\":298}},{\"type\":\"text\",\"text\":\"vicāraṇa\",\"attrs\":{\"start\":298,\"end\":306},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":298,\"end\":306,\"uuid\":\"6a5e5b0d-1add-41fe-84c7-dfd4b864185a\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", and \",\"attrs\":{\"start\":306,\"end\":312}},{\"type\":\"text\",\"text\":\"vijñāna\",\"attrs\":{\"start\":312,\"end\":319},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":312,\"end\":320,\"uuid\":\"0dc58ee8-654f-49fd-a7f7-75c03bae8b1c\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2f9b275a-4384-48e1-82d5-36ad42fe9878\",\"uuid\":\"25ae1d25-38dc-43f1-8d8d-b35d1dc778de\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\",\",\"attrs\":{\"start\":319,\"end\":320},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":319,\"end\":320,\"uuid\":\"0dc58ee8-654f-49fd-a7f7-75c03bae8b1c\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" in which the upasarga \",\"attrs\":{\"start\":320,\"end\":343}},{\"type\":\"text\",\"text\":\"vi\",\"attrs\":{\"start\":343,\"end\":345},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":343,\"end\":345,\"uuid\":\"fae8e633-c82b-4d74-86ad-971a0e9dc291\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"- expresses the notion of taking apart). In fact, translators translate into the target language their \",\"attrs\":{\"start\":345,\"end\":448}},{\"type\":\"text\",\"text\":\"comprehension\",\"attrs\":{\"start\":448,\"end\":461},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f906d3b1-54d9-404c-b6f8-61b44462c590\",\"uuid\":\"ef4a28ff-7308-401c-9e49-b394c3a9a82b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of the source text. They actually never translate the text itself but their understanding or representation of ideas, situations, and emotions conveyed by a text. To illustrate this point, one could mention the problem, encountered by scholars, of translating terms related to meditative practice. The \",\"attrs\":{\"start\":461,\"end\":764}},{\"type\":\"text\",\"text\":\"Maitreya\",\"attrs\":{\"start\":764,\"end\":772},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"91e6a61d-94e5-4e5e-9d70-0c9f940e123e\",\"uuid\":\"262db6e2-8da7-42d2-8cdd-e3777cc3d0d0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" chapter of \",\"attrs\":{\"start\":772,\"end\":784}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana\",\"attrs\":{\"start\":784,\"end\":800},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"71a63c15-1579-486f-b054-bfc42adc41de\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" is probably the most difficult to understand if one is not familiar with Buddhist practice. Lamotte translates \",\"attrs\":{\"start\":800,\"end\":912}},{\"type\":\"text\",\"text\":\"manasikāra\",\"attrs\":{\"start\":912,\"end\":922},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":912,\"end\":922,\"uuid\":\"a28df703-c2c0-41ee-9235-62d600310883\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" with “réflection,” while Frauwallner uses “Beobachtung” (lit. “observation”). Both these translation choices obfuscate the meaning of what the term “\",\"attrs\":{\"start\":922,\"end\":1072}},{\"type\":\"text\",\"text\":\"directing one’s attention\",\"attrs\":{\"start\":1072,\"end\":1097},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f19bd612-2823-4192-89e9-c338ff237e73\",\"uuid\":\"1cd1d36d-4b41-4ec7-9cc0-476758b96248\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"” actually denotes. This is not in itself a major issue, but if such inaccuracies proliferate in the same passage or chapter, the meaning of the translation becomes unclear, although it may well be technically correct on a syntactic level and lexicographical perspective (at least when it comes to correctly identifying Tibetan technical terms on the basis of the Sanskrit).\",\"attrs\":{\"start\":1097,\"end\":1471}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"bb40c489-bc5f-4356-8831-6941b51d84dd\",\"sort\":1862,\"type\":\"introduction\",\"label\":\"i.45\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1334,\"uuid\":\"bb40c489-bc5f-4356-8831-6941b51d84dd\"},\"content\":[{\"type\":\"text\",\"text\":\"In the context of pre-Dignāgean Buddhist logic, chapter 10 represents another case in point. This chapter is indeed replete with abstruse concepts not belonging to the well-researched and documented later systems of Buddhist logic. In this case, translating the many occurrences of the connective particle \",\"attrs\":{\"start\":0,\"end\":306}},{\"type\":\"text\",\"text\":\"kyi\",\"attrs\":{\"start\":306,\"end\":309},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":306,\"end\":309,\"uuid\":\"9ac2e4d7-699b-45c4-90a0-1530957f48b8\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" in long compounds with the English preposition “of” will not help the reader much, though it will certainly give the translators the peace of \",\"attrs\":{\"start\":309,\"end\":452}},{\"type\":\"text\",\"text\":\"mind\",\"attrs\":{\"start\":452,\"end\":456},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b667709c-9e2a-4877-96d5-8b056867ac96\",\"uuid\":\"e2a54dbf-42ab-420d-a294-94f7aa6ca9bd\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of having produced a “technically correct” translation. However, I believe that translators have only two options here: (a) take a risk and, for example, tell us if they actually understand the connective \",\"attrs\":{\"start\":456,\"end\":662}},{\"type\":\"text\",\"text\":\"kyi\",\"attrs\":{\"start\":662,\"end\":665},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":662,\"end\":665,\"uuid\":\"e16a47ba-2ece-44ef-b437-1431df00d9dd\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" in the sense of “belonging to,” “resulting from,” “consisting of,” and so on; or (b) admit that they do not understand the source text. In the case of the technical compounds found in chapter 10, I therefore tried to ask myself what these terms actually referred to, what could have been the system of logic presented in these pages. For example, I read \",\"attrs\":{\"start\":665,\"end\":1020}},{\"type\":\"text\",\"text\":\"gzhan gyi rigs kyi dpe nye bar sbyar ba’i mtshan nyid\",\"attrs\":{\"start\":1020,\"end\":1073},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":1020,\"end\":1073,\"uuid\":\"16683708-e0c8-4ab1-ac19-a67635b92c6d\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":1073,\"end\":1075}},{\"type\":\"text\",\"text\":\"anyajātīyadṛṣṭāntopasaṃhāralakṣaṇa\",\"attrs\":{\"start\":1075,\"end\":1109},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":1075,\"end\":1109,\"uuid\":\"dde85e09-26b3-4464-ba45-b7981c67820f\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\")\",\"attrs\":{\"start\":1109,\"end\":1110},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"1fe93eec-26a1-4b55-8462-7433a631dce4\",\"label\":\"26\",\"uuid\":\"9c594ccf-7fda-42f9-ac74-6f60cc5dca55\",\"start\":1110,\"end\":1110,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" as rendering into Tibetan a Sanskrit \",\"attrs\":{\"start\":1110,\"end\":1148}},{\"type\":\"text\",\"text\":\"bahuvrīhi\",\"attrs\":{\"start\":1148,\"end\":1157},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2283dbd7-1426-4735-a42e-fa3085c70c20\",\"uuid\":\"89c45162-b949-4d78-bdd7-57f42b3cb525\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". As a consequence, I translated this long compound with “[The logical proof] \",\"attrs\":{\"start\":1157,\"end\":1235}},{\"type\":\"text\",\"text\":\"characterized by\",\"attrs\":{\"start\":1235,\"end\":1251},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bec5686e-d233-4767-9078-f8c7919dc20d\",\"uuid\":\"fad4a210-a57b-4fa1-b206-6f157f3cb8cf\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" a \",\"attrs\":{\"start\":1251,\"end\":1254}},{\"type\":\"text\",\"text\":\"demonstration\",\"attrs\":{\"start\":1254,\"end\":1267},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5caeef5e-c07a-4329-a983-856788c5fa41\",\"uuid\":\"de7cc13b-764a-49e5-b700-0b69255cf73a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" through an instance belonging to a different class [of phenomena]”\",\"attrs\":{\"start\":1267,\"end\":1334}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"acbb1b22-7883-45ce-8d63-6eea95b6a5c2\",\"sort\":1882,\"type\":\"introduction\",\"label\":\"i.46\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":486,\"uuid\":\"acbb1b22-7883-45ce-8d63-6eea95b6a5c2\"},\"content\":[{\"type\":\"text\",\"text\":\"It goes without saying that these translations are at this \",\"attrs\":{\"start\":0,\"end\":59}},{\"type\":\"text\",\"text\":\"stage\",\"attrs\":{\"start\":59,\"end\":64},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4e64e8cc-e904-47f6-8554-e8273dd3587a\",\"uuid\":\"ef356e25-3b40-4fbf-8601-2526f963f446\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" provisional, as further research on the subject matter is necessary. But in order to translate these technical terms, we cannot just give a technically correct translation of a succession of words. Beyond the first phase of the work, which is purely analytical, we still need to develop a mental representation of the situation presented in the text by \",\"attrs\":{\"start\":64,\"end\":418}},{\"type\":\"text\",\"text\":\"establishing\",\"attrs\":{\"start\":418,\"end\":430},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"25ffc2fd-62b2-45e5-9cdd-388f2d1c28cc\",\"uuid\":\"a439d9f4-c647-4e5a-a2ef-79649002d2ed\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" relations with a context that might go beyond the text.\",\"attrs\":{\"start\":430,\"end\":486}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"fa929069-29f9-4a52-93d8-2715693f2d52\",\"sort\":1888,\"type\":\"introduction\",\"label\":\"i.47\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":749,\"uuid\":\"fa929069-29f9-4a52-93d8-2715693f2d52\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"f170864d-ac23-4ffb-9bd5-6d6030f886eb\"},\"content\":[{\"type\":\"text\",\"text\":\"3. In the third operation, Billeter insists on the necessity for translators to become writers. They should formulate in the target language their understanding of the source text as accurately and naturally as possible. At this \",\"attrs\":{\"start\":0,\"end\":229}},{\"type\":\"text\",\"text\":\"stage\",\"attrs\":{\"start\":229,\"end\":234},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4e64e8cc-e904-47f6-8554-e8273dd3587a\",\"uuid\":\"492e39de-b2d2-480a-9756-dc4356c21b56\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", translators should focus on literary elements of the translation, such as idioms, voice, and figures of speech. According to Billeter, difficulties in writing accurately and naturally in the target language are often the direct consequence of not having performed the second operation. The translation might well be technically correct, but it still does not make sense, an experience all translators go through when they fail to understand the meaning (or visualize the situation) referred to by the source text.\",\"attrs\":{\"start\":234,\"end\":749}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"07a14bf2-0f95-4723-92bf-83e78050375b\",\"sort\":1892,\"type\":\"introduction\",\"label\":\"i.48\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1509,\"uuid\":\"07a14bf2-0f95-4723-92bf-83e78050375b\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"07a5601d-89f2-40c3-bc06-ff6580dd69cb\"},\"content\":[{\"type\":\"text\",\"text\":\"4. In the fourth operation, translators should reflect on the role played by linguistic constraints and conventions in the formulation of the source text as well as those imposed by the target language. What options did the author of the text have in terms of expression? How would someone express the same ideas in the target language? As a consequence, the notion of form and pragmatics in the target language becomes central. To detail the various operations leading to an actual translation, Vinay and Darbelnet’s model is useful.\",\"attrs\":{\"start\":0,\"end\":534},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"c1f1c71b-a6ba-450e-8824-2188ea0d5a55\",\"label\":\"27\",\"uuid\":\"66d25637-a3b2-4988-bf8c-f14810b46833\",\"start\":534,\"end\":534,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" Translators should first identify the units of translation in relation to the translation process: the lexicon (e.g., semantic values, objective and affective aspects, lexical associations and modulations), the syntactic structure (e.g., transpositions between word classes, supplementation of pronouns or conjunctions, modifications in terms of gender, number, characterization, tenses, voice, modality, and verbal aspects), and the message (e.g., meaning, stylistics, pragmatics, topicalization, figures of speech, metalinguistic aspects, specific segmentation of reality). Then, they should examine the descriptive, affective, and intellectual content of the units of translation in the source text to reconstitute the situation at the origin of the message. These two first steps correspond to Billeter’s two first operations. Finally, translators still have to formulate the message in the target language without omitting any relevant element from the source language.\",\"attrs\":{\"start\":534,\"end\":1509}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"aa68da35-34ce-4ed2-aac6-2af1f0581a86\",\"sort\":1902,\"type\":\"introduction\",\"label\":\"i.49\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":160,\"uuid\":\"dd774de9-98b6-4da2-bde5-e596012aff2e\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"c676e152-bba4-4c45-babb-47b8a406b555\"},\"content\":[{\"type\":\"text\",\"text\":\"To achieve this, Vinay and Darbelnet argue that translators have only two methods: direct and oblique translation. Direct translation includes three strategies:\",\"attrs\":{\"start\":0,\"end\":160}}]},{\"type\":\"bulletList\",\"attrs\":{\"start\":160,\"end\":700,\"uuid\":\"265a1adb-29e0-4a36-9eb2-e4728f3dacc6\",\"spacing\":\"horizontal\"},\"content\":[{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"• a. Borrowing: the term in the source language is used in the target language to overcome an insuperable metalinguistic lacuna, or it is used because the term is also commonly used in the target language. For instance, I use the Sanskrit \",\"attrs\":{\"start\":160,\"end\":399}},{\"type\":\"text\",\"text\":\"bodhisattva\",\"attrs\":{\"start\":399,\"end\":410},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":399,\"end\":410,\"uuid\":\"89c81af0-056b-478a-b14d-b51b49f60b3e\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" and \",\"attrs\":{\"start\":410,\"end\":415}},{\"type\":\"text\",\"text\":\"nirvāṇa\",\"attrs\":{\"start\":415,\"end\":422},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":415,\"end\":422,\"uuid\":\"5ca60c59-c940-48c7-8a3e-68679da879ee\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"957da5d5-795e-4533-909b-58063c94b409\",\"uuid\":\"7a04cbb0-14cf-49bc-b442-fcca71ea15dc\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in my English translation. \",\"attrs\":{\"start\":422,\"end\":450}}],\"attrs\":{\"start\":160,\"end\":450,\"uuid\":\"1922ab5c-76a8-4c05-a5df-80c2a5f8160f\"}}],\"attrs\":{\"start\":160,\"end\":450,\"uuid\":\"1922ab5c-76a8-4c05-a5df-80c2a5f8160f\"}},{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"• b. Calque: I translated \",\"attrs\":{\"start\":450,\"end\":476}},{\"type\":\"text\",\"text\":\"bodhicitta\",\"attrs\":{\"start\":476,\"end\":486},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c0849f08-9eba-42c8-9f16-e8ca8d34f002\",\"uuid\":\"8f870b2f-3ad7-471c-8e4d-4db08a65f154\",\"toh\":null,\"start\":476,\"end\":0}},{\"type\":\"italic\",\"attrs\":{\"start\":476,\"end\":486,\"uuid\":\"8b3c1100-3c2b-4d22-b27f-1fcbe75903c5\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" with “\",\"attrs\":{\"start\":486,\"end\":493}},{\"type\":\"text\",\"text\":\"awakening mind\",\"attrs\":{\"start\":493,\"end\":507},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c0849f08-9eba-42c8-9f16-e8ca8d34f002\",\"uuid\":\"f1448a37-b903-45b7-93d8-09328aa85530\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\",” which is both a lexical and structural calque. \",\"attrs\":{\"start\":507,\"end\":557}}],\"attrs\":{\"start\":450,\"end\":557,\"uuid\":\"1642dd46-dc37-4db8-bc66-f08e176fe833\"}}],\"attrs\":{\"start\":450,\"end\":557,\"uuid\":\"1642dd46-dc37-4db8-bc66-f08e176fe833\"}},{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"• c. Literal translation: most lists and simple sentences are for instance relatively unproblematic direct translations of the source language.\",\"attrs\":{\"start\":557,\"end\":700}}],\"attrs\":{\"start\":557,\"end\":700,\"uuid\":\"28ae8375-d3f9-4f46-b616-b2872f2dd53b\"}}],\"attrs\":{\"start\":557,\"end\":700,\"uuid\":\"28ae8375-d3f9-4f46-b616-b2872f2dd53b\"}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"132622f7-08ea-4111-8c4a-16151ff55853\",\"sort\":1919,\"type\":\"introduction\",\"label\":\"i.50\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":265,\"uuid\":\"8438bea1-edcc-4c25-8aae-f1c215102744\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"e1ed0e27-d301-491b-92a5-2612d43315f9\"},\"content\":[{\"type\":\"text\",\"text\":\"When a Literal translation fails to render the message, is structurally impossible, or misleads the reader due to the lack of a corresponding expression belonging to the same register, one should turn to an oblique translation method among the following strategies:\",\"attrs\":{\"start\":0,\"end\":265}}]},{\"type\":\"bulletList\",\"attrs\":{\"start\":265,\"end\":5467,\"uuid\":\"25304c6c-32c8-4b6b-8d11-0111994f03f3\",\"spacing\":\"horizontal\"},\"content\":[{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"• d. Transposition: one replaces a word class by another. For example, the frequent nominalizations of Sanskrit and Tibetan are turned into verb clauses. The highly technical nature of some terms makes it necessary to reflect the Sanskrit as much as possible while “unpacking” what is a condensed compound. As an illustration, I translated \",\"attrs\":{\"start\":265,\"end\":605}},{\"type\":\"text\",\"text\":\"tadanyavairūpyopalabdhi\",\"attrs\":{\"start\":605,\"end\":628},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":605,\"end\":628,\"uuid\":\"8ce8c209-e50d-4640-b8b3-822fb5e72578\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" with “a perception that does not conform with anything other than the [\",\"attrs\":{\"start\":628,\"end\":700}},{\"type\":\"text\",\"text\":\"thing\",\"attrs\":{\"start\":700,\"end\":705},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c5f03657-2f4a-4be8-89cc-ab14d505c429\",\"uuid\":\"ef4f92b3-e566-4aa2-9c0f-9f2180755db8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" to establish],” in which \",\"attrs\":{\"start\":705,\"end\":731}},{\"type\":\"text\",\"text\":\"vairūpya\",\"attrs\":{\"start\":731,\"end\":739},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":731,\"end\":739,\"uuid\":\"83fdbb29-5fd7-43cf-9efa-136308ace20f\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" is translated as a verb. Our text is mostly written in the same way as a treatise (\",\"attrs\":{\"start\":739,\"end\":823}},{\"type\":\"text\",\"text\":\"śāstra\",\"attrs\":{\"start\":823,\"end\":829},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":823,\"end\":829,\"uuid\":\"371d3eb1-fe68-44f3-9034-95e48be62fc6\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"), reflecting what is referred to as the nominal style in Sanskrit, or scholastic Sanskrit, in which the nominalization of verbal clauses by means of compounds or suffixes is common. As is often the case in technical or hyperspecialized environments, processes or conceptual frameworks are encapsulated as technical terms (often nouns) implying a complex or recurring pattern. As an analogy, think of a medical term such as hemiglossectomy standing for a removal of a part of the tongue. The passive impersonal phrase “a hemiglossectomy was performed on the patient at 11 pm” includes the nominalization of an action through a compound (hemiglossectomy). It could be rewritten as “[the surgeon] removed a portion of the patient’s tongue at 11 pm.” As can be seen from the translations of Lamotte and Frauwallner, nominalization seems to be less of a problem in French and German than it is in modern (American) English in which readability is more of a concern. When translating the \",\"attrs\":{\"start\":829,\"end\":1812}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana\",\"attrs\":{\"start\":1812,\"end\":1828},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"45731df2-cd9b-4619-811b-4ff4fbcaa762\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\", I therefore tried to turn nominal compounds common in scholastic Sanskrit into English verbal sentences by transposing these compounds into verbal sentences. However, since the text is very technical (particularly from Chapter 7 onward), I decided in some cases to keep nominal compounds that were indicative of a technical term and not just a nontechnical action or state of affairs. For example, the text mentions throughout a “concept” being referred to a “X” (see for instance \",\"attrs\":{\"start\":1828,\"end\":2311}},{\"type\":\"text\",\"text\":\"7.3–6\",\"attrs\":{\"start\":2311,\"end\":2316},\"marks\":[{\"type\":\"internalLink\",\"attrs\":{\"uuid\":\"014845a8-1f7d-409c-a134-35696d3e9f7d\",\"href\":\"/entity/passage/25be803e-9f3d-40fc-baaf-b7cc030b009d\",\"entity\":\"25be803e-9f3d-40fc-baaf-b7cc030b009d\",\"type\":\"passage\",\"toh\":null,\"isSameWork\":true,\"subtype\":\"translation\"}}]},{\"type\":\"text\",\"text\":\"). Just like the surgical term above, such complex nominal compounds stand for a specific action or concept and are part of a “specialist’s jargon.” Turning these compounds into verbal sentences might have the counterproductive effect of erasing an essential feature of this kind of literature consisting in endless lists of often technical terms. Therefore, in this particular case, it would probably be best to avoid transposition. \",\"attrs\":{\"start\":2316,\"end\":2750}}],\"attrs\":{\"start\":265,\"end\":2750,\"uuid\":\"11ea8562-0b54-4c6a-9832-15f7eb850120\"}}],\"attrs\":{\"start\":265,\"end\":2750,\"uuid\":\"11ea8562-0b54-4c6a-9832-15f7eb850120\"}},{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"• e. Modulation: this strategy implies a change of perspective or standpoint made in order to avoid an awkward rendering of the source language. In its simplest form, translating \",\"attrs\":{\"start\":2750,\"end\":2929}},{\"type\":\"text\",\"text\":\"sla ba ma yin\",\"attrs\":{\"start\":2929,\"end\":2942},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":2929,\"end\":2942,\"uuid\":\"d602e039-2bb6-43d6-b017-326622f73f78\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" (D, folio 25.b, \",\"attrs\":{\"start\":2942,\"end\":2959}},{\"type\":\"text\",\"text\":\"7.32\",\"attrs\":{\"start\":2959,\"end\":2963},\"marks\":[{\"type\":\"internalLink\",\"attrs\":{\"uuid\":\"969405dc-783f-4ce6-8f52-a7d297343f40\",\"href\":\"/entity/passage/af27a1f9-44b4-4123-b7e0-c5be2a99e70d\",\"entity\":\"af27a1f9-44b4-4123-b7e0-c5be2a99e70d\",\"type\":\"passage\",\"toh\":null,\"isSameWork\":true,\"subtype\":\"translation\"}}]},{\"type\":\"text\",\"text\":\") with “it is difficult” is an illustration of an optional modulation. Any change of syntactic subject for the sake of clarifying a sentence would be a modulation. Whether this decision is appropriate or not on the part of the translator is something that one should evaluate on a case-by-case basis. I would like to illustrate this point with issues related to the \",\"attrs\":{\"start\":2963,\"end\":3329}},{\"type\":\"text\",\"text\":\"nidāna\",\"attrs\":{\"start\":3329,\"end\":3335},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"72f80123-e9e7-421f-a43f-59ce107c9879\",\"uuid\":\"538c9a12-2bf1-4836-948c-7b31cbacad41\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of the sūtra, in which topicalization plays an important role. The first paragraph of the prologue is a presentation of the place where the Buddha is dwelling. The topicalization of the temple (\",\"attrs\":{\"start\":3335,\"end\":3530}},{\"type\":\"text\",\"text\":\"khang\",\"attrs\":{\"start\":3530,\"end\":3535},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":3530,\"end\":3535,\"uuid\":\"d08b946b-c92e-48a2-a897-005511a8a21f\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\") is achieved through a succession of compounds, mainly \",\"attrs\":{\"start\":3535,\"end\":3591}},{\"type\":\"text\",\"text\":\"bahuvrīhis\",\"attrs\":{\"start\":3591,\"end\":3601},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2283dbd7-1426-4735-a42e-fa3085c70c20\",\"uuid\":\"dc937c5f-3b71-4435-a0e3-f52e51b19cce\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Lamotte’s translation reflects this thematization to perfection. In contrast, Powers fails to topicalize the palace to the same degree. In his translation, the logical subject of the several clauses describing this palace is sometimes ambiguous. In this case, one should consider the fact that the Sanskrit structure of this paragraph is built on a process of topicalization that we can easily render in English. In a word, we have no reason to alter this literary device by inducing a modulation of the translation through a change of perspective induced, for example, by a modification of the grammatical or logical subject in the target language. \",\"attrs\":{\"start\":3601,\"end\":4253}}],\"attrs\":{\"start\":2750,\"end\":4253,\"uuid\":\"1593605e-4fe1-469f-8ee4-424630ee1879\"}}],\"attrs\":{\"start\":2750,\"end\":4253,\"uuid\":\"1593605e-4fe1-469f-8ee4-424630ee1879\"}},{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"• f. Equivalence: the same situation can be expressed both in the source language and the target language in completely different stylistic and structural ways due to the necessity to resort to idioms in order to convey the message of the source text. For example, I translated \",\"attrs\":{\"start\":4253,\"end\":4531}},{\"type\":\"text\",\"text\":\"evam etat\",\"attrs\":{\"start\":4531,\"end\":4540},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":4531,\"end\":4540,\"uuid\":\"9cf6d735-22b7-4dfe-a951-0a1c5e36544b\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":4540,\"end\":4542}},{\"type\":\"text\",\"text\":\"de de bzhin te/no\",\"attrs\":{\"start\":4542,\"end\":4559},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":4542,\"end\":4559,\"uuid\":\"67f4b65d-6555-477b-93e5-eeb8c7c17594\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\") literally with “so it is” in English, which is a slightly pompous and old-fashioned expression no one would probably use today. Instead, one would probably say in an actual dialogue something like “You are right, \",\"attrs\":{\"start\":4559,\"end\":4774}},{\"type\":\"text\",\"text\":\"Dharmodgata\",\"attrs\":{\"start\":4774,\"end\":4785},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5359c54c-64c3-4292-8516-a81ee7baed3b\",\"uuid\":\"f074a7dd-cf06-4073-95ac-baea393e4057\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"” or “This is true, \",\"attrs\":{\"start\":4785,\"end\":4805}},{\"type\":\"text\",\"text\":\"Dharmodgata\",\"attrs\":{\"start\":4805,\"end\":4816},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5359c54c-64c3-4292-8516-a81ee7baed3b\",\"uuid\":\"8b44ecb1-f012-40a0-8184-1bafafa26d23\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".”\",\"attrs\":{\"start\":4816,\"end\":4818},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"ed092c38-e25b-4fba-afd2-b8b00c11b8dc\",\"label\":\"28\",\"uuid\":\"f2bef3f7-ac4a-41f2-9d98-cfcbaccbc07c\",\"start\":4818,\"end\":4818,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":4818,\"end\":4819}}],\"attrs\":{\"start\":4253,\"end\":4819,\"uuid\":\"e492c9d3-2e3e-4d6f-b3b6-c199a49dbb6c\"}}],\"attrs\":{\"start\":4253,\"end\":4819,\"uuid\":\"e492c9d3-2e3e-4d6f-b3b6-c199a49dbb6c\"}},{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"• g. Adaptation: this method aims at replacing altogether a reference to a situation in the source language if it is completely unknown in the target language. I generally try to avoid adaptations while translating, for the simple reason that one has to be certain that, for instance, two different metaphors or examples refer to the same situation or object. To conclude on this point, it seems to me that a number of fixed or technical expressions in the Kangyur could be translated in a systematic way following Vinay and Darbelnet’s approach. This research would establish a set of solid conventions that would improve accuracy and readability.\",\"attrs\":{\"start\":4819,\"end\":5467}}],\"attrs\":{\"start\":4819,\"end\":5467,\"uuid\":\"3a307819-95ec-4b93-83a5-1f333f56d6be\"}}],\"attrs\":{\"start\":4819,\"end\":5467,\"uuid\":\"3a307819-95ec-4b93-83a5-1f333f56d6be\"}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"322b32fa-6aae-40f2-a67a-b30f5356c98d\",\"sort\":1977,\"type\":\"introduction\",\"label\":\"i.51\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":2031,\"uuid\":\"322b32fa-6aae-40f2-a67a-b30f5356c98d\"},\"content\":[{\"type\":\"text\",\"text\":\"$7a\",\"attrs\":{\"start\":0,\"end\":1794}},{\"type\":\"text\",\"text\":\"mind\",\"attrs\":{\"start\":1794,\"end\":1798},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b667709c-9e2a-4877-96d5-8b056867ac96\",\"uuid\":\"d1cac7aa-fabd-4c41-a512-19a325ecdef3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" that the translation is also obviously culturally situated. This process is fundamental because it facilitates the validation (or invalidation) of translation hypotheses resulting from the two first steps of the translation process.\",\"attrs\":{\"start\":1798,\"end\":2031}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"9b1bf835-a5ff-4647-8992-ea772f39b178\",\"sort\":1981,\"type\":\"introduction\",\"label\":\"i.52\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":651,\"uuid\":\"9b1bf835-a5ff-4647-8992-ea772f39b178\"},\"content\":[{\"type\":\"text\",\"text\":\"In the context of \",\"attrs\":{\"start\":0,\"end\":18}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana\",\"attrs\":{\"start\":18,\"end\":34},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"57bca40a-6cfb-4f4d-b55e-1e38c20c2ef3\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\", the problem is compounded by the fact that the sūtra can be read as a collection of independent texts that would have been put together during the third or fourth century \",\"attrs\":{\"start\":34,\"end\":207}},{\"type\":\"text\",\"text\":\"ᴄᴇ\",\"attrs\":{\"start\":207,\"end\":209},\"marks\":[{\"type\":\"smallCaps\",\"attrs\":{\"start\":207,\"end\":209,\"uuid\":\"942df5d7-d99f-4104-9364-e1a48f88e328\",\"type\":\"span\",\"textStyle\":\"small-caps\"}}]},{\"type\":\"text\",\"text\":\". The academic community considers the sūtra as a highly composite compilation lacking coherence from a philological perspective.\",\"attrs\":{\"start\":209,\"end\":338},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"7db3114d-503f-4db6-bad3-9e574c7cb920\",\"label\":\"29\",\"uuid\":\"ef29e73a-926c-48a1-b0bf-91408bdb3786\",\"start\":338,\"end\":338,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" Lamotte explains that the first four chapters represent a \",\"attrs\":{\"start\":338,\"end\":397}},{\"type\":\"text\",\"text\":\"Prajñāpāramitā\",\"attrs\":{\"start\":397,\"end\":411},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"8b1606d0-a5a2-44f7-bb40-75e49d3ad6d2\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" for the reasons mentioned above. He sees chapters 5 through 7 as forming a second group of ideas found in the \",\"attrs\":{\"start\":411,\"end\":522}},{\"type\":\"text\",\"text\":\"Prajñāpāramitā\",\"attrs\":{\"start\":522,\"end\":536},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"406c3faf-bc44-4dac-9dbc-eccb1905b612\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" literature that influenced the Yogācāra school. Finally, he considers chapters 8 through 10 to be later additions.\",\"attrs\":{\"start\":536,\"end\":651}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"474dfb25-8ce7-4dfb-a0bf-b3b2e15f5a57\",\"sort\":1993,\"type\":\"introduction\",\"label\":\"i.53\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1265,\"uuid\":\"474dfb25-8ce7-4dfb-a0bf-b3b2e15f5a57\"},\"content\":[{\"type\":\"text\",\"text\":\"It is undeniable that the various recensions in Tibetan and Chinese refer to texts that are quite different in structure. For instance, Paramārtha’s translation includes only the first four chapters, which, according to Lamotte, might have originally formed an independent sūtra. In addition, it is obvious that the ten chapters of \",\"attrs\":{\"start\":0,\"end\":332}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana\",\"attrs\":{\"start\":332,\"end\":348},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"c9079eaf-a253-4e56-a043-aef46b23dab4\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" do not follow a consistent textual pattern. The first six have no title. They are concluded by a few summarizing \",\"attrs\":{\"start\":348,\"end\":462}},{\"type\":\"text\",\"text\":\"gāthā\",\"attrs\":{\"start\":462,\"end\":467},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":462,\"end\":467,\"uuid\":\"2065f316-f3c0-41f5-92ff-9e66fe9115bd\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"71bbdd49-c6e1-487c-9d30-86e7fa56a899\",\"uuid\":\"7f49c834-2086-489c-9943-eafd53830497\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" s and a standard formula indicating the name of the person who questioned the Buddha and the number of the chapter (e.g., “This was the chapter of \",\"attrs\":{\"start\":467,\"end\":615}},{\"type\":\"text\",\"text\":\"Guṇākara\",\"attrs\":{\"start\":615,\"end\":623},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"86d71a61-2aa9-4311-9ffe-e3044e9961fb\",\"uuid\":\"394d361d-feb9-432d-a65d-822623541087\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"‍—the sixth chapter”). Chapter 7 has a whole summary of the chapter in the form of a supplement right after the concluding \",\"attrs\":{\"start\":623,\"end\":746}},{\"type\":\"text\",\"text\":\"gāthās\",\"attrs\":{\"start\":746,\"end\":752},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"71bbdd49-c6e1-487c-9d30-86e7fa56a899\",\"uuid\":\"40515177-52f3-4b88-a908-289a65ad26e3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", while in chapter 10 the Buddha is questioned on complementary topics once the concluded \",\"attrs\":{\"start\":752,\"end\":842}},{\"type\":\"text\",\"text\":\"gāthās\",\"attrs\":{\"start\":842,\"end\":848},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"71bbdd49-c6e1-487c-9d30-86e7fa56a899\",\"uuid\":\"072bc566-d6c4-4ad2-9a13-79123d0bc47a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" have been proclaimed. Chapters 7, 8, 9, and 10 each come to an end with a \",\"attrs\":{\"start\":848,\"end\":923}},{\"type\":\"text\",\"text\":\"nītārthanirdeśa\",\"attrs\":{\"start\":923,\"end\":938},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":923,\"end\":938,\"uuid\":\"71599142-61aa-4c09-b375-b1b19b1aa377\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" (instruction of definitive meaning) on the chapter topic. This \",\"attrs\":{\"start\":938,\"end\":1002}},{\"type\":\"text\",\"text\":\"nītārthanirdeśa\",\"attrs\":{\"start\":1002,\"end\":1017},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":1002,\"end\":1017,\"uuid\":\"51f85664-3975-40a2-92e2-a4873a9108e4\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" is referred to as a \",\"attrs\":{\"start\":1017,\"end\":1038}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana\",\"attrs\":{\"start\":1038,\"end\":1054},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":1038,\"end\":1054,\"uuid\":\"372f8949-f1c1-44f7-98be-3839e4e10e17\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" and used as the chapter title. On account of this, Lamotte surmises that there might have originally been several independent \",\"attrs\":{\"start\":1054,\"end\":1181}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana­sūtra\",\"attrs\":{\"start\":1181,\"end\":1203},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"8a7efddf-31c5-4645-8849-cc7854bcfe44\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" s that came to be grouped together as the text we know today.\",\"attrs\":{\"start\":1203,\"end\":1265}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"97b7993a-5109-400d-9f75-2c0a1d159ce1\",\"sort\":2015,\"type\":\"introduction\",\"label\":\"i.54\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1663,\"uuid\":\"97b7993a-5109-400d-9f75-2c0a1d159ce1\"},\"content\":[{\"type\":\"text\",\"text\":\"One should also note that the dialogue structure of chapters 1 through 7 differs from that of chapters 8 through 10. In the first group, the Buddha elaborates on a topic in the form of a monologue once his interlocutor has questioned him on a specific topic, whereas in the second group a dialogue takes place through short questions and answers. As a consequence of all these philological divergences, one has to conclude that the text is rather composite in nature and probably the result of a succession of additions and adjustments. In a word, I agree with Schmithausen that \",\"attrs\":{\"start\":0,\"end\":579}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana\",\"attrs\":{\"start\":579,\"end\":595},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"0c69c76c-482a-49f3-aca4-21e5a879c5e5\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" is not an organic whole that would have been composed from the onset in its present form and that its chapters are not mutually dependent.\",\"attrs\":{\"start\":595,\"end\":734},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"fec8e261-2d49-4afc-b0e9-f568c0aa2192\",\"label\":\"30\",\"uuid\":\"b35f7c23-1bc6-4e4f-b526-95af780627bd\",\"start\":734,\"end\":734,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" However, this hypothesis should ideally be the object of further research by a team following an approach similar to that of Professor Jonathan Silk’s European Research Council project “Open Philology ‍— The Composition of Buddhist Scriptures” at the University of Leiden, to which I have had the good fortune to take part. The multiformity and intertextuality of Mahāyāna sūtras are not the result of a linear development from an Ur-text but the expression of oral-formulaic processes of composition and transmission. For our research program focusing on the \",\"attrs\":{\"start\":734,\"end\":1295}},{\"type\":\"text\",\"text\":\"Ratnakūṭa\",\"attrs\":{\"start\":1295,\"end\":1304},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"b8626aa0-b911-418e-a15e-39e58b424a9b\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" collection of sūtras, we have been developing digital and philological tools to identify, \",\"attrs\":{\"start\":1304,\"end\":1395}},{\"type\":\"text\",\"text\":\"analyze\",\"attrs\":{\"start\":1395,\"end\":1402},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a0849c8e-a301-4513-9fb5-6d97229d1a4c\",\"uuid\":\"f7ecc102-f0cc-40e5-9bb8-c1a02aa4125b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and map the fluidity and modularity of Mahāyāna texts. By using these tools, we could better understand the historical development of the complex textual environment of the \",\"attrs\":{\"start\":1402,\"end\":1577}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana\",\"attrs\":{\"start\":1577,\"end\":1593},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"615e3b3a-e491-4c81-af33-5bc48a686e8d\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\", which includes several translations and many witnesses of this work.\",\"attrs\":{\"start\":1593,\"end\":1663}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"48d849cf-0340-4703-b1b7-7b0ed20642ca\",\"sort\":2029,\"type\":\"introduction\",\"label\":\"i.55\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":2722,\"uuid\":\"48d849cf-0340-4703-b1b7-7b0ed20642ca\"},\"content\":[{\"type\":\"text\",\"text\":\"From the perspective of the narrative and doctrinal content of the Tibetan translation, a somewhat different picture emerges. Even if each chapter does not depend on all others in terms of meaning, there is definitely a progression with regard to the flow of thought in \",\"attrs\":{\"start\":0,\"end\":270}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana\",\"attrs\":{\"start\":270,\"end\":286},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"a94c3b0e-3ea0-4e99-b0d3-1dc205530074\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"$7b\",\"attrs\":{\"start\":286,\"end\":1636}},{\"type\":\"text\",\"text\":\"ādānavijñāna\",\"attrs\":{\"start\":1636,\"end\":1648},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"0b062c2c-29c2-48dc-932b-48db574cedee\",\"uuid\":\"1109a3fc-e394-4c88-a7df-4aef3b8d8347\",\"toh\":null,\"start\":1636,\"end\":0}},{\"type\":\"italic\",\"attrs\":{\"start\":1636,\"end\":1648,\"uuid\":\"83711b3e-1a1c-4b08-864f-40c434d85d16\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" in \",\"attrs\":{\"start\":1648,\"end\":1652}},{\"type\":\"text\",\"text\":\"5.3\",\"attrs\":{\"start\":1652,\"end\":1655},\"marks\":[{\"type\":\"internalLink\",\"attrs\":{\"uuid\":\"8da8e2ac-c786-4004-a2d2-a0f7cf3504be\",\"href\":\"/entity/passage/55ff1c8f-9e67-4757-88c1-2236ed8bf426\",\"entity\":\"55ff1c8f-9e67-4757-88c1-2236ed8bf426\",\"type\":\"passage\",\"toh\":null,\"isSameWork\":true,\"subtype\":\"translation\"}}]},{\"type\":\"text\",\"text\":\" is also found in \",\"attrs\":{\"start\":1655,\"end\":1673}},{\"type\":\"text\",\"text\":\"8.37.1.i\",\"attrs\":{\"start\":1673,\"end\":1681},\"marks\":[{\"type\":\"internalLink\",\"attrs\":{\"uuid\":\"14cd56dd-66e9-4aff-afa2-ebc0530fdcc7\",\"href\":\"/entity/passage/4fcd7dc8-553b-4c79-8c5c-da5a57dfec17\",\"entity\":\"4fcd7dc8-553b-4c79-8c5c-da5a57dfec17\",\"type\":\"passage\",\"toh\":null,\"isSameWork\":true,\"subtype\":\"translation\"}}]},{\"type\":\"text\",\"text\":\"; the model of the three kinds of \",\"attrs\":{\"start\":1681,\"end\":1715}},{\"type\":\"text\",\"text\":\"essencelessness\",\"attrs\":{\"start\":1715,\"end\":1730},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"511f85e3-f5bd-4380-81c7-87048ba56676\",\"uuid\":\"f24a5cfa-884b-49bf-bbc0-2e62044766f0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":1730,\"end\":1732}},{\"type\":\"text\",\"text\":\"niḥsva­bhāvatā\",\"attrs\":{\"start\":1732,\"end\":1746},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"511f85e3-f5bd-4380-81c7-87048ba56676\",\"uuid\":\"15e5beca-ca4d-465e-b99e-a83a25e398f4\",\"toh\":null,\"start\":1732,\"end\":0}},{\"type\":\"italic\",\"attrs\":{\"start\":1732,\"end\":1746,\"uuid\":\"b03573e6-b98d-4023-ab97-42f92694526c\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\") of chapter 7 corresponds to the model of the three \",\"attrs\":{\"start\":1746,\"end\":1799}},{\"type\":\"text\",\"text\":\"defining characteristics\",\"attrs\":{\"start\":1799,\"end\":1823},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f4503be0-02d4-474f-8f1c-a69993648574\",\"uuid\":\"ad76ea46-df8a-4cbb-a9d4-7f00e9dfc8ac\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":1823,\"end\":1825}},{\"type\":\"text\",\"text\":\"lakṣaṇa\",\"attrs\":{\"start\":1825,\"end\":1832},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e6185c2c-6566-40d4-a854-a5c1ae649cf9\",\"uuid\":\"3c11d7b8-a655-4a66-923d-e881938fb259\",\"toh\":null,\"start\":1825,\"end\":0}},{\"type\":\"italic\",\"attrs\":{\"start\":1825,\"end\":1832,\"uuid\":\"ba978aee-5767-4876-a191-c3f89e45eb45\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\") of chapter 6, of which two are foreshadowed in \",\"attrs\":{\"start\":1832,\"end\":1881}},{\"type\":\"text\",\"text\":\"1.2\",\"attrs\":{\"start\":1881,\"end\":1884},\"marks\":[{\"type\":\"internalLink\",\"attrs\":{\"uuid\":\"0b9c9326-f156-466c-83f0-f7ef28b2f37f\",\"href\":\"/entity/passage/368491e9-5031-4cd8-bb10-086577164072\",\"entity\":\"368491e9-5031-4cd8-bb10-086577164072\",\"type\":\"passage\",\"toh\":null,\"isSameWork\":true,\"subtype\":\"translation\"}}]},{\"type\":\"text\",\"text\":\" through the terms \",\"attrs\":{\"start\":1884,\"end\":1903}},{\"type\":\"text\",\"text\":\"parikalpa\",\"attrs\":{\"start\":1903,\"end\":1912},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7c1cb501-6e53-491d-8cf0-f84c3fd49fd1\",\"uuid\":\"8a0694a1-0ecf-46d6-837b-751b592fda8d\",\"toh\":null,\"start\":1903,\"end\":0}},{\"type\":\"italic\",\"attrs\":{\"start\":1903,\"end\":1912,\"uuid\":\"d093d767-4154-43e3-a1e9-ac97ca7161c0\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":1912,\"end\":1914}},{\"type\":\"text\",\"text\":\"kun tu rtog pa\",\"attrs\":{\"start\":1914,\"end\":1928},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":1914,\"end\":1928,\"uuid\":\"c6ba3bd0-18b8-40d3-90a7-595b5e1b7ac9\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\") and *\",\"attrs\":{\"start\":1928,\"end\":1935}},{\"type\":\"text\",\"text\":\"apariniṣpanna\",\"attrs\":{\"start\":1935,\"end\":1948},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e6e4b2ce-848f-42f6-adcd-559066db3843\",\"uuid\":\"fafb5af9-3935-43b3-b7f9-7b30253b7b9a\",\"toh\":null,\"start\":1935,\"end\":0}},{\"type\":\"italic\",\"attrs\":{\"start\":1935,\"end\":1948,\"uuid\":\"8fb79641-0f2a-4419-bf22-c0d612429608\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":1948,\"end\":1950}},{\"type\":\"text\",\"text\":\"yongs su ma grub pa\",\"attrs\":{\"start\":1950,\"end\":1969},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":1950,\"end\":1969,\"uuid\":\"44f04dfe-c97c-4436-a7cb-8abb48be82a9\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"); the \",\"attrs\":{\"start\":1969,\"end\":1976}},{\"type\":\"text\",\"text\":\"other-dependent defining characteristic\",\"attrs\":{\"start\":1976,\"end\":2015},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f0218001-adfb-405e-8ff8-5bb6e9bb4d14\",\"uuid\":\"87ccf0dd-f208-4f70-b015-f36f7694004b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":2015,\"end\":2017}},{\"type\":\"text\",\"text\":\"para­tantra­lakṣaṇa\",\"attrs\":{\"start\":2017,\"end\":2036},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":2017,\"end\":2036,\"uuid\":\"218a44d4-d552-48f3-89bc-b1fb0f24bca0\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\") introduced in chapter 6 is mentioned in \",\"attrs\":{\"start\":2036,\"end\":2078}},{\"type\":\"text\",\"text\":\"7.10\",\"attrs\":{\"start\":2078,\"end\":2082},\"marks\":[{\"type\":\"internalLink\",\"attrs\":{\"uuid\":\"e79e227d-98ed-42a2-9089-47663358207b\",\"href\":\"/entity/passage/6df5a185-c94a-488b-8e4a-ff85b4b33351\",\"entity\":\"6df5a185-c94a-488b-8e4a-ff85b4b33351\",\"type\":\"passage\",\"toh\":null,\"isSameWork\":true,\"subtype\":\"translation\"}}]},{\"type\":\"text\",\"text\":\"; chapter 8 presupposes chapters 5 and 6;\",\"attrs\":{\"start\":2082,\"end\":2123},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"6ca1a6bb-b793-45ef-a1da-bf0db81d30d0\",\"label\":\"31\",\"uuid\":\"75226502-054d-46fd-ae05-f90835900b01\",\"start\":2123,\"end\":2123,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" the concluding paragraphs of \",\"attrs\":{\"start\":2123,\"end\":2153}},{\"type\":\"text\",\"text\":\"7.33\",\"attrs\":{\"start\":2153,\"end\":2157},\"marks\":[{\"type\":\"internalLink\",\"attrs\":{\"uuid\":\"f428be36-ccb3-4db6-b56f-87162c1c15a1\",\"href\":\"/entity/pas