":161,\"end\":340}},{\"type\":\"text\",\"text\":\"awakening\",\"attrs\":{\"start\":340,\"end\":349},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d0fda944-71f7-4a27-a806-7debbf320eea\",\"uuid\":\"e2622ae1-c75e-4cb8-aeca-0cceb491fbfd\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", I communicated through words, gave explanations, \",\"attrs\":{\"start\":349,\"end\":400}},{\"type\":\"text\",\"text\":\"established\",\"attrs\":{\"start\":400,\"end\":411},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"25ffc2fd-62b2-45e5-9cdd-388f2d1c28cc\",\"uuid\":\"fbcbd6dd-0e96-4ef9-bb11-b954bfd0a087\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" distinctions, expressed myself through \",\"attrs\":{\"start\":411,\"end\":451}},{\"type\":\"text\",\"text\":\"conventions\",\"attrs\":{\"start\":451,\"end\":462},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4e5c2faa-9e68-4024-a3d5-daf175e06d51\",\"uuid\":\"de88feb8-e128-4d29-a9aa-8cb84b6459b3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and imparted teachings. One might ask why I did this.\",\"attrs\":{\"start\":462,\"end\":517}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"2d038741-761e-41d0-973c-fb1c7927289c\",\"sort\":3773,\"type\":\"translation\",\"label\":\"4.8\",\"alignments\":{\"toh106\":{\"folioUuid\":\"5ada112e-f7b9-4295-932d-c477affd1496\",\"toh\":\"toh106\",\"tibetan\":\"རབ་འབྱོར་ཕུང་པོ་རྣམས་ལ་རྣམ་པར་དག་པའི་དམིགས་པ་གང་ཡིན་པ་དེ་ནི་ངས་དོན་དམ་པ་ཡིན་པར་ཡོངས་སུ་བསྟན་ཅིང་། རབ་འབྱོར་སྐྱེ་མཆེད་རྣམས་དང་། \\nརྟེན་ཅིང་འབྲེལ་པར་འབྱུང་བ་དང་། ཟས་རྣམས་དང་། བདེན་པ་རྣམས་དང་། ཁམས་རྣམས་དང་། དྲན་པ་ཉེ་བར་གཞག་པ་རྣམས་དང་། ཡང་དག་པར་སྤོང་བ་རྣམས་དང་། རྫུ་འཕྲུལ་གྱི་རྐང་པ་རྣམས་དང་། དབང་པོ་རྣམས་དང་། སྟོབས་རྣམས་དང་། བྱང་\\nཆུབ་ཀྱི་ཡན་ལག་རྣམས་དང་། རབ་འབྱོར་འཕགས་པའི་ལམ་ཡན་ལག་བརྒྱད་པ་ལ་རྣམ་པར་དག་པའི་དམིགས་པ་གང་ཡིན་པ་དེ་ནི་དོན་དམ་པ་ཡིན་པར་ཡོངས་སུ་བསྟན་པའི་ཕྱིར་རོ། །ཕུང་པོ་རྣམས་ལ་རྣམ་པར་དག་པའི་དམིགས་པ་དེ་ཡང་ཐམས་ཅད་དུ་རོ་གཅིག་པ་སྟེ། \\nམཚན་ཉིད་ཐ་དད་པ་མ་ཡིན་ནོ། །ཕུང་པོ་རྣམས་ལ་ཇི་ལྟ་བ་དེ་བ