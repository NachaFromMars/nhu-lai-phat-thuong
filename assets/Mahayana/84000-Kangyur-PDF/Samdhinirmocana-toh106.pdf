3,\"end\":1256},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"01f7741b-46b7-44e3-aa02-149e60ded38e\",\"uuid\":\"6d953211-59bf-4970-a708-c8cca3790e2a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", gods, demigods, and humans for a very long time.\",\"attrs\":{\"start\":1256,\"end\":1306}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"dc0ff6aa-6230-4b74-907c-e6eb28fdb72f\",\"sort\":5177,\"type\":\"translation\",\"label\":\"7.11\",\"alignments\":{\"toh106\":{\"folioUuid\":\"4ae82e8e-a8f4-4890-bf5c-a02291521ae6\",\"toh\":\"toh106\",\"tibetan\":\"དོན་དམ་ཡང་དག་འཕགས་དེ་ལ་སེམས་ཅན་གང་དག་དང་པོ་\\nཉིད་ནས་དགེ་བའི་རྩ་བ་མ་བསྐྱེད་པ། སྒྲིབ་པ་ཡོངས་སུ་མ་དག་པ་རྒྱུད་ཡོངས་སུ་མ་སྨིན་པ་མོས་པ་མི་མང་བ། བསོད་ནམས་དང་ཡེ་ཤེས་ཀྱི་ཚོགས་ཡང་དག་པར་མ་གྲུབ་པ་དེ་དག་ལ་ནི་ང་སྐྱེ་བ་ངོ་བོ་ཉིད་མེད་པ་ཉིད་ལས་བརྩམས་ནས་ཆོས་སྟོན་ཏེ། དེ་དག་གིས་ཆོས་དེ་ཐོས་\\nནས་རྟེན་ཅིང་འབྲེལ་བར་འབྱུང་བའི་འདུ་བྱེད་རྣམས་ལ་མི་རྟག་པ་ཉིད་དུ་ཤེས་ཤིང་མི་བརྟན་པ་ཉིད་དང་། ཡིད་བརྟན་དུ་མི་རུང་བ་ཉིད་དང་། འགྱུར་བའི་ཆོས་ཉིད་དུ་ཤེས་ནས། འདུ་བྱེད་ཐམས་ཅད་ལས་ཡིད་སྡང་བར་བྱེད་སྐྱོ་བར་བྱེད་དོ། །ཡིད་སྡང་བར་བྱས་སྐྱོ་བར་བྱས་\\nནས་སྡིག་པ་ལས་ཕྱིར་ཟློག་སྟེ། དེ་དག་སྡིག་པ་གང་ཡིན་པ་དེ་མི་བྱེད་ཅིང་དགེ་བ་ལ་སྟེན་པར་བྱེད་དོ། །དགེ་བ་ལ་བསྟེན་པའི་རྒྱུས་དགེ་བའི་རྩ་བ་མ་བསྐྱེད་པ་རྣམས་ནི་སྐྱེད་དོ། །སྒྲིབ་པ་ཡོངས་སུ་མ་བྱང་བ་རྣམས་ཀྱང་ཡོངས་སུ་སྦྱོང་ངོ་། །རྒྱུད་ཡོངས་སུ་མ་སྨིན་པ་\\nཡང་ཡོངས་སུ་སྨིན་པར་བྱེད་དོ། །གཞི་དེས་མོས་པ་མང་ཞིང་བསོད་ནམས་དང་ཡེ་ཤེས་ཀྱི་ཚོགས་ཡང་དག་པར་གྲུབ་པར་འགྱུར་རོ། །\",\"folioNumber\":18,\"volumeNumber\":49}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1073,\"uuid\":\"dc0ff6aa-6230-4b74-907c-e6eb28fdb72f\"},\"content\":[{\"type\":\"text\",\"text\":\"“Among these \",\"attrs\":{\"start\":0,\"end\":13}},{\"type\":\"text\",\"text\":\"beings\",\"attrs\":{\"start\":13,\"end\":19},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ad3097fe-b272-4d95-8811-3cbb3824ee9e\",\"uuid\":\"68471d28-ed50-4229-8c4f-b2dc2798ca43\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":19,\"end\":21}},{\"type\":\"text\",\"text\":\"Para­mārtha­samud­gata\",\"attrs\":{\"start\":21,\"end\":43},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"537e957c-58b2-4ce7-88cc-ad811243d1ba\",\"uuid\":\"a5e28b11-81fe-45c3-89c5-cd3e9bc2262f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", some do not produce roots of virtue from the very beginning. They do not clear \",\"attrs\":{\"start\":43,\"end\":124}},{\"type\":\"text\",\"text\":\"obstructions\",\"attrs\":{\"start\":124,\"end\":136},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a9865148-8f12-4e17-81e7-ebadc56c7fac\",\"uuid\":\"ec4b5b13-acb6-40fc-b706-1d440376aa39\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" or bring their mental continuums to maturity. Their confidence in my teaching is limited and they have not accomplished the accumulations of merit and \",\"attrs\":{\"start\":136,\"end\":288}},{\"type\":\"text\",\"text\":\"gnosis\",\"attrs\":{\"start\":288,\"end\":294},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b36258b5-bd30-4205-aeeb-75bac743076f\",\"uuid\":\"84ce9a49-2ba3-4ae3-ad21-0ee562510d81\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". I impart to those \",\"attrs\":{\"start\":294,\"end\":314}},{\"type\":\"text\",\"text\":\"beings\",\"attrs\":{\"start\":314,\"end\":320},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ad3097fe-b272-4d95-8811-3cbb3824ee9e\",\"uuid\":\"5a48462c-2d97-4496-8774-7e20ba75ecd0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" the teaching on \",\"attrs\":{\"start\":320,\"end\":337}},{\"type\":\"text\",\"text\":\"essencelessness with regard to arising\",\"attrs\":{\"start\":337,\"end\":375},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"3b04bcec-d4bd-44c9-989d-6de3cbd8b0fa\",\"uuid\":\"b99257a8-5856-4795-9763-ece1e1d8f248\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Once they have heard this teaching, they understand that \",\"attrs\":{\"start\":375,\"end\":434}},{\"type\":\"text\",\"text\":\"conditioned phenomena\",\"attrs\":{\"start\":434,\"end\":455},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cf78a4e2-f7a7-4e09-992d-8e8c0671369b\",\"uuid\":\"98eb2e17-1a0f-4ba8-875e-c1b2efcacc72\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" arising in dependence on causes are of an impermanent, unstable, and unreliable nature. They develop aversion and repulsion towards \",\"attrs\":{\"start\":455,\"end\":588}},{\"type\":\"text\",\"text\":\"conditioned phenomena\",\"attrs\":{\"start\":588,\"end\":609},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cf78a4e2-f7a7-4e09-992d-8e8c0671369b\",\"uuid\":\"8f241bd9-3d22-4bb0-bbcf-9e636eeaceb4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Once they have done this, they turn away from wrongdoing. Not committing any wrongdoing, they establish themselves in virtue. With this as a cause, they produce the roots of virtue that were yet to be produced. They clear \",\"attrs\":{\"start\":609,\"end\":833}},{\"type\":\"text\",\"text\":\"obstructions\",\"attrs\":{\"start\":833,\"end\":845},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a9865148-8f12-4e17-81e7-ebadc56c7fac\",\"uuid\":\"bfc2e8a6-8d7d-4156-a549-ec21c45cfb41\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" that were yet to be cleared. They bring their mental continuums, which were not yet mature, to maturity. As a result, their confidence in my teaching becomes vast, and they will accomplish the accumulations of merit and \",\"attrs\":{\"start\":845,\"end\":1066}},{\"type\":\"text\",\"text\":\"gnosis\",\"attrs\":{\"start\":1066,\"end\":1072},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b36258b5-bd30-4205-aeeb-75bac743076f\",\"uuid\":\"d1a95766-ab17-4fae-9d63-627404ed7046\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":1072,\"end\":1073}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"390c7449-f731-4129-b35f-cb39f21bee2a\",\"sort\":5199,\"type\":\"translation\",\"label\":\"7.12\",\"alignments\":{\"toh106\":{\"folioUuid\":\"4ae82e8e-a8f4-4890-bf5c-a02291521ae6\",\"toh\":\"toh106\",\"tibetan\":\"དེ་དག་དེ་ལྟར་དགེ་བའི་རྩ་བ་བསྐྱེད་པ་ནས་བསོད་ནམས་དང་ཡེ་ཤེས་ཀྱི་ཚོགས་ཀྱི་བར་དུ་ཡང་དག་པར་འགྲུབ་མོད་ཀྱི། འོན་ཀྱང་སྐྱེ་བ་ངོ་བོ་ཉིད་[F.19.a]མེད་པ་ཉིད་དེ་ལ་མཚན་ཉིད་ངོ་བོ་ཉིད་མེད་པ་ཉིད་དང་། དོན་དམ་པ་ངོ་བོ་ཉིད་མེད་པ་ཉིད་རྣམ་པ་གཉིས་ཡང་དག་པ་ཇི་ལྟ་བ་བཞིན་དུ་མི་ཤེས་པས། འདུ་བྱེད་ཐམས་ཅད་ལས་ཡང་དག་པར་སྐྱོ་བར་མི་འགྱུར། ཡང་དག་པར་འདོད་ཆགས་དང་བྲལ་བར་མི་\\nའགྱུར། ཡང་དག་པར་རྣམ་པར་གྲོལ་བར་མི་འགྱུར་ཞིང་། ཉོན་མོངས་པའི་ཀུན་ནས་ཉོན་མོངས་པ་ལས་ཀྱང་ཡོངས་སུ་གྲོལ་བར་མི་འགྱུར། ལས་ཀྱི་ཀུན་ནས་ཉོན་མོངས་པ་ལས་ཀྱང་ཡོངས་སུ་གྲོལ་བར་མི་འགྱུར། སྐྱེ་བའི་ཀུན་ནས་ཉོན་མོངས་པ་ལས་ཀྱང་ཡོངས་སུ་གྲོལ་\\nབར་མི་འགྱུར་བས། ཡང་དེ་བཞིན་གཤེགས་པ་དེ་དག་ལ་འདི་ལྟ་སྟེ། མཚན་ཉིད་ངོ་བོ་ཉིད་མེད་པ་ཉིད་དང་། དོན་དམ་པ་ངོ་བོ་ཉིད་མེད་པ་ཉིད་ལས་བརྩམས་ནས་འདི་ལྟར་འདུ་བྱེད་ཐམས་ཅད་ལས་ཡང་དག་པར་སྐྱོ་བར་བྱ་བ་དང་། འདོད་ཆགས་དང་བྲལ་བར་བྱ་བ་དང་། རྣམ་\\nཔར་གྲོལ་བར་བྱ་བ་དང་། ཉོན་མོངས་པའི་ཀུན་ནས་ཉོན་མོངས་པ་ལས་ཡང་དག་པར་བཟླ་བ་དང་། ལས་ཀྱི་ཀུན་ནས་ཉོན་མོངས་པ་ལས་ཡང་དག་པར་བཟླ་བ་དང་། སྐྱེ་བའི་ཀུན་ནས་ཉོན་མོངས་པ་ལས་ཡང་དག་པར་བཟླ་བའི་ཕྱིར་ཆོས་སྟོན་ཏོ། །\",\"folioNumber\":18,\"volumeNumber\":49}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":990,\"uuid\":\"390c7449-f731-4129-b35f-cb39f21bee2a\"},\"content\":[{\"type\":\"text\",\"text\":\"“Although such \",\"attrs\":{\"start\":0,\"end\":15}},{\"type\":\"text\",\"text\":\"beings\",\"attrs\":{\"start\":15,\"end\":21},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ad3097fe-b272-4d95-8811-3cbb3824ee9e\",\"uuid\":\"cef0158e-babb-4efb-9a93-2ebe3c4c7534\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" have produced in this way roots of virtue up to the accomplishment of the accumulation of merit and \",\"attrs\":{\"start\":21,\"end\":122}},{\"type\":\"text\",\"text\":\"gnosis\",\"attrs\":{\"start\":122,\"end\":128},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b36258b5-bd30-4205-aeeb-75bac7