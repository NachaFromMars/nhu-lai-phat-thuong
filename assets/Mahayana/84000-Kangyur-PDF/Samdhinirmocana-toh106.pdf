\"uuid\":\"69419033-bb3c-4502-9202-b346578220fd\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".’\",\"attrs\":{\"start\":492,\"end\":494}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"dee99220-ee92-4dca-a3d5-fa50d9e1f1b6\",\"sort\":5386,\"type\":\"translation\",\"label\":\"7.18\",\"alignments\":{\"toh106\":{\"folioUuid\":\"cc457fc9-b6ec-4d66-9f6c-de4949739cb6\",\"toh\":\"toh106\",\"tibetan\":\"དེ་ལ་སེམས་ཅན་གང་དག་དགེ་བའི་རྩ་བ་ཆེན་པོ་བསྐྱེད་པ་དང་། སྒྲིབ་\\nཔ་ཡོངས་སུ་དག་པ། རྒྱུད་ཡོངས་སུ་སྨིན་པ། མོས་པ་མང་བ། བསོད་ནམས་དང་ཡེ་ཤེས་ཀྱི་ཚོགས་ཆེན་པོ་ཡང་དག་པར་གྲུབ་པ་དེ་དག་གིས་ནི་ཆོས་དེ་ཐོས་ན་ངའི་དགོངས་ཏེ་བཤད་པ་ཡང་དག་པ་ཇི་ལྟ་བ་བཞིན་དུ་རབ་ཏུ་ཤེས་ཤིང་། ཆོས་དེ་ལ་ཡང་ཆོས་ཤེས་པར་འགྱུར་ལ། དོན་\\nདེ་ཡང་ཤེས་རབ་ཀྱིས་ཡང་དག་པ་ཇི་ལྟ་བ་བཞིན་དུ་རྟོགས་པར་འགྱུར་ཞིང་། དེ་རྟོགས་པ་གོམས་པས་ཀྱང་མྱུར་བ་མྱུར་བ་ཁོ་ནར་ཤིན་ཏུ་མཐར་ཐུག་པ་ཉིད་རྗེས་སུ་འཐོབ་པར་འགྱུར་ཏེ། དེ་ལ་ཡང་ཨ་ལ་ལ་བཅོམ་ལྡན་འདས་དེ་ནི་ཡང་དག་པར་རྫོགས་པའི་སངས་རྒྱས་ཡིན་ཏེ། དེས་\\nནི་ཆོས་ཐམས་ཅད་ལེགས་པར་མངོན་པར་རྫོགས་པར་སངས་རྒྱས་སོ་ཞེས་དད་པ་ཐོབ་པར་འགྱུར་རོ། །\",\"folioNumber\":20,\"volumeNumber\":49}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":804,\"uuid\":\"dee99220-ee92-4dca-a3d5-fa50d9e1f1b6\"},\"content\":[{\"type\":\"text\",\"text\":\"“Among such \",\"attrs\":{\"start\":0,\"end\":12}},{\"type\":\"text\",\"text\":\"beings\",\"attrs\":{\"start\":12,\"end\":18},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ad3097fe-b272-4d95-8811-3cbb3824ee9e\",\"uuid\":\"afe145c2-a06b-431a-8b7d-7cfe5df3c4ea\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":18,\"end\":20}},{\"type\":\"text\",\"text\":\"Para­mārtha­samud­gata\",\"attrs\":{\"start\":20,\"end\":42},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"537e957c-58b2-4ce7-88cc-ad811243d1ba\",\"uuid\":\"6976030e-5d46-4afc-b508-42c481e8e5d8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", some have produced roots of virtue, purified their \",\"attrs\":{\"start\":42,\"end\":95}},{\"type\":\"text\",\"text\":\"obscurations\",\"attrs\":{\"start\":95,\"end\":107},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9c961f85-80e2-4d1c-a536-20d956f9dbe8\",\"uuid\":\"6e10620f-6cd4-4173-b798-3ad51639005e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and brought their mental continuum to maturity. They have much confidence in my teaching and have accomplished the accumulations of merit and \",\"attrs\":{\"start\":107,\"end\":251}},{\"type\":\"text\",\"text\":\"gnosis\",\"attrs\":{\"start\":251,\"end\":257},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b36258b5-bd30-4205-aeeb-75bac743076f\",\"uuid\":\"81bad2fd-ab91-42fd-ba2c-1d765f4864a0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Once they have heard my teaching, they understand my explanations in accordance with my underlying intent exactly as it is. Moreover, they recognize that this teaching is the truth.\",\"attrs\":{\"start\":257,\"end\":440},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"1db4e3fe-428e-497a-a96c-073e00206ee9\",\"label\":\"156\",\"uuid\":\"ae6ee088-6300-48e7-b246-0e653e839ac2\",\"start\":440,\"end\":440,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" Through their \",\"attrs\":{\"start\":440,\"end\":455}},{\"type\":\"text\",\"text\":\"wisdom\",\"attrs\":{\"start\":455,\"end\":461},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4c3420a1-ffdd-40b2-9f85-e4293f7c2bbb\",\"uuid\":\"f9d7e971-5e02-4267-a0bf-79268d2b6a33\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", they realize its meaning exactly as it is. By also engaging in the practice of this realization, they will very quickly attain the \",\"attrs\":{\"start\":461,\"end\":594}},{\"type\":\"text\",\"text\":\"ultimate\",\"attrs\":{\"start\":594,\"end\":602},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1ce42c0c-900f-47c2-9d40-98ccbafcb2bf\",\"uuid\":\"80796c1a-f1b5-4dc2-b8d5-43a6b0eff3b9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" state. They will develop \",\"attrs\":{\"start\":602,\"end\":628}},{\"type\":\"text\",\"text\":\"faith\",\"attrs\":{\"start\":628,\"end\":633},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b5c3b14c-540c-45c6-a354-f4c471890720\",\"uuid\":\"d661bf0b-3e73-4d9f-88c0-461f9a39fa0f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in these teachings, and think, ‘Amazing! The \",\"attrs\":{\"start\":633,\"end\":679}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":679,\"end\":690},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1b51c11a-be57-45e7-82eb-2691bb785c0d\",\"uuid\":\"4d7ef52a-974f-4081-902f-a9ac9c2266e2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is completely and perfectly awakened. Through him, one becomes perfectly awakened with respect to all phenomena.’\",\"attrs\":{\"start\":690,\"end\":804}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"93480f71-e17f-40bc-90b3-7f9343510062\",\"sort\":5408,\"type\":\"translation\",\"label\":\"7.19\",\"alignments\":{\"toh106\":{\"folioUuid\":\"cc457fc9-b6ec-4d66-9f6c-de4949739cb6\",\"toh\":\"toh106\",\"tibetan\":\"$8e\",\"folioNumber\":20,\"volumeNumber\":49}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1919,\"uuid\":\"93480f71-e17f-40bc-90b3-7f9343510062\"},\"content\":[{\"type\":\"text\",\"text\":\"“Among such \",\"attrs\":{\"start\":0,\"end\":12}},{\"type\":\"text\",\"text\":\"beings\",\"attrs\":{\"start\":12,\"end\":18},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ad3097fe-b272-4d95-8811-3cbb3824ee9e\",\"uuid\":\"b7922d93-044e-4cc4-b0ca-f0cb22f65838\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", some have not produced roots of virtue, purified their \",\"attrs\":{\"start\":18,\"end\":75}},{\"type\":\"text\",\"text\":\"obscurations\",\"attrs\":{\"start\":75,\"end\":87},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9c961f85-80e2-4d1c-a536-20d956f9dbe8\",\"uuid\":\"2c64be67-a2e9-4573-be8f-7f373cedcaa2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and brought their mental continuums to maturity. Their confidence in my teaching is limited and they have not accomplished the accumulations of merit and \",\"attrs\":{\"start\":87,\"end\":243}},{\"type\":\"text\",\"text\":\"gnosis\",\"attrs\":{\"start\":243,\"end\":249},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b36258b5-bd30-4205-aeeb-75bac743076f\",\"uuid\":\"3080bff0-53b2-405d-9f53-c49a1faf7fea\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". They are honest and sincere. Unable to evaluate and refute\",\"attrs\":{\"start\":249,\"end\":309},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"02cdbca4-c445-44ae-9e7c-50c2e7a08bd4\",\"label\":\"157\",\"uuid\":\"c7cf02be-933f-4c71-bec8-0c8b3f54e711\",\"start\":309,\"end\":309,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" [others’ views], they do not consider their own as supreme. Once they have heard my teaching, although they do not understand my explanations in accordance with my underlying intent exactly as it is, they still develop confidence and \",\"attrs\":{\"start\":309,\"end\":544}},{\"type\":\"text\",\"text\":\"faith\",\"attrs\":{\"start\":544,\"end\":549},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b5c3b14c-540c-45c6-a354-f4c471890720\",\"uuid\":\"c66fe858-1ba5-4475-927c-e8d79c1da67d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in these teachings: ‘The \",\"attrs\":{\"start\":549,\"end\":575}},{\"type\":\"text\",\"text\":\"Tathāgata\",\"attrs\":{\"start\":575,\"end\":584},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8bf0a239-7fda-4995-8cc7-36b960a1507a\",\"uuid\":\"b90e0671-95f3-4ef8-a9a3-115f48a4320c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s discourse is profound and has the \",\"attrs\":{\"start\":584,\"end\":621}},{\"type\":\"text\",\"text\":\"appearance\",\"attrs\":{\"start\":621,\"end\":631},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c55da13f-bceb-4490-9ec0-b80198240718\",\"uuid\":\"e2911622-6f64-4a4b-97cd-90edb5cbe24e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of profundity. [Because] \",\"attrs\":{\"start\":631,\"end\":657}},{\"type\":\"text\",\"text\":\"emptiness\",\"attrs\":{\"start\":657,\"end\":666},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"986c5541-3cde-4239-9e0e-933b5ef0981e\",\"uuid\":\"843f8f3d-8961-45ef-91cc-41bea0d47f3e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is the topic of this discourse, it is difficult to perceive and difficult to understand. Being beyond judgment, it does not belong to the domain of speculation. It \",\"attrs\":{\"start\":666,\"end\":831}},{\"type\":\"text\",\"text\":\"can [only] be known by intelligent scholars well versed in the subtle\",\"attrs\":{\"start\":831,\"end\":900},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"30db83b9-fb86-44d2-ae83-c614ad5c97a0\",\"uuid\":\"3db7fcd1-3c74-4331-b945-f9e3c609f9ea\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".’\",\"attrs\":{\"start\":900,\"end\":902},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"4b729a27-0783-4185-a49a-24b583336f61\",\"label\":\"158\",\"uuid\":\"fe66796b-da24-4ed1-9e1d-c74c142f3bea\",\"start\":902,\"end\":902,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" They think, ‘We do not understand the meaning of this sūtra and these teachings that were taught by the \",\"attrs\":{\"start\":902,\"end\":1007}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":1007,\"end\":1018},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1b51c11a-be57-45e7-82eb-2691bb785c0d\",\"uuid\":\"8ef7fcee-b6ab-4ad6-8d9b-7d72c72ad10b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Profound is the \",\"attrs\":{\"start\":1018,\"end\":1036}},{\"type\":\"text\",\"text\":\"awakening\",\"attrs\":{\"start\":1036,\"end\":1045},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d0fda944-71f7-4a27-a806-7debbf320eea\",\"uuid\":\"b2daf644-2400-4fb3-a633-4cd09532d539\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of the Buddha and the \",\"attrs\":{\"start\":1045,\"end\":1068}},{\"type\":\"text\",\"text\":\"nature of phenomena\",\"attrs\":{\"start\":1068,\"end\":1087},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ecb1ac3f-0f71-41d9-a18a-3d68807a68bb\",\"uuid\":\"dd7d600c-c888-4ac3-a714-ed94af5a3c49\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Only the \",\"attrs\":{\"start\":1087,\"end\":1098}},{\"type\":\"text\",\"text\":\"Tathāgata\",\"attrs\":{\"start\":1098,\"end\":1107},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8bf0a239-7fda-4995-8cc7-36b960a1507a\",\"uuid\":\"29e76172-145c-411d-a0e1-4a2d3e46403e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" understands them. We, however, do not. The Dharma taught by the \",\"attrs\":{\"start\":1107,\"end\":1172}},{\"type\":\"text\",\"text\":\"tathāgatas\",\"attrs\":{\"start\":1172,\"end\":1182},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8bf0a239-7fda-4995-8cc7-36b960a1507a\",\"uuid\":\"5e9875ee-fa0d-488e-b42b-fb1934e65794\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" arises according to the various inclinations of \",\"attrs\":{\"start\":1182,\"end\":1231}},{\"type\":\"text\",\"text\":\"beings\",\"attrs\":{\"start\":1231,\"end\":1237},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ad3097fe-b272-4d95-8811-3cbb3824ee9e\",\"uuid\":\"d40ae0ce-d9f7-4823-a668-28d0e35bdaaf\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Their \",\"attrs\":{\"start\":1237,\"end\":1245}},{\"type\":\"text\",\"text\":\"gnosis\",\"attrs\":{\"start\":1245,\"end\":1251},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b36258b5-bd30-4205-aeeb-75bac743076f\",\"uuid\":\"f937332a-0bf3-47fe-b208-0dff0696bbd3\",\"toh\":null}},{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"2dd7efe3-928f-46e3-a19b-e1eee24ba857\",\"label\":\"159\",\"uuid\":\"04d0bdeb-e728-4b6d-b922-a1c462d9351e\",\"start\":1251,\"end\":1251,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" and perception are infinite, whereas ours are merely like the [shallow] hoofprints left by a cow.’ Filled with devotion for these discourses, they also write them down. Having written them down, they also keep them in \",\"attrs\":{\"start\":1251,\"end\":1470}},{\"type\":\"text\",\"text\":\"mind\",\"attrs\":{\"start\":1470,\"end\":1474},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b667709c-9e2a-4877-96d5-8b056867ac96\",\"uuid\":\"a050c39c-c339-44a6-96ea-a1ed8090bc48\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", read them, propagate them, venerate them, expound them, recite them, and chant them aloud. However, because they do not understand these profound teachings in accordance with my underlying intent, they are unable to engage themselves in the various aspects of practice. As a consequence of this, they will further develop their accumulation of merit and \",\"attrs\":{\"start\":1474,\"end\":1830}},{\"type\":\"text\",\"text\":\"gnosis\",\"attrs\":{\"start\":1830,\"end\":1836},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b36258b5-bd30-4205-aeeb-75bac743076f\",\"uuid\":\"5266949b-973b-40f4-ad05-c047dde5c067\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and those whose mental continuums are still immature will bring them to maturity.\",\"attrs\":{\"start\":1836,\"end\":1919}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"e66886a9-505e-48f3-9d1b-a45ea8e97f91\",\"sort\":5451,\"type\":\"translation\",\"label\":\"7.20\",\"alignments\":{\"toh106\":{\"folioUuid\":\"05a6a1a9-399e-486f-9cc2-a14a3cb9274e\",\"toh\":\"toh106\",\"tibetan\":\"$8f\",\"folioNumber\":20,\"volumeNumber\":49}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":2089,\"uuid\":\"e66886a9-505e-48f3-9d1b-a45ea8e97f91\"},\"content\":[{\"type\":\"text\",\"text\":\"“Other \",\"attrs\":{\"start\":0,\"end\":7}},{\"type\":\"text\",\"text\":\"beings\",\"attrs\":{\"start\":7,\"end\":13},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ad3097fe-b272-4d95-8811-3cbb3824ee9e\",\"uuid\":\"35427ba1-d35f-4b2b-89e6-2019be68f0f2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" have not perfectly completed these \",\"attrs\":{\"start\":13,\"end\":49}},{\"type\":\"text\",\"text\":\"stages\",\"attrs\":{\"start\":49,\"end\":55},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4e64e8cc-e904-47f6-8554-e8273dd3587a\",\"uuid\":\"fcb5830e-7946-4ee2-a456-3d867f92f7ba\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" up to the great accumulation of merit and \",\"attrs\":{\"start\":55,\"end\":98}},{\"type\":\"text\",\"text\":\"gnosis\",\"attrs\":{\"start\":98,\"end\":104},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b36258b5-bd30-4205-aeeb-75bac743076f\",\"uuid\":\"2e5d8915-b41b-4e68-af8b-431a47b12a02\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". They are dishonest and insincere. Capable of evaluating and refuting [others’ views], they consider their own as supreme. Once they have heard my teaching, they do not understand my profound explanations in accordance with my underlying intent exactly as it is. Although they have confidence in this teaching, they \",\"attrs\":{\"start\":104,\"end\":421}},{\"type\":\"text\",\"text\":\"wrongly conceive\",\"attrs\":{\"start\":421,\"end\":437},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a3e3ca3d-5d92-43b5-bf7a-d02257107104\",\"uuid\":\"2a7cf9cd-498e-4680-96c1-7509af7c8fec\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" it according to its \",\"attrs\":{\"start\":437,\"end\":458}},{\"type\":\"text\",\"text\":\"literal\",\"attrs\":{\"start\":458,\"end\":465},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"0f1e