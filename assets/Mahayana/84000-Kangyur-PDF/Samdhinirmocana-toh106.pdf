90a-977a-dae3410f2641\",\"definition\":\"\",\"names\":{\"english\":\"conception, saṃjñā\",\"tibetan\":\"འདུ་ཤེས།\",\"sanskrit\":\"saṃjñā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’du shes\"}},{\"uuid\":\"246a0eb5-4b80-4bcc-aa5d-ae60c274b356\",\"authority\":\"0c814657-de47-4ed1-980f-dfa4b965316e\",\"definition\":\"\",\"names\":{\"english\":\"conceptualization\",\"tibetan\":\"རྣམ་པར་རྟོག་པ།, རྣམ་རྟོག\",\"sanskrit\":\"vikalpa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rnam par rtog pa, rnam rtog\"}},{\"uuid\":\"849eab88-55ca-4ea5-b91f-cd427d9d9e81\",\"authority\":\"62d140fc-9783-4985-bbb1-268e3989f2dc\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAlso translated here as “\u003cspan data-glossary-id=\\\"UT22084-049-001-1387\\\"\u003edecide\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"conceptualize, decide, designation\",\"tibetan\":\"གདགས་པ།, གདགས་པ།, བཏགས་པ།\",\"sanskrit\":\"prajñapti, prajñapti, prajñapti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"btags pa, gdags pa, gdags pa\"}},{\"uuid\":\"51155bb1-2098-44df-809d-771de9b1ee1a\",\"authority\":\"62d140fc-9783-4985-bbb1-268e3989f2dc\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAlso translated here as “\u003cspan data-glossary-id=\\\"UT22084-049-001-1365\\\"\u003econceptualize\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"conceptualize, decide, designation\",\"tibetan\":\"གདགས་པ།, གདགས་པ།, བཏགས་པ།\",\"sanskrit\":\"prajñapti, prajñapti, prajñapti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"btags pa, gdags pa, gdags pa\"}},{\"uuid\":\"40b7317d-88e6-4622-81f7-124865177c3a\",\"authority\":\"62d140fc-9783-4985-bbb1-268e3989f2dc\",\"definition\":\"\",\"names\":{\"english\":\"conceptualize, decide, designation\",\"tibetan\":\"གདགས་པ།, གདགས་པ།, བཏགས་པ།\",\"sanskrit\":\"prajñapti, prajñapti, prajñapti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"btags pa, gdags pa, gdags pa\"}},{\"uuid\":\"333327c4-7990-4e05-966c-0b739c81acf4\",\"authority\":\"5af2b070-da8f-4030-b0c1-51cc962b5b26\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eMahāvyutpatti 7587. \u003c/p\u003e\",\"names\":{\"english\":\"conclusive\",\"tibetan\":\"གཅིག་ཏུ་ངེས་པ།\",\"sanskrit\":\"aikāntikaḥ\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gcig tu nges pa\"}},{\"uuid\":\"c41c6d0c-b684-45c0-9367-3c0df3d7d01b\",\"authority\":\"299bac15-ab76-454f-a60c-219b19a9ae43\",\"definition\":\"\",\"names\":{\"english\":\"conditioned\",\"tibetan\":\"འདུ་བྱས།\",\"sanskrit\":\"saṃskṛta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’du byas\"}},{\"uuid\":\"cf78a4e2-f7a7-4e09-992d-8e8c0671369b\",\"authority\":\"da1cbe63-d5d7-4ee7-b579-8f13a92555e3\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAlso translated here as “\u003cspan data-glossary-id=\\\"UT22084-049-001-1369\\\"\u003econditioning mental factors\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"conditioned phenomena, conditioning mental factors\",\"tibetan\":\"འདུ་བྱེད།, འདུ་བྱེད།\",\"sanskrit\":\"saṃskāra, saṃskāra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’du byed, ’du byed\"}},{\"uuid\":\"f4b18959-cf86-4172-a49b-127582d0ac6b\",\"authority\":\"da1cbe63-d5d7-4ee7-b579-8f13a92555e3\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAlso translated here as “\u003cspan data-glossary-id=\\\"UT22084-049-001-1368\\\"\u003econditioned phenomena\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"conditioned phenomena, conditioning mental factors\",\"tibetan\":\"འདུ་བྱེད།, འདུ་བྱེད།\",\"sanskrit\":\"saṃskāra, saṃskāra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’du byed, ’du byed\"}},{\"uuid\":\"43d25ace-6522-4836-895c-e0cd7dfb9684\",\"authority\":\"dab66521-b21a-4352-9e33-fac61d2de879\",\"definition\":\"\",\"names\":{\"english\":\"conditioning process of the mental factors\",\"tibetan\":\"འདུ་བྱེད་མངོན་པར་འདུ་བྱ་བ།\",\"sanskrit\":\"saṃskārābhi­saṃskaraṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’du byed mngon par ’du bya ba\"}},{\"uuid\":\"a74858e1-f1ef-45ce-b905-05d7ffee13f3\",\"authority\":\"e82eb647-b8df-4462-acb7-2fb013e741b2\",\"definition\":\"\",\"names\":{\"english\":\"conducive\",\"tibetan\":\"གྲོགས།\",\"sanskrit\":\"sahāya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"grogs\"}},{\"uuid\":\"d1a5a535-923a-4fe0-9931-5e360f8fd1e9\",\"authority\":\"c6403928-d719-424b-a1fc-6a07d1909655\",\"definition\":\"\",\"names\":{\"english\":\"confined\",\"tibetan\":\"རྗེས་སུ་འབྲེལ་བ།\",\"sanskrit\":\"anubandha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rjes su ’brel ba\"}},{\"uuid\":\"6cd964f3-8507-4616-b59f-03c70b37f614\",\"authority\":\"937bee46-0d62-4617-97ee-0007c098672a\",\"definition\":\"\",\"names\":{\"english\":\"confusion\",\"tibetan\":\"འཁྲུལ་པ།\",\"sanskrit\":\"bhrānta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’khrul pa\"}},{\"uuid\":\"b202258c-dc0d-4dc8-bed1-637aec1218ec\",\"authority\":\"6fd987d5-c4cc-42d9-9bce-8d2b0784929f\",\"definition\":\"\",\"names\":{\"english\":\"consequence\",\"tibetan\":\"ཆུད་མི་ཟ་བ།\",\"sanskrit\":\"avipraṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chud mi za ba\"}},{\"uuid\":\"ef971d85-9939-43c2-b733-f361b9528c88\",\"authority\":\"78b3b7c2-b25f-447a-9cab-71278587bbac\",\"definition\":\"\",\"names\":{\"english\":\"consideration, considering, fabrication, imagination, parikalpa, paritarka\",\"tibetan\":\"ཀུན་ཏུ་རྟོག་པ།, ཡོངས་སུ་རྟོག་པ།, ཡོངས་སུ་རྟོག་པ།\",\"sanskrit\":\"parikalpa, parikalpa, paritarka, saṃkalpa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kun tu rtog pa, yongs su rtog pa, yongs su rtog pa\"}},{\"uuid\":\"837db9ef-79a8-4fdb-be27-a77b04ceb440\",\"authority\":\"78b3b7c2-b25f-447a-9cab-71278587bbac\",\"definition\":\"\",\"names\":{\"english\":\"consideration, considering, fabrication, imagination, parikalpa, paritarka\",\"tibetan\":\"ཀུན་ཏུ་རྟོག་པ།, ཡོངས་སུ་རྟོག་པ།, ཡོངས་སུ་རྟོག་པ།\",\"sanskrit\":\"parikalpa, parikalpa, paritarka, saṃkalpa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kun tu rtog pa, yongs su rtog pa, yongs su rtog pa\"}},{\"uuid\":\"7c1cb501-6e53-491d-8cf0-f84c3fd49fd1\",\"authority\":\"78b3b7c2-b25f-447a-9cab-71278587bbac\",\"definition\":\"\",\"names\":{\"english\":\"consideration, considering, fabrication, imagination, parikalpa, paritarka\",\"tibetan\":\"ཀུན་ཏུ་རྟོག་པ།, ཡོངས་སུ་རྟོག་པ།, ཡོངས་སུ་རྟོག་པ།\",\"sanskrit\":\"parikalpa, parikalpa, paritarka, saṃkalpa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kun tu rtog pa, yongs su rtog pa, yongs su rtog pa\"}},{\"uuid\":\"fb787432-dbbb-4be6-9bcb-8094373c9ba5\",\"authority\":\"044b7293-7476-45ad-94b3-36dc1211e50e\",\"definition\":\"\",\"names\":{\"english\":\"constant\",\"tibetan\":\"རྣམ་པར་གནས་པ།\",\"sanskrit\":\"vyavasthita\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rnam par gnas pa\"}},{\"uuid\":\"c6863d5d-f557-4305-90d2-9dbb8228b0e2\",\"authority\":\"e3685c95-a735-4cb3-a0e7-d0d5dc0b3295\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe eighteen \u003cspan class=\\\"ignore\\\"\u003econstituents\u003c/span\u003e are: eye, visual \u003cspan class=\\\"ignore\\\"\u003eobject\u003c/span\u003e, visual consciousness; ear, sound, auditive consciousness; nose, smell, olfactory consciousness; tongue, taste, gustative consciousness; body, touch, tactile consciousness; \u003cspan class=\\\"ignore\\\"\u003emind\u003c/span\u003e, mental \u003cspan class=\\\"ignore\\\"\u003eobjects\u003c/span\u003e, mental consciousness. When it refers to six elements, they are: earth, water, fire, air, \u003cspan data-glossary-id=\\\"UT22084-049-001-1620\\\"\u003espace\u003c/span\u003e, and consciousness.\u003c/p\u003e\",\"names\":{\"english\":\"constituent\",\"tibetan\":\"ཁམས།\",\"sanskrit\":\"dhātu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"khams\"}},{\"uuid\":\"aa99c966-8207-42e7-b979-d5ba4ea87da7\",\"authority\":\"221f5446-c7cf-4b44-abf7-b81064396399\",\"definition\":\"\",\"names\":{\"english\":\"contemplation\",\"tibetan\":\"བསམས་པ།\",\"sanskrit\":\"cintā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bsams pa\"}},{\"uuid\":\"4e5c2faa-9e68-4024-a3d5-daf175e06d51\",\"authority\":\"3e9c5b32-1c99-4c05-a4b7-a93b8c8b8d05\",\"definition\":\"\",\"names\":{\"english\":\"convention\",\"tibetan\":\"རྗེས་སུ་ཐ་སྙད།\",\"sanskrit\":\"anuvyavahāra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rjes su tha snyad\"}},{\"uuid\":\"0ab265b8-c9d5-46e6-bcb4-13de5249005e\",\"authority\":\"a42fd1a1-115f-493e-a09c-e83dd37d4794\",\"definition\":\"\",\"names\":{\"english\":\"conventionally\",\"tibetan\":\"བརྡ།\",\"sanskrit\":\"saṃketa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"brda\"}},{\"uuid\":\"4089309d-5428-43d0-9540-5d93dba16a4f\",\"authority\":\"7ec366e5-b1f6-4f41-a4e4-bb0352f54aa7\",\"definition\":\"\",\"names\":{\"english\":\"correct concentration\",\"tibetan\":\"ཡང་དག་པའི་ཏིང་ངེ་འཛིན།\",\"sanskrit\":\"samyaksamādhi\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yang dag pa’i ting nge ’dzin\"}},{\"uuid\":\"330c83ee-7197-4c35-985e-d35a296f5ab4\",\"authority\":\"b72040dc-e0f7-4d9d-9ed9-ff2fb7d1d3de\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee “\u003cspan data-glossary-id=\\\"UT22084-049-001-1470\\\"\u003efour correct self-restraints\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"correct self-restraints, self-restraints\",\"tibetan\":\"ཡང་དག་པར་སྤོང་བ།\",\"sanskrit\":\"samyakprahāṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yang dag par spong ba\"}},{\"uuid\":\"beb8bd2f-4c8d-4044-b122-b481bb12239f\",\"authority\":\"6d5bda0a-7bf1-4364-9548-abaee2c7ab40\",\"definition\":\"\",\"names\":{\"english\":\"corruption, dauṣṭhulya\",\"tibetan\":\"གནས་ངན་ལེན།\",\"sanskrit\":\"dauṣṭhulya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gnas ngan len\"}},{\"uuid\":\"1f5b2933-956b-4d29-8336-bf4a6a09429e\",\"authority\":\"af25965a-d479-4c7c-93d9-c7ca052e9cf8\",\"definition\":\"\",\"names\":{\"english\":\"dedication of merit\",\"tibetan\":\"ཡོངས་སུ་བསྔོ་བ།\",\"sanskrit\":\"pariṇata, pariṇāmanā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yongs su bsngo ba\"}},{\"uuid\":\"eeb7f80e-c2e0-437d-b066-fe52cc37586c\",\"authority\":\"5b90301e-f02f-4ee0-a0f4-c25241dc049c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eLit. “outer.”\u003c/p\u003e\",\"names\":{\"english\":\"deeper\",\"tibetan\":\"ཕྱི།, ཕྲི།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"phri, phyi\"}},{\"uuid\":\"c35b6b5e-a42a-4b59-b65c-8599a8539bf4\",\"authority\":\"84bd2cb3-7065-496c-b129-ce8382ca5ec2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe forest, located outside of Varanasi, where the Buddha first taught the Dharma.\u003c/p\u003e\",\"names\":{\"english\":\"deer park\",\"tibetan\":\"རི་དགས་ཀྱི་ནགས།\",\"sanskrit\":\"mṛgadāva\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ri dags kyi nags\"}},{\"uuid\":\"9d6bad47-4054-4cc3-8a45-1638d9041602\",\"authority\":\"c87671dd-3ffd-410d-a94d-fca04ee8ccc2\",\"definition\":\"$66\",\"names\":{\"english\":\"defilement\",\"tibetan\":\"ཉོན་མོངས་པ།\",\"sanskrit\":\"kleśa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nyon mongs pa\"}},{\"uuid\":\"746b96f6-c6e3-4fce-9151-a270508e50d8\",\"authority\":\"e2045c3c-1ea8-4e9c-b1c8-18b18102e6b3\",\"definition\":\"\",\"names\":{\"english\":\"defining characteristic specific to, specific defining characteristic\",\"tibetan\":\"རང་གི་མཚན་ཉིད།\",\"sanskrit\":\"svalakṣaṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rang gi mtshan nyid\"}},{\"uuid\":\"f4503be0-02d4-474f-8f1c-a69993648574\",\"authority\":\"1c610456-c9db-4225-82d0-7205608630eb\",\"definition\":\"\",\"names\":{\"english\":\"defining characteristic, defining characteristic, lakṣaṇa\",\"tibetan\":\"མཚན་ཉིད།, མཚན་ཉིད།\",\"sanskrit\":\"lakṣaṇa, svabhāvalakṣaṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mtshan nyid, mtshan nyid\"}},{\"uuid\":\"e6185c2c-6566-40d4-a854-a5c1ae649cf9\",\"authority\":\"1c610456-c9db-4225-82d0-7205608630eb\",\"definition\":\"\",\"names\":{\"english\":\"defining characteristic, defining characteristic, lakṣaṇa\",\"tibetan\":\"མཚན་ཉིད།, མཚན་ཉིད།\",\"sanskrit\":\"lakṣaṇa, svabhāvalakṣaṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mtshan nyid, mtshan nyid\"}},{\"uuid\":\"e2d5ea69-c013-4922-b6c0-d08434570157\",\"authority\":\"6ef7f2eb-e75e-4754-88d1-5fcc50aa3cc0\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the three poisons (\u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003edug gsum\u003c/em\u003e) along with aversion, or hatred, and attachment, or desire, which perpetuate the sufferings of cyclic existence. It is the obfuscating mental state which obstructs an individual from generating knowledge or insight, and it is said to be the dominant characteristic of the animal world in general. Commonly rendered as confusion, delusion, and ignorance, or bewilderment.\u003c/p\u003e\",\"names\":{\"english\":\"delusion\",\"tibetan\":\"གཏི་མུག\",\"sanskrit\":\"moha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gti mug\"}},{\"uuid\":\"5fc98b2a-f628-432a-b121-c416797c1d00\",\"authority\":\"62d464da-b7de-40a2-8acb-7b1a0c64dfb5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAlso translated here as “\u003cspan data-glossary-id=\\\"UT22084-049-001-1560\\\"\u003eobscuration\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"delusion, obscuration\",\"tibetan\":\"ཀུན་ཏུ་རྨོངས་པ།, ཀུན་ཏུ་རྨོངས་པ།, རྣམ་པར་རྨོངས་པ།\",\"sanskrit\":\"saṃmoha, saṃmoha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kun tu rmongs pa, kun tu rmongs pa, rnam par rmongs pa\"}},{\"uuid\":\"9c961f85-80e2-4d1c-a536-20d956f9dbe8\",\"authority\":\"62d464da-b7de-40a2-8acb-7b1a0c64dfb5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAlso translated here as “\u003cspan data-glossary-id=\\\"UT22084-049-001-1402\\\"\u003edelusion\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"delusion, obscuration\",\"tibetan\":\"ཀུན་ཏུ་རྨོངས་པ།, ཀུན་ཏུ་རྨོངས་པ།, རྣམ་པར་རྨོངས་པ།\",\"sanskrit\":\"saṃmoha, saṃmoha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kun tu rmongs pa, kun tu rmongs pa, rnam par rmongs pa\"}},{\"uuid\":\"5caeef5e-c07a-4329-a983-856788c5fa41\",\"authority\":\"a7dfb0c0-cdec-49b9-8c14-b5200645acda\",\"definition\":\"\",\"names\":{\"english\":\"demonstration\",\"tibetan\":\"བཤད་པ།\",\"sanskrit\":\"deśana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bshad pa\"}},{\"uuid\":\"8711cdc7-0cd4-4533-8584-6a1a06a4f307\",\"authority\":\"01853cc8-7b6e-49f1-8825-d80aaaf63889\",\"definition\":\"\",\"names\":{\"english\":\"description\",\"tibetan\":\"རྣམ་པར་བསྙད་པ།\",\"sanskrit\":\"vyākhyā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rnam par bsnyad pa\"}},{\"uuid\":\"635477fe-b5fd-4b2a-9642-f55d341eadf5\",\"authority\":\"fa2336ec-1d17-4734-9c90-994f8614a1dc\",\"definition\":\"\",\"names\":{\"english\":\"determination, established, establishing, posited\",\"tibetan\":\"རྣམ་པར་བཞག་པ།, རྣམ་པར་བཞག་པ།, རྣམ་པར་བཞག་པ།\",\"sanskrit\":\"vyavasthā, vyavasthā, vyavasthā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rnam par bzhag pa, rnam par bzhag pa, rnam par bzhag pa\"}},{\"uuid\":\"25ffc2fd-62b2-45e5-9cdd-388f2d1c28cc\",\"authority\":\"fa2336ec-1d17-4734-9c90-994f8614a1dc\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAlso translated here as “\u003cspan data-glossary-id=\\\"UT22084-049-001-1582\\\"\u003eposited\u003c/span\u003e” and “determination.”\u003c/p\u003e\",\"names\":{\"english\":\"determination, established, establishing, posited\",\"tibetan\":\"རྣམ་པར་བཞག་པ།, རྣམ་པར་བཞག་པ།, རྣམ་པར་བཞག་པ།\",\"sanskrit\":\"vyavasthā, vyavasthā, vyavasthā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rnam par bzhag pa, rnam par bzhag pa, rnam par bzhag pa\"}},{\"uuid\":\"e8587840-8619-45ba-a6ca-c2945fd37cca\",\"authority\":\"fa2336ec-1d17-4734-9c90-994f8614a1dc\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThis term has the connotation of something being agreed upon, represented, arranged, settled, decreed, or \u003cspan class=\\\"ignore\\\"\u003eestablished\u003c/span\u003e. Also translated here as “\u003cspan data-glossary-id=\\\"UT22084-049-001-1447\\\"\u003eestablished\u003c/span\u003e” and “\u003cspan class=\\\"ignore\\\"\u003eposited\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"determination, established, establishing, posited\",\"tibetan\":\"རྣམ་པར་བཞག་པ།, རྣམ་པར་བཞག་པ།, རྣམ་པར་བཞག་པ།\",\"sanskrit\":\"vyavasthā, vyavasthā, vyavasthā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rnam par bzhag pa, rnam par bzhag pa, rnam par bzhag pa\"}},{\"uuid\":\"110462bd-ffe8-4b89-91b9-e506e21441b0\",\"authority\":\"0baf976f-a73f-4674-bea3-56e3d670ba1a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAlso rendered here as “\u003cspan data-glossary-id=\\\"UT22084-049-001-1716\\\"\u003ekeeping it in mind\u003c/span\u003e,” “\u003cspan data-glossary-id=\\\"UT22084-049-001-1717\\\"\u003eformula\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"dhāraṇī, formula, keeping it in mind\",\"tibetan\":\"གཟུངས།, གཟུངས།, གཟུངས།\",\"sanskrit\":\"dhāraṇī, dhāraṇī, dhāraṇī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gzungs, gzungs, gzungs\"}},{\"uuid\":\"ab86af6e-eb6b-4db7-9540-35f39534ff7d\",\"authority\":\"0baf976f-a73f-4674-bea3-56e3d670ba1a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAlso rendered here as “\u003cspan data-glossary-id=\\\"UT22084-049-001-1408\\\"\u003edhāraṇī\u003c/span\u003e,” “\u003cspan data-glossary-id=\\\"UT22084-049-001-1717\\\"\u003eformula\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"dhāraṇī, formula, keeping it in mind\",\"tibetan\":\"གཟུངས།, གཟུངས།, གཟུངས།\",\"sanskrit\":\"dhāraṇī, dhāraṇī, dhāraṇī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gzungs, gzungs, gzungs\"}},{\"uuid\":\"d1e79f42-b8af-4467-91a1-553eed148d5e\",\"authority\":\"0baf976f-a73f-4674-bea3-56e3d670ba1a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e“\u003cspan class=\\\"ignore\\\"\u003eFormula\u003c/span\u003e” in the sense of a “mnemonic \u003cspan class=\\\"ignore\\\"\u003eformula\u003c/span\u003e” encapsulating a method or key points in a few words. On the meaning of this term, see Braarvig 1985.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003eAlso rendered here as “\u003cspan data-glossary-id=\\\"UT22084-049-001-1716\\\"\u003ekeeping it in mind\u003c/span\u003e,” “\u003cspan data-glossary-id=\\\"UT22084-049-001-1408\\\"\u003edhāraṇī\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"dhāraṇī, formula, keeping it in mind\",\"tibetan\":\"གཟུངས།, གཟུངས།, གཟུངས།\",\"sanskrit\":\"dhāraṇī, dhāraṇī, dhāraṇī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gzungs, gzungs, gzungs\"}},{\"uuid\":\"32ab0975-da71-4c63-92b8-1311c9ecf499\",\"authority\":\"e33c0257-cc6f-4ed5-a185-d0ca72550975\",\"definition\":\"\",\"names\":{\"english\":\"Dharma discourse\",\"tibetan\":\"ཆོས་ཀྱི་རྣམ་གྲངས།\",\"sanskrit\":\"dharmaparyāya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chos kyi rnam grangs\"}},{\"uuid\":\"0e60513c-0406-43a4-aca5-0c0a616ab25a\",\"authority\":\"9ecb429c-d2be-4ab7-bb10-0882fc41ce3d\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eMahāvyutpatti 353. \u003c/p\u003e\",\"names\":{\"english\":\"Dharma of the nonexistence of defining characteristics\",\"tibetan\":\"མཚན་ཉིད་མེད་པའི་ཆོས།\",\"sanskrit\":\"alakṣaṇadharma\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mtshan nyid med pa’i chos\"}},{\"uuid\":\"d0071581-760e-4a6f-b1e7-14a3e072eb1f\",\"authority\":\"6e5dc81d-3c8a-493e-9a77-987aa0ef3895\",\"definition\":\"\",\"names\":{\"english\":\"dharmakāya, truth body\",\"tibetan\":\"ཆོས་ཀྱི་སྐུ།\",\"sanskrit\":\"dharmakāya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chos kyi sku\"}},{\"uuid\":\"ecb1ac3f-0f71-41d9-a18a-3d68807a68bb\",\"authority\":\"d5a9ed53-8d7f-4a71-ba55-23fdb5e67fda\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe real nature, true quality, or condition of things. Throughout Buddhist discourse this term is used in two distinct ways. In one, it designates the relative nature that is either the essential characteristic of a specific phenomenon, such as the heat of fire and the moisture of water, or the defining feature of a specific term or category. The other very important and widespread way it is used is to designate the ultimate nature of all phenomena, which cannot be conveyed in conceptual, dualistic terms and is often synonymous with emptiness or the absence of intrinsic existence.\u003c/p\u003e\",\"names\":{\"english\":\"dharmatā, nature of phenomena\",\"tibetan\":\"ཆོས་ཉིད།\",\"sanskrit\":\"dharmatā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chos nyid\"}},{\"uuid\":\"5359c54c-64c3-4292-8516-a81ee7baed3b\",\"authority\":\"e44b3938-8b38-4cc3-93fa-ba04ebad4418\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA bodhisattva mahāsattva.\u003c/p\u003e\",\"names\":{\"english\":\"Dharmodgata\",\"tibetan\":\"ཆོས་འཕགས།\",\"sanskrit\":\"dharmodgata\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chos ’phags\"}},{\"uuid\":\"a2901304-6ccb-4623-ac9f-79c0293e44a3\",\"authority\":\"20406663-7d7c-498a-9e4a-dca327a8a87b\",\"definition\":\"\",\"names\":{\"english\":\"differentiating, vibhājanā\",\"tibetan\":\"རྣམ་པར་འབྱེད་པ།\",\"sanskrit\":\"vibhājanā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rnam par ’byed pa\"}},{\"uuid\":\"065909f4-1b7c-4381-861a-1f120f6a0554\",\"authority\":\"e8f0b0c6-293c-40a3-9546-8a8dd36b0bfd\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAlso translated here as “\u003cspan data-glossary-id=\\\"UT22084-049-001-1682\\\"\u003evigor\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"diligence, vigor\",\"tibetan\":\"བརྩོན་འགྲུས།, བརྩོན་འགྲུས།\",\"sanskrit\":\"viryā, vīrya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"brtson ’grus, brtson ’grus\"}},{\"uuid\":\"a8971ade-695e-45fe-b0b9-267ce0083fd3\",\"authority\":\"e8f0b0c6-293c-40a3-9546-8a8dd36b0bfd\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAlso translated here as “\u003cspan data-glossary-id=\\\"UT22084-049-001-1412\\\"\u003ediligence\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"diligence, vigor\",\"tibetan\":\"བརྩོན་འགྲུས།, བརྩོན་འགྲུས།\",\"sanskrit\":\"viryā, vīrya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"brtson ’grus, brtson ’grus\"}},{\"uuid\":\"674bbbfe-6b4f-4425-bd35-05bc168ed629\",\"authority\":\"16d7ec15-2a08-4cfc-9306-e866706454dc\",\"definition\":\"\",\"names\":{\"english\":\"direct cognition\",\"tibetan\":\"མངོན་སུམ་གྱི་ཚད་མ།\",\"sanskrit\":\"pratyakṣapramāṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mngon sum gyi tshad ma\"}},{\"uuid\":\"f19bd612-2823-4192-89e9-c338ff237e73\",\"authority\":\"3412bfd8-94dd-4d9e-a8a1-43eb6ce85438\",\"definition\":\"\",\"names\":{\"english\":\"direct their attention, directing attention, directing one’s attention\",\"tibetan\":\"ཡིད་ལ་བྱེད།\",\"sanskrit\":\"manasikāra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yid la byed\"}},{\"uuid\":\"51be5a4a-bca5-49d3-b607-692e85af7dd5\",\"authority\":\"e9461679-1481-4dc2-a701-b961ef491c5d\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eMahāvyutpatti 7450. \u003c/p\u003e\",\"names\":{\"english\":\"discerning\",\"tibetan\":\"ངེས་པར་རྟོག་པ།, ངེས་པར་རྟོགས་པ།\",\"sanskrit\":\"nirūpaṇā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nges par rtog pa, nges par rtogs pa\"}},{\"uuid\":\"8fb62f7f-1ea7-435e-b5ca-f36314dea7e9\",\"authority\":\"6e987e0f-94af-48e1-a601-9997586b7050\",\"definition\":\"\",\"names\":{\"english\":\"discerning, pravicaya\",\"tibetan\":\"རབ་ཏུ་རྣམ་པར་འབྱེད་པ།\",\"sanskrit\":\"pravicaya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rab tu rnam par ’byed pa\"}},{\"uuid\":\"6217fe34-e4af-42f1-b937-302537e92a18\",\"authority\":\"b38659ed-9407-4d7d-b9f4-1586169f4bc2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eMorally virtuous or disciplined conduct and the abandonment of morally undisciplined conduct of body, speech, and mind. In a general sense, moral discipline is the cause for rebirth in higher, more favorable states, but it is also foundational to Buddhist practice as one of the three trainings (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003etriśikṣā\u003c/em\u003e) and one of the six perfections of a bodhisattva. Often rendered as “ethics,” “discipline,” and “morality.”\u003c/p\u003e\",\"names\":{\"english\":\"discipline\",\"tibetan\":\"ཚུལ་ཁྲིམས།\",\"sanskrit\":\"śīla\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"tshul khrims\"}},{\"uuid\":\"95b762f9-b8ce-4661-abd5-45d504108e8c\",\"authority\":\"37ec4184-87c8-4193-a1c7-304d9915bf23\",\"definition\":\"\",\"names\":{\"english\":\"discourses teaching Dharma\",\"tibetan\":\"ཆོས་གདགས་པ་རྣམ་པར་གཞག་པ།\",\"sanskrit\":\"dharmaprajñaptivyavasthā(pa)na\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chos gdags pa rnam par gzhag pa\"}},{\"uuid\":\"bddb0c1a-c339-4394-8d79-bb80288cd87e\",\"authority\":\"41057942-4347-4f05-a252-b83fd6416ed4\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAlso rendered here as “\u003cspan data-glossary-id=\\\"UT22084-049-001-1728\\\"\u003ediscriminating\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"discriminate, discriminating, distinguish, distinguishing, nitīraṇa\",\"tibetan\":\"བྱེ་བྲག་འབྱེད་པ།, བྱེ་བྲག་འབྱེད་པ།\",\"sanskrit\":\"nitīraṇa, nitīraṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bye brag ’byed pa, bye brag ’byed pa\"}},{\"uuid\":\"cb9bf06e-4f3e-4b5a-a7fa-dc3116844471\",\"authority\":\"41057942-4347-4f05-a252-b83fd6416ed4\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAlso rendered here as “\u003cspan data-glossary-id=\\\"UT22084-049-001-1424\\\"\u003edistinguishing\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"discriminate, discriminating, distinguish, distinguishing, nitīraṇa\",\"tibetan\":\"བྱེ་བྲག་འབྱེད་པ།, བྱེ་བྲག་འབྱེད་པ།\",\"sanskrit\":\"nitīraṇa, nitīraṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bye brag ’byed pa, bye brag ’byed pa\"}},{\"uuid\":\"c9057224-3d20-4049-b8cd-4719ba6c602e\",\"authority\":\"dd37d7b0-d649-40fb-8664-3e0ef147dd70\",\"definition\":\"\",\"names\":{\"english\":\"discrimination of dharmas\",\"tibetan\":\"ཆོས་རབ་ཏུ་རྣམ་པར་འབྱེད་པ།\",\"sanskrit\":\"dharmapravicaya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chos rab tu rnam par ’byed pa\"}},{\"uuid\":\"737fe7f0-9182-42a4-9c4b-98e0a7bf2283\",\"authority\":\"81b33594-c247-4db8-ab09-b1ad2803bc82\",\"definition\":\"\",\"names\":{\"english\":\"distinct\",\"tibetan\":\"ཐ་དད་པ།\",\"sanskrit\":\"bheda\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"tha dad pa\"}},{\"uuid\":\"d204abc1-4ab7-4286-9f7e-2e91873a0e6e\",\"authority\":\"baed1410-64d8-4464-a22d-692b9566791e\",\"definition\":\"\",\"names\":{\"english\":\"distinctive\",\"tibetan\":\"བྱེ་བྲག\",\"sanskrit\":\"viśeṣa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bye brag\"}},{\"uuid\":\"d87d5ff4-ca2a-428c-82d4-47c697d525ed\",\"authority\":\"46cc3544-f9fa-4ce1-8ffe-965202a33794\",\"definition\":\"\",\"names\":{\"english\":\"distinctive characteristic\",\"tibetan\":\"བྱེ་བྲག་གི་མཚན་ཉིད།\",\"sanskrit\":\"viṣeśalakṣaṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bye brag gi mtshan nyid\"}},{\"uuid\":\"473a3019-9fa8-4939-b8f8-b19071a434f6\",\"authority\":\"f4c4d079-e448-4eb6-9161-e2d35d2e0d8c\",\"definition\":\"\",\"names\":{\"english\":\"distinctly perceive, distinctly perceived\",\"tibetan\":\"རབ་ཏུ་ཤེས།\",\"sanskrit\":\"prajānāti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rab tu shes\"}},{\"uuid\":\"e22107eb-623c-4d81-b876-cce17e4985d3\",\"authority\":\"c487b694-c101-4fc0-a0e8-4926847abc54\",\"definition\":\"\",\"names\":{\"english\":\"diversity of things\",\"tibetan\":\"ཇི་སྙེད་ཡོད་པ་ཉིད།\",\"sanskrit\":\"yāvadbhāvikatā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ji snyed yod pa nyid\"}},{\"uuid\":\"e2261750-30ce-449b-9518-7b3653e343cc\",\"authority\":\"ebb48fae-4edb-40ff-b9e7-188a2a3f4a98\",\"definition\":\"\",\"names\":{\"english\":\"domain of truth\",\"tibetan\":\"ཆོས་ཀྱི་དབྱིངས།\",\"sanskrit\":\"dharmadhātu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chos kyi dbyings\"}},{\"uuid\":\"33b83df7-3758-446a-b05a-c680f923bb50\",\"authority\":\"4359bedf-d1fb-40ca-9f05-72472706f5ac\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee Buswell \u0026amp; Lopez 2014, p. 2.\u003c/p\u003e\",\"names\":{\"english\":\"domains of mastery\",\"tibetan\":\"ཟིལ་གྱིས་གནོན་པའི་སྐྱེ་མཆེད།\",\"sanskrit\":\"abhibhvāyatana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"zil gyis gnon pa’i skye mched\"}},{\"uuid\":\"be3e23ec-42bc-492e-aa32-e7774419eef2\",\"authority\":\"00dc2cef-9bd7-4e03-8598-bce48d222170\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThis term corresponds to the \u003cem class=\\\"foreign text-pi\\\" lang=\\\"pi-LATN\\\"\u003ekasiṇa\u003c/em\u003e of the Pāli tradition, a visualization \u003cspan data-glossary-id=\\\"UT22084-049-001-1557\\\"\u003eobject\u003c/span\u003e is used as a support for the totality of the meditator’s attention. \u003c/p\u003e\",\"names\":{\"english\":\"domains of totality\",\"tibetan\":\"ཟད་པར་གྱི་སྐྱེ་མཆེད།\",\"sanskrit\":\"kṛtsnāyatana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"zad par gyi skye mched\"}},{\"uuid\":\"af32ecfa-1b74-4d47-a27a-d2ab3965f2ac\",\"authority\":\"a0a8e6fe-d080-4159-9e8d-5270c96d0706\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eType of Sanskrit compound.\u003c/p\u003e\",\"names\":{\"english\":\"dvandva\",\"tibetan\":\"\",\"sanskrit\":\"dvandva\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"\"}},{\"uuid\":\"b1376735-2044-4e82-b1fb-c62d59518e2a\",\"authority\":\"075f4092-07a0-45c5-8fa8-28b2b6b3f68f\",\"definition\":\"\",\"names\":{\"english\":\"effortless, spontaneously accomplished\",\"tibetan\":\"ལྷུན་གྱིས་གྲུབ་པ།, ལྷུན་གྱིས་གྲུབ་པ།\",\"sanskrit\":\"anābhoga, anābhoga\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lhun gyis grub pa, lhun gyis grub pa\"}},{\"uuid\":\"1f853a8d-2ff1-43cd-92a9-135c55fb533a\",\"authority\":\"075f4092-07a0-45c5-8fa8-28b2b6b3f68f\",\"definition\":\"\",\"names\":{\"english\":\"effortless, spontaneously accomplished\",\"tibetan\":\"ལྷུན་གྱིས་གྲུབ་པ།, ལྷུན་གྱིས་གྲུབ་པ།\",\"sanskrit\":\"anābhoga, anābhoga\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lhun gyis grub pa, lhun gyis grub pa\"}},{\"uuid\":\"88fa2d14-a7a7-4f63-9707-f95aeff41c80\",\"authority\":\"69642f08-5f73-44bf-8300-c0b0a8371e6b\",\"definition\":\"\",\"names\":{\"english\":\"elaboration of conventional expressions\",\"tibetan\":\"ཐ་སྙད་འདོགས་པའི་སྤྲོས་པ།\",\"sanskrit\":\"vyavahāraprapañca\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"tha snyad ’dogs pa’i spros pa\"}},{\"uuid\":\"5c8dc01a-3e4b-4a7e-b19f-3574a48205a4\",\"authority\":\"8654b96c-6b27-41bd-a0e9-a38c6f1542ff\",\"definition\":\"\",\"names\":{\"english\":\"eloquence\",\"tibetan\":\"སྤོབས་པ།\",\"sanskrit\":\"pratibhāna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"spobs pa\"}},{\"uuid\":\"8776caa7-9402-49c7-95df-bfa9a820b85b\",\"authority\":\"6e065713-5e0f-41dc-908b-5638ea658a48\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee \u003ca href=\\\"end-notes.xhtml#UT22084-049-001-1099\\\" data-pointer-type=\\\"id\\\"\u003en.365\u003c/a\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"emanation\",\"tibetan\":\"སྤྲུལ་པ།\",\"sanskrit\":\"nirmāṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sprul pa\"}},{\"uuid\":\"e08703f2-fd27-4645-972a-37566d302889\",\"authority\":\"9692559e-037d-4ec3-acf1-df2ebffe2597\",\"definition\":\"\",\"names\":{\"english\":\"emanation bodies, emanation body\",\"tibetan\":\"སྤྲུལ་སྐུ།\",\"sanskrit\":\"nirmāṇakāya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sprul sku\"}},{\"uuid\":\"1d4420eb-eac6-4d43-9fa1-048e40c71418\",\"authority\":\"45e85493-7355-4690-b982-f729a7fb85cf\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAlso translated here as “\u003cspan data-glossary-id=\\\"UT22084-049-001-1570\\\"\u003epathway\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"emancipated, emancipating, emancipation, gone forth, pathway\",\"tibetan\":\"ངེས་པར་འབྱུང་བ།, ངེས་པར་འབྱུང་བ།, ངེས་པར་འབྱུང་བ།\",\"sanskrit\":\"niryātaka, niryāṇa, niryāṇa, niḥsaraṇa, niḥsaraṇa, parivrājaka\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nges par ’byung ba, nges par ’byung ba, nges par ’byung ba\"}},{\"uuid\":\"410acf04-e631-4372-a5a7-72ce6e293126\",\"authority\":\"45e85493-7355-4690-b982-f729a7fb85cf\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eHaving left one’s home to become a wandering mendicant. Also translated here as \u003cspan data-glossary-id=\\\"UT22084-049-001-1434\\\"\u003eemancipation\u003c/span\u003e and as \u003cspan data-glossary-id=\\\"UT22084-049-001-1570\\\"\u003epathway\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"emancipated, emancipating, emancipation, gone forth, pathway\",\"tibetan\":\"ངེས་པར་འབྱུང་བ།, ངེས་པར་འབྱུང་བ།, ངེས་པར་འབྱུང་བ།\",\"sanskrit\":\"niryātaka, niryāṇa, niryāṇa, niḥsaraṇa, niḥsaraṇa, parivrājaka\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nges par ’byung ba, nges par ’byung ba, nges par ’byung ba\"}},{\"uuid\":\"36444cda-8207-40cf-ba61-86b5cdb3d739\",\"authority\":\"45e85493-7355-4690-b982-f729a7fb85cf\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSetting forth, issue, exit, departure, escape, a road out of town. Also translated here as “\u003cspan data-glossary-id=\\\"UT22084-049-001-1434\\\"\u003eemancipated\u003c/span\u003e” and “\u003cspan data-glossary-id=\\\"UT22084-049-001-1486\\\"\u003egone forth\u003c/span\u003e.”\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003eSee also \u003ca href=\\\"end-notes.xhtml#UT22084-049-001-177\\\" data-pointer-type=\\\"id\\\"\u003en.39\u003c/a\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"emancipated, emancipating, emancipation, gone forth, pathway\",\"tibetan\":\"ངེས་པར་འབྱུང་བ།, ངེས་པར་འབྱུང་བ།, ངེས་པར་འབྱུང་བ།\",\"sanskrit\":\"niryātaka, niryāṇa, niryāṇa, niḥsaraṇa, niḥsaraṇa, parivrājaka\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nges par ’byung ba, nges par ’byung ba, nges par ’byung ba\"}},{\"uuid\":\"986c5541-3cde-4239-9e0e-933b5ef0981e\",\"authority\":\"73d1ceda-eda2-4181-ad71-d9c09c063106\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eEmptiness denotes the ultimate nature of reality, the total absence of inherent existence and self-identity with respect to all phenomena. According to this view, all things and events are devoid of any independent, intrinsic reality that constitutes their essence. Nothing can be said to exist independent of the complex network of factors that gives rise to its origination, nor are phenomena independent of the cognitive processes and mental constructs that make up the conventional framework within which their identity and existence are posited. When all levels of conceptualization dissolve and when all forms of dichotomizing tendencies are quelled through deliberate meditative deconstruction of conceptual elaborations, the ultimate nature of reality will finally become manifest. It is the first of the three gateways to liberation.\u003c/p\u003e\",\"names\":{\"english\":\"emptiness\",\"tibetan\":\"སྟོང་པ་ཉིད།\",\"sanskrit\":\"śūnyatā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"stong pa nyid\"}},{\"uuid\":\"2be815ad-ed6d-43cc-b9fa-09d1fad366bf\",\"authority\":\"231070df-b200-4df6-bbbc-b45f0ca0cfdf\",\"definition\":\"\",\"names\":{\"english\":\"emptiness devoid of rejection\",\"tibetan\":\"དོར་བ་མེད་པ་སྟོང་པ་ཉིད།\",\"sanskrit\":\"anavakāraśūnyatā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dor ba med pa stong pa nyid\"}},{\"uuid\":\"e54de864-7807-4661-b331-8c0a2b5688b6\",\"authority\":\"53c27c49-314b-4fbd-b527-73a1bdc6f707\",\"definition\":\"\",\"names\":{\"english\":\"emptiness of the limitless\",\"tibetan\":\"མཐའ་ལས་སྟོང་པ་ཉིད།\",\"sanskrit\":\"atyantaśūnyatā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mtha’ las stong pa nyid\"}},{\"uuid\":\"235b259b-8a65-4c94-ae9c-8e1cea04692a\",\"authority\":\"440750ed-33ca-4025-96bd-712acdf54417\",\"definition\":\"\",\"names\":{\"english\":\"emptiness of the substanceless\",\"tibetan\":\"དངོས་པོ་སྟོང་པ་ཉིད།\",\"sanskrit\":\"a(sva)bhāvaśūnyatā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dngos po stong pa nyid\"}},{\"uuid\":\"1ff23cf3-857a-493c-98de-6e589b0bf784\",\"authority\":\"06366f5d-04b8-4e96-bf44-e24ccbfef2f3\",\"definition\":\"\",\"names\":{\"english\":\"equanimity\",\"tibetan\":\"བཏང་སྙོམས།\",\"sanskrit\":\"upekṣā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"btang snyoms\"}},{\"uuid\":\"47c8923c-56be-43d8-b398-ff4290cece41\",\"authority\":\"cae5cd7c-89ec-47f7-a872-43c8c578a552\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThis term denotes the ontological status of phenomena, according to which they are said to possess existence in their own right‍—inherently, in and of themselves, objectively, and independent of any other phenomena such as our conception and labelling. The absence of such an ontological reality is defined as the true nature of reality, emptiness.\u003c/p\u003e\",\"names\":{\"english\":\"essence\",\"tibetan\":\"ངོ་བོ་ཉིད།\",\"sanskrit\":\"svabhāva\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ngo bo nyid\"}},{\"uuid\":\"3b04bcec-d4bd-44c9-989d-6de3cbd8b0fa\",\"authority\":\"64ab8b53-0563-462f-a18c-89b439bd033e\",\"definition\":\"\",\"names\":{\"english\":\"essencelessness regarding arising, essencelessness with regard to arising\",\"tibetan\":\"སྐྱེ་བ་ངོ་བོ་ཉིད་མེད་པ་ཉིད།\",\"sanskrit\":\"utpattiniḥsva­bhāvatā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"skye ba ngo bo nyid med pa nyid\"}},{\"uuid\":\"bf56ea7e-1d1a-4fdc-a1ba-51f2859f5bbd\",\"authority\":\"a44be6ed-1d29-4b4e-880a-b24d94e844ad\",\"definition\":\"\",\"names\":{\"english\":\"essencelessness regarding defining characteristics, essencelessness with regard to the defining characteristics, lakṣaṇaniḥsva­bhāvatā\",\"tibetan\":\"མཚན་ཉིད་ངོ་བོ་ཉིད་མེད་པ་ཉིད།\",\"sanskrit\":\"lakṣaṇaniḥsva­bhāvatā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mtshan nyid ngo bo nyid med pa nyid\"}},{\"uuid\":\"664120b2-4588-4b3e-9632-3c7586b13cad\",\"authority\":\"a02b076f-2a6a-4894-a713-041ab0a79387\",\"definition\":\"\",\"names\":{\"english\":\"essencelessness regarding the ultimate, essencelessness with regard to the ultimate\",\"tibetan\":\"དོན་དམ་པ་ངོ་བོ་ཉིད་མེད་པ་ཉིད།\",\"sanskrit\":\"paramārthaniḥsva­bhāvatā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"don dam pa ngo bo nyid med pa nyid\"}},{\"uuid\":\"511f85e3-f5bd-4380-81c7-87048ba56676\",\"authority\":\"fc93b09c-fa39-466a-b5ac-3880c670466f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe three kinds of essencelessness are \u003cspan data-glossary-id=\\\"UT22084-049-001-1444\\\"\u003eessencelessness regarding defining characteristics\u003c/span\u003e, \u003cspan data-glossary-id=\\\"UT22084-049-001-1443\\\"\u003eessencelessness regarding arising\u003c/span\u003e, and \u003cspan data-glossary-id=\\\"UT22084-049-001-1445\\\"\u003eessencelessness regarding the ultimate\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"essencelessness, niḥsva­bhāvatā\",\"tibetan\":\"ངོ་བོ་ཉིད་མེད་པ་ཉིད།\",\"sanskrit\":\"niḥsva­bhāvatā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ngo bo nyid med pa nyid\"}},{\"uuid\":\"501335a6-fab7-46eb-8735-fde9d6d8b0e4\",\"authority\":\"a111d5d6-9d97-4088-80ee-a28a527d5958\",\"definition\":\"\",\"names\":{\"english\":\"essential characteristic\",\"tibetan\":\"ངོ་བོ་ཉིད་ཀྱི་མཚན་ཉིད།\",\"sanskrit\":\"svabhāvalakṣaṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ngo bo nyid kyi mtshan nyid\"}},{\"uuid\":\"40022e8e-5fc5-43ba-83d0-0b8711d878e6\",\"authority\":\"b94700fb-9547-4ac8-a9c6-0cd6000e6d3e\",\"definition\":\"\",\"names\":{\"english\":\"examine, examined\",\"tibetan\":\"རྣམ་པར་དཔྱད།\",\"sanskrit\":\"vicāraṇa, vicārita\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rnam par dpyad\"}},{\"uuid\":\"ada4e9d6-f3be-4824-b549-e45d949f23ed\",\"authority\":\"4892411b-2daf-4b8c-9dc6-2fc7a7ab6d80\",\"definition\":\"\",\"names\":{\"english\":\"examine, examined, examining\",\"tibetan\":\"འཇལ་བ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’jal ba\"}},{\"uuid\":\"c15924e0-c0e9-4625-b1e3-37c2789f9775\",\"authority\":\"84d6d47a-c243-4008-a010-dfde2b10c00d\",\"definition\":\"\",\"names\":{\"english\":\"examining, parimīmāṃsā\",\"tibetan\":\"ཡོངས་སུ་དཔྱོད་པ།\",\"sanskrit\":\"paricāra, parimīmāṃsā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yongs su dpyod pa\"}},{\"uuid\":\"3137b167-2b22-46a8-808d-6ff62ea5e2dc\",\"authority\":\"07e0c7c3-d09c-436a-8ecd-aaebcea522cf\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eMahāvyutpatti 1115.\u003c/p\u003e\",\"names\":{\"english\":\"excellence of their peaceful conduct\",\"tibetan\":\"བཟོད་པ་དང་དེས་པ་ཆེན་པོ་དང་ལྡན་པ།\",\"sanskrit\":\"mahākṣāntisauratyasamanvāgataḥ\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bzod pa dang des pa chen po dang ldan pa\"}},{\"uuid\":\"53beb0cc-6340-484b-8199-700f8e9764ee\",\"authority\":\"d1b83816-416e-4ff3-9c5e-b16ac56665df\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe name of a bodhisattva \u003cspan data-glossary-id=\\\"UT22084-049-001-1624\\\"\u003estage\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Excellent Intelligence\",\"tibetan\":\"ལེགས་པའི་བློ་གྲོས།\",\"sanskrit\":\"sādhumatī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"legs pa’i blo gros\"}},{\"uuid\":\"5233ab19-a5b9-4642-a9af-a0c8afc4d26f\",\"authority\":\"f9697fe0-e024-46a0-aca0-0b89b9692000\",\"definition\":\"\",\"names\":{\"english\":\"excited\",\"tibetan\":\"བཟླུམས།\",\"sanskrit\":\"uddhata\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bzlums\"}},{\"uuid\":\"5b41c518-1ba6-4010-8e99-ebdf6cf8f220\",\"authority\":\"2eedd7a0-db3f-45f6-8a0b-c2722024c69f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eIn the sūtra, \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eparyāya\u003c/em\u003e is used to denote (1) an \u003cspan class=\\\"ignore\\\"\u003eexpedient\u003c/span\u003e or a trick in the context of illusions produced by a magician; (2) a method, an approach through which one can practice in accordance with a teaching; or (3) a scripture, a teaching regarding a specific aspect.\u003c/p\u003e\",\"names\":{\"english\":\"expedient\",\"tibetan\":\"རྣམ་གྲངས།\",\"sanskrit\":\"paryāya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rnam grangs\"}},{\"uuid\":\"5300c01f-2fcd-43bb-bc65-208560e019ac\",\"authority\":\"ea97a75e-12df-4d77-a617-8e017ab42297\",\"definition\":\"\",\"names\":{\"english\":\"express themselves through conventions\",\"tibetan\":\"ཐ་སྙད་འདོགས།\",\"sanskrit\":\"vyavaharanti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"tha snyad ’dogs\"}},{\"uuid\":\"2a22b28d-3a6c-41e7-8062-ca74b7b6df81\",\"authority\":\"bf0f89e8-8417-425a-afd0-b34e36704ee0\",\"definition\":\"\",\"names\":{\"english\":\"extent\",\"tibetan\":\"མཐར་ཐུག་པ།\",\"sanskrit\":\"paryanta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mthar thug pa\"}},{\"uuid\":\"0dce41cf-b8ab-4f43-a124-56b4754a7829\",\"authority\":\"8025283a-e6a9-4e5c-9429-8e20192321f2\",\"definition\":\"$67\",\"names\":{\"english\":\"factors of conditioned existence\",\"tibetan\":\"སྲིད་པའི་ཡན་ལག\",\"sanskrit\":\"bhavāṅga\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"srid pa’i yan lag\"}},{\"uuid\":\"14e78617-e431-4217-bcdb-aff1243376b1\",\"authority\":\"07bf1655-7a5b-48dd-a6bd-431b610812c4\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee “\u003cspan data-glossary-id=\\\"UT22084-049-001-1462\\\"\u003efive faculties\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"faculties\",\"tibetan\":\"དབང་པོ།\",\"sanskrit\":\"indriya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dbang po\"}},{\"uuid\":\"b5c3b14c-540c-45c6-a354-f4c471890720\",\"authority\":\"d48d08d2-ecb5-48e6-a14b-c05abf93a31a\",\"definition\":\"\",\"names\":{\"english\":\"faith\",\"tibetan\":\"དད་པ།\",\"sanskrit\":\"śraddhā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dad pa\"}},{\"uuid\":\"16b546aa-4b0e-4144-8fa2-597573ee205c\",\"authority\":\"fc6136ce-5736-4a3c-a525-a3f13d26e025\",\"definition\":\"\",\"names\":{\"english\":\"falsity\",\"tibetan\":\"སྐྱོན་ཆགས་པ།\",\"sanskrit\":\"duṣṭatā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"skyon chags pa\"}},{\"uuid\":\"409a21c2-6b75-45e3-888d-8e43c3435274\",\"authority\":\"bdaeca33-367f-4ccf-8cb9-6557ae2b2bde\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe name of a bodhisattva \u003cspan data-glossary-id=\\\"UT22084-049-001-1624\\\"\u003estage\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Far Reaching\",\"tibetan\":\"རིང་དུ་སོང་བ།\",\"sanskrit\":\"dūraṅgamā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ring du song ba\"}},{\"uuid\":\"e5b9c22c-4ab5-4272-b8df-9994c8930eb8\",\"authority\":\"2ed19de6-a31c-45a0-ad9c-76ebdeac3a3f\",\"definition\":\"\",\"names\":{\"english\":\"faultless state of truth\",\"tibetan\":\"ཡང་དག་པ་ཉིད་སྐྱོན་མེད་པ།\",\"sanskrit\":\"samyaktvanyāma\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yang dag pa nyid skyon med pa\"}},{\"uuid\":\"c90319a5-c258-44a9-9771-4f0742c818a7\",\"authority\":\"663c93aa-0b28-40da-9cb7-29526f18ddb8\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eDiffering only in intensity, the \u003cspan class=\\\"ignore\\\"\u003efive forces\u003c/span\u003e are similar to the \u003cspan data-glossary-id=\\\"UT22084-049-001-1462\\\"\u003efive faculties\u003c/span\u003e: (1) \u003cspan data-glossary-id=\\\"UT22084-049-001-1458\\\"\u003efaith\u003c/span\u003e, (2) \u003cspan data-glossary-id=\\\"UT22084-049-001-1682\\\"\u003evigor\u003c/span\u003e, (3) \u003cspan data-glossary-id=\\\"UT22084-049-001-1544\\\"\u003emindfulness\u003c/span\u003e, (4) \u003cspan data-glossary-id=\\\"UT22084-049-001-1361\\\"\u003econcentration\u003c/span\u003e (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003esamādhi\u003c/em\u003e), and (5) \u003cspan data-glossary-id=\\\"UT22084-049-001-1689\\\"\u003ewisdom\u003c/span\u003e (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eprajñā\u003c/em\u003e). \u003c/p\u003e\",\"names\":{\"english\":\"five forces\",\"tibetan\":\"སྟོབས་ལྔ།\",\"sanskrit\":\"pañcabalāni\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"stobs lnga\"}},{\"uuid\":\"18a92e5d-ed32-4429-8ad1-42e8850e65ba\",\"authority\":\"920e0512-2b5a-43e6-9b5e-1a6bd731bcbd\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe \u003cspan class=\\\"ignore\\\"\u003efive great fears\u003c/span\u003e are “the fear concerning livelihood, fear of disapproval, fear of death, fear of bad transmigrations, and fear that is timidity when addressing assemblies.” (Powers 1995, p. 316, n. 19).\u003c/p\u003e\",\"names\":{\"english\":\"five great fears\",\"tibetan\":\"འཇིགས་པ་ཆེན་པོ་ལྔ།\",\"sanskrit\":\"pañcamahābhaya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’jigs pa chen po lnga\"}},{\"uuid\":\"6d1b2ca8-320e-41e9-8d04-c295df300d63\",\"authority\":\"25a5db33-b14f-44b1-a7d6-91b6a6369e3b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe five sciences are grammar, logic, philosophy, medicine, and crafts.\u003c/p\u003e\",\"names\":{\"english\":\"five sciences\",\"tibetan\":\"རིགས་པའི་གནས་ལྔ་པོ།\",\"sanskrit\":\"pañcavidyā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rigs pa’i gnas lnga po\"}},{\"uuid\":\"927d23f8-93ea-4575-89d0-9e5cf11278e8\",\"authority\":\"37215b51-b2c8-4b2c-8986-ab71010f7da4\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eFifth among the branches or limbs of awakening (Skt. \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003ebodhyaṅga\u003c/em\u003e); a condition of calm, clarity, and composure in mind and body that serves as an antidote to negativity and confers a mental and physical capacity that facilitates meditation and virtuous action.\u003c/p\u003e\",\"names\":{\"english\":\"flexibility, flexible, praśrabdhi\",\"tibetan\":\"ཤིན་ཏུ་སྦྱངས་པ།\",\"sanskrit\":\"praśrabdhi\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shin tu sbyangs pa\"}},{\"uuid\":\"647d7271-4517-4478-8089-b25dafbaf018\",\"authority\":\"4a866bfa-d571-4aa6-8bbd-5caadd887701\",\"definition\":\"\",\"names\":{\"english\":\"focus their minds within\",\"tibetan\":\"སེམས་ནང་དུ་འཇོག\",\"sanskrit\":\"cittasthāpana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sems nang du ’jog\"}},{\"uuid\":\"b127b59f-78d0-4984-9c0e-d6d401287f6e\",\"authority\":\"14d513b0-ce98-4c59-a58f-e2ba6022a2c4\",\"definition\":\"\",\"names\":{\"english\":\"foolish being\",\"tibetan\":\"བྱིས་པ།\",\"sanskrit\":\"bāla\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"byis pa\"}},{\"uuid\":\"fb599b92-6e0b-4137-91f3-0074d6f8e307\",\"authority\":\"0c5ec4ad-cb20-4880-bf35-62ca54d81186\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee “\u003cspan data-glossary-id=\\\"UT22084-049-001-1463\\\"\u003efive forces\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"forces\",\"tibetan\":\"སྟོབས།\",\"sanskrit\":\"bala\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"stobs\"}},{\"uuid\":\"f1cf545f-f14c-4ade-9bcb-04904754c00a\",\"authority\":\"c0fc2af2-094e-4418-b5b6-4076fdf24c4a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eIn this text, the six \u003cspan class=\\\"ignore\\\"\u003efoundations of training\u003c/span\u003e are listed as \u003cspan data-glossary-id=\\\"UT22084-049-001-1483\\\"\u003egenerosity\u003c/span\u003e, \u003cspan data-glossary-id=\\\"UT22084-049-001-1417\\\"\u003ediscipline\u003c/span\u003e, \u003cspan data-glossary-id=\\\"UT22084-049-001-1571\\\"\u003epatience\u003c/span\u003e, \u003cspan data-glossary-id=\\\"UT22084-049-001-1412\\\"\u003ediligence\u003c/span\u003e, \u003cspan data-glossary-id=\\\"UT22084-049-001-1533\\\"\u003emeditative absorption\u003c/span\u003e, and \u003cspan data-glossary-id=\\\"UT22084-049-001-1689\\\"\u003ewisdom\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"foundations of training\",\"tibetan\":\"བསླབ་པའི་གཞི།\",\"sanskrit\":\"śikṣāpada\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bslab pa’i gzhi\"}},{\"uuid\":\"280a5a6c-8e25-4fdf-b4e8-f5f3e3e2ae47\",\"authority\":\"92de6b42-9665-43a5-aa41-6ac96dd93fbe\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe \u003cspan class=\\\"ignore\\\"\u003efour correct self-restraints\u003c/span\u003e are: giving up nonvirtues, avoiding nonvirtues, generating virtues, developing virtues. See Edgerton 1953, p. 389,2. \u003c/p\u003e\",\"names\":{\"english\":\"four correct self-restraints\",\"tibetan\":\"ཡང་དག་པར་སྤོང་བ་བཞི།\",\"sanskrit\":\"catvāri prahāṇāni\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yang dag par spong ba bzhi\"}},{\"uuid\":\"e22e96fc-fd60-42eb-8e83-fb1226bd9c01\",\"authority\":\"4fd43520-939f-4f26-98c3-f8e40155dada\",\"definition\":\"$68\",\"names\":{\"english\":\"four kinds of assurance\",\"tibetan\":\"མི་འཇིགས་པ་བཞི།\",\"sanskrit\":\"catvāri vaiśāradyāni\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mi ’jigs pa bzhi\"}},{\"uuid\":\"59a420e1-6617-408b-b521-ae5397c598a7\",\"authority\":\"2bcee9d1-76ca-477e-9c31-ba9770456437\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eMahāvyutpatti 924. The \u003cspan class=\\\"ignore\\\"\u003efour methods of conversion\u003c/span\u003e are: (1) \u003cspan data-glossary-id=\\\"UT22084-049-001-1483\\\"\u003egenerosity\u003c/span\u003e (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003edāna\u003c/em\u003e), (2) kind words (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003epriyavādita\u003c/em\u003e), (3) being supportive of others (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003earthacaryā\u003c/em\u003e), and (4) being consistent with one’s own teachings (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003esamānārthatā\u003c/em\u003e). (see Mvyut 924).\u003c/p\u003e\",\"names\":{\"english\":\"four methods of conversion\",\"tibetan\":\"བསྡུ་བའི་དངོས་པོ་བཞིའི་མིང་།\",\"sanskrit\":\"catvāri saṃgrahavastūni\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bsdu ba’i dngos po bzhi’i ming\"}},{\"uuid\":\"2def8539-15b9-4e7a-b15c-3bb0c6268655\",\"authority\":\"ce1c196b-ed27-413a-81a2-19e45d3c5a2c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe \u003cspan class=\\\"ignore\\\"\u003efour noble truths\u003c/span\u003e, as stated in this sūtra, are: the \u003cspan data-glossary-id=\\\"UT22084-049-001-1359\\\"\u003ecomprehension\u003c/span\u003e of suffering, the abandoning of the cause of suffering, the \u003cspan data-glossary-id=\\\"UT22084-049-001-1306\\\"\u003eactualization\u003c/span\u003e of the cessation of suffering, and the practice of the path.\u003c/p\u003e\",\"names\":{\"english\":\"four noble truths\",\"tibetan\":\"འཕགས་པའི་བདེན་པ་བཞི།\",\"sanskrit\":\"catvāri āryasatyāni\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’phags pa’i bden pa bzhi\"}},{\"uuid\":\"60e78631-0352-4420-9f00-b31e2124d404\",\"authority\":\"59500d87-caef-443d-b4fd-96aa2bceb408\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe impermanence of all \u003cspan data-glossary-id=\\\"UT22084-049-001-1368\\\"\u003econditioned phenomena\u003c/span\u003e, the suffering inherent to all \u003cspan data-glossary-id=\\\"UT22084-049-001-1368\\\"\u003econditioned phenomena\u003c/span\u003e, the selflessness of all phenomena, and \u003cspan data-glossary-id=\\\"UT22084-049-001-1553\\\"\u003enirvāṇa\u003c/span\u003e as the state of peace.\u003c/p\u003e\",\"names\":{\"english\":\"four seals of Dharma\",\"tibetan\":\"ཕྱག་རྒྱ་བཞི།\",\"sanskrit\":\"caturmudrā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"phyag rgya bzhi\"}},{\"uuid\":\"174a99d8-40ff-44ec-a2b1-0849a0d04efb\",\"authority\":\"abd55263-6cc4-4b38-9c84-7ef2333eb896\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eIn the sense of “disinterested,” “not expecting a reward.” \u003c/p\u003e\",\"names\":{\"english\":\"free from covetousness\",\"tibetan\":\"ཟང་ཟིང་མེད་པ།\",\"sanskrit\":\"nirāmiṣa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"zang zing med pa\"}},{\"uuid\":\"d9670643-9f59-4430-8a9a-750fd47041b2\",\"authority\":\"47cba514-0c0a-4e09-a588-ef3958ba7f16\",\"definition\":\"\",\"names\":{\"english\":\"free of any wrongdoing\",\"tibetan\":\"ཁ་ན་མ་ཐོ་བ་མེད་པ།\",\"sanskrit\":\"anavadya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kha na ma tho ba med pa\"}},{\"uuid\":\"7fbcc538-193d-4161-aaea-2b03f15c52f2\",\"authority\":\"4d862f07-12b7-4700-b994-35c2a99e8ce9\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA bodhisattva mahāsattva.\u003c/p\u003e\",\"names\":{\"english\":\"Gam­bhīrārtha­saṃdhi­nirmo­cana\",\"tibetan\":\"དོན་ཟབ་དགོངས་པ་ངེས་པར་འགྲེལ།\",\"sanskrit\":\"gam­bhīrārtha­saṃdhi­nirmo­cana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"don zab dgongs pa nges par ’grel\"}},{\"uuid\":\"2432c308-6920-44c5-ad61-a308599ff0bb\",\"authority\":\"74461fd0-5ed8-4923-b6bb-16bb40dfa426\",\"definition\":\"\u003cp\u003eA class of generally benevolent nonhuman beings who inhabit the skies, sometimes said to inhabit fantastic cities in the clouds, and more specifically to dwell on the eastern slopes of Mount Meru, where they are ruled by the Great King Dhṛtarāṣṭra. They are most renowned as celestial musicians who serve the gods. In the Abhidharma, the term is also used to refer to the mental body assumed by sentient beings during the intermediate state between death and rebirth. Gandharvas are said to live on fragrances (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003egandha\u003c/em\u003e) in the desire realm, hence the Tibetan translation \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003edri za\u003c/em\u003e, meaning “scent eater.”\u003c/p\u003e\",\"names\":{\"english\":\"gandharva\",\"tibetan\":\"དྲི་ཟ།\",\"sanskrit\":\"gandharva\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dri za\"}},{\"uuid\":\"e4eb082c-79ea-4002-bdb4-3b4549a31c73\",\"authority\":\"ba7579fc-ce40-4ade-b704-5f7d033091cc\",\"definition\":\"\u003cp\u003eIn Indian mythology, the garuḍa is an eagle-like bird that is regarded as the king of all birds, normally depicted with a sharp, owl-like beak, often holding a snake, and with large and powerful wings. They are traditionally enemies of the nāgas. In the Vedas, they are said to have brought nectar from the heavens to earth. \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eGaruḍa\u003c/em\u003e can also be used as a proper name for a king of such creatures.\u003c/p\u003e\",\"names\":{\"english\":\"garuḍa\",\"tibetan\":\"\",\"sanskrit\":\"garuḍa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"\"}},{\"uuid\":\"da6f44fa-f721-4e7f-bf48-424bb1433d7d\",\"authority\":\"d0973019-0afa-4079-9338-8dab201c2df7\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-049-001-1435\\\"\u003eEmptiness\u003c/span\u003e, \u003cspan data-glossary-id=\\\"UT22084-049-001-1317\\\"\u003eappearancelessness\u003c/span\u003e, and \u003cspan data-glossary-id=\\\"UT22084-049-001-1690\\\"\u003ewishlessness\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"gates of liberation\",\"tibetan\":\"རྣམ་པར་ཐར་པའི་སྒོ།\",\"sanskrit\":\"vimokṣamukha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rnam par thar pa’i sgo\"}},{\"uuid\":\"71bbdd49-c6e1-487c-9d30-86e7fa56a899\",\"authority\":\"3626ef26-426c-47b4-b3b4-ba46a6c6a28b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan class=\\\"ignore\\\"\u003egāthā\u003c/span\u003e is a verse or stanza.\u003c/p\u003e\",\"names\":{\"english\":\"gāthā\",\"tibetan\":\"ཚིགས་སུ་བཅད་པ།\",\"sanskrit\":\"gāthā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"tshigs su bcad pa\"}},{\"uuid\":\"aed54203-4863-4c60-8198-893ee6822d24\",\"authority\":\"d37007db-922a-497b-af29-e70cb3030d9e\",\"definition\":\"\",\"names\":{\"english\":\"generosity\",\"tibetan\":\"སྦྱིན་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sbyin pa\"}},{\"uuid\":\"b36258b5-bd30-4205-aeeb-75bac743076f\",\"authority\":\"41de0789-5ce0-4cf7-b975-7dafa09d7d9b\",\"definition\":\"\",\"names\":{\"english\":\"gnosis\",\"tibetan\":\"ཡེ་ཤེས།\",\"sanskrit\":\"jñāna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ye shes\"}},{\"uuid\":\"c159df12-8fe9-498c-a07b-02104cd05a1f\",\"authority\":\"8423b5da-ec0c-4674-b454-ee4d12104b77\",\"definition\":\"\",\"names\":{\"english\":\"gnosis and vision, jñānadarśana\",\"tibetan\":\"ཤེས་པ་དང་མཐོང་བ།\",\"sanskrit\":\"jñānadarśana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shes pa dang mthong ba\"}},{\"uuid\":\"fad8dd9b-4641-4448-850e-59418ce7d4c2\",\"authority\":\"b7d69d4a-aeac-4566-9e8e-d763da36506d\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe \u003cspan data-glossary-id=\\\"UT22084-049-001-1435\\\"\u003eemptiness\u003c/span\u003e of the \u003cspan data-glossary-id=\\\"UT22084-049-001-1620\\\"\u003espace\u003c/span\u003e containing all domains, \u003cspan data-glossary-id=\\\"UT22084-049-001-1557\\\"\u003eobjects\u003c/span\u003e, and locations.\u003c/p\u003e\",\"names\":{\"english\":\"great emptiness\",\"tibetan\":\"ཆེན་པོ་སྟོང་པ་ཉིད།\",\"sanskrit\":\"mahāśūnyatā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chen po stong pa nyid\"}},{\"uuid\":\"86d71a61-2aa9-4311-9ffe-e3044e9961fb\",\"authority\":\"0fb287a6-b14b-4abc-b918-2f87388743a1\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA bodhisattva mahāsattva.\u003c/p\u003e\",\"names\":{\"english\":\"Guṇākara\",\"tibetan\":\"ཡོན་ཏན་འབྱུང་གནས།\",\"sanskrit\":\"guṇākara\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yon tan ’byung gnas\"}},{\"uuid\":\"bfafa7ea-8c6e-492b-a266-afaee98c8b8a\",\"authority\":\"0dcd7050-818d-4466-8a9a-93d5ccb93fd3\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eMahāvyutpatti 369. \u003c/p\u003e\",\"names\":{\"english\":\"had realized the sameness [of all phenomena], the state of a buddha in which there is neither a center nor a periphery\",\"tibetan\":\"མཐའ་དང་དབུས་མེད་པའི་སངས་རྒྱས་ཀྱི་ས་མཉམ་པ་ཉིད་བུ་ཐུགས་སུ་ཆུད་པ།\",\"sanskrit\":\"anantamadhyabuddhabhūmisamatādhigataḥ\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mtha’ dang dbus med pa’i sangs rgyas kyi sa mnyam pa nyid bu thugs su chud pa\"}},{\"uuid\":\"e237c25d-5d78-41e7-98ea-631a7e5515e1\",\"authority\":\"b11d5585-85b2-4e33-85f5-9bfc5fd2008a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe name of a bodhisattva \u003cspan data-glossary-id=\\\"UT22084-049-001-1624\\\"\u003estage\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Hard to Conquer\",\"tibetan\":\"ཤིན་ཏུ་སྦྱང་དཀའ།\",\"sanskrit\":\"sudurjayā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shin tu sbyang dka’\"}},{\"uuid\":\"09872ba1-9454-42fc-a9a1-83b2db59413e\",\"authority\":\"b662e79b-4cff-4567-b74a-1c23d3f1fea7\",\"definition\":\"$69\",\"names\":{\"english\":\"hearer\",\"tibetan\":\"ཉན་ཐོས།\",\"sanskrit\":\"śrāvaka\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nyan thos\"}},{\"uuid\":\"ee9dd921-6b0c-41cc-8768-b35240e3cfd9\",\"authority\":\"f244bde0-638a-4708-93e6-87e00213da71\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eType of being in Buddhist cosmogony.\u003c/p\u003e\",\"names\":{\"english\":\"hell being\",\"tibetan\":\"དམྱལ་བ་པ།\",\"sanskrit\":\"nāraka\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dmyal ba pa\"}},{\"uuid\":\"3ef61603-95e6-48f0-941f-e5762cecb871\",\"authority\":\"6c73b48a-13cd-45e2-8d98-1ecf82f9ea77\",\"definition\":\"\",\"names\":{\"english\":\"how, truly\",\"tibetan\":\"ཇི་ཙམ་དུ།, ཇི་ཙམ་དུ།\",\"sanskrit\":\"tāvat, tāvat, tāvatā, tāvatā, yāvat, yāvat\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ji tsam du, ji tsam du\"}},{\"uuid\":\"1004957d-3e01-4c47-86df-a92ca43a7d30\",\"authority\":\"6c73b48a-13cd-45e2-8d98-1ecf82f9ea77\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eWith the meaning of “\u003cspan\u003e\u003cspan data-glossary-id=\\\"UT22084-049-001-1725\\\"\u003etruly\u003c/span\u003e\u003c/span\u003e, really, indeed.”\u003c/p\u003e\",\"names\":{\"english\":\"how, truly\",\"tibetan\":\"ཇི་ཙམ་དུ།, ཇི་ཙམ་དུ།\",\"sanskrit\":\"tāvat, tāvat, tāvatā, tāvatā, yāvat, yāvat\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ji tsam du, ji tsam du\"}},{\"uuid\":\"01f7741b-46b7-44e3-aa02-149e60ded38e\",\"authority\":\"51729823-abc4-4d42-abd1-cac0b83a8945\",\"definition\":\"$6a\",\"names\":{\"english\":\"hungry ghost\",\"tibetan\":\"ཡི་དགས།\",\"sanskrit\":\"preta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yi dags\"}},{\"uuid\":\"69214950-7fff-482f-b6f7-57d30b20e07e\",\"authority\":\"a5215d5c-9487-49b0-ba8e-79b7f3956625\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe name of a bodhisattva \u003cspan data-glossary-id=\\\"UT22084-049-001-1624\\\"\u003estage\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"engli