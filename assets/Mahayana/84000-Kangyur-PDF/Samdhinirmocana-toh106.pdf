གཏན་ཡོངས་སུ་མ་གྲུབ་པའི་ཕྱིར་འདུས་བྱས་མ་ཡིན་[F.3.b]ནོ། །རིགས་ཀྱི་བུ་འདུས་མ་བྱས་ཞེས་བྱ་བ་དེ་ཡང་ཐ་སྙད་ཀྱི་ཁོངས་སུ་གཏོགས་པ་ཡིན་ལ། འདུས་བྱས་དང་འདུས་མ་བྱས་སུ་མ་གཏོགས་པ་གང་ཅི་བརྗོད་ཀྱང་དེ་ཡང་དེ་དང་འདྲ་བ་ཉིད་དུ་གྱུར། དེ་ཡང་དེ་དང་འདྲ་བ་ཉིད་དུ་འགྱུར་རོ། །བརྗོད་པ་ནི་དངོས་པོ་མེད་པ་\\nཅན་ཡང་མ་ཡིན་ཏེ། དངོས་པོ་དེ་ཡང་གང་ཞེ་ན། འཕགས་པ་རྣམས་ཀྱི་འཕགས་པའི་ཤེས་པ་དང་། འཕགས་པའི་མཐོང་བས་བརྗོད་དུ་མེད་པར་མངོན་པར་རྫོགས་པར་སངས་རྒྱས་པ་གང་ཡིན་པ་སྟེ། བརྗོད་དུ་མེད་པའི་ཆོས་ཉིད་དེ་ཉིད་མངོན་པར་རྫོགས་\\nཔར་རྟོགས་པར་བྱ་བའི་ཕྱིར་འདུས་བྱས་ཞེས་མིང་དུ་བཏགས་སོ། །\",\"folioNumber\":3,\"volumeNumber\":49}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":186,\"uuid\":\"c77f9778-68b2-48a6-b52f-e8359c3c838d\"},\"content\":[{\"type\":\"text\",\"text\":\"Vidhi­vatpari­pṛcchaka\",\"attrs\":{\"start\":0,\"end\":22},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"afb1fe39-9a5a-4dfe-8723-31f7d6185185\",\"uuid\":\"45e2962b-ea8e-40c5-ae3c-be6c714039be\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" inquired, “O son of the Victorious One, why is the \",\"attrs\":{\"start\":22,\"end\":74}},{\"type\":\"text\",\"text\":\"conditioned\",\"attrs\":{\"start\":74,\"end\":85},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c41c6d0c-b684-45c0-9367-3c0df3d7d01b\",\"uuid\":\"ef48ba3b-78ba-4ef2-933b-a4cbe4a11147\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" neither \",\"attrs\":{\"start\":85,\"end\":94}},{\"type\":\"text\",\"text\":\"conditioned\",\"attrs\":{\"start\":94,\"end\":105},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c41c6d0c-b684-45c0-9367-3c0df3d7d01b\",\"uuid\":\"cd726c78-9755-49b5-85b4-fef5f944dd2e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" nor \",\"attrs\":{\"start\":105,\"end\":110}},{\"type\":\"text\",\"text\":\"unconditioned\",\"attrs\":{\"start\":110,\"end\":123},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d680987b-fab1-4356-95cb-fce547654eec\",\"uuid\":\"77ee9173-81cf-4b83-a861-e578aabfa450\",\"