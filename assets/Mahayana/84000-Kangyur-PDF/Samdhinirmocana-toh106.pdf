་བ་དེ་ལྟ་བུར་ནི་མཚན་ཉིད་ངོ་བོ་ཉིད་མེད་\\nཔ་ཉིད་བལྟ་བར་བྱའོ། །དོན་དམ་ཡང་དག་འཕགས་དེ་ལ་འདི་ལྟ་སྟེ་དཔེར་ན། སྒྱུ་མ་བྱས་པ་ཇི་ལྟ་བ་དེ་ལྟ་བུར་ནི་སྐྱེ་བ་ངོ་བོ་ཉིད་མེད་པ་ཉིད་ཀྱང་བལྟ་བར་བྱ། དོན་དམ་པ་ངོ་བོ་ཉིད་མེད་པ་ཉིད་དེ་ལས་གཅིག་ཀྱང་བལྟ་བར་བྱའོ། །དོན་དམ་ཡང་དག་འཕགས་དེ་ལ་འདི་ལྟ་སྟེ་དཔེར་\\nན། ནམ་མཁའི་གཟུགས་ཀྱི་ངོ་བོ་ཉིད་མེད་པ་ཉིད་ཙམ་གྱིས་རབ་ཏུ་ཕྱེ་བ་དང་། ཐམས་ཅད་དུ་སོང་བ་ཇི་ལྟ་བ་དེ་ལྟ་བུར་ནི་དོན་དམ་པ་ངོ་བོ་ཉིད་མེད་པ་ཉིད་ལས་ཆོས་བདག་མེད་པས་རབ་ཏུ་ཕྱེ་བ་དང་ཐམས་ཅད་དུ་སོང་བ་གཅིག་བལྟ་བར་བྱ་སྟེ། \",\"folioNumber\":17,\"volumeNumber\":49}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":561,\"uuid\":\"c326b5ff-1fa8-43e0-a9b8-eb4336694391\"},\"content\":[{\"type\":\"text\",\"text\":\"“\",\"attrs\":{\"start\":0,\"end\":1}},{\"type\":\"text\",\"text\":\"Para­mārtha­samud­gata\",\"attrs\":{\"start\":1,\"end\":23},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"537e957c-58b2-4ce7-88cc-ad811243d1ba\",\"uuid\":\"523dc89c-c48c-43ed-9857-55af6f08fea0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", it is like this: consider \",\"attrs\":{\"start\":23,\"end\":51}},{\"type\":\"text\",\"text\":\"essencelessness\",\"attrs\":{\"start\":51,\"end\":66},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"511f85e3-f5bd-4380-81c7-87048ba56676\",\"uuid\":\"dc233376-70f1-4351-9f1d-200a38dec805\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" with regard to \",\"attrs\":{\"start\":66,\"end\":82}},{\"type\":\"text\",\"text\":\"defining characteristics\",\"attrs\":{\"start\":82,\"end\":106},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f4503be0-02d4-474f-8f1c-a69993648574\",\"uuid\":\"d45c7ba1-a397-4216-b588-4bc6d066292b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" to be exactly like a [nonexistent] sky flower; consider \",\"attrs\":{\"start\":106,\"end\":163}},{\"type\":\"text\",\"text\":\"essencelessness with regard to arising\",\"attrs\":{\"start\":163,\"end\":201},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glo