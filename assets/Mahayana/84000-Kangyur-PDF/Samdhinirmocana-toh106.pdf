རྣམ་པར་རྨོངས་པར་བྱེད་དོ། །གང་གི་ཚེ་ཚོན་དམར་པོ་དང་ཕྲད་པར་གྱུར་པ་དེའི་ཚེ་ནི་ནོར་བུ་རིན་པོ་ཆེ་པད་མ་རཱ་ག་ལྟ་བུར་སྣང་བར་འགྱུར་\\nཞིང་། ནོར་བུ་རིན་པོ་ཆེ་པད་མ་རཱ་ག་རུ་ལོག་པར་འཛིན་པས་སེམས་ཅན་རྣམས་རྣམ་པར་རྨོངས་པར་བྱེད་དོ། །གང་གི་ཚེ་ན་ཚོན་ལྗང་ཁུ་དང་ཕྲད་པར་གྱུར་པ་དེའི་ཚེ་ནི་ནོར་བུ་རིན་པོ་ཆེ་མརྒད་ལྟ་བུར་སྣང་བར་འགྱུར་ཞིང་། ནོར་བུ་རིན་པོ་ཆེ་མརྒད་དུ་ལོག་པར་འཛིན་པས་ཀྱང་སེམས་[F.15.a]ཅན་རྣམས་རྣམ་པར་རྨོངས་པར་བྱེད་དོ། །གང་གི་ཚེ་ཚོན་སེར་པོ་དང་ཕྲད་པར་གྱུར་པ་དེའི་ཚེ་ནི་གསེར་ལྟ་བུར་སྣང་བར་འགྱུར་ཞིང་། གསེར་དུ་ལོག་པར་འཛིན་པས་ཀྱང་སེམས་ཅན་རྣམས་རྣམ་པར་རྨོངས་པར་བྱེད་དོ། །\",\"folioNumber\":14,\"volumeNumber\":49}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":405,\"uuid\":\"a50b6380-b473-48d5-a056-50af0e8eac32\"},\"content\":[{\"type\":\"text\",\"text\":\"“\",\"attrs\":{\"start\":0,\"end\":1}},{\"type\":\"text\",\"text\":\"Guṇākara\",\"attrs\":{\"start\":1,\"end\":9},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"86d71a61-2aa9-4311-9ffe-e3044e9961fb\",\"uuid\":\"3f989e53-2eec-474c-a0f2-d93582df59a9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", it is like this: when a pure crystal is in contact with something blue, it appears to be a sapphire. Because people perceive it by mistake as a sapphire, they are deceived by it. When this pure crystal is in contact with something red, green, or yellow, it appears to be a ruby, an emerald, or gold. Because people perceive it by mistake as a ruby, an emerald, or gold, they are deceived by it.\",\"attrs\":{\"start\":9,\"end\":405}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"c1a99f70-410d-4cf5-bf1d-f57270e6df29\",\"sort\":4486,\"type\":\"translation\",\"label\":\"6.9\",\"alignments\":{\"toh106\":{\"folioUuid\":\"f3a5df49-3b6c-4667-b8dc-0b4b742d1eda\",\"toh\":\"toh106\",\"tibetan\":\"ཡོན་ཏན་འབྱུང་གནས་འདི་ལྟ་སྟེ་\\nདཔེར་ན། ཤེལ་ཤིན་ཏུ་གསལ་བ་ཚོན་དང་ཕྲད་པ་དེ་ལྟ་བུར་ནི་གཞན་གྱི་དབང་གི་མཚན་ཉིད་ལ་ཀུན་བརྟགས་པའི་མཚན་ཉིད་ཀྱི་ཐ་སྙད་ཀྱི་བག་ཆགས་སུ་བལྟ་བར་བྱའོ། །འདི་ལྟ་སྟེ་དཔེར་ན། ཤེལ་ཤིན་ཏུ་གསལ་བ་ལ་ནོར་བུ་རིན་པོ་ཆེ་ཨན་ད་རྙིལ་དང་། མཐོན་ཀ་ཆེན་པོ་དང་། \\nཔད་མ་རཱ་ག་དང་། མརྒད་དང་། གསེར་དུ་ལོག་པར་འཛིན་པ་ལྟ་བུར་ནི་གཞན་གྱི་དབང་གི་མཚན་ཉིད་ལ་ཀུན་བརྟགས་པའི་མཚན་ཉིད་དུ་འཛིན་པར་བལྟ་བར་བྱའོ། །ཡོན་ཏན་འབྱུང་གནས་འདི་ལྟ་སྟེ་དཔེར་ན། ཤེལ་ཤིན་ཏུ་གསལ་བ་དེ་ཉིད་ལྟ་བུར་ནི་གཞན་གྱི་དབང་གི་\\nམཚན་ཉིད་བལྟ་བར་བྱའོ། །འདི་ལྟ་སྟེ་དཔེར་ན། ཤེལ་ཤིན་ཏུ་གསལ་བ་ཉིད་ནོར་བུ་རིན་པོ་ཆེ་ཨན་ད་རྙིལ་དང་། མཐོན་ཀ་ཆེན་པོ་དང་པད་མ་རཱ་ག་དང་། མརྒད་དང་། གསེར་གྱི་མཚན་ཉིད་དེར་རྟག་པ་རྟག་པའི་དུས་དང་། ཐེར་ཟུག་ཐེར་ཟུག་གི་དུས་སུ་ཡོངས་སུ་\\nམ་གྲུབ་ཅིང་ངོ་བོ་ཉིད་མེད་པ་དེ་ལྟ་བུར་ནི་གཞན་གྱི་དབང་གི་མཚན་ཉིད་དེ། ཀུན་བརྟགས་པའི་མཚན་ཉིད་དེར་རྟག་པ་རྟག་པའི་དུས་དང་། ཐེར་ཟུག་ཐེར་ཟུག་གི་དུས་སུ་ཡོངས་སུ་མ་གྲུབ་ཅིང་ངོ་བོ་ཉིད་མེད་པ་ཉིད་ཀྱིས་ཡོངས་སུ་གྲུབ་པའི་མཚན་ཉིད་བལྟ་བར་བྱའོ། །\",\"folioNumber\":15,\"volumeNumber\":49}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":496,\"uuid\":\"e8ae6a33-3fe8-4d52-b49d-c1c9cebb145b\"},\"content\":[{\"type\":\"text\",\"text\":\"“\",\"attrs\":{\"start\":0,\"end\":1}},{\"type\":\"text\",\"text\":\"Guṇākara\",\"attrs\":{\"start\":1,\"end\":9},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"86d71a61-2aa9-4311-9ffe-e3044e9961fb\",\"uuid\":\"4c04f1e5-e0f6-494f-925f-049af78eb907\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", it is like this: You should consider the \",\"attrs\":{\"start\":9,\"end\":52}},{\"type\":\"text\",\"text\":\"mental imprint\",\"attrs\":{\"start\":52,\"end\":66},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d6851c20-665e-4ad5-b43b-a2b51dca335f\",\"uuid\":\"0cc60627-9498-4428-b8b5-aa6c99c6ae25\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of \",\"attrs\":{\"start\":66,\"end\":70}},{\"type\":\"text\",\"text\":\"conventions\",\"attrs\":{\"start\":70,\"end\":81},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4e5c2faa-9e68-4024-a3d5-daf175e06d51\",\"uuid\":\"bbf80b78-8514-4e87-bf2b-8dd2ffe46cad\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in terms of an \",\"attrs\":{\"start\":81,\"end\":97}},{\"type\":\"text\",\"text\"