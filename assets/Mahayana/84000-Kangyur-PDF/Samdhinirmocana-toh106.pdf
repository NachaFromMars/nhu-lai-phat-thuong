། །དེའི་ཕྱིར་ཞི་བའི་བགྲོད་པ་གཅིག་པུ་པ་ཞེས་བྱའོ། །\",\"folioNumber\":19,\"volumeNumber\":49}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":859,\"uuid\":\"d66a75d4-16a3-4f9e-b374-453020690f5b\"},\"content\":[{\"type\":\"text\",\"text\":\"“\",\"attrs\":{\"start\":0,\"end\":1}},{\"type\":\"text\",\"text\":\"Para­mārtha­samud­gata\",\"attrs\":{\"start\":1,\"end\":23},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"537e957c-58b2-4ce7-88cc-ad811243d1ba\",\"uuid\":\"830e6a4d-0a9d-4d59-a343-8951fe25f48c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", even if they were to exert themselves as all buddhas did,\",\"attrs\":{\"start\":23,\"end\":82},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"7236cb9e-4b80-431a-9177-4b1c313900bd\",\"label\":\"154\",\"uuid\":\"0e2ca1cf-c37d-42a1-b667-59389eaddd43\",\"start\":82,\"end\":82,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" individuals belonging to the \",\"attrs\":{\"start\":82,\"end\":112}},{\"type\":\"text\",\"text\":\"hearers\",\"attrs\":{\"start\":112,\"end\":119},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"09872ba1-9454-42fc-a9a1-83b2db59413e\",\"uuid\":\"3dafbfce-f7bd-4c56-b2e7-f933bc7bc097\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’ lineage with the state of peace as their sole journey could not reach the heart of \",\"attrs\":{\"start\":119,\"end\":204}},{\"type\":\"text\",\"text\":\"awakening\",\"attrs\":{\"start\":204,\"end\":213},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d0fda944-71f7-4a27-a806-7debbf320eea\",\"uuid\":\"54f36d62-0447-49ed-b511-f068b6861add\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and attain the unsurpassable, complete and perfect \",\"attrs\":{\"start\":213,\"end\":265}},{\"type\":\"text\",\"text\":\"awakening\",\"attrs\":{\"start\":265,\"end\":274},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d0fda944-71f7-4a27-a806-7debbf320eea\",\"uuid\":\"43a713cc-716b-4e1d-8c3f-8c529bfb76c5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Why? Because, having limited compassion and a great fear of suffering, they belong to a lineage that is by nature inferior. Thus, having limited compassion, they avoid striving for beings’ welfare. Being afraid of suffering, they stay clear from the \",\"attrs\":{\"start\":274,\"end\":526}},{\"type\":\"text\",\"text\":\"conditioning process of the mental factors\",\"attrs\":{\"start\":526,\"end\":568},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"43d25ace-6522-4836-895c-e0cd7dfb9684\",\"uuid\":\"6a07da6a-5224-44de-b7e3-aee2799969d6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":568,\"end\":569},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"6a0af7a2-a756-4ca7-9101-df2f4d8fe2b2\",\"label\":\"155\",\"uuid\":\"540059d2-89c9-4b8a-b44c-674bbbd81bed\",\"start\":569,\"end\":569,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" However, I did not teach that avoiding striving for beings’ welfare and staying clear from the \",\"attrs\":{\"start\":569,\"end\":665}},{\"type\":\"text\",\"text\":\"conditioning process of the mental factors\",\"attrs\":{\"start\":665,\"end\":707},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"43d25ace-6522-4836-895c-e0cd7dfb9684\",\"uuid\":\"4fdf54eb-cb2c-469f-8c6c-94e198f45128\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" was the unsurpassable, complete and perfect \",\"attrs\":{\"start\":707,\"end\":752}},{\"type\":\"text\",\"text\":\"awakening\",\"attrs\":{\"start\":752,\"end\":761},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d0fda944-71f7-4a27-a806-7debbf320eea\",\"uuid\":\"2dc2f96e-c1d4-4773-99f2-902918710de1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Therefore, these individuals are called \",\"attrs\":{\"start\":761,\"end\":803}},{\"type\":\"text\",\"text\":\"those who have the state of peace as their sole journey\",\"attrs\":{\"start\":803,\"end\":858},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":803,\"end\":858,\"uuid\":\"54fcebc7-dfab-4150-b003-448c2da3fc87\",\"type\":\"span\",\"textStyle\":\"distinct\"}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":858,\"end\":859}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"742e1eed-1fc8-48ae-99e8-c650fee3bb76\",\"sort\":5335,\"type\":\"translation\",\"label\":\"7.16\",\"alignments\":{\"toh106\":{\"folioUuid\":\"422c6b37-9835-4636-8afb-e5bdea27e626\",\"toh\":\"toh106\",\"tibetan\":\"ཉན་ཐོས་བྱང་ཆུབ་ཏུ་ཡོངས་སུ་འགྱུར་བ་གང་ཡིན་པ་དེ་ནི་ངས་རྣམ་[F.20.a]གྲངས་ཀྱིས་བྱང་ཆུབ་སེམས་དཔའ་ཡིན་པར་བསྟན་ཏེ། འདི་ལྟར་དེ་ནི་ཉོན་མོངས་པའི་སྒྲིབ་པ་ལས་རྣམ་པར་གྲོལ་ནས། དེ་བཞིན་གཤེགས་པ་རྣམས་ཀྱིས་བསྐུལ་ན། ཤེས་བྱའི་སྒྲིབ་པ་ལས་སེམས་རྣམ་པར་གྲོལ་བར་བྱེད་པའི་ཕྱིར་རོ། །དེ་ནི་དང་\\nཔོར་བདག་གི་དོན་ལ་སྦྱོར་བའི་རྣམ་པས་ཉོན་མོངས་པའི་སྒྲིབ་པ་ལས་རྣམ་པར་གྲོལ་ཏེ། དེའི་ཕྱིར་དེ་བཞིན་གཤེགས་པས་དེ་ཉན་ཐོས་ཀྱི་རིགས་སུ་འདོགས་སོ། །\",\"folioNumber\":19,\"volumeNumber\":49}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":415,\"uuid\":\"742e1eed-1fc8-48ae-99e8-c650fee3bb76\"},\"content\":[{\"type\":\"text\",\"text\":\"“I taught that \",\"attrs\":{\"start\":0,\"end\":15}},{\"type\":\"text\",\"text\":\"hearers\",\"attrs\":{\"start\":15,\"end\":22},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"09872ba1-9454-42fc-a9a1-83b2db59413e\",\"uuid\":\"f42985b1-f1d0-45d3-9b4e-4e9be00a047d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" who evolve toward \",\"attrs\":{\"start\":22,\"end\":41}},{\"type\":\"text\",\"text\":\"awakening\",\"attrs\":{\"start\":41,\"end\":50},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d0fda944-71f7-4a27-a806-7debbf320eea\",\"uuid\":\"c02e3e78-944c-420b-b4bb-b24843296d26\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" belong to the category of bodhisattvas because, liberated from the \",\"attrs\":{\"start\":50,\"end\":118}},{\"type\":\"text\",\"text\":