uid\":\"1c1823f4-0e7f-461a-ae00-fdf60586103e\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"The Context\",\"attrs\":{\"start\":0,\"end\":11}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"a3d8b502-aa70-4368-8318-2633ebe48de1\",\"sort\":106,\"type\":\"introduction\",\"label\":\"i.3\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":850,\"uuid\":\"a3d8b502-aa70-4368-8318-2633ebe48de1\"},\"content\":[{\"type\":\"text\",\"text\":\"The sūtra is structured in the form of a series of dialogues between the Buddha and advanced bodhisattvas or \",\"attrs\":{\"start\":0,\"end\":109}},{\"type\":\"text\",\"text\":\"hearers\",\"attrs\":{\"start\":109,\"end\":116},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"09872ba1-9454-42fc-a9a1-83b2db59413e\",\"uuid\":\"cc5c41f7-cf2c-4d43-9845-707b89f007e3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", as well as between bodhisattvas (see \",\"attrs\":{\"start\":116,\"end\":155}},{\"type\":\"text\",\"text\":\"chapter 1\",\"attrs\":{\"start\":155,\"end\":164},\"marks\":[{\"type\":\"internalLink\",\"attrs\":{\"uuid\":\"6d61cdec-4f5b-4c76-a80a-5958ffca4dc1\",\"href\":\"/entity/passage/9737af74-7337-4ab2-a155-bac9d2739e7e\",\"entity\":\"9737af74-7337-4ab2-a155-bac9d2739e7e\",\"type\":\"passage\",\"toh\":null,\"isSameWork\":true,\"subtype\":\"translation\"}}]},{\"type\":\"text\",\"text\":\"). These dialogues deal with both the theory and practice of the entire bodhisattva path. Narrative elements are extremely limited in this teaching. However, a narrative pattern can be found in chapter 2 and 3, which begin, respectively, with a story about a group of \",\"attrs\":{\"start\":164,\"end\":432}},{\"type\":\"text\",\"text\":\"non-Buddhists\",\"attrs\":{\"start\":432,\"end\":445},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f72c6722-81a1-48c8-9569-2e4976845d31\",\"uuid\":\"d209267c-68a0-4cd7-9682-aced0d6d8386\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":445,\"end\":447}},{\"type\":\"text\",\"text\":\"tīrthika\",\"attrs\":{\"start\":447,\"end\":455},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":447,\"end\":455,\"uuid\":\"ce6152ae-4c38-4675-86ff-f8d6fad9a369\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"s) and some followers of the Buddha who have gathered to discuss a difficult point regarding the nature of reality and cannot agree on anything. The main protagonists then beg the Buddha to provide an explanation for the quandary these assemblies cannot not resolve, or alternatively to explain his underlying intent when he expounded the teachings that gave rise to conflicting interpretations.\",\"attrs\":{\"start\":455,\"end\":850}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"efbd55e5-24e4-4153-b38e-2042d31888b5\",\"sort\":116,\"type\":\"introduction\",\"label\":\"i.4\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1602,\"uuid\":\"efbd55e5-24e4-4153-b38e-2042d31888b5\"},\"content\":[{\"type\":\"text\",\"text\":\"Each chapter starts with a question on a topic requiring further elucidation: In the first chapter, the bodhisattva \",\"attrs\":{\"start\":0,\"end\":116}},{\"type\":\"text\",\"text\":\"Vidhi­vatpari­pṛcchaka\",\"attrs\":{\"start\":116,\"end\":138},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"afb1fe39-9a5a-4dfe-8723-31f7d6185185\",\"uuid\":\"e1c79bf7-7da5-4717-9283-ba539b295406\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" questions the bodhisattva \",\"attrs\":{\"start\":138,\"end\":165}},{\"type\":\"text\",\"text\":\"Gam­bhīrārtha­saṃdhi­nirmo­cana\",\"attrs\":{\"start\":165,\"end\":196},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7fbcc538-193d-4161-aaea-2b03f15c52f2\",\"uuid\":\"2437078c-52af-481b-9f75-f76515ea23a8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" on the \",\"attrs\":{\"start\":196,\"end\":