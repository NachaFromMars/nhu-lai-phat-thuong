"text\",\"text\":\"negate\",\"attrs\":{\"start\":1457,\"end\":1463},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":1447,\"end\":1498,\"uuid\":\"da0be1cf-ff02-473b-bfee-02a57df6131f\",\"type\":\"span\",\"textStyle\":\"distinct\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7696ecf2-46e6-4c50-81e8-de20c2de8f9e\",\"uuid\":\"a86dca44-ba6e-4e3f-83d3-86e9211292d8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" all three \",\"attrs\":{\"start\":1463,\"end\":1474},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":1463,\"end\":1498,\"uuid\":\"da0be1cf-ff02-473b-bfee-02a57df6131f\",\"type\":\"span\",\"textStyle\":\"distinct\"}}]},{\"type\":\"text\",\"text\":\"defining characteristics\",\"attrs\":{\"start\":1474,\"end\":1498},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":1474,\"end\":1498,\"uuid\":\"da0be1cf-ff02-473b-bfee-02a57df6131f\",\"type\":\"span\",\"textStyle\":\"distinct\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f4503be0-02d4-474f-8f1c-a69993648574\",\"uuid\":\"5f591de7-f160-4d93-871d-36174696b425\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". They consider my teaching to be the \",\"attrs\":{\"start\":1498,\"end\":1536}},{\"type\":\"text\",\"text\":\"truth\",\"attrs\":{\"start\":1536,\"end\":1541},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"abe60eab-c2c6-4378-8741-74dc4f33f705\",\"uuid\":\"08209856-8212-45c1-8e90-68499ba89b63\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" while considering some nonsense to be its meaning. Those who consider my teaching to be the \",\"attrs\":{\"start\":1541,\"end\":1634}},{\"type\":\"text\",\"text\":\"truth\",\"attrs\":{\"start\":1634,\"end\":1639},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"abe60eab-c2c6-4378-8741-74dc4f33f705\",\"uuid\":\"3c38c315-734b-4d85-b057-1cd6450facf2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" while considering some nonsense to be its meaning cling to my teaching as the \",\"attrs\":{\"start\":1639,\"end\":1718}},{\"type\":\"text\",\"text\":\"truth\",\"attrs\":{\"start\":1718,\"end\":1723},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"abe60eab-c2c6-4378-8741-74dc4f33f705\",\"uuid\":\"5d026d4f-da15-4516-b9f1-2216c6c71c66\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" while at the same time clinging to some nonsense as its meaning. Since they have confidence in my teaching, they will progress by developing virtuous qualities. However, because they \",\"attrs\":{\"start\":1723,\"end\":1907}},{\"type\":\"text\",\"text\":\"wrongly conceive\",\"attrs\":{\"start\":1907,\"end\":1923},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a3e3ca3d-5d92-43b5-bf7a-d02257107104\",\"uuid\":\"e651f354-e0dd-4296-96f6-7feaed97df8c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" some nonsense to be the meaning of my teaching, they will stray from \",\"attrs\":{\"start\":1923,\"end\":1993}},{\"type\":\"text\",\"text\":\"wisdom\",\"attrs\":{\"start\":1993,\"end\":1999},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4c3420a1-ffdd-40b2-9f85-e4293f7c2bbb\",\"uuid\":\"a6fb51fb-6e34-4349-9307-56907854833a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Straying from \",\"attrs\":{\"start\":1999,\"end\":2015}},{\"type\":\"text\",\"text\":\"wisdom\",\"attrs\":{\"start\":2015,\"end\":2021},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4c3420a1-ffdd-40b2-9f85-e4293f7c2bbb\",\"uuid\":\"0f083b61-5b9a-4fb1-8fa5-4bf9c3f73be8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", they will stray from the vast and immeasurable virtuous qualities.\",\"attrs\":{\"start\":2021,\"end\":2089}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"5f2944ef-8cf1-41d2-b95c-4b1be4ef0dd0\",\"sort\":5538,\"type\":\"translation\",\"label\":\"7.21\",\"alignments\":{\"toh106\":{\"folioUuid\":\"cfa2ad4f-ca6b-4403-80a8-a9fc10a0c925\",\"toh\":\"toh106\",\"tibetan\":\"དེ་དག་ལས་གཞན་དག་གིས་ཆོས་ལ་ཆོས་སུ་དང་། དོན་མ་ཡིན་པ་ལ་དོན་དུ་ཐོས་ནས་གང་དག་ལྟ་བ་ལ་དགའ་བར་བྱེད་པ་དེ་དག་ནི་ཆོས་ལ་ཆོས་སུ་འདུ་ཤེས་པ་དང་། དོན་མ་ཡིན་པ་ལ་དོན་དུ་འདུ་ཤེས་པས་ཆོས་ལ་ཆོས་\\nསུ་དང་། དོན་མ་ཡིན་པ་ལ་དོན་དུ་མངོན་པར་ཞེན་པར་འགྱུར་ཏེ། དེ་དག་གཞི་དེས་ན་དེ་བཞིན་དུ་དགེ་བའི་ཆོས་ལས་ཉམས་པར་རིག་པར་བྱའོ། །\",\"folioNumber\":21,\"volumeNumber\":49}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":387,\"uuid\":\"5f2944ef-8cf1-41d2-b95c-4b1be4ef0dd0\"},\"content\":[{\"type\":\"text\",\"text\":\"“Others hear from those beings that my teaching is the \",\"attrs\":{\"start\":0,\"end\":55}},{\"type\":\"text\",\"text\":\"truth\",\"attrs\":{\"start\":55,\"end\":60},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"abe60eab-c2c6-4378-8741-74dc4f33f705\",\"uuid\":\"8249554e-1f2f-4117-9ba8-9b8723315c54\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" while some nonsense is its meaning. Then, delighted by this view, they \",\"attrs\":{\"start\":60,\"end\":132}},{\"type\":\"text\",\"text\":\"accept\",\"attrs\":{\"start\":132,\"end\":138},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b7a96b61-49dc-47df-b835-9b316e7d9e37\",\"uuid\":\"f10a896e-4fe0-4215-b29d-de2f461b72c2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" that my teaching is the \",\"attrs\":{\"start\":138,\"end\":163}},{\"type\":\"text\",\"text\":\"truth\",\"attrs\":{\"start\":163,\"end\":168},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"abe60eab-c2c6-4378-8741-74dc4f33f705\",\"uuid\":\"e4139287-a0fe-41d0-bfa6-31890dfa0185\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and some nonsense is its meaning. Thus, they \",\"attrs\":{\"start\":168,\"end\":214}},{\"type\":\"text\",\"text\":\"wrongly conceive\",\"attrs\":{\"start\":214,\"end\":230},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a3e3ca3d-5d92-43b5-bf7a-d02257107104\",\"uuid\":\"0fa6fb62-9908-4824-8f6d-365da1502967\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" my teaching as the \",\"attrs\":{\"start\":230,\"end\":250}},{\"type\":\"text\",\"text\":\"truth\",\"attrs\":{\"start\":250,\"end\":255},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"abe60eab-c2c6-4378-8741-74dc4f33f705\",\"uuid\":\"210e6d0f-64f0-452e-aa93-3263d87d0f86\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" with some nonsense as its meaning. As a consequence of this, you should know that they will likewise stray from virtuous qualities.\",\"attrs\":{\"start\":255,\"end\":387}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"39de7fd6-8943-4795-890a-b26eb41a9720\",\"sort\":5550,\"type\":\"translation\",\"label\":\"7.22\",\"alignments\":{\"toh106\":{\"folioUuid\":\"cfa2ad4f-ca6b-4403-80a8-a9fc10a0c925\",\"toh\":\"toh106\",\"tibetan\":\"གང་དག་ལྟ་བ་ལ་དགའ་བར་མི་བྱེད་པ་དེ་དག་ནི་དེ་དག་ལས་ཆོས་རྣམས་ཀྱི་ངོ་བོ་ཉིད་མེད་པ་ཉིད་ཐོས་ཤིང་ཆོས་རྣམས་ཀྱི་སྐྱེ་བ་མེད་པ་དང་། \\nའགག་པ་མེད་པ་དང་། གཟོད་མ་ནས་ཞི་བ་དང་། རང་བཞིན་གྱིས་ཡོངས་སུ་མྱ་ངན་ལས་འདས་པ་ཐོས་ནས་སྐྲག་ཅིང་དངང་ལ་ཀུན་ཏུ་དངང་བར་འགྱུར་ཞིང་འདི་སྐད་ཅེས་འདི་ནི་སངས་རྒྱས་ཀྱི་བཀའ་མ་ཡིན་གྱི། འདི་ནི་བདུད་ཀྱིས་སྨྲས་པ་ཡིན་ནོ་ཞེས་ཀྱང་ཟེར་ཞིང་དེ་ལྟར་རིག་ནས་མདོ་སྡེ་\\nདེ་དག་ལ་སྐུར་པ་འདེབས་པར་བྱེད། སྤོང་བར་བྱེད། མི་བསྔགས་པ་རྗོད་པར་བྱེད། ངན་དུ་རྗོད་པར་བྱེད། གཞི་དེས་ན་ཕོངས་པ་ཆེན་པོ་འཐོབ་པར་འགྱུར་ཞིང་ལས་ཀྱི་སྒྲིབ་པ་ཆེན་པོས་ཀྱང་རེག་པར་འགྱུར་རོ། །གཞི་དེས་ཀྱང་གང་དག་སྐྱེ་བོ་ཕལ་པོ་ཆེ་ལ་ལས་ཀྱི་སྒྲིབ་པ་ཆེན་པོ་\\nའཐོབ་པས་སླུ་བར་བྱེད་པ། མཚན་ཉིད་ཐམས་ཅད་མེད་པར་ལྟ་ཞིང་དོན་མ་ཡིན་པ་དོན་དུ་སྟོན་པར་བྱེད་པ་དེ་དག་ནི་ལས་ཀྱི་སྒྲིབ་པ་ཆེན་པོ་དང་ལྡན་པར་ང་སྨྲའོ། །\",\"folioNumber\":21,\"volumeNumber\":49}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":827,\"uuid\":\"39de7fd6-8943-4795-890a-b26eb41a9720\"},\"content\":[{\"type\":\"text\",\"text\":\"“Others who take no delight in this view are overcome by fear and anxiety when they hear that all phenomena are without an \",\"attrs\":{\"start\":0,\"end\":123}},{\"type\":\"text\",\"text\":\"essence\",\"attrs\":{\"start\":123,\"end\":130},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"47c8923c-56be-43d8-b398-ff4290cece41\",\"uuid\":\"58e67f73-8f97-4327-b2a3-1b0f277c83a3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":130,\"end\":132}},{\"type\":\"text\",\"text\":\"unborn\",\"attrs\":{\"start\":132,\"end\":138},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"760ae48f-4c62-4d01-9846-06e850f94816\",\"uuid\":\"6de79214-8fee-430a-954c-df87ac35b2cc\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", unceasing, \",\"attrs\":{\"start\":138,\"end\":151}},{\"type\":\"text\",\"text\":\"primordially in the state of peace\",\"attrs\":{\"start\":151,\"end\":185},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1e90dc88-d44c-4d41-a2d6-f27e9685ce7f\",\"uuid\":\"dda3d702-c73b-473e-8b2a-1e006af2260d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and naturally in the state of \",\"attrs\":{\"start\":185,\"end\":217}},{\"type\":\"text\",\"text\":\"nirvāṇa\",\"attrs\":{\"start\":217,\"end\":224},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"957da5d5-795e-4533-909b-58063c94b409\",\"uuid\":\"7406d0d8-0aa3-47e2-8eee-9aa734f27266\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". They then say, ‘These are not the words of the Buddha but the words of Māra!’ Thinking in this way, they reject this discourse, disparage it, denigrate it, and criticize it. As a consequence of this, they will obtain the great misfortune as well as the great karmic \",\"attrs\":{\"start\":224,\"end\":492}},{\"type\":\"text\",\"text\":\"obscuration\",\"attrs\":{\"start\":492,\"end\":503},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9c961f85-80e2-4d1c-a536-20d956f9dbe8\",\"uuid\":\"ccc94ba9-2f70-4b1c-8ed8-76806e155b41\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" [of rejecting the \",\"attrs\":{\"start\":503,\"end\":522}},{\"type\":\"text\",\"text\":\"truth\",\"attrs\":{\"start\":522,\"end\":527},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"abe60eab-c2c6-4378-8741-74dc4f33f705\",\"uuid\":\"87f98de1-0a6b-4323-9fe8-8a9b5d6eaeec\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"].\",\"attrs\":{\"start\":527,\"end\":529},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"ff64653d-45fa-47f4-83c8-f4fac87b74d0\",\"label\":\"160\",\"uuid\":\"757f002e-d8e4-4d3d-8b84-899b2c35f0ef\",\"start\":529,\"end\":529,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" This is precisely why I said, ‘Those who mislead the multitude of beings into obtaining the great karmic \",\"attrs\":{\"start\":529,\"end\":635}},{\"type\":\"text\",\"text\":\"obscuration\",\"attrs\":{\"start\":635,\"end\":646},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9c961f85-80e2-4d1c-a536-20d956f9dbe8\",\"uuid\":\"f707b422-2166-4b15-bd44-b3ca8e1ad8f0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", who consider all \",\"attrs\":{\"start\":646,\"end\":665}},{\"type\":\"text\",\"text\":\"defining characteristics\",\"attrs\":{\"start\":665,\"end\":689},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f4503be0-02d4-474f-8f1c-a69993648574\",\"uuid\":\"56082ff5-633a-458d-8cf7-ac9d8754ca39\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" as inexistent and teach some nonsense as the meaning of my teaching, are burdened with great karmic \",\"attrs\":{\"start\":689,\"end\":790}},{\"type\":\"text\",\"text\":\"obscuration\",\"attrs\":{\"start\":790,\"end\":801},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9c961f85-80e2-4d1c-a536-20d956f9dbe8\",\"uuid\":\"9ba1996c-811d-4805-a819-8973e3ec6c15\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" [of rejecting the \",\"attrs\":{\"start\":801,\"end\":820}},{\"type\":\"text\",\"text\":\"truth\",\"attrs\":{\"start\":820,\"end\":825},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"abe60eab-c2c6-4378-8741-74dc4f33f705\",\"uuid\":\"a561e4f0-651d-4eb3-8ba6-39135278e9fb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"].\",\"attrs\":{\"start\":825,\"end\":827}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"1d5ac0dc-2af1-4818-b2a1-830b1b5a7f74\",\"sort\":5574,\"type\":\"translation\",\"label\":\"7.23\",\"alignments\":{\"toh106\":{\"folioUuid\":\"cfa2ad4f-ca6b-4403-80a8-a9fc10a0c925\",\"toh\":\"toh106\",\"tibetan\":\"$90\",\"folioNumber\":21,\"volumeNumber\":49}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1327,\"uuid\":\"72a2d78e-19d1-4e8a-b1c8-c549d0d88b10\"},\"content\":[{\"type\":\"text\",\"text\":\"“\",\"attrs\":{\"start\":0,\"end\":1}},{\"type\":\"text\",\"text\":\"Para­mārtha­samud­gata\",\"attrs\":{\"start\":1,\"end\":23},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"537e957c-58b2-4ce7-88cc-ad811243d1ba\",\"uuid\":\"c9ac7db0-35cc-4b07-8963-b1d268c6cc45\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", among such beings, some have not produced roots of virtue, purified their \",\"attrs\":{\"start\":23,\"end\":99}},{\"type\":\"text\",\"text\":\"obscurations\",\"attrs\":{\"start\":99,\"end\":111},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9c961f85-80e2-4d1c-a536-20d956f9dbe8\",\"uuid\":\"75c4b109-0124-4ae8-88a4-c7a805cf1fa0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and brought their mental continuum to maturity. Their confidence in my teaching is limited, and they have not accomplished the accumulations of merit and \",\"attrs\":{\"start\":111,\"end\":267}},{\"type\":\"text\",\"text\":\"gnosis\",\"attrs\":{\"start\":267,\"end\":273},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b36258b5-bd30-4205-aeeb-75bac743076f\",\"uuid\":\"74984533-f325-49b8-9647-eb18fbbb1856\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". They are dishonest and insincere. Although they are unable to evaluate and refute [others’ views], they consider their own as supreme. When they hear my teaching, they neither understand my explanations in accordance with my underlying intent exactly as it is, nor do they develop confidence in this teaching. They \",\"attrs\":{\"start\":273,\"end\":590}},{\"type\":\"text\",\"text\":\"accept\",\"attrs\":{\"start\":590,\"end\":596},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b7a96b61-49dc-47df-b835-9b316e7d9e37\",\"uuid\":\"26c2c79b-5dba-49e8-aae4-3d189c58b7e5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" that my teaching is not the \",\"attrs\":{\"start\":596,\"end\":625}},{\"type\":\"text\",\"text\":\"truth\",\"attrs\":{\"start\":625,\"end\":630},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"abe60eab-c2c6-4378-8741-74dc4f33f705\",\"uuid\":\"e52df86b-180e-47fb-bbcc-411944f00106\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and its meaning is some nonsense. They say, ‘These are not the words of the Buddha but the words of Māra!’ Thinking in this way, they reject this discourse, disparage it, denigrate it, criticize it, and distort [its meaning]. In many ways, they apply themselves to discarding, undermining, and subverting this discourse, considering as enemies those who are devoted to it. From the very beginning, they are affected by the karmic \",\"attrs\":{\"start\":630,\"end\":1061}},{\"type\":\"text\",\"text\":\"obscuration\",\"attrs\":{\"start\":1061,\"end\":1072},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9c961f85-80e2-4d1c-a536-20d956f9dbe8\",\"uuid\":\"0a47956a-1163-4fd8-b9ce-6cadde4c0c3a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" [of rejecting the \",\"attrs\":{\"start\":1072,\"end\":1091}},{\"type\":\"text\",\"text\":\"truth\",\"attrs\":{\"start\":1091,\"end\":1096},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"abe60eab-c2c6-4378-8741-74dc4f33f705\",\"uuid\":\"63e43a4e-ad8e-4d1f-b18d-9b9d64feb743\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"]. As a consequence of this, they also cause [others] to be obscured by this karmic \",\"attrs\":{\"start\":1096,\"end\":1180}},{\"type\":\"text\",\"text\":\"obscuration\",\"attrs\":{\"start\":1180,\"end\":1191},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9c961f85-80e2-4d1c-a536-20d956f9dbe8\",\"uuid\":\"36897fec-1eba-41b7-9e3c-b9990dca93ff\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Although it is easy to determine the beginning of this karmic \",\"attrs\":{\"start\":1191,\"end\":1255}},{\"type\":\"text\",\"text\":\"obscuration\",\"attrs\":{\"start\":1255,\"end\":1266},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9c961f85-80e2-4d1c-a536-20d956f9dbe8\",\"uuid\":\"e8042b78-4c04-45ca-9f03-d7f2d4058e4f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", it is difficult to know how many myriad eons it will last. \",\"attrs\":{\"start\":1266,\"end\":1327}}]},{\"type\":\"paragraph\",\"attrs\":{\"start\":1327,\"end\":1520,\"uuid\":\"94db67d7-96db-40a4-b320-b452fed5b729\"},\"content\":[{\"type\":\"text\",\"text\":\"“Thus, \",\"attrs\":{\"start\":1327,\"end\":1334}},{\"type\":\"text\",\"text\":\"Para­mārtha­samud­gata\",\"attrs\":{\"start\":1334,\"end\":1356},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"537e957c-58b2-4ce7-88cc-ad811243d1ba\",\"uuid\":\"3554d83c-20c7-4d79-bf50-39b177d1040e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", those are the various degrees of confidence in my Dharma and my Vinaya,\",\"attrs\":{\"start\":1356,\"end\":1429},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"2b05df0b-6021-4c33-9d03-7516670ee99c\",\"label\":\"161\",\"uuid\":\"783cdd73-8c7d-4c91-be06-446abc385c4a\",\"start\":1429,\"end\":1429,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" which are well proclaimed, well imparted, pure in their \",\"attrs\":{\"start\":1429,\"end\":1486}},{\"type\":\"text\",\"text\":\"intention\",\"attrs\":{\"start\":1486,\"end\":1495},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1d91dcb1-52df-4912-8c74-aded9c238d9e\",\"uuid\":\"e3c90636-8ec0-40f0-a08a-7ff1c0136ede\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and well communicated.”\",\"attrs\":{\"start\":1495,\"end\":1520}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"193a5539-8dd2-4d5b-aac4-5f52114cfee4\",\"sort\":5603,\"type\":\"translation\",\"label\":\"7.24\",\"alignments\":{\"toh106\":{\"folioUuid\":\"fe81db7d-89a7-46b5-a057-b8ba9712ab50\",\"toh\":\"toh106\",\"tibetan\":\"དེ་ནས་བཅོམ་ལྡན་འདས་ཀྱིས་དེའི་ཚེ་ཚིགས་སུ་བཅད་པ་འདི་དག་བཀའ་སྩལ་ཏོ། །ཆོས་རྣམས་ངོ་བོ་ཉིད་མེད་ཆོས་རྣམས་མ་སྐྱེས་\\nདང་། །ཆོས་རྣམས་མ་འགགས་ཆོས་རྣམས་གཟོད་ནས་ཞི་བ་དང་། །ཆོས་རྣམས་ཐམས་ཅད་རང་བཞིན་མྱ་ངན་འདས་པར་ནི། །དགོངས་པ་མེད་པར་མཁས་པ་སུ་ཞིག་སྨྲ་བར་བྱེད། །མཚན་ཉིད་ངོ་བོ་ཉིད་མེད་སྐྱེ་བ་ངོ་བོ་མེད། །དོན་དམ་ངོ་བོ་ཉིད་མེད་དོ་ཞེས་ངས་\\nབཤད་དེ། །འདི་ལ་མཁས་པ་གང་ཞིག་དགོངས་པ་ཤེས་པ་ནི། །རབ་ཏུ་ཉམས་པར་འགྱུར་བའི་ལམ་དུ་དེ་མི་འགྲོ །ཀུན་གྱི་རྣམ་དག་ལམ་ནི་གཅིག་པུ་འདི་ཡིན་ཏེ། །རྣམ་པར་དག་པའང་གཅིག་སྟེ་གཉིས་པ་གང་ཡང་མེད། །དེ་ཕྱིར་ཐེག་པ་གཅིག་པ་འདི་ནི་འདོགས་\\nབྱེད་ཀྱང་། །སེམས་ཅན་རིགས་ནི་རྣམ་པ་སྣ་ཚོགས་མེད་མ་ཡིན། །སེམས་ཅན་ཁམས་འདི་ན་ནི་གང་བདག་གཅིག་པུ་པ། །མྱ་ངན་འདའ་བར་བྱེད་པའི་སེམས་ཅན་དཔག་ཏུ་མེད། །གང་དག་མྱ་ངན་འདས་ཀྱང་སེམས་ཅན་མི་གཏོང་བའི། །བརྟན་པ་སྙིང་རྗེ་ལྡན་པ་དེ་[F.22.b]དག་ཤིན་ཏུ་དཀོན། །གང་གྲོལ་དེ་དག་རྣམས་ཀྱི་ཟག་པ་མེད་པའི་དབྱིངས། །ཕྲ་ཞིང་བསམ་གྱིས་མི་ཁྱབ་མཉམ་ཞིང་བྱེ་བྲག་མེད། །ཐམས་ཅད་དོན་གྲུབ་སྡུག་བསྔལ་ཉོན་མོངས་སྤངས་པ་སྟེ། །གཉིས་སུ་བརྗོད་པ་མ་ཡིན་བདེ་ཞིང་བརྟན་པ་ཡིན། །\",\"folioNumber\":22,\"volumeNumber\":49}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":58,\"uuid\":\"e76dfb4f-953b-42e2-92a4-95aa2ecac2a0\"},\"content\":[{\"type\":\"text\",\"text\":\"Then, at that moment, the \",\"attrs\":{\"start\":0,\"end\":26}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":26,\"end\":37},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1b51c11a-be57-45e7-82eb-2691bb785c0d\",\"uuid\":\"828e2ed0-2e67-4236-b8a6-9dc107c596d8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" spoke these verses: \",\"attrs\":{\"start\":37,\"end\":58}}]},{\"type\":\"lineGroup\",\"attrs\":{\"start\":58,\"end\":253,\"uuid\":\"d4aacab8-b118-4ca4-8ce0-3ddd0d050a66\