ssary\":\"47d7ce80-c6de-4173-bf62-5997019ee7de\",\"uuid\":\"a9bfffd7-28b9-4a83-b494-1c218cdcdc5c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the antidotes to their adverse factors, their practice, their arising from having been non-arisen, their remaining after they arose, and their maintaining, resuming, or increasing.\",\"attrs\":{\"start\":672,\"end\":854},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"30aab3aa-3c92-41c3-a2c8-3253e2586957\",\"label\":\"93\",\"uuid\":\"9c3b859a-e5cb-4581-a28f-90072c215c52\",\"start\":854,\"end\":854,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"d89bcc48-4bd3-4471-90c7-41b65c4af9cf\",\"sort\":3724,\"type\":\"translation\",\"label\":\"4.6\",\"alignments\":{\"toh106\":{\"folioUuid\":\"bb741158-22d2-4146-8469-37a45240faa0\",\"toh\":\"toh106\",\"tibetan\":\"མཐོང་ནས་ཀྱང་བདག་འདི་སྙམ་བགྱིད་དེ། ཚེ་དང་ལྡན་པ་འདི་དག་ནི་ཆོས་རྣམ་པ་སྣ་ཚོགས་པའི་མངོན་པར་རྟོགས་པ་སྟོན་པས་ཤེས་པ་བརྡ་སྤྲོད་པར་བགྱིད་ཅིང་འདི་ལྟར་དོན་དམ་པ་ཐམས་ཅད་དུ་རོ་གཅིག་པའི་མཚན་ཉིད་མ་འཚལ་བས། ཚེ་དང་ལྡན་པ་འདི་དག་ནི་མངོན་པའི་ང་\\nརྒྱལ་ཅན་མངོན་པའི་ང་རྒྱལ་གྱིས་མངོན་དུ་ཟིན་ཅིང་ཤེས་པ་བརྡ་སྤྲོད་པར་བགྱིད་པ་ཤ་སྟག་ལགས་སོ་སྙམ་བགྱིད་ལགས་སོ། །བཅོམ་ལྡན་འདས་བཅོམ་ལྡན་འདས་ཀྱི་གང་གི་སླད་དུ་འདི་སྐད་ཅེས་དོན་དམ་པ་ནི་ཕྲ་བ། ཟབ་པ་རྟོགས་པར་དཀའ་བ། མཆོག་ཏུ་རྟོགས་པར་\\nདཀའ་བ། ཐམས་ཅད་དུ་རོ་གཅིག་པའི་མཚན་ཉིད་ཡིན་ནོ་ཞེས་བཀའ་སྩལ་པ་ཇི་ཙམ་དུ་བཅོམ་ལྡན་འདས་ཀྱིས་ལེགས་པར་གསུངས་པ་དེ་ནི་ངོ་མཚར་ལགས་ཏེ། བཅོམ་ལྡན་འདས་དོན་དམ་པ་ཐམས་ཅད་དུ་རོ་གཅིག་པའི་མཚན་ཉིད་ནི་བཅོམ་ལྡན་འདས་ཀྱིས་བསྟན་པ་འདི་\\nཉིད་ལ་ཞུགས་པ། དགེ་སློང་དུ་གྱུར་པའི་སེམས་ཅན་རྣམས་ཀྱིས་ཀྱང་དེ་ལྟར་རྟོགས་པར་དཀའ་བ་ལགས་ན། འདི་ལས་སླད་རོལ་པའི་མུ་སྟེགས་ཅན་རྣམས་ཀྱིས་ལྟ་སྨོས་ཀྱང་ཅི་འཚལ། \",\"folioNumber\":10,\"volumeNumber\":49}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":972,\"uuid\":\"d89bcc48-4bd3-4471-90c7-41b65c4af9cf\"},\"content\":[{\"type\":\"text\",\"text\":\"“Then I thought to myself, ‘These venerable monks displayed their knowledge by revealing their understanding by taki