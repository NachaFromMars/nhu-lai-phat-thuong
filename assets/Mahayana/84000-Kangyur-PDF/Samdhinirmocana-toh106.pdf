oreign\"}}]},{\"type\":\"text\",\"text\":\"; \",\"attrs\":{\"start\":7,\"end\":9}},{\"type\":\"text\",\"text\":\"na kṣamate\",\"attrs\":{\"start\":9,\"end\":19},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":9,\"end\":19,\"uuid\":\"ae75c5d9-faa7-4895-81ea-28413b5cfdab\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":19,\"end\":21}},{\"type\":\"text\",\"text\":\"na kṣamati\",\"attrs\":{\"start\":21,\"end\":31},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":21,\"end\":31,\"uuid\":\"aab2414e-58fe-4bab-9425-747d4f14fe18\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" (see Edgerton 1953, p. 199,1). Pāli: \",\"attrs\":{\"start\":31,\"end\":69}},{\"type\":\"text\",\"text\":\"khamati\",\"attrs\":{\"start\":69,\"end\":76},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":69,\"end\":76,\"uuid\":\"df6aee45-c5a8-41a3-9813-504e9b21d6da\",\"type\":\"span\",\"lang\":\"Pi-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" (see \",\"attrs\":{\"start\":76,\"end\":82}},{\"type\":\"text\",\"text\":\"The Pali–English Dictionary\",\"attrs\":{\"start\":82,\"end\":109},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"70b06a8b-40a1-4bc3-a511-460409fae4af\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" (Rhys-Davids 1921), p. 234).\",\"attrs\":{\"start\":109,\"end\":138}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"41347021-37ff-49dc-a650-399f3669384b\",\"sort\":13208,\"type\":\"endnotes\",\"label\":\"n.86\",\"alignments\":{},\"references\":[{\"content\":\"$61\",\"label\":\"3.6\",\"sort\":3490,\"type\":\"translation\",\"uuid\":\"9e4038f4-d563-49ab-a098-246550d8acfd\",\"workUuid\":\"da0adcd3-4abf-406a-8021-b656a348fab8\",\"xmlId\":\"UT22084-049-001-266\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":717,\"uuid\":\"41347021-37ff-49dc-a650-399f3669384b\"},\"content\":[{\"type\":\"text\",\"text\":\"D: \",\"attrs\":{\"start\":0,\"end\":3}},{\"type\":\"text\",\"text\":\"blo gros shin tu rnam dag ngas ni de ltar don dam pa phra ba mchog tu phrag mchog tu zab pa/ rtogs par dka’ ba/ mchog tu dka’ ba/ tha dad pa dang / tha dad pa ma yin pa nyid las yang dag par ’das pa’i mtshan nyid mngon par rdzogs par sangs rgyas te\",\"attrs\":{\"start\":3,\"end\":251},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":3,\"end\":251,\"uuid\":\"4ab5a3b8-cfd7-4cd9-9114-aebdcd6894db\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\". I read \",\"attrs\":{\"start\":251,\"end\":260}},{\"type\":\"text\",\"text\":\"tha dad pa ma yin pa nyid las yang dag par ’das pa’i mtshan nyid\",\"attrs\":{\"start\":260,\"end\":324},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":260,\"end\":324,\"uuid\":\"1be8aaa0-dbd9-4746-99f7-67aa8484901c\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" as a \",\"attrs\":{\"start\":324,\"end\":330}},{\"type\":\"text\",\"text\":\"bahuvrīhi\",\"attrs\":{\"start\":330,\"end\":339},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2283dbd7-1426-4735-a42e-fa3085c70c20\",\"uuid\":\"3020a3a7-c6c1-4d65-bf97-61dc1f4ee14e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", not a \",\"attrs\":{\"start\":339,\"end\":347}},{\"type\":\"text\",\"text\":\"tatpuruṣa\",\"attrs\":{\"start\":347,\"end\":356},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9bd9c153-adda-44e8-a777-c891f1060bba\",\"uuid\":\"9a3eec3f-8c63-48d4-866c-6b633827bbc5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". The terms \",\"attrs\":{\"start\":356,\"end\":368}},{\"type\":\"text\",\"text\":\"don dam pa\",\"attrs\":{\"start\":368,\"end\":378},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":368,\"end\":378,\"uuid\":\"58a0c471-a53d-4e23-a1f9-3772b1925547\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" and \",\"attrs\":{\"start\":378,\"end\":383}},{\"type\":\"text\",\"text\":\"tshan nyid\",\"attrs\":{\"start\":383,\"end\":393},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":383,\"end\":393,\"uuid\":\"95255064-938e-4a82-bf73-5ef257810f82\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" are not in apposition in chapter 3, since the two terms are repeatedly connected through a genitive particle: \",\"attrs\":{\"start\":393,\"end\":504}},{\"type\":\"text\",\"text\":\"don dam pa’i mtshan nyid\",\"attrs\":{\"start\":504,\"end\":528},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":504,\"end\":528,\"uuid\":\"d6a79332-7cc9-4260-a73f-5aea75bcf2c6\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" (which occurs 32 times in folios 5.a, 5.b, 6.b, 7.a, 7.b, 8.a, 8.b, and 9.a). I also understand similar constructions with \",\"attrs\":{\"start\":528,\"end\":652}},{\"type\":\"text\",\"text\":\"don dam pa\",\"attrs\":{\"start\":652,\"end\":662},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":652,\"end\":662,\"uuid\":\"7f73edcb-ff8f-4dbd-b13b-5767b0d61b98\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" and \",\"attrs\":{\"start\":662,\"end\":667}},{\"type\":\"text\",\"text\":\"tshan nyid\",\"attrs\":{\"start\":667,\"end\":677},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":667,\"end\":677,\"uuid\":\"0392f959-6da2-446e-bbbb-d6fcb94465f8\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" in the following chapter as \",\"attrs\":{\"start\":677,\"end\":706}},{\"type\":\"text\",\"text\":\"bahuvrīhis\",\"attrs\":{\"start\":706,\"end\":716},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2283dbd7-1426-4735-a42e-fa3085c70c20\",\"uuid\":\"cffa9753-ec75-42e7-82c0-c12feea434e5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":716,\"end\":717}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"6ac78886-4116-4ba3-9efe-0a5d49d14195\",\"sort\":13230,\"type\":\"endnotes\",\"label\":\"n.87\",\"alignments\":{},\"references\":[{\"content\":\"$62\",\"label\":\"3.6\",\"sort\":3490,\"type\":\"translation\",\"uuid\":\"9e4038f4-d563-49ab-a098-246550d8acfd\",\"workUuid\":\"da0adcd3-4abf-406a-8021-b656a348fab8\",\"xmlId\":\"UT22084-049-001-266\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":208,\"uuid\":\"6ac78886-4116-4ba3-9efe-0a5d49d14195\"},\"content\":[{\"type\":\"text\",\"text\":\"This phrase is also found in \",\"attrs\":{\"start\":0,\"end\":29}},{\"type\":\"text\",\"text\":\"2.2\",\"attrs\":{\"start\":29,\"end\":32},\"marks\":[{\"type\":\"internalLink\",\"attrs\":{\"uuid\":\"02dad5f0-ad6d-4670-b91b-42acdd22fd7d\",\"href\":\"/entity/passage/3faa44e6-9bb4-4672-a02d-cca23dbdb2a4\",\"entity\":\"3faa44e6-9bb4-4672-a02d-cca23dbdb2a4\",\"type\":\"passage\",\"toh\":null,\"isSameWork\":true,\"subtype\":\"translation\"}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":32,\"end\":34}},{\"type\":\"text\",\"text\":\"3.6\",\"attrs\":{\"start\":34,\"end\":37},\"marks\":[{\"type\":\"internalLink\",\"attrs\":{\"uuid\":\"ae9ecfa5-ab25-4532-9d75-907def07a369\",\"href\":\"/entity/passage/9e4038f4-d563-49ab-a098-246550d8acfd\",\"entity\":\"9e4038f4-d563-49ab-a098-246550d8acfd\",\"type\":\"passage\",\"toh\":null,\"isSameWork\":true,\"subtype\":\"translation\"}}]},{\"type\":\"text\",\"text\":\", and \",\"attrs\":{\"start\":37,\"end\":43}},{\"type\":\"text\",\"text\":\"4.7\",\"attrs\":{\"start\":43,\"end\":46},\"marks\":[{\"type\":\"internalLink\",\"attrs\":{\"uuid\":\"137a1db1-9e0b-4be6-aa84-0ef8bc2af1e9\",\"href\":\"/entity/passage/57a237e9-b5a0-4103-8b46-1974ae993e85\",\"entity\":\"57a237e9-b5a0-4103-8b46-1974ae993e85\",\"type\":\"passage\",\"toh\":null,\"isSameWork\":true,\"subtype\":\"translation\"}}]},{\"type\":\"text\",\"text\":\" (see also folios 5.b, 9.a–b, and 10.b–11.a): \",\"attrs\":{\"start\":46,\"end\":92}},{\"type\":\"text\",\"text\":\"mngon par rdzogs par sangs rgyas nas kyang bsnyad cing gsal bar byas/ rnam par phye/ gdags pa byas/ rab tu bstan to\",\"attrs\":{\"start\":92,\"end\":207},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":92,\"end\":207,\"uuid\":\"93a01a70-49fe-40c9-ba3c-b0830534d614\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":207,\"end\":208}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"f9211a6e-8a15-4195-a353-589ff3091245\",\"sort\":13240,\"type\":\"endnotes\",\"label\":\"n.88\",\"alignments\":{},\"references\":[{\"content\":\"Then, at that moment, the Blessed One spoke these verses: “The defining characteristics of the domains of conditioned phenomena and of the ultimate Are free from being distinct or indistinct. Those who imagine them to be distinct or indistinct are mistaken. “As beings practice mental stillness and insight, They will be liberated from the bonds of corruption And the bonds of phenomenal appearance.” This was the chapter of the bodhisattva Su­viśuddha­mati‍—the third chapter.\",\"label\":\"3.7\",\"sort\":3583,\"type\":\"translation\",\"uuid\":\"8d9aca09-79fa-423a-8b2b-97da01af896a\",\"workUuid\":\"da0adcd3-4abf-406a-8021-b656a348fab8\",\"xmlId\":\"UT22084-049-001-272\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":306,\"uuid\":\"f9211a6e-8a15-4195-a353-589ff3091245\"},\"content\":[{\"type\":\"text\",\"text\":\"Powers translates \",\"attrs\":{\"start\":0,\"end\":18}},{\"type\":\"text\",\"text\":\"mtshan nyid\",\"attrs\":{\"start\":18,\"end\":29},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":18,\"end\":29,\"uuid\":\"90e08c96-a200-4a96-b810-6bf456c706d4\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" as singular (see Powers 1995, p. 49). But the question of the identity or difference in this chapter is evaluated from the perspective of two \",\"attrs\":{\"start\":29,\"end\":172}},{\"type\":\"text\",\"text\":\"defining characteristics\",\"attrs\":{\"start\":172,\"end\":196},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f4503be0-02d4-474f-8f1c-a69993648574\",\"uuid\":\"44cd91fd-5bff-405b-b8ed-1140867e6bdf\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", namely, the \",\"attrs\":{\"start\":196,\"end\":210}},{\"type\":\"text\",\"text\":\"defining characteristic\",\"attrs\":{\"start\":210,\"end\":233},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f4503be0-02d4-474f-8f1c-a69993648574\",\"uuid\":\"5532952e-f9c3-4484-97dd-9206c8923839\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of the \",\"attrs\":{\"start\":233,\"end\":241}},{\"type\":\"text\",\"text\":\"conditioned\",\"attrs\":{\"start\":241,\"end\":252},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c41c6d0c-b684-45c0-9367-3c0df3d7d01b\",\"uuid\":\"175fd4b5-785a-481f-bc73-5668e1f4135d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and the \",\"attrs\":{\"start\":252,\"end\":261}},{\"type\":\"text\",\"text\":\"defining characteristic\",\"attrs\":{\"start\":261,\"end\":284},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f4503be0-02d4-474f-8f1c-a69993648574\",\"uuid\":\"a3098c75-292e-463f-b300-4b8d6d53be87\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of the \",\"attrs\":{\"start\":284,\"end\":292}},{\"type\":\"text\",\"text\":\"unconditioned\",\"attrs\":{\"start\":292,\"end\":305},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d680987b-fab1-4356-95cb-fce547654eec\",\"uuid\":\"b73c088a-8df0-4be3-ba97-054f557cbeaa\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":305,\"end\":306}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"779bc67d-de09-4b16-8f33-cccf8962d4d2\",\"sort\":13254,\"type\":\"endnotes\",\"label\":\"n.89\",\"alignments\":{},\"references\":[{\"content\":\"Then, at that moment, the Blessed One spoke these verses: “The defining characteristics of the domains of conditioned phenomena and of the ultimate Are free from being distinct or indistinct. Those who imagine them to be distinct or indistinct are mistaken. “As beings practice mental stillness and insight, They will be liberated from the bonds of corruption And the bonds of phenomenal appearance.” This was the chapter of the bodhisattva Su­viśuddha­mati‍—the third chapter.\",\"label\":\"3.7\",\"sort\":3583,\"type\":\"translation\",\"uuid\":\"8d9aca09-79fa-423a-8b2b-97da01af896a\",\"workUuid\":\"da0adcd3-4abf-406a-8021-b656a348fab8\",\"xmlId\":\"UT22084-049-001-272\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":170,\"uuid\":\"779bc67d-de09-4b16-8f33-cccf8962d4d2\"},\"content\":[{\"type\":\"text\",\"text\":\"The last two lines are quoted in the \",\"attrs\":{\"start\":0,\"end\":37}},{\"type\":\"text\",\"text\":\"Bhāvanākrama\",\"attrs\":{\"start\":37,\"end\":49},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"24dd022f-ff56-478b-9dfd-40831f595497\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"; see Tucci 1971, p. 1: \",\"attrs\":{\"start\":49,\"end\":73}},{\"type\":\"text\",\"text\":\"nimittabandhanāj jantur atho dauṣṭhulabandhanāt/ vipaśyanāṃ bhāvayitvā śamathañ ca vimucyata iti\",\"attrs\":{\"start\":73,\"end\":169},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":73,\"end\":169,\"uuid\":\"494e3b3b-69db-482f-9108-bc8c220967ba\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":169,\"end\":170}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"39306e08-df00-41c4-9b60-e0e4d79aee4f\",\"sort\":13260,\"type\":\"endnotes\",\"label\":\"n.90\",\"alignments\":{},\"references\":[{\"content\":\"Then the Blessed One spoke these words to Subhūti: “Subhūti, do you know how many beings in the world display their knowledge under the influence of conceit? Do you know how many beings in the world display their knowledge without conceit?” Subhūti answered, “Blessed One, according to my knowledge, there are only a few in the world of beings who present their knowledge without conceit, but countless, innumerable, and inexpressible in number are those who do so under its influence. Blessed One, at one time I was staying in a hermitage set in a great forest. There were many monks living in the vicinity who had also established themselves there. At sunrise, I saw them gather together. They showed their knowledge and revealed their understanding by taking various aspects of phenomena as referential objects.\",\"label\":\"4.1\",\"sort\":3622,\"type\":\"translation\",\"uuid\":\"592fa1a1-8b49-4a45-b8c1-c3806aa83272\",\"workUuid\":\"da0adcd3-4abf-406a-8021-b656a348fab8\",\"xmlId\":\"UT22084-049-001-278\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":30,\"uuid\":\"39306e08-df00-41c4-9b60-e0e4d79aee4f\"},\"content\":[{\"type\":\"text\",\"text\":\"Lit. “in the world of \",\"attrs\":{\"start\":0,\"end\":22}},{\"type\":\"text\",\"text\":\"beings\",\"attrs\":{\"start\":22,\"end\":28},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ad3097fe-b272-4d95-8811-3cbb3824ee9e\",\"uuid\":\"cb7d7854-c962-444a-ae20-05e71e297d0c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".”\",\"attrs\":{\"start\":28,\"end\":30}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"47308e18-6186-4787-ac53-f85c76eebd89\",\"sort\":13264,\"type\":\"endnotes\",\"label\":\"n.91\",\"alignments\":{},\"references\":[{\"content\":\"Then the Blessed One spoke these words to Subhūti: “Subhūti, do you know how many beings in the world display their knowledge under the influence of conceit? Do you know how many beings in the world display their knowledge without conceit?” Subhūti answered, “Blessed One, according to my knowledge, there are only a few in the world of beings who present their knowledge without conceit, but countless, innumerable, and inexpressible in number are those who do so under its influence. Blessed One, at one time I was staying in a hermitage set in a great forest. There were many monks living in the vicinity who had also established themselves there. At sunrise, I saw them gather together. They showed their knowledge and revealed their understanding by taking various aspects of phenomena as referential objects.\",\"label\":\"4.1\",\"sort\":3622,\"type\":\"translation\",\"uuid\":\"592fa1a1-8b49-4a45-b8c1-c3806aa83272\",\"workUuid\":\"da0adcd3-4abf-406a-8021-b656a348fab8\",\"xmlId\":\"UT22084-049-001-278\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":62,\"uuid\":\"47308e18-6186-4787-ac53-f85c76eebd89\"},\"content\":[{\"type\":\"text\",\"text\":\"F reads here \",\"attrs\":{\"start\":0,\"end\":13}},{\"type\":\"text\",\"text\":\"shes pa\",\"attrs\":{\"start\":13,\"end\":20},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":13,\"end\":20,\"uuid\":\"0d5e86a5-09c4-43ea-90a3-261749d75fc2\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" in agreement with D. See F, folio 14.bff.\",\"attrs\":{\"start\":20,\"end\":62}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"c00e67f3-d97d-4877-951d-283a9c0150ad\",\"sort\":13268,\"type\":\"endnotes\",\"label\":\"n.92\",\"alignments\":{},\"references\":[{\"content\":\"Then the Blessed One spoke these words to Subhūti: “Subhūti, do you know how many beings in the world display their knowledge under the influence of conceit? Do you know how many beings in the world display their knowledge without conceit?” Subhūti answered, “Blessed One, according to my knowledge, there are only a few in the world of beings who present their knowledge without conceit, but countless, innumerable, and inexpressible in number are those who do so under its influence. Blessed One, at one time I was staying in a hermitage set in a great forest. There were many monks living in the vicinity who had also established themselves there. At sunrise, I saw them gather together. They showed their knowledge and revealed their understanding by taking various aspects of phenomena as referential objects.\",\"label\":\"4.1\",\"sort\":3622,\"type\":\"translation\",\"uuid\":\"592fa1a1-8b49-4a45-b8c1-c3806aa83272\",\"workUuid\":\"da0adcd3-4abf-406a-8021-b656a348fab8\",\"xmlId\":\"UT22084-049-001-278\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":725,\"uuid\":\"c00e67f3-d97d-4877-951d-283a9c0150ad\"},\"content\":[{\"type\":\"text\",\"text\":\"dmigs pa\",\"attrs\":{\"start\":0,\"end\":8},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":0,\"end\":8,\"uuid\":\"80f16c31-4796-462c-906f-edc79661a596\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"; \",\"attrs\":{\"start\":8,\"end\":10}},{\"type\":\"text\",\"text\":\"ālambana\",\"attrs\":{\"start\":10,\"end\":18},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"32d38a05-df64-4e0b-89c0-d67fbf88da5e\",\"uuid\":\"563b02b8-0414-4faa-bd1c-dc95c11e27eb\",\"toh\":null,\"start\":10,\"end\":0}},{\"type\":\"italic\",\"attrs\":{\"start\":10,\"end\":18,\"uuid\":\"433db4cb-2ef4-45cb-a33b-15bd44f4d1f4\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\". I think it is important here to read \",\"attrs\":{\"start\":18,\"end\":57}},{\"type\":\"text\",\"text\":\"dmigs pa\",\"attrs\":{\"start\":57,\"end\":65},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":57,\"end\":65,\"uuid\":\"939f6755-b09a-4dc2-9402-793fe288ce64\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" as meaning “\",\"attrs\":{\"start\":65,\"end\":78}},{\"type\":\"text\",\"text\":\"object\",\"attrs\":{\"start\":78,\"end\":84},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cf9988ae-d23d-4a8e-a24a-2f5503ee7f00\",\"uuid\":\"759cbf7a-5464-4365-b93a-f2b514e73853\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"” because in folio 11.a the Buddha contrasts these various \",\"attrs\":{\"start\":84,\"end\":143}},{\"type\":\"text\",\"text\":\"objects\",\"attrs\":{\"start\":143,\"end\":150},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cf9988ae-d23d-4a8e-a24a-2f5503ee7f00\",\"uuid\":\"a4880174-545a-4ea2-8919-95d66975a751\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":150,\"end\":152}},{\"type\":\"text\",\"text\":\"aggregates\",\"attrs\":{\"start\":152,\"end\":162},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8374849e-bf9a-4380-bfff-576677d94ca0\",\"uuid\":\"744233f9-c206-4fd0-a2cd-49fb5b020b30\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", sense sources, \",\"attrs\":{\"start\":162,\"end\":179}},{\"type\":\"text\",\"text\":\"constituents\",\"attrs\":{\"start\":179,\"end\":191},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c6863d5d-f557-4305-90d2-9dbb8228b0e2\",\"uuid\":\"151b32b4-8cd3-4ae6-a6ff-385b6e5b0e18\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":191,\"end\":193}},{\"type\":\"text\",\"text\":\"truths\",\"attrs\":{\"start\":193,\"end\":199},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"abe60eab-c2c6-4378-8741-74dc4f33f705\",\"uuid\":\"0b987ef0-9140-48cc-bdd4-6a9397746f28\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", etc.) with the “\",\"attrs\":{\"start\":199,\"end\":217}},{\"type\":\"text\",\"text\":\"object conducive to purification\",\"attrs\":{\"start\":217,\"end\":249},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d84afd2b-0e37-47ca-b1a1-00c09c47e855\",\"uuid\":\"c70dd6a5-698c-4cb7-9c32-25063659d434\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"” (\",\"attrs\":{\"start\":249,\"end\":252}},{\"type\":\"text\",\"text\":\"rnam par dag pa’i dmigs pa\",\"attrs\":{\"start\":252,\"end\":278},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":252,\"end\":278,\"uuid\":\"160917e8-03ad-47a1-8d68-a3d57cc34be5\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", *\",\"attrs\":{\"start\":278,\"end\":281}},{\"type\":\"text\",\"text\":\"viśuddhyālambana\",\"attrs\":{\"start\":281,\"end\":297},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":281,\"end\":297,\"uuid\":\"72794991-44e9-4483-9306-9d6f1c68e4c9\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d84afd2b-0e37-47ca-b1a1-00c09c47e855\",\"uuid\":\"2e9b1e43-c9ad-4529-ae3d-480de4a95a26\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"; see Schmithausen 2014, p. 362, §306.5 and n. 1644). Translating \",\"attrs\":{\"start\":297,\"end\":363}},{\"type\":\"text\",\"text\":\"dmigs pa\",\"attrs\":{\"start\":363,\"end\":371},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":363,\"end\":371,\"uuid\":\"e64f333b-4dcf-4b52-9aa4-2bfc5f3421f5\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" here as “observing” would weaken the central opposition between (a) the \",\"attrs\":{\"start\":371,\"end\":444}},{\"type\":\"text\",\"text\":\"objects\",\"attrs\":{\"start\":444,\"end\":451},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cf9988ae-d23d-4a8e-a24a-2f5503ee7f00\",\"uuid\":\"cd30f5fc-d065-4a65-8eaf-436dc3ba85dc\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" taken as a reference point for their practice by those who have not realized the \",\"attrs\":{\"start\":451,\"end\":533}},{\"type\":\"text\",\"text\":\"defining characteristic\",\"attrs\":{\"start\":533,\"end\":556},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f4503be0-02d4-474f-8f1c-a69993648574\",\"uuid\":\"eac4ac6a-053b-4c5b-86cc-8904375802a1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of the \",\"attrs\":{\"start\":556,\"end\":564}},{\"type\":\"text\",\"text\":\"ultimate\",\"attrs\":{\"start\":564,\"end\":572},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1ce42c0c-900f-47c2-9d40-98ccbafcb2bf\",\"uuid\":\"6c78d370-d2ac-474e-a152-4a9d6ecbe5fc\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and (b) the \",\"attrs\":{\"start\":572,\"end\":585}},{\"type\":\"text\",\"text\":\"object conducive to purification\",\"attrs\":{\"start\":585,\"end\":617},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d84afd2b-0e37-47ca-b1a1-00c09c47e855\",\"uuid\":\"a9552883-988e-4a24-912a-b7f0dc2924e6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", which is present within all phenomena. The purpose of this chapter is to introduce this fundamental point.\",\"attrs\":{\"start\":617,\"end\":725}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"30aab3aa-3c92-41c3-a2c8-3253e2586957\",\"sort\":13301,\"type\":\"endnotes\",\"label\":\"n.93\",\"alignments\":{},\"references\":[{\"content\":\"“Some showed their knowledge by taking the four applications of mindfulness as referential objects: their phenomenal appearance, their adverse factors, their antidotes, their practice, their arising from having been non-arisen, their remaining after they arose, and their maintaining, resuming, or increasing. In the same way, some showed their knowledge by taking as referential objects the four correct self-restraints, as well as the four bases of supernatural powers, the five faculties, the five forces, and the seven branches of awakening. Some showed their knowledge by taking as referential objects the eight branches of the noble path: their phenomenal appearance, the antidotes to their adverse factors, their practice, their arising from having been non-arisen, their remaining after they arose, and their maintaining, resuming, or increasing.\",\"label\":\"4.5\",\"sort\":3697,\"type\":\"translation\",\"uuid\":\"5054d69b-04ce-4613-9a99-bd7279b9214d\",\"workUuid\":\"da0adcd3-4abf-406a-8021-b656a348fab8\",\"xmlId\":\"UT22084-049-001-286\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":103,\"uuid\":\"30aab3aa-3c92-41c3-a2c8-3253e2586957\"},\"content\":[{\"type\":\"text\",\"text\":\"This paragraph deals with the thirty-seven \",\"attrs\":{\"start\":0,\"end\":43}},{\"type\":\"text\",\"text\":\"branches of awakening\",\"attrs\":{\"start\":43,\"end\":64},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e8fdd6ff-6a03-404c-ab6f-63e7897326fe\",\"uuid\":\"199fae11-fd7c-45a6-9964-79133314b0ae\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":64,\"end\":66}},{\"type\":\"text\",\"text\":\"byang chub kyi yan lag\",\"attrs\":{\"start\":66,\"end\":88},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":66,\"end\":88,\"uuid\":\"1a4530d1-1a4a-4e0f-b0f5-cc4b487c9c93\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"; \",\"attrs\":{\"start\":88,\"end\":90}},{\"type\":\"text\",\"text\":\"bodhyaṅgāni\",\"attrs\":{\"start\":90,\"end\":101},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":90,\"end\":101,\"uuid\":\"ecb061fb-9d8a-4b10-8007-4e8c51b34b73\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\").\",\"attrs\":{\"start\":101,\"end\":103}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"5bc7328f-c6f5-4789-8c41-be0b54478515\",\"sort\":13309,\"type\":\"endnotes\",\"label\":\"n.94\",\"alignments\":{},\"references\":[{\"content\":\"“Then I thought to myself, ‘These venerable monks displayed their knowledge by revealing their understanding by taking various aspects of phenomena as referential objects, but they have not perceived the ultimate, whose defining characteristic is of a single nature everywhere.’ These venerable persons have conceit and, without doubt, display their knowledge under the influence of conceit. Blessed One, at an earlier time, you spoke these words: ‘The ultimate is subtle, profound, difficult to understand, extremely difficult to understand, and characterized as being of a single nature everywhere.’ How wonderful indeed are these very words of yours! Blessed One, if even those who practice your teaching, such as these beings who became monks, find it difficult to understand in this way the ultimate whose defining characteristic is of a single nature everywhere, what need is there to mention how difficult it is for those outsiders who do not follow your teaching?”\",\"label\":\"4.6\",\"sort\":3724,\"type\":\"translation\",\"uuid\":\"d89bcc48-4bd3-4471-90c7-41b65c4af9cf\",\"workUuid\":\"da0adcd3-4abf-406a-8021-b656a348fab8\",\"xmlId\":\"UT22084-049-001-289\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":704,\"uuid\":\"5bc7328f-c6f5-4789-8c41-be0b54478515\"},\"content\":[{\"type\":\"text\",\"text\":\"ro gcig pa\",\"attrs\":{\"start\":0,\"end\":10},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":0,\"end\":10,\"uuid\":\"10440c87-6591-43fc-b9e2-ab874779de83\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"; \",\"attrs\":{\"start\":10,\"end\":12}},{\"type\":\"text\",\"text\":\"ekarasa\",\"attrs\":{\"start\":12,\"end\":19},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":12,\"end\":19,\"uuid\":\"98161c4d-2d23-42be-a9e9-8828bdfdbe5d\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\". I read the compound \",\"attrs\":{\"start\":19,\"end\":41}},{\"type\":\"text\",\"text\":\"thams cad du ro gcig pa’i mtshan nyid\",\"attrs\":{\"start\":41,\"end\":78},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":41,\"end\":78,\"uuid\":\"bf429a3b-1a80-4114-83d9-bcad0d51912a\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"; *\",\"attrs\":{\"start\":78,\"end\":81}},{\"type\":\"text\",\"text\":\"sarvatraikarasalakṣaṇa\",\"attrs\":{\"start\":81,\"end\":103},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":81,\"end\":103,\"uuid\":\"cf20c177-ae57-467e-9ef3-b24f719d9105\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" (?) as a \",\"attrs\":{\"start\":103,\"end\":113}},{\"type\":\"text\",\"text\":\"bahuvrīhi\",\"attrs\":{\"start\":113,\"end\":122},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2283dbd7-1426-4735-a42e-fa3085c70c20\",\"uuid\":\"5eea9a48-02c6-4ff2-a299-0e8ef928d9e9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"; see D, folio 12.a: \",\"attrs\":{\"start\":122,\"end\":143}},{\"type\":\"text\",\"text\":\"rab ’byor de bzhin du don dam pa yang mtshan nyid tha dad pa’i chos rnams la thams cad du ro gcig pa’i mtshan nyid yin par blta bar bya’o\",\"attrs\":{\"start\":143,\"end\":280},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":143,\"end\":280,\"uuid\":\"b16b1a7a-7069-48ed-8d42-47c76d5c558b\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\". I understand \",\"attrs\":{\"start\":280,\"end\":295}},{\"type\":\"text\",\"text\":\"thams cad du ro gcig pa’i mtshan nyid\",\"attrs\":{\"start\":295,\"end\":332},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":295,\"end\":332,\"uuid\":\"6e211aa1-4cd2-45aa-a528-ec4e037dcf26\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" to refer here to the \",\"attrs\":{\"start\":332,\"end\":354}},{\"type\":\"text\",\"text\":\"defining characteristic\",\"attrs\":{\"start\":354,\"end\":377},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f4503be0-02d4-474f-8f1c-a69993648574\",\"uuid\":\"e1cccef4-1e91-473f-ad14-70c2723d4607\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of the \",\"attrs\":{\"start\":377,\"end\":385}},{\"type\":\"text\",\"text\":\"ultimate\",\"attrs\":{\"start\":385,\"end\":393},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1ce42c0c-900f-47c2-9d40-98ccbafcb2bf\",\"uuid\":\"d74063dd-977e-4e64-a3fb-d0225a1ea3b1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" since this definition presents \",\"attrs\":{\"start\":393,\"end\":425}},{\"type\":\"text\",\"text\":\"dharma\",\"attrs\":{\"start\":425,\"end\":431},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":425,\"end\":431,\"uuid\":\"e0b465e6-82b8-40b8-b46d-c56114e776f5\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" as having various \",\"attrs\":{\"start\":431,\"end\":450}},{\"type\":\"text\",\"text\":\"lakṣaṇa\",\"attrs\":{\"start\":450,\"end\":457},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e6185c2c-6566-40d4-a854-a5c1ae649cf9\",\"uuid\":\"bfa969f4-7571-47f9-8e3a-08c0946c2fa0\",\"toh\":null,\"start\":450,\"end\":0}},{\"type\":\"italic\",\"attrs\":{\"start\":450,\"end\":457,\"uuid\":\"8f56db6e-3094-4de3-b88d-9956e729dd61\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\". As a consequence, I read this sentence as stating that the \",\"attrs\":{\"start\":457,\"end\":518}},{\"type\":\"text\",\"text\":\"ultimate\",\"attrs\":{\"start\":518,\"end\":526},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1ce42c0c-900f-47c2-9d40-98ccbafcb2bf\",\"uuid\":\"48d51df7-0c71-4ce3-b660-8b25946bdd09\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is that whose \",\"attrs\":{\"start\":526,\"end\":541}},{\"type\":\"text\",\"text\":\"defining characteristic\",\"attrs\":{\"start\":541,\"end\":564},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f4503be0-02d4-474f-8f1c-a69993648574\",\"uuid\":\"a87c4a6a-d3dd-456a-bc92-31dda9ed62fd\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is always \",\"attrs\":{\"start\":564,\"end\":575}},{\"type\":\"text\",\"text\":\"of a single nature\",\"attrs\":{\"start\":575,\"end\":593},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cbea69eb-013b-4e05-aff4-98b5c2b872ef\",\"uuid\":\"1fbb59ff-1112-4461-a5a2-323eec6b096f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in all phenomena that have diverse \",\"attrs\":{\"start\":593,\"end\":629}},{\"type\":\"text\",\"text\":\"defining characteristics\",\"attrs\":{\"start\":629,\"end\":653},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f4503be0-02d4-474f-8f1c-a69993648574\",\"uuid\":\"23b499d7-8912-4500-a915-ba872ea8f3d9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". See also \",\"attrs\":{\"start\":653,\"end\":664}},{\"type\":\"text\",\"text\":\"4.8\",\"attrs\":{\"start\":664,\"end\":667},\"marks\":[{\"type\":\"internalLink\",\"attrs\":{\"uuid\":\"45476b9c-f6fd-4bf1-8a4e-009c3535b63c\",\"href\":\"/entity/passage/2d038741-761e-41d0-973c-fb1c7927289c\",\"entity\":\"2d038741-761e-41d0-973c-fb1c7927289c\",\"type\":\"passage\",\"toh\":null,\"isSameWork\":true,\"subtype\":\"translation\"}}]},{\"type\":\"text\",\"text\":\", which supports this interpretation.\",\"attrs\":{\"start\":667,\"end\":704}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"00ecb8b2-2153-4f94-976d-c746efc4ee25\",\"sort\":13342,\"type\":\"endnotes\",\"label\":\"n.95\",\"alignments\":{},\"references\":[{\"content\":\"“Subhūti, it is because I teach that the ultimate is the referential object conducive to purification within the aggregates, as well as within the sense domains, dependent arising, the sustenances, the truths, the constituents, the applications of mindfulness, the self-restraints, the bases of supernatural powers, the faculties, the forces, the branches of awakening, and, Subhūti, the eightfold path. This referential object conducive to purification within the aggregates is of a single nature everywhere and its defining characteristic is not different from theirs. It is just the same from the sense domains up to the eightfold path: the referential object conducive to purification within these various referential objects is of a single nature everywhere and its defining characteristic is not different from theirs. Subhūti, through this approach, you should thus know that what is characterized as being of a single nature everywhere is the ultimate.\",\"label\":\"4.8\",\"sort\":3773,\"type\":\"translation\",\"uuid\":\"2d038741-761e-41d0-973c-fb1c7927289c\",\"workUuid\":\"da0adcd3-4abf-406a-8021-b656a348fab8\",\"xmlId\":\"UT22084-049-001-292\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":827,\"uuid\":\"00ecb8b2-2153-4f94-976d-c746efc4ee25\"},\"content\":[{\"type\":\"text\",\"text\":\"rnam par dag pa’i dmigs pa\",\"attrs\":{\"start\":0,\"end\":26},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":0,\"end\":26,\"uuid\":\"324eddba-ff29-4458-b831-2477df5001db\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"; *\",\"attrs\":{\"start\":26,\"end\":29}},{\"type\":\"text\",\"text\":\"viśuddhyālambana\",\"attrs\":{\"start\":29,\"end\":45},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":29,\"end\":45,\"uuid\":\"4d69da6c-0723-4e10-8cc3-5a61b9359995\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d84afd2b-0e37-47ca-b1a1-00c09c47e855\",\"uuid\":\"2395ef93-9eb3-4211-9434-071b956ce8ea\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Lamotte reads here \",\"attrs\":{\"start\":45,\"end\":66}},{\"type\":\"text\",\"text\":\"rnam par dag pa’i dmigs pa\",\"attrs\":{\"start\":66,\"end\":92},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":66,\"end\":92,\"uuid\":\"bf943328-671c-46d0-aed4-35b5936f1c51\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" with the meaning of \",\"attrs\":{\"start\":92,\"end\":113}},{\"type\":\"text\",\"text\":\"viśuddhālambana\",\"attrs\":{\"start\":113,\"end\":128},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":113,\"end\":128,\"uuid\":\"5440d432-55a0-4c64-a8cf-53340d16ee1d\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" (“objet pur”), but Schmithausen gives *\",\"attrs\":{\"start\":128,\"end\":168}},{\"type\":\"text\",\"text\":\"viśuddhyālambana\",\"attrs\":{\"start\":168,\"end\":184},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":168,\"end\":184,\"uuid\":\"2797df63-9e3e-47cf-b231-061f4964dc9d\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d84afd2b-0e37-47ca-b1a1-00c09c47e855\",\"uuid\":\"4b8eb8c8-4c38-4f06-bc01-8858d868d196\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" as the Sanskrit equivalent for the Tibetan (see Schmithausen 2014, p. 362, §306.5 and n. 1644). It is worth noting that this term is also found in chapter 7, where it is again equated with the \",\"attrs\":{\"start\":184,\"end\":378}},{\"type\":\"text\",\"text\":\"ultimate\",\"attrs\":{\"start\":378,\"end\":386},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1ce42c0c-900f-47c2-9d40-98ccbafcb2bf\",\"uuid\":\"805d2ef4-e3cb-463a-8d47-0511549a6ff6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":386,\"end\":388}},{\"type\":\"text\",\"text\":\"don dam pa\",\"attrs\":{\"start\":388,\"end\":398},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":388,\"end\":398,\"uuid\":\"7fa21d57-d3cf-40e9-8b22-11c7afb77251\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"). In this context, it is said that \",\"attrs\":{\"start\":398,\"end\":434}},{\"type\":\"text\",\"text\":\"paratantra\",\"attrs\":{\"start\":434,\"end\":444},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":434,\"end\":444,\"uuid\":\"d52e4fd9-f949-4a2a-8165-2d73b3849a19\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c475e47d-cad4-48bb-b82e-fc4f919a67c2\",\"uuid\":\"ee66bd6d-6ca5-460c-b0db-0524b627a717\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is not an \",\"attrs\":{\"start\":444,\"end\":455}},{\"type\":\"text\",\"text\":\"object conducive to purification\",\"attrs\":{\"start\":455,\"end\":487},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d84afd2b-0e37-47ca-b1a1-00c09c47e855\",\"uuid\":\"a25ba229-fea9-44c7-9c0c-0fb043f8844d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" whereas the \",\"attrs\":{\"start\":487,\"end\":500}},{\"type\":\"text\",\"text\":\"actual\",\"attrs\":{\"start\":500,\"end\":506},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bf3c7cca-3030-4d6b-a560-9a324c4f01ee\",\"uuid\":\"e89b4ac6-e214-4e28-97c4-e91f92ff44ff\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":506,\"end\":508}},{\"type\":\"text\",\"text\":\"pariniṣpanna\",\"attrs\":{\"start\":508,\"end\":520},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bf3c7cca-3030-4d6b-a560-9a324c4f01ee\",\"uuid\":\"82bd8e99-9c97-4103-be91-1c77c907fcf5\",\"toh\":null,\"start\":508,\"end\":0}},{\"type\":\"italic\",\"attrs\":{\"start\":508,\"end\":520,\"uuid\":\"14661a37-6cf6-4109-aebb-4583245a419b\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\") is. In this sense, one should make the distinction here between \",\"attrs\":{\"start\":520,\"end\":586}},{\"type\":\"text\",\"text\":\"vastu\",\"attrs\":{\"start\":586,\"end\":591},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cf9988ae-d23d-4a8e-a24a-2f5503ee7f00\",\"uuid\":\"e4e327b7-0240-410e-9db5-628c1f130c9a\",\"toh\":null,\"start\":586,\"end\":0}},{\"type\":\"italic\",\"attrs\":{\"start\":586,\"end\":591,\"uuid\":\"425619e3-e3f6-4260-a10a-4386d173cbe1\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" and \",\"attrs\":{\"start\":591,\"end\":596}},{\"type\":\"text\",\"text\":\"ālambana\",\"attrs\":{\"start\":596,\"end\":604},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":596,\"end\":604,\"uuid\":\"febbd751-f77d-491c-837d-78335608fc55\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"32d38a05-df64-4e0b-89c0-d67fbf88da5e\",\"uuid\":\"f5a20a52-3c7c-4fa7-8e1f-e5803714ecc6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". The \",\"attrs\":{\"start\":604,\"end\":610}},{\"type\":\"text\",\"text\":\"ultimate\",\"attrs\":{\"start\":610,\"end\":618},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1ce42c0c-900f-47c2-9d40-98ccbafcb2bf\",\"uuid\":\"fc9f1663-e39c-4e32-b374-f85f9bc5590c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is conceived here as the \",\"attrs\":{\"start\":618,\"end\":644}},{\"type\":\"text\",\"text\":\"referential object\",\"attrs\":{\"start\":644,\"end\":662},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"32d38a05-df64-4e0b-89c0-d67fbf88da5e\",\"uuid\":\"57444dfe-f349-496e-bbf9-15b4bf567e31\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", or support \",\"attrs\":{\"start\":662,\"end\":675}},{\"type\":\"text\",\"text\":\"object\",\"attrs\":{\"start\":675,\"end\":681},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cf9988ae-d23d-4a8e-a24a-2f5503ee7f00\",\"uuid\":\"9bcaa3d2-598e-4e9b-9a58-314033123c43\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", of a \",\"attrs\":{\"start\":681,\"end\":688}},{\"type\":\"text\",\"text\":\"purification\",\"attrs\":{\"start\":688,\"end\":700},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d9bbbe9e-7677-4d94-85cb-1af68799c360\",\"uuid\":\"4e2a7499-f978-4e38-b996-abbb71c9f33a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" that leads to \",\"attrs\":{\"start\":700,\"end\":715}},{\"type\":\"text\",\"text\":\"awakening\",\"attrs\":{\"start\":715,\"end\":724},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d0fda944-71f7-4a27-a806-7debbf320eea\",\"uuid\":\"befffe71-650d-49d8-b445-151deda18b2c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". The usage of \",\"attrs\":{\"start\":724,\"end\":739}},{\"type\":\"text\",\"text\":\"ālambana\",\"attrs\":{\"start\":739,\"end\":747},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"32d38a05-df64-4e0b-89c0-d67fbf88da5e\",\"uuid\":\"be5310d8-78eb-48d0-a049-641894988648\",\"toh\":null,\"start\":739,\"end\":0}},{\"type\":\"italic\",\"attrs\":{\"start\":739,\"end\":747,\"uuid\":\"137a21c2-1482-4018-b842-e90bc5d4ba6a\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" in reference to the \",\"attrs\":{\"start\":747,\"end\":768}},{\"type\":\"text\",\"text\":\"ultimate\",\"attrs\":{\"start\":768,\"end\":776},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1ce42c0c-900f-47c2-9d40-98ccbafcb2bf\",\"uuid\":\"b1e2e26b-db68-47b2-a1d8-d1f7070c291c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" clearly refers to practice in the present chapter.\",\"attrs\":{\"start\":776,\"end\":827}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"8836ba95-b69f-4f55-8c1b-59f8bf962ee0\",\"sort\":13383,\"type\":\"endnotes\",\"label\":\"n.96\",\"alignments\":{},\"references\":[{\"content\":\"“Subhūti, it is because I teach that the ultimate is the referential object conducive to purification within the aggregates, as well as within the sense domains, dependent arising, the sustenances, the truths, the constituents, the applications of mindfulness, the self-restraints, the bases of supernatural powers, the faculties, the forces, the branches of awakening, and, Subhūti, the eightfold path. This referential object conducive to purification within the aggregates is of a single nature everywhere and its defining characteristic is not different from theirs. It is just the same from the sense domains up to the eightfold path: the referential object conducive to purification within these various referential objects is of a single nature everywhere and its defining characteristic is not different from theirs. Subhūti, through this approach, you should thus know that what is characterized as being of a single nature everywhere is the ultimate.\",\"label\":\"4.8\",\"sort\":3773,\"type\":\"translation\",\"uuid\":\"2d038741-761e-41d0-973c-fb1c7927289c\",\"workUuid\":\"da0adcd3-4abf-406a-8021-b656a348fab8\",\"xmlId\":\"UT22084-049-001-292\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":328,\"uuid\":\"8836ba95-b69f-4f55-8c1b-59f8bf962ee0\"},\"content\":[{\"type\":\"text\",\"text\":\"Compare D, folio 11.a: \",\"attrs\":{\"start\":0,\"end\":23}},{\"type\":\"text\",\"text\":\"rab ’byor rnam grangs des na khyod kyis ’di ltar thams cad du ro gcig pa’i mtshan nyid gang yin pa de ni don dam pa yin par rig par bya’o\",\"attrs\":{\"start\":23,\"end\":160},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":23,\"end\":160,\"uuid\":\"25605d87-9561-46d7-98a0-c6ca08928673\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" with D, folio 12.a: \",\"attrs\":{\"start\":160,\"end\":181}},{\"type\":\"text\",\"text\":\"rab ’byor de bzhin du don dam pa yang mtshan nyid tha dad pa’i chos rnams la thams cad du ro gcig pa’i mtshan nyid yin par blta bar bya’o\",\"attrs\":{\"start\":181,\"end\":318},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":181,\"end\":318,\"uuid\":\"beba9121-a48c-4c49-88e5-54e563e8f945\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" (passim).\",\"attrs\":{\"start\":318,\"end\":328}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"5a0b70be-0fb9-41f7-9a83-7a6c07bed23a\",\"sort\":13389,\"type\":\"endnotes\",\"label\":\"n.97\",\"alignments\":{},\"references\":[{\"content\":\"“Moreover, Subhūti, once renunciants who practice yoga have realized in reference to a single aggregate the selflessness of phenomena, which is the ultimate reality, they do not look for this ultimate reality, this selflessness, individually within the other aggregates or in the sense domains, dependent arising, the sustenances, the truths, the constituents, the applications of mindfulness, the self-restraints, the bases of supernatural powers, the faculties, the forces, the branches of awakening, and the eightfold path. Instead, they rely upon the nondual gnosis that is in accordance with true reality. Through this alone, they infallibly ascertain and realize the ultimate, characterized as being of a single nature everywhere. Subhūti, through this approach, you should thus know that what is characterized as being of a single nature everywhere is the ultimate.\",\"label\":\"4.9\",\"sort\":3833,\"type\":\"translation\",\"uuid\":\"fa51d115-712a-4f60-ab84-7463302c6e58\",\"workUuid\":\"da0adcd3-4abf-406a-8021-b656a348fab8\",\"xmlId\":\"UT22084-049-001-295\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":420,\"uuid\":\"5a0b70be-0fb9-41f7-9a83-7a6c07bed23a\"},\"content\":[{\"type\":\"text\",\"text\":\"de bzhin nyid\",\"attrs\":{\"start\":0,\"end\":13},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":0,\"end\":13,\"uuid\":\"4c2f3ec8-3618-4880-8093-3638f92f41c4\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"; \",\"attrs\":{\"start\":13,\"end\":15}},{\"type\":\"text\",\"text\":\"tathatā\",\"attrs\":{\"start\":15,\"end\":22},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":15,\"end\":22,\"uuid\":\"622e1935-9749-474f-91e3-fca79a4feedf\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\". I translate \",\"attrs\":{\"start\":22,\"end\":36}},{\"type\":\"text\",\"text\":\"tathatā\",\"attrs\":{\"start\":36,\"end\":43},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":36,\"end\":43,\"uuid\":\"e6fddf8c-d8eb-45b2-aa7c-db17cdf00ecc\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" with “\",\"attrs\":{\"start\":43,\"end\":50}},{\"type\":\"text\",\"text\":\"true reality\",\"attrs\":{\"start\":50,\"end\":62},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"76ba6263-e6ce-4069-b4c8-114361f6c5d0\",\"uuid\":\"2f69c7fe-31bf-4d86-8e0a-840350a1a6de\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"” (in the sense of the true state or \",\"attrs\":{\"start\":62,\"end\":99}},{\"type\":\"text\",\"text\":\"nature of things\",\"attrs\":{\"start\":99,\"end\":115},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b620497-2ccc-4aa5-b0d4-b22530a83cd0\",\"uuid\":\"8340de45-2ccb-4ade-a91a-a722798b0a48\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\") instead of the more usual “suchness” or “thusness.” However, when \",\"attrs\":{\"start\":115,\"end\":183}},{\"type\":\"text\",\"text\":\"de bzhin nyid\",\"attrs\":{\"start\":183,\"end\":196},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":183,\"end\":196,\"uuid\":\"25a3e154-3571-49e1-a73f-507d873b549b\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" is qualified by an adjective such as \",\"attrs\":{\"start\":196,\"end\":234}},{\"type\":\"text\",\"text\":\"don dam pa\",\"attrs\":{\"start\":234,\"end\":244},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":234,\"end\":244,\"uuid\":\"8b603855-3036-4421-94bd-8d9cb765382d\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", I simply translate it with “reality” to improve readability. See Schmithausen 2014, p. 356, §303.1 (passim), in which \",\"attrs\":{\"start\":244,\"end\":364}},{\"type\":\"text\",\"text\":\"tathatā\",\"attrs\":{\"start\":364,\"end\":371},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":364,\"end\":371,\"uuid\":\"ff574c2d-cc91-4766-9d31-94a0c1d449a3\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" is translated with “\",\"attrs\":{\"start\":371,\"end\":392}},{\"type\":\"text\",\"text\":\"True Reality\",\"attrs\":{\"start\":392,\"end\":404},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"76ba6263-e6ce-4069-b4c8-114361f6c5d0\",\"uuid\":\"7d263423-65c1-4d66-8637-758a3bceab98\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"” or “Suchness.”\",\"attrs\":{\"start\":404,\"end\":420}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"aa4ad6c7-642c-4692-8b7d-cffc461a84cb\",\"sort\":13408,\"type\":\"endnotes\",\"label\":\"n.98\",\"alignments\":{},\"references\":[{\"content\":\"“Moreover, Subhūti, once renunciants who practice yoga have realized in reference to a single aggregate the selflessness of phenomena, which is the ultimate reality, they do not look for this ultimate reality, this selflessness, individually within the other aggregates or in the sense domains, dependent arising, the sustenances, the truths, the constituents, the applications of mindfulness, the self-restraints, the bases of supernatural powers, the faculties, the forces, the branches of awakening, and the eightfold path. Instead, they rely upon the nondual gnosis that is in accordance with true reality. Through this alone, they infallibly ascertain and realize the ultimate, characterized as being of a single nature everywhere. Subhūti, through this approach, you should thus know that what is characterized as being of a single nature everywhere is the ultimate.\",\"label\":\"4.9\",\"sort\":3833,\"type\":\"translation\",\"uuid\":\"fa51d115-712a-4f60-ab84-7463302c6e58\",\"workUuid\":\"da0adcd3-4abf-406a-8021-b656a348fab8\",\"xmlId\":\"UT22084-049-001-295\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":84,\"uuid\":\"aa4ad6c7-642c-4692-8b7d-cffc461a84cb\"},\"content\":[{\"type\":\"text\",\"text\":\"D reads \",\"attrs\":{\"start\":0,\"end\":8}},{\"type\":\"text\",\"text\":\"gnyis med pa’i shes pa\",\"attrs\":{\"start\":8,\"end\":30},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":8,\"end\":30,\"uuid\":\"26d7403d-8b5f-44b3-8ece-1105b1a83084\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", while F, folio 16.b reads \",\"attrs\":{\"start\":30,\"end\":58}},{\"type\":\"text\",\"text\":\"gnyis su med pa’i ye shes\",\"attrs\":{\"start\":58,\"end\":83},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":58,\"end\":83,\"uuid\":\"a2eb3259-d795-49c7-95bd-4dfca95ad2a6\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":83,\"end\":84}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"e2056c47-00b9-4622-a4b1-8e23c290c681\",\"sort\":13414,\"type\":\"endnotes\",\"label\":\"n.99\",\"alignments\":{},\"references\":[{\"content\":\"“Moreover, Subhūti, once renunciants who practice yoga have realized in reference to a single aggregate the selflessness of phenomena, which is the ultimate reality, they do not look for this ultimate reality, this selflessness, individually within the other aggregates or in the sense domains, dependent arising, the sustenances, the truths, the constituents, the applications of mindfulness, the self-restraints, the bases of supernatural powers, the faculties, the forces, the branches of awakening, and the eightfold path. Instead, they rely upon the nondual gnosis that is in accordance with true reality. Through this alone, they infallibly ascertain and realize the ultimate, characterized as being of a single nature everywhere. Subhūti, through this approach, you should thus know that what is characterized as being of a single nature everywhere is the ultimate.\",\"label\":\"4.9\",\"sort\":3833,\"type\":\"translation\",\"uuid\":\"fa51d115-712a-4f60-ab84-7463302c6e58\",\"workUuid\":\"da0adcd3-4abf-406a-8021-b656a348fab8\",\"xmlId\":\"UT22084-049-001-295\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":135,\"uuid\":\"e2056c47-00b9-4622-a4b1-8e23c290c681\"},\"content\":[{\"type\":\"text\",\"text\":\"kho na\",\"attrs\":{\"start\":0,\"end\":6},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":0,\"end\":6,\"uuid\":\"1b5b71ee-4023-4756-9b79-4741a58ad068\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"; \",\"attrs\":{\"start\":6,\"end\":8}},{\"type\":\"text\",\"text\":\"eva\",\"attrs\":{\"start\":8,\"end\":11},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":8,\"end\":11,\"uuid\":\"8e9fed21-8163-459d-bffb-7bd13a39d721\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\". For a comparison between Buescher’s and Schmithausen’s translations of this sentence, see Schmithausen 2014, p. 380, §324.\",\"attrs\":{\"start\":11,\"end\":135}}]}]}],\"glossary\":[{\"uuid\":\"3337283c-de00-4fc7-a620-01a3880e630c\",\"authority\":\"1c017260-18a6-4001-a4df-0b86adaae1a9\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe five faculties are those of (1) \u003cspan data-glossary-id=\\\"UT22084-049-001-1458\\\"\u003efaith\u003c/span\u003e, (2) \u003cspan data-glossary-id=\\\"UT22084-049-001-1682\\\"\u003evigor\u003c/span\u003e, (3) \u003cspan data-glossary-id=\\\"UT22084-049-001-1544\\\"\u003emindfulness\u003c/span\u003e, (4) \u003cspan data-glossary-id=\\\"UT22084-049-001-1361\\\"\u003econcentration\u003c/span\u003e (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003esamādhi\u003c/em\u003e), and (5) \u003cspan data-glossary-id=\\\"UT22084-049-001-1689\\\"\u003ewisdom\u003c/span\u003e (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eprajñā\u003c/em\u003e). These are similar to the \u003cspan data-glossary-id=\\\"UT22084-049-001-1463\\\"\u003efive forces\u003c/span\u003e but in a lesser \u003cspan data-glossary-id=\\\"UT22084-049-001-1624\\\"\u003estage\u003c/span\u003e of development. \u003c/p\u003e\",\"names\":{\"english\":\"[five] faculties, five faculties\",\"tibetan\":\"དབང་པོ་ལྔ།\",\"sanskrit\":\"pañcendriyāṇi\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dbang po lnga\"}},{\"uuid\":\"0424c860-5400-4461-987d-8901b6b7101a\",\"authority\":\"235580a4-d7fa-46de-9f28-040432b1aa02\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe \u003cspan\u003efour kinds of sustenance\u003c/span\u003e are the sustenance of material ingestion, the sustenance of contact, the sustenance of will, and the sustenance of consciousness.\u003c/p\u003e\",\"names\":{\"english\":\"[four kinds] of sustenance, four kinds of sustenance\",\"tibetan\":\"ཟས་བཞི།\",\"sanskrit\":\"catvārāhārāḥ\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"zas bzhi\"}},{\"uuid\":\"e418bdfb-b2bc-43d1-83f3-c08cbfd4316c\",\"authority\":\"254ee2ba-8fb3-47a6-9d1e-b85af4889597\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee “\u003cspan data-glossary-id=\\\"UT22084-049-001-1474\\\"\u003efour noble truths\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"[noble] truth, noble truth\",\"tibetan\":\"འཕགས་པའི་བདེན་པ།\",\"sanskrit\":\"ārya­satya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’phags pa’i bden pa\"}},{\"uuid\":\"50842e77-6495-4f22-bb13-2d5616baf1ee\",\"authority\":\"76435a0f-82d9-4541-8232-f2c81b7adc45\",\"definition\":\"\",\"names\":{\"english\":\"abiding in phenomena, constancy of phenomena\",\"tibetan\":\"ཆོས་གནས་པ་ཉིད།, ཆོས་གནས་པ་ཉིད།\",\"sanskrit\":\"dharmasthititā, dharmasthititā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chos gnas pa nyid, chos gnas pa nyid\"}},{\"uuid\":\"e6a0be6e-94b5-468e-b115-1dfe67998b9c\",\"authority\":\"76435a0f-82d9-4541-8232-f2c81b7adc45\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eMahāvyutpatti 1719. \u003c/p\u003e\",\"names\":{\"english\":\"abiding in phenomena, constancy of phenomena\",\"tibetan\":\"ཆོས་གནས་པ་ཉིད།, ཆོས་གནས་པ་ཉིད།\",\"sanskrit\":\"dharmasthititā, dharmasthititā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chos gnas pa nyid, chos gnas pa nyid\"}},{\"uuid\":\"93577576-cd69-4df1-bfd8-583a7b087cf8\",\"authority\":\"1b579d82-b45b-4056-8d73-1cd34a70a1b6\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe Sanskrit literally means “attainment,” and is used to refer specifically to meditative attainment and to particular meditative states. The Tibetan translators interpreted it as \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003esama-āpatti\u003c/em\u003e, which suggests the idea of “equal” or “level”; however, they also parsed it as \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003esam-āpatti\u003c/em\u003e, in which case it would have the sense of “concentration” or “absorption,” much like \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003esamādhi\u003c/em\u003e, but with the added sense of “attainment.”\u003c/p\u003e\",\"names\":{\"english\":\"absorption\",\"tibetan\":\"སྙོམས་པར་འཇུག་པ།\",\"sanskrit\":\"samāpatti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"snyoms par ’jug pa\"}},{\"uuid\":\"71f76501-f55e-44e7-97e4-42ad298ec793\",\"authority\":\"cacb6b14-dcc1-4088-b625-9093c275b765\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee Mvyut 1500 and 1988.\u003c/p\u003e\",\"names\":{\"english\":\"absorption in the state of cessation\",\"tibetan\":\"འགོག་པ་ལ་སྙོམས་པར་ཞུགས་པ།\",\"sanskrit\":\"nirodhasamāpatti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’gog pa la snyoms par zhugs pa\"}},{\"uuid\":\"b7a96b61-49dc-47df-b835-9b316e7d9e37\",\"authority\":\"f80007c8-dd3e-488a-bb54-0ad7e8851f8b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003ecf. Sanskrit text in Matsuda 2013, p. 940 \u003cem class=\\\"distinct\\\"\u003ead\u003c/em\u003e Lamotte VIII.40.\u003c/p\u003e\",\"names\":{\"english\":\"accept, accepted\",\"tibetan\":\"ལེན།\",\"sanskrit\":\"ādadante\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"len\"}},{\"uuid\":\"a64d208d-5bfa-47f5-977a-f3965a021305\",\"authority\":\"19e108c4-2f10-40ed-9649-5736f26a0424\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe bodhisattvas’ realization that all phenomena are unproduced and empty. It sustains them on the difficult path of benefiting all beings so that they do not succumb to the goal of personal liberation. Different sources link this realization to the first or eighth bodhisattva level (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003ebhūmi\u003c/em\u003e).\u003c/p\u003e\",\"names\":{\"english\":\"acceptance that phenomena are non-arisen\",\"tibetan\":\"མི་སྐྱེ་བའི་ཆོས་ལ་བཟོད་པ།\",\"sanskrit\":\"anutpattidharmakṣānti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mi skye ba’i chos la bzod pa\"}},{\"uuid\":\"cea59c3e-f95c-4c07-b5fd-9d2a8585bc9f\",\"authority\":\"41bfae21-d30a-48ce-943b-e40feb2ba57b\",\"definition\":\"\",\"names\":{\"english\":\"accomplishment of the goal\",\"tibetan\":\"དགོས་པ་ཡོངས་སུ་གྲུབ་པ།\",\"sanskrit\":\"kṛtyānuṣṭhāna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dgos pa yongs su grub pa\"}},{\"uuid\":\"0337bf7a-bb0a-4e26-bde7-6d34219dc604\",\"authority\":\"8ee553ca-45bc-45f6-83c9-6ac541a733a7\",\"definition\":\"\",\"names\":{\"english\":\"accumulated\",\"tibetan\":\"ཀུན་ཏུ་བསགས་པ།\",\"sanskrit\":\"ācita\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kun tu bsags pa\"}},{\"uuid\":\"e0126492-66c1-4460-a854-51aba7ad431b\",\"authority\":\"c58300d7-f51c-46a1-81d2-9f26851105af\",\"definition\":\"\",\"names\":{\"english\":\"accused\",\"tibetan\":\"ཤག་ཀྱིས་འཆགས།\",\"sanskrit\":\"codanā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shag kyis ’chags\"}},{\"uuid\":\"f423f038-1637-4e21-908e-a2e2fb698bf2\",\"authority\":\"316e37c5-8a3e-4a01-8507-5c138decad1d\",\"definition\":\"\",\"names\":{\"english\":\"activity of conditioning mental factors\",\"tibetan\":\"འདུ་བྱེད་ཀྱི་འཇུག་པ།\",\"sanskrit\":\"saṃskārapravṛtti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’du byed kyi ’jug pa\"}},{\"uuid\":\"9824d9e7-fe91-4bd2-b6a2-b0f39df50f51\",\"authority\":\"9b7b28d5-0e4f-4ac8-a8fe-f0a98dcaa009\",\"definition\":\"\",\"names\":{\"english\":\"actual defining characteristic\",\"tibetan\":\"ཡོངས་སུ་གྲུབ་པའི་མཚན་ཉིད།\",\"sanskrit\":\"pari­niṣpanna­lakṣaṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yongs su grub pa’i mtshan nyid\"}},{\"uuid\":\"15e5b656-11a1-4b39-95dd-97194159b293\",\"authority\":\"de056087-0100-44d5-83c8-3b0a2af6913b\",\"definition\":\"\",\"names\":{\"english\":\"actual essence\",\"tibetan\":\"ཡོངས་སུ་གྲུབ་པའི་ངོ་བོ་ཉིད།, ཡོངས་སུ་གྲུབ་པའི་རང་བཞིན།\",\"sanskrit\":\"pariniṣpannasvabhāva\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yongs su grub pa’i ngo bo nyid, yongs su grub pa’i rang bzhin\"}},{\"uuid\":\"bf3c7cca-3030-4d6b-a560-9a324c4f01ee\",\"authority\":\"d8bf518c-9bd9-4147-a908-fbe36093129b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee \u003ca href=\\\"end-notes.xhtml#UT22084-049-001-347\\\" data-pointer-type=\\\"id\\\"\u003en.125\u003c/a\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"actual, pariniṣpanna\",\"tibetan\":\"ཡོངས་སུ་གྲུབ་པ།\",\"sanskrit\":\"pariniṣpanna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yongs su grub pa\"}},{\"uuid\":\"fc0adedd-0475-41e8-8e95-9e11ceafcf51\",\"authority\":\"5d239448-b86a-40de-9241-d35fe00fc3bb\",\"definition\":\"\",\"names\":{\"english\":\"actualization\",\"tibetan\":\"མངོན་དུ་བྱ་བ།\",\"sanskrit\":\"sākṣātkāra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mngon du bya ba\"}},{\"uuid\":\"cf6a6985-eefe-49a3-855c-e43e7222aa79\",\"authority\":\"e185d423-589f-447b-bf4a-abe2cfcb6582\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eMahāvyutpatti 1290. \u003c/p\u003e\",\"names\":{\"english\":\"actually refer to\",\"tibetan\":\"མངོན་པར་རྗོད་པས་རྗོད་པ།\",\"sanskrit\":\"abhivadamānā, abhivadanti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mngon par rjod pas rjod pa\"}},{\"uuid\":\"096578ea-4bc4-49a3-b39c-bb89d277b3ef\",\"authority\":\"d6e8afc8-2339-4873-8e7c-caab0bd24d8c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA term meaning defilement, impurity, and pollution, broadly referring to cognitive and emotional factors that disturb and obscure the mind. As the self-perpetuating process of affliction in the minds of beings, it is a synonym for \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003esaṃsāra\u003c/em\u003e. It is often paired with its opposite, \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003evyavadāna\u003c/em\u003e, meaning “purification.”\u003c/p\u003e\",\"names\":{\"english\":\"affliction\",\"tibetan\":\"ཀུན་ནས་ཉོན་མོངས་པ།\",\"sanskrit\":\"saṃkleśa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kun nas nyon mongs pa\"}},{\"uuid\":\"8374849e-bf9a-4380-bfff-576677d94ca0\",\"authority\":\"befb80a6-3a70-411f-84f4-2016cc3a88fa\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe five skandhas (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003epañcaskandha\u003c/em\u003e) are: forms (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003erūpa\u003c/em\u003e), sensation (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003evedanā\u003c/em\u003e), \u003cspan data-glossary-id=\\\"UT22084-049-001-1362\\\"\u003econception\u003c/span\u003e (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-049-001-1362\\\"\u003esaṃjñā\u003c/span\u003e\u003c/em\u003e), formations (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003esaṃskāra\u003c/em\u003e), consciousness (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-049-001-1353\\\"\u003evijñāna\u003c/span\u003e\u003c/em\u003e).\u003c/p\u003e\",\"names\":{\"english\":\"aggregate\",\"tibetan\":\"ཕུང་ཕོ།\",\"sanskrit\":\"skandha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"phung pho\"}},{\"uuid\":\"0074f3b5-760e-4bb9-8abf-a0e643afa24f\",\"authority\":\"05f4b0cd-95cb-40ac-9db7-cec0611dfe61\",\"definition\":\"\",\"names\":{\"english\":\"analysis, examine, examined, examining\",\"tibetan\":\"བརྟག, བརྟག་པ།\",\"sanskrit\":\"parīkṣā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"brtag, brtag pa\"}},{\"uuid\":\"6a3e4d93-90b0-491e-b354-c6a7d952e5b4\",\"authority\":\"05f4b0cd-95cb-40ac-9db7-cec0611dfe61\",\"definition\":\"\",\"names\":{\"english\":\"analysis, examine, examined, examining\",\"tibetan\":\"བརྟག, བརྟག་པ།\",\"sanskrit\":\"parīkṣā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"brtag, brtag pa\"}},{\"uuid\":\"52a43376-0e37-4735-92e6-257998d83884\",\"authority\":\"1f8c95fa-1054-407a-8035-b954bbe3ef1d\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee Har Dayal 2004, p. 260ff.\u003c/p\u003e\",\"names\":{\"english\":\"analytical knowledge\",\"tibetan\":\"སོ་སོར་ཡང་དག་པར་རིག་པ།\",\"sanskrit\":\"pratisaṃvid\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"so sor yang dag par rig pa\"}},{\"uuid\":\"15dd2d8f-6f51-491a-965d-508b0ff395f0\",\"authority\":\"d53de739-4f3c-45bc-81ca-b9851a45651a\",\"definition\":\"\",\"names\":{\"english\":\"analytical knowledge of designations\",\"tibetan\":\"ཆོས་སོ་སོར་ཡང་དག་པར་རིག་པ།\",\"sanskrit\":\"dharma­prati­saṃvid\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chos so sor yang dag par rig pa\"}},{\"uuid\":\"e29ef49f-aee5-4a46-a202-dc8f256325ba\",\"authority\":\"483d65b9-d43a-4bf0-8f88-143826e65ea5\",\"definition\":\"\",\"names\":{\"english\":\"analytical knowledge of the objects of designation\",\"tibetan\":\"དོན་སོ་སོར་ཡང་དག་པར་རིག་པ།\",\"sanskrit\":\"ārthapratisaṃvid\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"don so sor yang dag par rig pa\"}},{\"uuid\":\"a0849c8e-a301-4513-9fb5-6d97229d1a4c\",\"authority\":\"bcd1e3d5-442d-4804-b2b7-c99c7a67c70e\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe term \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003eso sor rtog pa\u003c/em\u003e has two meanings in our text: (1) \u003cspan class=\\\"ignore\\\"\u003eanalysis\u003c/span\u003e (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003epratyavekṣa\u003c/em\u003e) and (2) \u003cspan class=\\\"ignore\\\"\u003ecomprehension\u003c/span\u003e, realization, \u003cspan class=\\\"ignore\\\"\u003eawakening\u003c/span\u003e (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003epratibodha\u003c/em\u003e).\u003c/p\u003e\",\"names\":{\"english\":\"analyze, analyzing, pratyavekṣaṇa\",\"tibetan\":\"སོ་སོར་རྟོག་པ།, སོ་སོར་རྟོག་པར་བྱེད།\",\"sanskrit\":\"pratyavekṣa, pratyavekṣaṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"so sor rtog pa, so sor rtog par byed\"}},{\"uuid\":\"838f52c4-9050-4c3a-9448-d2551bd51a3d\",\"authority\":\"82d703d6-93a8-42dd-9df8-449b6ed2b795\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eTechnical term in Buddhist logic.\u003c/p\u003e\",\"names\":{\"english\":\"anumāṇa\",\"tibetan\":\"\",\"sanskrit\":\"anumāṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"\"}},{\"uuid\":\"e6e4b2ce-848f-42f6-adcd-559066db3843\",\"authority\":\"612d48d3-ccff-498a-a87c-fd12d0750c7f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003elack of [any] actuality, no actuality, deprived of any actuality, devoid of any actuality\u003c/p\u003e\",\"names\":{\"english\":\"apariniṣpanna, unreal\",\"tibetan\":\"ཡོངས་སུ་མ་གྲུབ་པ།\",\"sanskrit\":\"apariniṣpanna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yongs su ma grub pa\"}},{\"uuid\":\"c55da13f-bceb-4490-9ec0-b80198240718\",\"authority\":\"c3faef3a-7a19-424a-9804-afdf9d74a131\",\"definition\":\"\",\"names\":{\"english\":\"appearance\",\"tibetan\":\"སྣང་བ།\",\"sanskrit\":\"pratibhāsa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"snang ba\"}},{\"uuid\":\"00274071-9887-4dfc-8f82-15ee3940b0ec\",\"authority\":\"ae1dc199-7873-4f6b-a146-9ab46d4af143\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the three \u003cspan data-glossary-id=\\\"UT22084-049-001-1481\\\"\u003egates of liberation\u003c/span\u003e along with \u003cspan data-glossary-id=\\\"UT22084-049-001-1435\\\"\u003eemptiness\u003c/span\u003e and \u003cspan data-glossary-id=\\\"UT22084-049-001-1690\\\"\u003ewishlessness\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"appearancelessness\",\"tibetan\":\"མཚན་མ་མེད་པ།\",\"sanskrit\":\"animitta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mtshan ma med pa\"}},{\"uuid\":\"7bf0f602-2608-4888-b126-e4ebc8621f83\",\"authority\":\"1af81df3-440c-4c37-897c-30aeb9faf235\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe four foundations of \u003cspan data-glossary-id=\\\"UT22084-049-001-1544\\\"\u003emindfulness\u003c/span\u003e refers to the application of \u003cspan data-glossary-id=\\\"UT22084-049-001-1544\\\"\u003emindfulness\u003c/span\u003e to: the body, sensations, the \u003cspan data-glossary-id=\\\"UT22084-049-001-1542\\\"\u003emind\u003c/span\u003e, phenomena.\u003c/p\u003e\",\"names\":{\"english\":\"applications of mindfulness\",\"tibetan\":\"དྲན་པ་ཉེ་བར་གཞག་པ།\",\"sanskrit\":\"smṛtyupasthāna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dran pa nye bar gzhag pa\"}},{\"uuid\":\"0b062c2c-29c2-48dc-932b-48db574cedee\",\"authority\":\"5a8d076d-ae70-432b-90f7-0dad9dab8266\",\"definition\":\"\",\"names\":{\"english\":\"appropriating cognition, ādānavijñāna\",\"tibetan\":\"ལེན་པའི་རྣམ་པར་ཤེས་པ།\",\"sanskrit\":\"ādānavijñāna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"len pa’i rnam par shes pa\"}},{\"uuid\":\"6091439d-40c9-41d8-bed0-be7851248498\",\"authority\":\"44f829f0-791e-4b5e-b38b-5d7f9a85f4c7\",\"definition\":\"\",\"names\":{\"english\":\"argumentative disputation\",\"tibetan\":\"རྩོད་པ།\",\"sanskrit\":\"vivāda\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rtsod pa\"}},{\"uuid\":\"6fe5e02d-827a-47a7-b414-89aaf5d45cc8\",\"authority\":\"de7c778e-e832-4bae-afcf-477ae2b9da10\",\"definition\":\"\",\"names\":{\"english\":\"aspiration\",\"tibetan\":\"སྨོན་ལམ།\",\"sanskrit\":\"praṇidhāna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"smon lam\"}},{\"uuid\":\"976b88ab-44b3-4582-96fa-ac60354c632a\",\"authority\":\"c899da45-ebc2-4d83-9730-bfb49a68c113\",\"definition\":\"\",\"names\":{\"english\":\"aspiration\",\"tibetan\":\"མོས་པ།\",\"sanskrit\":\"praṇidhāna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mos pa\"}},{\"uuid\":\"c5540d92-f1c5-48ff-9dd7-a4c9a3d8128c\",\"authority\":\"863cb2f9-5d69-42d1-9e8e-c5f95b21f2ec\",\"definition\":\"\",\"names\":{\"english\":\"assumption, erroneous conception, wrongly conceive\",\"tibetan\":\"མངོན་པར་ཞེན་པ།, མངོན་པར་ཞེན་པ།, མངོན་པར་ཞེན།\",\"sanskrit\":\"abhiniveśa, abhiniviśanti, abhiniviśanti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mngon par zhen, mngon par zhen pa, mngon par zhen pa\"}},{\"uuid\":\"260d711e-0ced-438d-a03b-7923b4dc4a01\",\"authority\":\"863cb2f9-5d69-42d1-9e8e-c5f95b21f2ec\",\"definition\":\"\",\"names\":{\"english\":\"assumption, erroneous conception, wrongly conceive\",\"tibetan\":\"མངོན་པར་ཞེན་པ།, མངོན་པར་ཞེན་པ།, མངོན་པར་ཞེན།\",\"sanskrit\":\"abhiniveśa, abhiniviśanti, abhiniviśanti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mngon par zhen, mngon par zhen pa, mngon par zhen pa\"}},{\"uuid\":\"a3e3ca3d-5d92-43b5-bf7a-d02257107104\",\"authority\":\"863cb2f9-5d69-42d1-9e8e-c5f95b21f2ec\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee Edgerton 1953, p. 53. The term has various shades of meaning such as “to be attached to,” “to adhere to,” “to \u003cspan class=\\\"ignore\\\"\u003ewrongly conceive\u003c/span\u003e,” “to hold fast to,” and “to believe in” with a negative connotation.\u003c/p\u003e\",\"names\":{\"english\":\"assumption, erroneous conception, wrongly conceive\",\"tibetan\":\"མངོན་པར་ཞེན་པ།, མངོན་པར་ཞེན་པ།, མངོན་པར་ཞེན།\",\"sanskrit\":\"abhiniveśa, abhiniviśanti, abhiniviśanti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mngon par zhen, mngon par zhen pa, mngon par zhen pa\"}},{\"uuid\":\"65c99d4b-8378-4dbe-b737-8c27c1149218\",\"authority\":\"02a3306b-becf-430d-8419-8616bebbf0c4\",\"definition\":\"\",\"names\":{\"english\":\"attaining the powers\",\"tibetan\":\"སྟོབས་བསྐྱེད་པ།\",\"sanskrit\":\"balādhāna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"stobs bskyed pa\"}},{\"uuid\":\"960917a1-b12e-4b4e-a342-001a818bf3e9\",\"authority\":\"fe8cc4f7-f95c-4eed-aadb-37833b49ad64\",\"definition\":\"\",\"names\":{\"english\":\"attend, attending\",\"tibetan\":\"རྗེས་སུ་དཔྱོད་པ།\",\"sanskrit\":\"anucaranti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rjes su dpyod pa\"}},{\"uuid\":\"f40cf7aa-6754-416b-9014-59d521983239\",\"authority\":\"7c59082c-172a-48e4-9388-93c61342d7fe\",\"definition\":\"\",\"names\":{\"english\":\"authoritative scripture\",\"tibetan\":\"ཡིད་ཆེས་པའི་ལུང་གི་ཚད་མ།\",\"sanskrit\":\"āptāgamapramāṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yid ches pa’i lung gi tshad ma\"}},{\"uuid\":\"17cba7f1-2de7-40eb-914b-e914b0d3cc50\",\"authority\":\"0ecba1e9-f6bc-4e30-823b-34a3dc139974\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the “eight close sons of the Buddha,” he is also known as the bodhisattva who embodies compassion. In certain tantras, he is also the lord of the three families, where he embodies the compassion of the buddhas. In Tibet, he attained great significance as a special protector of Tibet, and in China, in female form, as Guanyin, the most important bodhisattva in all of East Asia.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003eAlso mentioned in this text as \u003cspan class=\\\"ignore\\\"\u003eĀryāva­loki­teśvara\u003c/span\u003e, the noble \u003cspan class=\\\"ignore\\\"\u003eAvaloki­teśvara\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Avaloki­teśvara, Āryāva­loki­teśvara\",\"tibetan\":\"འཕགས་པ་སྤྱན་རས་གཟིགས་དབང་ཕྱུག, སྤྱན་རས་གཟིགས།\",\"sanskrit\":\"avaloki­teśvara, āryāva­loki­teśvara\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"spyan ras gzigs, ’phags pa spyan ras gzigs dbang phyug\"}},{\"uuid\":\"d0fda944-71f7-4a27-a806-7debbf320eea\",\"authority\":\"56041e12-c29c-45ae-87d9-9db5682dc563\",\"definition\":\"\",\"names\":{\"english\":\"awakening\",\"tibetan\":\"བྱང་ཆུབ།\",\"sanskrit\":\"bodhi\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"byang chub\"}},{\"uuid\":\"20e0d91d-2b54-4a47-84f8-bc4eac85f0f8\",\"authority\":\"d446af6c-b807-4c2d-ae67-641d4f0de5f9\",\"definition\":\"\",\"names\":{\"english\":\"awakening factors\",\"tibetan\":\"བྱང་ཆུབ་ཀྱི་ཕྱོགས་དང་འཐུན་པའི་ཆོས།\",\"sanskrit\":\"bodhi­pakṣya­dharma\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"byang chub kyi phyogs dang ’thun pa’i chos\"}},{\"uuid\":\"c0849f08-9eba-42c8-9f16-e8ca8d34f002\",\"authority\":\"71c3e498-a282-46c2-a1b2-09bff483deac\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eIn the general Mahāyāna teachings the mind of awakening (bodhicitta) is the intention to attain the complete awakening of a perfect buddha for the sake of all beings. On the level of absolute truth, the mind of awakening is the realization of the awakened state itself.\u003c/p\u003e\",\"names\":{\"english\":\"awakening mind, bodhicitta\",\"tibetan\":\"བྱང་ཆུབ་ཀྱི་སེམས།\",\"sanskrit\":\"bodhicitta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"byang chub kyi sems\"}},{\"uuid\":\"deddb27a-9b11-4d74-8db6-3e1ec86d3905\",\"authority\":\"b9ad143d-7cf5-40e8-9286-90ee648ab727\",\"definition\":\"\",\"names\":{\"english\":\"awareness\",\"tibetan\":\"ཤེས་བཞིན།\",\"sanskrit\":\"samprajāna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shes bzhin\"}},{\"uuid\":\"2283dbd7-1426-4735-a42e-fa3085c70c20\",\"authority\":\"17f36814-2e15-4b6b-9dad-aa46104d6bbd\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eType of Sanskrit compound.\u003c/p\u003e\",\"names\":{\"english\":\"bahuvrīhi\",\"tibetan\":\"\",\"sanskrit\":\"bahuvrīhi\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"\"}},{\"uuid\":\"821f306a-a110-4274-8a91-035ea30b9389\",\"authority\":\"ff79a6be-1e3d-441b-a66b-7b6b5d087319\",\"definition\":\"$63\",\"names\":{\"english\":\"bases of supernatural powers\",\"tibetan\":\"རྫུ་འཕྲུལ་གྱི་རྐང་པ།\",\"sanskrit\":\"ṛddhipādaḥ\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rdzu ’phrul gyi rkang pa\"}},{\"uuid\":\"ad3097fe-b272-4d95-8811-3cbb3824ee9e\",\"authority\":\"23440fad-1a92-40b7-97ba-808e7d4e1962\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOften rendered simply as “being.”\u003c/p\u003e\",\"names\":{\"english\":\"being, sentient being\",\"tibetan\":\"སེམས་ཅན།\",\"sanskrit\":\"sattva\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sems can\"}},{\"uuid\":\"84127eb5-0b6c-44c9-af0b-af8d0d8d5130\",\"authority\":\"62043aa4-c0d8-4cf1-8628-8c0fc29c5004\",\"definition\":\"\",\"names\":{\"english\":\"belief in a perduring self\",\"tibetan\":\"འཇིག་ཚོགས་ལ་ལྟ་བ།\",\"sanskrit\":\"satkāyadṛṣṭi\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’jig tshogs la lta ba\"}},{\"uuid\":\"88b90b1b-99ac-4b88-81b0-3ecc3c52d507\",\"authority\":\"6e7d97ae-2219-4971-8336-362aa5cfc678\",\"definition\":\"\",\"names\":{\"english\":\"beryl\",\"tibetan\":\"བཻ་དཱུརྱ།\",\"sanskrit\":\"vaidūrya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bai dUr+ya\"}},{\"uuid\":\"b2dce9e4-3534-414a-b2d6-cff7c661c202\",\"authority\":\"661b834b-9cbc-48a2-acff-9b3e1fff6f9b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eEqual to a thousand \u003cspan data-glossary-id=\\\"UT22084-049-001-1673\\\"\u003euniverses of a thousand worlds\u003c/span\u003e (i.e., a universe of a million worlds). \u003c/p\u003e\",\"names\":{\"english\":\"bichiliocosm\",\"tibetan\":\"སྟོང་གཉིས་པ་བར་མའི་འཇིག་རྟེན་གྱི་ཁམས།\",\"sanskrit\":\"dvitīyamadhyama sāhasralokadhātu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"stong gnyis pa bar ma’i ’jig rten gyi khams\"}},{\"uuid\":\"af66dd3c-6528-471c-b580-a844c4e22358\",\"authority\":\"2e5d49b1-f4e0-4d92-8000-460a7301dd2f\",\"definition\":\"\",\"names\":{\"english\":\"binding\",\"tibetan\":\"འཆིང་བ།\",\"sanskrit\":\"bandhana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’ching ba\"}},{\"uuid\":\"1b51c11a-be57-45e7-82eb-2691bb785c0d\",\"authority\":\"2b190410-5ef2-4a3a-a428-89d999d14336\",\"definition\":\"$64\",\"names\":{\"english\":\"blessed one\",\"tibetan\":\"བཅོམ་ལྡན་འདས།\",\"sanskrit\":\"bhagavat, bhagavān\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bcom ldan ’das\"}},{\"uuid\":\"072b1969-eda8-4f65-8019-8dc01bc43ed8\",\"authority\":\"b355d858-e2c0-4a95-beff-95494a43b8c5\",\"definition\":\"\",\"names\":{\"english\":\"body afflicted by corruption, dauṣṭhulyakāya\",\"tibetan\":\"གནས་ངན་ལེན་གྱི་ལུས།\",\"sanskrit\":\"dauṣṭhulyakāya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gnas ngan len gyi lus\"}},{\"uuid\":\"e8fdd6ff-6a03-404c-ab6f-63e7897326fe\",\"authority\":\"ca63bb7f-ceba-45f1-b520-ac2199b60741\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe \u003cspan class=\\\"ignore\\\"\u003eseven branches of awakening\u003c/span\u003e are: (1) correct \u003cspan data-glossary-id=\\\"UT22084-049-001-1544\\\"\u003emindfulness\u003c/span\u003e, (2) correct \u003cspan data-glossary-id=\\\"UT22084-049-001-1419\\\"\u003ediscrimination of dharmas\u003c/span\u003e, (3) correct \u003cspan data-glossary-id=\\\"UT22084-049-001-1682\\\"\u003evigor\u003c/span\u003e, (4) correct \u003cspan data-glossary-id=\\\"UT22084-049-001-1517\\\"\u003ejoy\u003c/span\u003e, (5) correct \u003cspan data-glossary-id=\\\"UT22084-049-001-1466\\\"\u003eflexibility\u003c/span\u003e, (6) \u003cspan data-glossary-id=\\\"UT22084-049-001-1384\\\"\u003ecorrect concentration\u003c/span\u003e, and (7) correct \u003cspan data-glossary-id=\\\"UT22084-049-001-1439\\\"\u003eequanimity\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"branches of awakening\",\"tibetan\":\"བྱང་ཆུབ་ཀྱི་ཡན་ལག\",\"sanskrit\":\"bodhyaṅgāni\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"byang chub kyi yan lag\"}},{\"uuid\":\"6ffb5915-a151-47df-97a7-db6ca506d632\",\"authority\":\"0ab07b1d-cd15-4d50-90f9-564c22f880b5\",\"definition\":\"\",\"names\":{\