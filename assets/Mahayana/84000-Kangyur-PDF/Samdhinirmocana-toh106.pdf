end\":1205}},{\"type\":\"text\",\"text\":\"gates of liberation\",\"attrs\":{\"start\":1205,\"end\":1224},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"da6f44fa-f721-4e7f-bf48-424bb1433d7d\",\"uuid\":\"266e6b94-b98a-4efc-b2c8-37deba343039\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"‍—\",\"attrs\":{\"start\":1224,\"end\":1226}},{\"type\":\"text\",\"text\":\"emptiness\",\"attrs\":{\"start\":1226,\"end\":1235},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"986c5541-3cde-4239-9e0e-933b5ef0981e\",\"uuid\":\"cc9110a7-2b6c-410c-b1e6-82cd86be4050\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":1235,\"end\":1237}},{\"type\":\"text\",\"text\":\"appearancelessness\",\"attrs\":{\"start\":1237,\"end\":1255},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"00274071-9887-4dfc-8f82-15ee3940b0ec\",\"uuid\":\"01604258-944d-4452-acaf-02a290980bb4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and \",\"attrs\":{\"start\":1255,\"end\":1261}},{\"type\":\"text\",\"text\":\"wishlessness\",\"attrs\":{\"start\":1261,\"end\":1273},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"93a3f64b-84f7-4f97-a268-b559e1128933\",\"uuid\":\"9bdf2ffd-72fa-4a04-ad77-9e4a41b8eb1a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"‍—were its entrance. It was set on foundations adorned with an infinite accumulation of excellent qualities, which were like great kings of jeweled lotuses.\",\"attrs\":{\"start\":1273,\"end\":1429},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"7dfc0185-81f1-4009-bb13-508944659f1d\",\"label\":\"40\",\"uuid\":\"8063e489-19c8-4220-beb5-0d9cdf44c5e2\",\"start\":1429,\"end\":1429,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"496ce909-bbb1-4e17-bae6-abc7b5da1256\",\"sort\":2304,\"type\":\"prologue\",\"label\":\"p.2\",\"alignments\":{\"toh106\":{\"folioUuid\":\"218973c4-f885-4186-96b0-089e14257e08\",\"toh\":\"toh106\",\"tibetan\":\"བཅོམ་ལྡན་འདས་ལེགས་པར་ཐུགས་སུ་ཆུད་པའི་བློ་དང་ལྡན་པ། ཀུན་ཏུ་སྤྱོད་པ། གཉིས་མི་མངའ་བ། མཚན་ཉིད་མེད་པའི་ཆོས་ལ་མཆོག་ཏུ་གཞོལ་བར་མཛད་པ། སངས་རྒྱས་\\nཀྱི་གནས་པས་གནས་པ། སངས་རྒྱས་ཐམས་ཅད་དང་མཉམ་པ་ཉིད་བརྙེས་པ། སྒྲིབ་པ་མེད་པའི་རྟོགས་པ་ཐུགས་སུ་ཆུད་པ། ཕྱིར་མི་ཟློག་པའི་ཆོས་དང་ལྡན་པ། སྤྱོད་ཡུལ་གྱིས་མི་འཕྲོགས་པ། བསམ་གྱིས་མི་ཁྱབ་པ་རྣམ་པར་འཇོག་པ། དུས་གསུམ་ལ་\\nམཉམ་པ་ཉིད་ཚར་ཕྱིན་པ། འཇིག་རྟེན་གྱི་ཁམས་ཐམས་ཅད་དུ་ཞུགས་པའི་སྐུ་ལྔ་དང་ལྡན་པ། ཆོས་ཐམས་ཅད་ལ་ཐེ་ཙོམ་མེད་པའི་མཁྱེན་པ་མངའ་བ། སྤྱོད་པ་ཐམས་ཅད་དང་ལྡན་པའི་བློ་མངའ་བ། ཆོས་ཤེས་པ་ལ་ནེམ་ནུར་མི་མངའ་བ། རྣམ་པར་མ་[F.2.b]བརྟགས་པའི་སྐུ་མངའ་བ། བྱང་ཆུབ་སེམས་དཔའ་ཐམས་ཅད་ཀྱིས་ཡེ་ཤེས་ཡང་དག་པར་བླངས་པ། སངས་རྒྱས་ཀྱི་གནས་པ་གཉིས་སུ་མེད་པ། དམ་པའི་ཕ་རོལ་ཏུ་བྱོན་པ། དེ་བཞིན་གཤེགས་པ་མ་འདྲེས་པའི་རྣམ་པར་ཐར་པར་མཛད་པའི་ཡེ་ཤེས་ཀྱི་མཐར་ཕྱིན་\\nཔ། མཐའ་དང་དབུང་མེད་པའི་སངས་རྒྱས་ཀྱི་ས་མཉམ་པ་ཉིད་ཐུགས་སུ་ཆུད་པ། ཆོས་ཀྱི་དབྱིངས་ཀྱིས་ཀླས་པ། ནམ་མཁའི་ཁམས་ཀྱི་མཐས་གཏུགས་པ་དེ། \",\"folioNumber\":2,\"volumeNumber\":49}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1062,\"uuid\":\"496ce909-bbb1-4e17-bae6-abc7b5da1256\"},\"content\":[{\"type\":\"text\",\"text\":\"The \",\"attrs\":{\"start\":0,\"end\":4}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":4,\"end\":15},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1b51c11a-be57-45e7-82eb-2691bb785c0d\",\"uuid\":\"ece299e5-ebde-4338-a3ba-6c19229897f9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" had a perfectly realized \",\"attrs\":{\"start\":15,\"end\":41}},{\"type\":\"text\",\"text\":\"mind\",\"attrs\":{\"start\":41,\"end\":45},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b667709c-9e2a-4877-96d5-8b056867ac96\",\"uuid\":\"740796d3-a25b-4a73-8d6e-ce18ca6a417a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and was free from dualistic behavior. Absorbed in the \",\"attrs\":{\"start\":45,\"end\":100}},{\"type\":\"text\",\"text\":\"Dharma of the nonexistence of defining characteristics\",\"attrs\":{\"start\":100,\"end\":154},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"0e60513c-0406-43a4-aca5-0c0a616ab25a\",\"uuid\":\"fcdaf719-a0c3-47af-a8bc-6ceb6864461d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", he was residing in the domain of the buddhas. He had attained equality with all buddhas. His realization was unobstructed and his qualities\",\"attrs\":{\"start\":154,\"end\":295},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"c2ef921a-f310-4187-b9af-5c51d5496220\",\"label\":\"41\",\"uuid\":\"6986348b-3710-474e-a819-c03fc55ba472\",\"start\":295,\"end\":295,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" were irreversible. He could not be overcome by \",\"attrs\":{\"start\":295,\"end\":343}},{\"type\":\"text\",\"text\":\"objects of experience\",\"attrs\":{\"start\":343,\"end\":364},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a5b75fc2-e4c9-4db3-a72b-3763d9f67e14\",\"uuid\":\"45577a12-7297-4787-82b9-4e8b3c796f92\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":364,\"end\":365},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"e4aa6f12-8e97-4da9-b7e7-2ec0ea839a76\",\"label\":\"42\",\"uuid\":\"1a47fd59-060b-4ff7-8a94-41270eeda54e\",\"start\":365,\"end\":365,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" His abode was inconceivable.\",\"attrs\":{\"start\":365,\"end\":394},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"c4c8bd87-d1f8-4016-8828-6cf42f544c31\",\"label\":\"43\",\"uuid\":\"01a2fa70-9793-47b9-8fb0-1cf406997430\",\"start\":394,\"end\":394,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":394,\"end\":395}},{\"type\":\"text\",\"text\":\"Perfectly skilled in the sameness of the three times\",\"attrs\":{\"start\":395,\"end\":447},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"3f200917-a25b-4eb3-ae79-00e2983a2a3e\",\"uuid\":\"bae9fb67-43b9-4ab0-a1b6-14135833f81f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\",\",\"attrs\":{\"start\":447,\"end\":448},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"05c54ddf-5975-4e9d-8589-d8585ecd39c6\",\"label\":\"44\",\"uuid\":\"fcb0c0b3-fe24-4325-8f3e-4f53cd4dce50\",\"start\":448,\"end\":448,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" his five bodies were present in all worlds. His knowledge of all phenomena was free from doubt. He \",\"attrs\":{\"start\":448,\"end\":548}},{\"type\":\"text\",\"text\":\"understood all practices\",\"attrs\":{\"start\":548,\"end\":572},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"21f1e13b-1a06-40b2-8c45-b653ba7eee42\",\"uuid\":\"2348cee0-6104-4d5e-8da8-53fb114033bf\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". His knowledge of phenomena was without uncertainty. His body was unimaginable. He \",\"attrs\":{\"start\":572,\"end\":656}},{\"type\":\"text\",\"text\":\"possessed the gnosis bodhisattvas vow to accomplish\",\"attrs\":{\"start\":656,\"end\":707},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"04a9d1c7-3855-42ed-a2ea-197b8d6961b3\",\"uuid\":\"7174b257-45f9-4892-bead-4c91f4febe73\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":707,\"end\":708},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"a3a0603c-8189-4410-b5f2-681b71797f2c\",\"label\":\"45\",\"uuid\":\"96c1c946-9be4-462e-b8be-529a292309a2\",\"start\":708,\"end\":708,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" He had attained the \",\"attrs\":{\"start\":708,\"end\":729}},{\"type\":\"text\",\"text\":\"nondual\",\"attrs\":{\"start\":729,\"end\":736},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8add1668-c7f5-4eae-ad45-edb7c22be603\",\"uuid\":\"554da6d8-5d4e-407a-ab66-b13ba40f8633\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" abode of the buddhas, \",\"attrs\":{\"start\":736,\"end\":759}},{\"type\":\"text\",\"text\":\"the sublime perfection, the supreme indivisible gnosis of the Tathāgata’s liberation\",\"attrs\":{\"start\":759,\"end\":843},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ba824090-6ecc-434d-ba21-21b70a0e789d\",\"uuid\":\"f06bd172-5732-4808-8040-4537b3e06b24\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":843,\"end\":844},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"f306ff9e-8dac-43dd-b524-88c083652764\",\"label\":\"46\",\"uuid\":\"09897997-b4c9-41b5-b87b-2412d21fc7a8\",\"start\":844,\"end\":844,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" He \",\"attrs\":{\"start\":844,\"end\":848}},{\"type\":\"text\",\"text\":\"had realized the sameness [of all phenomena], the state of a buddha in which there is neither a center nor a periphery\",\"attrs\":{\"start\":848,\"end\":966},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bfafa7ea-8c6e-492b-a266-afaee98c8b8a\",\"uuid\":\"d0f86fa3-63dc-424b-9ab8-7301513fbc25\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\",\",\"attrs\":{\"start\":966,\"end\":967},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"82d64bb2-cae2-4535-8799-be81cd600ab3\",\"label\":\"47\",\"uuid\":\"454d2acd-e7e4-49c9-91fe-4a6a342917fd\",\"start\":967,\"end\":967,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" and reached the \",\"attrs\":{\"start\":967,\"end\":984}},{\"type\":\"text\",\"text\":\"ultimate within the domain of truth\",\"attrs\":{\"start\":984,\"end\":1019},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"00431ab2-3f39-4944-b485-94bfdb8418ef\",\"uuid\":\"d90e7438-cd72-482d-9917-c2c3fa660db7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the \",\"attrs\":{\"start\":1019,\"end\":1025}},{\"type\":\"text\",\"text\":\"point where the sphere of space ends\",\"attrs\":{\"start\":1025,\"end\":1061},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"88c055af-6986-493b-8e94-603f99e21461\",\"uuid\":\"2e841aec-864d-4c7f-8b9e-feebbe42fa97\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":1061,\"end\":1062},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"dd37e139-4f43-4d3d-bf9b-d4738116b252\",\"label\":\"48\",\"uuid\":\"432c484b-f383-4852-8ed8-4f02d2ec0095\",\"start\":1062,\"end\":1062,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"06cc5e23-228e-48b5-9f27-eff6955db577\",\"sort\":2347,\"type\":\"prologue\",\"label\":\"p.3\",\"alignments\":{\"toh106\":{\"folioUuid\":\"ae4eaa14-8c6b-4543-a57a-92bd2832fdb8\",\"toh\":\"toh106\",\"tibetan\":\"ཉན་ཐོས་ཀྱི་དགེ་འདུན་ཚད་མེད་པ་ཐམས་ཅད་ཀྱང་། ཅང་ཤེས་པ། སངས་\\nརྒྱས་ཀྱི་སྲས། སེམས་ཤིན་ཏུ་རྣམ་པར་གྲོལ་བ། ཤེས་རབ་ཤིན་ཏུ་རྣམ་པར་གྲོལ་བ། ཚུལ་ཁྲིམས་ཤིན་ཏུ་རྣམ་པར་དག་པ། ཆོས་འདོད་པ་རྣམས་དང་བདེ་བར་ཕྲད་པ། མང་དུ་ཐོས་པ། ཐོས་པ་འཛིན་པ། ཐོས་པ་བསྩགས་པ། ལེགས་པར་བསམ་པ་སེམས་\\nཔ། ལེགས་པར་སྨྲ་བ་རྗོད་པ། ལེགས་པར་བྱ་བའི་ལས་བྱེད་པ། ཤེས་རབ་མྱུར་བ། ཤེས་རབ་མགྱོགས་པ། ཤེས་རབ་རྣོ་བ། ངེས་པར་འབྱུང་བའི་ཤེས་རབ་ཅན། ངེས་པར་རྟོགས་པའི་ཤེས་རབ་ཅན། ཤེས་རབ་ཆེ་བ། ཤེས་རབ་ཡངས་པ། ཤེས་རབ་ཟབ་པ། \\nཤེས་རབ་མཉམ་པ་མེད་པ། ཤེས་རབ་རིན་པོ་ཆེ་དང་ལྡན་པ། རིག་པ་གསུམ་དང་ལྡན་པ། ཚེ་འདི་ལ་བདེ་བར་གནས་པའི་མཆོག་ཐོབ་པ། །ཡོངས་སུ་སྦྱོང་བ་ཆེན་པོ། །སྤྱོད་ལམ་རབ་ཏུ་ཞི་བ་ཕུན་སུམ་ཚོགས་པ། བཟོད་པ་དང་ངེས་པ་ཆེན་པོ་དང་ལྡན་པ། དེ་བཞིན་\\nགཤེགས་པའི་བཀའ་ལ་ཤིན་ཏུ་ཞུགས་པ་ཤ་སྟག་དང་། \",\"folioNumber\":2,\"volumeNumber\":49}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":863,\"uuid\":\"06cc5e23-228e-48b5-9f27-eff6955db577\"},\"content\":[{\"type\":\"text\",\"text\":\"The \",\"attrs\":{\"start\":0,\"end\":4}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":4,\"end\":15},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1b51c11a-be57-45e7-82eb-2691bb785c0d\",\"uuid\":\"67fd2495-9c89-43d0-bd11-c4c9181186f4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" was accompanied by the entire immeasurable assembly of \",\"attrs\":{\"start\":15,\"end\":71}},{\"type\":\"text\",\"text\":\"hearers\",\"attrs\":{\"start\":71,\"end\":78},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"09872ba1-9454-42fc-a9a1-83b2db59413e\",\"uuid\":\"9f276983-3de6-487d-88e2-d859e6a5149f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Children of noble family, they were the heirs of the Buddha. Their \",\"attrs\":{\"start\":78,\"end\":147}},{\"type\":\"text\",\"text\":\"minds\",\"attrs\":{\"start\":147,\"end\":152},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b667709c-9e2a-4877-96d5-8b056867ac96\",\"uuid\":\"60e47033-a5bd-48da-8c84-dd95f9dee9c6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" were liberated, their \",\"attrs\":{\"start\":152,\"end\":175}},{\"type\":\"text\",\"text\":\"wisdom\",\"attrs\":{\"start\":175,\"end\":181},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4c3420a1-ffdd-40b2-9f85-e4293f7c2bbb\",\"uuid\":\"78a8f8e1-8ed3-4a42-a870-d2bae1b6c49f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" was \",\"attrs\":{\"start\":181,\"end\":186}},{\"type\":\"text\",\"text\":\"emancipated\",\"attrs\":{\"start\":186,\"end\":197},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1d4420eb-eac6-4d43-9fa1-048e40c71418\",\"uuid\":\"67c4640f-af0b-41a4-9296-14f97697f9d4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and their \",\"attrs\":{\"start\":197,\"end\":209}},{\"type\":\"text\",\"text\":\"discipline\",\"attrs\":{\"start\":209,\"end\":219},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"6217fe34-e4af-42f1-b937-302537e92a18\",\"uuid\":\"8002c869-77a0-4399-8b5a-d9efd6fb1a37\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" was completely pure. They happily gathered with those who longed for the Dharma. They had heard much, kept in mind what they had heard, and \",\"attrs\":{\"start\":219,\"end\":360}},{\"type\":\"text\",\"text\":\"accumulated\",\"attrs\":{\"start\":3