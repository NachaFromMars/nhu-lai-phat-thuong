\"attrs\":{\"uuid\":\"deb6614c-84fc-461f-ba62-e25cce3afdc1\",\"sort\":12364,\"type\":\"abbreviations\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"class\":\"flex flex-row gap-2\",\"start\":0,\"end\":26,\"uuid\":\"deb6614c-84fc-461f-ba62-e25cce3afdc1\"},\"content\":[{\"type\":\"abbreviation\",\"text\":\"X \",\"attrs\":{\"start\":0,\"end\":2,\"abbreviation\":\"deb6614c-84fc-461f-ba62-e25cce3afdc1\",\"uuid\":\"f95225e5-3a65-4cff-b4cf-34e86b2d0de4\"},\"content\":[{\"type\":\"text\",\"text\":\"X \"}]},{\"type\":\"hasAbbreviation\",\"text\":\"Basgo manuscript Kangyur\",\"attrs\":{\"start\":2,\"end\":26,\"abbreviation\":\"deb6614c-84fc-461f-ba62-e25cce3afdc1\",\"uuid\":\"f6662241-fb34-4055-a83b-697a4d7cfdfb\"},\"content\":[{\"type\":\"text\",\"text\":\"Basgo manuscript Kangyur\"}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"ab6bdf4e-5cb6-4af9-ac00-22d378f9a03e\",\"sort\":12366,\"type\":\"abbreviations\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"class\":\"flex flex-row gap-2\",\"start\":0,\"end\":147,\"uuid\":\"ab6bdf4e-5cb6-4af9-ac00-22d378f9a03e\"},\"content\":[{\"type\":\"abbreviation\",\"text\":\"YBht P ’i \",\"attrs\":{\"start\":0,\"end\":10,\"abbreviation\":\"ab6bdf4e-5cb6-4af9-ac00-22d378f9a03e\",\"uuid\":\"2cb5694a-6234-49c4-aa46-48b4b8aa1308\"},\"content\":[{\"type\":\"text\",\"text\":\"YBht P ’i \"}]},{\"type\":\"hasAbbreviation\",\"text\":\"Tibetan translation of Acarya Asanga’s Yogācāra­bhūmi from the Peking Tengyur (n°. 5540, sems-tsam, ’i 143aI-382a5 (vol. I l l : 121-217)\",\"attrs\":{\"start\":10,\"end\":147,\"abbreviation\":\"ab6bdf4e-5cb6-4af9-ac00-22d378f9a03e\",\"uuid\":\"fffc6fc8-46a3-4bcd-8f3f-73f202362edc\"},\"content\":[{\"type\":\"text\",\"text\":\"Tibetan translation of Acarya Asanga’s Yogācāra­bhūmi from the Peking Tengyur (n°. 5540, sems-tsam, ’i 143aI-382a5 (vol. I l l : 121-217)\"}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"b3ea1a13-587c-48a4-a5b2-057cb030b54e\",\"sort\":12370,\"type\":\"abbreviations\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"class\":\"flex flex-row gap-2\",\"start\":0,\"end\":32,\"uuid\":\"b3ea1a13-587c-48a4-a5b2-057cb030b54e\"},\"content\":[{\"type\":\"abbreviation\",\"text\":\"Z \",\"attrs\":{\"start\":0,\"end\":2,\"abbreviation\":\"b3ea1a13-587c-48a4-a5b2-057cb030b54e\",\"uuid\":\"da046d7f-1aba-412e-ae1c-b4e26db01ad2\"},\"content\":[{\"type\":\"text\",\"text\":\"Z \"}]},{\"type\":\"hasAbbreviation\",\"text\":\"Shey Palace manuscript Kangyur\",\"attrs\":{\"start\":2,\"end\":32,\"abbreviation\":\"b3ea1a13-587c-48a4-a5b2-057cb030b54e\",\"uuid\":\"1171480e-f125-4adf-865f-352ad00d42d8\"},\"content\":[{\"type\":\"text\",\"text\":\"Shey Palace manuscript Kangyur\"}]}]}]}],\"bibliography\":[{\"heading\":\"Tibetan Sources\",\"entries\":[{\"uuid\":\"46717089-56df-4e6e-a464-2a9114595b55\",\"html\":\"\u003cp\u003e\u003cem\u003e’phags pa dgongs pa nges par ’grel pa zhes bya ba theg pa chen po’i mdo\u003c/em\u003e (\u003cem\u003eĀryasaṃdhi­nirmocananāmamahāyānasūtra\u003c/em\u003e). Toh 106, Degé Kangyur vol. 49 (mdo sde, ca) folios 1.b–55.b. \u003c/p\u003e\",\"workUuid\":null},{\"uuid\":\"e141cb6e-08c0-40cf-8792-23ec20ff8695\",\"html\":\"\u003cp\u003e\u003cem\u003e’phags pa dgongs pa nges par ’grel pa zhes bya ba theg pa chen po’i mdo\u003c/em\u003e. bka’ ’gyur (dpe bsdur ma) [Comparative Edition of the Kangyur], krung go’i bod rig pa zhib ’jug ste gnas kyi bka’ bstan dpe sdur khang (The Tibetan Tripitaka Collation Bureau of the China Tibetology Research Center). 108 volumes. Beijing: krung go’i bod rig pa dpe skrun khang (China Tibetology Publishing House), 2006–9, vol. 49, pp. 3–131.\u003c/p\u003e\",\"workUuid\":null},{\"uuid\":\"844153c2-bf8d-468e-a250-9aa811d4964b\",\"html\":\"\u003cp\u003eAsaṅga. \u003cem\u003ernal ’byor spyod pa’i sa\u003c/em\u003e (\u003cem\u003eYogācāra­bhūmi\u003c/em\u003e). Toh 4035, Degé Tengyur vol. 127 (sems tsam, tshi) folios 1.b–283.a\u003c/p\u003e\",\"workUuid\":null},{\"uuid\":\"8f26c335-0915-41fb-a7d6-71f6fa083d08\",\"html\":\"\u003cp\u003eAsaṅga. \u003cem\u003ernal ’byor spyod pa’i sa rnam par gtan la dbab pa bsdu ba\u003c/em\u003e (\u003cem\u003eYogācāra­bhūmiviniścayasaṃgraha\u003c/em\u003e). Toh 4038, Degé Tengyur vol. 130 (sems tsam, zhi), folios 1.b–289.a; vol. 131 (sems tsam, zi), folios 1.b–127.a.\u003c/p\u003e\",\"workUuid\":null},{\"uuid\":\"5f5a514b-1bb1-46bf-ac65-fcd2f190826f\",\"html\":\"\u003cp\u003e\u003cem\u003eBuddha­bhūmi­sūtra\u003c/em\u003e (\u003cem\u003esangs rgyas kyi sa’i mdo\u003c/em\u003e). Toh 275, Degé Kangyur vol. 68 (mdo sde, ya), folios 36.a–44.b.\u003c/p\u003e\",\"workUuid\":null},{\"uuid\":\"9bf1dd76-8857-420e-80f0-a4fad484be86\",\"html\":\"\u003cp\u003eKamalaśila. \u003cem\u003ebsgom pa’i rim pa\u003c/em\u003e (\u003cem\u003eBhāvanākrama\u003c/em\u003e). Toh 3915, Degé Tengyur vol. 110 (dbu ma, ki), folios 22.a–41.b; Toh 3916, Degé Tengyur vol. 110 (dbu ma, ki), folios 42.a–55.b; and Toh 3917, Degé Tengyur vol. 110 (dbu ma, ki), folios 55.b–68.b.\u003c/p\u003e\",\"workUuid\":null},{\"uuid\":\"ac752d31-6c9e-41f3-9b22-a86095275733\",\"html\":\"\u003cp\u003e\u003cem\u003eMahāvyutpatti\u003c/em\u003e (\u003cem\u003ebye brag tu rtogs par byed pa chen po\u003c/em\u003e). Toh 4346, Degé Tengyur vol. 204 (sna tshogs, co), folios 1.b–131.a.\u003c/p\u003e\",\"workUuid\":null},{\"uuid\":\"e496c57e-9145-424d-a4a7-64d6f5388dde\",\"html\":\"\u003cp\u003e\u003cem\u003eMāyājāla\u003c/em\u003e (\u003cem\u003emdo chen sgyu ma’i dra ba\u003c/em\u003e). Toh 288, Degé Kangyur vol. 71 (mdo sde, sha), folios 230.a–244.a. English translation \u003cem\u003e\u003ca href=\\\"https://read.84000.co/translation/toh288.html\\\"\u003eThe Mahāsūtra “Illusion’s Net”\u003c/a\u003e\u003c/em\u003e 2025.\u003c/p\u003e\",\"workUuid\":null},{\"uuid\":\"64e267c1-0772-4890-8c5f-dc43262a7508\",\"html\":\"\u003cp\u003e\u003cem\u003e\u003ca href=\\\"https://read.84000.co/translation/toh185.html\\\"\u003eTathāgata­guṇa­jñānā­cintyaviṣayāva­tāra­nirdeśa­sūtra\u003c/a\u003e\u003c/em\u003e (\u003cem\u003ede bzhin gshegs pa’i yon tan dang ye shes bsam gyis mi khyab pa’i yul la ’jug pa bstan pa’i mdo\u003c/em\u003e). Toh 185, Degé Kangyur vol. 61 (mdo sde, tsa), folios 106.a–143.b.\u003c/p\u003e\",\"workUuid\":null},{\"uuid\":\"974f5085-8e7d-486d-8376-50c134aae67f\",\"html\":\"\u003cp\u003eTrisong Detsen (\u003cem\u003ekhri srong lde brtsan\u003c/em\u003e). \u003cem\u003ebka’ yang dag pa’i tshad ma las mdo btus pa\u003c/em\u003e (\u003cem\u003eSamyagvāk­pramāṇoddhṛta­sūtra\u003c/em\u003e). Toh 4352, Degé Tengyur vol. 204 (sna tshogs, co), folios 173.b–203.a.\u003c/p\u003e\",\"workUuid\":null},{\"uuid\":\"ecaaee7f-195e-4208-88b8-ab8147cf2cef\",\"html\":\"\u003cp\u003eVasubandhu. \u003cem\u003edbus dang mtha’ rnam par ’byed pa’i ’grel pa\u003c/em\u003e (\u003cem\u003eMadhyānta­vibhāga­bhāṣya\u003c/em\u003e). Toh 4027, Degé Tengyur vol. 124 (sems tsam, bi), folios 1.b–27.a.\u003c/p\u003e\",\"workUuid\":null},{\"uuid\":\"891c63d4-fa3e-4eea-b821-9afa39f88b0c\",\"html\":\"\u003cp\u003eWonch’uk. \u003cem\u003edgongs pa zab mo nges par ’grel pa’i mdo rgya cher ’grel pa\u003c/em\u003e (*\u003cem\u003eĀrya­gambhīra­saṃdhi­nirmocana­sūtraṭīkā\u003c/em\u003e) Toh 4016, Degé Tengyur vol. 118 (mdo ’grel, ti), folios 1.b–291.a; vol. 119 (mdo ’grel, thi), folios 1.b–175.a.\u003c/p\u003e\",\"workUuid\":null},{\"uuid\":\"f2b7906f-553a-4910-9b8c-c42a39767554\",\"html\":\"\u003cp\u003e\u003ca href=\\\"http://idp.bl.uk/database/oo_loader.a4d?pm=IOL Tib J 194;img=1\\\"\u003eIOL Tib J 194\u003c/a\u003e. British Library, London. Accessed through The International Dunhuang Project: The Silk Road Online. \u003c/p\u003e\",\"workUuid\":null}]},{\"heading\":\"Other Canonical Sources for Samdh.\",\"entries\":[{\"uuid\":\"ce7f99b7-355f-4ee0-979c-7670d7f109bf\",\"html\":\"\u003cp\u003eBd3.7 vol. 3 (ta) pha, folios 1.b–84.a\u003c/p\u003e\",\"workUuid\":null},{\"uuid\":\"3e82938b-1cbc-442b-880f-ccda