,\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" This turning of the Dharma wheel by the \",\"attrs\":{\"start\":1276,\"end\":1317}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":1317,\"end\":1328},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1b51c11a-be57-45e7-82eb-2691bb785c0d\",\"uuid\":\"6c11c9c0-7a34-4510-97c0-8e4e6be143c1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" was unsurpassable and not limited to the circumstances. Being of definitive meaning, it did not become a topic of dispute.\",\"attrs\":{\"start\":1328,\"end\":1451}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"6b603a38-1475-4e1b-ab08-b87890401d3d\",\"sort\":6100,\"type\":\"translation\",\"label\":\"7.31\",\"alignments\":{\"toh106\":{\"folioUuid\":\"fa697996-fb2b-4bf9-93e7-c6cad0d70cf2\",\"toh\":\"toh106\",\"tibetan\":\"བཅོམ་ལྡན་འདས་\\nཆོས་རྣམས་ཀྱི་ངོ་བོ་ཉིད་མ་མཆིས་པ་ཉིད་ལས་བརྩམས། རང་བཞིན་གྱིས་ཡོངས་སུ་མྱ་ངན་ལས་འདས་པ་ཉིད་ཀྱི་བར་ལས་བརྩམས་ནས། བཅོམ་ལྡན་འདས་ཀྱིས་ངེས་པའི་དོན་བསྟན་པ་འདི་རིགས་ཀྱི་བུའམ། རིགས་ཀྱི་བུ་མོ་གང་གིས་ཐོས་ནས་མོས་པར་བགྱིད་པ་དང་། \\nཡི་གེར་འདྲིར་སྩོལ་བ་དང་། ཡི་གེར་བྲིས་ནས་ཀྱང་འཆང་བ་དང་། ཀློག་པ་དང་། མཆོད་པ་དང་། ཡང་དག་པར་འགྱེད་པ་དང་། ལུང་ནོད་པ་དང་། ཁ་ཏོན་བགྱིད་པ་དང་། སེམས་པ་དང་། བསྒོམ་པའི་རྣམ་པས་སྦྱོར་བར་བགྱིད་པ་དེ་བསོད་ནམས་ཇི་ཙམ་ཞིག་\\nསྐྱེད་པར་འགྱུར་བ་ལགས། \",\"folioNumber\":25,\"volumeNumber\":49}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":595,\"uuid\":\"6b603a38-1475-4e1b-ab08-b87890401d3d\"},\"content\":[{\"type\":\"text\",\"text\":\"“\",\"attrs\":{\"start\":0,\"end\":1}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":1,\"end\":12},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1b51c11a-be57-45e7-82eb-2691bb785c0d\",\"uuid\":\"038bdc11-9435-49b0-8d06-322d066b7fa3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", when sons or daughters of noble family have heard the teaching of definitive meaning taught by the \",\"attrs\":{\"start\":12,\"end\":113}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":113,\"end\":124},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1b51c11a-be57-45e7-82eb-2691bb785c0d\",\"uuid\":\"3097419a-03f9-4a76-b3d9-912cb3a28279\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in reference to the statement, ‘All phenomena are without an \",\"attrs\":{\"start\":124,\"end\":186}},{\"type\":\"text\",\"text\":\"essence\",\"attrs\":{\"start\":186,\"end\":193},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"47c8923c-56be-43d8-b398-ff4290cece41\",\"uuid\":\"a88e56d9-4aed-4b4c-bd7b-a6247f3818b3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":193,\"end\":195}},{\"type\":\"text\",\"text\":\"unborn\",\"attrs\":{\"start\":195,\"end\":201},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"760ae48f-4c62-4d01-9846-06e850f94816\",\"uuid\":\"af071273-4483-4809-bcca-dfa9581d13fb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", unceasing, \",\"attrs\":{\"start\":201,\"end\":214}},{\"type\":\"text\",\"text\":\"primordially in the state of peace\",\"attrs\":{\"start\":214,\"end\":248},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1e90dc88-d44c-4d41-a2d6-f27e9685ce7f\",\"uuid\":\"f8b483cc-e635-43bd-9976-0e85e53ca155\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and naturally in the state of \",\"attrs\":{\"start\":248,\"end\":280}},{\"type\":\"text\",\"text\":\"nirvāṇa\",\"attrs\":{\"start\":280,\"end\":287},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"957da5d5-795e-4533-909b-58063c94b409\",\"uuid\":\"5ef33fc2-eae4-49e0-8395-90fd191ef714\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\",’ they develop devotion for this teaching and commission its transcription into writing. Once it has been put into writing, they \",\"attrs\":{\"start\":287,\"end\":417}},{\"type\":\"text\",\"text\":\"keep it in mind\",\"attrs\":{\"start\":417,\"end\":432},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ce6a97b5-8b0b-4542-b216-c7710d4abef3\",\"uuid\":\"405f4544-067b-4038-8e17-373c0eefa9f5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", read it, venerate it, propagate it, expound it, chant it aloud, contemplate it, and apply it in their practice. As they do so, how much merit will they produce?”\",\"attrs\":{\"start\":432,\"end\":595}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"af27a1f9-44b4-4123-b7e0-c5be2a99e70d\",\"sort\":6116,\"type\":\"translation\",\"label\":\"7.32\",\"alignments\":{\"toh106\":{\"folioUuid\":\"fa697996-fb2b-4bf9-93e7-c6cad0d70cf2\",\"toh\":\"toh106\",\"tibetan\":\"དེ་སྐད་ཅེས་གསོལ་པ་དང་། བཅོམ་ལྡན་འདས་ཀྱིས་བྱང་ཆུབ་སེམས་དཔའ་དོན་དམ་ཡང་དག་འཕགས་ལ་འདི་སྐད་ཅེས་བཀའ་སྩལ་ཏོ། །དོན་དམ་ཡང་དག་འཕགས་རིགས་ཀྱི་བུའམ། རིགས་ཀྱི་བུ་མོ་དེ་ནི་བསོད་ནམས་དཔག་ཏུ་མེད་[F.25.b]གྲངས་མེད་པ་བསྐྱེད་དེ། དེའི་དཔེ་བྱ་བར་སླ་བ་མ་ཡིན་མོད་ཀྱི། འོན་ཀྱང་མདོར་བསྡུས་ཏེ་ཁྱོད་ལ་བཤད་པར་བྱའོ། །དོན་དམ་ཡང་དག་འཕགས་འདི་ལྟ་སྟེ་དཔེར་ན། སེན་མོའི་རྩེ་མོ་ལ་གནས་པའི་སའི་རྡུལ་གང་དག་ཡིན་པ་དེ་ནི། ས་ལ་གནས་པའི་རྡུལ་རྣམས་\\nདང་བསྒྲུན་ན་བརྒྱའི་ཆར་ཡང་ཉེ་བར་མི་འགྲོ་ཞིང་སྟོང་གི་ཆ་དང་། འབུམ་གྱི་ཆ་དང་། གྲངས་དང་། ཆ་དང་། བགྲང་བ་དང་། དཔེ་དང་། རྒྱུར་ཡང་ཉེ་བར་མི་འགྲོའོ། །བ་ལང་གི་རྗེས་ཀྱི་ཆུ་ནི་མཚོ་ཆེན་པོ་བཞིའི་ཆུ་དང་བསྒྲུན་ན་བརྒྱའི་ཆར་ཡང་ཉེ་བར་མི་འགྲོ་བ་\\nནས་རྒྱུའི་བར་དུ་ཡང་ཉེ་བར་མི་འགྲོའོ། །དོན་དམ་ཡང་དག་འཕགས་དེ་བཞིན་དུ་ངས་དྲང་བའི་དོན་གྱི་མདོ་སྡེ་ལ་མོས་པ་ནས་བསྒོམ་པའི་རྣམ་པར་སྦྱོར་བར་བྱེད་པའི་བར་གྱི་བསོད་ནམས་གང་བཤད་པ་དེ་ནི་ངེས་པའི་དོན་བསྟན་པ་ལ་མོས་པ་ལས་ཡང་དག་པར་གྲུབ་པ་ནས། \\nབསྒོམ་པའི་རྣམ་པས་སྦྱོར་བ་ལས་ཡང་དག་པར་གྲུབ་པའི་བར་གྱི་བསོད་ནམས་དང་བསྒྲུན་ན་བརྒྱའི་ཆར་ཡང་ཉེ་བར་མི་འགྲོ་བ་ནས་རྒྱུའི་བར་དུ་ཡང་ཉེ་བར་མི་འགྲོའོ། །དེ་སྐད་ཅེས་བཀའ་སྩལ་པ་དང་། \",\"folioNumber\":25,\"volumeNumber\":49}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1278,\"uuid\":\"af27a1f9-44b4-4123-b7e0-c5be2a99e70d\"},\"content\":[{\"type\":\"text\",\"text\":\"The \",\"attrs\":{\"start\":0,\"end\":4}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":4,\"end\":15},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1b51c11a-be57-45e7-82eb-2691bb785c0d\",\"uuid\":\"e637ba76-8a43-4b82-8990-21cb375f0799\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" answered, “\",\"attrs\":{\"start\":15,\"end\":27}},{\"type\":\"text\",\"text\":\"Para­mārtha­samud­gata\",\"attrs\":{\"start\":27,\"end\":49},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"537e957c-58b2-4ce7-88cc-ad811243d1ba\",\"uuid\":\"991408e1-3026-4d7e-9ca7-628fe7f3a948\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", these sons and daughters of noble family will produce immeasurable and incalculable merit. Although it is difficult to illustrate this with examples, I will briefly explain it to you. \",\"attrs\":{\"start\":49,\"end\":235}},{\"type\":\"text\",\"text\":\"Para­mārtha­samud­gata\",\"attrs\":{\"start\":235,\"end\":257},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"537e957c-58b2-4ce7-88cc-ad811243d1ba\",\"uuid\":\"417fae27-0250-44b2-8459-0265f4482220\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", it is like this: Compared to the amount of earth, the amount of dirt at the tip of a fingernail does not come close to a hundredth, a thousandth, a one hundred thousandth of it, or anything implying calculation, partition, numeration, analogy, or comparison. Compared to the amount of water contained in the four great oceans, the amount of water contained in the hoofprint of an ox does not come close to a hundredth, a thousandth, a one hundred thousandth of it, or anything implying calculation, partition, numeration, analogy, or comparison. Likewise, \",\"attrs\":{\"start\":257,\"end\":815}},{\"type\":\"text\",\"text\":\"Para­mārtha­samud­gata\",\"attrs\":{\"start\":815,\"end\":837},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"537e957c-58b2-4ce7-88cc-ad811243d1ba\",\"uuid\":\"1ea348f7-578f-4ba9-b391-18cba68a9430\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", compared to the amount of merit \",\"attrs\":{\"start\":837,\"end\":871}},{\"type\":\"text\",\"text\":\"accumulated\",\"attrs\":{\"start\":871,\"end\":882},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"0337bf7a-bb0a-4e26-bde7-6d34219dc604\",\"uuid\":\"2f227ed5-9e57-4d04-a71a-4e939422696f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" by developing confidence in my teaching of definitive meaning up to applying it in one’s practice, the amount of merit \",\"attrs\":{\"start\":882,\"end\":1002}},{\"type\":\"text\",\"text\":\"accumulated\",\"attrs\":{\"start\":1002,\"end\":1013},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"0337bf7a-bb0a-4e26-bde7-6d34219dc604\",\"uuid\":\"619b437f-b868-4e5c-9884-c9dc5f97ead8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" by developing confidence in my teaching of provisional meaning … up to applying it in one’s practice does not come close to a hundredth, a thousandth, a one hundred thousandth of it, or anything implying calculation, partition, numeration, analogy, or comparison.”\",\"attrs\":{\"start\":1013,\"end\":1278}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"03f740e1-0916-4b46-a221-4cd50c1bdc64\",\"sort\":6132,\"type\":\"translation\",\"label\":\"7.33\",\"alignments\":{\"toh106\":{\"folioUuid\":\"de394e4e-e097-4b1d-9cc4-b987b568da43\",\"toh\":\"toh106\",\"tibetan\":\"བཅོམ་ལྡན་འདས་ལ་བྱང་ཆུབ་སེམས་དཔའ་དོན་དམ་ཡང་དག་\\nའཕགས་ཀྱིས་འདི་སྐད་ཅེས་གསོལ་ཏོ། །བཅོམ་ལྡན་འདས་དགོངས་པ་ངེས་པར་འགྲེལ་པའི་ཆོས་ཀྱི་རྣམ་གྲངས་འདིར་བསྟན་པ་འདིའི་མིང་ཅི་ལགས། འདི་ཇི་ལྟར་གཟུང་བར་བགྱི། བཅོམ་ལྡན་འདས་ཀྱིས་དེ་ལ་བཀའ་སྩལ་པ། དོན་དམ་ཡང་དག་འཕགས་འདི་ནི་དོན་\\nདམ་པའི་ངེས་པའི་དོན་བསྟན་པ་ཡིན་ཏེ། འདི་དོན་དམ་པ་ངེས་པའི་དོན་བསྟན་པ་ཞེས་བྱ་བར་ཟུང་ཤིག །དོན་དམ་པ་ངེས་པའི་དོན་བསྟན་པ་འདི་བཤད་པ་ན་སྲོག་ཆགས་དྲུག་འབུམ་ནི་བླ་ན་མེད་པ་ཡང་དག་པར་རྫོགས་པའི་བྱང་ཆུབ་ཏུ་སེམས་སྐྱེས་སོ། །ཉན་ཐོས་སུམ་\\nའབུམ་ནི་ཆོས་རྣམས་ལ་ཆོས་ཀྱི་མིག་རྡུལ་མེད་ཅིང་དྲི་མ་དང་བྲལ་བ་རྣམ་པར་དག་གོ། །ཉན་ཐོས་འབུམ་ལྔ་ཁྲི་ནི་ལེན་པ་མེད་པར་ཟག་པ་རྣམས་ལས་སེམས་རྣམ་པར་གྲོལ་ལོ། །བྱང་ཆུབ་སེམས་དཔའ་བདུན་ཁྲི་ལྔ་སྟོང་གིས་ནི་མི་སྐྱེ་བའི་ཆོས་ལ་བཟོད་པ་ཐོབ་པར་གྱུར་ཏོ། །[F.26.a]དོན་དམ་ཡང་དག་འཕགས་ཀྱི་ལེའུ་སྟེ་བདུན་པའོ།། །།\",\"folioNumber\":25,\"volumeNumber\":49}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":188,\"uuid\":\"60ef0032-4d57-4c05-b3aa-c3006d2629b7\"},\"content\":[{\"type\":\"text\",\"text\":\"The bodhisattva \",\"attrs\":{\"start\":0,\"end\":16}},{\"type\":\"text\",\"text\":\"Para­mārtha­samud­gata\",\"attrs\":{\"start\":16,\"end\":38},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"537e957c-58b2-4ce7-88cc-ad811243d1ba\",\"uuid\":\"c89a1382-2dc0-49f7-b689-020abb463d45\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" inquired, “\",\"attrs\":{\"start\":38,\"end\":50}},{\"type\":\"text\",\"text\":\"Blessed One\",\"attrs\":{\"start\":50,\"end\":61},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1b51c11a-be57-45e7-82eb-2691bb785c0d\",\"uuid\":\"54b295db-066e-4487-81e0-7809308d5132\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", what is the name of this teaching as a \",\"attrs\":{\"start\":61,\"end\":102}},{\"type\":\"text\",\"text\":\"Dharma discourse\",\"attrs\":{\"start\":102,\"end\":118},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"32ab0975-da71-4c63-92b8-1311c9ecf499\",\"uuid\":\"63ec4618-d1e4-4eb1-9c54-738f1148d9a5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" that unravels the \",\"attrs\":{\"start\":118,\"end\":137}},{\"type\":\"text\",\"text\":\"Tathāgata\",\"attrs\":{\"start\":137,\"end\":146},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8bf0a239-7fda-4995-8cc7-36b960a1507a\",\"uuid\":\"b8cf1949-e793-4633-8303-b0fdbf92ba38\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s intent?\",\"attrs\":{\"start\":146,\"end\":156},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"686f7705-f6a0-4e66-b989-4d534dda41f0\",\"label\":\"173\",\"uuid\":\"e93be48e-7905-467f-a089-50be735841c5\",\"start\":156,\"end\":156,\"location\":\"end\",\"toh\":null}]}}]},{