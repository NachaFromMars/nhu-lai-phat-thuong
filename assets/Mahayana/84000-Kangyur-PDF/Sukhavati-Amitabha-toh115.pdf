རིའི་བུ་ཤར་ཕྱོགས་ན་བཅོམ་ལྡན་འདས་དེ་བཞིན་གཤེགས་པ་མི་འཁྲུགས་པ་ཞེས་བྱ་བ་དང་། དེ་བཞིན་གཤེགས་པ་ལྷུན་པོའི་རྒྱལ་མཚན་ཞེས་བྱ་བ་དང་། དེ་བཞིན་གཤེགས་པ་ལྷུན་པོ་ཞེས་བྱ་བ་དང་། དེ་བཞིན་གཤེགས་པ་ལྷུན་པོ་ཆེན་པོ་ཞེས་བྱ་བ་\\nདང་། དེ་བཞིན་གཤེགས་པ་ལྷུན་པོ་ཆེན་པོ་སྣང་བ་ཞེས་བྱ་བ་དང་། དེ་བཞིན་གཤེགས་པ་འཇམ་སྒྲ་ཞེས་བྱ་བ་དང་། དེ་བཞིན་གཤེགས་པ་འཇམ་དབྱངས་ཞེས་བྱ་བ་དང་། དེ་དག་ལ་སོགས་པ་ཤར་ཕྱོགས་ཀྱི་སངས་རྒྱས་བཅོམ་ལྡན་འདས་གང་གཱའི་ཀླུང་\\nགི་བྱེ་མ་སྙེད་དག་རང་རང་གི་སངས་རྒྱས་ཀྱི་ཞིང་རྣམས་ལྗགས་ཀྱི་དབང་པོས་ཁེབས་པར་མཛད་དེ། ཁྱེད་ཅག་ཡོན་ཏན་བསམ་གྱིས་མི་ཁྱབ་པ་ཡོངས་སུ་བརྗོད་པ་སངས་རྒྱས་ཐམས་ཅད་ཀྱིས་ཡོངས་སུ་བཟུང་བའི་ཆོས་ཀྱི་རྣམ་གྲངས་འདི་ལ་ཡིད་ཆེས་པར་གྱིས་ཤིག་ཅེས་\\nགསུང་བ་མཛད་དོ། །\",\"folioNumber\":198,\"volumeNumber\":51}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":618,\"uuid\":\"ddabdb92-ed2b-46d7-b65d-49d93737a6af\"},\"content\":[{\"type\":\"text\",\"text\":\"“O \",\"attrs\":{\"start\":0,\"end\":3}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":3,\"end\":12},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"135f3abf-9fb4-4595-950f-afc4d377f8d3\",\"uuid\":\"4c4d8d15-2fd0-4f74-a487-cec738800c6e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", I, the \",\"attrs\":{\"start\":12,\"end\":21}},{\"type\":\"text\",\"text\":\"Tathāgata\",\"attrs\":{\"start\":21,\"end\":30},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"112ee268-cc96-43d6-9b25-3c948f36e0e5\",\"uuid\":\"d3c13112-451d-437b-b4e8-f9ed6bd8a2c1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", at present praise [this \",\"attrs\":{\"start\":30,\"end\":56}},{\"type\":\"text\",\"text\":\"Sukhāvatī\",\"attrs\":{\"start\":56,\"end\":65},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8cf35b98-d3a2-4bb5-b2f7-1a95c6bd693e\",\"uuid\":\"2beb402b-d620-4544-a025-3358f4674a3b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"].\",\"attrs\":{\"start\":65,\"end\":67},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"b3dfaa4f-50e0-4cdd-a1b4-21cc85d659