8ab67111551\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Furthermore, \",\"attrs\":{\"start\":203,\"end\":218}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":218,\"end\":227},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"135f3abf-9fb4-4595-950f-afc4d377f8d3\",\"uuid\":\"02a6d9d9-8034-4754-a7ea-4d2e864d4f37\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the \",\"attrs\":{\"start\":227,\"end\":233}},{\"type\":\"text\",\"text\":\"Sukhāvatī\",\"attrs\":{\"start\":233,\"end\":242},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8cf35b98-d3a2-4bb5-b2f7-1a95c6bd693e\",\"uuid\":\"175faf01-af8c-46e9-b1c6-70d536868964\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" world is surrounded on all sides by seven layers of terraces, seven rows of \",\"attrs\":{\"start\":242,\"end\":319}},{\"type\":\"text\",\"text\":\"palm trees\",\"attrs\":{\"start\":319,\"end\":329},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"dc33eabf-781b-46a7-b33f-222eda12328a\",\"uuid\":\"297a7b24-ec5a-4a7d-b973-17daede697ae\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and filigrees of chimes. It is radiantly beautiful. \",\"attrs\":{\"start\":329,\"end\":383}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":383,\"end\":392},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"135f3abf-9fb4-4595-950f-afc4d377f8d3\",\"uuid\":\"8933c17f-ce3f-4d47-8a7e-24071a87db4b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", this buddha realm is beautifully adorned with displays of the excellences of buddha realms, such as the four kinds of jewels, namely, gold, silver, \",\"attrs\":{\"start\":392,\"end\":542}},{\"type\":\"text\",\"text\":\"beryl\",\"attrs\":{\"start\":542,\"end\":547},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"352fd1e2-6817-483a-8dc6-2a68cc2cc7dd\",\"uuid\":\"b6f2cfce-f8a4-4b30-8d83-c1b79478855b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and crystal. Furthermore, \",\"attrs\":{\"start\":547,\"end\":575}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":575,\"end\":584},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"135f3abf-9fb4-4595-950f-afc4d377f8d3\",\"uuid\":\"798c1d9b-410a-4f36-9443-fa3cbddca72f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the \",\"attrs\":{\"start\":584,\"end\":590}},{\"type\":\"text\",\"text\":\"Sukhāvatī\",\"attrs\":{\"start\":590,\"end\":599},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8cf35b98-d3a2-4bb5-b2f7-1a95c6bd693e\",\"uuid\":\"82ba666e-3d9e-4466-bbaa-1277e359ee7a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" world has ponds adorned with seven kinds of jewels. The ponds are full of \",\"attrs\":{\"start\":599,\"end\":674}},{\"type\":\"text\",\"text\":\"water possessing the eight qualities\",\"attrs\":{\"start\":674,\"end\":710},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5dca12bb-41c2-4344-b250-004caab85340\",\"uuid\":\"ee0dffdc-77c7-42d5-9c47-395612d7b929\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". They are covered by jeweled lotuses, are filled to the top to enable crows to drink, and are lined with golden sand. All around, on the four sides of the ponds are four radiantly elegant staircases, each made of one of the four precious substances: gold, silver, \",\"attrs\":{\"start\":710,\"end\":975}},{\"type\":\"text\",\"text\":\"beryl\",\"attrs\":{\"start\":975,\"end\":980},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"352fd1e2-6817-483a-8dc6-2a68cc2cc7dd\",\"uuid\":\"a22c5eaa-3f31-4cd3-bb1c-5640e34813ea\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and crystal. By the banks of the ponds grow jeweled trees of the seven radiantly beautiful jewels: gold, silver, \",\"attrs\":{\"start\":980,\"end\":1095}},{\"type\":\"text\",\"text\":\"beryl\",\"attrs\":{\"start\":1095,\"end\":1100},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"352fd1e2-6817-483a-8dc6-2a68cc2cc7dd\",\"uuid\":\"17049664-944c-4b7b-af4e-b9dbfc1bb4a0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", crystal, rosy pearls, \",\"attrs\":{\"start\":1100,\"end\":1124}},{\"type\":\"text\",\"text\":\"emerald\",\"attrs\":{\"start\":1124,\"end\":1131},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"199e0291-ee9c-427a-8e31-6e47ef322b42\",\"uuid\":\"eef2388f-490e-4617-8c5a-d38b57d3c053\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and \",\"attrs\":{\"start\":1131,\"end\":1137}},{\"type\":\"text\",\"text\":\"coral\",\"attrs\":{\"start\":1137,\"end\":1142},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"6e956151-b3eb-4769-a347-3f7728356ae4\",\"uuid\":\"e1673467-0c8f-44af-b2e5-a33cdb50fe37\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". From all those ponds grow lotuses that bloom as large as chariot wheels.\",\"attrs\":{\"start\":1142,\"end\":1216}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"d0291ece-6ca2-490b-90e0-84e56ba772da\",\"sort\":350,\"type\":\"translation\",\"label\":\"1.4\",\"alignments\":{\"toh115\":{\"folioUuid\":\"ca29a4aa-0cf6-409c-ad16-5dc1a270358c\",\"toh\":\"toh115\",\"tibetan\":\"གསེར་དང་། གསེར་གྱི་ཁ་དོག །གསེར་གྱི་འོད་འབྱུང་བ། གསེར་ལྟ་བུར་སྟོན་པ། སྔོན་པོ་ཁ་དོག་སྔོན་པོ། འོད་སྔོན་པོ་འབྱུང་བ། སྔོན་པོ་ལྟ་བུར་སྟོན་པ། སེར་པོ་ཁ་དོག་སེར་པོ། འོད་སེར་པོ་འབྱུང་བ། སེར་པོ་ལྟ་བུར་སྟོན་པ། དམར་པོ་ཁ་དོག་དམར་\\nཔོ། །འོད་དམར་པོ་འབྱུང་བ། དམར་པོ་ལྟ་བུར་སྟོན་པ། དཀར་པོ། ཁ་དོག་དཀར་པོ། །འོད་དཀར་པོ་འབྱུང་བ། དཀར་པོ་ལྟ་བུར་སྟོན་པ། བཀྲ་བ། ཁ་དོག་བཀྲ་བ། འོད་བཀྲ་བ་འབྱུང་བ། བཀྲ་བ་ལྟ་བུར་སྟོན་པ། ཤིང་རྟའི་འཕང་ལོ་ཙམ་དག་སྐྱེས་སོ། །ཤཱ་རིའི་བུ་\\nསངས་རྒྱས་ཀྱི་ཞིང་དེ་ན་སངས་རྒྱས་ཀྱི་ཞིང་གི་ཡོན་ཏན་བཀོད་པ་རྣམ་པ་དེ་ལྟ་བུ་དག་གིས་ལེགས་པར་བརྒྱན་པའོ། ཤཱ་རིའི་བུ་གཞན་ཡང་འཇིག་རྟེན་གྱི་ཁམས་བདེ་བ་ཅན་ན་ལྷའི་སིལ་སྙན་གྱི་སྒྲ་རྟག་ཏུ་འབྱུང་ངོ་། །ས་ཆེན་པོ་ནི་གསེར་གྱི་ཁ་དོག་ལྟ་བུ་སྟེ་ཉམས་དགའ་བའོ། །ཤཱ་རིའི་\\nབུ་སངས་རྒྱས་ཀྱི་ཞིང་དེ་ནི་སངས་རྒྱས་ཀྱི་ཞིང་གི་ཡོན་ཏན་བཀོད་པ་རྣམ་པ་དེ་ལྟ་བུ་དག་གིས་ལེགས་པར་བརྒྱན་པའོ། །\",\"folioNumber\":196,\"volumeNumber\":51}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":806,\"uuid\":\"d0291ece-6ca2-490b-90e0-84e56ba772da\"},\"content\":[{\"type\":\"text\",\"text\":\"“The golden lotuses have a golden hue, a golden sheen, and manifest as gold. The blue ones have a blue hue, a blue sheen, and manifest as blue. The yellow ones have a yellow hue, a yellow sheen, and manifest as yellow. The red ones have a red hue, a red sheen, and manifest as red. The white ones have a white hue, a white sheen, and manifest as white. The iridescent ones have an iridescent hue, an iridescent sheen, and manifest as iridescence. \",\"attrs\":{\"start\":0,\"end\":447}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":447,\"end\":456},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"135f3abf-9fb4-4595-950f-afc4d377f8d3\",\"uuid\":\"72939fe0-c74b-4784-a04b-8fc4aa41da2d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", this buddha realm is beautifully adorned by such displays of the excellences of buddha realms. Furthermore, \",\"attrs\":{\"start\":456,\"end\":566}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":566,\"end\":575},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"135f3abf-9fb4-4595-950f-afc4d377f8d3\",\"uuid\":\"7521fddd-d0f3-47bb-b5e7-477bc1f4e152\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", in the \",\"attrs\":{\"start\":575,\"end\":584}},{\"type\":\"text\",\"text\":\"Sukhāvatī\",\"attrs\":{\"start\":584,\"end\":593},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8cf35b98-d3a2-4bb5-b2f7-1a95c6bd693e\",\"uuid\":\"8f5feafe-d535-4ef0-8959-0e1215b31c6c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" world, the sound of divine cymbals is always heard. The vast ground is magnificent, as if golden in color. \",\"attrs\":{\"start\":593,\"end\":701}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":701,\"end\":710},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"135f3abf-9fb4-4595-950f-afc4d377f8d3\",\"uuid\":\"a65e5a46-0df6-4dcf-a102-cbc489f412d2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", this buddha realm is beautifully adorned by such displays of the excellences of buddha realms.\",\"attrs\":{\"start\":710,\"end\":806}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"4a6e5072-7374-4cd8-8a31-1d769568a9ce\",\"sort\":360,\"type\":\"translation\",\"label\":\"1.5\",\"alignments\":{\"toh115\":{\"folioUuid\":\"ca29a4aa-0cf6-409c-ad16-5dc1a270358c\",\"toh\":\"toh115\",\"tibetan\":\"ཤཱ་རིའི་བུ་གཞན་ཡང་སངས་རྒྱས་ཀྱི་ཞིང་དེ་ན་ཉིན་ལན་གསུམ། མཚན་ལན་གསུམ་དུ་ལྷའི་མེ་ཏོག་མན་དཱ་ར་བའི་ལྷའི་མེ་ཏོག་གི་ཆར་འབབ་བོ། །དེར་སེམས་\\nཅན་གང་དག་སྐྱེས་པ་དེ་དག་ཀྱང་སྔ་དྲོ་གཅིག་བཞིན་དུ་སངས་རྒྱས་ཀྱི་ཞིང་གཞན་དང་གཞན་དུ་དོང་སྟེ་སངས་རྒྱས་བྱེ་བ་ཕྲག་འབུམ་ལ་ཕྱག་འཚལ་ཞིང་། དེ་བཞིན་གཤེགས་པ་རེ་རེ་ལ་ཡང་མེ་ཏོག་སྐོན་བུ་བྱེ་བ་ཕྲག་འབུམ་མངོན་པར་འཐོར་ཏེ། གཏོར་ནས་ཉིན་མོ་གནས་[F.197.a]པའི་ཕྱིར་སླར་འཇིག་རྟེན་གྱི་ཁམས་དེ་ཉིད་དུ་འདོང་ངོ་། །ཤཱ་རིའི་བུ་སངས་རྒྱས་ཀྱི་ཞིང་དེ་ནི་སངས་རྒྱས་ཀྱི་ཞིང་གི་ཡོན་ཏན་བཀོད་པ་རྣམ་པ་དེ་ལྟ་བུ་དག་གིས་ལེགས་པར་བརྒྱན་པའོ། །\",\"folioNumber\":196,\"volumeNumber\":51}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":580,\"uuid\":\"4a6e5072-7374-4cd8-8a31-1d769568a9ce\"},\"content\":[{\"type\":\"text\",\"text\":\"“Furthermore, \",\"attrs\":{\"start\":0,\"end\":14}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":14,\"end\":23},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"135f3abf-9fb4-4595-950f-afc4d377f8d3\",\"uuid\":\"30896b6b-8828-4263-b5ca-b3f817349ce4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", in that buddha realm a shower of divine flowers, divine \",\"attrs\":{\"start\":23,\"end\":81}},{\"type\":\"text\",\"text\":\"mandārava\",\"attrs\":{\"start\":81,\"end\":90},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"3467117e-28dd-43da-86cb-596f3d7434dc\",\"uuid\":\"040ea6b6-2724-498a-ac6a-e7fc5a6f88f0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" flowers, descends three times every day and three times every night. In a single morning, the sentient beings that are born there proceed from one buddha realm to the next, paying homage to hundreds of thousands of buddhas. They also toss hundreds of thousands of bouquets of flowers toward each \",\"attrs\":{\"start\":90,\"end\":387}},{\"type\":\"text\",\"text\":\"tathāgata\",\"attrs\":{\"start\":387,\"end\":396},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"112ee268-cc96-43d6-9b25-3c948f36e0e5\",\"uuid\":\"e4ced3e8-fa7e-4eb9-8532-e21eb83165de\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". After making offerings, they return to that same world for their daily rest. \",\"attrs\":{\"start\":396,\"end\":475}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":475,\"end\":484},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"135f3abf-9fb4-4595-950f-afc4d377f8d3\",\"uuid\":\"f07f6707-2361-4e69-880c-d92941813ff7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", this buddha realm is beautifully adorned by such displays of the excellences of buddha realms.\",\"attrs\":{\"start\":484,\"end\":580}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"7ad597df-a23b-472e-bebf-97b13d2240fa\",\"sort\":372,\"type\":\"translation\",\"label\":\"1.6\",\"alignments\":{\"toh115\":{\"folioUuid\":\"b899f7f6-d3b7-4c45-bcaa-f5be36b3eadf\",\"toh\":\"toh115\",\"tibetan\":\"ཤཱ་རིའི་བུ་གཞན་ཡང་འཇིག་རྟེན་གྱི་ཁམས་བདེ་བ་ཅན་ན་ངང་པ་དང་། \\nཁྲུང་ཁྲུང་དང་། རྨ་བྱ་དག་ཡོད་པ་དེ་དག་ཀྱང་ཉིན་ལན་གསུམ། མཚན་ལན་གསུམ་འདུས་ནས་ཡང་དག་པར་བགྲོ་བར་བྱེད་དེ། རང་རང་གི་སྐད་དག་གིས་སྨྲའོ། །དེ་དག་སྨྲ་བ་ན་དབང་པོ་དང་སྟོབས་དང་། བྱང་ཆུབ་ཀྱི་ཡན་ལག་གི་སྒྲ་དག་འབྱུང་ངོ་། །སེམས་\\nཅན་གང་དག་དེར་སྐྱེས་པ་དེ་དག་གིས་སྒྲ་དེ་ཐོས་ནས་སངས་རྒྱས་ཡིད་ལ་བྱེད་པ་སྐྱེ། ཆོས་ཡིད་ལ་བྱེད་པ་སྐྱེ། དགེ་འདུན་ཡིད་ལ་བྱེད་པར་སྐྱེའོ། །ཤཱ་རིའི་བུ་འདི་ཇི་སྙམ་དུ་སེམས། སེམས་ཅན་དེ་དག་དུད་འགྲོའི་སྐྱེ་གནས་སུ་གྱུར་པ་ཡིན་སྙམ་དུ་སེམས་པ་ལྟ་ན་\\nདེ་ལྟར་མི་བལྟའོ། །དེ་ཅིའི་ཕྱིར་ཞེ་ན། ཤཱ་རིའི་བུ་སངས་རྒྱས་ཀྱི་ཞིང་དེ་ན་སེམས་ཅན་དམྱལ་བ་དང་། དུད་འགྲོའི་སྐྱེ་གནས་དང་། གཤིན་རྗེའི་འཇིག་རྟེན་དུ་སྐྱེ་བའི་མིང་ཡང་མེད་དོ། །བྱའི་ཚོགས་དེ་དག་ནི་དེ་བཞིན་གཤེགས་པ་ཚེ་དཔག་མེད་དེ་ཉིད་ཀྱིས་ཆོས་\\nཀྱི་སྒྲ་དབྱུང་བའི་ཕྱིར་སྤྲུལ་པ་དག་གོ། །ཤཱ་རིའི་བུ་སངས་རྒྱས་ཀྱི་ཞིང་དེ་ནི་སངས་རྒྱས་ཀྱི་ཞིང་གི་ཡོན་ཏན་བཀོད་པ་རྣམ་པ་དེ་ལྟ་བུ་དག་གིས་ལེགས་པར་བརྒྱན་པའོ། །\",\"folioNumber\":197,\"volumeNumber\":51}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":937,\"uuid\":\"7ad597df-a23b-472e-bebf-97b13d2240fa\"},\"content\":[{\"type\":\"text\",\"text\":\"“Furthermore, \",\"attrs\":{\"start\":0,\"end\":14}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":14,\"end\":23},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"135f3abf-9fb4-4595-950f-afc4d377f8d3\",\"uuid\":\"5e77420b-e042-4fde-9f70-2422ac8db892\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", in the \",\"attrs\":{\"start\":23,\"end\":32}},{\"type\":\"text\",\"text\":\"Sukhāvatī\",\"attrs\":{\"start\":32,\"end\":41},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8cf35b98-d3a2-4bb5-b2f7-1a95c6bd693e\",\"uuid\":\"8a2ced12-e253-4294-93be-4b9e02fbe02c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" world there are swans, cranes, and peacocks that assemble three times during the day and three times at night and perform a concert, each singing its own melody. When they sing, the sounds of the \",\"attrs\":{\"start\":41,\"end\":238}},{\"type\":\"text\",\"text\":\"powers\",\"attrs\":{\"start\":238,\"end\":244},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"51f52255-edd6-4293-bc12-e2cf1728c67b\",\"uuid\":\"f21ed14e-b6e7-49bb-be2a-ff4fb9b4b07f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":244,\"end\":246}},{\"type\":\"text\",\"text\":\"strengths\",\"attrs\":{\"start\":246,\"end\":255},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f50cfb2f-a0d3-4937-abc7-32f85ec32a25\",\"uuid\":\"4d1d3f92-73f5-4352-9b67-98ab3b8574c9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and \",\"attrs\":{\"start\":255,\"end\":261}},{\"type\":\"text\",\"text\":\"branches of enlightenment\",\"attrs\":{\"start\":261,\"end\":286},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"6c29513e-d408-4dce-bf30-bb680944251e\",\"uuid\":\"18ede36b-7d9c-478f-a416-c195d37dfd11\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" emerge. Upon hearing those sounds, the sentient beings born there are moved to contemplate the Buddha, to contemplate the Dharma, and to contemplate the Saṅgha. Now what do you think about this, \",\"attrs\":{\"start\":286,\"end\":482}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":482,\"end\":491},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"135f3abf-9fb4-4595-950f-afc4d377f8d3\",\"uuid\":\"9e410df2-90c6-41bb-be17-c33fc1ee9b08\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"? Have those sentient beings taken birth as animals? You should not think so. Why is that? \",\"attrs\":{\"start\":491,\"end\":582}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":582,\"end\":591},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"135f3abf-9fb4-4595-950f-afc4d377f8d3\",\"uuid\":\"5e27c511-388d-4886-a9a7-b863eb3eb3c1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", in this buddha realm there are not even words for birth as a hell being, birth as an animal, or birth in the world of the \",\"attrs\":{\"start\":591,\"end\":715}},{\"type\":\"text\",\"text\":\"Lord of Death\",\"attrs\":{\"start\":715,\"end\":728},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"71de5a26-899a-49b1-af00-bf2dd62d6a9e\",\"uuid\":\"9e822196-48eb-414f-8060-088f9698cb4c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Those flocks of birds were manifested by the \",\"attrs\":{\"start\":728,\"end\":775}},{\"type\":\"text\",\"text\":\"Tathāgata\",\"attrs\":{\"start\":775,\"end\":784},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"112ee268-cc96-43d6-9b25-3c948f36e0e5\",\"uuid\":\"8e34fced-12f7-4361-a52c-4b2b94542bbc\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":784,\"end\":785}},{\"type\":\"text\",\"text\":\"Amitāyus\",\"attrs\":{\"start\":785,\"end\":793},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"016abcba-d2ad-4141-a0c4-a1630608c46a\",\"uuid\":\"4ae0f1c8-8148-4f64-a025-42892533284f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" himself to voice the sound of Dharma. \",\"attrs\":{\"start\":793,\"end\":832}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":832,\"end\":841},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"135f3abf-9fb4-4595-950f-afc4d377f8d3\",\"uuid\":\"58b23f01-8aed-4505-b8ae-fd7d6a578a4a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", this buddha realm is beautifully adorned by such displays of the excellences of buddha realms.\",\"attrs\":{\"start\":841,\"end\":937}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"0426a4fb-fdaa-4b64-8138-93cc6965fe36\",\"sort\":396,\"type\":\"translation\",\"label\":\"1.7\",\"alignments\":{\"toh115\":{\"folioUuid\":\"b899f7f6-d3b7-4c45-bcaa-f5be36b3eadf\",\"toh\":\"toh115\",\"tibetan\":\"ཤཱ་རིའི་བུ་གཞན་ཡང་སངས་རྒྱས་ཀྱི་ཞིང་དེའི་ཏ་ལའི་ཕྲེང་བ་དེ་དག་དང་། དྲིལ་བུ་གཡེར་\\nཀའི་དྲ་བ་དེ་དག་ལ་རླུང་གིས་ཕོག་ཅིང་རླུང་གིས་བསྐྱོད་ན་སྒྲ་སྙན་པ་ཡིད་དུ་འོང་བ། ཉམས་དགའ་བ་འབྱུང་སྟེ། འདི་ལྟ་སྟེ་དཔེར་ན། རོལ་མོ་མཁན་གྱིས་ཡན་ལག་བྱེ་བ་འབུམ་དང་ལྡན་པའི་ལྷའི་སིལ་སྙན་བླངས་པ་བཞིན་ནོ། །དེར་མི་དེ་དག་གིས་སྒྲ་དེ་ཐོས་ནས་སངས་\\nརྒྱས་རྗེས་སུ་དྲན་པ་དང་། ཆོས་རྗེས་སུ་དྲན་པ་དང་། དགེ་འདུན་རྗེས་སུ་དྲན་པ་ལུས་ལ་གནས་སོ། །ཤཱ་རིའི་བུ་སངས་རྒྱས་ཀྱི་ཞིང་དེ་ནི་སངས་རྒྱས་ཀྱི་ཞིང་གི་ཡོན་ཏན་བཀོད་པའི་རྒྱན་རྣམ་པ་དེ་ལྟ་བུ་དག་གིས་ལེགས་པར་བརྒྱན་པའོ། །\",\"folioNumber\":197,\"volumeNumber\":51}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":523,\"uuid\":\"0426a4fb-fdaa-4b64-8138-93cc6965fe36\"},\"content\":[{\"type\":\"text\",\"text\":\"“Furthermore, \",\"attrs\":{\"start\":0,\"end\":14}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":14,\"end\":23},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"135f3abf-9fb4-4595-950f-afc4d377f8d3\",\"uuid\":\"1dce9ef9-88e7-4348-9d8e-695c6eeec6ed\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", when the wind blows in that buddha realm it sways the rows of \",\"attrs\":{\"start\":23,\"end\":87}},{\"type\":\"text\",\"text\":\"palm trees\",\"attrs\":{\"start\":87,\"end\":97},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"dc33eabf-781b-46a7-b33f-222eda12328a\",\"uuid\":\"7bb1eb8f-76f8-4d95-abf8-1a44fce8db06\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and the filigree net of chimes, creating sweet, enchanting, and delightful sounds, like the myriad subtleties of divine cymbals when played by a skilled musician. The people there, upon hearing those sounds, settle into the recollection of the Buddha, the recollection of the Dharma, and the recollection of the Saṅgha. \",\"attrs\":{\"start\":97,\"end\":418}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":418,\"end\":427},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"135f3abf-9fb4-4595-950f-afc4d377f8d3\",\"uuid\":\"69a876e9-3c18-428c-bfe4-9f3befcb6c32\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", this buddha realm is beautifully adorned by such displays of the excellences of buddha realms.\",\"attrs\":{\"start\":427,\"end\":523}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"d756ea61-cee8-44b2-9f10-a986fb75f450\",\"sort\":404,\"type\":\"translation\",\"label\":\"1.8\",\"alignments\":{\"toh115\":{\"folioUuid\":\"b899f7f6-d3b7-4c45-bcaa-f5be36b3eadf\",\"toh\":\"toh115\",\"tibetan\":\"ཤཱ་རིའི་བུ་འདི་ཇི་སྙམ་དུ་སེམས།[F.197.b]ཅིའི་ཕྱིར་དེ་བཞིན་གཤེགས་པ་ཚེ་དཔག་ཏུ་མེད་ཅེས་བྱ་ཞེ་ན། ཤཱ་རིའི་བུ་དེ་བཞིན་གཤེགས་པ་ཚེ་དཔག་མེད་དེའི་ཚེའི་ཚད་དཔག་ཏུ་མེད་དེ། དེའི་ཕྱིར་དེ་བཞིན་གཤེགས་པ་ཚེ་དཔག་མེད་ཅེས་བྱའོ། །ཤཱ་རིའི་བུ་གཞན་ཡང་ཅིའི་ཕྱིར་དེ་བཞིན་གཤེགས་པ་དེ་འོད་དཔག་\\nམེད་ཅེས་བྱ་ཞེ་ན། ཤཱ་རིའི་བུ་དེ་བཞིན་གཤེགས་པ་འོད་དཔག་མེད་དེའི་འོད་སངས་རྒྱས་ཀྱི་ཞིང་ཐམས་ཅད་དུ་ཐོགས་པ་མེད་དེ། དེའི་ཕྱིར་དེ་བཞིན་གཤེགས་པ་འོད་དཔག་མེད་ཅེས་བྱའོ། །བཅོམ་ལྡན་འདས་དེ་བཞིན་གཤེགས་པ་འོད་དཔག་མེད་དེ་བླ་ན་མེད་པ་ཡང་\\nདག་པར་རྫོགས་པའི་བྱང་ཆུབ་ཏུ་མངོན་པར་རྫོགས་པར་སངས་རྒྱས་ནས་བསྐལ་པ་བཅུ་ལོན་ནོ། །\",\"folioNumber\":197,\"volumeNumber\":51}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":558,\"uuid\":\"d756ea61-cee8-44b2-9f10-a986fb75f450\"},\"content\":[{\"type\":\"text\",\"text\":\"“Now what do you think, \",\"attrs\":{\"start\":0,\"end\":24}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":24,\"end\":33},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"135f3abf-9fb4-4595-950f-afc4d377f8d3\",\"uuid\":\"380189f2-7a95-4e15-9e77-0d760f817316\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", why is that \",\"attrs\":{\"start\":33,\"end\":47}},{\"type\":\"text\",\"text\":\"tathāgata\",\"attrs\":{\"start\":47,\"end\":56},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"112ee268-cc96-43d6-9b25-3c948f36e0e5\",\"uuid\":\"1f863da8-ab9e-416a-8bf3-590002d1d2e1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" called ‘\",\"attrs\":{\"start\":56,\"end\":65}},{\"type\":\"text\",\"text\":\"Amitāyus\",\"attrs\":{\"start\":65,\"end\":73},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"016abcba-d2ad-4141-a0c4-a1630608c46a\",\"uuid\":\"468c0bad-1e75-49eb-a8a4-c6adc8c76257\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’ (Immeasurable Life)? \",\"attrs\":{\"start\":73,\"end\":96}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":96,\"end\":105},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"135f3abf-9fb4-4595-950f-afc4d377f8d3\",\"uuid\":\"cf579edc-6bc8-4250-bec6-dd9eeaf20d83\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the lifespan of the \",\"attrs\":{\"start\":105,\"end\":127}},{\"type\":\"text\",\"text\":\"Tathāgata\",\"attrs\":{\"start\":127,\"end\":136},\"mar