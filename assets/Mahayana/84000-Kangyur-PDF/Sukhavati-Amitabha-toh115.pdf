ི་བུ་གཞན་ཡང་བཅོམ་ལྡན་འདས་དེའི་ཉན་ཐོས་ཀྱི་དགེ་འདུན་དག་པ་དགྲ་བཅོམ་པ་ཤ་སྟག་ཚད་མེད་དེ། དེ་དག་གི་ཚད་བརྗོད་པར་སླ་བ་མ་ཡིན་ནོ། །ཤཱ་རིའི་\\nབུ་གཞན་ཡང་སངས་རྒྱས་ཀྱི་ཞིང་དེར་སྐྱེས་པའི་སེམས་ཅན་དག་ནི་ཕྱིར་མི་ལྡོག་པ། སྐྱེ་བ་གཅིག་གིས་ཐོགས་པའི་བྱང་ཆུབ་སེམས་དཔའ་དག་པ་ཤ་སྟག་གོ། །ཤཱ་རིའི་བུ་བྱང་ཆུབ་སེམས་དཔའ་དེ་དག་གི་ཚད་ནི་བརྗོད་པར་སླ་བ་མ་ཡིན་ཏེ། གཞན་དུ་ན་ཚད་མེད་གྲངས་\\nམེད་ཅེས་བྱ་བའི་གྲངས་སུ་འགྲོའོ། །ཤཱ་རིའི་བུ་སངས་རྒྱས་ཀྱི་ཞིང་དེ་ནི་སངས་རྒྱས་ཀྱི་ཞིང་གི་ཡོན་ཏན་བཀོད་པ་རྣམ་པ་དེ་ལྟ་བུ་དག་གིས་ལེགས་པར་བརྒྱན་པའོ། \",\"folioNumber\":197,\"volumeNumber\":51}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":523,\"uuid\":\"b63f60e8-a4d4-4dfa-8d22-6e147ac4ca78\"},\"content\":[{\"type\":\"text\",\"text\":\"“Furthermore, \",\"attrs\":{\"start\":0,\"end\":14}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":14,\"end\":23},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"135f3abf-9fb4-4595-950f-afc4d377f8d3\",\"uuid\":\"41ec62cc-110a-47af-b3d5-5b08c76c5be9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", this \",\"attrs\":{\"start\":23,\"end\":30}},{\"type\":\"text\",\"text\":\"bhagavān\",\"attrs\":{\"start\":30,\"end\":38},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ac3d1322-40ec-43b9-a027-cf2bbc3eac29\",\"uuid\":\"9a171fa9-03c7-46b9-99cd-c8d259472355\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" has an immeasurable saṅgha of \",\"attrs\":{\"start\":38,\"end\":69}},{\"type\":\"text\",\"text\":\"śrāvakas\",\"attrs\":{\"start\":69,\"end\":77},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a228dd64-edf0-47f9-8d90-55883408ec6a\",\"uuid\":\"f0a82201-c3d9-4f7e-95c0-1abd30834142\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", who are all pure \",\"attrs\":{\"start\":77,\"end\":96}},{\"type\":\"text\",\"text\":\"arhats\",\"attrs\":{\"start\":96,\"end\":102},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"69c51647-a349-4599-ae95-dbde5c407416\",\"uuid\":\"7a5357dc-0642-4391-85a1-87dd