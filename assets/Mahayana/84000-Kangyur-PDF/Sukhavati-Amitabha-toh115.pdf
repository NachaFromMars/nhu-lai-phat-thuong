":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"9ac0a29d-a4b5-49bc-a9b5-0bfc1cc38217\",\"label\":\"15\",\"uuid\":\"7a527e8c-46cd-4194-bd44-780391bff777\",\"start\":468,\"end\":468,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" and proclaim, ‘You should place your trust in this Dharma discourse called “Complete Embrace by all Buddhas,”\",\"attrs\":{\"start\":468,\"end\":578},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"d81665f2-3d46-4399-990d-130b094d69ae\",\"label\":\"16\",\"uuid\":\"22ee8a4f-73f2-42a5-850b-3192ab792882\",\"start\":578,\"end\":578,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" which praises inconceivable qualities.’\",\"attrs\":{\"start\":578,\"end\":618}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"3b95bbbf-9d29-4579-a7cb-3850adf92391\",\"sort\":564,\"type\":\"translation\",\"label\":\"1.13\",\"alignments\":{\"toh115\":{\"folioUuid\":\"f069368e-e6ad-4fb0-be5b-7d97637798cd\",\"toh\":\"toh115\",\"tibetan\":\"དེ་བཞིན་དུ་ལྷོ་ཕྱོགས་ན་དེ་བཞིན་གཤེགས་པ་ཉི་ཟླའི་སྒྲོན་མ་ཞེས་བྱ་བ་དང་། དེ་བཞིན་གཤེགས་པ་གྲགས་པ་ཞེས་བྱ་བ་དང་། དེ་བཞིན་གཤེགས་པ་གྲགས་པའི་འོད་ཅེས་བྱ་བ་དང་། དེ་བཞིན་གཤེགས་པ་འོད་འཕྲོ་ཕུང་པོ་ཞེས་བྱ་བ་[F.198.b]དང་། དེ་བཞིན་གཤེགས་པ་ལྷུན་པོའི་སྒྲོན་མ་ཞེས་བྱ་བ་དང་། དེ་བཞིན་གཤེགས་པ་བརྩོན་འགྲུས་མཐའ་ཡས་ཞེས་བྱ་བ་དང་། དེ་དག་ལ་སོགས་པ་ལྷོ་ཕྱོགས་ཀྱི་སངས་རྒྱས་བཅོམ་ལྡན་འདས་གང་གཱའི་ཀླུང་གི་བྱེ་མ་སྙེད་དག་རང་རང་གི་སངས་རྒྱས་ཀྱི་ཞིང་རྣམས་\\nལྗགས་ཀྱི་དབང་པོས་ཁེབས་པར་མཛད་དེ། ཁྱེད་ཅག་ཡོན་ཏན་བསམ་གྱིས་མི་ཁྱབ་པ་ཡོངས་སུ་བརྗོད་པ་སངས་རྒྱས་ཐམས་ཅད་ཀྱིས་ཡོངས་སུ་བཟུང་བའི་ཆོས་ཀྱི་རྣམ་གྲངས་འདི་ལ་ཡིད་ཆེས་པར་གྱིས་ཤིག་ཅེས་གསུང་བ་མཛད་དོ། །\",\"folioNumber\":198,\"volumeNumber\":51}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":524,\"uuid\":\"3b95bbbf-9d29-4579-a7cb-3850adf92391\"},\"content\":[{\"type\":\"text\",\"text\":\"“Likewise, in the south, the \",\"attrs\":{\"start\":0,\"end\":29}},{\"type\":\"text\",\"text\":\"bhagavān\",\"attrs\":{\"start\":29,\"end\":37},\"marks