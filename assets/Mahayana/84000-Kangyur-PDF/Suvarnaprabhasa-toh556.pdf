\"attrs\":{\"glossary\":\"7317e301-9d9a-41ce-9424-338eceefcc6b\",\"uuid\":\"c9dfba72-668c-4326-bbe5-1c0f05ff4bfa\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":319,\"end\":320}},{\"type\":\"text\",\"text\":\"Śākyamuni\",\"attrs\":{\"start\":320,\"end\":329},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"30470857-9228-4b50-ad00-ff8c913dc02a\",\"uuid\":\"c8681956-12da-4985-91ab-4d54214c9812\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" have such a short lifespan of eighty years?”\",\"attrs\":{\"start\":329,\"end\":374}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"60a07274-550a-4ac1-9457-151a20a6351e\",\"sort\":1692,\"type\":\"translation\",\"label\":\"2.2\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":519,\"uuid\":\"60a07274-550a-4ac1-9457-151a20a6351e\"},\"content\":[{\"type\":\"text\",\"text\":\"Then he thought, “The \",\"attrs\":{\"start\":0,\"end\":22}},{\"type\":\"text\",\"text\":\"Bhagavat\",\"attrs\":{\"start\":22,\"end\":30},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7317e301-9d9a-41ce-9424-338eceefcc6b\",\"uuid\":\"c3d172db-2df3-432b-be86-00c217249217\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" has said, ‘There are two causes and two conditions for a long life. What are those two? Forsaking killing and giving food.’ The \",\"attrs\":{\"start\":30,\"end\":159}},{\"type\":\"text\",\"text\":\"Bhagavat\",\"attrs\":{\"start\":159,\"end\":167},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7317e301-9d9a-41ce-9424-338eceefcc6b\",\"uuid\":\"2940da7e-de7c-460c-b685-871723dedfd4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":167,\"end\":168}},{\"type\":\"text\",\"text\":\"Śākyamuni\",\"attrs\":{\"start\":168,\"end\":177},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"30470857-9228-4b50-ad00-ff8c913dc02a\",\"uuid\":\"ee9602d8-72ca-4f01-af37-496c58a54ce8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" has forsaken killing and has correctly adopted\",\"attrs\":{\"start\":177,\"end\":224},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"9c6bc1ed-da03-409d-947f-30e798f1d95a\",\"label\":\"48\",\"uuid\":\"eaf05dcb-167f-46c3-aa63-3183503fdfdf\",\"start\":224,\"end\":224,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" the path of the ten good actions for countless hundreds of thousands of quintillions of \",\"attrs\":{\"start\":224,\"end\":313}},{\"type\":\"text\",\"text\":\"eons\",\"attrs\":{\"start\":313,\"end\":317},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"928932c0-6792-4c7e-a680-51bed7aee745\",\"uuid\":\"edcf9b3e-2991-45d9-bdf0-09ec03f28ee5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". He has given external and internal substances as food to beings, even to the extent\",\"attrs\":{\"start\":317,\"end\":402},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"89f1956a-18d5-4d5f-b2a7-8488a3ae805b\",\"label\":\"49\",\"uuid\":\"6ea7c0f1-ff5d-4e3e-b550-0c71c243c7c9\",\"start\":402,\"end\":402,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" of satisfying hungry beings with his own body, blood, bones, and limbs, to say nothing of every other kind of food.”\",\"attrs\":{\"start\":402,\"end\":519}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"2228856a-579f-4774-a774-62cd50864647\",\"sort\":1708,\"type\":\"translation\",\"label\":\"2.3\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":290,\"uuid\":\"2228856a-579f-4774-a774-62cd50864647\"},\"content\":[{\"type\":\"text\",\"text\":\"When that sublime being’s mind had thought that, with his attention focused upon the Buddha, his house became immense, vast, and made of blue beryl. It was adorned with many divine jewels, its color transformed by the \",\"attrs\":{\"start\":0,\"end\":218}},{\"type\":\"text\",\"text\":\"Tathāgata\",\"attrs\":{\"start\":218,\"end\":227},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e73562d6-15c5-4706-82c3-8f843ccfec58\",\"uuid\":\"87e811aa-cb1d-492b-bc3c-a291f1033f71\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\",\",\"attrs\":{\"start\":227,\"end\":228},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"b24d76d7-c8fe-49d8-8abe-95da655fe136\",\"label\":\"50\",\"uuid\":\"8b1dbb51-111a-45c2-b66f-f7701379ebc6\",\"start\":228,\"end\":228,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" and it was pervaded by a perfume that transcended the divine.\",\"attrs\":{\"start\":228,\"end\":290}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"fc7850e7-4135-487a-89d9-3252b8f3859e\",\"sort\":1714,\"type\":\"translation\",\"label\":\"2.4\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":183,\"uuid\":\"fc7850e7-4135-487a-89d9-3252b8f3859e\"},\"content\":[{\"type\":\"text\",\"text\":\"In the four directions of that house there appeared four thrones made of divine jewels. The thrones were overspread with layers\",\"attrs\":{\"start\":0,\"end\":127},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"ae718c49-d51c-4b80-8251-e8c4c0349c76\",\"label\":\"51\",\"uuid\":\"7d8565fc-62eb-49f9-a4dc-cbe80a7ea169\",\"start\":127,\"end\":127,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" of precious, divine cloth decorated with divine jewels.\",\"attrs\":{\"start\":127,\"end\":183},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"d813d6c6-ce33-43d7-bafa-f227875ad0d8\",\"label\":\"52\",\"uuid\":\"b0585e23-5da8-4f2f-b4f7-3fd65d07f3dc\",\"start\":183,\"end\":183,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"12e5fa1f-174a-4fff-8c40-3aa0b5e1c257\",\"sort\":1719,\"type\":\"translation\",\"label\":\"2.5\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1346,\"uuid\":\"12e5fa1f-174a-4fff-8c40-3aa0b5e1c257\"},\"content\":[{\"type\":\"text\",\"text\":\"Upon those\",\"attrs\":{\"start\":0,\"end\":10},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"659fdbf8-be3b-4a3a-8d00-a84f2485883b\",\"label\":\"53\",\"uuid\":\"b9407d76-d36e-4293-8f0e-513745a1e262\",\"start\":10,\"end\":10,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" thrones appeared divine lotus flowers, their colors transformed by the \",\"attrs\":{\"start\":10,\"end\":82}},{\"type\":\"text\",\"text\":\"Tathāgata\",\"attrs\":{\"start\":82,\"end\":91},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e73562d6-15c5-4706-82c3-8f843ccfec58\",\"uuid\":\"df464f21-fd0b-4567-a86c-f2f24fcbac53\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\",\",\"attrs\":{\"start\":91,\"end\":92},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"d9e04992-a786-445d-b1d3-832c7efb6334\",\"label\":\"54\",\"uuid\":\"e8bd2380-9d9a-4e85-a49c-57e63e2341f3\",\"start\":92,\"end\":92,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" and adorned by many jewels. Upon those lotuses there appeared the four buddha \",\"attrs\":{\"start\":92,\"end\":171}},{\"type\":\"text\",\"text\":\"bhagavats\",\"attrs\":{\"start\":171,\"end\":180},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7317e301-9d9a-41ce-9424-338eceefcc6b\",\"uuid\":\"5b02bf1f-cd62-485a-aed4-92c4640726e9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". To the east appeared the \",\"attrs\":{\"start\":180,\"end\":207}},{\"type\":\"text\",\"text\":\"Tathāgata\",\"attrs\":{\"start\":207,\"end\":216},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e73562d6-15c5-4706-82c3-8f843ccfec58\",\"uuid\":\"0550b89a-b1c7-4591-b705-e14e645c3d72\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":216,\"end\":217}},{\"type\":\"text\",\"text\":\"Akṣobhya\",\"attrs\":{\"start\":217,\"end\":225},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"15b53e78-cf61-4aec-86bd-5380bbcb3129\",\"uuid\":\"e3803d06-ac7e-4b70-aa8d-e3e08a6e0a9d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". To the south appeared the \",\"attrs\":{\"start\":225,\"end\":253}},{\"type\":\"text\",\"text\":\"Tathāgata\",\"attrs\":{\"start\":253,\"end\":262},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e73562d6-15c5-4706-82c3-8f843ccfec58\",\"uuid\":\"011b437f-419d-4fda-a01f-f43336c3700f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":262,\"end\":263}},{\"type\":\"text\",\"text\":\"Ratnaketu\",\"attrs\":{\"start\":263,\"end\":272},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c10c0c1a-4fb8-494d-916f-0269e31c11bc\",\"uuid\":\"e70125e7-7ee4-4cb6-9d28-9871777aa24b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". To the west appeared the \",\"attrs\":{\"start\":272,\"end\":299}},{\"type\":\"text\",\"text\":\"Tathāgata\",\"attrs\":{\"start\":299,\"end\":308},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e73562d6-15c5-4706-82c3-8f843ccfec58\",\"uuid\":\"db151d9c-7339-42c2-b02d-f1f25beeff2c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":308,\"end\":309}},{\"type\":\"text\",\"text\":\"Amitābha\",\"attrs\":{\"start\":309,\"end\":317},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b4043124-016c-46e7-b162-8a823ecbce68\",\"uuid\":\"9967ed04-3938-42f7-9f69-b84ee6a44118\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". To the north appeared the \",\"attrs\":{\"start\":317,\"end\":345}},{\"type\":\"text\",\"text\":\"Tathāgata\",\"attrs\":{\"start\":345,\"end\":354},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e73562d6-15c5-4706-82c3-8f843ccfec58\",\"uuid\":\"bb62f120-da79-4bb0-9653-6703911a33b0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":354,\"end\":355}},{\"type\":\"text\",\"text\":\"Dundubhisvara\",\"attrs\":{\"start\":355,\"end\":368},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"49c93315-1451-4874-87c0-974a619ab4e8\",\"uuid\":\"92245f75-786c-40c6-a9f0-c59294992d8e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". At the moment when those buddha \",\"attrs\":{\"start\":368,\"end\":402}},{\"type\":\"text\",\"text\":\"bhagavats\",\"attrs\":{\"start\":402,\"end\":411},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7317e301-9d9a-41ce-9424-338eceefcc6b\",\"uuid\":\"bb476708-bf3a-4530-81a7-a474647d720c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" appeared upon those lion thrones, the great city of \",\"attrs\":{\"start\":411,\"end\":464}},{\"type\":\"text\",\"text\":\"Rājagṛha\",\"attrs\":{\"start\":464,\"end\":472},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8a64da85-ad7e-4c47-b376-c981f1c2a4b2\",\"uuid\":\"614e0ba7-44a6-4091-851f-ffecefbd18e2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" was filled by a great illuminating light. That light spread throughout the \",\"attrs\":{\"start\":472,\"end\":548}},{\"type\":\"text\",\"text\":\"trichiliocosm\",\"attrs\":{\"start\":548,\"end\":561},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"15fc18c2-88b8-4b6b-80b5-7b16a0dc9174\",\"uuid\":\"9c1234d4-e6de-464d-9891-8395e8ad0779\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" world realm, throughout as many world realms in the ten directions as there are grains of sand in the \",\"attrs\":{\"start\":561,\"end\":664}},{\"type\":\"text\",\"text\":\"Ganges\",\"attrs\":{\"start\":664,\"end\":670},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f1f547b8-a278-490a-9223-f949fcad521b\",\"uuid\":\"ede82635-1f40-46f3-8886-62504d7b4540\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" River. A rain of flowers fell. There came the sound of divine music. Through the power of the Buddha, all beings in this \",\"attrs\":{\"start\":670,\"end\":792}},{\"type\":\"text\",\"text\":\"trichiliocosm\",\"attrs\":{\"start\":792,\"end\":805},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"15fc18c2-88b8-4b6b-80b5-7b16a0dc9174\",\"uuid\":\"271e4e1d-f0a3-4647-943f-d98394293b63\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" world realm gained divine happiness. Those who had incomplete faculties gained all their faculties. The blind saw forms with their eyes; the deaf heard sounds with their ears; the insane gained their sanity; those with distracted\",\"attrs\":{\"start\":805,\"end\":1035},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"80d61e93-794e-4614-a023-a0307209ebde\",\"label\":\"55\",\"uuid\":\"99b7d70b-3f0c-4cf3-a3fa-278098656fc8\",\"start\":1035,\"end\":1035,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" minds became undistracted; the naked became clothed; the hungry had their stomachs filled; the thirsty found drink;\",\"attrs\":{\"start\":1035,\"end\":1151},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"35fafcb1-bffa-49ad-8a92-8008f7bc5160\",\"label\":\"56\",\"uuid\":\"6434a676-102c-43d0-9cf7-5fd6306fbef4\",\"start\":1151,\"end\":1151,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" beings afflicted by illness were healed; and those with impaired physical faculties became possessed of complete faculties. In those worlds there appeared vast, astonishing, wonderful qualities.\",\"attrs\":{\"start\":1151,\"end\":1346}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"cb9db483-a68d-404f-88dc-b36304ac3c8a\",\"sort\":1761,\"type\":\"translation\",\"label\":\"2.6\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":476,\"uuid\":\"cb9db483-a68d-404f-88dc-b36304ac3c8a\"},\"content\":[{\"type\":\"text\",\"text\":\"The bodhisattva\",\"attrs\":{\"start\":0,\"end\":15},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"044cf6df-a11f-4249-b1ed-3056252c12e2\",\"label\":\"57\",\"uuid\":\"392b27f9-7ba2-4f57-b284-01c2d6ac770f\",\"start\":15,\"end\":15,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":15,\"end\":16}},{\"type\":\"text\",\"text\":\"Ruciraketu\",\"attrs\":{\"start\":16,\"end\":26},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"727c3a9f-2dae-46b4-89e7-d5f8bedeb247\",\"uuid\":\"cf287644-6051-451c-8c20-9eebfc0b00b3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" was amazed to see those buddha \",\"attrs\":{\"start\":26,\"end\":58}},{\"type\":\"text\",\"text\":\"bhagavats\",\"attrs\":{\"start\":58,\"end\":67},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7317e301-9d9a-41ce-9424-338eceefcc6b\",\"uuid\":\"149d0a8d-5430-4048-bf2a-ec3064f1e389\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and, filled with joy, delighted, elated, pleased, and happy, with his palms together in homage, he bowed toward those buddha \",\"attrs\":{\"start\":67,\"end\":194}},{\"type\":\"text\",\"text\":\"bhagavats\",\"attrs\":{\"start\":194,\"end\":203},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7317e301-9d9a-41ce-9424-338eceefcc6b\",\"uuid\":\"780b9eb2-c16b-4244-9844-2925ec1f8317\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Mindful of those buddha \",\"attrs\":{\"start\":203,\"end\":229}},{\"type\":\"text\",\"text\":\"bhagavats\",\"attrs\":{\"start\":229,\"end\":238},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7317e301-9d9a-41ce-9424-338eceefcc6b\",\"uuid\":\"577be787-52ce-41b4-bd82-48f0307768d0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and mindful of the qualities of the Buddha \",\"attrs\":{\"start\":238,\"end\":282}},{\"type\":\"text\",\"text\":\"Bhagavat\",\"attrs\":{\"start\":282,\"end\":290},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7317e301-9d9a-41ce-9424-338eceefcc6b\",\"uuid\":\"f045ad57-854d-476b-b2e0-6c14e8b4ca52\",\"toh\":null}}]},{\"type\":\"text\"