,\"uuid\":\"fa88895d-e4c7-43fb-9907-3f45fd00f79a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":242,\"end\":243}},{\"type\":\"text\",\"text\":\"Mahāmaudgalyāyana\",\"attrs\":{\"start\":243,\"end\":260},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"69a9cbc7-a145-499e-be6c-54c36e84f199\",\"uuid\":\"00914c27-0875-44a7-b425-473d348e07f0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and \",\"attrs\":{\"start\":260,\"end\":266}},{\"type\":\"text\",\"text\":\"Ānanda\",\"attrs\":{\"start\":266,\"end\":272},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"25d30c62-21d4-45f4-aa28-a30a59ba2248\",\"uuid\":\"64f7755d-ce70-46ec-9a63-c2f065e38331\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". These and the other great \",\"attrs\":{\"start\":272,\"end\":300}},{\"type\":\"text\",\"text\":\"śrāvakas\",\"attrs\":{\"start\":300,\"end\":308},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"df2147ef-e586-4828-a111-730705966794\",\"uuid\":\"510f851b-c033-40fd-9429-edd143675640\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" had each risen in the afternoon from resting inwardly and had come into the presence of the \",\"attrs\":{\"start\":308,\"end\":401}},{\"type\":\"text\",\"text\":\"Bhagavat\",\"attrs\":{\"start\":401,\"end\":409},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7317e301-9d9a-41ce-9424-338eceefcc6b\",\"uuid\":\"ec077784-8eb9-4259-ae9d-40e176173e58\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", bowed down their heads to the feet of the \",\"attrs\":{\"start\":409,\"end\":453}},{\"type\":\"text\",\"text\":\"Bhagavat\",\"attrs\":{\"start\":453,\"end\":461},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7317e301-9d9a-41ce-9424-338eceefcc6b\",\"uuid\":\"a59148a1-7d6a-4fc1-b7c7-5df060f6bb6d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", circumambulated him three times, and sat to one side.\",\"attrs\":{\"start\":461,\"end\":516}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"d1168543-98bf-4a26-8a3e-50c3af6289ba\",\"sort\":1007,\"type\":\"translation\",\"label\":\"1.3\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1842,\"uuid\":\"d1168543-98bf-4a26-8a3e-50c3af6289ba\"},\"content\":[{\"type\":\"text\",\"text\":\"A trillion\",\"attrs\":{\"start\":0,\"end\":10},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"209d87c4-f78c-44fb-aaac-a2ee8d6a433e\",\"label\":\"24\",\"uuid\":\"1778d692-1958-4995-b1b0-7f73a2428fae\",\"start\":10,\"end\":10,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" bodhisattva \",\"attrs\":{\"start\":10,\"end\":23}},{\"type\":\"text\",\"text\":\"mahāsattvas\",\"attrs\":{\"start\":23,\"end\":34},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d1c7dfac-7376-48af-bc36-07491c77e7ac\",\"uuid\":\"91f4dded-4e97-407f-990d-f24715e97513\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" were also gathered there. They were renowned because of being endowed with great brilliance and glory like the great kings of the \",\"attrs\":{\"start\":34,\"end\":165}},{\"type\":\"text\",\"text\":\"nāgas\",\"attrs\":{\"start\":165,\"end\":170},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5a08fb0f-b8eb-4159-8018-bfd9bd66d5d9\",\"uuid\":\"d0281afc-c3b0-4802-9d56-3ade6764e8ee\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". They aspired to always maintain generosity and pure conduct; they had practiced patience and diligence for countless \",\"attrs\":{\"start\":170,\"end\":289}},{\"type\":\"text\",\"text\":\"eons\",\"attrs\":{\"start\":289,\"end\":293},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"928932c0-6792-4c7e-a680-51bed7aee745\",\"uuid\":\"128b1683-8247-46c9-8e73-edfa21c9775f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"; they manifested the mindfulness that transcends all \",\"attrs\":{\"start\":293,\"end\":347}},{\"type\":\"text\",\"text\":\"dhyānas\",\"attrs\":{\"start\":347,\"end\":354},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7df1427c-236b-4443-b0e5-2a5da6419026\",\"uuid\":\"d4525b31-2483-40a9-b44d-786d4e0dee8d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"; they had opened the door to wisdom; they had accomplished skill in methods; they enjoyed sublime sensory \",\"attrs\":{\"start\":354,\"end\":461}},{\"type\":\"text\",\"text\":\"powers\",\"attrs\":{\"start\":461,\"end\":467},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"52ea6881-4383-4b08-a074-1e566dc75917\",\"uuid\":\"5c3ae762-ff8c-4ddc-b1da-aba5d4180da4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and had acquired clairvoyance; they had attained the great power of mental \",\"attrs\":{\"start\":467,\"end\":543}},{\"type\":\"text\",\"text\":\"retention\",\"attrs\":{\"start\":543,\"end\":552},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"46efeb6b-88fc-404c-a409-46b148a31cf0\",\"uuid\":\"60b90da3-c26e-4710-baf5-511df3eab971\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"; they had unceasing eloquence; they had eliminated all \",\"attrs\":{\"start\":552,\"end\":608}},{\"type\":\"text\",\"text\":\"kleśas\",\"attrs\":{\"start\":608,\"end\":614},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f8b603ad-07d1-4b0b-8c9a-e94d5caa865e\",\"uuid\":\"af51bee4-8aa9-4bc5-b5de-76ae7c2b33c9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and \",\"attrs\":{\"start\":614,\"end\":619}},{\"type\":\"text\",\"text\":\"afflictions\",\"attrs\":{\"start\":619,\"end\":630},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"45a48b06-14a4-4a11-beac-df1118f20976\",\"uuid\":\"fb7f6e7a-2362-499c-8963-bc9af9a0b156\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"; they had quickly attained omniscient wisdom and defeated Māra and the hosts of adversaries; through beating the drum of the Dharma they subdued all \",\"attrs\":{\"start\":630,\"end\":780}},{\"type\":\"text\",\"text\":\"tīrthikas\",\"attrs\":{\"start\":780,\"end\":789},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4b2c2119-6dd4-4607-afda-9c0ea3cd6860\",\"uuid\":\"e13e63b4-edda-427d-b8d1-a4fd03e1d62a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and caused them to develop clear minds; through turning the wheel of the Dharma they liberated \",\"attrs\":{\"start\":789,\"end\":885}},{\"type\":\"text\",\"text\":\"devas\",\"attrs\":{\"start\":885,\"end\":890},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a09787ca-2952-4bf6-a04c-bde6f4cf3e40\",\"uuid\":\"3b64adcb-e03a-4e92-8e22-3128b82950b0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and humans; they adorned all the buddha realms in the ten directions; they brought benefit to those who dwelled in the six existences; they had consummate great wisdom; they were endowed with great patience; they were endowed with love; they maintained the motivation of great compassion; they had enduring great might; they served all the buddhas; they did not pass into \",\"attrs\":{\"start\":890,\"end\":1263}},{\"type\":\"text\",\"text\":\"nirvāṇa\",\"attrs\":{\"start\":1263,\"end\":1270},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bebe04fd-2b22-4637-89db-ae1cd69dffe1\",\"uuid\":\"efa3f756-e067-42e5-afbf-e131c7b0c711\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", but instead maintained the great commitment to remain until the future’s end; they had developed pure causes in the presence of many buddhas; they had attained patience toward the quality of birthlessness of the phenomena of the three times; they had completely transcended the field of activity of the \",\"attrs\":{\"start\":1270,\"end\":1575}},{\"type\":\"text\",\"text\":\"śrāvakas\",\"attrs\":{\"start\":1575,\"end\":1583},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"df2147ef-e586-4828-a111-730705966794\",\"uuid\":\"fcbc3889-2e32-4b66-b162-173c939244f2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and \",\"attrs\":{\"start\":1583,\"end\":1588}},{\"type\":\"text\",\"text\":\"pratyekabuddhas\",\"attrs\":{\"start\":1588,\"end\":1603},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"dd537b63-172f-4115-ac04-ef342e1774b7\",\"uuid\":\"523055e1-bbe3-41ba-ab8a-ef1b59b21493\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"; with great skill in methods they were skilled in explaining the implied meaning of the profound Dharma taught by the great teachers, the guides of the world; and they had cut through all doubts through the direct perception of emptiness.\",\"attrs\":{\"start\":1603,\"end\":1842}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"3daf33d4-d723-43ee-9876-e21c99bbbb1b\",\"sort\":1037,\"type\":\"translation\",\"label\":\"1.4\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":2407,\"uuid\":\"3daf33d4-d723-43ee-9876-e21c99bbbb1b\"},\"content\":[{\"type\":\"text\",\"text\":\"Among them were the bodhisattva \",\"attrs\":{\"start\":0,\"end\":32}},{\"type\":\"text\",\"text\":\"Anāvaraṇa­dharma­cakra­varta\",\"attrs\":{\"start\":32,\"end\":60},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cb7577e3-d76f-4598-93c0-76a3991799cb\",\"uuid\":\"993b8dd6-615d-4054-8594-d3dfa0592514\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the bodhisattva \",\"attrs\":{\"start\":60,\"end\":78}},{\"type\":\"text\",\"text\":\"Aspiring to Always Turn the Dharma Wheel\",\"attrs\":{\"start\":78,\"end\":118},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cd64ca4d-45fd-4ab3-9701-125845e35df4\",\"uuid\":\"c71cc09b-e540-4660-84fb-7079f5a22aa3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the bodhisattva \",\"attrs\":{\"start\":118,\"end\":136}},{\"type\":\"text\",\"text\":\"Nityodyukta\",\"attrs\":{\"start\":136,\"end\":147},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"60d12d7e-1f7e-4517-b2d1-5bae24cae7db\",\"uuid\":\"9cc4db87-0bf