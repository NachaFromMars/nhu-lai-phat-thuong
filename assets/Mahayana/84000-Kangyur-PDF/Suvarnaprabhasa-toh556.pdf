text\":\", together with a \",\"attrs\":{\"start\":320,\"end\":338}},{\"type\":\"text\",\"text\":\"saṅgha\",\"attrs\":{\"start\":338,\"end\":344},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7078fbd0-e398-4d44-b061-a6b5fe6bfce4\",\"uuid\":\"8512ce8d-fe89-4d99-91e0-caadc766b1f2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of ninety-eight thousand\",\"attrs\":{\"start\":344,\"end\":369},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"28d92c9f-59b9-4e8e-95a4-c1eb50e9771d\",\"label\":\"23\",\"uuid\":\"5114e136-b1d4-4773-a6f3-a9424a736b3a\",\"start\":369,\"end\":369,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" great \",\"attrs\":{\"start\":369,\"end\":376}},{\"type\":\"text\",\"text\":\"bhikṣus\",\"attrs\":{\"start\":376,\"end\":383},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5365d0e6-91d5-4ce8-8796-a14339d6e504\",\"uuid\":\"8a2eb428-1d53-478f-907e-d3a2f9182919\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". All of them were great \",\"attrs\":{\"start\":383,\"end\":408}},{\"type\":\"text\",\"text\":\"arhats\",\"attrs\":{\"start\":408,\"end\":414},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9a49890c-94f8-4129-9740-fac8887e030b\",\"uuid\":\"83e60d0f-ca6e-4afa-99a1-f64ef9a00172\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", perfectly tamed like the king of elephants. Their \",\"attrs\":{\"start\":414,\"end\":466}},{\"type\":\"text\",\"text\":\"defilements\",\"attrs\":{\"start\":466,\"end\":477},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f8703e2c-28d1-4072-87d5-c8898004245d\",\"uuid\":\"9dd3292e-5848-4554-aa6e-9cd8bc4e1e2a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" had ceased, they were devoid of \",\"attrs\":{\"start\":477,\"end\":510}},{\"type\":\"text\",\"text\":\"kleśas\",\"attrs\":{\"start\":510,\"end\":516},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f8b603ad-07d1-4b0b-8c9a-e94d5caa865e\",\"uuid\":\"f2503133-cae3-4736-bc92-ec54494c1a44\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", their minds were completely liberated, their wisdom was completely liberated, they had done what had to be done, they had put down their burdens, they had attained their goals, they had cut through engagement with existence, they had attained supreme and sublime power, they had perfectly maintained pure conduct, they were arrayed with methods and wisdom, they had manifested the \",\"attrs\":{\"start\":516,\"end\":899}},{\"type\":\"text\",\"text\":\"eight liberations\",\"attrs\":{\"start\":899,\"end\":916},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"df742301-a2f1-43ee-ab72-6150dc202923\",\"uuid\":\"3dce7b7c-bfc2-4400-8c4b-28d22a34a103\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and they had reached the farther shore.\",\"attrs\":{\"start\":916,\"end\":957}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"838d1e9e-4dce-464e-8277-fd1d86dc3898\",\"sort\":952,\"type\":\"translation\",\"label\":\"1.2\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":516,\"uuid\":\"838d1e9e-4dce-464e-8277-fd1d86dc3898\"},\"content\":[{\"type\":\"text\",\"text\":\"Their names were \",\"attrs\":{\"start\":0,\"end\":17}},{\"type\":\"text\",\"text\":\"Venerable\",\"attrs\":{\"start\":17,\"end\":26},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"36789778-dfff-49f5-919b-5ef4da528975\",\"uuid\":\"16e512c0-dc13-43a3-a731-d91b495bc4ee\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":26,\"end\":27}},{\"type\":\"text\",\"text\":\"Kauṇḍinya\",\"attrs\":{\"start\":27,\"end\":36},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"aa2c2a31-ffdb-4887-a677-972a8ec87ca3\",\"uuid\":\"719668fa-e276-4296-853d-ed9b2e4ab30c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":36,\"end\":38}},{\"type\":\"text\",\"text\":\"Venerable\",\"attrs\":{\"start\"