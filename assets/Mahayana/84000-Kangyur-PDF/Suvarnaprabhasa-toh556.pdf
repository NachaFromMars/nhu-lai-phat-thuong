7},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"30470857-9228-4b50-ad00-ff8c913dc02a\",\"uuid\":\"fc68e2da-cd85-400b-89d7-8297adf29749\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", asked those \",\"attrs\":{\"start\":97,\"end\":111}},{\"type\":\"text\",\"text\":\"bhagavats\",\"attrs\":{\"start\":111,\"end\":120},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7317e301-9d9a-41ce-9424-338eceefcc6b\",\"uuid\":\"20bd2e5a-0333-45d7-bfda-b83e722677b6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", “Why is it that the \",\"attrs\":{\"start\":120,\"end\":142}},{\"type\":\"text\",\"text\":\"Bhagavat\",\"attrs\":{\"start\":142,\"end\":150},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7317e301-9d9a-41ce-9424-338eceefcc6b\",\"uuid\":\"d95a035e-7f25-45d5-a3c9-040ad34b1037\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":150,\"end\":151}},{\"type\":\"text\",\"text\":\"Śākyamuni\",\"attrs\":{\"start\":151,\"end\":160},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"30470857-9228-4b50-ad00-ff8c913dc02a\",\"uuid\":\"a29616ca-e9b0-45c5-b6a8-33cc01593041\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the \",\"attrs\":{\"start\":160,\"end\":166}},{\"type\":\"text\",\"text\":\"Tathāgata\",\"attrs\":{\"start\":166,\"end\":175},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e73562d6-15c5-4706-82c3-8f843ccfec58\",\"uuid\":\"2ca9b33d-6f22-4cac-a4e6-189848b57e96\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", manifests such a short lifespan?”\",\"attrs\":{\"start\":175,\"end\":210}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"9476eed3-166f-4442-9210-fa901c80ae16\",\"sort\":1954,\"type\":\"translation\",\"label\":\"2.19\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":742,\"uuid\":\"9476eed3-166f-4442-9210-fa901c80ae16\"},\"content\":[{\"type\":\"text\",\"text\":\"The \",\"attrs\":{\"start\":0,\"end\":4}}