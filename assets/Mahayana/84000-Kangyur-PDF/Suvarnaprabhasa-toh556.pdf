ibetan\":\"སྤྲིན་ཆེན་ཉི་མའི་སྙིང་པོ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sprin chen nyi ma’i snying po\"}},{\"uuid\":\"3c52996b-395b-4b4d-b683-286f81ce8f3e\",\"authority\":\"b4ddd22a-7af5-4c1b-9ece-3e1c9565dacb\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA bodhisattva.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003esprin chen glang po che’i rgyal po’i sgra\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Great Cloud Supreme Bull’s Sound\",\"tibetan\":\"སྤྲིན་ཆེན་ཁྱུ་མཆོག་སྒྲ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sprin chen khyu mchog sgra\"}},{\"uuid\":\"112de0ee-cfda-4cc6-a6da-04a1e00d118f\",\"authority\":\"05a13fb3-8dbb-490c-ba17-236b51fed417\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA bodhisattva.\u003c/p\u003e\",\"names\":{\"english\":\"Great Cloud Thunder\",\"tibetan\":\"སྤྲིན་ཆེན་འབྲུག་སྒྲ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sprin chen ’brug sgra\"}},{\"uuid\":\"397485f6-6d97-4d20-9192-9f341f88e6aa\",\"authority\":\"5854560a-e633-48c9-815c-fabcddc6c141\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA bodhisattva.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003esprin chen pad ma sngon po’i bsung\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Great Cloud Utpala Scent\",\"tibetan\":\"སྤྲིན་ཆེན་ཨུཏྤ་ལའི་དྲི།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sprin chen ut+pa la’i dri\"}},{\"uuid\":\"af7e774d-e8cf-42b6-bd3b-3a56a7e22a5a\",\"authority\":\"4973254d-39d6-46ed-9464-481197dfc968\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA bodhisattva.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003echos kyi stobs\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Great Dharma Power\",\"tibetan\":\"ཆོས་ཆེན་མཐུ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chos chen mthu\"}},{\"uuid\":\"1e658181-745d-48fa-a42d-9005e02178df\",\"authority\":\"e5d53172-e917-4eb4-a4b2-c96752dff6cf\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2496\\\"\u003eLicchavī\u003c/span\u003e youth.\u003c/p\u003e\",\"names\":{\"english\":\"Great Glory\",\"tibetan\":\"དཔལ་ཆེན།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dpal chen\"}},{\"uuid\":\"4aa0c900-0a02-403c-b168-16fb992da4b7\",\"authority\":\"2d9b173e-a2bb-42a7-915e-0cc7f53e696d\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA bodhisattva.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003egser gyi ’od rgyan chen po\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Great Golden Radiant Array\",\"tibetan\":\"གསེར་འོད་ཆེན་པོས་བཀོད་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gser ’od chen pos bkod pa\"}},{\"uuid\":\"3c825a14-1bd0-4316-ab08-ba32150f5d52\",\"authority\":\"7d83173b-2917-4232-9327-1b5ce14f843f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA buddha in the distant past.\u003c/p\u003e\",\"names\":{\"english\":\"Great Mass of Light\",\"tibetan\":\"འོད་ཟེར་གྱི་ཕུང་པོ་ཆེན་པོ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’od zer gyi phung po chen po\"}},{\"uuid\":\"1e66b66e-9bfc-46c1-b8df-e40219dad81b\",\"authority\":\"ae395a35-cc0b-435d-9306-6575e741ef7f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA bodhisattva.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eMahā­gaṃbhīra­sagara­rāja\u003c/em\u003e; \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ergya mtsho chen po zab mo’i rgyal po\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Great Ocean Profound King\",\"tibetan\":\"རྒྱ་མཚོ་ཆེན་པོ་ཟབ་མོའི་རྒྱལ་པོ།, རྒྱ་མཚོ་ཟབ་མོའི་རྒྱལ་པོ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rgya mtsho chen po zab mo’i rgyal po, rgya mtsho zab mo’i rgyal po\"}},{\"uuid\":\"6fe41eb7-981f-4a84-a922-29b4346bc742\",\"authority\":\"b3305aea-8e2b-41da-add1-2aee0160a4eb\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e king.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003egangs ri\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Haimavata\",\"tibetan\":\"གངས་ཅན།\",\"sanskrit\":\"haimavata\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gangs can\"}},{\"uuid\":\"ade43d84-6dad-4353-a0c0-6727824bdf62\",\"authority\":\"5ed70a45-5f9c-41dd-a151-0ef85d727e46\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eUnidentified deity. Possibly Kṛṣṇa.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003eAcording to Lithang and Cone. Degé, etc.: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ehi ri tshig ’chang\u003c/em\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Haridhara\",\"tibetan\":\"ཧ་རི་ཚིག་འཆང་།\",\"sanskrit\":\"haridhara\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ha ri tshig ’chang\"}},{\"uuid\":\"a86fd94d-a590-4d6e-a1cb-7d09167009ef\",\"authority\":\"e05f6ba7-cb97-49c0-be99-3e03491b9ed8\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA rākṣasī with hundreds of children whom the Buddha converted into a protector of children.\u003c/p\u003e\",\"names\":{\"english\":\"Hārītī\",\"tibetan\":\"འཕྲོག་མ།\",\"sanskrit\":\"hārītī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’phrog ma\"}},{\"uuid\":\"d552a07d-7371-461a-ad95-aea6f645ee57\",\"authority\":\"a788cae8-0c9d-45be-ac4b-eda48948b0c8\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe higher cognitions are listed as either five or six. The first five are divine sight, divine hearing, knowing how to manifest miracles, remembering previous lives, and knowing what is in the minds of others. A sixth, knowing that all defects have been eliminated, is often added. The first five are attained through concentration (Skt. \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-089-013-2564\\\"\u003edhyāna\u003c/span\u003e\u003c/em\u003e), and are sometimes described as worldly, as they can be attained to some extent by non-Buddhist yogis, while the sixth is supramundane and attained only by realization.\u003c/p\u003e\",\"names\":{\"english\":\"higher cognitions\",\"tibetan\":\"མངོན་པར་ཤེས་པ།\",\"sanskrit\":\"abhijñā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mngon par shes pa\"}},{\"uuid\":\"0ba28d7c-6a60-4c4a-bd45-86d77cf4a50a\",\"authority\":\"59ebcaf2-1ccb-434e-acf2-3ef339e96462\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA buddha.\u003c/p\u003e\",\"names\":{\"english\":\"Highest Jewels\",\"tibetan\":\"རིན་ཆེན་བླ་མ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rin chen bla ma\"}},{\"uuid\":\"e9385054-b5d4-4219-ab26-746fec21764c\",\"authority\":\"9bbd3fbe-22d5-47c2-9d39-e88ec535ea91\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThis term is uncommon in the Kangyur as it seems to appear only in this sūtra and in Toh 555. It is found in Yijing’s Chinese version from which the Tibetan translation of Toh 555 was produced. It may originally have been a reference to the \u003cspan data-glossary-id=\\\"UT22084-089-013-2535\\\"\u003eeighteen unique qualities of a buddha\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"hundred and eighty unique qualities\",\"tibetan\":\"མ་འདྲེས་པའི་ཆོས་བརྒྱ་བརྒྱད་ཆུ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ma ’dres pa’i chos brgya brgyad chu\"}},{\"uuid\":\"af375b98-b3cb-4a94-84a5-e08e3619f09f\",\"authority\":\"c514fbee-7a6a-4c3a-b636-377cdb911983\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA god who is the king of lightning in the southern direction.\u003c/p\u003e\",\"names\":{\"english\":\"Hundredth Moment\",\"tibetan\":\"སྐད་བརྒྱ་པ།\",\"sanskrit\":\"kṣaṇaśatara\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"skad brgya pa\"}},{\"uuid\":\"abd01d6a-5c3f-4893-9180-11e662e0741b\",\"authority\":\"7ca79d81-6bcc-455a-9727-fcd026696953\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA world realm in the distant future.\u003c/p\u003e\",\"names\":{\"english\":\"Immaculate Banner\",\"tibetan\":\"རྡུལ་དང་བྲལ་བའི་རྒྱལ་མཚན།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rdul dang bral ba’i rgyal mtshan\"}},{\"uuid\":\"ab968d0b-817f-47cc-aa92-1afebfb1bda8\",\"authority\":\"b1f0c238-c324-4c54-ab18-5a9a00dc6084\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eConceptual cognition; an alternative translation is “the imaginary.” One of the three natures that are a central philosophy of the Yogācāra tradition.\u003c/p\u003e\",\"names\":{\"english\":\"imputed\",\"tibetan\":\"ཀུན་བརྟགས་པ།\",\"sanskrit\":\"parikalpita\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kun brtags pa\"}},{\"uuid\":\"7045ba28-23a7-4e65-ac32-3d872bad82dc\",\"authority\":\"eda797cf-2934-4c67-98cd-62f8c8fff0b2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe deity that is also called Mahendra, “lord of the \u003cspan data-glossary-id=\\\"UT22084-089-013-2471\\\"\u003edevas\u003c/span\u003e,” who dwells on the summit of Mount \u003cspan data-glossary-id=\\\"UT22084-089-013-2940\\\"\u003eSumeru\u003c/span\u003e and wields a thunderbolt. He is also known as \u003cspan data-glossary-id=\\\"UT22084-089-013-2796\\\"\u003eŚakra\u003c/span\u003e (Tib. \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ebrgya byin\u003c/em\u003e, “hundred offerings”). The Buddhist tradition sometimes interprets this name as an abbreviation of \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eśata-kratu\u003c/em\u003e, “one who has performed a hundred sacrifices.” The highest Vedic sacrifice was the horse sacrifice, and there is a tradition that \u003cspan data-glossary-id=\\\"UT22084-089-013-2796\\\"\u003eIndra\u003c/span\u003e became the lord of the gods through performing them. \u003c/p\u003e\",\"names\":{\"english\":\"Indra\",\"tibetan\":\"དབང་པོ།\",\"sanskrit\":\"indra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dbang po\"}},{\"uuid\":\"10d9ccbb-4514-4ab1-9c19-578c6d5f6f4c\",\"authority\":\"6fbdb5b0-3b2a-4d90-a1e1-76b9a42657e0\",\"definition\":\"\u003cp\u003eThe lord of the gods in the Heaven of the Thirty-Three (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003etrāyastriṃśa\u003c/em\u003e). Alternatively known as Indra, the deity that is called “lord of the gods” dwells on the summit of Mount Sumeru and wields the thunderbolt. The Tibetan translation \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ebrgya byin\u003c/em\u003e (meaning “one hundred sacrifices”) is based on an etymology that \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eśakra\u003c/em\u003e is an abbreviation of \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eśata-kratu\u003c/em\u003e, one who has performed a hundred sacrifices. Each world with a central Sumeru has a Śakra. Also known by other names such as Kauśika, Devendra, and Śacipati. \u003c/p\u003e\",\"names\":{\"english\":\"Indra, Śakra\",\"tibetan\":\"བརྒྱ་བྱིན།\",\"sanskrit\":\"śakra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"brgya byin\"}},{\"uuid\":\"0116b0ca-3bc6-4392-b88b-13d39c746425\",\"authority\":\"afb97924-e2ec-490b-ad64-b282a4fe7f6d\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cem class=\\\"foreign\\\"\u003eMesua ferrea\u003c/em\u003e. Evergreen tree up to 100 feet tall. Known as Assam ironwood, Ceylon ironwood, Indian rose chestnut, Cobra’s \u003cspan data-glossary-id=\\\"UT22084-089-013-2517\\\"\u003esaffron\u003c/span\u003e, and nāgakesara. The flowers are large and fragrant, with four white petals and a yellow center. \u003c/p\u003e\",\"names\":{\"english\":\"ironwood flowers, keśarā\",\"tibetan\":\"ནཱ་ག་གེ་སར།\",\"sanskrit\":\"keśarā, nāgakeśara\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nA ga ge sar\"}},{\"uuid\":\"f00dda01-a511-4156-9497-a7e2231daa2d\",\"authority\":\"fe8375e9-f08b-4117-b7da-6f8dc94297da\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA river.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003echu skyes\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Jalāgamā\",\"tibetan\":\"ཆུ་འབབ་པ།\",\"sanskrit\":\"jalāgamā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chu ’bab pa\"}},{\"uuid\":\"50799e5f-1ece-439c-a637-15b486466c13\",\"authority\":\"cf65965c-5a01-4000-8df0-038b836a387a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe younger son of \u003cspan data-glossary-id=\\\"UT22084-089-013-2661\\\"\u003eJalavāhana\u003c/span\u003e and \u003cspan data-glossary-id=\\\"UT22084-089-013-2660\\\"\u003eJalāmbujagarbhā\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Jalagarbha\",\"tibetan\":\"ཆུའི་སྙིང་པོ།\",\"sanskrit\":\"jalagarbha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chu’i snying po\"}},{\"uuid\":\"25a19adb-2808-4804-ab56-72a8c8d421cd\",\"authority\":\"2783f0b8-8ff5-4656-9c2f-ac679370629a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe elder son of \u003cspan data-glossary-id=\\\"UT22084-089-013-2661\\\"\u003eJalavāhana\u003c/span\u003e and \u003cspan data-glossary-id=\\\"UT22084-089-013-2660\\\"\u003eJalāmbujagarbhā\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Jalāmbara\",\"tibetan\":\"ཆུའི་གོས།\",\"sanskrit\":\"jalāmbara\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chu’i gos\"}},{\"uuid\":\"750d5647-ee14-4dc3-a522-6098689cd177\",\"authority\":\"b5a58304-a480-45c5-9cc3-cdae489e9367\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe wife of \u003cspan data-glossary-id=\\\"UT22084-089-013-2661\\\"\u003eJalavāhana\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Jalāmbujagarbhā\",\"tibetan\":\"ཆུའི་པདྨའི་སྙིང་པོ།\",\"sanskrit\":\"jalāmbujagarbhā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chu’i pad+ma’i snying po\"}},{\"uuid\":\"57f0f961-6f2b-495c-bf32-21720f0875d5\",\"authority\":\"f1127be9-211b-4d06-9b95-4971cbaa86b8\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA learned physician in the distant past and son of \u003cspan data-glossary-id=\\\"UT22084-089-013-2663\\\"\u003eJaṭiṃdhara\u003c/span\u003e who, as a result of performing Dharma recitations while standing in a lake, ensured the rebirth of ten thousand fish into the paradise of \u003cspan data-glossary-id=\\\"UT22084-089-013-2942\\\"\u003eTrāyastriṃśa\u003c/span\u003e. He was the Buddha in a previous life.\u003c/p\u003e\",\"names\":{\"english\":\"Jalavāhana\",\"tibetan\":\"ཆུ་འབེབས།\",\"sanskrit\":\"jalavāhana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chu ’bebs\"}},{\"uuid\":\"3456a106-d5da-4357-9633-8660cc738b51\",\"authority\":\"b952b2a9-a83a-46a5-bc41-96914a5a94d3\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2587\\\"\u003etathāgata\u003c/span\u003e.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eSuvarṇaketuprabha\u003c/em\u003e; \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003egser tog ’od\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Jambu Golden Victory Banner That is Golden in Appearance\",\"tibetan\":\"འཛམ་བུ་གསེར་གྱི་རྒྱལ་མཚན་གསེར་དུ་སྣང་བ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’dzam bu gser gyi rgyal mtshan gser du snang ba\"}},{\"uuid\":\"976873dd-bd9c-436b-8fcb-0b632aedab12\",\"authority\":\"327b66e0-9056-4c8d-b00b-04f109d06c70\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe rivers that flow down from the immense lake at the foot of the legendary Jambu tree. The fruits of that tree are made of gold and are carried down by the rivers through \u003cspan data-glossary-id=\\\"UT22084-089-013-3198\\\"\u003eJambudvīpa\u003c/span\u003e. Such gold is considered the best kind.\u003c/p\u003e\",\"names\":{\"english\":\"Jambū River\",\"tibetan\":\"འཛམ་བུའི་ཆུ་ཀླུང་།\",\"sanskrit\":\"jambūnadī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’dzam bu’i chu klung\"}},{\"uuid\":\"a7a63b0e-ff89-451b-8593-40349c576c28\",\"authority\":\"a7b369fe-fecb-43b8-9447-c5373ac1fcf7\",\"definition\":\"$41\",\"names\":{\"english\":\"Jambudvīpa\",\"tibetan\":\"འཛམ་བུ་གླིང་།\",\"sanskrit\":\"jambudvīpa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’dzam bu gling\"}},{\"uuid\":\"00b75345-720a-4f43-8d9f-5cc7fe2cc96e\",\"authority\":\"9dc5ced3-a65d-416b-9d71-054b9de10e4c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA head merchant and physician in the distant past.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eJaladhara\u003c/em\u003e; \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003echu ’dzin\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Jaṭiṃdhara\",\"tibetan\":\"རལ་པ་འཛིན།\",\"sanskrit\":\"jaṭiṃdhara\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ral pa ’dzin\"}},{\"uuid\":\"4a4426a2-92c8-43a0-8413-753077eeafaa\",\"authority\":\"95e659ed-65f2-47e3-b3cc-ee6029b7a48b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn epithet for a buddha meaning “victorious one.”\u003c/p\u003e\",\"names\":{\"english\":\"jina\",\"tibetan\":\"རྒྱལ་བ།\",\"sanskrit\":\"jina\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rgyal ba\"}},{\"uuid\":\"b654fd57-78ef-498c-b735-47932a5790ca\",\"authority\":\"a87beec8-9bbb-49ec-9d68-5a89b9875823\",\"definition\":\"\u003cp\u003eJinamitra was invited to Tibet during the reign of King Tri Songdetsen (\u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ekhri srong lde btsan\u003c/em\u003e, r. 742–98 \u003cspan class=\\\"small-caps\\\"\u003eᴄᴇ\u003c/span\u003e) and was involved with the translation of nearly two hundred texts, continuing into the reign of King Ralpachen (\u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003eral pa can\u003c/em\u003e, r. 815–38 \u003cspan class=\\\"small-caps\\\"\u003eᴄᴇ\u003c/span\u003e). He was one of the small group of paṇḍitas responsible for the \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eMahāvyutpatti\u003c/cite\u003e Sanskrit–Tibetan dictionary.\u003c/p\u003e\",\"names\":{\"english\":\"Jinamitra\",\"tibetan\":\"ཛི་ན་མི་ཏྲ།\",\"sanskrit\":\"jinamitra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dzi na mi tra\"}},{\"uuid\":\"e4881bae-391a-483e-baf8-964b74e7fc3d\",\"authority\":\"aebfc7b8-23fd-481c-b359-1dd3f036bcbe\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e king.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003e’dam bu rgyal\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Jinarāja\",\"tibetan\":\"རྒྱལ་བའི་རྒྱལ།\",\"sanskrit\":\"jinarāja\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rgyal ba’i rgyal\"}},{\"uuid\":\"717c66fb-08f0-45ee-87b6-337426c452c8\",\"authority\":\"0f051b8e-e7e8-45e9-91a6-47b624aac58c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e king and the son of \u003cspan data-glossary-id=\\\"UT22084-089-013-2847\\\"\u003eVaiśravaṇa\u003c/span\u003e.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ertag tu rgyal\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Jinarṣabha\",\"tibetan\":\"རྒྱལ་བ་ཁྱུ་མཆོག\",\"sanskrit\":\"jinarṣabha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rgyal ba khyu mchog\"}},{\"uuid\":\"cb6cc75e-3b24-4025-9040-db7485022e5e\",\"authority\":\"871af724-3f30-43f1-82f0-4e3a03655cc4\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA bodhisattva.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003e’phags par dga’ ba\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Joyful High King\",\"tibetan\":\"དགའ་བས་མཐོ་བའི་རྒྱལ་པོ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dga’ bas mtho ba’i rgyal po\"}},{\"uuid\":\"2e0961b8-f430-4962-9e8d-5d52b5d634c8\",\"authority\":\"e632ed84-4505-4974-b1e2-b09ffeeab744\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA deity in the \u003cspan data-glossary-id=\\\"UT22084-089-013-2942\\\"\u003eTrāyastriṃśa\u003c/span\u003e paradise.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 557: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003e’bar ba’i khyad par gyi gzi brjid rgyal po\u003c/em\u003e. Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003emchog tu rgyal ba’i ’od\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Jvalanāntara­tejo­rāja\",\"tibetan\":\"འབར་བའི་ཁྱད་པར་གྱི་གཟི་བརྗིད་ཀྱི་རྒྱལ་པོ།\",\"sanskrit\":\"jvalanāntara­tejo­rāja\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’bar ba’i khyad par gyi gzi brjid kyi rgyal po\"}},{\"uuid\":\"06800f21-f0b9-475a-8ff0-71416a7085dc\",\"authority\":\"91b052d0-d797-40d1-b568-8a0d7d3d7b39\",\"definition\":\"$42\",\"names\":{\"english\":\"kalaviṅka\",\"tibetan\":\"ཀ་ལ་པིང་ཀ\",\"sanskrit\":\"kalaviṅka\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ka la ping ka\"}},{\"uuid\":\"ceffcc95-e521-47c9-84b5-8771e4f32a53\",\"authority\":\"9861c4ef-4f1e-4332-bb65-01b36e4285a7\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA spiritual teacher who can contribute to an individual’s progress on the spiritual path to awakening and act wholeheartedly for the welfare of students.\u003c/p\u003e\",\"names\":{\"english\":\"kalyāṇamitra\",\"tibetan\":\"དགེ་བའི་བཤེས་གཉེན།\",\"sanskrit\":\"kalyāṇamitra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dge ba’i bshes gnyen\"}},{\"uuid\":\"c4bffd10-82cd-4896-9e12-26dc853c1d68\",\"authority\":\"6b636171-071d-45cd-be83-5d58a7e600de\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e king.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003e’dod mchog\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Kāmaśreṣṭha\",\"tibetan\":\"དོད་པའི་མཆོག\",\"sanskrit\":\"kāmaśreṣṭha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dod pa’i mchog\"}},{\"uuid\":\"7558493f-9b38-4a75-9131-f935b4102307\",\"authority\":\"ce9d9785-4406-424f-b789-6f0358e74b0f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA son of the king \u003cspan data-glossary-id=\\\"UT22084-089-013-2831\\\"\u003eSuvarṇabhujendra\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Kanakabhujendra\",\"tibetan\":\"གསེར་གྱི་ལག་པའི་དབང་པོ།\",\"sanskrit\":\"kanakabhujendra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gser gyi lag pa’i dbang po\"}},{\"uuid\":\"3f1bf63e-f60e-46f8-851b-7fe841df1224\",\"authority\":\"c6d89f9c-bad2-40de-bf66-65014daa868c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA son of the king \u003cspan data-glossary-id=\\\"UT22084-089-013-2831\\\"\u003eSuvarṇabhujendra\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Kanaka­prabhā­svara\",\"tibetan\":\"གསེར་གྱི་འོད།\",\"sanskrit\":\"kanaka­prabhā­svara\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gser gyi ’od\"}},{\"uuid\":\"e7af750c-7d25-42ea-9011-d044c6506879\",\"authority\":\"e59c22ec-5fa1-41c9-9ab3-678ae267853c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e king.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ekha dog ser po\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Kapila\",\"tibetan\":\"སེར་སྐྱ།\",\"sanskrit\":\"kapila\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ser skya\"}},{\"uuid\":\"8d419490-a43b-49a2-8516-47d089d9f888\",\"authority\":\"e6c67f2b-9bad-44f9-bb30-b946305cb4c2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA coin that varied in value according to whether it was made of gold, silver, or copper.\u003c/p\u003e\",\"names\":{\"english\":\"kārṣāpaṇa\",\"tibetan\":\"ཀཱ་པ་ཎ།\",\"sanskrit\":\"kārṣāpaṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kA pa Na\"}},{\"uuid\":\"aa2c2a31-ffdb-4887-a677-972a8ec87ca3\",\"authority\":\"ac0a84c2-7013-41c6-ad05-c441da891215\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAccording to the Chinese translation, this is the family name (\u003cem class=\\\"foreign text-zh\\\" lang=\\\"zh\\\"\u003e姓\u003c/em\u003e) of the \u003cspan data-glossary-id=\\\"UT22084-089-013-2457\\\"\u003ebrahmin\u003c/span\u003e master \u003cspan data-glossary-id=\\\"UT22084-089-013-2890\\\"\u003eVyākaraṇa\u003c/span\u003e, an interlocutor in \u003ccite class=\\\"title text-en\\\" lang=\\\"en\\\"\u003eThe Sūtra of the Sublime Golden Light\u003c/cite\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Kauṇḍinya\",\"tibetan\":\"ཀཽཎྜི་ནྱ།\",\"sanskrit\":\"kauṇḍinya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kauN+Di n+ya\"}},{\"uuid\":\"0366d57a-2931-4c1e-8029-bfca79b21968\",\"authority\":\"d313e685-b792-4e73-87cf-85cafb75a231\",\"definition\":\"$43\",\"names\":{\"english\":\"Kauśika\",\"tibetan\":\"ཀཽ་ཤི་ཀ\",\"sanskrit\":\"kauśika\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kau shi ka\"}},{\"uuid\":\"44211909-4f96-453b-8a68-861117e1b049\",\"authority\":\"9b62b5c1-b076-4b8d-bcca-78c079cdd6bc\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn \u003cspan data-glossary-id=\\\"UT22084-089-013-2559\\\"\u003easura\u003c/span\u003e king.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ebong bu dpung\u003c/em\u003e; Toh 556 Degé: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003erab tshim byed\u003c/em\u003e; Toh 557 Yongle and Peking: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003erab sil byed\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Kharaskandha\",\"tibetan\":\"རབ་ཚིམ་བྱེད།\",\"sanskrit\":\"kharaskandha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rab tshim byed\"}},{\"uuid\":\"70014dd8-67ec-4be2-9261-1c8857a47732\",\"authority\":\"68967b0f-05c1-487c-8550-2f1ac9fbad3b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe name prophesied for the \u003cspan data-glossary-id=\\\"UT22084-089-013-2450\\\"\u003ebhikṣus\u003c/span\u003e who will attain buddhahood in the \u003cspan data-glossary-id=\\\"UT22084-089-013-2480\\\"\u003eeon\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-089-013-2477\\\"\u003eDifficult to Conquer King of Radiance\u003c/span\u003e, in the realm called \u003cspan data-glossary-id=\\\"UT22084-089-013-2946\\\"\u003eVimalaprabhā\u003c/span\u003e.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003ePraṇidhāna­vyūhalaṃkāra­rāja\u003c/em\u003e; \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003esmon lam gyi bkod pas brgyan pa’i rgyal po\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"King Array of Pure Prayers\",\"tibetan\":\"སྨོན་ལམ་རྣམ་པར་བཀོད་པའི་རྒྱལ་པོ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"smon lam rnam par bkod pa’i rgyal po\"}},{\"uuid\":\"818b8a98-c363-42fc-946e-b5d436944647\",\"authority\":\"360bce5e-2a16-46dd-89f5-8eb1e1484b61\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA bodhisattva.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003espobs pa chen po’i rgyan gyi rgyal po\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"King Fearless Powerful Array\",\"tibetan\":\"སྤོབས་པ་ཆེན་པོས་བཀོད་པའི་རྒྱལ་པོ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"spobs pa chen pos bkod pa’i rgyal po\"}},{\"uuid\":\"803c1d4b-4952-4233-a680-88fc3bf5bff7\",\"authority\":\"32eb1d4b-e3f8-408d-9b4f-1eb37d6f2f91\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA buddha.\u003c/p\u003e\",\"names\":{\"english\":\"King of Illumination\",\"tibetan\":\"སྣང་བའི་རྒྱལ་པོ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"snang ba’i rgyal po\"}},{\"uuid\":\"f7eea1b0-d065-4761-92b6-d605ef563d5d\",\"authority\":\"e54f019b-0e86-4baa-8f7d-60d3d0b13636\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA bodhisattva.\u003c/p\u003e\",\"names\":{\"english\":\"King of Supreme Mount Meru\",\"tibetan\":\"ལྷུན་པོའི་རྒྱལ་པོ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lhun po’i rgyal po\"}},{\"uuid\":\"6efa6098-a749-48c8-ba73-e629967e1352\",\"authority\":\"b57a5182-b1eb-4168-bd5f-28ca6def5a9f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA class of nonhuman beings that resemble humans to the degree that their very name‍—which means “is that human?”‍—suggests some confusion as to their divine status. Kinnaras are mythological beings found in both Buddhist and Brahmanical literature, where they are portrayed as creatures half human, half animal. They are often depicted as highly skilled celestial musicians.\u003c/p\u003e\",\"names\":{\"english\":\"kinnara\",\"tibetan\":\"མི་འམ་ཅི།, མིའམ་ཅི།\",\"sanskrit\":\"kinnara, kiṃnara\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mi ’am ci, mi’am ci\"}},{\"uuid\":\"7f569129-9d7a-4745-8cfb-a83dd02390a8\",\"authority\":\"08fa6236-ac9a-4341-acb1-8ad8c2098720\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eKnown in the Avadāna literature as a previous life of the Buddha, his name is translated there as \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ebyas shes\u003c/em\u003e. In that tale, his brother (a previous life of Devadatta) gouges out his eyes. Nonetheless, a princess chooses him for a husband and is banished by her father, the king. When she speaks the words of truth of her love for him, one of Kṛtajña’s eyes is restored. When he speaks the words of truth that he has no hate for his brother, his other eye is restored, and he is enthroned by the king as his successor.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003edrin gzo\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Kṛtajña\",\"tibetan\":\"བྱས་པ་གཟོ་བ།\",\"sanskrit\":\"kṛtajña\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"byas pa gzo ba\"}},{\"uuid\":\"97ae6f4e-7b36-4074-b55a-94f47679707c\",\"authority\":\"7f981f55-b847-4d5d-931a-d6f5b6f58df6\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe warrior or aristocratic class of the four social classes of India. Rulers were often from this class.\u003c/p\u003e\",\"names\":{\"english\":\"kṣatriya\",\"tibetan\":\"རྒྱལ་རིགས།\",\"sanskrit\":\"kṣatriya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rgyal rigs\"}},{\"uuid\":\"16ff29f2-2c38-4e2d-a90b-ed12c092a5c7\",\"authority\":\"dddfe48e-7143-4898-908b-760d0cdd0174\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA bodhisattva.\u003c/p\u003e\",\"names\":{\"english\":\"Kṣitigarbha\",\"tibetan\":\"སའི་སྙིང་པོ།\",\"sanskrit\":\"kṣitigarbha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sa’i snying po\"}},{\"uuid\":\"81b11a50-901c-4362-8456-b7c320ab5cff\",\"authority\":\"fcf5202a-1510-499f-b477-5eac19acd584\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA polite address for a young man, it can, in context, also mean “prince.”\u003c/p\u003e\",\"names\":{\"english\":\"Kumāra\",\"tibetan\":\"གཞོན་ནུ།\",\"sanskrit\":\"Kumāra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gzhon nu\"}},{\"uuid\":\"f252bdb7-ef16-42f8-ab89-314e798cb2da\",\"authority\":\"593752fe-f23b-4a10-a9ef-106a900f7e7e\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA class of dwarf beings subordinate to Virūḍhaka, one of the Four Great Kings, associated with the southern direction. The name uses a play on the word \u003cem class=\\\"foreign\\\"\u003eaṇḍa\u003c/em\u003e, which means “egg” but is also a euphemism for a testicle. Thus, they are often depicted as having testicles as big as pots (from \u003cem class=\\\"foreign\\\"\u003ekumbha\u003c/em\u003e, or “pot”).\u003c/p\u003e\",\"names\":{\"english\":\"kumbhāṇḍa\",\"tibetan\":\"གྲུལ་བུམ།\",\"sanskrit\":\"kumbhāṇḍa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"grul bum\"}},{\"uuid\":\"c9846b00-4b53-40f7-9ab1-3d390baeff41\",\"authority\":\"cc11d101-f245-458d-9910-1ef8c779057a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e king; also known as Kubera.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003eku be ra\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Kumbhīra\",\"tibetan\":\"ཇི་འཇིགས།\",\"sanskrit\":\"kumbhīra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ji ’jigs\"}},{\"uuid\":\"8d3b6aa2-1554-47f0-932e-65c0b98124d8\",\"authority\":\"d019a5b2-d915-41be-aca4-7be663ae80dc\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA fierce goddess.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003eso brtsegs ma\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Kūṭadantī\",\"tibetan\":\"སོ་བརྩེགས།\",\"sanskrit\":\"kūṭadantī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"so brtsegs\"}},{\"uuid\":\"83cef396-e5d4-4358-9bd2-076af1d9b37c\",\"authority\":\"63e7229a-51c6-4cec-b3af-4f443ab6ffa9\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA clan with its capital Vaiśalī, in present-day Bihar, north of the \u003cspan data-glossary-id=\\\"UT22084-089-013-3197\\\"\u003eGanges\u003c/span\u003e. Their capital was a place where the Buddha had many followers when they were an independent republic.\u003c/p\u003e\",\"names\":{\"english\":\"Licchavī\",\"tibetan\":\"ལིཙྪ་བཱི།\",\"sanskrit\":\"licchavī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lits+tsha bI\"}},{\"uuid\":\"33c62823-8c0a-4d0e-af7c-0142a280b203\",\"authority\":\"6284b153-7255-444c-9df3-d747ab9418ed\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2503\\\"\u003enāga\u003c/span\u003e king.\u003c/p\u003e\",\"names\":{\"english\":\"Lightning Tongue\",\"tibetan\":\"གློག་ལྕེ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"glog lce\"}},{\"uuid\":\"780c0037-ad5c-4121-9e9b-71d6b1bc70f2\",\"authority\":\"06334a5f-39df-4372-a375-e1ac345c8125\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOil from the seed of the flax plant (\u003cem class=\\\"foreign\\\"\u003eLinum usitatissimum\u003c/em\u003e).\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003esmig bcud\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"linseed\",\"tibetan\":\"དབྱི་མོ།\",\"sanskrit\":\"cavya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dbyi mo\"}},{\"uuid\":\"e2725cd4-ff09-4c6d-9ddf-c4d7e548c083\",\"authority\":\"d64ffa31-e318-4730-b707-efd188bbd9f6\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2496\\\"\u003eLicchavī\u003c/span\u003e youth.\u003c/p\u003e\",\"names\":{\"english\":\"Lion’s Light\",\"tibetan\":\"སེང་གེའི་འོད།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"seng ge’i ’od\"}},{\"uuid\":\"d6a2a346-aec3-4600-a234-f0b1f8606ab4\",\"authority\":\"a873cee5-fa32-460a-9b6d-bf977c7a5d1c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA bodhisattva.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003erin po che’i phyag dbang phyug\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Lord with Jeweled Hands\",\"tibetan\":\"ལག་ན་རིན་ཆེན་དབང་ཕྱུག\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lag na rin chen dbang phyug\"}},{\"uuid\":\"f4435f0e-8534-4ffc-a33c-75dee8dec384\",\"authority\":\"2a3f0e81-47b6-40ca-89fa-8e13c5448f29\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003epadma’i bzhin\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Lotus Face\",\"tibetan\":\"པདྨོའི་གདོང་།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"pad+mo’i gdong\"}},{\"uuid\":\"655529d7-bddc-41de-937b-b35612717330\",\"authority\":\"d15fee39-3404-43d8-a587-a30b0dc5f359\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2503\\\"\u003enāga\u003c/span\u003e king.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003estobs po che\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Mahābala\",\"tibetan\":\"སྟོབས་ཆེན།\",\"sanskrit\":\"mahābala\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"stobs chen\"}},{\"uuid\":\"5ff2846b-7d20-4767-962b-2367e5a25af8\",\"authority\":\"687d75a8-dce4-409e-bae7-85e53d329251\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e king.\u003c/p\u003e\",\"names\":{\"english\":\"Mahābhāga\",\"tibetan\":\"སྐལ་བ་ཆེན་པོ།\",\"sanskrit\":\"mahābhāga\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"skal ba chen po\"}},{\"uuid\":\"7d2c00ca-715b-4899-b2fe-cc750687c66c\",\"authority\":\"b2d7b1da-0595-47e4-953c-5ef6c704327a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e“Great \u003cspan data-glossary-id=\\\"UT22084-089-013-2896\\\"\u003eBrahmā\u003c/span\u003e.” The highest of the three (or, in this sūtra, four) paradises that correspond to the first \u003cspan data-glossary-id=\\\"UT22084-089-013-2564\\\"\u003edhyāna\u003c/span\u003e in the form realm.\u003c/p\u003e\",\"names\":{\"english\":\"Mahābrahmā\",\"tibetan\":\"ཚངས་ཆེན།\",\"sanskrit\":\"mahābrahmā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"tshangs chen\"}},{\"uuid\":\"599f6cf5-8529-4072-b98f-c335ca718227\",\"authority\":\"9c2fe0c4-4da1-49a5-bc13-8cd9e5532fe2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee “\u003cspan data-glossary-id=\\\"UT22084-089-013-2896\\\"\u003eBrahmā\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"Mahābrahmā\",\"tibetan\":\"ཚངས་ཆེན།, ཚངས་པ་ཆེན།\",\"sanskrit\":\"mahābrahmā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"tshangs chen, tshangs pa chen\"}},{\"uuid\":\"ef3f3971-bcf4-4c04-b58c-0e8906b3e3e9\",\"authority\":\"299bddd2-05a9-4552-abbe-187662b538e6\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThis appears to refer to the great circles of mountains that enclose a thousand worlds, each with its own \u003cspan data-glossary-id=\\\"UT22084-089-013-2914\\\"\u003eCakravāḍa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Mahācakravāḍa\",\"tibetan\":\"ཁོར་ཡུག་ཆེན་པོ།\",\"sanskrit\":\"mahācakravāḍa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"khor yug chen po\"}},{\"uuid\":\"54354dbb-3a96-4443-aef4-acd92bc1c8ac\",\"authority\":\"761fd804-0c73-429a-9820-032bcf1e1b40\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA prince in the past, the middle son of the King \u003cspan data-glossary-id=\\\"UT22084-089-013-2727\\\"\u003eMahāratha\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Mahādeva\",\"tibetan\":\"ལྷ་ཆེན་པོ།\",\"sanskrit\":\"mahādeva\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lha chen po\"}},{\"uuid\":\"8401386a-e37d-4039-895b-9eabe1655320\",\"authority\":\"5aab526e-b8b3-4f55-b27e-98cfba37f42a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2503\\\"\u003enāga\u003c/span\u003e king.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003esgra bo che\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Mahāghoṣa\",\"tibetan\":\"སྒྲ་ཆེན།\",\"sanskrit\":\"mahāghoṣa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sgra chen\"}},{\"uuid\":\"4c029921-fe4e-4f8c-a9b0-f99cd0592bb6\",\"authority\":\"1e0d8ce9-ba80-4bc0-9fea-23002afaaa15\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e king.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 557: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ekam po ji\u003c/em\u003e (corrupt), Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003emchog tu rgyal ba\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Mahāgrāsa\",\"tibetan\":\"ཁམ་པོ་ཆེ།\",\"sanskrit\":\"mahāgrāsa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kham po che\"}},{\"uuid\":\"6ebc760a-e7fa-478c-9bbe-3efbe5748dbf\",\"authority\":\"a8f9adbe-3e06-4056-b40a-a9b7475905cf\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e lord.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003enag po che\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Mahākāla\",\"tibetan\":\"ནག་པོ།\",\"sanskrit\":\"mahākāla\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nag po\"}},{\"uuid\":\"7fe2e4f5-7ce7-4210-8d25-0a0a1c0393a6\",\"authority\":\"1aff34d4-5da6-49ab-b312-523fffccb2d7\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the Buddha’s principal pupils, who became a leader of the \u003cspan data-glossary-id=\\\"UT22084-089-013-2522\\\"\u003esaṅgha\u003c/span\u003e after the Buddha’s passing.\u003c/p\u003e\",\"names\":{\"english\":\"Mahākāśyapa\",\"tibetan\":\"འོད་སྲུང་ཆེན་པོ།\",\"sanskrit\":\"mahākāśyapa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’od srung chen po\"}},{\"uuid\":\"69a9cbc7-a145-499e-be6c-54c36e84f199\",\"authority\":\"93cfa4be-811b-4391-8571-246488029b30\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the principal \u003cspan data-glossary-id=\\\"UT22084-089-013-2585\\\"\u003eśrāvaka\u003c/span\u003e disciples of the Buddha, paired with \u003cspan data-glossary-id=\\\"UT22084-089-013-2807\\\"\u003eŚāriputra\u003c/span\u003e. He was renowned for his miraculous \u003cspan data-glossary-id=\\\"UT22084-089-013-2512\\\"\u003epowers\u003c/span\u003e. His family clan was descended from Mudgala, hence his name Maudgalyāyana, “the son of Mudgala’s descendants.” Respectfully referred to as Mahāmaudgalyāyana.\u003c/p\u003e\",\"names\":{\"english\":\"Mahāmaudgalyāyana, Maudgalyāyana\",\"tibetan\":\"མཽད་གལ་གྱི་བུ་ཆེན་པོ།\",\"sanskrit\":\"mahāmaudgalyāyana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"maud gal gyi bu chen po\"}},{\"uuid\":\"440e86f7-0317-4ed0-b5a8-878867898223\",\"authority\":\"3214d00d-5fb8-44b7-8e84-ff84a200d612\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the Buddha’s five companions in asceticism before his enlightenment and later one of his first five pupils, he attained the state of a \u003cspan data-glossary-id=\\\"UT22084-089-013-2529\\\"\u003estream entrant\u003c/span\u003e after three days, the fourth to attain that realization. He attained the state of an \u003cspan data-glossary-id=\\\"UT22084-089-013-2437\\\"\u003earhat\u003c/span\u003e on hearing \u003ccite class=\\\"title text-en\\\" lang=\\\"en\\\"\u003eThe Sūtra on the Characteristics of Selflessness\u003c/cite\u003e. Not to be confused with the cousin of the Buddha, who had the same name and was a significant lay follower and patron.\u003c/p\u003e\",\"names\":{\"english\":\"Mahānāman\",\"tibetan\":\"མིང་ཆེན།\",\"sanskrit\":\"mahānāman\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ming chen\"}},{\"uuid\":\"f28df2d3-a1f8-42a4-99b5-bb26459a27ce\",\"authority\":\"66cfc431-ce40-4c8a-955b-b238c9957809\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e king.\u003c/p\u003e\",\"names\":{\"english\":\"Mahāpāla\",\"tibetan\":\"ཆོས་སྐྱོང་།\",\"sanskrit\":\"mahāpāla\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chos skyong\"}},{\"uuid\":\"043ec0da-f3f0-4b81-99c2-27804ff8d946\",\"authority\":\"780c62ef-2367-44f4-a1b1-e5d3aebfeb56\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA bodhisattva.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ema hā ping ga la\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Mahāpiṅgala\",\"tibetan\":\"པིང་ག་ལ་ཆེན་པོ།\",\"sanskrit\":\"mahāpiṅgala\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ping ga la chen po\"}},{\"uuid\":\"d16662fa-d2f2-414b-9bd1-f2579e556ca1\",\"authority\":\"8a09a59d-6ae5-4777-9d1b-c93a0f0c18c8\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2496\\\"\u003eLicchavī\u003c/span\u003e youth.\u003c/p\u003e\",\"names\":{\"english\":\"Mahāprabha\",\"tibetan\":\"འོད་ཆེན།\",\"sanskrit\":\"mahāprabha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’od chen\"}},{\"uuid\":\"a21dd26d-2823-452c-bd32-2587ab28028d\",\"authority\":\"e5543329-5365-4115-b07d-1ec24bdd9976\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2587\\\"\u003etathāgata\u003c/span\u003e. \u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eMahāpradīpaprabha\u003c/em\u003e; \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003esgron ma chen po’i ’od\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Mahāpradīpa\",\"tibetan\":\"སྒྲོན་མ་ཆེན་པོ།\",\"sanskrit\":\"mahāpradīpa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sgron ma chen po\"}},{\"uuid\":\"a9cdc127-a0df-4b87-81d3-81884dcf0489\",\"authority\":\"5c893dbb-e784-4cc1-93f8-68058fff0262\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe Buddha’s mother’s sister and his stepmother. She was the mother of \u003cspan data-glossary-id=\\\"UT22084-089-013-2893\\\"\u003eNanda\u003c/span\u003e, whom the Buddha later inspired to become a monk, as recorded in two sūtras bearing his name and elsewhere. She became the first \u003cspan data-glossary-id=\\\"UT22084-089-013-2451\\\"\u003ebhikṣuṇī\u003c/span\u003e after the death of the Buddha’s father.\u003c/p\u003e\",\"names\":{\"english\":\"Mahāprajāpatī\",\"tibetan\":\"སྐྱེ་དགུའི་བདག་མོ་ཆེན་མོ།\",\"sanskrit\":\"mahāprajāpatī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"skye dgu’i bdag mo chen mo\"}},{\"uuid\":\"c89acb6f-2f97-4596-b431-a21488261274\",\"authority\":\"f65d7a83-eb93-4f7b-81aa-ab6815aabb87\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA prince in the past, the eldest son of King \u003cspan data-glossary-id=\\\"UT22084-089-013-2727\\\"\u003eMahāratha\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Mahāpraṇāda\",\"tibetan\":\"སྒྲ་ཆེན་པོ།\",\"sanskrit\":\"mahāpraṇāda\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sgra chen po\"}},{\"uuid\":\"74f3a194-32a5-4d08-8829-a0cfbe95f161\",\"authority\":\"eb29a996-9610-4b68-8ac4-836fd08f17a9\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e king.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 556 Degé: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003eyul chen can\u003c/em\u003e; Toh 557 Degé: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003eyul chen can\u003c/em\u003e; Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003epra na li chen\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Mahāpraṇālin\",\"tibetan\":\"ཡུར་ཆེན་ཅན།\",\"sanskrit\":\"mahāpraṇālin\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yur chen can\"}},{\"uuid\":\"31f670fc-6f54-431a-9e3a-8105fb7f68a0\",\"authority\":\"15691c33-266b-43f9-acae-35d9e63e4712\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA king in the past.\u003c/p\u003e\",\"names\":{\"english\":\"Mahāratha\",\"tibetan\":\"ཤིང་རྟ་ཆེན་པོ།\",\"sanskrit\":\"mahāratha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shing rta chen po\"}},{\"uuid\":\"bd58d6fe-aed0-4a25-af8c-07773776842f\",\"authority\":\"dd3f0185-b0dc-49a2-bec1-91438e409f75\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA bodhisattva.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eMahāratnadhvaja\u003c/em\u003e; \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003erin po che’i rgyal mtshan chen po\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Mahāratnaketu\",\"tibetan\":\"རིན་པོ་ཆེའི་ཏོག་ཆེན་པོ།\",\"sanskrit\":\"mahāratnaketu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rin po che’i tog chen po\"}},{\"uuid\":\"d1c7dfac-7376-48af-bc36-07491c77e7ac\",\"authority\":\"a6c40c30-43ed-4634-9b0a-1d707dbc463f\",\"definition\":\"$44\",\"names\":{\"english\":\"mahāsattva\",\"tibetan\":\"སེམས་ཅན་ཆེན་པོ།\",\"sanskrit\":\"mahāsattva\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sems can chen po\"}},{\"uuid\":\"0a07a07f-acbb-4b37-9ee3-09bb5e553b06\",\"authority\":\"2e80d6a1-2f5d-4e86-917e-09d863436a71\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA prince in the past, the youngest son of King \u003cspan data-glossary-id=\\\"UT22084-089-013-2727\\\"\u003eMahāratha\u003c/span\u003e. A previous life of the Buddha, when he decided to give his body to a tigress.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 557: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003esems can chen po\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Mahāsattva\",\"tibetan\":\"སྙིང་སྟོབས་ཆེན་པོ།\",\"sanskrit\":\"mahāsattva\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"snying stobs chen po\"}},{\"uuid\":\"9abf3170-658c-4d8e-83cf-29c9c0f4ce45\",\"authority\":\"17b9b902-a287-45e5-9813-d8e7a6e9d763\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the two principal bodhisattvas in Sukhāvatī and prominent in Chinese Buddhism. In Tibetan Buddhism he is identified with \u003cspan data-glossary-id=\\\"UT22084-089-013-2850\\\"\u003eVajrapāṇi\u003c/span\u003e, though they are separate bodhisattvas in the sūtras.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003emthu chen po thob pa\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Mahāsthāmaprāpta\",\"tibetan\":\"མཐུ་ཆེན་ཐོབ།\",\"sanskrit\":\"mahāsthāmaprāpta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mthu chen thob\"}},{\"uuid\":\"f3fbdf9c-f5a6-4a60-81fa-8e8615d622e0\",\"authority\":\"9a756070-8289-4da7-8340-e4e06d2ade44\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eWhen the Buddhist teachings are classified according to their power to lead beings to an awakened state, a distinction is made between the teachings of the Lesser Vehicle (Hīnayāna), which emphasizes the individual’s own freedom from cyclic existence as the primary motivation and goal, and those of the Great Vehicle (Mahāyāna), which emphasizes altruism and has the liberation of all sentient beings as the principal objective. As the term “Great Vehicle” implies, the path followed by bodhisattvas is analogous to a large carriage that can transport a vast number of people to liberation, as compared to a smaller vehicle for the individual practitioner.\u003c/p\u003e\",\"names\":{\"english\":\"Mahāyāna\",\"tibetan\":\"ཐེག་པ་ཆེན་པོ།\",\"sanskrit\":\"mahāyāna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"theg pa chen po\"}},{\"uuid\":\"b06d8d21-2e41-43b6-aabd-d93196ab1e50\",\"authority\":\"44457ceb-d84a-408e-a9b3-bfc1e99bac24\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn epithet of Śiva; sometimes refers specifically to one of the forms of Śiva.\u003c/p\u003e\",\"names\":{\"english\":\"Maheśvara\",\"tibetan\":\"དབང་ཕྱུག་ཆེན་པོ།\",\"sanskrit\":\"maheśvara\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dbang phyug chen po\"}},{\"uuid\":\"c90f63de-65ce-4551-9c2b-73105430d813\",\"authority\":\"eb1c6fc0-d2f8-4d3e-8fad-825f71769dd7\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eLiterally “great serpents,” mahoragas are supernatural beings depicted as large, subterranean beings with human torsos and heads and the lower bodies of serpents. Their movements are said to cause earthquakes, and they make up a class of subterranean geomantic spirits whose movement through the seasons and months of the year is deemed significant for construction projects.\u003c/p\u003e\",\"names\":{\"english\":\"mahoraga\",\"tibetan\":\"ལྟོ་འཕྱེ་ཆེན་པོ།\",\"sanskrit\":\"mahoraga\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lto ’phye chen po\"}},{\"uuid\":\"d89e365d-201f-4efa-953b-c218d5c56976\",\"authority\":\"cdfb8e4f-6d68-4c38-a3c5-5bd8897f3897\",\"definition\":\"$45\",\"names\":{\"english\":\"Maitreya\",\"tibetan\":\"བྱམས་པ།\",\"sanskrit\":\"maitreya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"byams pa\"}},{\"uuid\":\"8e8fa022-dae6-40e7-8891-dc0d87c3be63\",\"authority\":\"b693b673-66cb-43e8-a843-ffeb90866512\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe range of mountains in West India, also called the Western Ghats, known for its \u003cspan data-glossary-id=\\\"UT22084-089-013-2521\\\"\u003esandalwood\u003c/span\u003e forests.\u003c/p\u003e\",\"names\":{\"english\":\"Malaya\",\"tibetan\":\"མ་ལ་ཡ།\",\"sanskrit\":\"malaya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ma la ya\"}},{\"uuid\":\"c613495b-c72c-438b-a6f0-a4aa926afacb\",\"authority\":\"349577da-14dc-4644-b429-bd9c8a3236fb\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2503\\\"\u003enāga\u003c/span\u003e.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003eyid bzhin\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Manasvin, Manasvī\",\"tibetan\":\"གཟི་ཅན།, གཟི་ཅན།\",\"sanskrit\":\"manasvin, manasvī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gzi can, gzi can\"}},{\"uuid\":\"650a9f98-3999-4832-92bd-52826aa74cb2\",\"authority\":\"349577da-14dc-4644-b429-bd9c8a3236fb\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2503\\\"\u003enāga\u003c/span\u003e king.\u003c/p\u003e\",\"names\":{\"english\":\"Manasvin, Manasvī\",\"tibetan\":\"གཟི་ཅན།, གཟི་ཅན།\",\"sanskrit\":\"manasvin, manasvī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gzi can, gzi can\"}},{\"uuid\":\"f9c67828-6608-4634-8a72-a6c7b1e85991\",\"authority\":\"71b01261-c006-43cd-9e58-7d98c6a5d215\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eLiterally a “disk” or “circle,” in the ritual context a maṇḍala is a sacred space on the ground or a raised platform, arranged according to a pattern that varies from rite to rite.\u003c/p\u003e\",\"names\":{\"english\":\"maṇḍala\",\"tibetan\":\"དཀྱིལ་འཁོར།\",\"sanskrit\":\"maṇḍala\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dkyil ’khor\"}},{\"uuid\":\"1fbf92a7-58c5-441f-b0fb-d69c84daa019\",\"authority\":\"4834443e-75d9-4048-81cb-c2fb627ed45d\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2471\\\"\u003edeva\u003c/span\u003e.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ernam par bkra shis\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Maṅgala\",\"tibetan\":\"བཀྲ་ཤིས།\",\"sanskrit\":\"maṅgala\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bkra shis\"}},{\"uuid\":\"15ab923a-4b5d-41af-9ca2-750e47823372\",\"authority\":\"b09f7e52-b5bc-48e4-88a1-c3d6f8fd92ab\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e king, the brother of Kubera.\u003c/p\u003e\",\"names\":{\"english\":\"Maṇibhadra, Māṇibhadra\",\"tibetan\":\"ནོར་བུ་བཟང་།, ནོར་བུ་བཟང་།\",\"sanskrit\":\"maṇibhadra, māṇibhadra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nor bu bzang, nor bu bzang\"}},{\"uuid\":\"dd7fc955-81ba-449b-a46c-bd92a483c30c\",\"authority\":\"b09f7e52-b5bc-48e4-88a1-c3d6f8fd92ab\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e general.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003erin chen bzang\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Maṇibhadra, Māṇibhadra\",\"tibetan\":\"ནོར་བུ་བཟང་།, ནོར་བུ་བཟང་།\",\"sanskrit\":\"maṇibhadra, māṇibhadra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nor bu bzang, nor bu bzang\"}},{\"uuid\":\"71011b45-ce86-404a-89e7-d3db8366d554\",\"authority\":\"955034dc-1f0c-42a9-80d5-6bb55ece64c2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003e’jigs pa mngon du ston pa\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Manifesting Great Fear\",\"tibetan\":\"འཇིགས་པ་ཆེན་པོ་སྟོན།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’jigs pa chen po ston\"}},{\"uuid\":\"b817e463-9b9a-40be-aaba-08763c67fb26\",\"authority\":\"2181ffcf-c293-433b-a5a0-eba1cf8038a3\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e king.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003enor bu gtsug\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Maṇikaṇṭha\",\"tibetan\":\"ནོར་བུའི་མགུལ།\",\"sanskrit\":\"maṇikaṇṭha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nor bu’i mgul\"}},{\"uuid\":\"c1790dd4-4463-4814-926d-5356a1e2cb7b\",\"authority\":\"320c5523-4cde-4365-aeb1-3e69be9b0e42\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eMañjuśrī is one of the “eight close sons of the Buddha” and a bodhisattva who embodies wisdom. He is a major figure in the Mahāyāna sūtras, appearing often as an interlocutor of the Buddha. In his most well-known iconographic form, he is portrayed bearing the sword of wisdom in his right hand and a volume of the \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003ePrajñā­pāramitā­sūtra\u003c/cite\u003e in his left. To his name, Mañjuśrī, meaning “Gentle and Glorious One,” is often added the epithet Kumārabhūta, “having a youthful form.” He is also called Mañjughoṣa, Mañjusvara, and Pañcaśikha.\u003c/p\u003e\",\"names\":{\"english\":\"Mañjuśrī, Mañjuśrī Kumārabhuta\",\"tibetan\":\"འཇམ་དཔལ།\",\"sanskrit\":\"mañjuśrī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’jam dpal\"}},{\"uuid\":\"399345bd-b048-4573-9680-22c5c83902ed\",\"authority\":\"e1fb564c-d272-4630-a364-c38802aa4143\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e king.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003espre’u rnams kyi ni rgyal po\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Markaṭa\",\"tibetan\":\"སྤྲེའུ།\",\"sanskrit\":\"markaṭa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"spre’u\"}},{\"uuid\":\"1bfeb61e-91c1-4b84-958a-d5af003d8b6d\",\"authority\":\"e6a3c853-cdff-4087-a705-b508560cb3ac\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e“Mother goddesses.” Anglicized as \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003ematrika\u003c/em\u003e. A group of goddesses, often eight in number, that correspond to principal male deities. \u003c/p\u003e\",\"names\":{\"english\":\"mātṛkā\",\"tibetan\":\"མ་མོ།\",\"sanskrit\":\"mātṛkā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ma mo\"}},{\"uuid\":\"d9299ecc-0466-4882-abb8-a2acd686b83b\",\"authority\":\"7791aeb8-42c8-4263-b2b6-6b281b9dd1b4\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe Buddha’s mother, more commonly called Māyādevī.\u003c/p\u003e\",\"names\":{\"english\":\"Māyā\",\"tibetan\":\"སྒྱུ་འཕྲུལ།\",\"sanskrit\":\"māyā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sgyu ’phrul\"}},{\"uuid\":\"834dc5dc-8d4e-47b5-9e05-fa96dd153ea8\",\"authority\":\"00c9880b-c835-42e4-8a54-7f9d0c52c4a4\",\"definition\":\"\u003cp\u003eAccording to ancient Buddhist cosmology, this is the great mountain forming the axis of the universe. At its summit is Sudarśana, home of Śakra and his thirty-two gods, and on its flanks live the asuras. The mount has four sides facing the cardinal directions, each of which is made of a different precious stone. Surrounding it are several mountain ranges and the great ocean where the four principal island continents lie: in the south, Jambudvīpa (our world); in the west, Godānīya; in the north, Uttarakuru; and in the east, Pūrvavideha. Above it are the abodes of the desire realm gods. It is variously referred to as Meru, Mount Meru, Sumeru, and Mount Sumeru.\u003c/p\u003e\",\"names\":{\"english\":\"Meru, Mount Meru, Sumeru\",\"tibetan\":\"རི་རབ།\",\"sanskrit\":\"sumeru\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ri rab\"}},{\"uuid\":\"6359e7c5-2d23-43d1-9c57-80a7747a6cd7\",\"authority\":\"13485b73-75fa-44e4-ad13-09fa8dcfd02b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2471\\\"\u003edeva\u003c/span\u003e.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ezla ba’i gtsug tor\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Moon Crest\",\"tibetan\":\"ཟླ་བའི་གཙུག་ཕུད།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"zla ba’i gtsug phud\"}},{\"uuid\":\"7db03410-eea2-43c5-972d-d43a1f218544\",\"authority\":\"d58ea57c-3462-4f99-91c6-70fdaf99733a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2503\\\"\u003enāga\u003c/span\u003e king.\u003c/p\u003e\",\"names\":{\"english\":\"Mucilinda\",\"tibetan\":\"བཏང་བཟུང་།\",\"sanskrit\":\"mucilinda\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"btang bzung\"}},{\"uuid\":\"be72558c-5b75-4347-8248-4effa127edb7\",\"authority\":\"28dcdb6b-4933-421d-906c-39f9bb5fc4ef\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e“Lord of \u003cspan data-glossary-id=\\\"UT22084-089-013-2518\\\"\u003esages\u003c/span\u003e”; an epithet for the Buddha.\u003c/p\u003e\",\"names\":{\"english\":\"Munīndra\",\"tibetan\":\"ཐུབ་དབང་།\",\"sanskrit\":\"Munīndra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"thub dbang\"}},{\"uuid\":\"61de6126-bfc2-4c44-8547-1093346724b3\",\"authority\":\"0f23f466-758f-4eb1-ae48-d01906c35e42\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAlso called \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003esubhaga\u003c/em\u003e in Sanskrit. Derived from a gland on the musk deer.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003esha ma ka sha mi\u003c/em\u003e. Chinese: \u003cem class=\\\"foreign\\\"\u003emojiapojia\u003c/em\u003e; \u003cem class=\\\"foreign text-zh\\\" lang=\\\"zh\\\"\u003e莫迦婆伽\u003c/em\u003e.)\u003c/p\u003e\",\"names\":{\"english\":\"musk\",\"tibetan\":\"སྐལ་བ་ཆེ།\",\"sanskrit\":\"mahābhāgā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"skal ba che\"}},{\"uuid\":\"fe6c8a12-edd1-453a-bf29-29adced76b67\",\"authority\":\"97c5b099-30e7-4d07-bce6-5914ef7c456d\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eVariant spelling: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003eyung dkar\u003c/em\u003e; “white mustard.”\u003c/p\u003e\",\"names\":{\"english\":\"mustard seed\",\"tibetan\":\"ཡུང་ཀར།, ཡུངས་འབྲུ།\",\"sanskrit\":\"sarṣapa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yung kar, yungs ’bru\"}},{\"uuid\":\"0d780e14-7170-41d5-ad91-08bec33f57ad\",\"authority\":\"be8845ad-a337-4f5e-ab0e-da21c6cf51b2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe brother of \u003cspan data-glossary-id=\\\"UT22084-089-013-2651\\\"\u003eGayākāśyapa\u003c/span\u003e and \u003cspan data-glossary-id=\\\"UT22084-089-013-2844\\\"\u003eUruvilva­kāśyapa\u003c/span\u003e. A practitioner of fire offering at Uruvilva (Bodhgayā), he and his three hundred students were converted to becoming \u003cspan data-glossary-id=\\\"UT22084-089-013-2450\\\"\u003ebhikṣus\u003c/span\u003e of the Buddha. He and his brothers and their students were the third group to become followers of the Buddha after his enlightenment.\u003c/p\u003e\",\"names\":{\"english\":\"Nadīkāśyapa\",\"tibetan\":\"ཆུ་ཀླུང་འོད་སྲུང་།, ཆུ་བོ་འོད་སྲུང་།\",\"sanskrit\":\"nadīkāśyapa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chu bo ’od srung, chu klung ’od srung\"}},{\"uuid\":\"5a08fb0f-b8eb-4159-8018-bfd9bd66d5d9\",\"authority\":\"bbc77e13-4bdd-4909-bfdd-d8a299ca4508\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA class of nonhuman beings who live in subterranean aquatic environments, where they guard wealth and sometimes also teachings. Nāgas are associated with serpents and have a snakelike appearance. In Buddhist art and in written accounts, they are regularly portrayed as half human and half snake, and they are also said to have the ability to change into human form. Some nāgas are Dharma protectors, but they can also bring retribution if they are disturbed. They may likewise fight one another, wage war, and destroy the lands of others by causing lightning, hail, and flooding.\u003c/p\u003e\",\"names\":{\"english\":\"nāga\",\"tibetan\":\"ཀླུ།\",\"sanskrit\":\"nāga\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"klu\"}},{\"uuid\":\"f262a892-2e4e-41db-9b21-70270af04e46\",\"authority\":\"19ce9942-5a9b-4a32-a81a-c8a8f9a15e6a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e king.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003eThe Tibetan appears to have been translated from a manuscript that had \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-089-013-2750\\\"\u003enārāyaṇa\u003c/span\u003e\u003c/em\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Nāgāyana\",\"tibetan\":\"མཐུ་བོ་ཆེ།\",\"sanskrit\":\"nāgāyana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mthu bo che\"}},{\"uuid\":\"6ae5df56-e875-4695-8e5e-b75069672faa\",\"authority\":\"5ece1be9-938c-43f6-aec1-fee4ecb9a794\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eGoddess of the Nairañjanā River, near which the Buddha practiced asceticism and later attained enlightenment.\u003c/p\u003e\",\"names\":{\"english\":\"Nairañjanāvasinī\",\"tibetan\":\"ནཻ་རཉྫ་ནར་གནས་པ།\",\"sanskrit\":\"nairañjanāvasinī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nai rany+dza nar gnas pa\"}},{\"uuid\":\"d4104d7a-d9ed-4904-9412-8f6d5efefb1f\",\"authority\":\"b7e438cf-4cc8-4b10-918f-3138cc23e3b1\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e king.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ena ku la\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Nakula\",\"tibetan\":\"ཁྱིམ་མེད།\",\"sanskrit\":\"nakula\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"khyim med\"}},{\"uuid\":\"a78a7b35-7bb6-43da-be09-cc552fc679b1\",\"authority\":\"2c826878-47b6-454b-adc8-92f40351abc8\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn \u003cspan data-glossary-id=\\\"UT22084-089-013-2559\\\"\u003easura\u003c/span\u003e king; this is the name of \u003cspan data-glossary-id=\\\"UT22084-089-013-2656\\\"\u003eIndra\u003c/span\u003e’s principal enemy among the \u003cspan data-glossary-id=\\\"UT22084-089-013-2559\\\"\u003easuras\u003c/span\u003e. In Buddhist mythology, Namuci appears as a drought-causing demon, and is also a name of Māra, the principal opponent of the Buddhadharma.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ephrag chen\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Namuci\",\"tibetan\":\"ཕྲག་རྩུབ།\",\"sanskrit\":\"namuci\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"phrag rtsub\"}},{\"uuid\":\"bcfebd30-f67b-4b80-8b66-7db144ef6c18\",\"authority\":\"ed1aaf66-e2c9-4d51-a847-ad97c39097e6\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2503\\\"\u003enāga\u003c/span\u003e king.\u003c/p\u003e\",\"names\":{\"english\":\"Nanda\",\"tibetan\":\"དགའ་བོ།\",\"sanskrit\":\"nanda\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dga’ bo\"}},{\"uuid\":\"13ade592-3240-4469-970f-080ab6be7482\",\"authority\":\"a17d51df-7483-492c-8b9f-ff85e824b7d4\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn alternate name for \u003cspan data-glossary-id=\\\"UT22084-089-013-2863\\\"\u003eViṣṇu\u003c/span\u003e (\u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ekhyab ’jug\u003c/em\u003e).\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003emthu bo che\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Nārāyaṇa\",\"tibetan\":\"སྲེད་མེད་བུ།\",\"sanskrit\":\"nārāyaṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sred med bu\"}},{\"uuid\":\"6e85df16-3c81-41db-bc11-5803eefcc4c0\",\"authority\":\"e6f5fcbc-0973-4225-91e8-3d689be37026\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA buddha.\u003c/p\u003e\",\"names\":{\"english\":\"Net of Light\",\"tibetan\":\"འོད་ཀྱི་དྲ་བ་ཅན།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’od kyi dra ba can\"}},{\"uuid\":\"70028793-c0da-4a9f-ac36-0d5639b49ce4\",\"authority\":\"307cad5c-6acc-4ca1-8a71-6420d09fbf87\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e king.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ene gan\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Nikaṇṭha\",\"tibetan\":\"ངེས་མགྲིན།\",\"sanskrit\":\"nikaṇṭha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nges mgrin\"}},{\"uuid\":\"3cc0410b-727f-4184-aca5-f15cdad3b8bd\",\"authority\":\"b564d2ca-b53a-4ef3-bffb-fe6e2fc9224f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e“Delight in Emanations.” The second highest paradise in the desire realm.\u003c/p\u003e\",\"names\":{\"english\":\"Nirmāṇarati\",\"tibetan\":\"འཕྲུལ་དགའ།\",\"sanskrit\":\"nirmāṇarati\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’phrul dga’\"}},{\"uuid\":\"bebe04fd-2b22-4637-89db-ae1cd69dffe1\",\"authority\":\"4a9c787d-e93e-4757-b5c4-65281f956020\",\"definition\":\"$46\",\"names\":{\"english\":\"nirvāṇa\",\"tibetan\":\"མྱ་ངན་ལས་འདས་པ།\",\"sanskrit\":\"nirvāṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mya ngan las ’das pa\"}},{\"uuid\":\"60d12d7e-1f7e-4517-b2d1-5bae24cae7db\",\"authority\":\"2a3871e4-e448-45db-b811-80087391eb5d\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ebrtson ’grus yongs su ldan pa\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Nityodyukta\",\"tibetan\":\"རྟག་ཏུ་བརྩོན་པ།\",\"sanskrit\":\"nityodyukta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rtag tu brtson pa\"}},{\"uuid\":\"3b40a3c1-0d93-4bb7-a3ad-c5d0ab096f71\",\"authority\":\"766f31ec-6e1b-44c5-a913-91f2ed55b3c6\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe third of the four attainments of śrāvakas, this term refers to a person who will no longer take rebirth in the desire realm (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003ekāmadhātu\u003c/em\u003e), but either be reborn in the Pure Abodes (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eśuddhāvāsa\u003c/em\u003e) or reach the state of an arhat in their current lifetime. (\u003cem class=\\\"distinct\\\"\u003eProvisional 84000 definition. New definition forthcoming.\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"non-returner\",\"tibetan\":\"ཕྱིར་མི་འོང་བ།\",\"sanskrit\":\"anāgāmin\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"phyir mi ’ong ba\"}},{\"uuid\":\"89375010-20fa-46f9-a3aa-8db0788ca507\",\"authority\":\"54012d58-9bfe-4243-b63d-d7c0ca2d5c6a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cem class=\\\"foreign\\\"\u003eCyperus rotundus\u003c/em\u003e. Its tubers are used in \u003cspan data-glossary-id=\\\"UT22084-089-013-2445\\\"\u003eĀyurveda\u003c/span\u003e. \u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 557: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003egas gang\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"nut grass\",\"tibetan\":\"གླ་སྒང་།\",\"sanskrit\":\"musta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gla sgang\"}},{\"uuid\":\"4cce357a-a5a4-4bef-8c8b-3341c68446c8\",\"authority\":\"0630c3ca-3e41-4df0-b6d3-0fb50a987cc6\",\"definition\":\"\u003cp\u003eOne who has achieved the second of the four levels of attainment on the śrāvaka path and who will attain liberation after only one more birth. (\u003cem class=\\\"distinct\\\"\u003eProvisional 84000 definition. New definition forthcoming.\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"once-returner\",\"tibetan\":\"ལན་ཅིག་ཕྱིར་འོང་བ།\",\"sanskrit\":\"sakṛdāgāmin\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lan cig phyir ’ong ba\"}},{\"uuid\":\"07a5c660-5d19-4b02-80cc-369f6e76c919\",\"authority\":\"c9b0dac4-2141-451b-ac81-eeaba2fe689a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cem class=\\\"foreign\\\"\u003eBletilla hyacinthina\u003c/em\u003e, hyacinth orchid. See Ludvik 2007, p. 310. Or possibly \u003cem class=\\\"foreign\\\"\u003eRhizoma iridis\u003c/em\u003e. The root of the iris flower, specifically the Indian iris (\u003cem class=\\\"foreign\\\"\u003eIris pallida\u003c/em\u003e). The root is said to resemble an arm, while the leaves resemble swords, and therefore there is a folktale of its having originated from \u003cspan data-glossary-id=\\\"UT22084-089-013-2656\\\"\u003eIndra\u003c/span\u003e cutting off a \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e’s arm.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 557: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003edbang po’i lag\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"orris root\",\"tibetan\":\"ཨིནྡྲ་ཧསྟ།\",\"sanskrit\":\"indrahasta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"in+d+ra hasta\"}},{\"uuid\":\"f05c4f1c-f3df-4e9f-98e0-4d3b8c1d31d9\",\"authority\":\"914094ae-b224-427d-86ae-bf59e9fe4ff0\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2503\\\"\u003enāga\u003c/span\u003e king.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003epad ma\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Padma\",\"tibetan\":\"པདྨོ།\",\"sanskrit\":\"padma\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"pad+mo\"}},{\"uuid\":\"6df1351f-0981-47ac-afca-0077283aa977\",\"authority\":\"b3c350fe-7120-4109-a472-f0c9060a0872\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the names of Lakṣmī, also known as \u003cspan data-glossary-id=\\\"UT22084-089-013-3204\\\"\u003eŚrī\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Padmā\",\"tibetan\":\"པེ་མ།\",\"sanskrit\":\"padmā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"pe ma\"}},{\"uuid\":\"c4c98d59-9279-4737-96dc-efc6d1309e86\",\"authority\":\"01087444-1c03-4423-baae-60dafabda500\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e“Sublime Lotus Golden Banner.” The palace of the \u003cspan data-glossary-id=\\\"UT22084-089-013-3204\\\"\u003egoddess Śrī\u003c/span\u003e, also known as Lakṣmī.\u003c/p\u003e\",\"names\":{\"english\":\"Padmottara­suvarṇa­dhvaja\",\"tibetan\":\"པདྨ་དམ་པ་གསེར་གྱི་རྒྱལ་མཚན།\",\"sanskrit\":\"padmottara­suvarṇa­dhvaja\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"pad+ma dam pa gser gyi rgyal mtshan\"}},{\"uuid\":\"99488b70-58af-4e3f-9d14-0ed8afe93b2c\",\"authority\":\"7a6c2b29-a49a-4387-a956-dd72c04aaee8\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cem class=\\\"foreign\\\"\u003eButea frondosa\u003c/em\u003e or \u003cem class=\\\"foreign\\\"\u003eButea monosperma\u003c/em\u003e. A tree that grows up to 15 meters tall and has bright red flowers. Other names include flame of the forest, riddle tree, Judas tree, parrot tree, bastard teak, dhak (in Hindi), palas (in Hindi), porasum (in Tamil), and khakda (in Gujarati). There is a tradition of combining its leaves together to make a plate for food.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003eThis is also known as \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003ekiṃśuka\u003c/em\u003e, which is translated in other sūtras as \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ene tso ci las grub pa\u003c/em\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"palash\",\"tibetan\":\"པ་ལ་ཤ།\",\"sanskrit\":\"palāśa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"pa la sha\"}},{\"uuid\":\"a1890c4c-4745-469b-81b0-83beb8ef9e5e\",\"authority\":\"823711aa-478b-47de-a9e5-ed37a5b2cecd\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the fifteen lands in ancient India at the time of the Buddha. This was at the western end of the \u003cspan data-glossary-id=\\\"UT22084-089-013-3197\\\"\u003eGanges\u003c/span\u003e basin, corresponding in the present time to an area in the western part of Uttar Pradesh.\u003c/p\u003e\",\"names\":{\"english\":\"Pañcāla\",\"tibetan\":\"ལྔ་ལེན།\",\"sanskrit\":\"pañcāla\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lnga len\"}},{\"uuid\":\"715f7321-d900-4d5c-9a42-76f2c0565587\",\"authority\":\"03f1a03d-babc-4839-8425-05e3b5c3d2f0\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2486\\\"\u003egandharva\u003c/span\u003e said to live on \u003cspan data-glossary-id=\\\"UT22084-089-013-2916\\\"\u003eGandhamādana\u003c/span\u003e Mountain, on the central peak of five peaks, at the source of the \u003cspan data-glossary-id=\\\"UT22084-089-013-3197\\\"\u003eGanges\u003c/span\u003e. In the early sūtras he acts as a messenger between the \u003cspan data-glossary-id=\\\"UT22084-089-013-2471\\\"\u003edevas\u003c/span\u003e and the Buddha. He is sometimes said to be a form of \u003cspan data-glossary-id=\\\"UT22084-089-013-2739\\\"\u003eMañjuśrī\u003c/span\u003e or historically to have been his original identity. \u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003emgo lnga\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Pañcaśikha\",\"tibetan\":\"ཟུར་ཕུད་ལྔ་ཅན།\",\"sanskrit\":\"pañcaśikha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"zur phud lnga can\"}},{\"uuid\":\"c375bb0c-451a-4d51-8ab9-7d150e7f88ce\",\"authority\":\"344ea1d9-0d6e-4158-8185-8a4d6ee3e837\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e king.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003epañ ts i ka\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Pāñcika\",\"tibetan\":\"ལྔས་རྩེན།\",\"sanskrit\":\"pāñcika\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lngas rtsen\"}},{\"uuid\":\"e4cf94ae-483b-44c6-9bab-efb770053ad6\",\"authority\":\"f1935ed0-dde8-489b-9272-1d2e52151e81\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e“Power Over the Emanations of Others.” The highest paradise in the desire realm.\u003c/p\u003e\",\"names\":{\"english\":\"Paranirmita­vaśavartin\",\"tibetan\":\"གཞན་འཕྲུལ་དབང་བྱེད།\",\"sanskrit\":\"paranirmita­vaśavartin\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gzhan ’phrul dbang byed\"}},{\"uuid\":\"09fe7948-20b9-408c-869d-71e3d970390a\",\"authority\":\"49d44990-c795-44ff-8472-3a1e6e4262cb\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e“Lesser Light.” The lowest of the three paradises that correspond to the second \u003cspan data-glossary-id=\\\"UT22084-089-013-2564\\\"\u003edhyāna\u003c/span\u003e in the form realm. The lowest paradise that is never destroyed at the end of a kalpa, but continues through all kalpas. In other texts translated as \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003esnang ba chung ngu\u003c/em\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Parīttābha\",\"tibetan\":\"འོད་ཆུང་།\",\"sanskrit\":\"parīttābha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’od chung\"}},{\"uuid\":\"249ddf15-b2a4-4012-a907-5f3ff0ad90be\",\"authority\":\"81d99b49-feef-44e4-a5e6-a4708d3a8277\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e“Lesser Goodness.” The lowest of the three paradises that correspond to the third \u003cspan data-glossary-id=\\\"UT22084-089-013-2564\\\"\u003edhyāna\u003c/span\u003e in the form realm.\u003c/p\u003e\",\"names\":{\"english\":\"Parīttaśubha\",\"tibetan\":\"དགེ་ཆུང་།\",\"sanskrit\":\"parīttaśubha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dge chung\"}},{\"uuid\":\"6b9b7665-ee51-41cd-833b-74b4cbfb3e7e\",\"authority\":\"390484ac-3b55-4fbe-8956-05a7625e2823\",\"definition\":\"$47\",\"names\":{\"english\":\"perfections\",\"tibetan\":\"ཕ་རོལ་ཏུ་ཕྱིན་པ།\",\"sanskrit\":\"pāramitā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"pha rol tu phyin pa\"}},{\"uuid\":\"47cf2030-d18d-4774-b6c7-77f890ad8da4\",\"authority\":\"6a2e30b8-b9df-4b1a-88f6-82c10bcf9b37\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e king.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ezas sbyin\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Piṅgala\",\"tibetan\":\"དམར་སེར།\",\"sanskrit\":\"piṅgala\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dmar ser\"}},{\"uuid\":\"6238d630-313e-4fe0-9fe5-8646ed29a756\",\"authority\":\"cb0d1d36-0994-455b-8de6-38010741ea31\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe father of \u003cspan data-glossary-id=\\\"UT22084-089-013-2619\\\"\u003eBalendraketu\u003c/span\u003e and a king in the distant past.\u003c/p\u003e\",\"names\":{\"english\":\"Pinnacle of Lords\",\"tibetan\":\"དབང་པོའི་ཏོག\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dbang po’i tog\"}},{\"uuid\":\"18df3892-84a2-4760-8104-00e27677a9f3\",\"authority\":\"00de0223-2bd6-48b6-af9d-6ad23555d949\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2496\\\"\u003eLicchavī\u003c/span\u003e youth.\u003c/p\u003e\",\"names\":{\"english\":\"Powerful Bestower\",\"tibetan\":\"དབང་པོ་སྦྱིན།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dbang po sbyin\"}},{\"uuid\":\"028700d0-fa97-434c-a088-a916f6def3c0\",\"authority\":\"562e5224-7349-4a7f-a10c-564845f627d8\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2487\\\"\u003egaruḍa\u003c/span\u003e king.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003espos kyi rgyal po che’i byin gyi mthu dang ldan pa\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Powerful King of Elephants\",\"tibetan\":\"སྤོས་ཀྱི་གླང་པོ་ཆེ་མཐུ་སྟོབས་རྒྱལ་པོ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"spos kyi glang po che mthu stobs rgyal po\"}},{\"uuid\":\"52ea6881-4383-4b08-a074-1e566dc75917\",\"authority\":\"07bf1655-7a5b-48dd-a6bd-431b610812c4\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eFaith, mindfulness, diligence, \u003cspan data-glossary-id=\\\"UT22084-089-013-2593\\\"\u003esamādhi\u003c/span\u003e, and wisdom.\u003c/p\u003e\",\"names\":{\"english\":\"powers\",\"tibetan\":\"དབང་པོ།\",\"sanskrit\":\"indriya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dbang po\"}},{\"uuid\":\"372422ef-df74-4afe-bd53-c41e064c575d\",\"authority\":\"011f5ffc-31d6-4d80-909e-6ccbe79e6923\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA buddha.\u003c/p\u003e\",\"names\":{\"english\":\"Prabhājvala\",\"tibetan\":\"འོད་འབར།\",\"sanskrit\":\"prabhājvala\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’od ’bar\"}},{\"uuid\":\"29eb7209-2410-4d6b-89df-5558af86ccd7\",\"authority\":\"35eb5968-7525-465d-b9e3-900f3107dbd7\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn \u003cspan data-glossary-id=\\\"UT22084-089-013-2559\\\"\u003easura\u003c/span\u003e king who waged a thousand-year war against the \u003cspan data-glossary-id=\\\"UT22084-089-013-2471\\\"\u003edevas\u003c/span\u003e and was for a time victorious. He was the grandfather of \u003cspan data-glossary-id=\\\"UT22084-089-013-2620\\\"\u003eBali\u003c/span\u003e. Also known as Prahlādana.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003erab dga’\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Prahrāda\",\"tibetan\":\"དབང་གཞན།\",\"sanskrit\":\"prahrāda\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dbang gzhan\"}},{\"uuid\":\"6fa6b4f4-343d-4d66-a05d-59f9edc85045\",\"authority\":\"af66ea05-0fe0-4398-b4a1-5d99139a7c29\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA Vedic deity who is seen particularly as being the god of animals, especially cattle, which he is said to have created.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003e’jig rten mgon po\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Prajāpati\",\"tibetan\":\"སྐྱེ་དགུ\",\"sanskrit\":\"prajāpati\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"skye dgu\"}},{\"uuid\":\"303ac9fe-1464-4e57-8021-6591732057f8\",\"authority\":\"4f98d8e0-d836-4195-86f8-047d5724059f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2471\\\"\u003edeva\u003c/span\u003e.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003eyid dga’ ba\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Pramudita\",\"tibetan\":\"རབ་དགའ།\",\"sanskrit\":\"pramudita\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rab dga’\"}},{\"uuid\":\"f86b3e7c-b287-4987-aa34-84f2d9c8230e\",\"authority\":\"33fbfba9-0119-4a4e-af48-bd03c98c845a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e king.\u003c/p\u003e\",\"names\":{\"english\":\"Praṇālin\",\"tibetan\":\"ཡུར་བ་ཅན།\",\"sanskrit\":\"praṇālin\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yur ba can\"}},{\"uuid\":\"cdbeb76c-5e86-4899-be00-879b88b310cb\",\"authority\":\"e1d57632-fa38-4a03-8ee4-6c47d2460d88\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe name of ten thousand future buddhas.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ezhal dang spyan rnam par dag cing ut pa la’i dri’i ri mo\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Prasanna­vadanotpala­gandha­kūṭa\",\"tibetan\":\"རབ་ཏུ་དང་བའི་ཞལ་ཨུཏྤ་ལའི་དྲི་བརྩེགས་པ།\",\"sanskrit\":\"prasanna­vadanotpala­gandha­kūṭa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rab tu dang ba’i zhal ut+pa la’i dri brtsegs pa\"}},{\"uuid\":\"dd537b63-172f-4115-ac04-ef342e1774b7\",\"authority\":\"f42315f4-3cee-44ca-872f-8a076ac1f696\",\"definition\":\"$48\",\"names\":{\"english\":\"pratyekabuddha\",\"tibetan\":\"རང་སངས་རྒྱས།\",\"sanskrit\":\"pratyekabuddha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rang sangs rgyas\"}},{\"uuid\":\"d13a3ce1-ffe3-46c4-a837-83256ffbde12\",\"authority\":\"97d90846-62b7-4e32-8c47-5e58980d6c89\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe vehicle comprising the teaching of the \u003cspan data-glossary-id=\\\"UT22084-089-013-2578\\\"\u003epratyekabuddhas\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Pratyeka­buddha­yāna\",\"tibetan\":\"རང་སངས་རྒྱས་ཀྱི་ཐེག་པ།\",\"sanskrit\":\"pratyeka­buddha­yāna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rang sangs rgyas kyi theg pa\"}},{\"uuid\":\"c45f701f-ba33-433e-a819-da5b21d02331\",\"authority\":\"0785d53a-aa79-491e-9ed6-af8e60404f2b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA bodhisattva.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003esprin chen rin po che’i tsan dan sku rnam par bsil ba\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Precious Cloud Sandalwood Cool Body\",\"tibetan\":\"སྤྲིན་ཆེན་རིན་པོ་ཆེ་ཙནྡན་དྲི་བསིལ་སྐུ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sprin chen rin po che tsan+dan dri bsil sku\"}},{\"uuid\":\"7eb37dc1-ba1f-4f18-ac93-39b3b807c51d\",\"authority\":\"51729823-abc4-4d42-abd1-cac0b83a8945\",\"definition\":\"$49\",\"names\":{\"english\":\"preta\",\"tibetan\":\"ཡི་དགས།\",\"sanskrit\":\"preta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yi dags\"}},{\"uuid\":\"25a3eed9-94cb-4bf5-a1a3-940b7ab18675\",\"authority\":\"f400a814-1930-40fe-88f1-fd0fff65e453\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA bodhisattva.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003egong du lung bstan pa thob pa\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Prophesied Attainment\",\"tibetan\":\"ལུང་བསྟན་མཆོག་ཐོབ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lung bstan mchog thob\"}},{\"uuid\":\"ec992896-0df3-497e-a56a-d3f3d932aa28\",\"authority\":\"d647e044-0255-4f28-b89d-39e3479ad712\",\"definition\":\"$4a\",\"names\":{\"english\":\"proximate kleśa\",\"tibetan\":\"ཉེ་བའི་ཉོན་མོངས་པ།\",\"sanskrit\":\"upakleśa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nye ba’i nyon mongs pa\"}},{\"uuid\":\"5fbb4aaa-7ae4-42ed-970d-7cae35c749e6\",\"authority\":\"3d528497-9ee4-4deb-9521-12e502bd6897\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eName of the park where the \u003cspan data-glossary-id=\\\"UT22084-089-013-3204\\\"\u003egoddess Śrī\u003c/span\u003e dwells, not far from \u003cspan data-glossary-id=\\\"UT22084-089-013-2902\\\"\u003eAlakāvati\u003c/span\u003e, the kingdom of the great king \u003cspan data-glossary-id=\\\"UT22084-089-013-2847\\\"\u003eVaiśravaṇa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Puṇya­kusuma­prabha\",\"tibetan\":\"བསོད་ནམས་ཀྱི་མེ་ཏོག་འོད།\",\"sanskrit\":\"puṇya­kusuma­prabha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bsod nams kyi me tog ’od\"}},{\"uuid\":\"f0afc359-857c-4aed-8a82-ffcf584a2306\",\"authority\":\"5ca4b6f2-1b41-4455-997a-67b6de448b4f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA buddha.\u003c/p\u003e\",\"names\":{\"english\":\"Puṇyaprabha\",\"tibetan\":\"བསོད་ནམས་འོད།\",\"sanskrit\":\"puṇyaprabha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bsod nams ’od\"}},{\"uuid\":\"dea36e66-14ea-474b-a4b9-c8798c86f974\",\"authority\":\"ace100da-b895-4eef-b5ab-c505affd8785\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e“Generating Merit.” In the Sarvāstivāda tradition, the second highest of the three paradises that correspond to the fourth \u003cspan data-glossary-id=\\\"UT22084-089-013-2564\\\"\u003edhyāna\u003c/span\u003e in the form realm. Translated in other texts as \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ebsod nams ’phel ba\u003c/em\u003e, “Increasing Merit.”\u003c/p\u003e\",\"names\":{\"english\":\"Puṇyaprasava\",\"tibetan\":\"བསོད་ནམས་སྐྱེས་པ།\",\"sanskrit\":\"puṇyaprasava\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bsod nams skyes pa\"}},{\"uuid\":\"e521677b-1169-437b-a622-dfb127298b42\",\"authority\":\"0daee62a-5939-43fc-8b70-86870d1927c9\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA bodhisattva.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003etshul khrims rnam par dag pa\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Pure Ethics\",\"tibetan\":\"ཚུལ་ཁྲིམས་རྣམ་དག\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"tshul khrims rnam dag\"}},{\"uuid\":\"4ae4e2a0-3747-45cc-b7cf-dc83a010cd64\",\"authority\":\"46e7bc87-2a67-4b93-94b8-a75d1aa0be6f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e lord.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003erdzogs bzang\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Pūrṇabhadra\",\"tibetan\":\"གང་བ་བཟང་པོ།\",\"sanskrit\":\"pūrṇabhadra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gang ba bzang po\"}},{\"uuid\":\"bc0f96a8-febc-490d-b82e-87d25162c38f\",\"authority\":\"0ed89aa0-a1ba-4d64-a7da-d82585971029\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the twenty-eight asterisms or constellations that the sun passes through during the course of a year, which are “lunar mansions” in the plane of the sky. It is composed of the three star systems: Gamma Cancri, Delta Cancri, and Theta Cancri. In the Western zodiac it is equivalent to the very end of Cancer and nearly half of Leo‍—in other words, the end of July and the first part of August.\u003c/p\u003e\",\"names\":{\"english\":\"Puṣya\",\"tibetan\":\"རྒྱལ་བ།\",\"sanskrit\":\"puṣya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rgyal ba\"}},{\"uuid\":\"f1d6b802-7d28-4c82-8c84-d5a20ec67b20\",\"authority\":\"618d3fc0-8248-4b14-a157-c7b621250e8b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn incarnation of a goddess as a milkmaid, who became Kṛṣṇa’s lover.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 556 Degé: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ergan’ mo\u003c/em\u003e.)\u003c/p\u003e\",\"names\":{\"english\":\"Rādhā\",\"tibetan\":\"དགའ་མོ།\",\"sanskrit\":\"rādhā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dga’ mo\"}},{\"uuid\":\"2c62c2ea-8732-43ed-8b33-ab1995d4eef8\",\"authority\":\"050090f0-4bf7-484e-a570-d55b687f79d5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2587\\\"\u003etathāgata\u003c/span\u003e.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eSuvarṇa­śata­prabhā­garbha\u003c/em\u003e; \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003egser brgya’i ’od kyi rnying po\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Radiance of a Hundred Suns’ Illuminating Essence\",\"tibetan\":\"ཉི་མ་བརྒྱའི་འོད་ཟེར་སྣང་བའི་སྙིང་པོ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nyi ma brgya’i ’od zer snang ba’i snying po\"}},{\"uuid\":\"c0ea2402-0c69-4659-8881-0d7acb1573c6\",\"authority\":\"8fbd3aa5-f428-4e82-b98b-013029675360\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA buddha.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003eme tog bkod pa’i ’od\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Radiant Flower Display\",\"tibetan\":\"མེ་ཏོག་འོད་བཀོད།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"me tog ’od bkod\"}},{\"uuid\":\"d345ac3f-e986-476d-baf1-33ccaea674a7\",\"authority\":\"df74b2cc-e30a-4a58-8507-4dd54e98becf\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn \u003cspan data-glossary-id=\\\"UT22084-089-013-2559\\\"\u003easura\u003c/span\u003e king said to cause eclipses.\u003c/p\u003e\",\"names\":{\"english\":\"Rāhu\",\"tibetan\":\"སྒྲ་གཅན།\",\"sanskrit\":\"rāhu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sgra gcan\"}},{\"uuid\":\"2cc28aa3-b932-4e89-9496-b9c925f9a9ff\",\"authority\":\"a05175c9-e2b3-438b-bfb4-4670ca3ddf37\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-089-013-2797\\\"\u003eŚākyamuni\u003c/span\u003e Buddha’s son who became the first novice monk and a prominent member of his monastic \u003cspan data-glossary-id=\\\"UT22084-089-013-2522\\\"\u003esaṅgha\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Rāhula\",\"tibetan\":\"སྒྲ་གཅན་ཟིན།, སྒྲ་གཅན།\",\"sanskrit\":\"Rāhula\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sgra gcan, sgra gcan zin\"}},{\"uuid\":\"8a64da85-ad7e-4c47-b376-c981f1c2a4b2\",\"authority\":\"b5a161b5-2aa7-4c37-a473-82556d4a3e8b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe ancient capital of Magadha prior to its relocation to Pāṭaliputra during the Mauryan dynasty, Rājagṛha is one of the most important locations in Buddhist history. The literature tells us that the Buddha and his saṅgha spent a considerable amount of time in residence in and around Rājagṛha‍—in nearby places, such as the Vulture Peak Mountain (Gṛdhrakūṭaparvata), a major site of the Mahāyāna sūtras, and the Bamboo Grove (Veṇuvana)‍—enjoying the patronage of King Bimbisāra and then of his son King Ajātaśatru. Rājagṛha is also remembered as the location where the first Buddhist monastic council was held after the Buddha Śākyamuni passed into parinirvāṇa. Now known as Rajgir and located in the modern Indian state of Bihar.\u003c/p\u003e\",\"names\":{\"english\":\"Rājagṛha\",\"tibetan\":\"རྒྱལ་པོའི་ཁབ།\",\"sanskrit\":\"rājagṛha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rgyal po’i khab\"}},{\"uuid\":\"7e5f6c6d-de35-47b5-9bbf-53cefcb94baf\",\"authority\":\"876d2af6-1945-40b0-a434-a0a06775fa7e\",\"definition\":\"\u003cp\u003eA class of nonhuman beings that are often, but certainly not always, considered demonic in the Buddhist tradition. They are often depicted as flesh-eating monsters who haunt frightening places and are ugly and evil-natured with a yearning for human flesh, and who additionally have miraculous powers, such as being able to change their appearance.\u003c/p\u003e\",\"names\":{\"english\":\"rākṣasa\",\"tibetan\":\"སྲིན་པོ།\",\"sanskrit\":\"rākṣasa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"srin po\"}},{\"uuid\":\"7dd7cd0e-93b0-4530-9a32-1b6ba6067f09\",\"authority\":\"b3a87822-4d62-4039-a732-1ec156e16031\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA king of Tibet, born ca. 806. His formal name was Tritsuk Detsen (\u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ekhri gtsug lde btsan\u003c/em\u003e), and he reigned from 815 to 838.\u003c/p\u003e\",\"names\":{\"english\":\"Ralpachen\",\"tibetan\":\"རལ་པ་ཅན།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ral pa can\"}},{\"uuid\":\"6415d3d1-05d3-48b0-850d-ca82906dff98\",\"authority\":\"d9d86fa8-f9be-4094-8535-e33003d719cc\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe extraction of the elixir of life from herbs or minerals.\u003c/p\u003e\",\"names\":{\"english\":\"rasāyana\",\"tibetan\":\"སྨན་བཅུད་ཀྱིས་ལེན།\",\"sanskrit\":\"rasāyana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sman bcud kyis len\"}},{\"uuid\":\"64c9a95c-ea88-4be7-be2c-d794bc29461c\",\"authority\":\"cc2659e7-0ce2-4da7-a05d-205bcdc8776a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA bodhisattva.\u003c/p\u003e\",\"names\":{\"english\":\"Ratibala\",\"tibetan\":\"དགའ་བའི་སྟོབས།\",\"sanskrit\":\"ratibala\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dga’ ba’i stobs\"}},{\"uuid\":\"e084d98c-6609-427a-ada5-7a8b6d1be56c\",\"authority\":\"6b0c1f01-c396-4568-ab47-e16428e39098\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2496\\\"\u003eLicchavī\u003c/span\u003e youth.\u003c/p\u003e\",\"names\":{\"english\":\"Ratnagarbha\",\"tibetan\":\"རིན་ཆེན་སྙིང་པོ།\",\"sanskrit\":\"ratnagarbha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rin chen snying po\"}},{\"uuid\":\"98732aab-365a-4b36-af84-0d2d40338ccd\",\"authority\":\"8d7b012e-6dd4-4cd6-aab9-7d66f8727695\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA buddha.\u003c/p\u003e\",\"names\":{\"english\":\"Ratnagarbha\",\"tibetan\":\"རིན་ཆེན་སྙིང་པོ།\",\"sanskrit\":\"ratnagarbha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rin chen snying po\"}},{\"uuid\":\"667c83e6-4afe-4dd5-9432-17eb785f0183\",\"authority\":\"9b84e197-a9de-418a-96f3-c0c05a5a1bb3\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e king.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003erin chen gtsug phud\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Ratnakeśa\",\"tibetan\":\"རིན་ཆེན་སྐྲ།\",\"sanskrit\":\"ratnakeśa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rin chen skra\"}},{\"uuid\":\"c10c0c1a-4fb8-494d-916f-0269e31c11bc\",\"authority\":\"b80d852d-4f99-48d9-98c0-c0348c4867b6\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe principal buddha of the southern direction.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003eSee also Toh 555, \u003ca href=\\\"https://read.84000.co/translation/toh555#UT22084-089-012-3853\\\" target=\\\"UT22084-089-012.html\\\" data-pointer-type=\\\"id\\\"\u003eg.376\u003c/a\u003e .\u003c/p\u003e\",\"names\":{\"english\":\"Ratnaketu\",\"tibetan\":\"རིན་ཆེན་ཏོག\",\"sanskrit\":\"ratnaketu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rin chen tog\"}},{\"uuid\":\"0a6bdcb0-1cf8-4a20-a26c-ff2e2a9892bc\",\"authority\":\"9e60b6fc-21d7-4fa3-bc33-fc88e86983da\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the bodhisattvas present at \u003cspan data-glossary-id=\\\"UT22084-089-013-2917\\\"\u003eVulture Peak\u003c/span\u003e.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003eIn Toh 555 the bodhisattva’s name is Ratnadhvaja (\u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003erin po che’i rgyal mtshan\u003c/em\u003e).\u003c/p\u003e\",\"names\":{\"english\":\"Ratnaketu\",\"tibetan\":\"རིན་པོ་ཆེའི་ཏོག\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rin po che’i tog\"}},{\"uuid\":\"c0f4fdd1-04a4-488d-af7b-df79bcf467c2\",\"authority\":\"970f1865-5bf9-4d53-b46f-b8510ccb4478\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eVaiḍūrya­kanaka­giri­ratna­kusuma­prabhā­śrīguṇa­sāgara\u003c/em\u003e; \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ebai DUr+ya dang gser gyi ri bo rin po che’i me tog snang ba spal gyi yon tan rgya mtsho\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Ratna­kusuma­guṇa­sāgara­vaiḍūrya­kanaka­giri­suvarṇa­kāñcana­prabhāsaśrī\",\"tibetan\":\"རིན་ཆེན་མེ་ཏོག་ཡོན་ཏན་རྒྱ་མཚོ་བཻ་ཌཱུརྱ་དང་གསེར་གྱི་རི་ཁ་དོག་བཟང་པོ་གསེར་དུ་སྣང་བའི་དཔལ།\",\"sanskrit\":\"ratna­kusuma­guṇa­sāgara­vaiḍūrya­kanaka­giri­suvarṇa­kāñcana­prabhāsaśrī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rin chen me tog yon tan rgya mtsho bai DUr+ya dang gser gyi ri kha dog bzang po gser du snang ba’i dpal\"}},{\"uuid\":\"61017ef1-caab-44fb-8a78-5283a71571ef\",\"authority\":\"41a7a2ce-5596-47d1-baea-77f2c069616b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA buddha.\u003c/p\u003e\",\"names\":{\"english\":\"Ratnaprabha\",\"tibetan\":\"རིན་ཆེན་འོད།\",\"sanskrit\":\"ratnaprabha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rin chen ’od\"}},{\"uuid\":\"029b03ef-f419-4162-9af1-46d6a28c3a9f\",\"authority\":\"6c8a0807-7714-448f-a0d0-d6b9fa91c26f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA buddha.\u003c/p\u003e\",\"names\":{\"english\":\"Ratnārci\",\"tibetan\":\"རིན་ཆེན་འོད་འཕྲོ།\",\"sanskrit\":\"ratnārci\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rin chen ’od ’phro\"}},{\"uuid\":\"216fea15-b9dd-4757-8088-4c244086c3b3\",\"authority\":\"a227ea38-2e43-422e-bf63-1267c5183bfc\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA buddha.\u003c/p\u003e\",\"names\":{\"english\":\"Ratnārci\",\"tibetan\":\"རིན་ཆེན་འོད་འཕྲོ།\",\"sanskrit\":\"ratnārci\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rin chen ’od ’phro\"}},{\"uuid\":\"0fad7036-66c0-4254-a572-211f8ffb4464\",\"authority\":\"c22fad2b-3b59-44e7-acbd-d980541a0ca6\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA buddha in the distant past.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003erin chen gtsug phud\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Ratnaśikhin\",\"tibetan\":\"རིན་ཆེན་གཙུག་ཏོར་ཅན།\",\"sanskrit\":\"ratnaśikhin\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rin chen gtsug tor can\"}},{\"uuid\":\"f34c08f4-c583-42a8-9bc4-4eba6c7e3dfd\",\"authority\":\"4c872780-2b64-49d1-b2bf-0158b1205e66\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2474\\\"\u003edharmabhāṇaka\u003c/span\u003e in the distant past who eventually became the Buddha \u003cspan data-glossary-id=\\\"UT22084-089-013-2604\\\"\u003eAkṣobhya\u003c/span\u003e.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Yongle, Lithang, Peking, Narthang, and Choné: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003erin chen sogs\u003c/em\u003e, \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003erin chen sogs pa\u003c/em\u003e. Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003erin chen brtsegs pa\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Ratnoccaya\",\"tibetan\":\"རིན་ཆེན་སོགས་པ།\",\"sanskrit\":\"ratnoccaya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rin chen sogs pa\"}},{\"uuid\":\"910f589b-d40b-472b-bb24-fb5d9d315dbe\",\"authority\":\"5be5d418-9201-41c9-bfb9-166037414fe9\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cem class=\\\"foreign\\\"\u003eArsenic sulphide\u003c/em\u003e, which consists of bright orange-red soft crystals, is also called “ruby sulphur” and “ruby of arsenic.” A number of Sanskrit synonyms include \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eyavāgraja\u003c/em\u003e, \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003epākya\u003c/em\u003e, \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003emanoguptā\u003c/em\u003e, \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003enāgajihivikā\u003c/em\u003e, \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003egolā\u003c/em\u003e, \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eśilā\u003c/em\u003e, \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003ekunṭī\u003c/em\u003e, and \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003enaipālī\u003c/em\u003e. \u003c/p\u003e\",\"names\":{\"english\":\"realgar\",\"tibetan\":\"ནི་ལྡོང་རོས།\",\"sanskrit\":\"manaḥśilā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ni ldong ros\"}},{\"uuid\":\"454abb50-cb5e-4b1c-b6cb-ee32ddd710e9\",\"authority\":\"78351c1c-a96f-4662-a2ab-3668756d6423\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA buddha.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003elegs ’od dri med grags pa’i rgyal po\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Renowned King Virtuous Stainless Light\",\"tibetan\":\"དགེ་འོད་དྲི་མ་མེད་པར་གྲགས་པའི་རྒྱལ་པོ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dge ’od dri ma med par grags pa’i rgyal po\"}},{\"uuid\":\"75043ae2-050e-46ec-92e8-35e7c85e2bf2\",\"authority\":\"5f37028a-f8f6-4b3e-8ce9-286b18cec362\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2503\\\"\u003enāga\u003c/span\u003e king.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003echu’i rgyu ’dzin\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"River Holder\",\"tibetan\":\"ཀླུང་འཛིན།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"klung ’dzin\"}},{\"uuid\":\"2529a08b-439a-4a18-afb2-06da36ba7bc6\",\"authority\":\"2311f2d7-958b-4639-bc9d-0bc65a24c66b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2503\\\"\u003enāga\u003c/span\u003e king.\u003c/p\u003e\",\"names\":{\"english\":\"Royal Light\",\"tibetan\":\"རྒྱལ་པོ་འོད།\",\"sanskrit\":\"śataraśmi\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rgyal po ’od\"}},{\"uuid\":\"1dbcd19e-bf08-4064-bb95-2da8bedfaff5\",\"authority\":\"97e18157-ca2d-44c4-905f-45bb066725ec\",\"definition\":\"\u003cp\u003eAn ancient Indian spiritual title, often translated as “sage” or “seer.” The title is particularly used for divinely inspired individuals credited with creating the foundations of Indian culture. The term is also applied to Śākyamuni and other realized Buddhist figures.\u003c/p\u003e\",\"names\":{\"english\":\"ṛṣi\",\"tibetan\":\"དྲང་སྲོང་།\",\"sanskrit\":\"ṛṣi\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"drang srong\"}},{\"uuid\":\"727c3a9f-2dae-46b4-89e7-d5f8bedeb247\",\"authority\":\"fc787159-0811-4245-8150-7da1c68afab4\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe name of a bodhisattva.\u003c/p\u003e\",\"names\":{\"english\":\"Ruciraketu\",\"tibetan\":\"མཛེས་པའི་ཏོག\",\"sanskrit\":\"ruciraketu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mdzes pa’i tog\"}},{\"uuid\":\"7006432b-e193-40f7-aa2f-4ff61df35bd1\",\"authority\":\"ff424bbe-1bbd-48a2-b155-2a231244892c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe name of a prince. Son of the king \u003cspan data-glossary-id=\\\"UT22084-089-013-2619\\\"\u003eBalendraketu\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Ruciraketu\",\"tibetan\":\"མཛེས་པའི་ཏོག\",\"sanskrit\":\"ruciraketu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mdzes pa’i tog\"}},{\"uuid\":\"86a25f84-5d03-4120-8da2-a789bbc11c74\",\"authority\":\"415756b8-38af-43b0-9b93-f33a80ffbb30\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe older son of the bodhisattva \u003cspan data-glossary-id=\\\"UT22084-089-013-2790\\\"\u003eRuciraketu\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Rūpyaketu\",\"tibetan\":\"དངུལ་ཏོག\",\"sanskrit\":\"rūpyaketu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dngul tog\"}},{\"uuid\":\"fdc66fbb-9edb-4f2f-b926-cb8dd58dcb62\",\"authority\":\"a74c47c2-567d-4641-a400-b770c48343f8\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe younger son of the bodhisattva \u003cspan data-glossary-id=\\\"UT22084-089-013-2790\\\"\u003eRuciraketu\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Rūpyaprabha\",\"tibetan\":\"དངུལ་འོད།\",\"sanskrit\":\"rūpyaprabha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dngul ’od\"}},{\"uuid\":\"8b1b7220-94d9-4967-a2c0-e5a4a7d2dab9\",\"authority\":\"1adb9d47-1b19-42c3-9b33-10f13c2ce686\",\"definition\":\"$4b\",\"names\":{\"english\":\"Sadāprarudita\",\"tibetan\":\"རྟག་ཏུ་ངུ།\",\"sanskrit\":\"sadāprarudita\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rtag tu ngu\"}},{\"uuid\":\"952ee94a-e97f-483f-bcf1-c7d4ce088802\",\"authority\":\"af199471-e234-4d66-a017-44d4c4093c22\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cem class=\\\"foreign\\\"\u003eCrocus sativus\u003c/em\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"saffron\",\"tibetan\":\"གུར་གུམ།\",\"sanskrit\":\"kuṅkuma\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gur gum\"}},{\"uuid\":\"13ba4dc3-c711-4a17-bd8e-194dfd420d8c\",\"authority\":\"e09d6f2d-ba80-4c9b-8733-01c44d62135e\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe principal \u003cspan data-glossary-id=\\\"UT22084-089-013-2503\\\"\u003enāga\u003c/span\u003e king in \u003ccite class=\\\"title text-en\\\" lang=\\\"en\\\"\u003eThe King of Samādhis Sūtra\u003c/cite\u003e and \u003ccite class=\\\"title text-en\\\" lang=\\\"en\\\"\u003eThe Questions of the Nāga King Sāgara\u003c/cite\u003e. This is also said to be another name for Vaṛuna, the god of the oceans.\u003c/p\u003e\",\"names\":{\"english\":\"Sāgara\",\"tibetan\":\"རྒྱ་མཚོ།\",\"sanskrit\":\"sāgara\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rgya mtsho\"}},{\"uuid\":\"17d04c49-8e95-41c0-b028-a1848108ba0d\",\"authority\":\"6621ff02-64cd-49b5-bc1e-e39375198dae\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA bodhisattva.\u003c/p\u003e\",\"names\":{\"english\":\"Sāgara\",\"tibetan\":\"རྒྱ་མཚོ།\",\"sanskrit\":\"sāgara\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rgya mtsho\"}},{\"uuid\":\"eef17539-251c-4ba2-bd32-f92a5d6e4a56\",\"authority\":\"362a3fe1-9b3c-40a0-8937-1f3244a502f5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA title that, like “buddha,” is given to those who have attained realization through their own contemplation and not by divine revelation.\u003c/p\u003e\",\"names\":{\"english\":\"sage\",\"tibetan\":\"ཐུབ་པ།\",\"sanskrit\":\"muni\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"thub pa\"}},{\"uuid\":\"48821165-db0c-449c-8bc7-b185d4941fd3\",\"authority\":\"53c4843a-47d4-4c6c-9809-8e95f5045eb3\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eIndian Buddhist name for either the four-continent world in which the Buddha \u003cspan data-glossary-id=\\\"UT22084-089-013-2797\\\"\u003eŚākyamuni\u003c/span\u003e appeared, or a universe of a thousand million such worlds. The name Sahā possibly derives from the Sanskrit √\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003esah\u003c/em\u003e, “to bear, endure, or withstand.” It is often interpreted as alluding to the inhabitants of this world having to endure suffering. The Tibetan translation, \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003emi mjed\u003c/em\u003e, follows along the same lines. It literally means “not unbearable,” in the sense that beings here are able to bear the suffering they experience. \u003c/p\u003e\",\"names\":{\"english\":\"Sahā\",\"tibetan\":\"མི་མཇེད།\",\"sanskrit\":\"sahā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mi mjed\"}},{\"uuid\":\"30470857-9228-4b50-ad00-ff8c913dc02a\",\"authority\":\"315d1554-9570-42a2-82a3-36f3790eccc9\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn epithet for the historical Buddha, Siddhārtha Gautama: he was a \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003emuni\u003c/em\u003e (“sage”) from the Śākya clan. He is counted as the fourth of the first four buddhas of the present Good Eon, the other three being Krakucchanda, Kanakamuni, and Kāśyapa. He will be followed by Maitreya, the next buddha in this eon.\u003c/p\u003e\",\"names\":{\"english\":\"Śākyamuni\",\"tibetan\":\"ཤཱཀྱ་ཐུབ་པ།\",\"sanskrit\":\"śākyamuni\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shAkya thub pa\"}},{\"uuid\":\"39dcd9b4-ca83-4d6e-b1de-0a82f1b693f0\",\"authority\":\"cd1e85dd-29b1-45d3-9489-73c3336fb9c6\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cem class=\\\"foreign\\\"\u003eShorea robusta\u003c/em\u003e. The dominant tree in the forests where it occurs.\u003c/p\u003e\",\"names\":{\"english\":\"sal\",\"tibetan\":\"སཱ་ལ།\",\"sanskrit\":\"sāla, śāla\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sA la\"}},{\"uuid\":\"46e996f3-5f00-47cf-bf5d-2ee88dbbb2ea\",\"authority\":\"457cff80-4c64-4081-bf67-bdd21b1c8139\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA world realm in the distant future.\u003c/p\u003e\",\"names\":{\"english\":\"Śālendra­dhvajāgravatī\",\"tibetan\":\"སཱ་ལའི་དབང་པོ་མཐོན་པོའི་རྒྱལ་མཚན།\",\"sanskrit\":\"śālendra­dhvajāgravatī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sA la’i dbang po mthon po’i rgyal mtshan\"}},{\"uuid\":\"5c76a316-06d8-45cc-9036-0b289b210d69\",\"authority\":\"1f935435-8218-4738-a453-aac30854a2a5\",\"definition\":\"$4c\",\"names\":{\"english\":\"samādhi\",\"tibetan\":\"ཏིང་ངེ་འཛིན།\",\"sanskrit\":\"samādhi\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ting nge ’dzin\"}},{\"uuid\":\"0402a752-9049-4d64-a5f8-f7e2c73b0e8a\",\"authority\":\"eef58685-0aa3-4d13-9c38-8c9f8521d62d\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003ePresently classed as one of the eight principal bodhisattvas, he is distinct from the primordial buddha with the same name in the Tibetan Nyingma tradition. He is prominent in \u003ccite class=\\\"title text-en\\\" lang=\\\"en\\\"\u003e\u003ca target=\\\"_blank\\\" href=\\\"https://read.84000.co/translation/toh44-45.html\\\" title=\\\"The Stem Array\\\"\u003eThe Stem Array\u003c/a\u003e\u003c/cite\u003e (\u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eGaṇḍavyūha\u003c/cite\u003e, Toh 44-45), and also in \u003ccite class=\\\"title text-en\\\" lang=\\\"en\\\"\u003e\u003ca target=\\\"_blank\\\" href=\\\"https://read.84000.co/translation/toh113.html\\\" title=\\\"The White Lotus of the Good Dharma\\\"\u003eThe White Lotus of the Good Dharma\u003c/a\u003e\u003c/cite\u003e (Toh 113, \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eSaddharma­puṇḍarīka\u003c/cite\u003e) and \u003ccite class=\\\"title text-en\\\" lang=\\\"en\\\"\u003eThe White Lotus of Great Compassion\u003c/cite\u003e (Toh 111, \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eMahā­karuṇā­puṇḍarīka­sūtra\u003c/cite\u003e). \u003c/p\u003e\",\"names\":{\"english\":\"Samantabhadra\",\"tibetan\":\"ཀུན་ཏུ་བཟང་པོ།\",\"sanskrit\":\"samantabhadra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kun tu bzang po\"}},{\"uuid\":\"2bc815a0-ca9f-450d-88d4-59bea4f6f61e\",\"authority\":\"4f8c21d4-9d29-4f99-bea1-cd2f682a463d\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA buddha.\u003c/p\u003e\",\"names\":{\"english\":\"Samantaprabha\",\"tibetan\":\"ཀུན་ཏུ་འོད།\",\"sanskrit\":\"samantaprabha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kun tu ’od\"}},{\"uuid\":\"d62fa8e6-a65c-43c3-8962-1f5f9822fa34\",\"authority\":\"f744fb52-d4b8-44a8-be43-bc9b4bd2eca4\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA buddha.\u003c/p\u003e\",\"names\":{\"english\":\"Samantāvabhāsa\",\"tibetan\":\"ཀུན་ཏུ་སྣང་བ།\",\"sanskrit\":\"samantāvabhāsa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kun tu snang ba\"}},{\"uuid\":\"cba81b20-4ff3-4081-82ab-0587f3e6e48c\",\"authority\":\"65e3e92a-cc1b-4b1f-88b8-39eccbecc032\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA bodhisattva.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ekun tu spyan ras gzigs kyi dbang po\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Samantāvalokiteśvara\",\"tibetan\":\"ཀུན་ཏུ་སྤྱན་རས་གཟིགས་དབང་ཕྱུག\",\"sanskrit\":\"samantāvalokiteśvara\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kun tu spyan ras gzigs dbang phyug\"}},{\"uuid\":\"a56b0539-1a6a-490e-bb85-5444d16ee137\",\"authority\":\"1b579d82-b45b-4056-8d73-1cd34a70a1b6\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe Sanskrit literally means “attainment,” and is used to refer specifically to meditative attainment and to particular meditative states. The Tibetan translators interpreted it as \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003esama-āpatti\u003c/em\u003e, which suggests the idea of “equal” or “level”; however, they also parsed it as \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003esam-āpatti\u003c/em\u003e, in which case it would have the sense of “concentration” or “absorption,” much like \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003esamādhi\u003c/em\u003e, but with the added sense of “attainment.”\u003c/p\u003e\",\"names\":{\"english\":\"samāpatti\",\"tibetan\":\"སྙོམས་པར་འཇུག་པ།\",\"sanskrit\":\"samāpatti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"snyoms par ’jug pa\"}},{\"uuid\":\"400c6243-9437-40e0-801b-1a346d491d92\",\"authority\":\"90f21047-4c56-44d7-b3cd-a58742dcb1ef\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e general.\u003c/p\u003e\",\"names\":{\"english\":\"Saṃjñeya\",\"tibetan\":\"ཡང་དག་ཤེས།\",\"sanskrit\":\"saṃjñeya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yang dag shes\"}},{\"uuid\":\"92bc860e-35a2-4273-9615-133b0c3534a4\",\"authority\":\"358d1f13-838f-44a7-9595-04699ebf2524\",\"definition\":\"\u003cp\u003eA state of involuntary existence conditioned by afflicted mental states and the imprint of past actions, characterized by suffering in a cycle of life, death, and rebirth. On its reversal, the contrasting state of nirvāṇa is attained, free from suffering and the processes of rebirth.\u003c/p\u003e\",\"names\":{\"english\":\"saṃsāra\",\"tibetan\":\"འཁོར་བ།\",\"sanskrit\":\"saṃsāra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’khor ba\"}},{\"uuid\":\"277591cf-3f67-44f3-8f87-e43dfb047a68\",\"authority\":\"c3c1abae-d223-4327-a031-30c905995797\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn \u003cspan data-glossary-id=\\\"UT22084-089-013-2559\\\"\u003easura\u003c/span\u003e king.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003esdom po pa\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Saṃvara\",\"tibetan\":\"བདེ་མཆོག\",\"sanskrit\":\"saṃvara\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bde mchog\"}},{\"uuid\":\"6750ea4d-1f76-48b8-a24b-eef4eaada4de\",\"authority\":\"9fdd9aab-c544-4a22-bde1-502c5f644ddb\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e“Perfectly realized one.” A buddha who teaches the Dharma, as opposed to a \u003cspan data-glossary-id=\\\"UT22084-089-013-2578\\\"\u003epratyekabuddha\u003c/span\u003e, who does not teach.\u003c/p\u003e\",\"names\":{\"english\":\"samyaksaṃbuddha\",\"tibetan\":\"ཡང་དག་པར་རྫོགས་པའི་སངས་རྒྱས།\",\"sanskrit\":\"samyaksaṃbuddha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yang dag par rdzogs pa’i sangs rgyas\"}},{\"uuid\":\"400ee81c-f76e-4dee-ae22-6914b5fc3df8\",\"authority\":\"aa37aa76-95f8-45e5-9721-fabcafc08bf5\",\"definition\":\"\",\"names\":{\"english\":\"sandalwood\",\"tibetan\":\"ཙནྡན།\",\"sanskrit\":\"candana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"tsan+dan\"}},{\"uuid\":\"7078fbd0-e398-4d44-b061-a6b5fe6bfce4\",\"authority\":\"34e21f8f-bc5b-45e8-ac86-82156fd45708\",\"definition\":\"\u003cp\u003eThough often specifically reserved for the monastic community, this term can be applied to any of the four Buddhist communities‍—monks, nuns, laymen, and laywomen‍—as well as to identify the different groups of practitioners, like the community of bodhisattvas or the community of śrāvakas. It is also the third of the Three Jewels (\u003cem class=\\\"foreign\\\"\u003etriratna\u003c/em\u003e) of Buddhism: the Buddha, the Teaching, and the Community. \u003c/p\u003e\",\"names\":{\"english\":\"saṅgha\",\"tibetan\":\"དགེ་འདུན།\",\"sanskrit\":\"saṅgha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dge ’dun\"}},{\"uuid\":\"5320ab53-5217-4169-ac5b-a1778de71ca2\",\"authority\":\"028f92a7-eb1f-4d2a-9d19-a4c4c188481c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the principal śrāvaka disciples of the Buddha, he was renowned for his discipline and for having been praised by the Buddha as foremost of the wise (often paired with Maudgalyā­yana, who was praised as foremost in the capacity for miraculous powers). His father, Tiṣya, to honor Śāriputra’s mother, Śārikā, named him Śāradvatīputra, or, in its contracted form, Śāriputra, meaning “Śārikā’s Son.”\u003c/p\u003e\",\"names\":{\"english\":\"Śāradvatīputra, Śāriputra\",\"tibetan\":\"ཤཱ་རིའི་བུ།\",\"sanskrit\":\"śāriputra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shA ri’i bu\"}},{\"uuid\":\"068fbf99-e394-467f-a59c-45b4bcdd2f78\",\"authority\":\"6b9b9d4b-272c-42a5-b486-d646b22404fc\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe goddess of wisdom, learning, and music.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003espobs pa’i lha mo\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Sarasvatī\",\"tibetan\":\"དབྱངས་ཅན།\",\"sanskrit\":\"sarasvatī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dbyangs can\"}},{\"uuid\":\"a3fad492-87b4-42e1-aa6f-ae960e703af1\",\"authority\":\"47d630fb-008c-4a4b-ad46-ea30c5c551ae\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2496\\\"\u003eLicchavī\u003c/span\u003e youth.\u003c/p\u003e\",\"names\":{\"english\":\"Sarva­sattva­priya­darśana\",\"tibetan\":\"སེམས་ཅན་ཐམས་ཅད་ཀྱིས་མཐོང་ན་དགའ་བ།\",\"sanskrit\":\"sarva­sattva­priya­darśana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sems can thams cad kyis mthong na dga’ ba\"}},{\"uuid\":\"9ab40a47-4d4d-4d5d-87aa-20e5a3d546e5\",\"authority\":\"18d7ba90-62ad-4ad2-830f-df815679318a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e king.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ebde ba’i ri\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Sātāgiri\",\"tibetan\":\"བདེ་བའི་རི་ཉིད།\",\"sanskrit\":\"sātāgiri\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bde ba’i ri nyid\"}},{\"uuid\":\"5a923304-4bac-471e-9911-98cbbdf4aa50\",\"authority\":\"e7fdbd7b-30a9-4571-993c-151c947a4ac4\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA buddha.\u003c/p\u003e\",\"names\":{\"english\":\"Śatakiraṇa\",\"tibetan\":\"འོད་ཟེར་བརྒྱ་པ།\",\"sanskrit\":\"śatakiraṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’od zer brgya pa\"}},{\"uuid\":\"a14bf14e-0326-4f01-b932-42c84f2a12ed\",\"authority\":\"ab6ab852-f68c-4081-b9e7-d7bb44ce1382\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA god who is the king of lightning in the northern direction.\u003c/p\u003e\",\"names\":{\"english\":\"Satamapati\",\"tibetan\":\"རྒྱུན་གྱི་བདག་པོ།\",\"sanskrit\":\"satamapati\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rgyun gyi bdag po\"}},{\"uuid\":\"8c2e38c1-2d4a-406f-8c9d-169cc9a9ce9c\",\"authority\":\"ae725e46-479c-443f-a514-f38dcd244ba7\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe seventh of the \u003cspan data-glossary-id=\\\"UT22084-089-013-3213\\\"\u003etwelve phases of dependent origination\u003c/span\u003e and the second of the \u003cspan data-glossary-id=\\\"UT22084-089-013-2569\\\"\u003efive skandhas\u003c/span\u003e. It refers to pleasant, unpleasant, or neutral sensations as a result of sensory experiences. \u003c/p\u003e\",\"names\":{\"english\":\"sensation\",\"tibetan\":\"ཚོར་བ།\",\"sanskrit\":\"vedanā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"tshor ba\"}},{\"uuid\":\"64108a80-563a-4b78-bf0e-440bb3fb9855\",\"authority\":\"52322944-8a7f-47f2-aff9-48472209b78e\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eWhen associated with the seven heavenly bodies, and therefore the seven days of the week, these are ruby for the sun, moonstone or pearl for the moon, coral for Mars, emerald for Mercury, yellow sapphire for Jupiter, diamond for Venus, and blue sapphire for Saturn. There are variant lists not associated with the heavenly bodies but retaining the number seven, which include gold, silver, and so on. In association with a \u003cspan data-glossary-id=\\\"UT22084-089-013-2460\\\"\u003ecakravartin\u003c/span\u003e, the seven jewels can refer, according to the Abhidharma, to his magical wheel, elephant, horse, wish-fulfilling jewel, queen, minister, and leading householder. In the Tibetan mandala-offering practice, the householder is replaced by a general.\u003c/p\u003e\",\"names\":{\"english\":\"seven jewels, seven precious materials\",\"tibetan\":\"རིན་པོ་ཆེ་སྣ་བདུན།, རིན་པོ་ཆེ་སྣ་བདུན།\",\"sanskrit\":\"saptaratna, saptaratna\",\"pali\":\"\",\"chinese\":\"七寶\",\"wylie\":\"rin po che sna bdun, rin po che sna bdun\"}},{\"uuid\":\"980831a1-2468-404c-ad42-07a23c9c08ce\",\"authority\":\"52322944-8a7f-47f2-aff9-48472209b78e\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe set of seven precious materials or substances includes a range of precious metals and gems, but their exact list varies. The set often consists of gold, silver, beryl, crystal, red pearls, emeralds, and white coral, but may also contain lapis lazuli, ruby, sapphire, chrysoberyl, diamonds, etc. The term is frequently used in the sūtras to exemplify preciousness, wealth, and beauty, and can describe treasures, offering materials, or the features of architectural structures such as stūpas, palaces, thrones, etc. The set is also used to describe the beauty and prosperity of buddha realms and the realms of the gods.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003eIn other contexts, the term \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003esaptaratna\u003c/em\u003e can also refer to the seven precious possessions of a cakravartin or to a set of seven precious moral qualities. \u003c/p\u003e\",\"names\":{\"english\":\"seven jewels, seven precious materials\",\"tibetan\":\"རིན་པོ་ཆེ་སྣ་བདུན།, རིན་པོ་ཆེ་སྣ་བདུན།\",\"sanskrit\":\"saptaratna, saptaratna\",\"pali\":\"\",\"chinese\":\"七寶\",\"wylie\":\"rin po che sna bdun, rin po che sna bdun\"}},{\"uuid\":\"bfa97d91-51df-4818-ad10-1c95ce31d633\",\"authority\":\"4f265cf2-aed2-445c-996a-e15dc55065a6\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cem class=\\\"foreign\\\"\u003eProsopis cineraria\u003c/em\u003e. A tree believed to be auspicious due to the power of its purification properties.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003esha mi\u003c/em\u003e; Toh 556 \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003esha myi\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"shami\",\"tibetan\":\"ཤ་མྱི།\",\"sanskrit\":\"śamī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sha myi\"}},{\"uuid\":\"76159604-dc51-4698-8a9a-1871f7e1dd7b\",\"authority\":\"3267aefd-66d5-4ccb-9cb6-5af1746fa24c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe principal town in the Tsang region of central Tibet, which was the capital during a period of Tibetan history.\u003c/p\u003e\",\"names\":{\"english\":\"Shigatsé\",\"tibetan\":\"གཞིས་ཀ་རྩེ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gzhis ka rtse\"}},{\"uuid\":\"625a1e94-fc39-4df9-ae39-8ee2142344b5\",\"authority\":\"cf3b0613-fbbd-4e4b-9f56-07b2a84f07d4\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA buddha.\u003c/p\u003e\",\"names\":{\"english\":\"Siṃha\",\"tibetan\":\"སེང་གེ\",\"sanskrit\":\"siṃha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"seng ge\"}},{\"uuid\":\"b3c43172-2126-4462-9b9e-11e5c8d64828\",\"authority\":\"542f125b-19b3-4f3f-a789-fac026b38fc9\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2496\\\"\u003eLicchavī\u003c/span\u003e youth.\u003c/p\u003e\",\"names\":{\"english\":\"Siṃhamati\",\"tibetan\":\"སེང་གེའི་བློ་གྲོས།\",\"sanskrit\":\"siṃhamati\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"seng ge’i blo gros\"}},{\"uuid\":\"5e66749d-11b9-45b4-8fed-bcae48244a80\",\"authority\":\"a8a4108a-a6b5-4b67-af28-8a69ac08c4a1\",\"definition\":\"$4d\",\"names\":{\"english\":\"sixty qualities\",\"tibetan\":\"ཡན་ལག་དྲུག་ཅུ།\",\"sanskrit\":\"ṣaṣṭyaṅga, ṣaṣṭāṅga\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yan lag drug cu\"}},{\"uuid\":\"6e470d0b-0f89-42d5-ad54-4622553843c8\",\"authority\":\"6073c1f3-5733-45f3-a03d-2213d96c41a7\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe Indian god of war.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ephrag chen\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Skanda\",\"tibetan\":\"སྐེམ་བྱེད།\",\"sanskrit\":\"skanda\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"skem byed\"}},{\"uuid\":\"19dac541-d922-4290-aa47-4be78357c62d\",\"authority\":\"83d8926f-1d47-4573-b163-50b18bbab57e\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe deity of the moon.\u003c/p\u003e\",\"names\":{\"english\":\"Soma\",\"tibetan\":\"ཟླ་བ།\",\"sanskrit\":\"soma\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"zla ba\"}},{\"uuid\":\"93204a84-a54f-4198-8bc5-b03b248b26cd\",\"authority\":\"9cf9c94d-6d1a-47f9-9edb-840b232286f6\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cem class=\\\"foreign\\\"\u003eNardostachys jatamansi\u003c/em\u003e. Also called “nard,” “nardin,” and “muskroot.” It is of the \u003cspan data-glossary-id=\\\"UT22084-089-013-2548\\\"\u003evalerian\u003c/span\u003e family and grows in the Himalayas. Its rhizome is the source of an aromatic, amber-colored oil.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003eBagchi edition: \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003enarada\u003c/em\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"spikenard\",\"tibetan\":\"ན་ལ་ད།\",\"sanskrit\":\"nalada\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"na la da\"}},{\"uuid\":\"df2147ef-e586-4828-a111-730705966794\",\"authority\":\"b662e79b-4cff-4567-b74a-1c23d3f1fea7\",\"definition\":\"$4e\",\"names\":{\"english\":\"śrāvaka\",\"tibetan\":\"ཉན་ཐོས།\",\"sanskrit\":\"śrāvaka\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nyan thos\"}},{\"uuid\":\"5641abdb-7597-4af2-b321-32243b48023b\",\"authority\":\"e6df66ae-c114-4c40-8ef3-59f530380449\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe vehicle comprising the teaching of the \u003cspan data-glossary-id=\\\"UT22084-089-013-2585\\\"\u003eśrāvakas\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Śrāvakayāna\",\"tibetan\":\"ཉན་ཐོས་ཀྱི་ཐེག་པ།\",\"sanskrit\":\"śrāvakayāna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nyan thos kyi theg pa\"}},{\"uuid\":\"d0faa71d-cf10-4af9-9944-d1f6d407ec7b\",\"authority\":\"95bd6c50-9174-42f3-ba1c-1a95f96c8500\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA name of \u003cspan data-glossary-id=\\\"UT22084-089-013-2773\\\"\u003eRādhā\u003c/span\u003e, Kṛṣṇa’s consort.\u003c/p\u003e\",\"names\":{\"english\":\"Śrīmatī\",\"tibetan\":\"དཔལ་གྱི་བློ་གྲོས།\",\"sanskrit\":\"śrīmatī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dpal gyi blo gros\"}},{\"uuid\":\"437eab6e-fa0e-4159-8aa1-a47cb71f978e\",\"authority\":\"979ab4d0-507a-4b1a-a225-238d5d349a90\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e The lowest of the four formless realms. See also “\u003cspan\u003e\u003cspan data-glossary-id=\\\"UT22084-089-013-3269\\\"\u003estate\u003c/span\u003e\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"state of infinite space\",\"tibetan\":\"ནམ་མཁའ་མཐའ་ཡས་སྐྱེ་མཆེད།\",\"sanskrit\":\"ākāśānantyāyatana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nam mkha’ mtha’ yas skye mched\"}},{\"uuid\":\"388d691f-5388-41b1-9238-fe830205744c\",\"authority\":\"ec1389ef-f8ae-4bcd-8406-9fa88813515a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e The highest of the four formless realms. See also “\u003cspan\u003e\u003cspan data-glossary-id=\\\"UT22084-089-013-3269\\\"\u003estate\u003c/span\u003e\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"state of neither perception nor nonperception\",\"tibetan\":\"འདུ་ཤེས་མེད་འདུ་ཤེས་མེད་མིན་སྐྱེ་མཆེད།\",\"sanskrit\":\"naiva­saṃjñānāsaṃjñāyatana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’du shes med ’du shes med min skye mched\"}},{\"uuid\":\"442e2644-9880-4ee9-bd97-4a2ba40ee989\",\"authority\":\"f7b31981-eba2-49c3-8722-7aa753928ca6\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e The second highest of the four formless realms. See also “\u003cspan\u003e\u003cspan data-glossary-id=\\\"UT22084-089-013-3269\\\"\u003estate\u003c/span\u003e\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"state of nothingness\",\"tibetan\":\"ཅི་ཡང་མེད་པའི་སྐྱེ་མཆེད།\",\"sanskrit\":\"ākiṃcanyāyatana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ci yang med pa’i skye mched\"}},{\"uuid\":\"bd878677-78cd-4364-85ee-3e508a30c7b3\",\"authority\":\"98a2a6bf-fbf2-44ff-bddd-c53418bf76d5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThese can be listed as twelve or as six sense sources (sometimes also called sense fields, bases of cognition, or simply āyatanas).\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003eIn the context of epistemology, it is one way of describing experience and the world in terms of twelve sense sources, which can be divided into inner and outer sense sources, namely: (1–2) eye and form, (3–4) ear and sound, (5–6) nose and odor, (7–8) tongue and taste, (9–10) body and touch, (11–12) mind and mental phenomena.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003eIn the context of the twelve links of dependent origination, only six sense sources are mentioned, and they are the inner sense sources (identical to the six faculties) of eye, ear, nose, tongue, body, and mind.\u003c/p\u003e\",\"names\":{\"english\":\"state, āyatana\",\"tibetan\":\"སྐྱེ་མཆེད།, སྐྱེ་མཆེད།\",\"sanskrit\":\"āyatana, āyatana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"skye mched, skye mched\"}},{\"uuid\":\"b32adfdb-914a-4a80-b4cd-3cbf780b84e0\",\"authority\":\"98a2a6bf-fbf2-44ff-bddd-c53418bf76d5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThis term has various meanings according to context. Here in this sūtra it is used to refer to the four meditative states associated with the formless realm: (1) infinite space, (2) infinite consciousness, (3) nothingness, and (4) neither perception nor nonperception. In the context of epistemology, it is one way of describing experience and the world in terms of twelve sense sources, which can be divided into inner and outer sense sources, namely: (1–2) eye and form, (3–4) ear and sound, (5–6) nose and odor, (7–8) tongue and taste, (9–10) body and touch, (11–12) mind and mental phenomena. In the context of the twelve links of \u003cspan data-glossary-id=\\\"UT22084-089-013-2562\\\"\u003edependent origination\u003c/span\u003e, only six sense sources are mentioned, and they are the inner sense sources (identical to the six faculties) of eye, ear, nose, tongue, body, and mind.\u003c/p\u003e\",\"names\":{\"english\":\"state, āyatana\",\"tibetan\":\"སྐྱེ་མཆེད།, སྐྱེ་མཆེད།\",\"sanskrit\":\"āyatana, āyatana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"skye mched, skye mched\"}},{\"uuid\":\"7878c162-9932-4033-817a-a187455f69fd\",\"authority\":\"536ec2c0-4b1e-4c07-a605-32961d7c3d28\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe first of four stages of spiritual accomplishment on the \u003cspan data-glossary-id=\\\"UT22084-089-013-2585\\\"\u003eśrāvaka\u003c/span\u003e path: stream entrant, \u003cspan data-glossary-id=\\\"UT22084-089-013-2507\\\"\u003eonce-returner\u003c/span\u003e, \u003cspan data-glossary-id=\\\"UT22084-089-013-2505\\\"\u003enon-returner\u003c/span\u003e, and \u003cspan data-glossary-id=\\\"UT22084-089-013-2437\\\"\u003earhat\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"stream entrant\",\"tibetan\":\"རྒྱུན་དུ་ཞུགས་པ།\",\"sanskrit\":\"srotāpanna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rgyun du zhugs pa\"}},{\"uuid\":\"9af9193f-e035-4a78-adc7-61f45871dcc8\",\"authority\":\"0c5ec4ad-cb20-4880-bf35-62ca54d81186\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe five strengths are a stronger form of the five \u003cspan data-glossary-id=\\\"UT22084-089-013-2512\\\"\u003epowers\u003c/span\u003e: faith, mindfulness, diligence, \u003cspan data-glossary-id=\\\"UT22084-089-013-2593\\\"\u003esamādhi\u003c/span\u003e, and wisdom.\u003c/p\u003e\",\"names\":{\"english\":\"strengths\",\"tibetan\":\"སྟོབས།\",\"sanskrit\":\"bala\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"stobs\"}},{\"uuid\":\"f1a638a0-fac3-4272-826c-78a7878aef14\",\"authority\":\"90f35cee-4ac2-45ca-ae7d-8b9054c45d66\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e“Vast Goodness.” The highest of the three paradises that correspond to the third \u003cspan data-glossary-id=\\\"UT22084-089-013-2564\\\"\u003edhyāna\u003c/span\u003e in the form realm.\u003c/p\u003e\",\"names\":{\"english\":\"Śubhakṛtsna\",\"tibetan\":\"དགེ་རྒྱས།\",\"sanskrit\":\"śubhakṛtsna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dge rgyas\"}},{\"uuid\":\"348e5ece-c5b0-40aa-8f93-06125a732a72\",\"authority\":\"cf30a0ea-0f8e-4b72-a382-d444d8c447ab\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e king.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ekhab spu\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Sūciroma\",\"tibetan\":\"ཁབ་ཀྱི་སྤུ།\",\"sanskrit\":\"sūciroma\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"khab kyi spu\"}},{\"uuid\":\"bf5045b0-2845-4c6a-9cef-e937ac0a87ab\",\"authority\":\"230c8d1b-9468-4cf7-a72b-e15a00cd970f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eIn the Sarvāstivāda tradition, this is the second highest of the \u003cspan data-glossary-id=\\\"UT22084-089-013-2938\\\"\u003eŚuddhāvāsa\u003c/span\u003e paradises, the highest paradises in the form realm. In this sūtra it is the fourth highest.\u003c/p\u003e\",\"names\":{\"english\":\"Sudarśana\",\"tibetan\":\"ཤིན་ཏུ་མཐོང་བ།\",\"sanskrit\":\"sudarśana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shin tu mthong ba\"}},{\"uuid\":\"de453836-a26d-4b71-8e67-40cceb227126\",\"authority\":\"e9ae4f71-d873-4b82-bee9-bf559a7b53fe\",\"definition\":\"$4f\",\"names\":{\"english\":\"Śuddhāvāsa\",\"tibetan\":\"གཙང་མའི་གནས།\",\"sanskrit\":\"śuddhāvāsa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gtsang ma’i gnas\"}},{\"uuid\":\"6f508ca8-b999-4554-856e-650eaec70528\",\"authority\":\"caea1d24-dfc6-42f8-80af-af9d16e473f1\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe Buddha \u003cspan data-glossary-id=\\\"UT22084-089-013-2797\\\"\u003eŚākyamuni\u003c/span\u003e’s father.\u003c/p\u003e\",\"names\":{\"english\":\"Śuddhodana\",\"tibetan\":\"ཟས་གཙང་མ།\",\"sanskrit\":\"śuddhodana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"zas gtsang ma\"}},{\"uuid\":\"68413d98-a056-4ae8-bf53-224ad36d306b\",\"authority\":\"4dd410d2-56a2-4ec8-92ca-207acf7a05db\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe fourth and lowest of the classes in the caste system of India. It generally covers the laboring class.\u003c/p\u003e\",\"names\":{\"english\":\"śūdra\",\"tibetan\":\"དམངས་རིགས།\",\"sanskrit\":\"śūdra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dmangs rigs\"}},{\"uuid\":\"01673bc8-ccbe-403e-a4b2-b55e5aef7f9a\",\"authority\":\"d995af90-8e59-4f3d-9e08-31c4b4b21761\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e“Perfect Light.” In the Sarvāstivāda tradition, this is the third highest of the five \u003cspan data-glossary-id=\\\"UT22084-089-013-2938\\\"\u003eŚuddhāvāsa\u003c/span\u003e paradises, the highest paradises in the form realm. In this sūtra it is the lowest of those five.\u003c/p\u003e\",\"names\":{\"english\":\"Sudṛśa\",\"tibetan\":\"གྱ་ནོམ་སྣང་བ།\",\"sanskrit\":\"sudṛśa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gya nom snang ba\"}},{\"uuid\":\"050f5da2-dcf4-4ad2-bc60-89c89c98922d\",\"authority\":\"e0c895bf-68db-4a04-be1e-98983ced51ee\",\"definition\":\"$50\",\"names\":{\"english\":\"sugata\",\"tibetan\":\"བདེ་བར་གཤེགས་པ།\",\"sanskrit\":\"sugata\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bde bar gshegs pa\"}},{\"uuid\":\"f2049d91-f20d-4a00-a733-972944b9d52f\",\"authority\":\"581954b0-e013-4dc5-b846-8dfba3485636\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA bodhisattva.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eSaṃtiṣṭha\u003c/em\u003e; \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003erab gnas\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Sukhavihāra\",\"tibetan\":\"བདེ་བར་གནས་པ།\",\"sanskrit\":\"sukhavihāra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bde bar gnas pa\"}},{\"uuid\":\"86d5ef47-0af7-4d6d-8c11-c3dccbfa1da0\",\"authority\":\"1419555a-15dc-4f80-8a53-7bbc43689a15\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA bodhisattva.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003eToh 556: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003edge ba’i blo gros\u003c/em\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Sumati\",\"tibetan\":\"ལེགས་པའི་བློ་གྲོས།\",\"sanskrit\":\"sumati\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"legs pa’i blo gros\"}},{\"uuid\":\"d8f48c95-f1b6-425c-b5d0-bd902e9411e3\",\"authority\":\"fa0673ad-9be7-4a27-a808-a900dcb060f5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA bodhisattva. \u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003eshin tu bde bar gnas pa\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Supratiṣṭha\",\"tibetan\":\"རབ་ཏུ་གནས་པ།\",\"sanskrit\":\"supratiṣṭha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rab tu gnas pa\"}},{\"uuid\":\"8dea9c46-4905-4030-b702-1ab457e61509\",\"authority\":\"39a8d74b-9640-425e-b9d6-54faac1a996a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2496\\\"\u003eLicchavī\u003c/span\u003e youth.\u003c/p\u003e\",\"names\":{\"english\":\"Supreme Auspicious Essence\",\"tibetan\":\"བཀྲ་ཤིས་མཆོག་གི་སྙིང་པོ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bkra shis mchog gi snying po\"}},{\"uuid\":\"dc16ab92-7a7c-4e90-8abc-f8ce14a8b5d3\",\"authority\":\"d640a587-777b-4248-b9d8-311fb2ce993c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA buddha.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555 Degé: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003espobs brtsegs\u003c/em\u003e; Yongle, Peking, and Narthang: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003espos brtsegs\u003c/em\u003e; Lithang and Choné: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003estobs brtse\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Supreme Incense Heap\",\"tibetan\":\"སྤོས་མཆོག་བརྩེགས།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"spos mchog brtsegs\"}},{\"uuid\":\"0877cae5-5ea3-4a25-8aa3-9f47522b3b1b\",\"authority\":\"72da0a1a-fcb2-41f2-82ef-2d52a3aff791\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA buddha.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003emchog tu rnam par rgyal ba’i rgyal po\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Supreme King\",\"tibetan\":\"རབ་མཆོག་རྒྱལ་པོ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rab mchog rgyal po\"}},{\"uuid\":\"0a170ec8-9eb8-4594-8345-b7f9936fdc9a\",\"authority\":\"c235df1b-6983-4d7e-9115-45cb22940f0f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA king in the distant past.\u003c/p\u003e\