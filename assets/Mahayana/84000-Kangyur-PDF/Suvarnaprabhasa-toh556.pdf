3-2790\\\"\u003eRuciraketu\u003c/span\u003e, in the time of \u003cspan data-glossary-id=\\\"UT22084-089-013-2797\\\"\u003eŚākyamuni\u003c/span\u003e.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-089-013-2838\\\"\u003eSuvarṇa­ratnākaracchatra­kūṭa\u003c/span\u003e\u003c/em\u003e; \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003egser dang rin po che’i ri bo’i rgyal po\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Suvarṇa­jambu­dhvaja­kāñcanābha\",\"tibetan\":\"གསེར་འཛམ་བུའི་གསེར་གྱི་རྒྱལ་མཚན་གྱི་འོད།\",\"sanskrit\":\"suvarṇa­jambu­dhvaja­kāñcanābha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gser ’dzam bu’i gser gyi rgyal mtshan gyi ’od\"}},{\"uuid\":\"d9d688dd-9c9f-4b69-8166-367dbcaf0390\",\"authority\":\"fe336134-43d8-4910-82ab-52bd9019682a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA world realm in the distant future.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003egser ’od\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Suvarṇaprabhā\",\"tibetan\":\"གསེར་དུ་སྣང་བ།\",\"sanskrit\":\"suvarṇaprabhā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gser du snang ba\"}},{\"uuid\":\"fb2c1956-a770-4cde-bbf9-4bd70acff182\",\"authority\":\"eb38c882-c4c2-44fc-b6fc-9c66824d2680\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2587\\\"\u003etathāgata\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Suvarṇa­prabhā­garbha\",\"tibetan\":\"གསེར་དུ་སྣང་བའི་སྙིང་པོ།\",\"sanskrit\":\"suvarṇa­prabhā­garbha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gser du snang ba’i snying po\"}},{\"uuid\":\"17603ac3-863b-4d62-9530-a81ecf966e19\",\"authority\":\"5cbdf83b-c128-490b-a122-ddadac50e524\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA bodhisattva with the same name as the title of the sūtra.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003egser gyi ’od\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Suvarṇa­prabhāsottama\",\"tibetan\":\"གསེར་འོད་དམ་པ།\",\"sanskrit\":\"suvarṇa­prabhāsottama\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gser ’od dam pa\"}},{\"uuid\":\"f7f116d5-a109-4e86-94e5-ac4c3be955cf\",\"authority\":\"242265cb-5897-4e08-ac24-807b80ba2e9a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2587\\\"\u003etathāgata\u003c/span\u003e. \u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eSuvarṇa­puṣpa­raśmi­dhvaja\u003c/em\u003e; \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003egser gyi me tog ’od zer rgyal mtshan\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Suvarṇa­puṣpa­jvala­raśmi­ketu\",\"tibetan\":\"གསེར་གྱི་མེ་ཏོག་འབར་བའི་འོད་ཟེར་གྱི་ཏོག\",\"sanskrit\":\"suvarṇa­puṣpa­jvala­raśmi­ketu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gser gyi me tog ’bar ba’i ’od zer gyi tog\"}},{\"uuid\":\"65b2f20f-7c74-4ee1-bc62-41574f376841\",\"authority\":\"b03e2f61-d47c-449a-9e51-31d8fd751428\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA buddha in the distant future who is the bodhisattva \u003cspan data-glossary-id=\\\"UT22084-089-013-2790\\\"\u003eRuciraketu\u003c/span\u003e in the time of \u003cspan data-glossary-id=\\\"UT22084-089-013-2797\\\"\u003eŚākyamuni\u003c/span\u003e. \u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003egser gdugs rin po che brtsegs pa\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Suvarṇa­ratnākaracchatra­kūṭa\",\"tibetan\":\"གསེར་དང་རིན་པོ་ཆེའི་འབྱུང་གནས་གདུགས་བརྩེགས།, གསེར་རི་རིན་ཆེན་འབྱུང་གནས་གདུགས་བརྩེགས།\",\"sanskrit\":\"suvarṇa­ratnākaracchatra­kūṭa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gser dang rin po che’i ’byung gnas gdugs brtsegs, gser ri rin chen ’byung gnas gdugs brtsegs\"}},{\"uuid\":\"0108e28b-5bcb-4ce4-826d-644d60fed1fc\",\"authority\":\"1aa2c53e-9c87-4098-9cfa-0f54f6ad6c20\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e king.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003esu bar na dang ke śa\u003c/em\u003e (incorrectly dividing the name into two names))\u003c/p\u003e\",\"names\":{\"english\":\"Svarṇakeśin\",\"tibetan\":\"གསེར་འདྲའི་སྐྲ།\",\"sanskrit\":\"svarṇakeśin\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gser ’dra’i skra\"}},{\"uuid\":\"36e894c5-d3e2-47b6-b319-d843a8cf6a87\",\"authority\":\"fda4f0f9-3506-4a8d-8214-2ac69cfcfac4\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cem class=\\\"foreign\\\"\u003eAcorus calamus\u003c/em\u003e. A plant of marshes and wetlands, native to India. There are a number of variant Sanskrit names for this plant. Its leaves, stem, and roots are used in Āyurvedic medicine.\u003c/p\u003e\",\"names\":{\"english\":\"sweet flag\",\"tibetan\":\"ཤུ་དག\",\"sanskrit\":\"vacā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shu dag\"}},{\"uuid\":\"e73562d6-15c5-4706-82c3-8f843ccfec58\",\"authority\":\"285a8525-75c9-4ab3-8d61-e257c5eb21ce\",\"definition\":\"$51\",\"names\":{\"english\":\"tathāgata\",\"tibetan\":\"དེ་བཞིན་གཤེགས་པ།\",\"sanskrit\":\"tathāgata\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"de bzhin gshegs pa\"}},{\"uuid\":\"e1835138-8dd9-4be2-b440-10fe21a3124c\",\"authority\":\"50455ffe-57ed-4802-83d7-95c67b3ab35e\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe ten \u003cspan data-glossary-id=\\\"UT22084-089-013-2530\\\"\u003estrengths\u003c/span\u003e are (1) the knowledge of what is possible; (2) the knowledge of the ripening of karma; (3) the knowledge of the variety of aspirations; (4) the knowledge of the variety of natures; (5) the knowledge of the different levels of capabilities; (6) the knowledge of the destinations of all paths of rebirth; (7) the knowledge of various states of meditation; (8) the knowledge of remembering previous lives; (9) the knowledge of deaths and rebirths; and (10) the knowledge of the cessation of \u003cspan data-glossary-id=\\\"UT22084-089-013-2470\\\"\u003edefilements\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"ten strengths\",\"tibetan\":\"སྟོབས་བཅུ།\",\"sanskrit\":\"daśabala\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"stobs bcu\"}},{\"uuid\":\"7834a906-6b84-466f-bd06-44338770f988\",\"authority\":\"405213ab-c716-4099-9542-7300262f93fd\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe third highest of the four formless realms. See also “\u003cspan\u003e\u003cspan data-glossary-id=\\\"UT22084-089-013-3269\\\"\u003estate\u003c/span\u003e\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"the state of infinite consciousness\",\"tibetan\":\"རྣམ་ཤེས་མཐའ་ཡས་སྐྱེ་མཆེད།\",\"sanskrit\":\"vijñānānantyāyatana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rnam shes mtha’ yas skye mched\"}},{\"uuid\":\"8af2c1e1-946c-4ad3-8e62-2af9c556a10d\",\"authority\":\"82b4d156-c044-4a5f-99fb-ee664c32e5bc\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA fierce goddess.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555 and Toh 557: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003esems can kun gyi mdangs ’phrog ma\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Thief of All Beings’ Splendor\",\"tibetan\":\"སེམས་ཅན་ཀུན་གྱི་གཟི་འཕྲོག་མ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sems can kun gyi gzi ’phrog ma\"}},{\"uuid\":\"63cafe4c-eba9-4989-a3c0-11ac3d24ef23\",\"authority\":\"7eb71c16-59ac-4550-ae75-37713adc626e\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThese are the thirty-two major physical of marks of a great being, namely a buddha or a universal monarch. These are complemented by \u003cspan data-glossary-id=\\\"UT22084-089-013-2566\\\"\u003eeighty features\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"thirty-two signs\",\"tibetan\":\"མཚན་སུམ་ཅུ་རྩ་གཉིས།\",\"sanskrit\":\"dvātriṃśalakṣaṇa, dvātriṃśallakṣaṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mtshan sum cu rtsa gnyis\"}},{\"uuid\":\"7015a5ba-934e-44c1-9e77-244de7b7c93a\",\"authority\":\"5dc9f755-ef14-4a9c-828c-1aac52cda6cb\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe three kāyas, or bodies, are the \u003cspan data-glossary-id=\\\"UT22084-089-013-2475\\\"\u003eDharma body\u003c/span\u003e, \u003cspan data-glossary-id=\\\"UT22084-089-013-2520\\\"\u003eenjoyment body\u003c/span\u003e, and \u003cspan data-glossary-id=\\\"UT22084-089-013-2504\\\"\u003eemanation body\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"three bodies\",\"tibetan\":\"སྐུ་གསུམ།\",\"sanskrit\":\"trikāya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sku gsum\"}},{\"uuid\":\"278e0920-e973-43fd-9ff8-bee92154851b\",\"authority\":\"3779c030-a446-45b1-b1c3-73f81aeb454d\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eKnowledge through divine sight (\u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003elha’i mig gi shes pa\u003c/em\u003e), knowledge through remembering past lives (\u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003esngon gyi gnas rjes su dran pa’i rig pa\u003c/em\u003e), and the knowledge that \u003cspan data-glossary-id=\\\"UT22084-089-013-2470\\\"\u003edefilements\u003c/span\u003e have ceased (\u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ezag pa zad pa’i rig pa\u003c/em\u003e). \u003c/p\u003e\",\"names\":{\"english\":\"three knowledges\",\"tibetan\":\"རིག་པ་གསུམ།\",\"sanskrit\":\"traividya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rig pa gsum\"}},{\"uuid\":\"5ce97104-9d23-45ca-84a6-2dbb47a60a00\",\"authority\":\"f4218164-dae3-4f5a-a518-caa4cc07aeac\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe three realms of desire, form, and formlessness.\u003c/p\u003e\",\"names\":{\"english\":\"three worlds\",\"tibetan\":\"འཇིག་རྟེན་གསུམ།\",\"sanskrit\":\"trailokya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’jig rten gsum\"}},{\"uuid\":\"37aad8a1-ee19-486a-b8cf-4a279d99ca14\",\"authority\":\"aba3316b-7904-408f-89e9-19041e8fe614\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2587\\\"\u003etathāgata\u003c/span\u003e.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eVimala­raśmi­ratna­ketu\u003c/em\u003e; \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003edri ma med pa’i ’od zer rin po che’i tog\u003c/em\u003e. Toh 557: \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eVimala­jvālā­ratna­suvarṇa­raśmi­prabhā­śikhin\u003c/em\u003e; \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003edri ma med par ’bar ba rin chen gser gyi ’od zer snang ba’i rtog\u003c/em\u003e. Sanskrit ms.: \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-089-013-2786\\\"\u003eRatnaśikhin\u003c/span\u003e\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Tip of Brilliant, Precious, Pure Fire\",\"tibetan\":\"དྲི་མ་མེད་པར་འབར་བ་རིན་ཆེན་འོད་ཟེར་སྣང་བའི་ཏོག\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dri ma med par ’bar ba rin chen ’od zer snang ba’i tog\"}},{\"uuid\":\"4b2c2119-6dd4-4607-afda-9c0ea3cd6860\",\"authority\":\"e5604cfb-e911-4e7f-9708-377807a2a901\",\"definition\":\"$52\",\"names\":{\"english\":\"tīrthika\",\"tibetan\":\"མུ་སྟེགས་ཅན།\",\"sanskrit\":\"tīrthika\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mu stegs can\"}},{\"uuid\":\"fb356f46-3c64-4256-8c64-7d0c8d24f7ba\",\"authority\":\"301df2be-922b-4250-8aa4-55bc54d32961\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe paradise of \u003cspan data-glossary-id=\\\"UT22084-089-013-2796\\\"\u003eŚakra\u003c/span\u003e, also known as \u003cspan data-glossary-id=\\\"UT22084-089-013-2656\\\"\u003eIndra\u003c/span\u003e, on the summit of \u003cspan data-glossary-id=\\\"UT22084-089-013-2940\\\"\u003eSumeru\u003c/span\u003e. The name means “Thirty-Three,” from the thirty-three principal deities that dwell there. The fifth highest of the six paradises in the desire realm.\u003c/p\u003e\",\"names\":{\"english\":\"Trāyastriṃśa\",\"tibetan\":\"སུམ་ཅུ་རྩ་གསུམ་པ།\",\"sanskrit\":\"trāyastriṃśa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sum cu rtsa gsum pa\"}},{\"uuid\":\"15fc18c2-88b8-4b6b-80b5-7b16a0dc9174\",\"authority\":\"37ee8261-363c-4e10-b7f6-97e58067bd03\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe largest universe described in Buddhist cosmology. This term, in Abhidharma cosmology, refers to 1,000\u003csup\u003e³\u003c/sup\u003e world systems, i.e., 1,000 “dichiliocosms” or “two thousand great thousand world realms” (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003edvi­sāhasra­mahā­sāhasra­lokadhātu\u003c/em\u003e), which are in turn made up of 1,000 first-order world systems, each with its own Mount Sumeru, continents, sun and moon, etc.\u003c/p\u003e\",\"names\":{\"english\":\"trichiliocosm\",\"tibetan\":\"སྟོང་གསུམ་གྱི་སྟོང་ཆེན་པོའི་རྗིག་རྟེན་གྱི་ཁམས།, སྟོང་གསུམ།\",\"sanskrit\":\"tri­sāhasra­mahā­sāhasra­loka­dhātu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"stong gsum, stong gsum gyi stong chen po’i rjig rten gyi khams\"}},{\"uuid\":\"4203fb7e-7856-4620-9067-849b57cb0e05\",\"authority\":\"8e7aaded-e408-43f5-8611-967afc01f211\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eKing of Tibet who reigned ca. 742/55–798/804 \u003cspan class=\\\"small-caps\\\"\u003eᴄᴇ\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Trisong Detsen\",\"tibetan\":\"འཁྲི་སྲོང་ལྡེ་བཙན།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’khri srong lde btsan\"}},{\"uuid\":\"65ca5a2a-58f4-48a7-875d-4c857644ce4b\",\"authority\":\"edf1481c-c58e-455d-91ac-4483ead30568\",\"definition\":\"$53\",\"names\":{\"english\":\"Tuṣita\",\"tibetan\":\"དགའ་ལྡན།\",\"sanskrit\":\"tuṣita\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dga’ ldan\"}},{\"uuid\":\"75361058-6742-4076-af23-8648a2692c65\",\"authority\":\"c1318e07-fe5d-42ac-afa7-5bc15bf16c09\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe classification of all aspects of the Buddha’s teachings into twelve types: \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003esūtra\u003c/em\u003e, \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003egeya\u003c/em\u003e, \u003cspan class=\\\"ignore\\\"\u003e\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003evyākaraṇa\u003c/em\u003e\u003c/span\u003e, \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003egāthā\u003c/em\u003e, \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eudāna\u003c/em\u003e, \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003enidāna\u003c/em\u003e, \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eavadāna\u003c/em\u003e, \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eitivṛttaka\u003c/em\u003e, \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003ejātaka\u003c/em\u003e, \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003evaipulya\u003c/em\u003e, \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eadbhutadharma\u003c/em\u003e, and \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eupadeśa\u003c/em\u003e. \u003c/p\u003e\",\"names\":{\"english\":\"twelve forms of the teaching\",\"tibetan\":\"གསུང་རབ་ཡན་ལག་བཅུ་གཉིས།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gsung rab yan lag bcu gnyis\"}},{\"uuid\":\"58885000-c069-48fe-8aa1-4a45303f548a\",\"authority\":\"3a9979bb-584f-4146-91cb-58bdc9f34c9a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe principle of dependent origination asserts that nothing exists independently of other factors, the reason for this being that things and events come into existence only by dependence on the aggregation of multiple causes and conditions. In general, the processes of cyclic existence, through which the external world and the sentient beings within it revolve in a continuous cycle of suffering, propelled by the propensities of past actions and their interaction with afflicted mental states, originate dependent on the sequential unfolding of twelve links: (1) fundamental ignorance, (2) formative predispositions, (3) consciousness, (4) name and form, (5) sense field, (6) sensory contact, (7) sensation, (8) craving, (9) grasping, (10) rebirth process, (11) actual birth, (12) aging and death. It is through deliberate reversal of these twelve links that one can succeed in bringing the whole cycle to an end.\u003c/p\u003e\",\"names\":{\"english\":\"twelve phases of dependent origination\",\"tibetan\":\"རྟེན་ཅིང་འབྲེལ་བར་འབྱུང་བ་ཡན་ལག་བཅུ་གཉིས།\",\"sanskrit\":\"dvādaśāṅga­pratītya­samutpāda\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rten cing ’brel bar ’byung ba yan lag bcu gnyis\"}},{\"uuid\":\"74dca416-c548-475c-b1ec-23b1692ad82a\",\"authority\":\"d8bf518c-9bd9-4147-a908-fbe36093129b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe direct perception of the nature of the mind and its objects. An alternative translation is “the absolute.” One of the three natures that are a central philosophy of the Yogācāra tradition.\u003c/p\u003e\",\"names\":{\"english\":\"ultimately real\",\"tibetan\":\"ཡོངས་སུ་གྲུབ་པ།\",\"sanskrit\":\"pariniṣpanna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yongs su grub pa\"}},{\"uuid\":\"4bcdfbef-2fa4-4c4a-943e-2b78601af192\",\"authority\":\"c93fc6ee-15a9-4728-a994-72d38fbd0098\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA goddess. \u003c/p\u003e\",\"names\":{\"english\":\"Umādevī\",\"tibetan\":\"ལྷ་མོ་ཨུ་མ།\",\"sanskrit\":\"umādevī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lha mo u ma\"}},{\"uuid\":\"7a0c5ff1-a4b7-4c1d-a4b8-be615a683340\",\"authority\":\"e55e002e-4681-4aae-beb0-3db051b3b050\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA bodhisattva.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003eYongle and Peking: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003eseng ge’i tog ’od zer snang ba thogs pa med pa\u003c/em\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Unobstructed Appearance of the Light of a Lion’s Ornament\",\"tibetan\":\"སེང་གེའི་ཏོག་གི་འོད་ཟེར་སྣང་བ་ཐོགས་པ་མེད་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"seng ge’i tog gi ’od zer snang ba thogs pa med pa\"}},{\"uuid\":\"03ad7ca4-c671-415b-87a1-864d8faa7a9c\",\"authority\":\"fbe25ea0-52da-4f4d-b7bd-c56927616bdc\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eIn India, a person’s particular preceptor within the monastic tradition, guiding that person for the taking of full vows and the maintenance of conduct and practice. The Tibetan translation \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003emkhan po\u003c/em\u003e has also come to mean “a learned scholar,” the equivalent of a \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003epaṇḍita\u003c/em\u003e, but that is not the intended meaning in the sūtras. \u003c/p\u003e\",\"names\":{\"english\":\"upādhyāya\",\"tibetan\":\"མཁན་པོ།\",\"sanskrit\":\"upādhyāya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mkhan po\"}},{\"uuid\":\"7bfd1347-20b7-4f5f-8bde-38f29e3b7402\",\"authority\":\"54a4b76b-5323-4377-965e-e27e5a74049c\",\"definition\":\"\u003cp\u003eOne of eight mythological nāga kings. The story of the two nāga kings Upananda and Nanda and their taming by the Buddha and Maudgalyāyana is told in the \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eVinayavibhaṅga\u003c/cite\u003e (Toh 3, Degé vol. 6, \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003e’dul ba\u003c/em\u003e, \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003eja\u003c/em\u003e, F.221.a–224.a).\u003c/p\u003e\",\"names\":{\"english\":\"Upananda\",\"tibetan\":\"ཉེ་དགའ་བོ།\",\"sanskrit\":\"upananda\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nye dga’ bo\"}},{\"uuid\":\"2bdf3bc7-527a-47ec-b8b5-58b49e2d27d2\",\"authority\":\"b2dbaf0a-b5c9-4ecb-82b6-bfe9a9232283\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA man who has taken the layperson’s vows.\u003c/p\u003e\",\"names\":{\"english\":\"upāsaka\",\"tibetan\":\"དགེ་བསྙེན།\",\"sanskrit\":\"upāsaka\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dge bsnyen\"}},{\"uuid\":\"4c34c0f5-37c5-4d26-8dd8-41e42b1dbeaa\",\"authority\":\"1bc2f10d-50aa-4a44-b04f-0836bccf0774\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA woman who has taken the layperson’s vows.\u003c/p\u003e\",\"names\":{\"english\":\"upāsikā\",\"tibetan\":\"དགེ་བསྙེན་མ།\",\"sanskrit\":\"upāsikā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dge bsnyen ma\"}},{\"uuid\":\"8d0903a2-f477-4f84-8692-b3cb32af25e1\",\"authority\":\"01953d51-51b2-4178-98d5-407fd18e297b\",\"definition\":\"\u003cp\u003eOne of the thirty-two marks of a great being. It consists of a soft, long, fine, coiled white hair between the eyebrows capable of emitting an intense bright light. Literally, the Sanskrit ūrṇā means “wool hair,” and kośa means “treasure.”\u003c/p\u003e\",\"names\":{\"english\":\"ūrṇā\",\"tibetan\":\"མཛོད་སྤུ།\",\"sanskrit\":\"ūrṇā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mdzod spu\"}},{\"uuid\":\"e21d2a6c-d330-45b8-b200-1358ce48bd11\",\"authority\":\"2ba8c0d9-359d-4629-b248-7a4abd0bfed3\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe brother of \u003cspan data-glossary-id=\\\"UT22084-089-013-2651\\\"\u003eGayākāśyapa\u003c/span\u003e and \u003cspan data-glossary-id=\\\"UT22084-089-013-2745\\\"\u003eNadīkāśyapa\u003c/span\u003e. A practitioner of fire offering at Uruvilva (Bodhgayā), he and his five hundred pupils were converted to becoming \u003cspan data-glossary-id=\\\"UT22084-089-013-2450\\\"\u003ebhikṣus\u003c/span\u003e of the Buddha. He and his brothers and their students were the third group to become followers of the Buddha after his enlightenment.\u003c/p\u003e\",\"names\":{\"english\":\"Uruvilva­kāśyapa\",\"tibetan\":\"ལྟང་རྒྱས་འོད་སྲུང་།\",\"sanskrit\":\"uruvilva­kāśyapa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ltang rgyas ’od srung\"}},{\"uuid\":\"169da212-d4f0-4402-9743-ef8193e94f46\",\"authority\":\"9599137b-1e80-4385-ac43-100d23580417\",\"definition\":\"\",\"names\":{\"english\":\"Vairocana\",\"tibetan\":\"རྣམ་པར་སྣང་མཛད།\",\"sanskrit\":\"vairocana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rnam par snang mdzad\"}},{\"uuid\":\"b34c94aa-14b1-4eaf-adf1-2c486d729f7d\",\"authority\":\"71154af3-b2a1-4fc9-80c1-6c01cabfe3f2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAs one of the \u003cspan data-glossary-id=\\\"UT22084-089-013-2867\\\"\u003eFour Mahārājas\u003c/span\u003e he is the lord of the northern region of the world and the northern continent, though in early Buddhism he is the lord of the far north of India and beyond. Also known as Kubera, he is the lord of the \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣas\u003c/span\u003e and a lord of wealth.\u003c/p\u003e\",\"names\":{\"english\":\"Vaiśravaṇa\",\"tibetan\":\"རྣམ་ཐོས་ཀྱི་བུ།\",\"sanskrit\":\"vaiśravaṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rnam thos kyi bu\"}},{\"uuid\":\"53fbb1f3-7ac3-4b87-b11b-b36093229f9b\",\"authority\":\"358c79f0-559b-4b5d-ba29-9af77ab47480\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe third of the four classes in the Indian caste system. It generally includes merchants and farmers.\u003c/p\u003e\",\"names\":{\"english\":\"vaiśya\",\"tibetan\":\"རྗེའུ་རིགས།\",\"sanskrit\":\"vaiśya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rje’u rigs\"}},{\"uuid\":\"d173b57a-c45c-4a6b-8354-3934f81db9d6\",\"authority\":\"d30cebec-fa43-4b42-88f7-86060b224788\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2496\\\"\u003eLicchavī\u003c/span\u003e youth.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003erdo rje skyabs\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Vajra Guard\",\"tibetan\":\"རྡོ་རྗེ་སྐྱོང་།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rdo rje skyong\"}},{\"uuid\":\"1585b1ef-2bd9-48cf-a525-2d94ef5009c5\",\"authority\":\"5f22c75d-2581-4fb0-9dfc-a7db2570eb2f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the names of Kubera, the god of wealth, meaning “Lightning Lord of the Guhyakas,” or “treasure guardian.” In the tantra tradition, Guhyapati, “Lord of Secrets,” became a title of \u003cspan data-glossary-id=\\\"UT22084-089-013-2850\\\"\u003eVajrapāṇi\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Vajra­guhyakādhipati\",\"tibetan\":\"རྡོ་རྗེ་གསང་བདག\",\"sanskrit\":\"vajra­guhyakādhipati\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rdo rje gsang bdag\"}},{\"uuid\":\"aa8dbe14-0268-4087-bb0e-b23d4f172ad7\",\"authority\":\"3d58ef2a-3ca7-41be-bc51-6e392c9774e7\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eVajrapāṇi means “Wielder of the Vajra.” In the Pali canon, he appears as a yakṣa guardian in the retinue of the Buddha. In the Mahāyāna scriptures he is a bodhisattva and one of the “eight close sons of the Buddha.” In the tantras, he is also regarded as an important Buddhist deity and instrumental in the transmission of tantric scriptures. \u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003erdo rje’i thal mo\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Vajrapāṇi\",\"tibetan\":\"ལག་ན་རྡོ་རྗེ།\",\"sanskrit\":\"vajrapāṇi\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lag na rdo rje\"}},{\"uuid\":\"9dfe53ed-6bc5-40bf-a98b-426653bc2a2f\",\"authority\":\"d816b7c7-82e5-448b-a70e-94fe50daaa57\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA mountain.\u003c/p\u003e\",\"names\":{\"english\":\"Vajraprākāra\",\"tibetan\":\"རྡོ་རྗེའི་འབྱུང་གནས།\",\"sanskrit\":\"vajraprākāra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rdo rje’i ’byung gnas\"}},{\"uuid\":\"01d79f9d-969f-40f5-9ed9-aace04146db4\",\"authority\":\"f7b7e2e2-10c3-46d0-b97f-ebecf7038326\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cem class=\\\"foreign\\\"\u003eValeriana wallichii\u003c/em\u003e. Specifically, Indian valerian, also known as \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003etagara\u003c/em\u003e and \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003etagar\u003c/em\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"valerian\",\"tibetan\":\"རྒྱ་སྤོས།\",\"sanskrit\":\"tagara\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rgya spos\"}},{\"uuid\":\"d0d8412d-d993-4a5d-9a68-ec95c31fb0a5\",\"authority\":\"c61b3a69-0b02-40ef-8b81-1631453a5a46\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e king.\u003c/p\u003e\",\"names\":{\"english\":\"Vāli\",\"tibetan\":\"འཁྲི་བྱེད།\",\"sanskrit\":\"vāli|\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’khri byed\"}},{\"uuid\":\"46a03f56-b8a6-4364-815a-c46fe1c8c186\",\"authority\":\"390e65f1-a98f-420b-8901-662df73b65e2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA buddha.\u003c/p\u003e\",\"names\":{\"english\":\"Varāṅga\",\"tibetan\":\"ཡན་ལག་མཆོག\",\"sanskrit\":\"varāṅga\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yan lag mchog\"}},{\"uuid\":\"32b540ca-3edf-4b2f-991d-e6fcfc940b08\",\"authority\":\"c6783950-727c-4115-a39c-a87124cfb102\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA buddha.\u003c/p\u003e\",\"names\":{\"english\":\"Varaprabha\",\"tibetan\":\"འོད་མཆོག\",\"sanskrit\":\"varaprabha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’od mchog\"}},{\"uuid\":\"62f42c0e-d91a-46e3-b023-18e6aa4e1559\",\"authority\":\"a76831d3-db97-485a-b186-cfe3f8fae520\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e king. The name means “Lord of Rain.”\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003echar pa’i dbang po\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Varṣādhipati\",\"tibetan\":\"ཆར་པའི་བདག་པོ།\",\"sanskrit\":\"varṣādhipati\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"char pa’i bdag po\"}},{\"uuid\":\"a26cc09a-abe6-47e9-944d-9590174c2948\",\"authority\":\"c96efb74-72d8-4e94-aad8-6baa34328659\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe name of the deity of water. In the Vedas, Varuṇa is an important deity and in particular the deity of the sky, but in later Indian tradition he is the god of only the water and the underworld. The Tibetan does not attempt to translate his name but instead has “god of water.” \u003c/p\u003e\",\"names\":{\"english\":\"Varuṇa\",\"tibetan\":\"ཆུ་ལྷ།\",\"sanskrit\":\"varuṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chu lha\"}},{\"uuid\":\"dd792a30-125e-4ad5-9418-22092de2cd82\",\"authority\":\"8aa4023c-19a7-49e4-8d15-8b66958fc3c2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eHe was one of the five companions of \u003cspan data-glossary-id=\\\"UT22084-089-013-2797\\\"\u003eŚākyamuni\u003c/span\u003e in asceticism and later one of his first five pupils, attaining the state of a \u003cspan data-glossary-id=\\\"UT22084-089-013-2529\\\"\u003estream entrant\u003c/span\u003e. \u003c/p\u003e\",\"names\":{\"english\":\"Vāṣpa\",\"tibetan\":\"རླངས་པ།\",\"sanskrit\":\"Bāṣpa, Vāṣpa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rlangs pa\"}},{\"uuid\":\"bbcb4b9b-c780-4212-8ca1-b692c23b70e7\",\"authority\":\"ee02bcfa-a1f7-4424-8cf1-8d822a51b76f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe name of a goddess, identified as the sister of \u003cspan data-glossary-id=\\\"UT22084-089-013-2687\\\"\u003eMahādeva\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Vasu\",\"tibetan\":\"བ་སུ།\",\"sanskrit\":\"vasu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ba su\"}},{\"uuid\":\"67bf2141-0183-41e2-9b1b-d99b7afa1f04\",\"authority\":\"f0d5f328-1354-42c1-91d9-8e69b3e2355c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2503\\\"\u003enāga\u003c/span\u003e king, well known in Indian mythology as being the serpent coiled around \u003cspan data-glossary-id=\\\"UT22084-089-013-2940\\\"\u003eMeru\u003c/span\u003e that was used to churn the ocean at the origin of the world. \u003c/p\u003e\",\"names\":{\"english\":\"Vāsuki\",\"tibetan\":\"ནོར་རྒྱས།\",\"sanskrit\":\"vāsuki\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nor rgyas\"}},{\"uuid\":\"3e4d8365-1139-4dd3-bcb0-5e315926fc79\",\"authority\":\"ef8a07af-5b63-4288-b9b7-c1abdbcd1c26\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe god of the air and the winds.\u003c/p\u003e\",\"names\":{\"english\":\"Vāyu\",\"tibetan\":\"རླུང་།\",\"sanskrit\":\"vāyu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rlung\"}},{\"uuid\":\"8877bcd2-0685-49fb-bc77-d4fbb309e71a\",\"authority\":\"cec3b332-10ad-4c95-a840-96aee0271047\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe king of the \u003cspan data-glossary-id=\\\"UT22084-089-013-2559\\\"\u003easuras\u003c/span\u003e. Also translated as \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ebzang ris\u003c/em\u003e.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003eDegé Toh 556, Peking, Narthang and Lhasa: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ethag bzangs\u003c/em\u003e. Degé Toh 557: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ethag bzangs\u003c/em\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Vemacitra\",\"tibetan\":\"ཐགས་ཟངས།\",\"sanskrit\":\"vemacitra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"thags zangs\"}},{\"uuid\":\"36789778-dfff-49f5-919b-5ef4da528975\",\"authority\":\"c93c2e27-5650-435e-b7b4-4a0ba26dad8f\",\"definition\":\"\u003cp\u003eA respectful form of address between monks, and also between lay companions of equal standing. It literally means “one who has a [long] life.”\u003c/p\u003e\",\"names\":{\"english\":\"Venerable\",\"tibetan\":\"ཚེ་དང་ལྡན་པ།\",\"sanskrit\":\"āyuṣmat\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"tshe dang ldan pa\"}},{\"uuid\":\"1b1e99da-21ed-4210-ac9c-8e048a470c51\",\"authority\":\"e03d7648-4ce5-49e6-b28c-8a7e466b248e\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA class of beings that typically haunt charnel grounds and enter into and animate corpses. Hence, the Tibetan translation means “risen corpse.”\u003c/p\u003e\",\"names\":{\"english\":\"vetāla\",\"tibetan\":\"རོ་ལངས།\",\"sanskrit\":\"vetāla\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ro langs\"}},{\"uuid\":\"e3b20cb4-6f07-49d9-a014-0f298e77705c\",\"authority\":\"b872e975-86b8-48b6-a0b3-22ddfcc2a093\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cem class=\\\"foreign\\\"\u003eAndropogon muricatus\u003c/em\u003e, \u003cem class=\\\"foreign\\\"\u003eAndropogon zizanioides\u003c/em\u003e. A type of grass. \u003c/p\u003e\",\"names\":{\"english\":\"vetiver\",\"tibetan\":\"ཨུ་ཤི་ར།\",\"sanskrit\":\"uśīra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"u shi ra\"}},{\"uuid\":\"8301c1cb-1410-43db-baa6-735291ab31c2\",\"authority\":\"315bdb1d-3791-4728-bad3-e6c55b36a6b8\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA buddha.\u003c/p\u003e\",\"names\":{\"english\":\"Vibhūṣita\",\"tibetan\":\"ཤིན་ཏུ་བརྒྱན།\",\"sanskrit\":\"vibhūṣita\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shin tu brgyan\"}},{\"uuid\":\"4b99845d-79aa-49c7-ac0c-9dab285dddf7\",\"authority\":\"fb8a9cd3-6829-4a0a-9538-0a4104dc3b6e\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA type of incantation or spell used to accomplish a ritual goal. This can be associated with either ordinary attainments or those whose goal is awakening.\u003c/p\u003e\",\"names\":{\"english\":\"vidyāmantra\",\"tibetan\":\"རིག་པའི་གསང་སྔགས།, རིག་སྔགས།\",\"sanskrit\":\"vidyāmantra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rig pa’i gsang sngags, rig sngags\"}},{\"uuid\":\"493a67ab-dcbf-4e3e-855a-c49ffde8f018\",\"authority\":\"64fcf88d-fdee-4323-8507-1862861695ce\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-089-013-2503\\\"\u003enāga\u003c/span\u003e king.\u003c/p\u003e\",\"names\":{\"english\":\"Vidyutprabha\",\"tibetan\":\"གློག་འོད།\",\"sanskrit\":\"vidyutprabha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"glog ’od\"}},{\"uuid\":\"75c946eb-d5f8-4076-b501-0a27636b15cd\",\"authority\":\"d2cb7c27-11df-4fed-ab57-b46c95202c9c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe future realm where five hundred thousand \u003cspan data-glossary-id=\\\"UT22084-089-013-2450\\\"\u003ebhikṣus\u003c/span\u003e in the Buddha’s \u003cspan data-glossary-id=\\\"UT22084-089-013-2522\\\"\u003esaṅgha\u003c/span\u003e will become buddhas.\u003c/p\u003e\",\"names\":{\"english\":\"Vimalaprabhā\",\"tibetan\":\"དྲི་མ་མེད་པའི་འོད།\",\"sanskrit\":\"vimalaprabhā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dri ma med pa’i ’od\"}},{\"uuid\":\"e5d8ecb7-0147-46b5-9d97-17b7ed06cd4a\",\"authority\":\"a1d9ee32-dfde-4b91-9bf4-9def86082df9\",\"definition\":\"\",\"names\":{\"english\":\"vinaya\",\"tibetan\":\"འདུལ་བ།\",\"sanskrit\":\"vinaya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’dul ba\"}},{\"uuid\":\"e8ba371d-c0e9-433d-b790-44db8459ce2e\",\"authority\":\"3dfa66d7-2863-4467-a3e7-32826ac8cbb9\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA series of mountain ranges that extend across central India. The usual translation is \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ebigs byed\u003c/em\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Vindhya\",\"tibetan\":\"བིན་དྷུ།\",\"sanskrit\":\"vindhya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bin dhu\"}},{\"uuid\":\"ebfd449d-b733-4c85-a12f-ae45b26e399c\",\"authority\":\"51d82e9b-8f3b-46f2-a5a4-7730f9cf4dd8\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA world realm in the distant future.\u003c/p\u003e\",\"names\":{\"english\":\"Virajadhvajā\",\"tibetan\":\"རྡུལ་མེད་པའི་རྒྱལ་མཚན།\",\"sanskrit\":\"virajadhvajā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rdul med pa’i rgyal mtshan\"}},{\"uuid\":\"18be2255-0ed5-4db9-9d71-15b7069c04f9\",\"authority\":\"73feacee-c44a-43c7-ba82-3c1909a30010\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA buddha.\u003c/p\u003e\",\"names\":{\"english\":\"Virtue of Light\",\"tibetan\":\"འོད་དགེ\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’od dge\"}},{\"uuid\":\"81ed76f6-e8c3-449e-b1bd-dfd1e3751283\",\"authority\":\"d04a9fb8-e675-4064-b8e2-48e7ff05c4b2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the \u003cspan data-glossary-id=\\\"UT22084-089-013-2867\\\"\u003eFour Mahārājas\u003c/span\u003e, he is the guardian of the southern direction and the lord of the \u003cspan data-glossary-id=\\\"UT22084-089-013-2573\\\"\u003ekumbhāṇḍas\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Virūḍhaka\",\"tibetan\":\"འཕགས་སྐྱེས་པོ།\",\"sanskrit\":\"virūḍhaka\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’phags skyes po\"}},{\"uuid\":\"cc4bedf3-722d-478c-a51b-f63ec54cb6f5\",\"authority\":\"54956c66-6985-4088-acf8-7752d0265810\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the \u003cspan data-glossary-id=\\\"UT22084-089-013-2867\\\"\u003eFour Mahārājas\u003c/span\u003e, he is the guardian of the western direction and the lord of the \u003cspan data-glossary-id=\\\"UT22084-089-013-2503\\\"\u003enāgas\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Virūpākṣa\",\"tibetan\":\"མིག་མི་བཟང་།\",\"sanskrit\":\"virūpākṣa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mig mi bzang\"}},{\"uuid\":\"decffb01-a15a-4366-a8c4-9633d0e0f8a9\",\"authority\":\"97991210-ea19-43c1-af94-cece748cb534\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA buddha.\u003c/p\u003e\",\"names\":{\"english\":\"Viśālaśrī\",\"tibetan\":\"ཡངས་པའི་དཔལ།\",\"sanskrit\":\"viśālaśrī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yangs pa’i dpal\"}},{\"uuid\":\"612fe3c1-7f5f-4186-aec2-263fa9964f75\",\"authority\":\"bc1bf76b-37a4-4def-8bbf-a19f234b4cd1\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the primary gods of the Brahmanical tradition, he is associated with the preservation and continuance of the universe.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(Toh 555: \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ekhyab ’jug\u003c/em\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Viṣṇu\",\"tibetan\":\"འཇུག་སེལ།\",\"sanskrit\":\"viṣṇu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’jug sel\"}},{\"uuid\":\"bbb9e0c6-80e9-4879-ad0d-7c85f53bda98\",\"authority\":\"260cb623-12cc-40a0-acf0-ce0b1a47aceb\",\"definition\":\"\u003cp\u003eThe Gṛdhra­kūṭa, literally Vulture Peak, was a hill located in the kingdom of Magadha, in the vicinity of the ancient city of Rājagṛha (modern-day Rajgir, in the state of Bihar, India), where the Buddha bestowed many sūtras, especially the Great Vehicle teachings, such as the Prajñāpāramitā sūtras. It continues to be a sacred pilgrimage site for Buddhists to this day.\u003c/p\u003e\",\"names\":{\"english\":\"Vulture Peak\",\"tibetan\":\"བྱ་རྒོད་ཀྱི་ཕུང་པོའི་རི།, བྱ་རྒོད་ཕུང་པོ།\",\"sanskrit\":\"gṛdhrakūṭa, gṛdhra­kūṭa­parvata\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bya rgod kyi phung po’i ri, bya rgod phung po\"}},{\"uuid\":\"4ab87917-09a8-4fc8-86f0-bcf3470b170a\",\"authority\":\"2077ca44-b9d1-4843-bd4a-cd52cc2dc6e2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe \u003cspan data-glossary-id=\\\"UT22084-089-013-2457\\\"\u003ebrahmin\u003c/span\u003e master, interlocutor in \u003ccite class=\\\"title text-en\\\" lang=\\\"en\\\"\u003eThe Sūtra of the Sublime Golden Light\u003c/cite\u003e. See also \u003ca href=\\\"end-notes.xhtml#UT22084-089-013-274\\\" data-pointer-type=\\\"id\\\"\u003en.62\u003c/a\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Vyākaraṇa\",\"tibetan\":\"ལུང་སྟོན་པ།\",\"sanskrit\":\"vyākaraṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lung ston pa\"}},{\"uuid\":\"4f990e63-9af4-4bbd-92b5-c2d339ca0f46\",\"authority\":\"58a6f788-f642-4876-82b0-3bddceb6b950\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA god who is the king of lightning in the western direction.\u003c/p\u003e\",\"names\":{\"english\":\"Waning Light\",\"tibetan\":\"འོད་ཉམས་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’od nyams pa\"}},{\"uuid\":\"e1ac7ae9-aee8-4af8-93a8-b2b50197e211\",\"authority\":\"6e7d97ae-2219-4971-8336-362aa5cfc678\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eGoshenite: pure beryl without the impurities that give it its various colors.\u003c/p\u003e\",\"names\":{\"english\":\"white beryl\",\"tibetan\":\"བཻ་ཌཱུརྱ།\",\"sanskrit\":\"veruli\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bai DUr+ya\"}},{\"uuid\":\"85557c47-a055-487c-b292-5fafd9983925\",\"authority\":\"c99154be-6441-4ac7-a5bd-d8cfc6cc77fb\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cem class=\\\"foreign\\\"\u003eNymphaea pubescens\u003c/em\u003e. The night-blossoming water lily, sometimes referred to as a “night lotus.” It can be white, pink, or red.\u003c/p\u003e\",\"names\":{\"english\":\"white water lilies, white water lily\",\"tibetan\":\"ཀུ་མུ་ད།\",\"sanskrit\":\"kumuda\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ku mu da\"}},{\"uuid\":\"c43d5a58-fb85-4e3a-afc6-f0a682651a64\",\"authority\":\"a27fe75a-6878-48ba-9f0f-5723cb1e94ab\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA set of deities, each guarding a certain direction. Most commonly these are \u003cspan data-glossary-id=\\\"UT22084-089-013-2656\\\"\u003eIndra\u003c/span\u003e (\u003cspan data-glossary-id=\\\"UT22084-089-013-2796\\\"\u003eŚakra\u003c/span\u003e) for the east, Agni for the southeast, \u003cspan data-glossary-id=\\\"UT22084-089-013-2866\\\"\u003eYama\u003c/span\u003e for the south, \u003cspan data-glossary-id=\\\"UT22084-089-013-2826\\\"\u003eSūrya\u003c/span\u003e or Nirṛti for the southwest, \u003cspan data-glossary-id=\\\"UT22084-089-013-2854\\\"\u003eVaruṇa\u003c/span\u003e for the west, \u003cspan data-glossary-id=\\\"UT22084-089-013-2858\\\"\u003eVāyu\u003c/span\u003e (Pavana) for the northwest, Kubera for the north, and \u003cspan data-glossary-id=\\\"UT22084-089-013-2817\\\"\u003eSoma\u003c/span\u003e (Candra), Iśāni, or Pṛthivī for the northeast.\u003c/p\u003e\",\"names\":{\"english\":\"world guardians\",\"tibetan\":\"འཇིག་རྟེན་སྐྱོང་བ།\",\"sanskrit\":\"lokapāla\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’jig rten skyong ba\"}},{\"uuid\":\"b4640039-6b60-4eb6-8695-1c0153d43a37\",\"authority\":\"6bc88464-d01f-41dd-83e3-906807fba845\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA class of nonhuman beings who inhabit forests, mountainous areas, and other natural spaces, or serve as guardians of villages and towns, and may be propitiated for health, wealth, protection, and other boons, or controlled through magic. According to tradition, their homeland is in the north, where they live under the rule of the Great King Vaiśravaṇa.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e Several members of this class have been deified as gods of wealth (these include the just-mentioned Vaiśravaṇa) or as bodhisattva generals of yakṣa armies, and have entered the Buddhist pantheon in a variety of forms, including, in tantric Buddhism, those of wrathful deities.\u003c/p\u003e\",\"names\":{\"english\":\"yakṣa\",\"tibetan\":\"གནོད་སྦྱིན།\",\"sanskrit\":\"yakṣa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gnod sbyin\"}},{\"uuid\":\"1e26e678-33c0-4607-8c82-26972918a7b9\",\"authority\":\"71fbaa0a-6c97-4637-b643-9fa2448a4471\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA female \u003cspan data-glossary-id=\\\"UT22084-089-013-2555\\\"\u003eyakṣa\u003c/span\u003e. \u003c/p\u003e\",\"names\":{\"english\":\"yakṣiṇī\",\"tibetan\":\"གནོད་སྦྱིན་མོ།\",\"sanskrit\":\"yakṣiṇī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gnod sbyin mo\"}},{\"uuid\":\"a2732adf-5a36-4094-8b21-eea5ae281056\",\"authority\":\"da44adf0-9a05-47f8-aebf-0a5485d7dbea\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe lord of death.\u003c/p\u003e\",\"names\":{\"english\":\"Yama\",\"tibetan\":\"གཤིན་རྗེ།\",\"sanskrit\":\"yama\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gshin rje\"}},{\"uuid\":\"99305b1b-4231-4b37-abf3-3eae59c96480\",\"authority\":\"b6bae17d-8e1c-4f88-bc1d-49f99038a139\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe third highest of the six paradises in the desire realm. Its name means “Free of Conflict.”\u003c/p\u003e\",\"names\":{\"english\":\"Yāma\",\"tibetan\":\"འཐབ་བྲལ།\",\"sanskrit\":\"yāma\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’thab bral\"}},{\"uuid\":\"a19e5bbe-8501-4ef7-acae-78182289d957\",\"authority\":\"b0056ad1-8105-493f-91a0-57f5141026f7\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe longest unit of distance in classical India. The lack of a uniform standard for the smaller units means that there is no precise equivalent, especially as its theoretical length tended to increase over time. Therefore, it can indicate a distance of between four and ten miles.\u003c/p\u003e\",\"names\":{\"english\":\"yojana\",\"tibetan\":\"དཔག་ཚད།\",\"sanskrit\":\"yojana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dpag tshad\"}}]}]\n"])</script><div hidden id="S:5"><div dir="ltr" data-orientation="horizontal" data-slot="tabs" class="flex flex-col w-full gap-0 @container/sidebar"><div class="sticky top-0 pt-1 pb-2 z-10 w-full rounded-t bg-background overflow-x-auto text-center"><div role="tablist" aria-orientation="horizontal" data-slot="tabs-list" class="bg-background gap-1 sm:gap-3 h-10 items-center justify-center sm:p-1 w-fit px-6 inline-flex mx-auto rounded-none" tabindex="-1" data-orientation="horizontal" style="outline:none"><button type="button" role="tab" aria-selected="true" aria-controls="radix-_R_2npftt6btb_-content-endnotes" data-state="active" id="radix-_R_2npftt6btb_-trigger-endnotes" data-slot="tabs-trigger" class="inline-flex items-center justify-center whitespace-nowrap px-1 py-0.75 text-sm data-[state=active]:font-semibold ring-offset-background transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-background text-foreground border-b-2 border-transparent data-[state=active]:border-primary-300 decoration-primary-25 hover:text-primary hover:border-primary/20 hover:cursor-pointer" tabindex="-1" data-orientation="horizontal" data-radix-collection-item="">Notes</button><button type="button" role="tab" aria-selected="false" aria-controls="radix-_R_2npftt6btb_-content-glossary" data-state="inactive" id="radix-_R_2npftt6btb_-trigger-glossary" data-slot="tabs-trigger" class="inline-flex items-center justify-center whitespace-nowrap px-1 py-0.75 text-sm data-[state=active]:font-semibold ring-offset-background transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-background text-foreground border-b-2 border-transparent data-[state=active]:border-primary-300 decoration-primary-25 hover:text-primary hover:border-primary/20 hover:cursor-pointer" tabindex="-1" data-orientation="horizontal" data-radix-collection-item="">Glossary</button><button type="button" role="tab" aria-selected="false" aria-controls="radix-_R_2npftt6btb_-content-bibliography" data-state="inactive" id="radix-_R_2npftt6btb_-trigger-bibliography" data-slot="tabs-trigger" class="inline-flex items-center justify-center whitespace-nowrap px-1 py-0.75 text-sm data-[state=active]:font-semibold ring-offset-background transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-background text-foreground border-b-2 border-transparent data-[state=active]:border-primary-300 decoration-primary-25 hover:text-primary hover:border-primary/20 hover:cursor-pointer" tabindex="-1" data-orientation="horizontal" data-radix-collection-item="">Biblio</button><button type="button" role="tab" aria-selected="false" aria-controls="radix-_R_2npftt6btb_-content-abbreviations" data-state="inactive" id="radix-_R_2npftt6btb_-trigger-abbreviations" data-slot="tabs-trigger" class="inline-flex items-center justify-center whitespace-nowrap px-1 py-0.75 text-sm data-[state=active]:font-semibold ring-offset-background transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-background text-foreground border-b-2 border-transparent data-[state=active]:border-primary-300 decoration-primary-25 hover:text-primary hover:border-primary/20 hover:cursor-pointer" tabindex="-1" data-orientation="horizontal" data-radix-collection-item="">Abbr</button></div></div><div class="px-2"><div class="overflow-auto md:h-[calc(100vh-8.5rem)] h-[calc(100vh-4rem)] rounded bg-surface"><div class="rounded ps-10 pe-4 max-w-readable mx-auto"><div data-state="active" data-orientation="horizontal" role="tabpanel" aria-labelledby="radix-_R_2npftt6btb_-trigger-endnotes" id="radix-_R_2npftt6btb_-content-endnotes" tabindex="0" data-slot="tabs-content" class="mt-2 ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 data-[state=inactive]:hidden" style="animation-duration:0s"><div class="h-0"></div><div></div><div class="h-0"></div><div class="flex flex-col gap-4 pb-8"><div class="flex gap-5"><div class="animate-pulse rounded-md bg-foreground/10 h-6 w-6"></div><div class="animate-pulse rounded-md bg-foreground/10 h-32 grow"></div></div><div class="flex gap-5"><div class="animate-pulse rounded-md bg-foreground/10 h-6 w-6"></div><div class="animate-pulse rounded-md bg-foreground/10 h-32 grow"></div></div><div class="flex gap-5"><div class="animate-pulse rounded-md bg-foreground/10 h-6 w-6"></div><div class="animate-pulse rounded-md bg-foreground/10 h-32 grow"></div></div></div></div><div data-state="inactive" data-orientation="horizontal" role="tabpanel" aria-labelledby="radix-_R_2npftt6btb_-trigger-glossary" id="radix-_R_2npftt6btb_-content-glossary" tabindex="0" data-slot="tabs-content" class="mt-2 ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 pb-8 data-[state=inactive]:hidden"><div class="flex flex-col w-full"><div id="glossary" class="relative scroll-mt-20"><button type="button" id="radix-_R_2lanpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4 @c/sidebar:mt-5 mt-6">g.</button><div class="passage pl-6 @c/sidebar:pl-4"><h2 class="font-serif font-light text-primary scroll-m-20 text-xl @c/sidebar:mt-4 mt-6 @c/sidebar:pb-2 pb-3 @c/sidebar:text-left text-center section-title">Glossary</h2></div></div><div class="mt-3 flex flex-col gap-6"><div id="805eaba9-4065-4743-b490-a04ef51d4e9d" class="relative scroll-mt-20"><button type="button" id="radix-_R_80d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.1</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ābhāsvara</div><ul class="ml-4 list-disc"><li class="italic">’od gsal</li><li class="pt-1"><span class="font-tibetan text-base">འོད་གསལ།</span></li><li class="italic">ābhāsvara</li></ul><div class="glossary-instance-definition"><p class="definition">“Clear Light.” The highest of the three paradises that correspond to the second <span data-glossary-id="UT22084-089-013-2564">dhyāna</span> in the form realm.</p></div></div></div></div><div id="2bb91118-86fe-4939-981b-b4a6dc4e4de1" class="relative scroll-mt-20"><button type="button" id="radix-_R_80l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.2</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Abhayakīrti</div><ul class="ml-4 list-disc"><li class="italic">’jigs med grags pa</li><li class="pt-1"><span class="font-tibetan text-base">འཇིགས་མེད་གྲགས་པ།</span></li><li class="italic">abhayakīrti</li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">bsnyengs pa mi mnga’ ba’i grags pa</em>)</p></div></div></div></div><div id="a6149485-1e33-43a4-96ba-655d24a56467" class="relative scroll-mt-20"><button type="button" id="radix-_R_80t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.3</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Abṛha, Avṛha</div><ul class="ml-4 list-disc"><li class="italic">mi che ba</li><li class="pt-1"><span class="font-tibetan text-base">མི་ཆེ་བ།</span></li><li class="italic">avṛha</li></ul><div class="glossary-instance-definition"><p class="definition">In the Sarvāstivāda tradition, this is the lowest of the five <span data-glossary-id="UT22084-089-013-2938">Śuddhāvāsa</span> paradises, the highest paradises in the form realm, and is said to be the most common rebirth for the “<span data-glossary-id="UT22084-089-013-2505">non-returners</span>” of the <span data-glossary-id="UT22084-089-013-3215">Śrāvakayāna</span>. In this sūtra it is the third highest. </p></div></div></div></div><div id="2f80c642-ecba-46cd-a8b2-9c0b1ed671e5" class="relative scroll-mt-20"><button type="button" id="radix-_R_8155anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.4</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">acacia</div><ul class="ml-4 list-disc"><li class="italic">shI ri shA</li><li class="pt-1"><span class="font-tibetan text-base">ཤཱི་རི་ཤཱ།</span></li><li class="italic">śirīṣa</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign">Albizia lebbeck</em>. A tall tree that can grow to 100 feet. Other common names include Indian walnut, lebbeck, lebbeck tree, flea tree, frywood, koko, and “woman’s tongue tree.” The bark is used medicinally.</p></div></div></div></div><div id="d756627e-57de-4181-8afd-d6dedb75bc11" class="relative scroll-mt-20"><button type="button" id="radix-_R_81d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.5</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">ācārya</div><ul class="ml-4 list-disc"><li class="italic">slob dpon</li><li class="pt-1"><span class="font-tibetan text-base">སློབ་དཔོན།</span></li><li class="italic">ācārya</li></ul><div class="glossary-instance-definition"><p class="definition">A spiritual teacher, meaning one who knows the conduct or practice (<em class="foreign break text-sa" lang="sa-LATN">ācāra</em>) to be performed. It can also be a title for a scholar, though that is not the context in this sūtra. </p></div></div></div></div><div id="789befb5-6df7-4ed5-8102-20f2e5e3db83" class="relative scroll-mt-20"><button type="button" id="radix-_R_81l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.6</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">aerial palace</div><ul class="ml-4 list-disc"><li class="italic">gzhal med khang</li><li class="pt-1"><span class="font-tibetan text-base">གཞལ་མེད་ཁང་།</span></li><li class="italic">vimāna</li></ul><div class="glossary-instance-definition"><p class="definition">These palaces served as both vehicles and residences for deities.</p></div></div></div></div><div id="f8b603ad-07d1-4b0b-8c9a-e94d5caa865e" class="relative scroll-mt-20"><button type="button" id="radix-_R_81t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.7</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">affliction, kleśa</div><ul class="ml-4 list-disc"><li class="italic">nyon mongs, nyon mongs</li><li class="pt-1"><span class="font-tibetan text-base">ཉོན་མོངས།, ཉོན་མོངས།</span></li><li class="italic">kleśa, kleśa</li></ul><div class="glossary-instance-definition"><p class="definition">The essentially pure nature of mind is obscured and afflicted by various psychological defilements, which destroy the mind’s peace and composure and lead to unwholesome deeds of body, speech, and mind, acting as causes for continued existence in saṃsāra. Included among them are the primary afflictions of desire (<em class="foreign break text-sa" lang="sa-LATN">rāga</em>), anger (<em class="foreign break text-sa" lang="sa-LATN">dveṣa</em>), and ignorance (<em class="foreign break text-sa" lang="sa-LATN">avidyā</em>). It is said that there are eighty-four thousand of these negative mental qualities, for which the eighty-four thousand categories of the Buddha’s teachings serve as the antidote.</p><p class="definition"><em class="foreign break text-sa" lang="sa-LATN">Kleśa</em> is also commonly translated as “negative emotions,” “disturbing emotions,” and so on. The Pāli <em class="foreign text-pi" lang="pi-LATN">kilesa</em>, Middle Indic <em class="foreign break text-sa" lang="sa-LATN">kileśa</em>, and Buddhist Hybrid Sanskrit <em class="foreign break text-sa" lang="sa-LATN">kleśa</em> all primarily mean “stain” or “defilement.” The translation “affliction” is a secondary development that derives from the more general (non-Buddhist) classical understanding of <em class="foreign break text-sa" lang="sa-LATN">√kliś</em> (“to harm,“ “to afflict”). Both meanings are noted by Buddhist commentators. </p></div></div></div></div><div id="45a48b06-14a4-4a11-beac-df1118f20976" class="relative scroll-mt-20"><button type="button" id="radix-_R_8255anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.8</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">affliction, kleśa</div><ul class="ml-4 list-disc"><li class="italic">nyon mongs, nyon mongs</li><li class="pt-1"><span class="font-tibetan text-base">ཉོན་མོངས།, ཉོན་མོངས།</span></li><li class="italic">kleśa, kleśa</li></ul><div class="glossary-instance-definition"><p class="definition">The essentially pure nature of mind is obscured and afflicted by various psychological defilements, which destroy the mind’s peace and composure and lead to unwholesome deeds of body, speech, and mind, acting as causes for continued existence in saṃsāra. Included among them are the primary afflictions of desire (<em class="foreign break text-sa" lang="sa-LATN">rāga</em>), anger (<em class="foreign break text-sa" lang="sa-LATN">dveṣa</em>), and ignorance (<em class="foreign break text-sa" lang="sa-LATN">avidyā</em>). It is said that there are eighty-four thousand of these negative mental qualities, for which the eighty-four thousand categories of the Buddha’s teachings serve as the antidote.</p><p class="definition"><em class="foreign break text-sa" lang="sa-LATN">Kleśa</em> is also commonly translated as “negative emotions,” “disturbing emotions,” and so on. The Pāli <em class="foreign text-pi" lang="pi-LATN">kilesa</em>, Middle Indic <em class="foreign break text-sa" lang="sa-LATN">kileśa</em>, and Buddhist Hybrid Sanskrit <em class="foreign break text-sa" lang="sa-LATN">kleśa</em> all primarily mean “stain” or “defilement.” The translation “affliction” is a secondary development that derives from the more general (non-Buddhist) classical understanding of <em class="foreign break text-sa" lang="sa-LATN">√kliś</em> (“to harm,“ “to afflict”). Both meanings are noted by Buddhist commentators. </p></div></div></div></div><div id="58e74b39-bca4-4800-a114-059795feb2fe" class="relative scroll-mt-20"><button type="button" id="radix-_R_82d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.9</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">agarwood</div><ul class="ml-4 list-disc"><li class="italic">a ga ru</li><li class="pt-1"><span class="font-tibetan text-base">ཨ་ག་རུ།</span></li><li class="italic">agaru</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign">Amyris agallocha</em>. Also called agallochum and aloeswood. This is a resinous heartwood that has been infected by the fungus <em class="foreign">Phialophora parasitica</em>. In India, agarwood is primarily derived from the fifteen Aquilaria (<em class="foreign">Aquilaria malaccensis</em>) and nine <em class="foreign">Gyrinops</em> species of lign-aloe trees. </p></div></div></div></div><div id="547d441f-ee55-43d1-bf8d-712745f3a103" class="relative scroll-mt-20"><button type="button" id="radix-_R_82l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.10</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Āgata</div><ul class="ml-4 list-disc"><li class="italic">’ong ba</li><li class="pt-1"><span class="font-tibetan text-base">འོང་བ།</span></li><li class="italic">āgata</li></ul><div class="glossary-instance-definition"><p class="definition">A god who is the king of lightning in the eastern direction.</p></div></div></div></div><div id="569c7928-b769-4d02-abf6-9f93a71c3804" class="relative scroll-mt-20"><button type="button" id="radix-_R_82t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.11</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Akaniṣṭha</div><ul class="ml-4 list-disc"><li class="italic">’og min</li><li class="pt-1"><span class="font-tibetan text-base">འོག་མིན།</span></li><li class="italic">akaniṣṭha</li></ul><div class="glossary-instance-definition"><p class="definition">The eighth and highest level of the Realm of Form (<em class="foreign break text-sa" lang="sa-LATN">rūpadhātu</em>), the last of the five pure abodes (<em class="foreign break text-sa" lang="sa-LATN">śuddhāvāsa</em>); it is only accessible as the result of specific states of <em class="foreign break text-sa" lang="sa-LATN">dhyāna</em>. According to some texts this is where non-returners (<em class="foreign break text-sa" lang="sa-LATN">anāgāmin</em>) dwell in their last lives. In other texts it is the realm of the enjoyment body (<em class="foreign break text-sa" lang="sa-LATN">saṃbhoga­kāya</em>) and is a buddhafield associated with the Buddha Vairocana; it is accessible only to bodhisattvas on the tenth level.</p></div></div></div></div><div id="b78f2e81-fa8d-4312-a7a1-86949f89ddfd" class="relative scroll-mt-20"><button type="button" id="radix-_R_8355anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.12</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ākāśagarbha</div><ul class="ml-4 list-disc"><li class="italic">nam mkha’i snying po</li><li class="pt-1"><span class="font-tibetan text-base">ནམ་མཁའི་སྙིང་པོ།</span></li><li class="italic">ākāśagarbha</li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p></div></div></div></div><div id="25f9b88e-7fb3-4d68-a52b-49e7a1e4da3c" class="relative scroll-mt-20"><button type="button" id="radix-_R_83d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.13</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ākāśaghoṣa</div><ul class="ml-4 list-disc"><li class="italic">nam mkha’ sgrogs</li><li class="pt-1"><span class="font-tibetan text-base">ནམ་མཁའ་སྒྲོགས།</span></li><li class="italic">ākāśaghoṣa</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2496">Licchavī</span> youth.</p></div></div></div></div><div id="ba5e7fb9-e30f-44bf-b7a9-76971f797abf" class="relative scroll-mt-20"><button type="button" id="radix-_R_83l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.14</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ākāśapāla</div><ul class="ml-4 list-disc"><li class="italic">nam mkha’ skyong</li><li class="pt-1"><span class="font-tibetan text-base">ནམ་མཁའ་སྐྱོང་།</span></li><li class="italic">ākāśapāla</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2496">Licchavī</span> youth.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">nam mkha’ skyabs</em>)</p></div></div></div></div><div id="5eaaf65c-6293-45b2-aca5-96506aa7e494" class="relative scroll-mt-20"><button type="button" id="radix-_R_83t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.15</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ākāśavat</div><ul class="ml-4 list-disc"><li class="italic">nam mkha’ bzhin</li><li class="pt-1"><span class="font-tibetan text-base">ནམ་མཁའ་བཞིན།</span></li><li class="italic">ākāśavat</li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">bsam pa nam mkha’ ci bzhin</em>)</p></div></div></div></div><div id="b38c05f5-9f1a-4b06-8cc2-d5ff8067e463" class="relative scroll-mt-20"><button type="button" id="radix-_R_8455anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.16</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ākāśa­viśuddha­prajña</div><ul class="ml-4 list-disc"><li class="italic">nam mkha’ rnam dag shes rab</li><li class="pt-1"><span class="font-tibetan text-base">ནམ་མཁའ་རྣམ་དག་ཤེས་རབ།</span></li><li class="italic">ākāśa­viśuddha­prajña</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2471">deva</span>.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">nam mkha’i blo gros rnam par dag pa</em>)</p></div></div></div></div><div id="497e05ef-9c9d-4cee-bb86-157997d6046f" class="relative scroll-mt-20"><button type="button" id="radix-_R_84d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.17</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Akṣayamati</div><ul class="ml-4 list-disc"><li class="italic">blo gros mi zad</li><li class="pt-1"><span class="font-tibetan text-base">བློ་གྲོས་མི་ཟད།</span></li><li class="italic">akṣayamati</li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">seng ge’i mtshan thogs pa med pa’i ’od zer ’bar ba</em>)</p></div></div></div></div><div id="15b53e78-cf61-4aec-86bd-5380bbcb3129" class="relative scroll-mt-20"><button type="button" id="radix-_R_84l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.18</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Akṣobhya</div><ul class="ml-4 list-disc"><li class="italic">mi ’khrugs pa</li><li class="pt-1"><span class="font-tibetan text-base">མི་འཁྲུགས་པ།</span></li><li class="italic">akṣobhya</li></ul><div class="glossary-instance-definition"><p class="definition">Lit. “Not Disturbed” or “Immovable One.” The buddha in the eastern realm of Abhirati. A well-known buddha in Mahāyāna, regarded in the higher tantras as the head of one of the five buddha families, the vajra family in the east.</p></div></div></div></div><div id="4d5fe580-1bb8-49ce-86e9-39f960262383" class="relative scroll-mt-20"><button type="button" id="radix-_R_84t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.19</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Alakāvati</div><ul class="ml-4 list-disc"><li class="italic">lcang lo can</li><li class="pt-1"><span class="font-tibetan text-base">ལྕང་ལོ་ཅན།</span></li><li class="italic">alakāvati</li></ul><div class="glossary-instance-definition"><p class="definition">The kingdom of <span data-glossary-id="UT22084-089-013-2555">yakṣas</span> located on Mount <span data-glossary-id="UT22084-089-013-2940">Sumeru</span> and ruled over by Kubera, also known as <span data-glossary-id="UT22084-089-013-2847">Vaiśravaṇa</span>.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">nor ldan</em>)</p></div></div></div></div><div id="a205f712-edf6-4633-a433-08e3bab530ce" class="relative scroll-mt-20"><button type="button" id="radix-_R_8555anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.20</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Alpormika</div><ul class="ml-4 list-disc"><li class="italic">dba’ rlabs chung</li><li class="pt-1"><span class="font-tibetan text-base">དབའ་རླབས་ཆུང་།</span></li><li class="italic">alpormika</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2503">nāga</span> king.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">dba’ rlabs chung ngu</em>)</p></div></div></div></div><div id="a91c8877-6a20-4d23-9475-e5bc915e2bc9" class="relative scroll-mt-20"><button type="button" id="radix-_R_85d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.21</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Always Concentrated</div><ul class="ml-4 list-disc"><li class="italic">rtag tu ting nge ’dzin</li><li class="pt-1"><span class="font-tibetan text-base">རྟག་ཏུ་ཏིང་ངེ་འཛིན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p></div></div></div></div><div id="b4043124-016c-46e7-b162-8a823ecbce68" class="relative scroll-mt-20"><button type="button" id="radix-_R_85l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.22</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Amitābha</div><ul class="ml-4 list-disc"><li class="italic">’od dpag med</li><li class="pt-1"><span class="font-tibetan text-base">འོད་དཔག་མེད།</span></li><li class="italic">amitābha</li></ul><div class="glossary-instance-definition"><p class="definition">The buddha of the western buddhafield of Sukhāvatī, where fortunate beings are reborn to make further progress toward spiritual maturity. Amitābha made his great vows to create such a realm when he was a bodhisattva called Dharmākara. In the Pure Land Buddhist tradition, popular in East Asia, aspiring to be reborn in his buddha realm is the main emphasis; in other Mahāyāna traditions, too, it is a widespread practice. For a detailed description of the realm, see <a target="_blank" href="https://read.84000.co/translation/toh115.html" title="The Display of the Pure Land of Sukhāvatī, Toh 115"><cite class="title text-en" lang="en">The Display of the Pure Land of Sukhāvatī</cite>, Toh 115</a>. In some tantras that make reference to the five families he is the tathāgata associated with the lotus family.</p><p class="definition">Amitābha, “Infinite Light,” is also known in many Indian Buddhist works as Amitāyus, “Infinite Life.” In both East Asian and Tibetan Buddhist traditions he is often conflated with another buddha named “Infinite Life,” Aparimitāyus, or “Infinite Life and Wisdom,”Aparimitāyurjñāna, the shorter version of whose name has also been back-translated from Tibetan into Sanskrit as Amitāyus but who presides over a realm in the zenith. For details on the relation between these buddhas and their names, see <a target="_blank" href="https://read.84000.co/translation/toh674.html#UT22084-091-072-14" title="The Aparimitāyurjñāna Sūtra (1) Toh 674, i.9"><cite class="title text-en" lang="en">The Aparimitāyurjñāna Sūtra</cite> (1) Toh 674, i.9</a>. </p></div></div></div></div><div id="0e4a8c27-a163-43ca-a541-e5906937a273" class="relative scroll-mt-20"><button type="button" id="radix-_R_85t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.23</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Amra</div><ul class="ml-4 list-disc"><li class="italic">a mra</li><li class="pt-1"><span class="font-tibetan text-base">ཨ་མྲ།</span></li><li class="italic">amra</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span>.</p></div></div></div></div><div id="ef4011fb-3baf-438a-9660-959e688818ad" class="relative scroll-mt-20"><button type="button" id="radix-_R_8655anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.24</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Amradhara</div><ul class="ml-4 list-disc"><li class="italic">a mra ’chang</li><li class="pt-1"><span class="font-tibetan text-base">ཨ་མྲ་འཆང་།</span></li><li class="italic">amradhara</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span>.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">a mra thogs pa</em>)</p></div></div></div></div><div id="e0d96fcc-e6d7-49bb-ad3e-fc50b223d78e" class="relative scroll-mt-20"><button type="button" id="radix-_R_86d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.25</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">amṛta</div><ul class="ml-4 list-disc"><li class="italic">bdud rtsi</li><li class="pt-1"><span class="font-tibetan text-base">བདུད་རྩི།</span></li><li class="italic">amṛta</li></ul><div class="glossary-instance-definition"><p class="definition">The nectar of immortality possessed by the <span data-glossary-id="UT22084-089-013-2471">devas</span>, it is used as a metaphor for the teaching that brings liberation.</p></div></div></div></div><div id="6c853461-7d86-47a4-9476-d994ab38a8d8" class="relative scroll-mt-20"><button type="button" id="radix-_R_86l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.26</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Aṃśurāja</div><ul class="ml-4 list-disc"><li class="italic">’od snang rgyal po</li><li class="pt-1"><span class="font-tibetan text-base">འོད་སྣང་རྒྱལ་པོ།</span></li><li class="italic">aṃśurāja</li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">snang ba’i rgyal po</em>)</p></div></div></div></div><div id="759b69fd-3945-476f-9464-efc71731b2c5" class="relative scroll-mt-20"><button type="button" id="radix-_R_86t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.27</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Anabhraka</div><ul class="ml-4 list-disc"><li class="italic">sprin med</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་མེད།</span></li><li class="italic">anabhraka</li></ul><div class="glossary-instance-definition"><p class="definition">“Cloudless.” In the Sarvāstivāda tradition, the lowest of the three paradises that correspond to the fourth <span data-glossary-id="UT22084-089-013-2564">dhyāna</span> in the form realm. Translated in other texts as <em class="foreign text-wy" lang="bo-LATN">sprin dang bral ba</em>.</p></div></div></div></div><div id="25d30c62-21d4-45f4-aa28-a30a59ba2248" class="relative scroll-mt-20"><button type="button" id="radix-_R_8755anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.28</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ānanda</div><ul class="ml-4 list-disc"><li class="italic">kun dga’ bo</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་དགའ་བོ།</span></li><li class="italic">ānanda</li></ul><div class="glossary-instance-definition"><p class="definition">A major śrāvaka disciple and personal attendant of the Buddha Śākyamuni during the last twenty-five years of his life. He was a cousin of the Buddha (according to the <cite class="title break text-sa" lang="sa-LATN">Mahāvastu</cite>, he was a son of Śuklodana, one of the brothers of King Śuddhodana, which means he was a brother of Devadatta; other sources say he was a son of Amṛtodana, another brother of King Śuddhodana, which means he would have been a brother of Aniruddha).</p><p class="definition">Ānanda, having always been in the Buddha’s presence, is said to have memorized all the teachings he heard and is celebrated for having recited all the Buddha’s teachings by memory at the first council of the Buddhist saṅgha, thus preserving the teachings after the Buddha’s parinirvāṇa. The phrase “Thus did I hear at one time,” found at the beginning of the sūtras, usually stands for his recitation of the teachings. He became a patriarch after the passing of Mahākāśyapa.</p></div></div></div></div><div id="cb7577e3-d76f-4598-93c0-76a3991799cb" class="relative scroll-mt-20"><button type="button" id="radix-_R_87d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.29</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Anāvaraṇa­dharma­cakra­varta</div><ul class="ml-4 list-disc"><li class="italic">thogs pa med par chos kyi ’khor lo bskor ba</li><li class="pt-1"><span class="font-tibetan text-base">ཐོགས་པ་མེད་པར་ཆོས་ཀྱི་འཁོར་ལོ་བསྐོར་བ།</span></li><li class="italic">anāvaraṇa­dharma­cakra­varta</li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p></div></div></div></div><div id="156530bf-0e66-4b03-807b-ea48f2f06480" class="relative scroll-mt-20"><button type="button" id="radix-_R_87l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.30</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Anavatapta</div><ul class="ml-4 list-disc"><li class="italic">ma dros pa</li><li class="pt-1"><span class="font-tibetan text-base">མ་དྲོས་པ།</span></li><li class="italic">anavatapta</li></ul><div class="glossary-instance-definition"><p>A nāga king whose domain is Lake Anavatapta. According to Buddhist cosmology, this lake is located near Mount Sumeru and is the source of the four great rivers of Jambudvīpa. It is often identified with Lake Manasarovar at the foot of Mount Kailash in Tibet.</p></div></div></div></div><div id="a84fe0e5-56a1-484f-829f-6fbeb6575eca" class="relative scroll-mt-20"><button type="button" id="radix-_R_87t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.31</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Anikṣiptadhura</div><ul class="ml-4 list-disc"><li class="italic">mi gtong brtson pa</li><li class="pt-1"><span class="font-tibetan text-base">མི་གཏོང་བརྩོན་པ།</span></li><li class="italic">anikṣiptadhura</li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p></div></div></div></div><div id="81d7585a-71d0-4c49-9e96-d6c53d49c14d" class="relative scroll-mt-20"><button type="button" id="radix-_R_8855anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.32</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Anikṣipta­mahā­praṇidhāna</div><ul class="ml-4 list-disc"><li class="italic">smon lam chen po mi gtong ba</li><li class="pt-1"><span class="font-tibetan text-base">སྨོན་ལམ་ཆེན་པོ་མི་གཏོང་བ།</span></li><li class="italic">anikṣipta­mahā­praṇidhāna</li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">smon lam chen po yongs su mi gcod pa</em>)</p></div></div></div></div><div id="80eb280d-22b5-48d5-85d5-94f83d5dddf5" class="relative scroll-mt-20"><button type="button" id="radix-_R_88d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.33</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Annaharaṇa</div><ul class="ml-4 list-disc"><li class="italic">zas ’phrog</li><li class="pt-1"><span class="font-tibetan text-base">ཟས་འཕྲོག</span></li><li class="italic">annaharaṇa</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span>.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">zas kyi ril ming</em>)</p></div></div></div></div><div id="52a06769-8761-4294-8f5f-896f2ffa5871" class="relative scroll-mt-20"><button type="button" id="radix-_R_88l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.34</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Apramāṇābha</div><ul class="ml-4 list-disc"><li class="italic">tshad med ’od</li><li class="pt-1"><span class="font-tibetan text-base">ཚད་མེད་འོད།</span></li><li class="italic">apramāṇābha</li></ul><div class="glossary-instance-definition"><p class="definition">“Immeasurable Light.” The second highest of the three paradises that correspond to the second <span data-glossary-id="UT22084-089-013-2564">dhyāna</span> in the form realm. Translated in other texts as <em class="foreign text-wy" lang="bo-LATN">tshad med snang ba</em>.</p></div></div></div></div><div id="26379e1f-3aa1-4b5e-b164-30105102abdf" class="relative scroll-mt-20"><button type="button" id="radix-_R_88t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.35</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Apramāṇaśubha</div><ul class="ml-4 list-disc"><li class="italic">tshad med dge</li><li class="pt-1"><span class="font-tibetan text-base">ཚད་མེད་དགེ</span></li><li class="italic">apramāṇaśubha</li></ul><div class="glossary-instance-definition"><p class="definition">“Immeasurable Goodness.” The second highest of the three paradises that correspond to the third <span data-glossary-id="UT22084-089-013-2564">dhyāna</span> in the form realm. </p></div></div></div></div><div id="9a49890c-94f8-4129-9740-fac8887e030b" class="relative scroll-mt-20"><button type="button" id="radix-_R_8955anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.36</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">arhat</div><ul class="ml-4 list-disc"><li class="italic">dgra bcom pa</li><li class="pt-1"><span class="font-tibetan text-base">དགྲ་བཅོམ་པ།</span></li><li class="italic">arhat</li></ul><div class="glossary-instance-definition"><p class="definition">According to Buddhist tradition, one who is worthy of worship (<em class="foreign break text-sa" lang="sa-LATN">pūjām arhati</em>), or one who has conquered the enemies, the mental afflictions (<em class="foreign break text-sa" lang="sa-LATN">kleśa-ari-hata-vat</em>), and reached liberation from the cycle of rebirth and suffering. It is the fourth and highest of the four fruits attainable by śrāvakas. Also used as an epithet of the Buddha.</p></div></div></div></div><div id="8bbd9642-1f8b-40bd-89dc-31b2f53eacfd" class="relative scroll-mt-20"><button type="button" id="radix-_R_89d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.37</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">artemisia</div><ul class="ml-4 list-disc"><li class="italic">sha mya</li><li class="pt-1"><span class="font-tibetan text-base">ཤ་མྱ།</span></li><li class="italic">śāmyaka</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign">Careva arborea</em>. Also known as mugwort and wormwood.</p><p class="definition">(Degé 557: <em class="foreign text-wy" lang="bo-LATN">sha myang</em>. Toh 555: <em class="foreign text-wy" lang="bo-LATN">sha ma ka</em>. Bagchi edition: <em class="foreign break text-sa" lang="sa-LATN">śyābhyaka</em>.)</p></div></div></div></div><div id="40dce0ff-b273-4107-acb0-3cc7cddc52c8" class="relative scroll-mt-20"><button type="button" id="radix-_R_89l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.38</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">ārya</div><ul class="ml-4 list-disc"><li class="italic">’phags pa</li><li class="pt-1"><span class="font-tibetan text-base">འཕགས་པ།</span></li><li class="italic">ārya</li></ul><div class="glossary-instance-definition"><p class="definition">The Sanskrit <em class="foreign break text-sa" lang="sa-LATN">ārya</em> has the general meaning of a noble person, one of a higher class or caste. In Buddhist literature, depending on the context, it often means specifically one who has gained the realization of the path and is superior for that reason. In particular, it applies to stream enterers, once-returners, non-returners, and worthy ones (<em class="foreign break text-sa" lang="sa-LATN">arhats</em>) and is also used as an epithet of bodhisattvas. In the five-path system, it refers to someone who has achieved at least the path of seeing (<em class="foreign break text-sa" lang="sa-LATN">darśanamārga</em>).</p></div></div></div></div><div id="60f077ca-e1d4-476c-9ef2-79952daef92b" class="relative scroll-mt-20"><button type="button" id="radix-_R_89t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.39</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Asaṃjñasattva</div><ul class="ml-4 list-disc"><li class="italic">sems can ’du shes med pa</li><li class="pt-1"><span class="font-tibetan text-base">སེམས་ཅན་འདུ་ཤེས་མེད་པ།</span></li><li class="italic">asaṃjñasattva</li></ul><div class="glossary-instance-definition"><p class="definition">“Beings without Perception.” A heavenly realm listed in this text between the twelfth heaven of the form realm, <span data-glossary-id="UT22084-089-013-2913">Bṛhatphala</span>, and the five Pure Abodes of the form realm, known collectively as <span data-glossary-id="UT22084-089-013-2938">Śuddhāvāsa</span>.</p></div></div></div></div><div id="136b1de2-9916-46f4-9d24-101eca1d61f3" class="relative scroll-mt-20"><button type="button" id="radix-_R_8a55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.40</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">asaṃkhyeya eon</div><ul class="ml-4 list-disc"><li class="italic">bskal pa grangs med pa</li><li class="pt-1"><span class="font-tibetan text-base">བསྐལ་པ་གྲངས་མེད་པ།</span></li><li class="italic">asaṃkhyeyakalpa</li></ul><div class="glossary-instance-definition"><p class="definition">The name of a certain kind of kalpa, literally meaning “incalculable.” The number of years in this kalpa differs in various sūtras that give a number. Also, twenty intermediate kalpas are said to be one <em class="foreign break text-sa" lang="sa-LATN">asaṃkhyeya</em> (incalculable) kalpa, and four incalculable kalpas are one great kalpa. In that case, those four incalculable kalpas represent the <span data-glossary-id="UT22084-089-013-2480">eons</span> of the creation, presence, destruction, and absence of a world. Buddhas are often described as appearing in a second incalculable kalpa.</p></div></div></div></div><div id="d1696558-a54d-4453-a65b-c8dc56343522" class="relative scroll-mt-20"><button type="button" id="radix-_R_8ad5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.41</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">aspects of enlightenment, bodhipakṣadharma</div><ul class="ml-4 list-disc"><li class="italic">byang chub kyi phyogs</li><li class="pt-1"><span class="font-tibetan text-base">བྱང་ཆུབ་ཀྱི་ཕྱོགས།</span></li><li class="italic">bodhipakṣa</li></ul><div class="glossary-instance-definition"><p class="definition">A set of qualities necessary as a method to attain the enlightenment of a <span data-glossary-id="UT22084-089-013-2585">śrāvaka</span>, <span data-glossary-id="UT22084-089-013-2578">pratyekabuddha</span>, or buddha. There are thirty-seven of these: (1–4) the four kinds of mindfulness: mindfulness of body, <span data-glossary-id="UT22084-089-013-2523">sensations</span>, mind, and phenomena; (5–8) the four correct exertions: not to do bad actions that have not been done, to give up bad actions that are being done, to do good actions that have not been done, and to increase the good actions that are being done; (9–12) the foundations for miraculous <span data-glossary-id="UT22084-089-013-2512">powers</span>: intention, diligence, mind, and analysis; (13–17) the five <span data-glossary-id="UT22084-089-013-2512">powers</span>: faith, diligence, mindfulness, <span data-glossary-id="UT22084-089-013-2593">samādhi</span>, and wisdom; (18–22) the five <span data-glossary-id="UT22084-089-013-2530">strengths</span>: even stronger forms of faith, diligence, mindfulness, <span data-glossary-id="UT22084-089-013-2593">samādhi</span>, and wisdom; (23–29) the seven limbs of enlightenment: correct mindfulness, correct wisdom of the analysis of phenomena, correct diligence, correct joy, correct serenity, correct <span data-glossary-id="UT22084-089-013-2593">samādhi</span>, and correct equanimity; (30–37) the eightfold noble path: right view, examination, speech, action, livelihood, effort, mindfulness, and <span data-glossary-id="UT22084-089-013-2593">samādhi</span>.</p></div></div></div></div><div id="cd64ca4d-45fd-4ab3-9701-125845e35df4" class="relative scroll-mt-20"><button type="button" id="radix-_R_8al5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.42</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Aspiring to Always Turn the Dharma Wheel</div><ul class="ml-4 list-disc"><li class="italic">rtag par chos kyi ’khor lo bskor bar sems bskyed</li><li class="pt-1"><span class="font-tibetan text-base">རྟག་པར་ཆོས་ཀྱི་འཁོར་ལོ་བསྐོར་བར་སེམས་བསྐྱེད།</span></li><li class="italic">satata­dharma­cakra­pravarta­cittotpada</li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign break text-sa" lang="sa-LATN">Dharma­cakra­pravarta­cittotpada</em>; <em class="foreign text-wy" lang="bo-LATN">chos kyi ’khor lo yongs su bskor bar sems bskyed</em>)</p></div></div></div></div><div id="b0f25636-a93c-40c2-824c-aeb9d1aa263a" class="relative scroll-mt-20"><button type="button" id="radix-_R_8at5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.43</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">asura</div><ul class="ml-4 list-disc"><li class="italic">lha ma yin</li><li class="pt-1"><span class="font-tibetan text-base">ལྷ་མ་ཡིན།</span></li><li class="italic">asura</li></ul><div class="glossary-instance-definition"><p class="definition">A type of nonhuman being whose precise status is subject to different views, but is included as one of the six classes of beings in the sixfold classification of realms of rebirth. In the Buddhist context, asuras are powerful beings said to be dominated by envy, ambition, and hostility. They are also known in the pre-Buddhist and pre-Vedic mythologies of India and Iran, and feature prominently in Vedic and post-Vedic Brahmanical mythology, as well as in the Buddhist tradition. In these traditions, asuras are often described as being engaged in interminable conflict with the devas (gods).</p></div></div></div></div><div id="e402ebc0-1717-4674-83d1-8e2ba3924cd3" class="relative scroll-mt-20"><button type="button" id="radix-_R_8b55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.44</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Aśvajit</div><ul class="ml-4 list-disc"><li class="italic">rta thul</li><li class="pt-1"><span class="font-tibetan text-base">རྟ་ཐུལ།</span></li><li class="italic">aśvajit</li></ul><div class="glossary-instance-definition"><p class="definition">One of the five companions with whom Siddhārtha Gautama practiced asceticism near the Nairañjanā River and who later heard the Buddha first teach the four noble truths at the Deer Park in Sarnath. He was renowned for his pure conduct and holy demeanor, so the Buddha sent him to attract <span data-glossary-id="UT22084-089-013-2807">Śāriputra</span> and <span data-glossary-id="UT22084-089-013-2694">Maudgalyāyana</span> to the order.</p></div></div></div></div><div id="52a2dde9-c02f-46be-acb9-16ac92edb4f5" class="relative scroll-mt-20"><button type="button" id="radix-_R_8bd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.45</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Atapa, Atapas</div><ul class="ml-4 list-disc"><li class="italic">mi gdung ba</li><li class="pt-1"><span class="font-tibetan text-base">མི་གདུང་བ།</span></li><li class="italic">atapa</li></ul><div class="glossary-instance-definition"><p class="definition">This is the fourth highest of the five <span data-glossary-id="UT22084-089-013-2938">Śuddhāvāsa</span> paradises, the highest paradises in the form realm. In this sūtra it is the second highest. Here translated as meaning “Not Pained.” In other texts translated as <em class="foreign text-wy" lang="bo-LATN">ma dros pa</em> (“Not Warm”). </p></div></div></div></div><div id="b17621cd-27ac-4814-80ad-3051f765f3a6" class="relative scroll-mt-20"><button type="button" id="radix-_R_8bl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.46</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Aṭavika</div><ul class="ml-4 list-disc"><li class="italic">’brog gnas</li><li class="pt-1"><span class="font-tibetan text-base">འབྲོག་གནས།</span></li><li class="italic">aṭavika</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king.</p></div></div></div></div><div id="ad802bad-24c7-4602-97a2-38342cedf1d0" class="relative scroll-mt-20"><button type="button" id="radix-_R_8bt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.47</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Aṭavīsaṃbhavā</div><ul class="ml-4 list-disc"><li class="italic">’brog khong khong na yod</li><li class="pt-1"><span class="font-tibetan text-base">འབྲོག་ཁོང་ཁོང་ན་ཡོད།</span></li><li class="italic">aṭavīsaṃbhavā</li></ul><div class="glossary-instance-definition"><p class="definition">A lake in a wilderness.</p><p class="definition">(Toh 557: <em class="foreign text-wy" lang="bo-LATN">dgon pa na yod pa</em>)</p></div></div></div></div><div id="81980d17-eb3d-491a-8297-35881384bb0d" class="relative scroll-mt-20"><button type="button" id="radix-_R_8c55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.48</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Avalokiteśvara</div><ul class="ml-4 list-disc"><li class="italic">kun tu spyan ras gzigs dbang phyug</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་ཏུ་སྤྱན་རས་གཟིགས་དབང་ཕྱུག</span></li><li class="italic">avalokiteśvara</li></ul><div class="glossary-instance-definition"><p class="definition">First appeared as a bodhisattva beside <span data-glossary-id="UT22084-089-013-2606">Amitābha</span> in the <cite class="title break text-sa" lang="sa-LATN">Sukhāvatīvyūha Sūtra</cite> ( <cite class="title text-en" lang="en"><a target="_blank" href="https://read.84000.co/translation/toh115.html" title="The Display of the Pure Land of Sukhāvatī">The Display of the Pure Land of Sukhāvatī</a></cite> , Toh 115). The name has been variously interpreted. In its meaning as “the lord of avalokita,” <em class="distinct">avalokita</em> has been interpreted as “seeing,” although, as a past passive participle, it is literally “lord of what has been seen.” One of the principal sūtras in the Mahāsāṃghika tradition was the <cite class="title text-en" lang="en">Avalokita Sūtra</cite>, which has not been translated into Tibetan, in which the word is a synonym for enlightenment, as it is “that which has been seen” by the buddhas. In the early tantras, he was one of the lords of the three families, as the embodiment of the compassion of the Buddhas. The Potalaka Mountain in South India became important in Southern Indian Buddhism as his residence in this world, but Potalaka does not feature in the <cite class="title break text-sa" lang="sa-LATN">Kāraṇḍavyūha Sūtra</cite> ( <cite class="title text-en" lang="en"><a target="_blank" href="https://read.84000.co/translation/toh116" title="The Basket’s Display">The Basket’s Display</a></cite> , Toh 116), which is the most important sūtra dedicated to Avalokiteśvara.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">spyan ras gzigs</em>)</p></div></div></div></div><div id="930f3b45-48ca-4dec-8331-b2328ed8afcf" class="relative scroll-mt-20"><button type="button" id="radix-_R_8cd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.49</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Avalokiteśvarābhaya</div><ul class="ml-4 list-disc"><li class="italic">spyan ras gzigs dbang mi ’jigs pa</li><li class="pt-1"><span class="font-tibetan text-base">སྤྱན་རས་གཟིགས་དབང་མི་འཇིགས་པ།</span></li><li class="italic">avalokiteśvarābhaya</li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">rtog pa ’jigs med dbang phyug</em>)</p></div></div></div></div><div id="de6e8d0d-5083-4cbe-9fd1-01273dfb56e3" class="relative scroll-mt-20"><button type="button" id="radix-_R_8cl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.50</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Āyurveda</div><ul class="ml-4 list-disc"><li class="italic">tshe’i rig byed</li><li class="pt-1"><span class="font-tibetan text-base">ཚེའི་རིག་བྱེད།</span></li><li class="italic">āyurveda</li></ul><div class="glossary-instance-definition"><p class="definition">The classical system of Indian medicine.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">shes pa</em>)</p></div></div></div></div><div id="517c0c22-1b23-4872-84b1-a79c9a77450a" class="relative scroll-mt-20"><button type="button" id="radix-_R_8ct5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.51</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">bad karma with immediate result, five actions with immediate result upon death</div><ul class="ml-4 list-disc"><li class="italic">mtshams med pa lnga</li><li class="pt-1"><span class="font-tibetan text-base">མཚམས་མེད་པ་ལྔ།</span></li><li class="italic">pañcānantarya</li></ul><div class="glossary-instance-definition"><p class="definition">The five actions that lead to going instantly to hell upon death: killing one’s father; killing one’s mother; killing an <span data-glossary-id="UT22084-089-013-2437">arhat</span>; splitting the sangha; and wounding a buddha so that he bleeds.</p></div></div></div></div><div id="92e4b294-545f-4787-9f48-96c5abd3b932" class="relative scroll-mt-20"><button type="button" id="radix-_R_8d55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.52</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Balendraketu</div><ul class="ml-4 list-disc"><li class="italic">stobs kyi dbang po’i tog</li><li class="pt-1"><span class="font-tibetan text-base">སྟོབས་ཀྱི་དབང་པོའི་ཏོག</span></li><li class="italic">balendraketu</li></ul><div class="glossary-instance-definition"><p class="definition">A king in the distant past.</p></div></div></div></div><div id="424d07fe-e805-4e2a-96bd-a925f6e5195d" class="relative scroll-mt-20"><button type="button" id="radix-_R_8dd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.53</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bali</div><ul class="ml-4 list-disc"><li class="italic">stobs chen</li><li class="pt-1"><span class="font-tibetan text-base">སྟོབས་ཆེན།</span></li><li class="italic">bali</li></ul><div class="glossary-instance-definition"><p class="definition">An <span data-glossary-id="UT22084-089-013-2559">asura</span> king. Indian literary sources describe how Bali wrested control of the world from the <span data-glossary-id="UT22084-089-013-2471">devas</span>, establishing a period of peace and prosperity with no caste distinction. <span data-glossary-id="UT22084-089-013-2656">Indra</span> requested <span data-glossary-id="UT22084-089-013-2863">Viṣṇu</span> to use his wiles to gain back the world from him for the <span data-glossary-id="UT22084-089-013-2471">devas</span>. <span data-glossary-id="UT22084-089-013-2863">Viṣṇu</span> appeared as a dwarf asking for two steps of ground, was offered three, and then traversed the world in two steps. Bali, remaining faithful to his promise, accepted the banishment of the <span data-glossary-id="UT22084-089-013-2559">asuras</span> into the underworld. A great Bali festival in his honor is held annually in South India. </p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">ba li</em>)</p></div></div></div></div><div id="b35e3086-7f46-4af9-9250-b231fe0e92c5" class="relative scroll-mt-20"><button type="button" id="radix-_R_8dl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.54</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">bdellium</div><ul class="ml-4 list-disc"><li class="italic">gu gul ra sa</li><li class="pt-1"><span class="font-tibetan text-base">གུ་གུལ་ར་ས།</span></li><li class="italic">guggulurasa</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign">Commiphora wighti</em>, or <em class="foreign">Commiphora mukul</em>. The resin, also known as guggul gum, is obtained from the bark of the tree. When burned, the smoke is said to drive away evil spirits</p><p class="definition">(Nobel edition: <em class="foreign break text-sa" lang="sa-LATN">guggulu</em>. Toh 555: <em class="foreign text-wy" lang="bo-LATN">gu gul</em>.)</p></div></div></div></div><div id="11a27248-f816-4d5c-b4b3-5337a66680be" class="relative scroll-mt-20"><button type="button" id="radix-_R_8dt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.55</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Beautiful to See</div><ul class="ml-4 list-disc"><li class="italic">dga’ ba mthong ba</li><li class="pt-1"><span class="font-tibetan text-base">དགའ་བ་མཐོང་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2471">deva</span>.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">mthong na dga’ ba</em>)</p></div></div></div></div><div id="e62b8fa4-3316-40ef-bfbb-4e0bc985ce76" class="relative scroll-mt-20"><button type="button" id="radix-_R_8e55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.56</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">bezoar, cow bezoar</div><ul class="ml-4 list-disc"><li class="italic">gi wang, gi’u wang</li><li class="pt-1"><span class="font-tibetan text-base">གི་ཝང་།, གིའུ་ཝང་།</span></li><li class="italic">gorocanā</li></ul><div class="glossary-instance-definition"><p class="definition">Used in <span data-glossary-id="UT22084-089-013-2445">Āyurveda</span> for both external and oral application in treating worm infestation, pruritus (itching), psychiatric disorders, low digestion strength, and more.</p><p class="definition">(Bagchi: <em class="foreign break text-sa" lang="sa-LATN">samocaka</em>)</p></div></div></div></div><div id="a923b9d8-34d7-4119-83ae-131b7f92aa46" class="relative scroll-mt-20"><button type="button" id="radix-_R_8ed5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.57</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bhadrika</div><ul class="ml-4 list-disc"><li class="italic">bzang po</li><li class="pt-1"><span class="font-tibetan text-base">བཟང་པོ།</span></li><li class="italic">bhadrika</li></ul><div class="glossary-instance-definition"><p class="definition">One of Siddhārtha’s five ascetic companions, who abandoned him when he renounced asceticism. When those five later became the Buddha’s first disciples, Bhadrika was the second of them to convert.</p></div></div></div></div><div id="7317e301-9d9a-41ce-9424-338eceefcc6b" class="relative scroll-mt-20"><button type="button" id="radix-_R_8el5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.58</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bhagavat</div><ul class="ml-4 list-disc"><li class="italic">bcom ldan ’das</li><li class="pt-1"><span class="font-tibetan text-base">བཅོམ་ལྡན་འདས།</span></li><li class="italic">bhagavat</li></ul><div class="glossary-instance-definition"><p class="definition">In Buddhist literature, this is an epithet applied to buddhas, most often to Śākyamuni. The Sanskrit term generally means “possessing fortune,” but in specifically Buddhist contexts it implies that a buddha is in possession of six auspicious qualities (<em class="foreign break text-sa" lang="sa-LATN">bhaga</em>) associated with complete awakening. The Tibetan term‍—where <em class="foreign break text-sa" lang="sa-LATN">bcom</em> is said to refer to “subduing” the four māras, <em class="foreign break text-sa" lang="sa-LATN">ldan</em> to “possessing” the great qualities of buddhahood, and <em class="foreign break text-sa" lang="sa-LATN">’das</em> to “going beyond” saṃsāra and nirvāṇa‍—possibly reflects the commentarial tradition where the Sanskrit <em class="foreign break text-sa" lang="sa-LATN">bhagavat</em> is interpreted, in addition, as “one who destroys the four māras.” This is achieved either by reading <em class="foreign break text-sa" lang="sa-LATN">bhagavat</em> as <em class="foreign break text-sa" lang="sa-LATN">bhagnavat</em> (“one who broke”), or by tracing the word <em class="foreign break text-sa" lang="sa-LATN">bhaga</em> to the root <em class="foreign break text-sa" lang="sa-LATN">√bhañj</em> (“to break”).</p></div></div></div></div><div id="997183d3-1ea8-4e8b-bef3-c1c37f789035" class="relative scroll-mt-20"><button type="button" id="radix-_R_8et5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.59</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bhaiṣajyadatta</div><ul class="ml-4 list-disc"><li class="italic">sman sbyin</li><li class="pt-1"><span class="font-tibetan text-base">སྨན་སྦྱིན།</span></li><li class="italic">bhaiṣajyadatta</li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">sman gtong</em>)</p></div></div></div></div><div id="ee90db88-34b8-483b-bd56-b0758dbe6bc2" class="relative scroll-mt-20"><button type="button" id="radix-_R_8f55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.60</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bhaiṣajyarāja</div><ul class="ml-4 list-disc"><li class="italic">sman pa’i rgyal po</li><li class="pt-1"><span class="font-tibetan text-base">སྨན་པའི་རྒྱལ་པོ།</span></li><li class="italic">bhaiṣajyarāja</li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">sman gyi rgyal po</em>)</p></div></div></div></div><div id="2df871fe-c65d-44dc-b97a-47039046f128" class="relative scroll-mt-20"><button type="button" id="radix-_R_8fd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.61</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">bherī drum</div><ul class="ml-4 list-disc"><li class="italic">rnga</li><li class="pt-1"><span class="font-tibetan text-base">རྔ།</span></li><li class="italic">bherī</li></ul><div class="glossary-instance-definition"><p class="definition">As specified in the Sanskrit, a conical or bowl-shaped kettledrum, with an upper surface that is beaten with sticks. The Tibetan and Chinese are not specific about the kind of drum it is.</p></div></div></div></div><div id="5365d0e6-91d5-4ce8-8796-a14339d6e504" class="relative scroll-mt-20"><button type="button" id="radix-_R_8fl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.62</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">bhikṣu</div><ul class="ml-4 list-disc"><li class="italic">dge slong</li><li class="pt-1"><span class="font-tibetan text-base">དགེ་སློང་།</span></li><li class="italic">bhikṣu</li></ul><div class="glossary-instance-definition"><p class="definition">The term <em class="foreign break text-sa" lang="sa-LATN">bhikṣu</em>, often translated as “monk,” refers to the highest among the eight types of prātimokṣa vows that make one part of the Buddhist assembly. The Sanskrit term literally means “beggar” or “mendicant,” referring to the fact that Buddhist monks and nuns‍—like other ascetics of the time‍—subsisted on alms (<em class="foreign break text-sa" lang="sa-LATN">bhikṣā</em>) begged from the laity. </p><p class="definition">In the Tibetan tradition, which follows the Mūlasarvāstivāda Vinaya, a monk follows 253 rules as part of his moral discipline. A nun (<em class="foreign">bhikṣuṇī</em>; <em class="foreign">dge slong ma</em>) follows 364 rules. A novice monk (<em class="foreign">śrāmaṇera</em>; <em class="foreign">dge tshul</em>) or nun (<em class="foreign">śrāmaṇerikā</em>; <em class="foreign">dge tshul ma</em>) follows thirty-six rules of moral discipline (although in other vinaya traditions novices typically follow only ten).</p></div></div></div></div><div id="5eb1d3c8-b031-4dfa-99a2-a469f6a9f835" class="relative scroll-mt-20"><button type="button" id="radix-_R_8ft5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.63</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">bhikṣuṇī</div><ul class="ml-4 list-disc"><li class="italic">dge slong ma</li><li class="pt-1"><span class="font-tibetan text-base">དགེ་སློང་མ།</span></li><li class="italic">bhikṣuṇī</li></ul><div class="glossary-instance-definition"><p class="definition">The term <em class="foreign break text-sa" lang="sa-LATN">bhikṣuṇī</em>, often translated as “nun,” refers to the highest among the eight types of prātimokṣa vows that make one part of the Buddhist assembly. The Sanskrit term <em class="foreign break text-sa" lang="sa-LATN">bhikṣu</em> (to which the female grammatical ending <em class="foreign break text-sa" lang="sa-LATN">ṇī</em> is added) literally means “beggar” or “mendicant,” referring to the fact that Buddhist nuns and monks‍—like other ascetics of the time‍—subsisted on alms (<em class="foreign break text-sa" lang="sa-LATN">bhikṣā</em>) begged from the laity. In the Tibetan tradition, which follows the Mūlasarvāstivāda Vinaya, a bhikṣuṇī follows 364 rules and a bhikṣu follows 253 rules as part of their moral discipline.</p><p class="definition">For the first few years of the Buddha’s teachings in India, there was no ordination for women. It started at the persistent request and display of determination of Mahāprajāpatī, the Buddha’s stepmother and aunt, together with five hundred former wives of men of Kapilavastu, who had themselves become monks. Mahāprajāpatī is thus considered to be the founder of the nun’s order.</p></div></div></div></div><div id="b699c0ca-caa4-48ce-abf0-acb0ff7f4361" class="relative scroll-mt-20"><button type="button" id="radix-_R_8g55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.64</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bhṛkuṭi</div><ul class="ml-4 list-disc"><li class="italic">khro gnyer can</li><li class="pt-1"><span class="font-tibetan text-base">ཁྲོ་གཉེར་ཅན།</span></li><li class="italic">bhṛkuṭi</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span>.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">khro gnyer</em>)</p></div></div></div></div><div id="ff1e1864-2411-4b97-a56d-bfd1b395dc48" class="relative scroll-mt-20"><button type="button" id="radix-_R_8gd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.65</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">bhūmi</div><ul class="ml-4 list-disc"><li class="italic">sa</li><li class="pt-1"><span class="font-tibetan text-base">ས།</span></li><li class="italic">bhūmi</li></ul><div class="glossary-instance-definition"><p class="definition">Literally the “grounds” in which qualities grow, and also meaning “levels.” Here it refers specifically to levels of enlightenment, especially the ten levels of the bodhisattvas.</p></div></div></div></div><div id="c3880ffb-0adb-41fa-82e1-09cee7cf6931" class="relative scroll-mt-20"><button type="button" id="radix-_R_8gl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.66</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bhūmikampa</div><ul class="ml-4 list-disc"><li class="italic">sa g.yo byed</li><li class="pt-1"><span class="font-tibetan text-base">ས་གཡོ་བྱེད།</span></li><li class="italic">bhūmikampa</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span>.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">sa kun g.yo ba</em>)</p></div></div></div></div><div id="1eef92ba-9f79-4834-8bda-da998d34f1f6" class="relative scroll-mt-20"><button type="button" id="radix-_R_8gt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.67</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">bimba</div><ul class="ml-4 list-disc"><li class="italic">bim pa</li><li class="pt-1"><span class="font-tibetan text-base">བིམ་པ།</span></li><li class="italic">bimba, bimbā</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign">Momordica monadelpha</em>. A perennial climbing plant, the fruit of which is a bright red gourd. Because of its color it is frequently used in poetry as a simile for lips. </p></div></div></div></div><div id="7b3f5ea0-4ec8-45e4-9122-240166249a66" class="relative scroll-mt-20"><button type="button" id="radix-_R_8h55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.68</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">black stone flower</div><ul class="ml-4 list-disc"><li class="italic">rdo dreg lo ma</li><li class="pt-1"><span class="font-tibetan text-base">རྡོ་དྲེག་ལོ་མ།</span></li><li class="italic">patraśaileya</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign">Parmelia perlata</em>. A lichen used as a spice and in <span data-glossary-id="UT22084-089-013-2445">Āyurveda</span> for the treatment of skin diseases, cough, asthma, kidney stones, painful urination, and localized swelling. Commonly called <em class="foreign break text-sa" lang="sa-LATN">śaileya</em> in Sanskrit.</p><p class="definition">Emmerick, based on the Nobel edition, separates the compound into two: <em class="foreign break text-sa" lang="sa-LATN">patra</em> (leaf) and <em class="foreign break text-sa" lang="sa-LATN">śaileya</em>. Toh 555: <em class="foreign text-wy" lang="bo-LATN">spra ba</em>.</p></div></div></div></div><div id="2a349391-f527-4ccd-b584-fcc7ec612dc6" class="relative scroll-mt-20"><button type="button" id="radix-_R_8hd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.69</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">blue jaybird</div><ul class="ml-4 list-disc"><li class="italic">tsa sha</li><li class="pt-1"><span class="font-tibetan text-base">ཙ་ཤ།</span></li><li class="italic">cāṣa</li></ul><div class="glossary-instance-definition"><p class="definition">More commonly known as the Indian roller (<em class="foreign">Coracias benghalensis</em>). </p></div></div></div></div><div id="2b1b14a2-798d-412c-91f2-0acb6ed6485b" class="relative scroll-mt-20"><button type="button" id="radix-_R_8hl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.70</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bodhimaṇḍa</div><ul class="ml-4 list-disc"><li class="italic">byang chub kyi snying po</li><li class="pt-1"><span class="font-tibetan text-base">བྱང་ཆུབ་ཀྱི་སྙིང་པོ།</span></li><li class="italic">bodhimaṇḍa</li></ul><div class="glossary-instance-definition"><p class="definition">The place where the Buddha Śākyamuni achieved awakening and where every buddha will manifest the attainment of buddhahood. In our world this is understood to be located under the Bodhi tree, the Vajrāsana, in present-day Bodhgaya, India. It can also refer to the state of awakening itself.</p></div></div></div></div><div id="9e6bac79-d0f2-420a-a6d3-d452e261ba6b" class="relative scroll-mt-20"><button type="button" id="radix-_R_8ht5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.71</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bodhisattvasamuccayā</div><ul class="ml-4 list-disc"><li class="italic">byang chub yang dag par bsdus pa</li><li class="pt-1"><span class="font-tibetan text-base">བྱང་ཆུབ་ཡང་དག་པར་བསྡུས་པ།</span></li><li class="italic">Bodhi­sattva­samuccayā</li></ul><div class="glossary-instance-definition"><p class="definition">A goddess. In Toh 555 called “goddess of the Bodhi tree.”</p></div></div></div></div><div id="ef9c1ac5-e9a9-4aad-886d-0b0ddf8d8dde" class="relative scroll-mt-20"><button type="button" id="radix-_R_8i55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.72</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Brahmā, Brahmā devas</div><ul class="ml-4 list-disc"><li class="italic">tshangs pa, tshangs pa</li><li class="pt-1"><span class="font-tibetan text-base">ཚངས་པ།, ཚངས་པ།</span></li><li class="italic">brahmā, brahmā</li></ul><div class="glossary-instance-definition"><p class="definition">In addition to being the name of the great deity, “<span data-glossary-id="UT22084-089-013-2896">Brahmā</span>” (sometimes “<span data-glossary-id="UT22084-089-013-3270">Mahābrahmā</span>”) can mean all the <span data-glossary-id="UT22084-089-013-2471">devas</span> that live in <span data-glossary-id="UT22084-089-013-2896">Brahmā</span>’s paradise. </p></div></div></div></div><div id="0ea2394f-1cfc-4258-a798-9a6eb4c60b62" class="relative scroll-mt-20"><button type="button" id="radix-_R_8id5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.73</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Brahmā, Brahmā devas</div><ul class="ml-4 list-disc"><li class="italic">tshangs pa, tshangs pa</li><li class="pt-1"><span class="font-tibetan text-base">ཚངས་པ།, ཚངས་པ།</span></li><li class="italic">brahmā, brahmā</li></ul><div class="glossary-instance-definition"><p>A high-ranking deity presiding over a divine world; he is also considered to be the lord of the Sahā world (our universe). Though not considered a creator god in Buddhism, Brahmā occupies an important place as one of two gods (the other being Indra/Śakra) said to have first exhorted the Buddha Śākyamuni to teach the Dharma. The particular heavens found in the form realm over which Brahmā rules are often some of the most sought-after realms of higher rebirth in Buddhist literature. Since there are many universes or world systems, there are also multiple Brahmās presiding over them. His most frequent epithets are “Lord of the Sahā World” (<em class="foreign break text-sa" lang="sa-LATN">sahāṃpati</em>) and Great Brahmā (<em class="foreign break text-sa" lang="sa-LATN">mahābrahman</em>).</p></div></div></div></div><div id="39c0206c-a427-41a4-ba6d-22b392e81be5" class="relative scroll-mt-20"><button type="button" id="radix-_R_8il5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.74</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Brahmakāyika</div><ul class="ml-4 list-disc"><li class="italic">tshangs pa</li><li class="pt-1"><span class="font-tibetan text-base">ཚངས་པ།</span></li><li class="italic">brahmakāyika</li></ul><div class="glossary-instance-definition"><p class="definition">“<span data-glossary-id="UT22084-089-013-2896">Brahmā</span>’s Multitude.” The lowest of the three paradises that form the paradises of the first <span data-glossary-id="UT22084-089-013-2564">dhyāna</span> in the form realm. </p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">tshangs ris</em>)</p></div></div></div></div><div id="85498276-32f9-4681-8f01-aff944c61f89" class="relative scroll-mt-20"><button type="button" id="radix-_R_8it5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.75</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Brahma­pariṣadya</div><ul class="ml-4 list-disc"><li class="italic">tshangs pa’i rgyal ’khor</li><li class="pt-1"><span class="font-tibetan text-base">ཚངས་པའི་རྒྱལ་འཁོར།</span></li><li class="italic">brahma­pariṣadya</li></ul><div class="glossary-instance-definition"><p class="definition">“<span data-glossary-id="UT22084-089-013-2896">Brahmā</span>’s entourage.” In this sūtra the highest of the three paradises that correspond to the first <span data-glossary-id="UT22084-089-013-2564">dhyāna</span> in the form realm. </p></div></div></div></div><div id="1d7673b8-0bc8-4a28-95cd-7a8af20615f1" class="relative scroll-mt-20"><button type="button" id="radix-_R_8j55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.76</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Brahmapurohita</div><ul class="ml-4 list-disc"><li class="italic">tshangs chen mdun ’don</li><li class="pt-1"><span class="font-tibetan text-base">ཚངས་ཆེན་མདུན་འདོན།</span></li><li class="italic">brahmapurohita</li></ul><div class="glossary-instance-definition"><p class="definition">“<span data-glossary-id="UT22084-089-013-2896">Brahmā</span>’s Principals.” In the generally established cosmology, the second highest of the three paradises that correspond to the first <span data-glossary-id="UT22084-089-013-2564">dhyāna</span> in the form realm. Here it is the third highest with the addition of another <span data-glossary-id="UT22084-089-013-2896">Brahmā</span> paradise.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">tshangs pa’i mdun na ’don pa</em>)</p></div></div></div></div><div id="ff2493de-380b-4b95-af5d-fae406385fdc" class="relative scroll-mt-20"><button type="button" id="radix-_R_8jd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.77</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Brahmarāja</div><ul class="ml-4 list-disc"><li class="italic">tshangs pa’i rgyal po</li><li class="pt-1"><span class="font-tibetan text-base">ཚངས་པའི་རྒྱལ་པོ།</span></li><li class="italic">brahmarāja</li></ul><div class="glossary-instance-definition"><p class="definition">See “<span data-glossary-id="UT22084-089-013-2896">Brahmā</span>.”</p></div></div></div></div><div id="41a01c6c-e7cf-4689-b3bb-4cdb181c88b6" class="relative scroll-mt-20"><button type="button" id="radix-_R_8jl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.78</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">brahmin</div><ul class="ml-4 list-disc"><li class="italic">bram ze</li><li class="pt-1"><span class="font-tibetan text-base">བྲམ་ཟེ།</span></li><li class="italic">brāhmaṇa</li></ul><div class="glossary-instance-definition"><p class="definition">A member of the highest of the four castes in Indian society, which is closely associated with religious vocations.</p></div></div></div></div><div id="f6e28c1e-ca63-417e-b2ed-0ca5a353c7e5" class="relative scroll-mt-20"><button type="button" id="radix-_R_8jt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.79</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">branches of enlightenment</div><ul class="ml-4 list-disc"><li class="italic">byang chub yan lag</li><li class="pt-1"><span class="font-tibetan text-base">བྱང་ཆུབ་ཡན་ལག</span></li><li class="italic">bodhyaṅga</li></ul><div class="glossary-instance-definition"><p class="definition">The seven branches of enlightenment are mindfulness, analysis of phenomena, diligence, joy, tranquility, <span data-glossary-id="UT22084-089-013-2593">samādhi</span>, and equanimity.</p></div></div></div></div><div id="6998a02f-d349-4a81-94ca-0848aebce803" class="relative scroll-mt-20"><button type="button" id="radix-_R_8k55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.80</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bṛhatphala</div><ul class="ml-4 list-disc"><li class="italic">’bras bu che</li><li class="pt-1"><span class="font-tibetan text-base">འབྲས་བུ་ཆེ།</span></li><li class="italic">bṛhatphala</li></ul><div class="glossary-instance-definition"><p class="definition">In the Sarvāstivāda tradition, the highest of the three paradises that correspond to the fourth <span data-glossary-id="UT22084-089-013-2564">dhyāna</span> in the form realm.</p></div></div></div></div><div id="37f167ba-e5a2-46bc-a572-5195d9c77832" class="relative scroll-mt-20"><button type="button" id="radix-_R_8kd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.81</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Buddhapālita</div><ul class="ml-4 list-disc"><li class="italic">sangs rgyas skyong</li><li class="pt-1"><span class="font-tibetan text-base">སངས་རྒྱས་སྐྱོང་།</span></li><li class="italic">buddhapālita</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2496">Licchavī</span> youth.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">sangs rgyas skyabs</em>)</p></div></div></div></div><div id="4e6fc7b2-160e-4c57-bfa1-a6888da1bb02" class="relative scroll-mt-20"><button type="button" id="radix-_R_8kl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.82</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">caitya, cetiya, stūpa</div><ul class="ml-4 list-disc"><li class="italic">mchod rten, mchod rten</li><li class="pt-1"><span class="font-tibetan text-base">མཆོད་རྟེན།, མཆོད་རྟེན།</span></li><li class="italic">caitya, stūpa</li></ul><div class="glossary-instance-definition"><p class="definition">The Tibetan translates both <em class="foreign break text-sa" lang="sa-LATN">stūpa</em> and <em class="foreign break text-sa" lang="sa-LATN">caitya</em> with the same word, <em class="foreign text-wy" lang="bo-LATN">mchod rten</em>, meaning “basis” or “recipient” of “offerings” or “veneration.” Pali: <em class="foreign text-pi" lang="pi-LATN">cetiya</em>.</p><p class="definition">A caitya, although often synonymous with <em class="foreign break text-sa" lang="sa-LATN">stūpa</em>, can also refer to any site, sanctuary or shrine that is made for veneration, and may or may not contain relics.</p><p class="definition">A stūpa, literally “heap” or “mound,” is a mounded or circular structure usually containing relics of the Buddha or the masters of the past. It is considered to be a sacred object representing the awakened mind of a buddha, but the symbolism of the stūpa is complex, and its design varies throughout the Buddhist world. Stūpas continue to be erected today as objects of veneration and merit making. </p></div></div></div></div><div id="a554ea8c-d3e8-4db4-8f02-731bdd5078f8" class="relative scroll-mt-20"><button type="button" id="radix-_R_8kt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.83</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">caitya, cetiya, stūpa</div><ul class="ml-4 list-disc"><li class="italic">mchod rten, mchod rten</li><li class="pt-1"><span class="font-tibetan text-base">མཆོད་རྟེན།, མཆོད་རྟེན།</span></li><li class="italic">caitya, stūpa</li></ul><div class="glossary-instance-definition"><p class="definition">The Tibetan translates both <em class="foreign break text-sa" lang="sa-LATN">stūpa</em> and <em class="foreign break text-sa" lang="sa-LATN">caitya</em> with the same word, <em class="foreign text-wy" lang="bo-LATN">mchod rten</em>, meaning “basis” or “recipient” of “offerings” or “veneration.” Pali: <em class="foreign text-pi" lang="pi-LATN">cetiya</em>.</p><p class="definition">A caitya, although often synonymous with <em class="foreign break text-sa" lang="sa-LATN">stūpa</em>, can also refer to any site, sanctuary or shrine that is made for veneration, and may or may not contain relics.</p><p class="definition">A stūpa, literally “heap” or “mound,” is a mounded or circular structure usually containing relics of the Buddha or the masters of the past. It is considered to be a sacred object representing the awakened mind of a buddha, but the symbolism of the stūpa is complex, and its design varies throughout the Buddhist world. Stūpas continue to be erected today as objects of veneration and merit making. </p></div></div></div></div><div id="03f8cdba-1bb6-4bc4-b3c7-d42fedeb80fc" class="relative scroll-mt-20"><button type="button" id="radix-_R_8l55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.84</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Cakravāḍa</div><ul class="ml-4 list-disc"><li class="italic">khor yug</li><li class="pt-1"><span class="font-tibetan text-base">ཁོར་ཡུག</span></li><li class="italic">cakravāḍa</li></ul><div class="glossary-instance-definition"><p class="definition">“Circular Enclosure”; there are at least three interpretations of what this name refers to. In the <cite class="title text-en" lang="en">Kṣitigarbha Sūtra</cite> it is a mountain that contains the hells. In that case, it is equivalent to the Vaḍaba submarine mountain of fire, also said to be the entrance to the hells. More commonly, it is the name of the outer ring of mountains at the edge of the flat disk that is the world, with <span data-glossary-id="UT22084-089-013-2940">Sumeru</span> in the center. This is also equated with Vaḍaba, as it is the heat of the mountain range that evaporates the ocean so that it does not overflow. <span data-glossary-id="UT22084-089-013-3198">Jambudvīpa</span>, the world of humans, is in this sea to <span data-glossary-id="UT22084-089-013-2940">Sumeru</span>’s south. However, the term is also used to mean the entire disk, including <span data-glossary-id="UT22084-089-013-2940">Meru</span> and the paradises above it. An alternate form is Cakravāla.</p></div></div></div></div><div id="9953004c-5b0d-443b-9386-76c5aa37c286" class="relative scroll-mt-20"><button type="button" id="radix-_R_8ld5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.85</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">cakravartin</div><ul class="ml-4 list-disc"><li class="italic">khor los sgyur ba</li><li class="pt-1"><span class="font-tibetan text-base">ཁོར་ལོས་སྒྱུར་བ།</span></li><li class="italic">cakravartin</li></ul><div class="glossary-instance-definition"><p class="definition">An ideal monarch or emperor who, as the result of the merit accumulated in previous lifetimes, rules over a vast realm in accordance with the Dharma. Such a monarch is called a <em class="foreign break text-sa" lang="sa-LATN">cakravartin</em> because he bears a wheel (<em class="foreign break text-sa" lang="sa-LATN">cakra</em>) that rolls (<em class="foreign break text-sa" lang="sa-LATN">vartate</em>) across the earth, bringing all lands and kingdoms under his power. The cakravartin conquers his territory without causing harm, and his activity causes beings to enter the path of wholesome actions. According to Vasubandhu’s <cite class="title break text-sa" lang="sa-LATN">Abhidharmakośa</cite>, just as with the buddhas, only one cakravartin appears in a world system at any given time. They are likewise endowed with the thirty-two major marks of a great being (<em class="foreign break text-sa" lang="sa-LATN">mahāpuruṣalakṣaṇa</em>), but a cakravartin’s marks are outshined by those of a buddha. They possess seven precious objects: the wheel, the elephant, the horse, the wish-fulfilling gem, the queen, the general, and the minister. An illustrative passage about the cakravartin and his possessions can be found in <cite class="title text-en" lang="en">The Play in Full</cite> (Toh 95), <a target="_blank" href="https://read.84000.co/translation/toh95.html#UT22084-046-001-94" title="3.3">3.3</a>–<a target="_blank" href="https://read.84000.co/translation/toh95.html#UT22084-046-001-104" title="3.13">3.13</a>. </p><p class="definition">Vasubandhu lists four types of cakravartins: (1) the cakravartin with a golden wheel (<em class="foreign break text-sa" lang="sa-LATN">suvarṇacakravartin</em>) rules over four continents and is invited by lesser kings to be their ruler; (2) the cakravartin with a silver wheel (<em class="foreign break text-sa" lang="sa-LATN">rūpyacakravartin</em>) rules over three continents and his opponents submit to him as he approaches; (3) the cakravartin with a copper wheel (<em class="foreign break text-sa" lang="sa-LATN">tāmracakravartin</em>) rules over two continents and his opponents submit themselves after preparing for battle; and (4) the cakravartin with an iron wheel (<em class="foreign break text-sa" lang="sa-LATN">ayaścakravartin</em>) rules over one continent and his opponents submit themselves after brandishing weapons. </p></div></div></div></div><div id="83f5bfd8-cca1-4a1f-8b9b-933c62c531d5" class="relative scroll-mt-20"><button type="button" id="radix-_R_8ll5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.86</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">camphor</div><ul class="ml-4 list-disc"><li class="italic">ga bur</li><li class="pt-1"><span class="font-tibetan text-base">ག་བུར།</span></li><li class="italic">karpūra</li></ul><div class="glossary-instance-definition"><p class="definition">A substance derived from the wood of the Kapur tree (<em class="foreign">Dryobalanops aromatica</em>) and also from the unrelated camphor laurel (<em class="foreign">Cinnamomum camphora</em>). </p></div></div></div></div><div id="60e5e25f-dfc6-4957-a2b8-79862e890ce8" class="relative scroll-mt-20"><button type="button" id="radix-_R_8lt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.87</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Caṇḍā</div><ul class="ml-4 list-disc"><li class="italic">gdol pa mo</li><li class="pt-1"><span class="font-tibetan text-base">གདོལ་པ་མོ།</span></li><li class="italic">caṇḍā</li></ul><div class="glossary-instance-definition"><p class="definition">A fierce goddess.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">ma rungs pa</em>)</p></div></div></div></div><div id="7a1acb8d-370c-492b-a420-9e5bacd6c434" class="relative scroll-mt-20"><button type="button" id="radix-_R_8m55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.88</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">caṇḍāla</div><ul class="ml-4 list-disc"><li class="italic">gdol pa</li><li class="pt-1"><span class="font-tibetan text-base">གདོལ་པ།</span></li><li class="italic">caṇḍāla</li></ul><div class="glossary-instance-definition"><p class="definition">The lowest and most disparaged class of people within the caste system of ancient India, they fall outside of the caste system altogether due to their low rank in society.</p></div></div></div></div><div id="51ebf6c1-8c83-49b2-aff2-52417ab7ec82" class="relative scroll-mt-20"><button type="button" id="radix-_R_8md5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.89</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Caṇḍālikā</div><ul class="ml-4 list-disc"><li class="italic">gtum mo</li><li class="pt-1"><span class="font-tibetan text-base">གཏུམ་མོ།</span></li><li class="italic">caṇḍālikā</li></ul><div class="glossary-instance-definition"><p class="definition">A fierce goddess.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">gdug pa</em>)</p></div></div></div></div><div id="0043bcae-82a2-4dc5-8dcf-5a1b18e0d2d6" class="relative scroll-mt-20"><button type="button" id="radix-_R_8ml5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.90</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Candana</div><ul class="ml-4 list-disc"><li class="italic">tsan+dan</li><li class="pt-1"><span class="font-tibetan text-base">ཙནྡན།</span></li><li class="italic">candana</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king.</p></div></div></div></div><div id="a9886d5c-4958-42cc-8547-9d8f0c6d1992" class="relative scroll-mt-20"><button type="button" id="radix-_R_8mt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.91</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Caṇḍikā</div><ul class="ml-4 list-disc"><li class="italic">gtum mo</li><li class="pt-1"><span class="font-tibetan text-base">གཏུམ་མོ།</span></li><li class="italic">caṇḍikā</li></ul><div class="glossary-instance-definition"><p class="definition">A fierce goddess.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">lag na dbyug thogs</em>)</p></div></div></div></div><div id="dc9f5c38-74b6-4cb1-b330-bd98ea8189cf" class="relative scroll-mt-20"><button type="button" id="radix-_R_8n55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.92</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">cardamom</div><ul class="ml-4 list-disc"><li class="italic">sug smel</li><li class="pt-1"><span class="font-tibetan text-base">སུག་སྨེལ།</span></li><li class="italic">sūkṣmelā</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign">Elettria cardamomum</em>. A digestive medicine in <span data-glossary-id="UT22084-089-013-2445">Āyurveda</span>.</p><p class="definition">(Degé 557: <em class="foreign text-wy" lang="bo-LATN">smug smel</em>. Toh 555: <em class="foreign text-wy" lang="bo-LATN">su ki ma le</em>.)</p></div></div></div></div><div id="f73cdd6f-c91b-4939-ac45-a7d06babf99c" class="relative scroll-mt-20"><button type="button" id="radix-_R_8nd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.93</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Cāturmahā­rāja­kāyika</div><ul class="ml-4 list-disc"><li class="italic">rgyal chen bzhi’i ris</li><li class="pt-1"><span class="font-tibetan text-base">རྒྱལ་ཆེན་བཞིའི་རིས།</span></li><li class="italic">cāturmahā­rāja­kāyika</li></ul><div class="glossary-instance-definition"><p class="definition">One of the heavens of Buddhist cosmology, lowest among the six heavens of the desire realm (<em class="foreign">kāmadhātu</em>, <em class="foreign">’dod khams</em>). Dwelling place of the Four Great Kings (<em class="foreign">caturmahārāja</em>, <em class="foreign">rgyal chen bzhi</em>), traditionally located on a terrace of Sumeru, just below the Heaven of the Thirty-Three. Each cardinal direction is ruled by one of the Four Great Kings and inhabited by a different class of nonhuman beings as their subjects: in the east, Dhṛtarāṣṭra rules the gandharvas; in the south, Virūḍhaka rules the kumbhāṇḍas; in the west, Virūpākṣa rules the nāgas; and in the north, Vaiśravaṇa rules the yakṣas.</p></div></div></div></div><div id="6223d32c-0cca-447c-9411-0abfa0ed50d6" class="relative scroll-mt-20"><button type="button" id="radix-_R_8nl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.94</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Chagalapāda</div><ul class="ml-4 list-disc"><li class="italic">ra rkang</li><li class="pt-1"><span class="font-tibetan text-base">ར་རྐང་།</span></li><li class="italic">chagalapāda</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king.</p></div></div></div></div><div id="5ac7ccd7-439b-4654-8843-aed37b612482" class="relative scroll-mt-20"><button type="button" id="radix-_R_8nt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.95</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">chir pine rosin</div><ul class="ml-4 list-disc"><li class="italic">shi ri bi sta</li><li class="pt-1"><span class="font-tibetan text-base">ཤི་རི་བི་སྟ།</span></li><li class="italic">nīveṣṭaka, śrīveṣṭaka</li></ul><div class="glossary-instance-definition"><p class="definition">This is a product of the chir pine, also known as the long leaf pine: <em class="foreign">Pinus roxbhurghii</em> or <em class="foreign">Pinus longifolia</em>. It is used in Āyurvedic medicine. Also known in Sanskrit as <em class="foreign break text-sa" lang="sa-LATN">śrīveṣṭa</em>, which appears to be the version in the manuscript from which the Tibetan was transliterated.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">thang chu</em>.)</p></div></div></div></div><div id="51cfcf89-cd79-4ef3-9ff7-fc09b3fc1433" class="relative scroll-mt-20"><button type="button" id="radix-_R_8o55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.96</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">cinnamon</div><ul class="ml-4 list-disc"><li class="italic">shing tsha</li><li class="pt-1"><span class="font-tibetan text-base">ཤིང་ཚ།</span></li><li class="italic">tvaca</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign">Cinnamonum tamale</em>. Specifically, the Indian species of cinnamon, which has medicinal properties.</p></div></div></div></div><div id="eb20f3ae-f850-4295-b88f-77d622eecbb9" class="relative scroll-mt-20"><button type="button" id="radix-_R_8od5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.97</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Citrasena</div><ul class="ml-4 list-disc"><li class="italic">sna tshogs sde</li><li class="pt-1"><span class="font-tibetan text-base">སྣ་ཚོགས་སྡེ།</span></li><li class="italic">citrasena</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king.</p></div></div></div></div><div id="b3d5a0e8-79a4-40e4-9579-4fa540e5bf12" class="relative scroll-mt-20"><button type="button" id="radix-_R_8ol5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.98</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Cittaratnārcī, Ratnārcī</div><ul class="ml-4 list-disc"><li class="italic">rin chen ’od ’phro</li><li class="pt-1"><span class="font-tibetan text-base">རིན་ཆེན་འོད་འཕྲོ།</span></li><li class="italic">ratnārcī</li></ul><div class="glossary-instance-definition"><p class="definition">A goddess who later becomes the bodhisattva Cittaratnārcī.</p></div></div></div></div><div id="f00df407-dd9e-41d4-9e8b-b92b156f2a09" class="relative scroll-mt-20"><button type="button" id="radix-_R_8ot5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.99</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Clear Insight</div><ul class="ml-4 list-disc"><li class="italic">shes rab gsal</li><li class="pt-1"><span class="font-tibetan text-base">ཤེས་རབ་གསལ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2471">deva</span>.</p></div></div></div></div><div id="80e0d4f9-c1ea-4e78-b4aa-46d849e8efbf" class="relative scroll-mt-20"><button type="button" id="radix-_R_8p55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.100</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Completely Pure Moonlight Sign Renowned King</div><ul class="ml-4 list-disc"><li class="italic">zla ’od rnam dag grags pa’i tog gi rgyal po</li><li class="pt-1"><span class="font-tibetan text-base">ཟླ་འོད་རྣམ་དག་གྲགས་པའི་ཏོག་གི་རྒྱལ་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">rnam dag zla ba’i ’od zer mtshan grags rgyal po</em>)</p></div></div></div></div><div id="a3d8c9cc-f6cd-48a8-b5f8-b4effbc098af" class="relative scroll-mt-20"><button type="button" id="radix-_R_8pd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.101</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Conch Shell</div><ul class="ml-4 list-disc"><li class="italic">dung can</li><li class="pt-1"><span class="font-tibetan text-base">དུང་ཅན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A fierce goddess.</p><p class="definition">(Toh 556 Degé: <em class="foreign text-wy" lang="bo-LATN">dung can</em>. Toh 555: <em class="foreign text-wy" lang="bo-LATN">dung chen</em>. Toh 555 Narthang: <em class="foreign text-wy" lang="bo-LATN">rung chen</em>)</p></div></div></div></div><div id="c984dd02-88e2-4f00-a348-cf795744824f" class="relative scroll-mt-20"><button type="button" id="radix-_R_8pl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.102</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">confidence</div><ul class="ml-4 list-disc"><li class="italic">mi ’jigs pa</li><li class="pt-1"><span class="font-tibetan text-base">མི་འཇིགས་པ།</span></li><li class="italic">vaiśāradya</li></ul><div class="glossary-instance-definition"><p class="definition">See the “<span data-glossary-id="UT22084-089-013-3201">four confidences</span>.”</p></div></div></div></div><div id="bc0e600b-8310-4ed6-8b4f-6e7495ab723b" class="relative scroll-mt-20"><button type="button" id="radix-_R_8pt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.103</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Consumer of Burnt Offerings</div><ul class="ml-4 list-disc"><li class="italic">bsreg bya za</li><li class="pt-1"><span class="font-tibetan text-base">བསྲེག་བྱ་ཟ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">Another name for Agni, the god of fire.</p><p class="definition">(Toh 557: <em class="foreign text-wy" lang="bo-LATN">sbyin sreg za</em>)</p></div></div></div></div><div id="e7fafd8f-5a23-44ca-b982-c530fa90f8d9" class="relative scroll-mt-20"><button type="button" id="radix-_R_8q55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.104</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">contact</div><ul class="ml-4 list-disc"><li class="italic">reg pa</li><li class="pt-1"><span class="font-tibetan text-base">རེག་པ།</span></li><li class="italic">sparśa</li></ul><div class="glossary-instance-definition"><p class="definition">The sixth of the twelve links or phases of <span data-glossary-id="UT22084-089-013-2562">dependent origination</span>, which is the contact between the sensory consciousnesses and organs with sensory objects.</p></div></div></div></div><div id="a6137041-6685-4790-a1bf-98fe7720b26e" class="relative scroll-mt-20"><button type="button" id="radix-_R_8qd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.105</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">costus root</div><ul class="ml-4 list-disc"><li class="italic">ru rta</li><li class="pt-1"><span class="font-tibetan text-base">རུ་རྟ།</span></li><li class="italic">kuṣṭha</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign">Saussurea lappa</em>. This is a 3–4-foot-tall shrub. Alternatively identified as <em class="foreign">Saussurea costus</em> and <em class="foreign">Costus speciosus</em>.</p><p class="definition">(Bagchi edition: <em class="foreign break text-sa" lang="sa-LATN">turuṣka</em>)</p></div></div></div></div><div id="9fa15c72-a6ef-433c-b817-da97a403cf09" class="relative scroll-mt-20"><button type="button" id="radix-_R_8ql5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.106</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Courageous Established Intention</div><ul class="ml-4 list-disc"><li class="italic">spobs pas bkod par dgongs pa</li><li class="pt-1"><span class="font-tibetan text-base">སྤོབས་པས་བཀོད་པར་དགོངས་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">spobs rab dgongs</em>)</p></div></div></div></div><div id="526737ed-20ae-4c3b-a4c5-17675082f5dd" class="relative scroll-mt-20"><button type="button" id="radix-_R_8qt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.107</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">crepe ginger</div><ul class="ml-4 list-disc"><li class="italic">dz+ha ma</li><li class="pt-1"><span class="font-tibetan text-base">ཛྷ་མ།</span></li><li class="italic">vyāmaka</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign">Cheilocostus speciosus</em>. This rhizome is used in Āyurvedic medicine to treat fever, rash, asthma, bronchitis, and intestinal worms.</p></div></div></div></div><div id="1d1c2898-dbc2-4207-917a-5a890db7df77" class="relative scroll-mt-20"><button type="button" id="radix-_R_8r55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.108</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Curing Affliction, Remover of Affliction</div><ul class="ml-4 list-disc"><li class="italic">nyon mongs nad sel, nyon mongs nad sel</li><li class="pt-1"><span class="font-tibetan text-base">ཉོན་མོངས་ནད་སེལ།, ཉོན་མོངས་ནད་སེལ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2471">deva</span>.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">nyon mongs pa yongs su spangs pa</em>; Degé Toh 556: <em class="foreign text-wy" lang="bo-LATN">nyong mongs nad sel</em>)</p></div></div></div></div><div id="37d938d2-8b9e-4c2b-99c3-3e87e5e836c3" class="relative scroll-mt-20"><button type="button" id="radix-_R_8rd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.109</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Curing Affliction, Remover of Affliction</div><ul class="ml-4 list-disc"><li class="italic">nyon mongs nad sel, nyon mongs nad sel</li><li class="pt-1"><span class="font-tibetan text-base">ཉོན་མོངས་ནད་སེལ།, ཉོན་མོངས་ནད་སེལ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">nyon mongs pa’i nad rnam par sel ba</em>)</p></div></div></div></div><div id="ca16fc7e-12ae-457f-aebb-fffa56c8654a" class="relative scroll-mt-20"><button type="button" id="radix-_R_8rl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.110</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">dammar gum</div><ul class="ml-4 list-disc"><li class="italic">sra rtsi</li><li class="pt-1"><span class="font-tibetan text-base">སྲ་རྩི།</span></li><li class="italic">sarjarasa</li></ul><div class="glossary-instance-definition"><p class="definition">A resin from the tree known as sarjarasa, sarja, white dammar, or Indian copal tree (<em class="foreign">Vateria indica</em>). The white dammar resin is used in incense and Āyurvedic medicine.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">sa rdza ra sa</em>.)</p></div></div></div></div><div id="eb798991-a7c3-403d-9071-323b1dd8f1cf" class="relative scroll-mt-20"><button type="button" id="radix-_R_8rt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.111</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Daṇḍapāṇi</div><ul class="ml-4 list-disc"><li class="italic">lag na be con</li><li class="pt-1"><span class="font-tibetan text-base">ལག་ན་བེ་ཅོན།</span></li><li class="italic">daṇḍapāṇi</li></ul><div class="glossary-instance-definition"><p class="definition">This is the Śākya Daṇḍapāṇi who, in the <cite class="title break text-sa" lang="sa-LATN">Lalitavistara Sūtra</cite> (<cite class="title text-en" lang="en"><a target="_blank" href="https://read.84000.co/translation/toh95.html" title="The Play in Full">The Play in Full</a></cite>), is described as the father of <span data-glossary-id="UT22084-089-013-2895">Gopā</span>, the Buddha’s wife. There are others of that name, such as the brother of the Buddha’s mother, <span><span data-glossary-id="UT22084-089-013-2742">Māyā</span></span>, and also the uncle of the Buddha’s other wife, Yaśodharā. However, that Daṇḍapāṇi was a member of the neighboring Koliya clan. There is also a contrasting account of a Śākya Daṇḍapāṇi who is said to have been a follower of Devadatta and who was dissatisfied by the Buddha’s answers when he met him in Kapilavastu, the capital of the Śākya clan. His nickname, “Cane Holder,” is said to be because he always carried a golden cane.</p></div></div></div></div><div id="f8703e2c-28d1-4072-87d5-c8898004245d" class="relative scroll-mt-20"><button type="button" id="radix-_R_8s55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.112</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">defilements</div><ul class="ml-4 list-disc"><li class="italic">zag pa</li><li class="pt-1"><span class="font-tibetan text-base">ཟག་པ།</span></li><li class="italic">āsrava, āśrava</li></ul><div class="glossary-instance-definition"><p class="definition">Literally, “to flow” or “to ooze.” Mental defilements or contaminations that “flow out” toward the objects of cyclic existence, binding us to them. Vasubandhu offers two alternative explanations of this term: “They cause beings to remain (<em class="foreign">āsayanti</em>) within saṃsāra” and “They flow from the Summit of Existence down to the Avīci hell, out of the six wounds that are the sense fields” (<cite class="title">Abhidharma­kośa­bhāṣya</cite> 5.40; Pradhan 1967, p. 308). The Summit of Existence (<em class="foreign break text-sa" lang="sa-LATN">bhavāgra</em>, <em class="foreign text-wy" lang="bo-LATN">srid pa’i rtse mo</em>) is the highest point within saṃsāra, while the hell called Avīci (<em class="foreign text-wy" lang="bo-LATN">mnar med</em>) is the lowest; the six sense fields (<em class="foreign break text-sa" lang="sa-LATN">āyatana</em>, <em class="foreign text-wy" lang="bo-LATN">skye mched</em>) here refer to the five sense faculties plus the mind, i.e., the six internal sense fields.</p></div></div></div></div><div id="2dd55171-519a-484c-a429-7a83bfef6390" class="relative scroll-mt-20"><button type="button" id="radix-_R_8sd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.113</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">dependent</div><ul class="ml-4 list-disc"><li class="italic">gzhan dbang</li><li class="pt-1"><span class="font-tibetan text-base">གཞན་དབང་།</span></li><li class="italic">paratantra</li></ul><div class="glossary-instance-definition"><p class="definition">This refers to the dependent nature of phenomena. One of the three natures that are a central philosophy of the Yogācāra tradition.</p></div></div></div></div><div id="59767f12-0e96-4bb4-8975-ba7b9a279e86" class="relative scroll-mt-20"><button type="button" id="radix-_R_8sl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.114</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">dependent origination</div><ul class="ml-4 list-disc"><li class="italic">rten cing ’brel par ’byung ba</li><li class="pt-1"><span class="font-tibetan text-base">རྟེན་ཅིང་འབྲེལ་པར་འབྱུང་བ།</span></li><li class="italic">pratītyasamutpāda</li></ul><div class="glossary-instance-definition"><p class="definition">See “<span data-glossary-id="UT22084-089-013-3213">twelve phases of dependent origination</span>.”</p></div></div></div></div><div id="a09787ca-2952-4bf6-a04c-bde6f4cf3e40" class="relative scroll-mt-20"><button type="button" id="radix-_R_8st5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.115</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">deva</div><ul class="ml-4 list-disc"><li class="italic">lha</li><li class="pt-1"><span class="font-tibetan text-base">ལྷ།</span></li><li class="italic">deva</li></ul><div class="glossary-instance-definition"><p class="definition">In the most general sense the devas‍—the term is cognate with the English <em class="emph">divine</em>‍—are a class of celestial beings who frequently appear in Buddhist texts, often at the head of the assemblies of nonhuman beings who attend and celebrate the teachings of the Buddha Śākyamuni and other buddhas and bodhisattvas. In Buddhist cosmology the devas occupy the highest of the five or six “destinies” (<em class="foreign break text-sa" lang="sa-LATN">gati</em>) of saṃsāra among which beings take rebirth. The devas reside in the <em class="foreign break text-sa" lang="sa-LATN">devalokas</em>, “heavens” that traditionally number between twenty-six and twenty-eight and are divided between the desire realm (<em class="foreign break text-sa" lang="sa-LATN">kāmadhātu</em>), form realm (<em class="foreign break text-sa" lang="sa-LATN">rūpadhātu</em>), and formless realm (<em class="foreign break text-sa" lang="sa-LATN">ārūpyadhātu</em>). A being attains rebirth among the devas either through meritorious deeds (in the desire realm) or the attainment of subtle meditative states (in the form and formless realms). While rebirth among the devas is considered favorable, it is ultimately a transitory state from which beings will fall when the conditions that lead to rebirth there are exhausted. Thus, rebirth in the god realms is regarded as a diversion from the spiritual path. </p></div></div></div></div><div id="79869af1-9ffa-45e1-9ef0-f5da257c2883" class="relative scroll-mt-20"><button type="button" id="radix-_R_8t55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.116</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">devī</div><ul class="ml-4 list-disc"><li class="italic">lha mo</li><li class="pt-1"><span class="font-tibetan text-base">ལྷ་མོ།</span></li><li class="italic">devī</li></ul><div class="glossary-instance-definition"><p class="definition">A female being in the paradises from the base of Mount <span data-glossary-id="UT22084-089-013-2940">Sumeru</span> upward. Also can refer to a female deity or goddess in the human world. See also “<span data-glossary-id="UT22084-089-013-2471">deva</span>.”</p></div></div></div></div><div id="c161a89c-8874-435b-a0cf-5dda3a665750" class="relative scroll-mt-20"><button type="button" id="radix-_R_8td5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.117</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">dhāraṇī, retention</div><ul class="ml-4 list-disc"><li class="italic">gzungs, gzungs, gzungs sngags</li><li class="pt-1"><span class="font-tibetan text-base">གཟུངས་སྔགས།, གཟུངས།, གཟུངས།</span></li><li class="italic">dhāraṇī, dhāraṇī</li></ul><div class="glossary-instance-definition"><p class="definition">The term <em class="foreign break text-sa" lang="sa-LATN">dhāraṇī</em> has the sense of something that “holds” or “retains,” and so it can refer to the special capacity of practitioners to memorize and recall detailed teachings. It can also refer to a verbal expression of the teachings‍—an incantation, spell, or mnemonic formula‍—that distills and “holds” essential points of the Dharma and is used by practitioners to attain mundane and supramundane goals. The same term is also used to denote texts that contain such formulas.</p></div></div></div></div><div id="46efeb6b-88fc-404c-a409-46b148a31cf0" class="relative scroll-mt-20"><button type="button" id="radix-_R_8tl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.118</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">dhāraṇī, retention</div><ul class="ml-4 list-disc"><li class="italic">gzungs, gzungs, gzungs sngags</li><li class="pt-1"><span class="font-tibetan text-base">གཟུངས་སྔགས།, གཟུངས།, གཟུངས།</span></li><li class="italic">dhāraṇī, dhāraṇī</li></ul><div class="glossary-instance-definition"><p class="definition">An exceptional power of mental retention. The term <span data-glossary-id="UT22084-089-013-2472">dhāraṇī</span> has the sense of something that “holds” or “retains,” and it can also refer to a verbal expression of the teachings‍—an incantation, spell, or mnemonic formula that distills and “holds” essential points of the Dharma and is used by practitioners to attain mundane and supramundane goals.</p></div></div></div></div><div id="5256ac41-c3df-43dd-8601-ded0a94fe9a5" class="relative scroll-mt-20"><button type="button" id="radix-_R_8tt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.119</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dharaṇīśvararāja</div><ul class="ml-4 list-disc"><li class="italic">gzungs kyi dbang phyug rgyal po</li><li class="pt-1"><span class="font-tibetan text-base">གཟུངས་ཀྱི་དབང་ཕྱུག་རྒྱལ་པོ།</span></li><li class="italic">dharaṇīśvararāja</li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p></div></div></div></div><div id="0a6167f8-dde3-4a27-9610-5a006a6f7516" class="relative scroll-mt-20"><button type="button" id="radix-_R_8u55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.120</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dharma body</div><ul class="ml-4 list-disc"><li class="italic">chos kyi sku</li><li class="pt-1"><span class="font-tibetan text-base">ཆོས་ཀྱི་སྐུ།</span></li><li class="italic">dharmakāya</li></ul><div class="glossary-instance-definition"><p class="definition">In its earliest use it generally meant that though the corporeal body of the Buddha had perished, his “body of the Dharma” continued. It also referred to the Buddha’s realization of reality, to his qualities as a whole, or to his teachings as embodying him. It later came to be synonymous with enlightenment or buddhahood, a “body” that can only be “seen” by a buddha.</p></div></div></div></div><div id="0bb9956b-39a4-4769-a0f3-f1ae1a69f236" class="relative scroll-mt-20"><button type="button" id="radix-_R_8ud5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.121</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dharma realm</div><ul class="ml-4 list-disc"><li class="italic">chos kyi dbyings</li><li class="pt-1"><span class="font-tibetan text-base">ཆོས་ཀྱི་དབྱིངས།</span></li><li class="italic">dharmadhātu</li></ul><div class="glossary-instance-definition"><p class="definition">A synonym for the ultimate nature of reality. The term is interpreted variously and can be translated according to context as “Dharma realm,” “Dharma element,” “the realm of phenomena,” or “the element of phenomena.”</p></div></div></div></div><div id="adee8b8e-5c28-4af7-ad3a-7a092cacba74" class="relative scroll-mt-20"><button type="button" id="radix-_R_8ul5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.122</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">dharmabhāṇaka</div><ul class="ml-4 list-disc"><li class="italic">chos smra ba</li><li class="pt-1"><span class="font-tibetan text-base">ཆོས་སྨྲ་བ།</span></li><li class="italic">dharmabhāṇaka</li></ul><div class="glossary-instance-definition"><p>Speaker or reciter of scriptures. In early Buddhism a section of the saṅgha would consist of <em class="foreign break text-sa" lang="sa-LATN">bhāṇakas</em>, who, particularly before the teachings were written down and were only transmitted orally, were a key factor in the preservation of the teachings. Various groups of dharmabhāṇakas specialized in memorizing and reciting a certain set of sūtras or vinaya.</p></div></div></div></div><div id="9fda5726-1115-4887-a239-7573df656507" class="relative scroll-mt-20"><button type="button" id="radix-_R_8ut5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.123</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dharmadatta</div><ul class="ml-4 list-disc"><li class="italic">chos sbyin</li><li class="pt-1"><span class="font-tibetan text-base">ཆོས་སྦྱིན།</span></li><li class="italic">dharmadatta</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2496">Licchavī</span> youth.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">chos byin</em>)</p></div></div></div></div><div id="2bfb32d5-be96-448f-959c-22c20746d8e5" class="relative scroll-mt-20"><button type="button" id="radix-_R_8v55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.124</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dharmadhvaja</div><ul class="ml-4 list-disc"><li class="italic">chos kyi rgyal mtshan</li><li class="pt-1"><span class="font-tibetan text-base">ཆོས་ཀྱི་རྒྱལ་མཚན།</span></li><li class="italic">dharmadhvaja</li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p></div></div></div></div><div id="7601da1e-595f-4cac-b032-f25da4ba4d4e" class="relative scroll-mt-20"><button type="button" id="radix-_R_8vd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.125</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dharmapāla</div><ul class="ml-4 list-disc"><li class="italic">chos skyong</li><li class="pt-1"><span class="font-tibetan text-base">ཆོས་སྐྱོང་།</span></li><li class="italic">dharmapāla</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2496">Licchavī</span> youth.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">chos skyabs</em>)</p></div></div></div></div><div id="1cd2a4c8-2b35-4488-be93-2d0f242583fc" class="relative scroll-mt-20"><button type="button" id="radix-_R_8vl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.126</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dharmodgata</div><ul class="ml-4 list-disc"><li class="italic">chos ’phags</li><li class="pt-1"><span class="font-tibetan text-base">ཆོས་འཕགས།</span></li><li class="italic">dharmodgata</li></ul><div class="glossary-instance-definition"><p class="definition">A great bodhisattva, residing in a divine city called Gandhavatī, who teaches the Prajñāpāramitā three times a day. He is known for becoming the <span>teacher</span> of the bodhisattva Sadāprarudita, who decides to sell his flesh and blood in order to make offerings to him and receive his teachings. This story is told in <cite class="title text-en" lang="en"><a target="_blank" href="https://read.84000.co/translation/toh10.html" title="The Perfection of Wisdom in Eighteen Thousand Lines">The Perfection of Wisdom in Eighteen Thousand Lines</a></cite> (Toh 10, ch. 85–86). It can also be found quoted in several works, such as <cite class="title text-en" lang="en">The Words of My Perfect Teacher</cite> (<cite class="title text-wy" lang="bo-LATN">kun bzang bla ma’i zhal lung</cite>) by Patrul Rinpoche.</p></div></div></div></div><div id="c0b79d0f-260a-4af7-b74a-a62f42950334" class="relative scroll-mt-20"><button type="button" id="radix-_R_8vt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.127</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">dhātu</div><ul class="ml-4 list-disc"><li class="italic">khams</li><li class="pt-1"><span class="font-tibetan text-base">ཁམས།</span></li><li class="italic">dhātu</li></ul><div class="glossary-instance-definition"><p class="definition">One way of describing experience and the world in terms of eighteen elements (eye and form, ear and sound, nose and smell, tongue and taste, body and physical objects, and mind and mental phenomena, to which the six consciousnesses are added). Also refers here to the four elements of earth, water, fire, and wind.</p></div></div></div></div><div id="34ee7b74-4c29-427c-b1cc-73098c8a2964" class="relative scroll-mt-20"><button type="button" id="radix-_R_9055anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.128</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dhṛtarāṣṭra</div><ul class="ml-4 list-disc"><li class="italic">yul ’khor srung</li><li class="pt-1"><span class="font-tibetan text-base">ཡུལ་འཁོར་སྲུང་།</span></li><li class="italic">dhṛtarāṣṭra</li></ul><div class="glossary-instance-definition"><p class="definition">One of the <span data-glossary-id="UT22084-089-013-2867">Four Mahārājas</span>, he is the guardian deity for the east and lord of the <span data-glossary-id="UT22084-089-013-2486">gandharvas</span>.</p></div></div></div></div><div id="7df1427c-236b-4443-b0e5-2a5da6419026" class="relative scroll-mt-20"><button type="button" id="radix-_R_90d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.129</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">dhyāna</div><ul class="ml-4 list-disc"><li class="italic">bsam gtan</li><li class="pt-1"><span class="font-tibetan text-base">བསམ་གཏན།</span></li><li class="italic">dhyāna</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign break text-sa" lang="sa-LATN">Dhyāna</em> is defined as one-pointed abiding in an undistracted state of mind, free from afflicted mental states. Four states of <em class="foreign break text-sa" lang="sa-LATN">dhyāna</em> are identified as being conducive to birth within the form realm. In the context of the Mahāyāna, it is the fifth of the six perfections. It is commonly translated as “concentration,” “meditative concentration,” and so on.</p></div></div></div></div><div id="1cd15e37-74a4-4aba-9a5f-404c78034ff1" class="relative scroll-mt-20"><button type="button" id="radix-_R_90l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.130</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Difficult to Conquer King of Radiance</div><ul class="ml-4 list-disc"><li class="italic">rgyal bar dka’ ba’i ’od kyi rgyal po</li><li class="pt-1"><span class="font-tibetan text-base">རྒྱལ་བར་དཀའ་བའི་འོད་ཀྱི་རྒྱལ་པོ།</span></li><li class="italic">durjayaprabharāja</li></ul><div class="glossary-instance-definition"><p class="definition">The name of an <span data-glossary-id="UT22084-089-013-2480">eon</span>. </p></div></div></div></div><div id="b4f56932-04e1-4e0c-90a5-533402ff3330" class="relative scroll-mt-20"><button type="button" id="radix-_R_90t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.131</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dravidian</div><ul class="ml-4 list-disc"><li class="italic">drA bi Da</li><li class="pt-1"><span class="font-tibetan text-base">དྲཱ་བི་ཌ།</span></li><li class="italic">drāviḍa</li></ul><div class="glossary-instance-definition"><p class="definition">A designation used for a group of languages spoken in the south of India, including Telugu, Kannada, Malayalam, and Tamil.</p></div></div></div></div><div id="61a9d519-40bc-47f2-8204-a84f6ee5ef65" class="relative scroll-mt-20"><button type="button" id="radix-_R_9155anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.132</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dṛḍhā</div><ul class="ml-4 list-disc"><li class="italic">brtan ma</li><li class="pt-1"><span class="font-tibetan text-base">བརྟན་མ།</span></li><li class="italic">dṛḍhā</li></ul><div class="glossary-instance-definition"><p class="definition">The goddess of the earth.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">sra ba</em>)</p></div></div></div></div><div id="49c93315-1451-4874-87c0-974a619ab4e8" class="relative scroll-mt-20"><button type="button" id="radix-_R_91d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.133</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dundubhisvara</div><ul class="ml-4 list-disc"><li class="italic">rnga sgra</li><li class="pt-1"><span class="font-tibetan text-base">རྔ་སྒྲ།</span></li><li class="italic">dundubhisvara</li></ul><div class="glossary-instance-definition"><p class="definition">The principal buddha of the northern direction.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">rnga sgra skyabs</em>)</p></div></div></div></div><div id="df742301-a2f1-43ee-ab72-6150dc202923" class="relative scroll-mt-20"><button type="button" id="radix-_R_91l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.134</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">eight liberations</div><ul class="ml-4 list-disc"><li class="italic">rnam par grol ba brgyad</li><li class="pt-1"><span class="font-tibetan text-base">རྣམ་པར་གྲོལ་བ་བརྒྱད།</span></li><li class="italic">aṣṭavimokṣa</li></ul><div class="glossary-instance-definition"><p class="definition">A series of progressively more subtle states of meditative realization or attainment. There are several presentations of these found in the canonical literature. One of the most common is as follows: (1) One observes form while the mind dwells at the level of the form realm. (2) One observes forms externally while discerning formlessness internally. (3) One dwells in the direct experience of the body’s pleasant aspect. (4) One dwells in the realization of the sphere of infinite space by transcending all conceptions of matter, resistance, and diversity. (5) Transcending the sphere of infinite space, one dwells in the realization of the sphere of infinite consciousness. (6) Transcending the sphere of infinite consciousness, one dwells in the realization of the sphere of nothingness. (7) Transcending the sphere of nothingness, one dwells in the realization of the sphere of neither perception nor nonperception. (8) Transcending the sphere of neither perception nor nonperception, one dwells in the realization of the cessation of conception and feeling.</p></div></div></div></div><div id="4169778b-b61e-4543-9188-38e7df4afde9" class="relative scroll-mt-20"><button type="button" id="radix-_R_91t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.135</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">eight unfavorable states</div><ul class="ml-4 list-disc"><li class="italic">mi khom pa brgyad</li><li class="pt-1"><span class="font-tibetan text-base">མི་ཁོམ་པ་བརྒྱད།</span></li><li class="italic">aṣṭākṣaṇa</li></ul><div class="glossary-instance-definition"><p class="definition">A set of circumstances that do not provide the freedom to practice the Buddhist path: being born in the realms of (1) the hells, (2) hungry ghosts (<em class="foreign break text-sa" lang="sa-LATN">pretas</em>), (3) animals, or (4) long-lived gods, or in the human realm among (5) barbarians or (6) extremists, (7) in places where the Buddhist teachings do not exist, or (8) without adequate faculties to understand the teachings where they do exist.</p></div></div></div></div><div id="99b9bf82-62aa-48b6-8fac-9e917973c3bd" class="relative scroll-mt-20"><button type="button" id="radix-_R_9255anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.136</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">eight vows</div><ul class="ml-4 list-disc"><li class="italic">gso sbyong</li><li class="pt-1"><span class="font-tibetan text-base">གསོ་སྦྱོང་།</span></li><li class="italic">poṣadha</li></ul><div class="glossary-instance-definition"><p class="definition">The eight vows taken by a layperson for just one day, usually a full-moon or new-moon day: no killing, no stealing, celibacy, no lying, no intoxicants, no sitting on a high chair, no singing or dancing, no wearing of adornments or perfumes.</p></div></div></div></div><div id="078683f8-28ea-4af5-8a96-968eed6c76c3" class="relative scroll-mt-20"><button type="button" id="radix-_R_92d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.137</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">eighteen unique qualities of a buddha, unique qualities of a buddha</div><ul class="ml-4 list-disc"><li class="italic">sangs rgyas gyi chos ma ’dres pa</li><li class="pt-1"><span class="font-tibetan text-base">སངས་རྒྱས་གྱི་ཆོས་མ་འདྲེས་པ།</span></li><li class="italic">āveṇika­buddha­dharma</li></ul><div class="glossary-instance-definition"><p class="definition">There are eighteen such qualities unique to a buddha, which consist of the <span data-glossary-id="UT22084-089-013-2533">ten strengths</span>, the four fearlessnesses, three mindfulnesses, and great compassion.</p></div></div></div></div><div id="1214ac9b-cd30-4785-96f5-43fbe6970113" class="relative scroll-mt-20"><button type="button" id="radix-_R_92l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.138</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">eighty features</div><ul class="ml-4 list-disc"><li class="italic">dpe byad bzang po brgyad cu</li><li class="pt-1"><span class="font-tibetan text-base">དཔེ་བྱད་བཟང་པོ་བརྒྱད་ཅུ།</span></li><li class="italic">aśītyanuvyañjana</li></ul><div class="glossary-instance-definition"><p class="definition">A set of eighty bodily characteristics borne by buddhas and universal emperors. They are considered “minor” in terms of being secondary to the thirty-two major marks of a great being. These can be found listed, for example, in Prajñāpāramitā sūtras (see <a target="_blank" href="https://read.84000.co/translation/UT22084-026-001.html#UT22084-026-001-5841" title="Toh 9">Toh 9</a>, <a target="_blank" href="https://read.84000.co/translation/UT22084-029-001.html#UT22084-029-001-5663" title="Toh 10">Toh 10</a>, <a target="_blank" href="https://read.84000.co/translation/UT22084-031-002.html#UT22084-031-002-292" title="Toh 11">Toh 11</a>) or in <cite class="title text-en" lang="en">The Play in Full</cite> (Toh 95, <a target="_blank" href="https://read.84000.co/translation/UT22084-046-001.html#UT22084-046-001-476" title="7.100">7.100</a>) and many other sūtras.</p></div></div></div></div><div id="f319605c-f007-4840-a761-76a0ad6aacf4" class="relative scroll-mt-20"><button type="button" id="radix-_R_92t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.139</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Elapatra</div><ul class="ml-4 list-disc"><li class="italic">e la’i ’dab ma</li><li class="pt-1"><span class="font-tibetan text-base">ཨེ་ལའི་འདབ་མ།</span></li><li class="italic">elapatra</li></ul><div class="glossary-instance-definition"><p class="definition">A nāga king often present in the retinue of the Buddha Śākyamuni. According to the Vinaya, in the time of the Buddha Kāśyapa he had been a monk (<em class="foreign break text-sa" lang="sa-LATN">bhikṣu</em>) who angrily cut down a thorny bush at the entrance of his cave because it always snagged his robes. Cutting down bushes or even grass is contrary to the monastic rules and he did not confess his action. Therefore, he was reborn as a nāga with a tree growing out of his head, which caused him great pain whenever the wind blew. This tale is found represented in ancient sculpture and is often quoted to demonstrate how small misdeeds can lead to great consequences. See, e.g., Patrul Rinpoche, <cite class="title text-en" lang="en">The Words of My Perfect Teacher</cite>.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">ela’i lo ma</em>)</p></div></div></div></div><div id="c73b5e86-3fdb-4c2c-8a69-e6b7e4c5cbe9" class="relative scroll-mt-20"><button type="button" id="radix-_R_9355anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.140</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">emanation body, illusory body</div><ul class="ml-4 list-disc"><li class="italic">sprul pa’i sku</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲུལ་པའི་སྐུ།</span></li><li class="italic">nirmitakāya, nirmāṇakāya</li></ul><div class="glossary-instance-definition"><p class="definition">Manifestations of the Buddha, particularly as the principal buddha of an age, that are perceivable by ordinary beings.</p></div></div></div></div><div id="1e7fa671-a07c-41c2-ac36-bd729926ac4d" class="relative scroll-mt-20"><button type="button" id="radix-_R_93d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.141</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">enjoyment body</div><ul class="ml-4 list-disc"><li class="italic">long spyod rdzogs pa’i sku</li><li class="pt-1"><span class="font-tibetan text-base">ལོང་སྤྱོད་རྫོགས་པའི་སྐུ།</span></li><li class="italic">saṃbhogakāya</li></ul><div class="glossary-instance-definition"><p class="definition">The enjoyment body denotes the luminous, immaterial, and unimpeded reflection-like forms that become spontaneously present and naturally manifest to tenth level bodhisattvas.</p><p class="definition">Degé 557: <em class="foreign text-wy" lang="bo-LATN">sha mi</em>.</p></div></div></div></div><div id="928932c0-6792-4c7e-a680-51bed7aee745" class="relative scroll-mt-20"><button type="button" id="radix-_R_93l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.142</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">eon</div><ul class="ml-4 list-disc"><li class="italic">bskal pa</li><li class="pt-1"><span class="font-tibetan text-base">བསྐལ་པ།</span></li><li class="italic">kalpa</li></ul><div class="glossary-instance-definition"><p class="definition">A cosmic period of time, sometimes equivalent to the time when a world system appears, exists, and disappears. According to the traditional Abhidharma understanding of cyclical time, a great eon (<em class="foreign break text-sa" lang="sa-LATN">mahākalpa</em>) is divided into eighty lesser eons. In the course of one great eon, the universe takes form and later disappears. During the first twenty of the lesser eons, the universe is in the process of creation and expansion; during the next twenty it remains; during the third twenty, it is in the process of destruction; and during the last quarter of the cycle, it remains in a state of empty stasis. A fortunate, or good, eon (<em class="foreign break text-sa" lang="sa-LATN">bhadrakalpa</em>) refers to any eon in which more than one buddha appears.</p></div></div></div></div><div id="854be481-bcd5-45d1-9b5f-e8b70ff40096" class="relative scroll-mt-20"><button type="button" id="radix-_R_93t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.143</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Equally Seeing</div><ul class="ml-4 list-disc"><li class="italic">mnyam par gzigs</li><li class="pt-1"><span class="font-tibetan text-base">མཉམ་པར་གཟིགས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p></div></div></div></div><div id="87dd20a5-cd48-4889-821e-a7e8257b068b" class="relative scroll-mt-20"><button type="button" id="radix-_R_9455anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.144</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Essence of Illustrious Precious Radiance</div><ul class="ml-4 list-disc"><li class="italic">rin po che’i ’od dpal gyi snying po</li><li class="pt-1"><span class="font-tibetan text-base">རིན་པོ་ཆེའི་འོད་དཔལ་གྱི་སྙིང་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">Name of the future buddha whom the goddess <span data-glossary-id="UT22084-089-013-2785">Ratnārcī</span> is prophesied to become.</p></div></div></div></div><div id="50a299a0-dabb-478d-9b4a-0499dcd6e8ee" class="relative scroll-mt-20"><button type="button" id="radix-_R_94d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.145</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Essence of Lotus Radiance</div><ul class="ml-4 list-disc"><li class="italic">pad+mo’i ’od kyi snying po</li><li class="pt-1"><span class="font-tibetan text-base">པདྨོའི་འོད་ཀྱི་སྙིང་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span>.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">pad ma ’od</em>)</p></div></div></div></div><div id="0f1a5dc6-f421-427a-a215-5335fbb89637" class="relative scroll-mt-20"><button type="button" id="radix-_R_94l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.146</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Essence of the Radiance of a Hundred Golden Lights</div><ul class="ml-4 list-disc"><li class="italic">gser brgya’i ’od zer du snang ba’i snying po</li><li class="pt-1"><span class="font-tibetan text-base">གསེར་བརྒྱའི་འོད་ཟེར་དུ་སྣང་བའི་སྙིང་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A buddha in the distant future who is <span data-glossary-id="UT22084-089-013-2792">Rūpyaprabha</span>, the son of the bodhisattva <span data-glossary-id="UT22084-089-013-2790">Ruciraketu</span> in the time of <span data-glossary-id="UT22084-089-013-2797">Śākyamuni</span>.</p><p class="definition">(Toh 555: <em class="foreign break text-sa" lang="sa-LATN">Suvarṇaketuprabha</em>; <em class="foreign text-wy" lang="bo-LATN">gser tog ’od</em>)</p></div></div></div></div><div id="a421de4e-da29-416c-b7eb-ba30a100163f" class="relative scroll-mt-20"><button type="button" id="radix-_R_94t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.147</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Exalted Light Rays</div><ul class="ml-4 list-disc"><li class="italic">’od zer mtho ba</li><li class="pt-1"><span class="font-tibetan text-base">འོད་ཟེར་མཐོ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p></div></div></div></div><div id="558ca933-65c5-44ad-8e08-b4577fef78cb" class="relative scroll-mt-20"><button type="button" id="radix-_R_9555anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.148</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Excellent Lotus</div><ul class="ml-4 list-disc"><li class="italic">pad+ma dam pa</li><li class="pt-1"><span class="font-tibetan text-base">པདྨ་དམ་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p><p class="definition">(Toh 555: <em class="foreign break text-sa" lang="sa-LATN">Padmavijaya</em>; <em class="foreign text-wy" lang="bo-LATN">rnam par rgyal ba’i pad ma</em>)</p></div></div></div></div><div id="fd7bdd27-46ed-4c05-9c6c-6045fe0c7e34" class="relative scroll-mt-20"><button type="button" id="radix-_R_95d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.149</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Extremely Pure Intelligence</div><ul class="ml-4 list-disc"><li class="italic">shin tu rnam dag blo gros</li><li class="pt-1"><span class="font-tibetan text-base">ཤིན་ཏུ་རྣམ་དག་བློ་གྲོས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign break text-sa" lang="sa-LATN">Viśuddhaprajñā</em>; <em class="foreign text-wy" lang="bo-LATN">shes rab rnam par dag pa</em>)</p></div></div></div></div><div id="ff6edbee-10df-4177-b75c-70b2b808f640" class="relative scroll-mt-20"><button type="button" id="radix-_R_95l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.150</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Extremely Radiant Array</div><ul class="ml-4 list-disc"><li class="italic">shin tu ’od bkod</li><li class="pt-1"><span class="font-tibetan text-base">ཤིན་ཏུ་འོད་བཀོད།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">’od rgyan chen po</em>)</p></div></div></div></div><div id="d2f43dfb-9961-4059-bee2-32b704884515" class="relative scroll-mt-20"><button type="button" id="radix-_R_95t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.151</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">fenugreek</div><ul class="ml-4 list-disc"><li class="italic">spr-i ka</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲྀ་ཀ</span></li><li class="italic">spṛkā</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign">Trigonella corniculata</em>.</p><p class="definition">(Toh 555 has <em class="foreign text-wy" lang="bo-LATN">spri ka spo</em>. Toh 557 translates as <em class="foreign text-wy" lang="bo-LATN">’u su</em>.)</p></div></div></div></div><div id="ff99b818-8f03-4066-a206-dbb804c6dbcb" class="relative scroll-mt-20"><button type="button" id="radix-_R_9655anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.152</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">fig tree flower</div><ul class="ml-4 list-disc"><li class="italic">u dum bA ra</li><li class="pt-1"><span class="font-tibetan text-base">ཨུ་དུམ་བཱ་ར།</span></li><li class="italic">udumbara</li></ul><div class="glossary-instance-definition"><p class="definition">The mythological flower of the fig tree, said to appear on rare occasions, such as the birth of a buddha. The actual fig tree flower is contained within the fruit. </p></div></div></div></div><div id="462e98db-df71-41ce-a887-83dcc04f94d0" class="relative scroll-mt-20"><button type="button" id="radix-_R_96d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.153</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Firm Effort</div><ul class="ml-4 list-disc"><li class="italic">brtson ’grus brtan</li><li class="pt-1"><span class="font-tibetan text-base">བརྩོན་འགྲུས་བརྟན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign break text-sa" lang="sa-LATN">Viryatapas</em>; <em class="foreign text-wy" lang="bo-LATN">brtson ’grus dka’ thub</em>)</p></div></div></div></div><div id="b63f158f-3aaa-4dc9-bb9b-61a3ebff3ac8" class="relative scroll-mt-20"><button type="button" id="radix-_R_96l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.154</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">five degenerations</div><ul class="ml-4 list-disc"><li class="italic">snyigs ma rnam pa lnga</li><li class="pt-1"><span class="font-tibetan text-base">སྙིགས་མ་རྣམ་པ་ལྔ།</span></li><li class="italic">pañcakaṣāya</li></ul><div class="glossary-instance-definition"><p class="definition">The five degenerations are (1) the degeneration of life span, (2) the degeneration of views, (3) the degeneration of the <span data-glossary-id="UT22084-089-013-2558">afflictions</span>, (4) the degeneration of beings, and (5) the degeneration of the era.</p></div></div></div></div><div id="65e50e3e-c2ad-4aa3-b391-9f055f541525" class="relative scroll-mt-20"><button type="button" id="radix-_R_96t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.155</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">five kinds of obscurations</div><ul class="ml-4 list-disc"><li class="italic">sgrib pa rnam pa lnga</li><li class="pt-1"><span class="font-tibetan text-base">སྒྲིབ་པ་རྣམ་པ་ལྔ།</span></li><li class="italic">pañcanīvaraṇa</li></ul><div class="glossary-instance-definition"><p class="definition">Five impediments to meditation (<em class="foreign text-wy" lang="bo-LATN">bsam gtan</em>, <em class="foreign break text-sa" lang="sa-LATN"><span data-glossary-id="UT22084-089-013-2564">dhyāna</span></em>): sensory desire (<em class="foreign text-wy" lang="bo-LATN">’dod pa la ’dun pa</em>, <em class="foreign break text-sa" lang="sa-LATN">kāmacchanda</em>), ill will (<em class="foreign text-wy" lang="bo-LATN">gnod sems</em>, <em class="foreign break text-sa" lang="sa-LATN">vyāpāda</em>), drowsiness and torpor (<em class="foreign text-wy" lang="bo-LATN">rmugs pa dang gnyid</em>, <em class="foreign break text-sa" lang="sa-LATN">styāna</em> and <em class="foreign break text-sa" lang="sa-LATN">middha</em>), agitation and regret (<em class="foreign text-wy" lang="bo-LATN">rgod pa dang ’gyod pa</em>, <em class="foreign break text-sa" lang="sa-LATN">auddhatya</em> and <em class="foreign break text-sa" lang="sa-LATN">kaukṛtya</em>), and doubt (<em class="foreign text-wy" lang="bo-LATN">the tshom</em>, <em class="foreign break text-sa" lang="sa-LATN">vicikitsā</em>).</p></div></div></div></div><div id="9bf44f16-bce8-4db4-bca7-98441af92d5b" class="relative scroll-mt-20"><button type="button" id="radix-_R_9755anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.156</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">five skandhas, skandhas</div><ul class="ml-4 list-disc"><li class="italic">phung po lnga</li><li class="pt-1"><span class="font-tibetan text-base">ཕུང་པོ་ལྔ།</span></li><li class="italic">pañcaskandha</li></ul><div class="glossary-instance-definition"><p class="definition">The five skandhas, or aggregates, are form, feeling, perception, <span data-glossary-id="UT22084-089-013-2483">formation</span>, and consciousness. On the individual level the five aggregates refer to the basis upon which the mistaken idea of a self is projected.</p></div></div></div></div><div id="64506262-075c-4d8b-a6e2-fcc1f40036da" class="relative scroll-mt-20"><button type="button" id="radix-_R_97d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.157</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">formation</div><ul class="ml-4 list-disc"><li class="italic">’du byed</li><li class="pt-1"><span class="font-tibetan text-base">འདུ་བྱེད།</span></li><li class="italic">saṃskāra</li></ul><div class="glossary-instance-definition"><p class="definition">The meaning of this term varies according to context. As one of the <span data-glossary-id="UT22084-089-013-2569">skandhas</span> it refers to various mental activities. In terms of the <span data-glossary-id="UT22084-089-013-3213">twelve phases of dependent origination</span> it is the second, “formation” or “creation,” referring to activities with karmic results. </p></div></div></div></div><div id="eb2c4c18-56a5-473e-87cd-dcf5f9869133" class="relative scroll-mt-20"><button type="button" id="radix-_R_97l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.158</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">four confidences</div><ul class="ml-4 list-disc"><li class="italic">mi ’jigs pa bzhi</li><li class="pt-1"><span class="font-tibetan text-base">མི་འཇིགས་པ་བཞི།</span></li><li class="italic">caturvaiśāradya</li></ul><div class="glossary-instance-definition"><p class="definition">This refers to the four <span data-glossary-id="UT22084-089-013-2464">confidences</span> or fearlessnesses (as translated into Tibetan) of a buddha: full <span data-glossary-id="UT22084-089-013-2464">confidence</span> that (1) they are fully awakened; (2) they have removed all <span data-glossary-id="UT22084-089-013-2470">defilements</span>; (3) they have taught about the obstacles to liberation; and (4) they have shown the path to liberation. </p></div></div></div></div><div id="d5db140f-bef5-4ec8-bb78-8ce31db8f39c" class="relative scroll-mt-20"><button type="button" id="radix-_R_97t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.159</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">four discernments</div><ul class="ml-4 list-disc"><li class="italic">so so yang dag par rig pa bzhi</li><li class="pt-1"><span class="font-tibetan text-base">སོ་སོ་ཡང་དག་པར་རིག་པ་བཞི།</span></li><li class="italic">catuḥpratisaṃvid</li></ul><div class="glossary-instance-definition"><p class="definition">The discernments of meaning, phenomena, language, and eloquence.</p></div></div></div></div><div id="0eb1982c-19be-4eb5-8ee3-dca0a2aa252d" class="relative scroll-mt-20"><button type="button" id="radix-_R_9855anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.160</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">four kinds of physical actions</div><ul class="ml-4 list-disc"><li class="italic">spyod lam rnam pa bzhi</li><li class="pt-1"><span class="font-tibetan text-base">སྤྱོད་ལམ་རྣམ་པ་བཞི།</span></li><li class="italic">caturvidham īryāpatham</li></ul><div class="glossary-instance-definition"><p class="definition">Walking, standing, sitting, and lying down. </p></div></div></div></div><div id="772224d0-971a-49ab-8f56-49664a2477ad" class="relative scroll-mt-20"><button type="button" id="radix-_R_98d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.161</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Four Mahārājas</div><ul class="ml-4 list-disc"><li class="italic">rgyal po chen po bzhi</li><li class="pt-1"><span class="font-tibetan text-base">རྒྱལ་པོ་ཆེན་པོ་བཞི།</span></li><li class="italic">caturmahārāja</li></ul><div class="glossary-instance-definition"><p class="definition">Four gods who live on the lower slopes (fourth level) of Mount Meru in the eponymous Heaven of the Four Great Kings (<em class="foreign break text-sa" lang="sa-LATN">Cāturmahā­rājika</em>, <em class="foreign text-wy" lang="bo-LATN">rgyal chen bzhi’i ris</em>) and guard the four cardinal directions. Each is the leader of a nonhuman class of beings living in his realm. They are Dhṛtarāṣṭra, ruling the gandharvas in the east; Virūḍhaka, ruling over the kumbhāṇḍas in the south; Virūpākṣa, ruling the nāgas in the west; and Vaiśravaṇa (also known as Kubera) ruling the yakṣas in the north. Also referred to as Guardians of the World or World Protectors (<em class="foreign break text-sa" lang="sa-LATN">lokapāla</em>, <em class="foreign break text-sa" lang="sa-LATN">’jig rten skyong ba</em>).</p></div></div></div></div><div id="d8333d1e-9682-4b7c-8b0e-a3d08e75f4ef" class="relative scroll-mt-20"><button type="button" id="radix-_R_98l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.162</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">fourfold army</div><ul class="ml-4 list-disc"><li class="italic">dpung gi tshogs yan lag bzhi</li><li class="pt-1"><span class="font-tibetan text-base">དཔུང་གི་ཚོགས་ཡན་ལག་བཞི།</span></li><li class="italic">caturaṅgabalakāya</li></ul><div class="glossary-instance-definition"><p class="definition">The ancient Indian army was composed of four branches (<em class="foreign break text-sa" lang="sa-LATN">caturaṅga</em>)‍—infantry, cavalry, chariots, and elephants.</p></div></div></div></div><div id="faf62992-77ce-4ac2-944b-a66ec4863aad" class="relative scroll-mt-20"><button type="button" id="radix-_R_98t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.163</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">frankincense</div><ul class="ml-4 list-disc"><li class="italic">du ru ska, sa la ki</li><li class="pt-1"><span class="font-tibetan text-base">དུ་རུ་སྐ།, ས་ལ་ཀི</span></li><li class="italic">śallaki</li></ul><div class="glossary-instance-definition"><p class="definition"> Also known as olibanum, this is a resin from trees of the genus <em class="foreign">Boswellia</em>, in this case, <em class="foreign">Boswellia serrata</em>, “Indian frankincense.” It is also known as <em class="foreign break text-sa" lang="sa-LATN">salai</em> and <em class="foreign break text-sa" lang="sa-LATN">śallakī</em>, <em class="foreign break text-sa" lang="sa-LATN">tilakalka</em>, <em class="foreign break text-sa" lang="sa-LATN">vṛścika</em>, and <em class="foreign break text-sa" lang="sa-LATN">turuṣka</em>.</p><p class="definition">(Bagchi edition: <em class="foreign break text-sa" lang="sa-LATN">sihlaka</em>. Toh 555: <em class="foreign text-wy" lang="bo-LATN">sa la ki</em>.)</p></div></div></div></div><div id="9e639ef1-5a68-4ae3-9c7f-8a12f268513c" class="relative scroll-mt-20"><button type="button" id="radix-_R_9955anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.164</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Gandhamādana</div><ul class="ml-4 list-disc"><li class="italic">spos kyi ngad ldang ba</li><li class="pt-1"><span class="font-tibetan text-base">སྤོས་ཀྱི་ངད་ལྡང་བ།</span></li><li class="italic">gandhamādana</li></ul><div class="glossary-instance-definition"><p class="definition">A mountain north of the Himalayas, said to be fifty <span data-glossary-id="UT22084-089-013-2557">yojanas</span> from Mount Kailash. In other sūtras, it is translated as <em class="foreign text-wy" lang="bo-LATN">spos ngad can</em>, <em class="foreign text-wy" lang="bo-LATN">spos ngad ldang</em>, or <em class="foreign text-wy" lang="bo-LATN">spos nad ldan</em>. Mount Gandhamardan in Orissa, India, was at one time a center for Buddhist study and practice.</p></div></div></div></div><div id="e5ecdd12-cdf7-40f9-8159-f2a466a8563e" class="relative scroll-mt-20"><button type="button" id="radix-_R_99d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.165</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">gandharva</div><ul class="ml-4 list-disc"><li class="italic">dri za</li><li class="pt-1"><span class="font-tibetan text-base">དྲི་ཟ།</span></li><li class="italic">gandharva</li></ul><div class="glossary-instance-definition"><p class="definition">A class of generally benevolent nonhuman beings who inhabit the skies, sometimes said to inhabit fantastic cities in the clouds, and more specifically to dwell on the eastern slopes of Mount Meru, where they are ruled by the Great King Dhṛtarāṣṭra. They are most renowned as celestial musicians who serve the gods. In the Abhidharma, the term is also used to refer to the mental body assumed by sentient beings during the intermediate state between death and rebirth. Gandharvas are said to live on fragrances (<em class="foreign break text-sa" lang="sa-LATN">gandha</em>) in the desire realm, hence the Tibetan translation <em class="foreign text-wy" lang="bo-LATN">dri za</em>, meaning “scent eater.”</p></div></div></div></div><div id="dc6807a0-2fe4-4e30-a622-969e73ebef7a" class="relative scroll-mt-20"><button type="button" id="radix-_R_99l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.166</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Gandharva</div><ul class="ml-4 list-disc"><li class="italic">dri za</li><li class="pt-1"><span class="font-tibetan text-base">དྲི་ཟ།</span></li><li class="italic">gandharva</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king.</p></div></div></div></div><div id="90b14b9b-aa32-458f-88b3-235142dbefbf" class="relative scroll-mt-20"><button type="button" id="radix-_R_99t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.167</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ganeśa</div><ul class="ml-4 list-disc"><li class="italic">tshogs bdag</li><li class="pt-1"><span class="font-tibetan text-base">ཚོགས་བདག</span></li><li class="italic">ganeśa</li></ul><div class="glossary-instance-definition"><p class="definition">The elephant-headed deity, more popularly known as Ganesh and associated with overcoming obstacles. The son of Śiva.</p></div></div></div></div><div id="9e8dcefa-ed96-45be-8284-93d779464b51" class="relative scroll-mt-20"><button type="button" id="radix-_R_9a55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.168</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Gaṅgadevī</div><ul class="ml-4 list-disc"><li class="italic">gang gA’i lha mo</li><li class="pt-1"><span class="font-tibetan text-base">གང་གཱའི་ལྷ་མོ།</span></li><li class="italic">gaṅgadevī</li></ul><div class="glossary-instance-definition"><p class="definition">A female disciple of the <span data-glossary-id="UT22084-089-013-2587">Tathāgata</span> <span data-glossary-id="UT22084-089-013-2726">Great Mass of Light</span> who became a <span data-glossary-id="UT22084-089-013-2460">cakravartin</span> king eighty-four thousand times and eventually the <span data-glossary-id="UT22084-089-013-2587">Tathāgata</span> <span data-glossary-id="UT22084-089-013-3279">Ratnārci</span>.</p></div></div></div></div><div id="f1f547b8-a278-490a-9223-f949fcad521b" class="relative scroll-mt-20"><button type="button" id="radix-_R_9ad5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.169</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ganges</div><ul class="ml-4 list-disc"><li class="italic">gang gA</li><li class="pt-1"><span class="font-tibetan text-base">གང་གཱ།</span></li><li class="italic">gaṅgā</li></ul><div class="glossary-instance-definition"><p class="definition">The Gaṅgā, or Ganges in English, is considered to be the most sacred river of India, particularly within the Hindu tradition. It starts in the Himalayas, flows through the northern plains of India, bathing the holy city of Vārāṇasī, and meets the sea at the Bay of Bengal, in Bangladesh. In the sūtras, however, this river is mostly mentioned not for its sacredness but for its abundant sands‍—noticeable still today on its many sandy banks and at its delta‍—which serve as a common metaphor for infinitely large numbers.</p><p class="definition">According to Buddhist cosmology, as explained in the <cite class="title text-en" lang="en">Abhidharmakośa</cite>, it is one of the four rivers that flow from Lake Anavatapta and cross the southern continent of Jambudvīpa‍—the known human world or more specifically the Indian subcontinent. </p></div></div></div></div><div id="63a551d2-800b-4bc7-802d-cecec8515ad2" class="relative scroll-mt-20"><button type="button" id="radix-_R_9al5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.170</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">garuḍa</div><ul class="ml-4 list-disc"><li class="italic">nam mkha’ lding</li><li class="pt-1"><span class="font-tibetan text-base">ནམ་མཁའ་ལྡིང་།</span></li><li class="italic">garuḍa</li></ul><div class="glossary-instance-definition"><p class="definition">In Indian mythology, the garuḍa is an eagle-like bird that is regarded as the king of all birds, normally depicted with a sharp, owl-like beak, often holding a snake, and with large and powerful wings. They are traditionally enemies of the nāgas. In the Vedas, they are said to have brought nectar from the heavens to earth. <em class="foreign break text-sa" lang="sa-LATN">Garuḍa</em> can also be used as a proper name for a king of such creatures.</p></div></div></div></div><div id="75515b84-5048-4e80-912e-05ad16932c85" class="relative scroll-mt-20"><button type="button" id="radix-_R_9at5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.171</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Gayākāśyapa</div><ul class="ml-4 list-disc"><li class="italic">ga yA ’od srung</li><li class="pt-1"><span class="font-tibetan text-base">ག་ཡཱ་འོད་སྲུང་།</span></li><li class="italic">gayākāśyapa</li></ul><div class="glossary-instance-definition"><p class="definition">The brother of <span data-glossary-id="UT22084-089-013-2745">Nadīkāśyapa</span> and <span data-glossary-id="UT22084-089-013-2844">Uruvilva­kāśyapa</span>. A practitioner of fire offering at Uruvilva (Bodhgayā), he and his two hundred students were converted to becoming <span data-glossary-id="UT22084-089-013-2450">bhikṣus</span> of the Buddha. He and his brothers and their students were the third group to become followers of the Buddha after his enlightenment.</p></div></div></div></div><div id="b42cf2c8-dbcd-4d9d-a3cb-65927ccdbde0" class="relative scroll-mt-20"><button type="button" id="radix-_R_9b55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.172</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Goddess Śrī, Śrī</div><ul class="ml-4 list-disc"><li class="italic">dpal, dpal gyi lha mo, lha mo dpal</li><li class="pt-1"><span class="font-tibetan text-base">དཔལ་གྱི་ལྷ་མོ།, དཔལ།, ལྷ་མོ་དཔལ།</span></li><li class="italic">śrī</li></ul><div class="glossary-instance-definition"><p class="definition">The great goddess Śrī, better known as Lakṣmī, who promises to aid those who recite this sūtra and to ensure its preservation so that beings will have good fortune. She dwells in a palace in the paradise of <span data-glossary-id="UT22084-089-013-2902">Alakāvati</span>.</p></div></div></div></div><div id="ce4453f2-e94f-4575-9fad-8936db171dc3" class="relative scroll-mt-20"><button type="button" id="radix-_R_9bd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.173</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Golden City Mountain</div><ul class="ml-4 list-disc"><li class="italic">gser gyi grong khyer ri bo</li><li class="pt-1"><span class="font-tibetan text-base">གསེར་གྱི་གྲོང་ཁྱེར་རི་བོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p></div></div></div></div><div id="f73b1614-329a-489d-9e5f-48330f86edc3" class="relative scroll-mt-20"><button type="button" id="radix-_R_9bl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.174</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Golden Essence</div><ul class="ml-4 list-disc"><li class="italic">gser gyi snying po</li><li class="pt-1"><span class="font-tibetan text-base">གསེར་གྱི་སྙིང་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">gser mdzod</em>)</p></div></div></div></div><div id="233dbec8-065f-452e-8983-ff75162cd133" class="relative scroll-mt-20"><button type="button" id="radix-_R_9bt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.175</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Golden Face</div><ul class="ml-4 list-disc"><li class="italic">gser gdong</li><li class="pt-1"><span class="font-tibetan text-base">གསེར་གདོང་།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2503">nāga</span> king.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">gser gyi bzhin</em>)</p></div></div></div></div><div id="797a0bad-d1b1-4825-b16a-d7c98c0efdc9" class="relative scroll-mt-20"><button type="button" id="radix-_R_9c55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.176</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Gopā</div><ul class="ml-4 list-disc"><li class="italic">sa ’tsho ma</li><li class="pt-1"><span class="font-tibetan text-base">ས་འཚོ་མ།</span></li><li class="italic">gopā</li></ul><div class="glossary-instance-definition"><p class="definition">A wife of the Buddha <span data-glossary-id="UT22084-089-013-2797">Śākyamuni</span> when he was Prince Siddhārtha, and the daughter of <span data-glossary-id="UT22084-089-013-2636">Daṇḍapāṇi</span>.</p></div></div></div></div><div id="0eaea7f5-9690-4a21-a84e-e80e30593a6f" class="relative scroll-mt-20"><button type="button" id="radix-_R_9cd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.177</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">gopi</div><ul class="ml-4 list-disc"><li class="italic">phyugs rdzi</li><li class="pt-1"><span class="font-tibetan text-base">ཕྱུགས་རྫི།</span></li><li class="italic">gopī</li></ul><div class="glossary-instance-definition"><p class="definition">Female cow herders or milk maids, the gopis are well known from their role in the mythology of Kṛṣṇa, in particular, <span data-glossary-id="UT22084-089-013-2773">Rādhā</span>, who became his lover. </p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">rdzi’i bu mo</em>)</p></div></div></div></div><div id="b711bcfc-11bb-4058-9a7c-9464a0a7605e" class="relative scroll-mt-20"><button type="button" id="radix-_R_9cl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.178</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Great Cloud Clearing Darkness</div><ul class="ml-4 list-disc"><li class="italic">sprin chen mun sel</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་ཆེན་མུན་སེལ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">sprin chen mun pa rnam par sel ba</em>)</p></div></div></div></div><div id="d710ef5e-5d1d-4329-a674-246838b2e85f" class="relative scroll-mt-20"><button type="button" id="radix-_R_9ct5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.179</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Great Cloud Clearing Obscured Vision</div><ul class="ml-4 list-disc"><li class="italic">sprin chen rab rib sel ba</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་ཆེན་རབ་རིབ་སེལ་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">sprin chen lta ba’i rab rib rnam par sel ba</em>)</p></div></div></div></div><div id="19b25ab8-71e3-47f1-b8b7-072500f756a2" class="relative scroll-mt-20"><button type="button" id="radix-_R_9d55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.180</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Great Cloud Completely Pure Radiance</div><ul class="ml-4 list-disc"><li class="italic">sprin chen rnam dag ’od</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་ཆེན་རྣམ་དག་འོད།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">sprin chen ’od gtsang</em>)</p></div></div></div></div><div id="7d51b120-f00b-461d-b4e2-8fa82862f550" class="relative scroll-mt-20"><button type="button" id="radix-_R_9dd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.181</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Great Cloud Constant Wisdom Rain</div><ul class="ml-4 list-disc"><li class="italic">sprin chen shes rab kun du ’char</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་ཆེན་ཤེས་རབ་ཀུན་དུ་འཆར།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign break text-sa" lang="sa-LATN">Mahā­megha­prajñā­samavarṣa</em>; <em class="foreign text-wy" lang="bo-LATN">sprin chen shes rab char yongs su snyoms pa</em>)</p></div></div></div></div><div id="e777c39d-95d9-4e15-913c-258db80fe171" class="relative scroll-mt-20"><button type="button" id="radix-_R_9dl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.182</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Great Cloud Dharma Holder</div><ul class="ml-4 list-disc"><li class="italic">sprin chen chos ’dzin</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་ཆེན་ཆོས་འཛིན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">sprin chen chos skyong</em>)</p></div></div></div></div><div id="2f3fffe1-e48e-482c-8dde-c6ff8a9e8bf3" class="relative scroll-mt-20"><button type="button" id="radix-_R_9dt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.183</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Great Cloud Firelight</div><ul class="ml-4 list-disc"><li class="italic">sprin chen me’i ’od</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་ཆེན་མེའི་འོད།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p></div></div></div></div><div id="0b8e4ac0-a3b9-4f13-a127-2b7a76cf2566" class="relative scroll-mt-20"><button type="button" id="radix-_R_9e55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.184</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Great Cloud Flower Tree King</div><ul class="ml-4 list-disc"><li class="italic">sprin chen me tog shing rgyal</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་ཆེན་མེ་ཏོག་ཤིང་རྒྱལ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">sprin chen me tog sdong po’i rgyal po</em>)</p></div></div></div></div><div id="a41d30b8-82cd-48a2-8450-2aeae0e499a2" class="relative scroll-mt-20"><button type="button" id="radix-_R_9ed5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.185</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Great Cloud Good Fortune</div><ul class="ml-4 list-disc"><li class="italic">sprin chen bkra shis</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་ཆེན་བཀྲ་ཤིས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p></div></div></div></div><div id="6a6235b2-9ee7-4f0e-b40b-de4735254317" class="relative scroll-mt-20"><button type="button" id="radix-_R_9el5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.186</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Great Cloud King Completely Pure Rain</div><ul class="ml-4 list-disc"><li class="italic">sprin chen rnam dag char pa’i rgyal po</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་ཆེན་རྣམ་དག་ཆར་པའི་རྒྱལ་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">sprin chen char gyi rgyal po yongs su dag pa</em>)</p></div></div></div></div><div id="b13ae87a-1bb8-4c8e-9e91-2fb11c5d43b9" class="relative scroll-mt-20"><button type="button" id="radix-_R_9et5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.187</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Great Cloud Lightning</div><ul class="ml-4 list-disc"><li class="italic">sprin chen glog gi ’od</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་ཆེན་གློག་གི་འོད།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p></div></div></div></div><div id="3e554043-9cba-4246-8ede-f8661ed00618" class="relative scroll-mt-20"><button type="button" id="radix-_R_9f55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.188</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Great Cloud Lion’s Roar</div><ul class="ml-4 list-disc"><li class="italic">sprin chen seng ge’i sgra</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་ཆེན་སེང་གེའི་སྒྲ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p></div></div></div></div><div id="3ebe3b0c-80ee-42d7-8080-d112ec8ea177" class="relative scroll-mt-20"><button type="button" id="radix-_R_9fd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.189</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Great Cloud Moon’s Essence</div><ul class="ml-4 list-disc"><li class="italic">sprin chen zla ba’i snying po</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་ཆེན་ཟླ་བའི་སྙིང་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p></div></div></div></div><div id="01bbc5a9-fd75-45dd-baa0-eb0595d18377" class="relative scroll-mt-20"><button type="button" id="radix-_R_9fl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.190</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Great Cloud Precious Glory</div><ul class="ml-4 list-disc"><li class="italic">sprin chen rin chen dpal</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་ཆེན་རིན་ཆེན་དཔལ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign break text-sa" lang="sa-LATN">Mahā­megha­ratna­guṇa</em>; <em class="foreign text-wy" lang="bo-LATN">sprin chen rin chen yon tan</em>)</p></div></div></div></div><div id="7c81e366-3254-4710-9aa9-8721c1d652ee" class="relative scroll-mt-20"><button type="button" id="radix-_R_9ft5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.191</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Great Cloud Renowned Joy</div><ul class="ml-4 list-disc"><li class="italic">sprin chen grags dga’</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་ཆེན་གྲགས་དགའ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">sprin chen grags can dga’</em>)</p></div></div></div></div><div id="1a199bff-3756-4af9-b997-f1e1a4b30562" class="relative scroll-mt-20"><button type="button" id="radix-_R_9g55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.192</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Great Cloud Renowned Limitless Revealer</div><ul class="ml-4 list-disc"><li class="italic">sprin chen grags pa mtha’ med ston</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་ཆེན་གྲགས་པ་མཐའ་མེད་སྟོན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign break text-sa" lang="sa-LATN">Mahā­meghānanta­kīrti</em>; <em class="foreign text-wy" lang="bo-LATN">sprin chen mtha’ yas grags</em>)</p></div></div></div></div><div id="b2dea9d5-0f66-49ef-8abe-ce2620acb5c6" class="relative scroll-mt-20"><button type="button" id="radix-_R_9gd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.193</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Great Cloud Starlight</div><ul class="ml-4 list-disc"><li class="italic">sprin chen skar ma’i ’od</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་ཆེན་སྐར་མའི་འོད།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p></div></div></div></div><div id="bbd6408e-e6ed-4918-91ca-4b74718ac477" class="relative scroll-mt-20"><button type="button" id="radix-_R_9gl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.194</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Great Cloud Sun’s Essence</div><ul class="ml-4 list-disc"><li class="italic">sprin chen nyi ma’i snying po</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་ཆེན་ཉི་མའི་སྙིང་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p></div></div></div></div><div id="3c52996b-395b-4b4d-b683-286f81ce8f3e" class="relative scroll-mt-20"><button type="button" id="radix-_R_9gt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.195</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Great Cloud Supreme Bull’s Sound</div><ul class="ml-4 list-disc"><li class="italic">sprin chen khyu mchog sgra</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་ཆེན་ཁྱུ་མཆོག་སྒྲ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">sprin chen glang po che’i rgyal po’i sgra</em>)</p></div></div></div></div><div id="112de0ee-cfda-4cc6-a6da-04a1e00d118f" class="relative scroll-mt-20"><button type="button" id="radix-_R_9h55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.196</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Great Cloud Thunder</div><ul class="ml-4 list-disc"><li class="italic">sprin chen ’brug sgra</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་ཆེན་འབྲུག་སྒྲ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p></div></div></div></div><div id="397485f6-6d97-4d20-9192-9f341f88e6aa" class="relative scroll-mt-20"><button type="button" id="radix-_R_9hd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.197</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Great Cloud Utpala Scent</div><ul class="ml-4 list-disc"><li class="italic">sprin chen ut+pa la’i dri</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་ཆེན་ཨུཏྤ་ལའི་དྲི།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">sprin chen pad ma sngon po’i bsung</em>)</p></div></div></div></div><div id="af7e774d-e8cf-42b6-bd3b-3a56a7e22a5a" class="relative scroll-mt-20"><button type="button" id="radix-_R_9hl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.198</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Great Dharma Power</div><ul class="ml-4 list-disc"><li class="italic">chos chen mthu</li><li class="pt-1"><span class="font-tibetan text-base">ཆོས་ཆེན་མཐུ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">chos kyi stobs</em>)</p></div></div></div></div><div id="1e658181-745d-48fa-a42d-9005e02178df" class="relative scroll-mt-20"><button type="button" id="radix-_R_9ht5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.199</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Great Glory</div><ul class="ml-4 list-disc"><li class="italic">dpal chen</li><li class="pt-1"><span class="font-tibetan text-base">དཔལ་ཆེན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2496">Licchavī</span> youth.</p></div></div></div></div><div id="4aa0c900-0a02-403c-b168-16fb992da4b7" class="relative scroll-mt-20"><button type="button" id="radix-_R_9i55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.200</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Great Golden Radiant Array</div><ul class="ml-4 list-disc"><li class="italic">gser ’od chen pos bkod pa</li><li class="pt-1"><span class="font-tibetan text-base">གསེར་འོད་ཆེན་པོས་བཀོད་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">gser gyi ’od rgyan chen po</em>)</p></div></div></div></div><div id="3c825a14-1bd0-4316-ab08-ba32150f5d52" class="relative scroll-mt-20"><button type="button" id="radix-_R_9id5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.201</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Great Mass of Light</div><ul class="ml-4 list-disc"><li class="italic">’od zer gyi phung po chen po</li><li class="pt-1"><span class="font-tibetan text-base">འོད་ཟེར་གྱི་ཕུང་པོ་ཆེན་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A buddha in the distant past.</p></div></div></div></div><div id="1e66b66e-9bfc-46c1-b8df-e40219dad81b" class="relative scroll-mt-20"><button type="button" id="radix-_R_9il5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.202</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Great Ocean Profound King</div><ul class="ml-4 list-disc"><li class="italic">rgya mtsho chen po zab mo’i rgyal po, rgya mtsho zab mo’i rgyal po</li><li class="pt-1"><span class="font-tibetan text-base">རྒྱ་མཚོ་ཆེན་པོ་ཟབ་མོའི་རྒྱལ་པོ།, རྒྱ་མཚོ་ཟབ་མོའི་རྒྱལ་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign break text-sa" lang="sa-LATN">Mahā­gaṃbhīra­sagara­rāja</em>; <em class="foreign text-wy" lang="bo-LATN">rgya mtsho chen po zab mo’i rgyal po</em>)</p></div></div></div></div><div id="6fe41eb7-981f-4a84-a922-29b4346bc742" class="relative scroll-mt-20"><button type="button" id="radix-_R_9it5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.203</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Haimavata</div><ul class="ml-4 list-disc"><li class="italic">gangs can</li><li class="pt-1"><span class="font-tibetan text-base">གངས་ཅན།</span></li><li class="italic">haimavata</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">gangs ri</em>)</p></div></div></div></div><div id="ade43d84-6dad-4353-a0c0-6727824bdf62" class="relative scroll-mt-20"><button type="button" id="radix-_R_9j55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.204</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Haridhara</div><ul class="ml-4 list-disc"><li class="italic">ha ri tshig ’chang</li><li class="pt-1"><span class="font-tibetan text-base">ཧ་རི་ཚིག་འཆང་།</span></li><li class="italic">haridhara</li></ul><div class="glossary-instance-definition"><p class="definition">Unidentified deity. Possibly Kṛṣṇa.</p><p class="definition">Acording to Lithang and Cone. Degé, etc.: <em class="foreign text-wy" lang="bo-LATN">hi ri tshig ’chang</em>.</p></div></div></div></div><div id="a86fd94d-a590-4d6e-a1cb-7d09167009ef" class="relative scroll-mt-20"><button type="button" id="radix-_R_9jd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.205</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Hārītī</div><ul class="ml-4 list-disc"><li class="italic">’phrog ma</li><li class="pt-1"><span class="font-tibetan text-base">འཕྲོག་མ།</span></li><li class="italic">hārītī</li></ul><div class="glossary-instance-definition"><p class="definition">A rākṣasī with hundreds of children whom the Buddha converted into a protector of children.</p></div></div></div></div><div id="d552a07d-7371-461a-ad95-aea6f645ee57" class="relative scroll-mt-20"><button type="button" id="radix-_R_9jl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.206</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">higher cognitions</div><ul class="ml-4 list-disc"><li class="italic">mngon par shes pa</li><li class="pt-1"><span class="font-tibetan text-base">མངོན་པར་ཤེས་པ།</span></li><li class="italic">abhijñā</li></ul><div class="glossary-instance-definition"><p class="definition">The higher cognitions are listed as either five or six. The first five are divine sight, divine hearing, knowing how to manifest miracles, remembering previous lives, and knowing what is in the minds of others. A sixth, knowing that all defects have been eliminated, is often added. The first five are attained through concentration (Skt. <em class="foreign break text-sa" lang="sa-LATN"><span data-glossary-id="UT22084-089-013-2564">dhyāna</span></em>), and are sometimes described as worldly, as they can be attained to some extent by non-Buddhist yogis, while the sixth is supramundane and attained only by realization.</p></div></div></div></div><div id="0ba28d7c-6a60-4c4a-bd45-86d77cf4a50a" class="relative scroll-mt-20"><button type="button" id="radix-_R_9jt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.207</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Highest Jewels</div><ul class="ml-4 list-disc"><li class="italic">rin chen bla ma</li><li class="pt-1"><span class="font-tibetan text-base">རིན་ཆེན་བླ་མ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p></div></div></div></div><div id="e9385054-b5d4-4219-ab26-746fec21764c" class="relative scroll-mt-20"><button type="button" id="radix-_R_9k55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.208</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">hundred and eighty unique qualities</div><ul class="ml-4 list-disc"><li class="italic">ma ’dres pa’i chos brgya brgyad chu</li><li class="pt-1"><span class="font-tibetan text-base">མ་འདྲེས་པའི་ཆོས་བརྒྱ་བརྒྱད་ཆུ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">This term is uncommon in the Kangyur as it seems to appear only in this sūtra and in Toh 555. It is found in Yijing’s Chinese version from which the Tibetan translation of Toh 555 was produced. It may originally have been a reference to the <span data-glossary-id="UT22084-089-013-2535">eighteen unique qualities of a buddha</span>.</p></div></div></div></div><div id="af375b98-b3cb-4a94-84a5-e08e3619f09f" class="relative scroll-mt-20"><button type="button" id="radix-_R_9kd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.209</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Hundredth Moment</div><ul class="ml-4 list-disc"><li class="italic">skad brgya pa</li><li class="pt-1"><span class="font-tibetan text-base">སྐད་བརྒྱ་པ།</span></li><li class="italic">kṣaṇaśatara</li></ul><div class="glossary-instance-definition"><p class="definition">A god who is the king of lightning in the southern direction.</p></div></div></div></div><div id="abd01d6a-5c3f-4893-9180-11e662e0741b" class="relative scroll-mt-20"><button type="button" id="radix-_R_9kl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.210</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Immaculate Banner</div><ul class="ml-4 list-disc"><li class="italic">rdul dang bral ba’i rgyal mtshan</li><li class="pt-1"><span class="font-tibetan text-base">རྡུལ་དང་བྲལ་བའི་རྒྱལ་མཚན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A world realm in the distant future.</p></div></div></div></div><div id="ab968d0b-817f-47cc-aa92-1afebfb1bda8" class="relative scroll-mt-20"><button type="button" id="radix-_R_9kt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.211</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">imputed</div><ul class="ml-4 list-disc"><li class="italic">kun brtags pa</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་བརྟགས་པ།</span></li><li class="italic">parikalpita</li></ul><div class="glossary-instance-definition"><p class="definition">Conceptual cognition; an alternative translation is “the imaginary.” One of the three natures that are a central philosophy of the Yogācāra tradition.</p></div></div></div></div><div id="7045ba28-23a7-4e65-ac32-3d872bad82dc" class="relative scroll-mt-20"><button type="button" id="radix-_R_9l55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.212</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Indra</div><ul class="ml-4 list-disc"><li class="italic">dbang po</li><li class="pt-1"><span class="font-tibetan text-base">དབང་པོ།</span></li><li class="italic">indra</li></ul><div class="glossary-instance-definition"><p class="definition">The deity that is also called Mahendra, “lord of the <span data-glossary-id="UT22084-089-013-2471">devas</span>,” who dwells on the summit of Mount <span data-glossary-id="UT22084-089-013-2940">Sumeru</span> and wields a thunderbolt. He is also known as <span data-glossary-id="UT22084-089-013-2796">Śakra</span> (Tib. <em class="foreign text-wy" lang="bo-LATN">brgya byin</em>, “hundred offerings”). The Buddhist tradition sometimes interprets this name as an abbreviation of <em class="foreign break text-sa" lang="sa-LATN">śata-kratu</em>, “one who has performed a hundred sacrifices.” The highest Vedic sacrifice was the horse sacrifice, and there is a tradition that <span data-glossary-id="UT22084-089-013-2796">Indra</span> became the lord of the gods through performing them. </p></div></div></div></div><div id="10d9ccbb-4514-4ab1-9c19-578c6d5f6f4c" class="relative scroll-mt-20"><button type="button" id="radix-_R_9ld5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.213</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Indra, Śakra</div><ul class="ml-4 list-disc"><li class="italic">brgya byin</li><li class="pt-1"><span class="font-tibetan text-base">བརྒྱ་བྱིན།</span></li><li class="italic">śakra</li></ul><div class="glossary-instance-definition"><p>The lord of the gods in the Heaven of the Thirty-Three (<em class="foreign break text-sa" lang="sa-LATN">trāyastriṃśa</em>). Alternatively known as Indra, the deity that is called “lord of the gods” dwells on the summit of Mount Sumeru and wields the thunderbolt. The Tibetan translation <em class="foreign text-wy" lang="bo-LATN">brgya byin</em> (meaning “one hundred sacrifices”) is based on an etymology that <em class="foreign break text-sa" lang="sa-LATN">śakra</em> is an abbreviation of <em class="foreign break text-sa" lang="sa-LATN">śata-kratu</em>, one who has performed a hundred sacrifices. Each world with a central Sumeru has a Śakra. Also known by other names such as Kauśika, Devendra, and Śacipati. </p></div></div></div></div><div id="0116b0ca-3bc6-4392-b88b-13d39c746425" class="relative scroll-mt-20"><button type="button" id="radix-_R_9ll5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.214</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">ironwood flowers, keśarā</div><ul class="ml-4 list-disc"><li class="italic">nA ga ge sar</li><li class="pt-1"><span class="font-tibetan text-base">ནཱ་ག་གེ་སར།</span></li><li class="italic">keśarā, nāgakeśara</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign">Mesua ferrea</em>. Evergreen tree up to 100 feet tall. Known as Assam ironwood, Ceylon ironwood, Indian rose chestnut, Cobra’s <span data-glossary-id="UT22084-089-013-2517">saffron</span>, and nāgakesara. The flowers are large and fragrant, with four white petals and a yellow center. </p></div></div></div></div><div id="f00dda01-a511-4156-9497-a7e2231daa2d" class="relative scroll-mt-20"><button type="button" id="radix-_R_9lt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.215</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Jalāgamā</div><ul class="ml-4 list-disc"><li class="italic">chu ’bab pa</li><li class="pt-1"><span class="font-tibetan text-base">ཆུ་འབབ་པ།</span></li><li class="italic">jalāgamā</li></ul><div class="glossary-instance-definition"><p class="definition">A river.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">chu skyes</em>)</p></div></div></div></div><div id="50799e5f-1ece-439c-a637-15b486466c13" class="relative scroll-mt-20"><button type="button" id="radix-_R_9m55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.216</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Jalagarbha</div><ul class="ml-4 list-disc"><li class="italic">chu’i snying po</li><li class="pt-1"><span class="font-tibetan text-base">ཆུའི་སྙིང་པོ།</span></li><li class="italic">jalagarbha</li></ul><div class="glossary-instance-definition"><p class="definition">The younger son of <span data-glossary-id="UT22084-089-013-2661">Jalavāhana</span> and <span data-glossary-id="UT22084-089-013-2660">Jalāmbujagarbhā</span>.</p></div></div></div></div><div id="25a19adb-2808-4804-ab56-72a8c8d421cd" class="relative scroll-mt-20"><button type="button" id="radix-_R_9md5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.217</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Jalāmbara</div><ul class="ml-4 list-disc"><li class="italic">chu’i gos</li><li class="pt-1"><span class="font-tibetan text-base">ཆུའི་གོས།</span></li><li class="italic">jalāmbara</li></ul><div class="glossary-instance-definition"><p class="definition">The elder son of <span data-glossary-id="UT22084-089-013-2661">Jalavāhana</span> and <span data-glossary-id="UT22084-089-013-2660">Jalāmbujagarbhā</span>.</p></div></div></div></div><div id="750d5647-ee14-4dc3-a522-6098689cd177" class="relative scroll-mt-20"><button type="button" id="radix-_R_9ml5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.218</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Jalāmbujagarbhā</div><ul class="ml-4 list-disc"><li class="italic">chu’i pad+ma’i snying po</li><li class="pt-1"><span class="font-tibetan text-base">ཆུའི་པདྨའི་སྙིང་པོ།</span></li><li class="italic">jalāmbujagarbhā</li></ul><div class="glossary-instance-definition"><p class="definition">The wife of <span data-glossary-id="UT22084-089-013-2661">Jalavāhana</span>.</p></div></div></div></div><div id="57f0f961-6f2b-495c-bf32-21720f0875d5" class="relative scroll-mt-20"><button type="button" id="radix-_R_9mt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.219</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Jalavāhana</div><ul class="ml-4 list-disc"><li class="italic">chu ’bebs</li><li class="pt-1"><span class="font-tibetan text-base">ཆུ་འབེབས།</span></li><li class="italic">jalavāhana</li></ul><div class="glossary-instance-definition"><p class="definition">A learned physician in the distant past and son of <span data-glossary-id="UT22084-089-013-2663">Jaṭiṃdhara</span> who, as a result of performing Dharma recitations while standing in a lake, ensured the rebirth of ten thousand fish into the paradise of <span data-glossary-id="UT22084-089-013-2942">Trāyastriṃśa</span>. He was the Buddha in a previous life.</p></div></div></div></div><div id="3456a106-d5da-4357-9633-8660cc738b51" class="relative scroll-mt-20"><button type="button" id="radix-_R_9n55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.220</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Jambu Golden Victory Banner That is Golden in Appearance</div><ul class="ml-4 list-disc"><li class="italic">’dzam bu gser gyi rgyal mtshan gser du snang ba</li><li class="pt-1"><span class="font-tibetan text-base">འཛམ་བུ་གསེར་གྱི་རྒྱལ་མཚན་གསེར་དུ་སྣང་བ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2587">tathāgata</span>.</p><p class="definition">(Toh 555: <em class="foreign break text-sa" lang="sa-LATN">Suvarṇaketuprabha</em>; <em class="foreign text-wy" lang="bo-LATN">gser tog ’od</em>)</p></div></div></div></div><div id="976873dd-bd9c-436b-8fcb-0b632aedab12" class="relative scroll-mt-20"><button type="button" id="radix-_R_9nd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.221</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Jambū River</div><ul class="ml-4 list-disc"><li class="italic">’dzam bu’i chu klung</li><li class="pt-1"><span class="font-tibetan text-base">འཛམ་བུའི་ཆུ་ཀླུང་།</span></li><li class="italic">jambūnadī</li></ul><div class="glossary-instance-definition"><p class="definition">The rivers that flow down from the immense lake at the foot of the legendary Jambu tree. The fruits of that tree are made of gold and are carried down by the rivers through <span data-glossary-id="UT22084-089-013-3198">Jambudvīpa</span>. Such gold is considered the best kind.</p></div></div></div></div><div id="a7a63b0e-ff89-451b-8593-40349c576c28" class="relative scroll-mt-20"><button type="button" id="radix-_R_9nl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.222</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Jambudvīpa</div><ul class="ml-4 list-disc"><li class="italic">’dzam bu gling</li><li class="pt-1"><span class="font-tibetan text-base">འཛམ་བུ་གླིང་།</span></li><li class="italic">jambudvīpa</li></ul><div class="glossary-instance-definition"><p class="definition">The name of the southern continent in Buddhist cosmology, which can signify either the known human world, or more specifically the Indian subcontinent, literally “the <em class="foreign break text-sa" lang="sa-LATN">jambu</em> island/continent.” Jambu is the name used for a range of plum-like fruits from trees belonging to the genus <em class="foreign">Szygium</em>, particularly <em class="foreign">Szygium jambos</em> and <em class="foreign">Szygium cumini</em>, and it has commonly been rendered “rose apple,” although “black plum” may be a less misleading term. Among various explanations given for the continent being so named, one (in the <cite class="title break text-sa" lang="sa-LATN">Abhidharmakośa</cite>) is that a jambu tree grows in its northern mountains beside Lake Anavatapta, mythically considered the source of the four great rivers of India, and that the continent is therefore named from the tree or the fruit. Jambudvīpa has the Vajrāsana at its center and is the only continent upon which buddhas attain awakening.</p></div></div></div></div><div id="00b75345-720a-4f43-8d9f-5cc7fe2cc96e" class="relative scroll-mt-20"><button type="button" id="radix-_R_9nt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.223</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Jaṭiṃdhara</div><ul class="ml-4 list-disc"><li class="italic">ral pa ’dzin</li><li class="pt-1"><span class="font-tibetan text-base">རལ་པ་འཛིན།</span></li><li class="italic">jaṭiṃdhara</li></ul><div class="glossary-instance-definition"><p class="definition">A head merchant and physician in the distant past.</p><p class="definition">(Toh 555: <em class="foreign break text-sa" lang="sa-LATN">Jaladhara</em>; <em class="foreign text-wy" lang="bo-LATN">chu ’dzin</em>)</p></div></div></div></div><div id="4a4426a2-92c8-43a0-8413-753077eeafaa" class="relative scroll-mt-20"><button type="button" id="radix-_R_9o55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.224</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">jina</div><ul class="ml-4 list-disc"><li class="italic">rgyal ba</li><li class="pt-1"><span class="font-tibetan text-base">རྒྱལ་བ།</span></li><li class="italic">jina</li></ul><div class="glossary-instance-definition"><p class="definition">An epithet for a buddha meaning “victorious one.”</p></div></div></div></div><div id="b654fd57-78ef-498c-b735-47932a5790ca" class="relative scroll-mt-20"><button type="button" id="radix-_R_9od5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.225</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Jinamitra</div><ul class="ml-4 list-disc"><li class="italic">dzi na mi tra</li><li class="pt-1"><span class="font-tibetan text-base">ཛི་ན་མི་ཏྲ།</span></li><li class="italic">jinamitra</li></ul><div class="glossary-instance-definition"><p>Jinamitra was invited to Tibet during the reign of King Tri Songdetsen (<em class="foreign text-wy" lang="bo-LATN">khri srong lde btsan</em>, r. 742–98 <span class="small-caps">ᴄᴇ</span>) and was involved with the translation of nearly two hundred texts, continuing into the reign of King Ralpachen (<em class="foreign text-wy" lang="bo-LATN">ral pa can</em>, r. 815–38 <span class="small-caps">ᴄᴇ</span>). He was one of the small group of paṇḍitas responsible for the <cite class="title break text-sa" lang="sa-LATN">Mahāvyutpatti</cite> Sanskrit–Tibetan dictionary.</p></div></div></div></div><div id="e4881bae-391a-483e-baf8-964b74e7fc3d" class="relative scroll-mt-20"><button type="button" id="radix-_R_9ol5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.226</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Jinarāja</div><ul class="ml-4 list-disc"><li class="italic">rgyal ba’i rgyal</li><li class="pt-1"><span class="font-tibetan text-base">རྒྱལ་བའི་རྒྱལ།</span></li><li class="italic">jinarāja</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">’dam bu rgyal</em>)</p></div></div></div></div><div id="717c66fb-08f0-45ee-87b6-337426c452c8" class="relative scroll-mt-20"><button type="button" id="radix-_R_9ot5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.227</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Jinarṣabha</div><ul class="ml-4 list-disc"><li class="italic">rgyal ba khyu mchog</li><li class="pt-1"><span class="font-tibetan text-base">རྒྱལ་བ་ཁྱུ་མཆོག</span></li><li class="italic">jinarṣabha</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king and the son of <span data-glossary-id="UT22084-089-013-2847">Vaiśravaṇa</span>.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">rtag tu rgyal</em>)</p></div></div></div></div><div id="cb6cc75e-3b24-4025-9040-db7485022e5e" class="relative scroll-mt-20"><button type="button" id="radix-_R_9p55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.228</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Joyful High King</div><ul class="ml-4 list-disc"><li class="italic">dga’ bas mtho ba’i rgyal po</li><li class="pt-1"><span class="font-tibetan text-base">དགའ་བས་མཐོ་བའི་རྒྱལ་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">’phags par dga’ ba</em>)</p></div></div></div></div><div id="2e0961b8-f430-4962-9e8d-5d52b5d634c8" class="relative scroll-mt-20"><button type="button" id="radix-_R_9pd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.229</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Jvalanāntara­tejo­rāja</div><ul class="ml-4 list-disc"><li class="italic">’bar ba’i khyad par gyi gzi brjid kyi rgyal po</li><li class="pt-1"><span class="font-tibetan text-base">འབར་བའི་ཁྱད་པར་གྱི་གཟི་བརྗིད་ཀྱི་རྒྱལ་པོ།</span></li><li class="italic">jvalanāntara­tejo­rāja</li></ul><div class="glossary-instance-definition"><p class="definition">A deity in the <span data-glossary-id="UT22084-089-013-2942">Trāyastriṃśa</span> paradise.</p><p class="definition">(Toh 557: <em class="foreign text-wy" lang="bo-LATN">’bar ba’i khyad par gyi gzi brjid rgyal po</em>. Toh 555: <em class="foreign text-wy" lang="bo-LATN">mchog tu rgyal ba’i ’od</em>)</p></div></div></div></div><div id="06800f21-f0b9-475a-8ff0-71416a7085dc" class="relative scroll-mt-20"><button type="button" id="radix-_R_9pl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.230</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">kalaviṅka</div><ul class="ml-4 list-disc"><li class="italic">ka la ping ka</li><li class="pt-1"><span class="font-tibetan text-base">ཀ་ལ་པིང་ཀ</span></li><li class="italic">kalaviṅka</li></ul><div class="glossary-instance-definition"><p class="definition">In Buddhist literature refers to a mythical bird whose call is said to be far more beautiful than that of all other birds, and so compelling that it can be heard even before the bird has hatched. The call of the kalaviṅka is thus used as an analogy to describe the sound of the discourse of bodhisattvas as being far superior to that of śrāvakas and pratyekabuddhas, even before bodhisattvas attain awakening. In some cases, the kalaviṅka also takes on mythical characteristics, being depicted as part human, part bird. It is also the sixteenth of the eighty designs on the palms and soles of a tathāgata.</p><p class="definition">While it is equated to an Indian bird renowned for its beautiful song, there is some uncertainty regarding the identity of the kalaviṅka; some dictionaries declare it to be a type of Indian cuckoo (probably <em class="foreign">Eudynamys scolopacea</em>, also known as the asian koel) or a red and green sparrow (possibly <em class="foreign">Amandava amandava</em>, also known as the red avadavat).</p></div></div></div></div><div id="ceffcc95-e521-47c9-84b5-8771e4f32a53" class="relative scroll-mt-20"><button type="button" id="radix-_R_9pt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.231</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">kalyāṇamitra</div><ul class="ml-4 list-disc"><li class="italic">dge ba’i bshes gnyen</li><li class="pt-1"><span class="font-tibetan text-base">དགེ་བའི་བཤེས་གཉེན།</span></li><li class="italic">kalyāṇamitra</li></ul><div class="glossary-instance-definition"><p class="definition">A spiritual teacher who can contribute to an individual’s progress on the spiritual path to awakening and act wholeheartedly for the welfare of students.</p></div></div></div></div><div id="c4bffd10-82cd-4896-9e12-26dc853c1d68" class="relative scroll-mt-20"><button type="button" id="radix-_R_9q55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.232</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Kāmaśreṣṭha</div><ul class="ml-4 list-disc"><li class="italic">dod pa’i mchog</li><li class="pt-1"><span class="font-tibetan text-base">དོད་པའི་མཆོག</span></li><li class="italic">kāmaśreṣṭha</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">’dod mchog</em>)</p></div></div></div></div><div id="7558493f-9b38-4a75-9131-f935b4102307" class="relative scroll-mt-20"><button type="button" id="radix-_R_9qd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.233</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Kanakabhujendra</div><ul class="ml-4 list-disc"><li class="italic">gser gyi lag pa’i dbang po</li><li class="pt-1"><span class="font-tibetan text-base">གསེར་གྱི་ལག་པའི་དབང་པོ།</span></li><li class="italic">kanakabhujendra</li></ul><div class="glossary-instance-definition"><p class="definition">A son of the king <span data-glossary-id="UT22084-089-013-2831">Suvarṇabhujendra</span>.</p></div></div></div></div><div id="3f1bf63e-f60e-46f8-851b-7fe841df1224" class="relative scroll-mt-20"><button type="button" id="radix-_R_9ql5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.234</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Kanaka­prabhā­svara</div><ul class="ml-4 list-disc"><li class="italic">gser gyi ’od</li><li class="pt-1"><span class="font-tibetan text-base">གསེར་གྱི་འོད།</span></li><li class="italic">kanaka­prabhā­svara</li></ul><div class="glossary-instance-definition"><p class="definition">A son of the king <span data-glossary-id="UT22084-089-013-2831">Suvarṇabhujendra</span>.</p></div></div></div></div><div id="e7af750c-7d25-42ea-9011-d044c6506879" class="relative scroll-mt-20"><button type="button" id="radix-_R_9qt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.235</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Kapila</div><ul class="ml-4 list-disc"><li class="italic">ser skya</li><li class="pt-1"><span class="font-tibetan text-base">སེར་སྐྱ།</span></li><li class="italic">kapila</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">kha dog ser po</em>)</p></div></div></div></div><div id="8d419490-a43b-49a2-8516-47d089d9f888" class="relative scroll-mt-20"><button type="button" id="radix-_R_9r55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.236</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">kārṣāpaṇa</div><ul class="ml-4 list-disc"><li class="italic">kA pa Na</li><li class="pt-1"><span class="font-tibetan text-base">ཀཱ་པ་ཎ།</span></li><li class="italic">kārṣāpaṇa</li></ul><div class="glossary-instance-definition"><p class="definition">A coin that varied in value according to whether it was made of gold, silver, or copper.</p></div></div></div></div><div id="aa2c2a31-ffdb-4887-a677-972a8ec87ca3" class="relative scroll-mt-20"><button type="button" id="radix-_R_9rd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.237</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Kauṇḍinya</div><ul class="ml-4 list-disc"><li class="italic">kauN+Di n+ya</li><li class="pt-1"><span class="font-tibetan text-base">ཀཽཎྜི་ནྱ།</span></li><li class="italic">kauṇḍinya</li></ul><div class="glossary-instance-definition"><p class="definition">According to the Chinese translation, this is the family name (<em class="foreign text-zh" lang="zh">姓</em>) of the <span data-glossary-id="UT22084-089-013-2457">brahmin</span> master <span data-glossary-id="UT22084-089-013-2890">Vyākaraṇa</span>, an interlocutor in <cite class="title text-en" lang="en">The Sūtra of the Sublime Golden Light</cite>.</p></div></div></div></div><div id="0366d57a-2931-4c1e-8029-bfca79b21968" class="relative scroll-mt-20"><button type="button" id="radix-_R_9rl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.238</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Kauśika</div><ul class="ml-4 list-disc"><li class="italic">kau shi ka</li><li class="pt-1"><span class="font-tibetan text-base">ཀཽ་ཤི་ཀ</span></li><li class="italic">kauśika</li></ul><div class="glossary-instance-definition"><p>“One who belongs to the Kuśika lineage.” An epithet of the god Śakra, also known as Indra, the king of the gods in the Trāyastriṃśa heaven. In the Ṛgveda, Indra is addressed by the epithet Kauśika, with the implication that he is associated with the descendants of the Kuśika lineage (<em class="foreign break text-sa" lang="sa-LATN">gotra</em>) as their aiding deity. In later epic and Purāṇic texts, we find the story that Indra took birth as Gādhi Kauśika, the son of Kuśika and one of the Vedic poet-seers, after the Puru king Kuśika had performed austerities for one thousand years to obtain a son equal to Indra who could not be killed by others. In the Pāli <cite class="title break text-sa" lang="sa-LATN">Kusajātaka</cite> (Jāt V 141–45), the Buddha, in one of his former bodhisattva lives as a Trāyastriṃśa god, takes birth as the future king Kusa upon the request of Indra, who wishes to help the childless king of the Mallas, Okkaka, and his chief queen Sīlavatī. This story is also referred to by Nāgasena in the <cite class="title break text-sa" lang="sa-LATN">Milindapañha</cite>.</p></div></div></div></div><div id="44211909-4f96-453b-8a68-861117e1b049" class="relative scroll-mt-20"><button type="button" id="radix-_R_9rt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.239</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Kharaskandha</div><ul class="ml-4 list-disc"><li class="italic">rab tshim byed</li><li class="pt-1"><span class="font-tibetan text-base">རབ་ཚིམ་བྱེད།</span></li><li class="italic">kharaskandha</li></ul><div class="glossary-instance-definition"><p class="definition">An <span data-glossary-id="UT22084-089-013-2559">asura</span> king.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">bong bu dpung</em>; Toh 556 Degé: <em class="foreign text-wy" lang="bo-LATN">rab tshim byed</em>; Toh 557 Yongle and Peking: <em class="foreign text-wy" lang="bo-LATN">rab sil byed</em>)</p></div></div></div></div><div id="70014dd8-67ec-4be2-9261-1c8857a47732" class="relative scroll-mt-20"><button type="button" id="radix-_R_9s55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.240</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">King Array of Pure Prayers</div><ul class="ml-4 list-disc"><li class="italic">smon lam rnam par bkod pa’i rgyal po</li><li class="pt-1"><span class="font-tibetan text-base">སྨོན་ལམ་རྣམ་པར་བཀོད་པའི་རྒྱལ་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">The name prophesied for the <span data-glossary-id="UT22084-089-013-2450">bhikṣus</span> who will attain buddhahood in the <span data-glossary-id="UT22084-089-013-2480">eon</span> <span data-glossary-id="UT22084-089-013-2477">Difficult to Conquer King of Radiance</span>, in the realm called <span data-glossary-id="UT22084-089-013-2946">Vimalaprabhā</span>.</p><p class="definition">(Toh 555: <em class="foreign break text-sa" lang="sa-LATN">Praṇidhāna­vyūhalaṃkāra­rāja</em>; <em class="foreign text-wy" lang="bo-LATN">smon lam gyi bkod pas brgyan pa’i rgyal po</em>)</p></div></div></div></div><div id="818b8a98-c363-42fc-946e-b5d436944647" class="relative scroll-mt-20"><button type="button" id="radix-_R_9sd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.241</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">King Fearless Powerful Array</div><ul class="ml-4 list-disc"><li class="italic">spobs pa chen pos bkod pa’i rgyal po</li><li class="pt-1"><span class="font-tibetan text-base">སྤོབས་པ་ཆེན་པོས་བཀོད་པའི་རྒྱལ་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">spobs pa chen po’i rgyan gyi rgyal po</em>)</p></div></div></div></div><div id="803c1d4b-4952-4233-a680-88fc3bf5bff7" class="relative scroll-mt-20"><button type="button" id="radix-_R_9sl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.242</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">King of Illumination</div><ul class="ml-4 list-disc"><li class="italic">snang ba’i rgyal po</li><li class="pt-1"><span class="font-tibetan text-base">སྣང་བའི་རྒྱལ་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p></div></div></div></div><div id="f7eea1b0-d065-4761-92b6-d605ef563d5d" class="relative scroll-mt-20"><button type="button" id="radix-_R_9st5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.243</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">King of Supreme Mount Meru</div><ul class="ml-4 list-disc"><li class="italic">lhun po’i rgyal po</li><li class="pt-1"><span class="font-tibetan text-base">ལྷུན་པོའི་རྒྱལ་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p></div></div></div></div><div id="6efa6098-a749-48c8-ba73-e629967e1352" class="relative scroll-mt-20"><button type="button" id="radix-_R_9t55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.244</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">kinnara</div><ul class="ml-4 list-disc"><li class="italic">mi ’am ci, mi’am ci</li><li class="pt-1"><span class="font-tibetan text-base">མི་འམ་ཅི།, མིའམ་ཅི།</span></li><li class="italic">kinnara, kiṃnara</li></ul><div class="glossary-instance-definition"><p class="definition">A class of nonhuman beings that resemble humans to the degree that their very name‍—which means “is that human?”‍—suggests some confusion as to their divine status. Kinnaras are mythological beings found in both Buddhist and Brahmanical literature, where they are portrayed as creatures half human, half animal. They are often depicted as highly skilled celestial musicians.</p></div></div></div></div><div id="7f569129-9d7a-4745-8cfb-a83dd02390a8" class="relative scroll-mt-20"><button type="button" id="radix-_R_9td5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.245</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Kṛtajña</div><ul class="ml-4 list-disc"><li class="italic">byas pa gzo ba</li><li class="pt-1"><span class="font-tibetan text-base">བྱས་པ་གཟོ་བ།</span></li><li class="italic">kṛtajña</li></ul><div class="glossary-instance-definition"><p class="definition">Known in the Avadāna literature as a previous life of the Buddha, his name is translated there as <em class="foreign text-wy" lang="bo-LATN">byas shes</em>. In that tale, his brother (a previous life of Devadatta) gouges out his eyes. Nonetheless, a princess chooses him for a husband and is banished by her father, the king. When she speaks the words of truth of her love for him, one of Kṛtajña’s eyes is restored. When he speaks the words of truth that he has no hate for his brother, his other eye is restored, and he is enthroned by the king as his successor.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">drin gzo</em>)</p></div></div></div></div><div id="97ae6f4e-7b36-4074-b55a-94f47679707c" class="relative scroll-mt-20"><button type="button" id="radix-_R_9tl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.246</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">kṣatriya</div><ul class="ml-4 list-disc"><li class="italic">rgyal rigs</li><li class="pt-1"><span class="font-tibetan text-base">རྒྱལ་རིགས།</span></li><li class="italic">kṣatriya</li></ul><div class="glossary-instance-definition"><p class="definition">The warrior or aristocratic class of the four social classes of India. Rulers were often from this class.</p></div></div></div></div><div id="16ff29f2-2c38-4e2d-a90b-ed12c092a5c7" class="relative scroll-mt-20"><button type="button" id="radix-_R_9tt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.247</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Kṣitigarbha</div><ul class="ml-4 list-disc"><li class="italic">sa’i snying po</li><li class="pt-1"><span class="font-tibetan text-base">སའི་སྙིང་པོ།</span></li><li class="italic">kṣitigarbha</li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p></div></div></div></div><div id="81b11a50-901c-4362-8456-b7c320ab5cff" class="relative scroll-mt-20"><button type="button" id="radix-_R_9u55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.248</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Kumāra</div><ul class="ml-4 list-disc"><li class="italic">gzhon nu</li><li class="pt-1"><span class="font-tibetan text-base">གཞོན་ནུ།</span></li><li class="italic">Kumāra</li></ul><div class="glossary-instance-definition"><p class="definition">A polite address for a young man, it can, in context, also mean “prince.”</p></div></div></div></div><div id="f252bdb7-ef16-42f8-ab89-314e798cb2da" class="relative scroll-mt-20"><button type="button" id="radix-_R_9ud5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.249</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">kumbhāṇḍa</div><ul class="ml-4 list-disc"><li class="italic">grul bum</li><li class="pt-1"><span class="font-tibetan text-base">གྲུལ་བུམ།</span></li><li class="italic">kumbhāṇḍa</li></ul><div class="glossary-instance-definition"><p class="definition">A class of dwarf beings subordinate to Virūḍhaka, one of the Four Great Kings, associated with the southern direction. The name uses a play on the word <em class="foreign">aṇḍa</em>, which means “egg” but is also a euphemism for a testicle. Thus, they are often depicted as having testicles as big as pots (from <em class="foreign">kumbha</em>, or “pot”).</p></div></div></div></div><div id="c9846b00-4b53-40f7-9ab1-3d390baeff41" class="relative scroll-mt-20"><button type="button" id="radix-_R_9ul5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.250</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Kumbhīra</div><ul class="ml-4 list-disc"><li class="italic">ji ’jigs</li><li class="pt-1"><span class="font-tibetan text-base">ཇི་འཇིགས།</span></li><li class="italic">kumbhīra</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king; also known as Kubera.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">ku be ra</em>)</p></div></div></div></div><div id="8d3b6aa2-1554-47f0-932e-65c0b98124d8" class="relative scroll-mt-20"><button type="button" id="radix-_R_9ut5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.251</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Kūṭadantī</div><ul class="ml-4 list-disc"><li class="italic">so brtsegs</li><li class="pt-1"><span class="font-tibetan text-base">སོ་བརྩེགས།</span></li><li class="italic">kūṭadantī</li></ul><div class="glossary-instance-definition"><p class="definition">A fierce goddess.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">so brtsegs ma</em>)</p></div></div></div></div><div id="83cef396-e5d4-4358-9bd2-076af1d9b37c" class="relative scroll-mt-20"><button type="button" id="radix-_R_9v55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.252</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Licchavī</div><ul class="ml-4 list-disc"><li class="italic">lits+tsha bI</li><li class="pt-1"><span class="font-tibetan text-base">ལིཙྪ་བཱི།</span></li><li class="italic">licchavī</li></ul><div class="glossary-instance-definition"><p class="definition">A clan with its capital Vaiśalī, in present-day Bihar, north of the <span data-glossary-id="UT22084-089-013-3197">Ganges</span>. Their capital was a place where the Buddha had many followers when they were an independent republic.</p></div></div></div></div><div id="33c62823-8c0a-4d0e-af7c-0142a280b203" class="relative scroll-mt-20"><button type="button" id="radix-_R_9vd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.253</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Lightning Tongue</div><ul class="ml-4 list-disc"><li class="italic">glog lce</li><li class="pt-1"><span class="font-tibetan text-base">གློག་ལྕེ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2503">nāga</span> king.</p></div></div></div></div><div id="780c0037-ad5c-4121-9e9b-71d6b1bc70f2" class="relative scroll-mt-20"><button type="button" id="radix-_R_9vl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.254</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">linseed</div><ul class="ml-4 list-disc"><li class="italic">dbyi mo</li><li class="pt-1"><span class="font-tibetan text-base">དབྱི་མོ།</span></li><li class="italic">cavya</li></ul><div class="glossary-instance-definition"><p class="definition">Oil from the seed of the flax plant (<em class="foreign">Linum usitatissimum</em>).</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">smig bcud</em>)</p></div></div></div></div><div id="e2725cd4-ff09-4c6d-9ddf-c4d7e548c083" class="relative scroll-mt-20"><button type="button" id="radix-_R_9vt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.255</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Lion’s Light</div><ul class="ml-4 list-disc"><li class="italic">seng ge’i ’od</li><li class="pt-1"><span class="font-tibetan text-base">སེང་གེའི་འོད།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2496">Licchavī</span> youth.</p></div></div></div></div><div id="d6a2a346-aec3-4600-a234-f0b1f8606ab4" class="relative scroll-mt-20"><button type="button" id="radix-_R_a055anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.256</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Lord with Jeweled Hands</div><ul class="ml-4 list-disc"><li class="italic">lag na rin chen dbang phyug</li><li class="pt-1"><span class="font-tibetan text-base">ལག་ན་རིན་ཆེན་དབང་ཕྱུག</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">rin po che’i phyag dbang phyug</em>)</p></div></div></div></div><div id="f4435f0e-8534-4ffc-a33c-75dee8dec384" class="relative scroll-mt-20"><button type="button" id="radix-_R_a0d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.257</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Lotus Face</div><ul class="ml-4 list-disc"><li class="italic">pad+mo’i gdong</li><li class="pt-1"><span class="font-tibetan text-base">པདྨོའི་གདོང་།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span>.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">padma’i bzhin</em>)</p></div></div></div></div><div id="655529d7-bddc-41de-937b-b35612717330" class="relative scroll-mt-20"><button type="button" id="radix-_R_a0l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.258</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahābala</div><ul class="ml-4 list-disc"><li class="italic">stobs chen</li><li class="pt-1"><span class="font-tibetan text-base">སྟོབས་ཆེན།</span></li><li class="italic">mahābala</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2503">nāga</span> king.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">stobs po che</em>)</p></div></div></div></div><div id="5ff2846b-7d20-4767-962b-2367e5a25af8" class="relative scroll-mt-20"><button type="button" id="radix-_R_a0t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.259</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahābhāga</div><ul class="ml-4 list-disc"><li class="italic">skal ba chen po</li><li class="pt-1"><span class="font-tibetan text-base">སྐལ་བ་ཆེན་པོ།</span></li><li class="italic">mahābhāga</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king.</p></div></div></div></div><div id="7d2c00ca-715b-4899-b2fe-cc750687c66c" class="relative scroll-mt-20"><button type="button" id="radix-_R_a155anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.260</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahābrahmā</div><ul class="ml-4 list-disc"><li class="italic">tshangs chen</li><li class="pt-1"><span class="font-tibetan text-base">ཚངས་ཆེན།</span></li><li class="italic">mahābrahmā</li></ul><div class="glossary-instance-definition"><p class="definition">“Great <span data-glossary-id="UT22084-089-013-2896">Brahmā</span>.” The highest of the three (or, in this sūtra, four) paradises that correspond to the first <span data-glossary-id="UT22084-089-013-2564">dhyāna</span> in the form realm.</p></div></div></div></div><div id="599f6cf5-8529-4072-b98f-c335ca718227" class="relative scroll-mt-20"><button type="button" id="radix-_R_a1d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.261</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahābrahmā</div><ul class="ml-4 list-disc"><li class="italic">tshangs chen, tshangs pa chen</li><li class="pt-1"><span class="font-tibetan text-base">ཚངས་ཆེན།, ཚངས་པ་ཆེན།</span></li><li class="italic">mahābrahmā</li></ul><div class="glossary-instance-definition"><p class="definition">See “<span data-glossary-id="UT22084-089-013-2896">Brahmā</span>.”</p></div></div></div></div><div id="ef3f3971-bcf4-4c04-b58c-0e8906b3e3e9" class="relative scroll-mt-20"><button type="button" id="radix-_R_a1l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.262</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahācakravāḍa</div><ul class="ml-4 list-disc"><li class="italic">khor yug chen po</li><li class="pt-1"><span class="font-tibetan text-base">ཁོར་ཡུག་ཆེན་པོ།</span></li><li class="italic">mahācakravāḍa</li></ul><div class="glossary-instance-definition"><p class="definition">This appears to refer to the great circles of mountains that enclose a thousand worlds, each with its own <span data-glossary-id="UT22084-089-013-2914">Cakravāḍa</span>.</p></div></div></div></div><div id="54354dbb-3a96-4443-aef4-acd92bc1c8ac" class="relative scroll-mt-20"><button type="button" id="radix-_R_a1t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.263</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahādeva</div><ul class="ml-4 list-disc"><li class="italic">lha chen po</li><li class="pt-1"><span class="font-tibetan text-base">ལྷ་ཆེན་པོ།</span></li><li class="italic">mahādeva</li></ul><div class="glossary-instance-definition"><p class="definition">A prince in the past, the middle son of the King <span data-glossary-id="UT22084-089-013-2727">Mahāratha</span>.</p></div></div></div></div><div id="8401386a-e37d-4039-895b-9eabe1655320" class="relative scroll-mt-20"><button type="button" id="radix-_R_a255anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.264</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahāghoṣa</div><ul class="ml-4 list-disc"><li class="italic">sgra chen</li><li class="pt-1"><span class="font-tibetan text-base">སྒྲ་ཆེན།</span></li><li class="italic">mahāghoṣa</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2503">nāga</span> king.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">sgra bo che</em>)</p></div></div></div></div><div id="4c029921-fe4e-4f8c-a9b0-f99cd0592bb6" class="relative scroll-mt-20"><button type="button" id="radix-_R_a2d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.265</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahāgrāsa</div><ul class="ml-4 list-disc"><li class="italic">kham po che</li><li class="pt-1"><span class="font-tibetan text-base">ཁམ་པོ་ཆེ།</span></li><li class="italic">mahāgrāsa</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king.</p><p class="definition">(Toh 557: <em class="foreign text-wy" lang="bo-LATN">kam po ji</em> (corrupt), Toh 555: <em class="foreign text-wy" lang="bo-LATN">mchog tu rgyal ba</em>)</p></div></div></div></div><div id="6ebc760a-e7fa-478c-9bbe-3efbe5748dbf" class="relative scroll-mt-20"><button type="button" id="radix-_R_a2l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.266</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahākāla</div><ul class="ml-4 list-disc"><li class="italic">nag po</li><li class="pt-1"><span class="font-tibetan text-base">ནག་པོ།</span></li><li class="italic">mahākāla</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> lord.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">nag po che</em>)</p></div></div></div></div><div id="7fe2e4f5-7ce7-4210-8d25-0a0a1c0393a6" class="relative scroll-mt-20"><button type="button" id="radix-_R_a2t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.267</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahākāśyapa</div><ul class="ml-4 list-disc"><li class="italic">’od srung chen po</li><li class="pt-1"><span class="font-tibetan text-base">འོད་སྲུང་ཆེན་པོ།</span></li><li class="italic">mahākāśyapa</li></ul><div class="glossary-instance-definition"><p class="definition">One of the Buddha’s principal pupils, who became a leader of the <span data-glossary-id="UT22084-089-013-2522">saṅgha</span> after the Buddha’s passing.</p></div></div></div></div><div id="69a9cbc7-a145-499e-be6c-54c36e84f199" class="relative scroll-mt-20"><button type="button" id="radix-_R_a355anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.268</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahāmaudgalyāyana, Maudgalyāyana</div><ul class="ml-4 list-disc"><li class="italic">maud gal gyi bu chen po</li><li class="pt-1"><span class="font-tibetan text-base">མཽད་གལ་གྱི་བུ་ཆེན་པོ།</span></li><li class="italic">mahāmaudgalyāyana</li></ul><div class="glossary-instance-definition"><p class="definition">One of the principal <span data-glossary-id="UT22084-089-013-2585">śrāvaka</span> disciples of the Buddha, paired with <span data-glossary-id="UT22084-089-013-2807">Śāriputra</span>. He was renowned for his miraculous <span data-glossary-id="UT22084-089-013-2512">powers</span>. His family clan was descended from Mudgala, hence his name Maudgalyāyana, “the son of Mudgala’s descendants.” Respectfully referred to as Mahāmaudgalyāyana.</p></div></div></div></div><div id="440e86f7-0317-4ed0-b5a8-878867898223" class="relative scroll-mt-20"><button type="button" id="radix-_R_a3d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.269</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahānāman</div><ul class="ml-4 list-disc"><li class="italic">ming chen</li><li class="pt-1"><span class="font-tibetan text-base">མིང་ཆེན།</span></li><li class="italic">mahānāman</li></ul><div class="glossary-instance-definition"><p class="definition">One of the Buddha’s five companions in asceticism before his enlightenment and later one of his first five pupils, he attained the state of a <span data-glossary-id="UT22084-089-013-2529">stream entrant</span> after three days, the fourth to attain that realization. He attained the state of an <span data-glossary-id="UT22084-089-013-2437">arhat</span> on hearing <cite class="title text-en" lang="en">The Sūtra on the Characteristics of Selflessness</cite>. Not to be confused with the cousin of the Buddha, who had the same name and was a significant lay follower and patron.</p></div></div></div></div><div id="f28df2d3-a1f8-42a4-99b5-bb26459a27ce" class="relative scroll-mt-20"><button type="button" id="radix-_R_a3l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.270</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahāpāla</div><ul class="ml-4 list-disc"><li class="italic">chos skyong</li><li class="pt-1"><span class="font-tibetan text-base">ཆོས་སྐྱོང་།</span></li><li class="italic">mahāpāla</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king.</p></div></div></div></div><div id="043ec0da-f3f0-4b81-99c2-27804ff8d946" class="relative scroll-mt-20"><button type="button" id="radix-_R_a3t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.271</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahāpiṅgala</div><ul class="ml-4 list-disc"><li class="italic">ping ga la chen po</li><li class="pt-1"><span class="font-tibetan text-base">པིང་ག་ལ་ཆེན་པོ།</span></li><li class="italic">mahāpiṅgala</li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">ma hā ping ga la</em>)</p></div></div></div></div><div id="d16662fa-d2f2-414b-9bd1-f2579e556ca1" class="relative scroll-mt-20"><button type="button" id="radix-_R_a455anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.272</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahāprabha</div><ul class="ml-4 list-disc"><li class="italic">’od chen</li><li class="pt-1"><span class="font-tibetan text-base">འོད་ཆེན།</span></li><li class="italic">mahāprabha</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2496">Licchavī</span> youth.</p></div></div></div></div><div id="a21dd26d-2823-452c-bd32-2587ab28028d" class="relative scroll-mt-20"><button type="button" id="radix-_R_a4d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.273</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahāpradīpa</div><ul class="ml-4 list-disc"><li class="italic">sgron ma chen po</li><li class="pt-1"><span class="font-tibetan text-base">སྒྲོན་མ་ཆེན་པོ།</span></li><li class="italic">mahāpradīpa</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2587">tathāgata</span>. </p><p class="definition">(Toh 555: <em class="foreign break text-sa" lang="sa-LATN">Mahāpradīpaprabha</em>; <em class="foreign text-wy" lang="bo-LATN">sgron ma chen po’i ’od</em>)</p></div></div></div></div><div id="a9cdc127-a0df-4b87-81d3-81884dcf0489" class="relative scroll-mt-20"><button type="button" id="radix-_R_a4l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.274</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahāprajāpatī</div><ul class="ml-4 list-disc"><li class="italic">skye dgu’i bdag mo chen mo</li><li class="pt-1"><span class="font-tibetan text-base">སྐྱེ་དགུའི་བདག་མོ་ཆེན་མོ།</span></li><li class="italic">mahāprajāpatī</li></ul><div class="glossary-instance-definition"><p class="definition">The Buddha’s mother’s sister and his stepmother. She was the mother of <span data-glossary-id="UT22084-089-013-2893">Nanda</span>, whom the Buddha later inspired to become a monk, as recorded in two sūtras bearing his name and elsewhere. She became the first <span data-glossary-id="UT22084-089-013-2451">bhikṣuṇī</span> after the death of the Buddha’s father.</p></div></div></div></div><div id="c89acb6f-2f97-4596-b431-a21488261274" class="relative scroll-mt-20"><button type="button" id="radix-_R_a4t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.275</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahāpraṇāda</div><ul class="ml-4 list-disc"><li class="italic">sgra chen po</li><li class="pt-1"><span class="font-tibetan text-base">སྒྲ་ཆེན་པོ།</span></li><li class="italic">mahāpraṇāda</li></ul><div class="glossary-instance-definition"><p class="definition">A prince in the past, the eldest son of King <span data-glossary-id="UT22084-089-013-2727">Mahāratha</span>.</p></div></div></div></div><div id="74f3a194-32a5-4d08-8829-a0cfbe95f161" class="relative scroll-mt-20"><button type="button" id="radix-_R_a555anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.276</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahāpraṇālin</div><ul class="ml-4 list-disc"><li class="italic">yur chen can</li><li class="pt-1"><span class="font-tibetan text-base">ཡུར་ཆེན་ཅན།</span></li><li class="italic">mahāpraṇālin</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king.</p><p class="definition">(Toh 556 Degé: <em class="foreign text-wy" lang="bo-LATN">yul chen can</em>; Toh 557 Degé: <em class="foreign text-wy" lang="bo-LATN">yul chen can</em>; Toh 555: <em class="foreign text-wy" lang="bo-LATN">pra na li chen</em>)</p></div></div></div></div><div id="31f670fc-6f54-431a-9e3a-8105fb7f68a0" class="relative scroll-mt-20"><button type="button" id="radix-_R_a5d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.277</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahāratha</div><ul class="ml-4 list-disc"><li class="italic">shing rta chen po</li><li class="pt-1"><span class="font-tibetan text-base">ཤིང་རྟ་ཆེན་པོ།</span></li><li class="italic">mahāratha</li></ul><div class="glossary-instance-definition"><p class="definition">A king in the past.</p></div></div></div></div><div id="bd58d6fe-aed0-4a25-af8c-07773776842f" class="relative scroll-mt-20"><button type="button" id="radix-_R_a5l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.278</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahāratnaketu</div><ul class="ml-4 list-disc"><li class="italic">rin po che’i tog chen po</li><li class="pt-1"><span class="font-tibetan text-base">རིན་པོ་ཆེའི་ཏོག་ཆེན་པོ།</span></li><li class="italic">mahāratnaketu</li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign break text-sa" lang="sa-LATN">Mahāratnadhvaja</em>; <em class="foreign text-wy" lang="bo-LATN">rin po che’i rgyal mtshan chen po</em>)</p></div></div></div></div><div id="d1c7dfac-7376-48af-bc36-07491c77e7ac" class="relative scroll-mt-20"><button type="button" id="radix-_R_a5t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.279</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">mahāsattva</div><ul class="ml-4 list-disc"><li class="italic">sems can chen po</li><li class="pt-1"><span class="font-tibetan text-base">སེམས་ཅན་ཆེན་པོ།</span></li><li class="italic">mahāsattva</li></ul><div class="glossary-instance-definition"><p class="definition">The term can be understood to mean “great courageous one” or "great hero,” or (from the Sanskrit) simply “great being,” and is almost always found as an epithet of “bodhisattva.” The qualification “great” in this term, according to the majority of canonical definitions, focuses on the generic greatness common to all bodhisattvas, i.e., the greatness implicit in the bodhisattva vow itself in terms of outlook, aspiration, number of beings to be benefited, potential or eventual accomplishments, and so forth. In this sense the <em class="foreign break text-sa" lang="sa-LATN">mahā-</em> (“great”) is close in its connotations to the <em class="foreign break text-sa" lang="sa-LATN">mahā-</em> in “Mahāyāna.” While individual bodhisattvas described as <em class="distinct">mahāsattva</em> may in many cases also be “great” in terms of their level of realization, this is largely coincidental, and in the canonical texts the epithet is not restricted to bodhisattvas at any particular point in their career. Indeed, in a few cases even bodhisattvas whose path has taken a wrong direction are still described as <em class="distinct">bodhisattva mahāsattva</em>.</p><p class="definition">Later commentarial writings do nevertheless define the term‍—variably‍—in terms of bodhisattvas having attained a particular level (<em class="foreign break text-sa" lang="sa-LATN">bhūmi</em>) or realization. The most common qualifying criteria mentioned are attaining the path of seeing, attaining irreversibility (according to its various definitions), or attaining the seventh bhūmi.</p></div></div></div></div><div id="0a07a07f-acbb-4b37-9ee3-09bb5e553b06" class="relative scroll-mt-20"><button type="button" id="radix-_R_a655anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.280</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahāsattva</div><ul class="ml-4 list-disc"><li class="italic">snying stobs chen po</li><li class="pt-1"><span class="font-tibetan text-base">སྙིང་སྟོབས་ཆེན་པོ།</span></li><li class="italic">mahāsattva</li></ul><div class="glossary-instance-definition"><p class="definition">A prince in the past, the youngest son of King <span data-glossary-id="UT22084-089-013-2727">Mahāratha</span>. A previous life of the Buddha, when he decided to give his body to a tigress.</p><p class="definition">(Toh 557: <em class="foreign text-wy" lang="bo-LATN">sems can chen po</em>)</p></div></div></div></div><div id="9abf3170-658c-4d8e-83cf-29c9c0f4ce45" class="relative scroll-mt-20"><button type="button" id="radix-_R_a6d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.281</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahāsthāmaprāpta</div><ul class="ml-4 list-disc"><li class="italic">mthu chen thob</li><li class="pt-1"><span class="font-tibetan text-base">མཐུ་ཆེན་ཐོབ།</span></li><li class="italic">mahāsthāmaprāpta</li></ul><div class="glossary-instance-definition"><p class="definition">One of the two principal bodhisattvas in Sukhāvatī and prominent in Chinese Buddhism. In Tibetan Buddhism he is identified with <span data-glossary-id="UT22084-089-013-2850">Vajrapāṇi</span>, though they are separate bodhisattvas in the sūtras.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">mthu chen po thob pa</em>)</p></div></div></div></div><div id="f3fbdf9c-f5a6-4a60-81fa-8e8615d622e0" class="relative scroll-mt-20"><button type="button" id="radix-_R_a6l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.282</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahāyāna</div><ul class="ml-4 list-disc"><li class="italic">theg pa chen po</li><li class="pt-1"><span class="font-tibetan text-base">ཐེག་པ་ཆེན་པོ།</span></li><li class="italic">mahāyāna</li></ul><div class="glossary-instance-definition"><p class="definition">When the Buddhist teachings are classified according to their power to lead beings to an awakened state, a distinction is made between the teachings of the Lesser Vehicle (Hīnayāna), which emphasizes the individual’s own freedom from cyclic existence as the primary motivation and goal, and those of the Great Vehicle (Mahāyāna), which emphasizes altruism and has the liberation of all sentient beings as the principal objective. As the term “Great Vehicle” implies, the path followed by bodhisattvas is analogous to a large carriage that can transport a vast number of people to liberation, as compared to a smaller vehicle for the individual practitioner.</p></div></div></div></div><div id="b06d8d21-2e41-43b6-aabd-d93196ab1e50" class="relative scroll-mt-20"><button type="button" id="radix-_R_a6t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.283</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Maheśvara</div><ul class="ml-4 list-disc"><li class="italic">dbang phyug chen po</li><li class="pt-1"><span class="font-tibetan text-base">དབང་ཕྱུག་ཆེན་པོ།</span></li><li class="italic">maheśvara</li></ul><div class="glossary-instance-definition"><p class="definition">An epithet of Śiva; sometimes refers specifically to one of the forms of Śiva.</p></div></div></div></div><div id="c90f63de-65ce-4551-9c2b-73105430d813" class="relative scroll-mt-20"><button type="button" id="radix-_R_a755anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.284</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">mahoraga</div><ul class="ml-4 list-disc"><li class="italic">lto ’phye chen po</li><li class="pt-1"><span class="font-tibetan text-base">ལྟོ་འཕྱེ་ཆེན་པོ།</span></li><li class="italic">mahoraga</li></ul><div class="glossary-instance-definition"><p class="definition">Literally “great serpents,” mahoragas are supernatural beings depicted as large, subterranean beings with human torsos and heads and the lower bodies of serpents. Their movements are said to cause earthquakes, and they make up a class of subterranean geomantic spirits whose movement through the seasons and months of the year is deemed significant for construction projects.</p></div></div></div></div><div id="d89e365d-201f-4efa-953b-c218d5c56976" class="relative scroll-mt-20"><button type="button" id="radix-_R_a7d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.285</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Maitreya</div><ul class="ml-4 list-disc"><li class="italic">byams pa</li><li class="pt-1"><span class="font-tibetan text-base">བྱམས་པ།</span></li><li class="italic">maitreya</li></ul><div class="glossary-instance-definition"><p class="definition">The bodhisattva Maitreya is an important figure in many Buddhist traditions, where he is unanimously regarded as the buddha of the future era. He is said to currently reside in the heaven of Tuṣita, as Śākyamuni’s regent, where he awaits the proper time to take his final rebirth and become the fifth buddha in the Fortunate Eon, reestablishing the Dharma in this world after the teachings of the current buddha have disappeared. Within the Mahāyāna sūtras, Maitreya is elevated to the same status as other central bodhisattvas such as Mañjuśrī and Avalokiteśvara, and his name appears frequently in sūtras, either as the Buddha’s interlocutor or as a teacher of the Dharma. <em class="foreign break text-sa" lang="sa-LATN">Maitreya</em> literally means “Loving One.” He is also known as Ajita, meaning “Invincible.”</p><p class="definition">For more information on Maitreya, see, for example, the introduction to <cite class="title text-en" lang="en"><a target="_blank" href="https://read.84000.co/translation/toh198.html#UT22084-061-018-3" title="Maitreya’s Setting Out">Maitreya’s Setting Out</a></cite> (Toh 198).</p></div></div></div></div><div id="8e8fa022-dae6-40e7-8891-dc0d87c3be63" class="relative scroll-mt-20"><button type="button" id="radix-_R_a7l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.286</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Malaya</div><ul class="ml-4 list-disc"><li class="italic">ma la ya</li><li class="pt-1"><span class="font-tibetan text-base">མ་ལ་ཡ།</span></li><li class="italic">malaya</li></ul><div class="glossary-instance-definition"><p class="definition">The range of mountains in West India, also called the Western Ghats, known for its <span data-glossary-id="UT22084-089-013-2521">sandalwood</span> forests.</p></div></div></div></div><div id="c613495b-c72c-438b-a6f0-a4aa926afacb" class="relative scroll-mt-20"><button type="button" id="radix-_R_a7t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.287</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Manasvin, Manasvī</div><ul class="ml-4 list-disc"><li class="italic">gzi can, gzi can</li><li class="pt-1"><span class="font-tibetan text-base">གཟི་ཅན།, གཟི་ཅན།</span></li><li class="italic">manasvin, manasvī</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2503">nāga</span>.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">yid bzhin</em>)</p></div></div></div></div><div id="650a9f98-3999-4832-92bd-52826aa74cb2" class="relative scroll-mt-20"><button type="button" id="radix-_R_a855anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.288</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Manasvin, Manasvī</div><ul class="ml-4 list-disc"><li class="italic">gzi can, gzi can</li><li class="pt-1"><span class="font-tibetan text-base">གཟི་ཅན།, གཟི་ཅན།</span></li><li class="italic">manasvin, manasvī</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2503">nāga</span> king.</p></div></div></div></div><div id="f9c67828-6608-4634-8a72-a6c7b1e85991" class="relative scroll-mt-20"><button type="button" id="radix-_R_a8d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.289</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">maṇḍala</div><ul class="ml-4 list-disc"><li class="italic">dkyil ’khor</li><li class="pt-1"><span class="font-tibetan text-base">དཀྱིལ་འཁོར།</span></li><li class="italic">maṇḍala</li></ul><div class="glossary-instance-definition"><p class="definition">Literally a “disk” or “circle,” in the ritual context a maṇḍala is a sacred space on the ground or a raised platform, arranged according to a pattern that varies from rite to rite.</p></div></div></div></div><div id="1fbf92a7-58c5-441f-b0fb-d69c84daa019" class="relative scroll-mt-20"><button type="button" id="radix-_R_a8l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.290</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Maṅgala</div><ul class="ml-4 list-disc"><li class="italic">bkra shis</li><li class="pt-1"><span class="font-tibetan text-base">བཀྲ་ཤིས།</span></li><li class="italic">maṅgala</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2471">deva</span>.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">rnam par bkra shis</em>)</p></div></div></div></div><div id="15ab923a-4b5d-41af-9ca2-750e47823372" class="relative scroll-mt-20"><button type="button" id="radix-_R_a8t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.291</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Maṇibhadra, Māṇibhadra</div><ul class="ml-4 list-disc"><li class="italic">nor bu bzang, nor bu bzang</li><li class="pt-1"><span class="font-tibetan text-base">ནོར་བུ་བཟང་།, ནོར་བུ་བཟང་།</span></li><li class="italic">maṇibhadra, māṇibhadra</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king, the brother of Kubera.</p></div></div></div></div><div id="dd7fc955-81ba-449b-a46c-bd92a483c30c" class="relative scroll-mt-20"><button type="button" id="radix-_R_a955anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.292</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Maṇibhadra, Māṇibhadra</div><ul class="ml-4 list-disc"><li class="italic">nor bu bzang, nor bu bzang</li><li class="pt-1"><span class="font-tibetan text-base">ནོར་བུ་བཟང་།, ནོར་བུ་བཟང་།</span></li><li class="italic">maṇibhadra, māṇibhadra</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> general.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">rin chen bzang</em>)</p></div></div></div></div><div id="71011b45-ce86-404a-89e7-d3db8366d554" class="relative scroll-mt-20"><button type="button" id="radix-_R_a9d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.293</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Manifesting Great Fear</div><ul class="ml-4 list-disc"><li class="italic">’jigs pa chen po ston</li><li class="pt-1"><span class="font-tibetan text-base">འཇིགས་པ་ཆེན་པོ་སྟོན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span>.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">’jigs pa mngon du ston pa</em>)</p></div></div></div></div><div id="b817e463-9b9a-40be-aaba-08763c67fb26" class="relative scroll-mt-20"><button type="button" id="radix-_R_a9l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.294</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Maṇikaṇṭha</div><ul class="ml-4 list-disc"><li class="italic">nor bu’i mgul</li><li class="pt-1"><span class="font-tibetan text-base">ནོར་བུའི་མགུལ།</span></li><li class="italic">maṇikaṇṭha</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">nor bu gtsug</em>)</p></div></div></div></div><div id="c1790dd4-4463-4814-926d-5356a1e2cb7b" class="relative scroll-mt-20"><button type="button" id="radix-_R_a9t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.295</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mañjuśrī, Mañjuśrī Kumārabhuta</div><ul class="ml-4 list-disc"><li class="italic">’jam dpal</li><li class="pt-1"><span class="font-tibetan text-base">འཇམ་དཔལ།</span></li><li class="italic">mañjuśrī</li></ul><div class="glossary-instance-definition"><p class="definition">Mañjuśrī is one of the “eight close sons of the Buddha” and a bodhisattva who embodies wisdom. He is a major figure in the Mahāyāna sūtras, appearing often as an interlocutor of the Buddha. In his most well-known iconographic form, he is portrayed bearing the sword of wisdom in his right hand and a volume of the <cite class="title break text-sa" lang="sa-LATN">Prajñā­pāramitā­sūtra</cite> in his left. To his name, Mañjuśrī, meaning “Gentle and Glorious One,” is often added the epithet Kumārabhūta, “having a youthful form.” He is also called Mañjughoṣa, Mañjusvara, and Pañcaśikha.</p></div></div></div></div><div id="399345bd-b048-4573-9680-22c5c83902ed" class="relative scroll-mt-20"><button type="button" id="radix-_R_aa55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.296</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Markaṭa</div><ul class="ml-4 list-disc"><li class="italic">spre’u</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲེའུ།</span></li><li class="italic">markaṭa</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">spre’u rnams kyi ni rgyal po</em>)</p></div></div></div></div><div id="1bfeb61e-91c1-4b84-958a-d5af003d8b6d" class="relative scroll-mt-20"><button type="button" id="radix-_R_aad5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.297</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">mātṛkā</div><ul class="ml-4 list-disc"><li class="italic">ma mo</li><li class="pt-1"><span class="font-tibetan text-base">མ་མོ།</span></li><li class="italic">mātṛkā</li></ul><div class="glossary-instance-definition"><p class="definition">“Mother goddesses.” Anglicized as <em class="foreign break text-sa" lang="sa-LATN">matrika</em>. A group of goddesses, often eight in number, that correspond to principal male deities. </p></div></div></div></div><div id="d9299ecc-0466-4882-abb8-a2acd686b83b" class="relative scroll-mt-20"><button type="button" id="radix-_R_aal5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.298</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Māyā</div><ul class="ml-4 list-disc"><li class="italic">sgyu ’phrul</li><li class="pt-1"><span class="font-tibetan text-base">སྒྱུ་འཕྲུལ།</span></li><li class="italic">māyā</li></ul><div class="glossary-instance-definition"><p class="definition">The Buddha’s mother, more commonly called Māyādevī.</p></div></div></div></div><div id="834dc5dc-8d4e-47b5-9e05-fa96dd153ea8" class="relative scroll-mt-20"><button type="button" id="radix-_R_aat5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.299</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Meru, Mount Meru, Sumeru</div><ul class="ml-4 list-disc"><li class="italic">ri rab</li><li class="pt-1"><span class="font-tibetan text-base">རི་རབ།</span></li><li class="italic">sumeru</li></ul><div class="glossary-instance-definition"><p>According to ancient Buddhist cosmology, this is the great mountain forming the axis of the universe. At its summit is Sudarśana, home of Śakra and his thirty-two gods, and on its flanks live the asuras. The mount has four sides facing the cardinal directions, each of which is made of a different precious stone. Surrounding it are several mountain ranges and the great ocean where the four principal island continents lie: in the south, Jambudvīpa (our world); in the west, Godānīya; in the north, Uttarakuru; and in the east, Pūrvavideha. Above it are the abodes of the desire realm gods. It is variously referred to as Meru, Mount Meru, Sumeru, and Mount Sumeru.</p></div></div></div></div><div id="6359e7c5-2d23-43d1-9c57-80a7747a6cd7" class="relative scroll-mt-20"><button type="button" id="radix-_R_ab55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.300</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Moon Crest</div><ul class="ml-4 list-disc"><li class="italic">zla ba’i gtsug phud</li><li class="pt-1"><span class="font-tibetan text-base">ཟླ་བའི་གཙུག་ཕུད།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2471">deva</span>.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">zla ba’i gtsug tor</em>)</p></div></div></div></div><div id="7db03410-eea2-43c5-972d-d43a1f218544" class="relative scroll-mt-20"><button type="button" id="radix-_R_abd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.301</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mucilinda</div><ul class="ml-4 list-disc"><li class="italic">btang bzung</li><li class="pt-1"><span class="font-tibetan text-base">བཏང་བཟུང་།</span></li><li class="italic">mucilinda</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2503">nāga</span> king.</p></div></div></div></div><div id="be72558c-5b75-4347-8248-4effa127edb7" class="relative scroll-mt-20"><button type="button" id="radix-_R_abl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.302</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Munīndra</div><ul class="ml-4 list-disc"><li class="italic">thub dbang</li><li class="pt-1"><span class="font-tibetan text-base">ཐུབ་དབང་།</span></li><li class="italic">Munīndra</li></ul><div class="glossary-instance-definition"><p class="definition">“Lord of <span data-glossary-id="UT22084-089-013-2518">sages</span>”; an epithet for the Buddha.</p></div></div></div></div><div id="61de6126-bfc2-4c44-8547-1093346724b3" class="relative scroll-mt-20"><button type="button" id="radix-_R_abt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.303</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">musk</div><ul class="ml-4 list-disc"><li class="italic">skal ba che</li><li class="pt-1"><span class="font-tibetan text-base">སྐལ་བ་ཆེ།</span></li><li class="italic">mahābhāgā</li></ul><div class="glossary-instance-definition"><p class="definition">Also called <em class="foreign break text-sa" lang="sa-LATN">subhaga</em> in Sanskrit. Derived from a gland on the musk deer.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">sha ma ka sha mi</em>. Chinese: <em class="foreign">mojiapojia</em>; <em class="foreign text-zh" lang="zh">莫迦婆伽</em>.)</p></div></div></div></div><div id="fe6c8a12-edd1-453a-bf29-29adced76b67" class="relative scroll-mt-20"><button type="button" id="radix-_R_ac55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.304</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">mustard seed</div><ul class="ml-4 list-disc"><li class="italic">yung kar, yungs ’bru</li><li class="pt-1"><span class="font-tibetan text-base">ཡུང་ཀར།, ཡུངས་འབྲུ།</span></li><li class="italic">sarṣapa</li></ul><div class="glossary-instance-definition"><p class="definition">Variant spelling: <em class="foreign text-wy" lang="bo-LATN">yung dkar</em>; “white mustard.”</p></div></div></div></div><div id="0d780e14-7170-41d5-ad91-08bec33f57ad" class="relative scroll-mt-20"><button type="button" id="radix-_R_acd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.305</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Nadīkāśyapa</div><ul class="ml-4 list-disc"><li class="italic">chu bo ’od srung, chu klung ’od srung</li><li class="pt-1"><span class="font-tibetan text-base">ཆུ་ཀླུང་འོད་སྲུང་།, ཆུ་བོ་འོད་སྲུང་།</span></li><li class="italic">nadīkāśyapa</li></ul><div class="glossary-instance-definition"><p class="definition">The brother of <span data-glossary-id="UT22084-089-013-2651">Gayākāśyapa</span> and <span data-glossary-id="UT22084-089-013-2844">Uruvilva­kāśyapa</span>. A practitioner of fire offering at Uruvilva (Bodhgayā), he and his three hundred students were converted to becoming <span data-glossary-id="UT22084-089-013-2450">bhikṣus</span> of the Buddha. He and his brothers and their students were the third group to become followers of the Buddha after his enlightenment.</p></div></div></div></div><div id="5a08fb0f-b8eb-4159-8018-bfd9bd66d5d9" class="relative scroll-mt-20"><button type="button" id="radix-_R_acl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.306</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">nāga</div><ul class="ml-4 list-disc"><li class="italic">klu</li><li class="pt-1"><span class="font-tibetan text-base">ཀླུ།</span></li><li class="italic">nāga</li></ul><div class="glossary-instance-definition"><p class="definition">A class of nonhuman beings who live in subterranean aquatic environments, where they guard wealth and sometimes also teachings. Nāgas are associated with serpents and have a snakelike appearance. In Buddhist art and in written accounts, they are regularly portrayed as half human and half snake, and they are also said to have the ability to change into human form. Some nāgas are Dharma protectors, but they can also bring retribution if they are disturbed. They may likewise fight one another, wage war, and destroy the lands of others by causing lightning, hail, and flooding.</p></div></div></div></div><div id="f262a892-2e4e-41db-9b21-70270af04e46" class="relative scroll-mt-20"><button type="button" id="radix-_R_act5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.307</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Nāgāyana</div><ul class="ml-4 list-disc"><li class="italic">mthu bo che</li><li class="pt-1"><span class="font-tibetan text-base">མཐུ་བོ་ཆེ།</span></li><li class="italic">nāgāyana</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king.</p><p class="definition">The Tibetan appears to have been translated from a manuscript that had <em class="foreign break text-sa" lang="sa-LATN"><span data-glossary-id="UT22084-089-013-2750">nārāyaṇa</span></em>.</p></div></div></div></div><div id="6ae5df56-e875-4695-8e5e-b75069672faa" class="relative scroll-mt-20"><button type="button" id="radix-_R_ad55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.308</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Nairañjanāvasinī</div><ul class="ml-4 list-disc"><li class="italic">nai rany+dza nar gnas pa</li><li class="pt-1"><span class="font-tibetan text-base">ནཻ་རཉྫ་ནར་གནས་པ།</span></li><li class="italic">nairañjanāvasinī</li></ul><div class="glossary-instance-definition"><p class="definition">Goddess of the Nairañjanā River, near which the Buddha practiced asceticism and later attained enlightenment.</p></div></div></div></div><div id="d4104d7a-d9ed-4904-9412-8f6d5efefb1f" class="relative scroll-mt-20"><button type="button" id="radix-_R_add5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.309</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Nakula</div><ul class="ml-4 list-disc"><li class="italic">khyim med</li><li class="pt-1"><span class="font-tibetan text-base">ཁྱིམ་མེད།</span></li><li class="italic">nakula</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">na ku la</em>)</p></div></div></div></div><div id="a78a7b35-7bb6-43da-be09-cc552fc679b1" class="relative scroll-mt-20"><button type="button" id="radix-_R_adl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.310</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Namuci</div><ul class="ml-4 list-disc"><li class="italic">phrag rtsub</li><li class="pt-1"><span class="font-tibetan text-base">ཕྲག་རྩུབ།</span></li><li class="italic">namuci</li></ul><div class="glossary-instance-definition"><p class="definition">An <span data-glossary-id="UT22084-089-013-2559">asura</span> king; this is the name of <span data-glossary-id="UT22084-089-013-2656">Indra</span>’s principal enemy among the <span data-glossary-id="UT22084-089-013-2559">asuras</span>. In Buddhist mythology, Namuci appears as a drought-causing demon, and is also a name of Māra, the principal opponent of the Buddhadharma.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">phrag chen</em>)</p></div></div></div></div><div id="bcfebd30-f67b-4b80-8b66-7db144ef6c18" class="relative scroll-mt-20"><button type="button" id="radix-_R_adt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.311</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Nanda</div><ul class="ml-4 list-disc"><li class="italic">dga’ bo</li><li class="pt-1"><span class="font-tibetan text-base">དགའ་བོ།</span></li><li class="italic">nanda</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2503">nāga</span> king.</p></div></div></div></div><div id="13ade592-3240-4469-970f-080ab6be7482" class="relative scroll-mt-20"><button type="button" id="radix-_R_ae55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.312</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Nārāyaṇa</div><ul class="ml-4 list-disc"><li class="italic">sred med bu</li><li class="pt-1"><span class="font-tibetan text-base">སྲེད་མེད་བུ།</span></li><li class="italic">nārāyaṇa</li></ul><div class="glossary-instance-definition"><p class="definition">An alternate name for <span data-glossary-id="UT22084-089-013-2863">Viṣṇu</span> (<em class="foreign text-wy" lang="bo-LATN">khyab ’jug</em>).</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">mthu bo che</em>)</p></div></div></div></div><div id="6e85df16-3c81-41db-bc11-5803eefcc4c0" class="relative scroll-mt-20"><button type="button" id="radix-_R_aed5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.313</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Net of Light</div><ul class="ml-4 list-disc"><li class="italic">’od kyi dra ba can</li><li class="pt-1"><span class="font-tibetan text-base">འོད་ཀྱི་དྲ་བ་ཅན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p></div></div></div></div><div id="70028793-c0da-4a9f-ac36-0d5639b49ce4" class="relative scroll-mt-20"><button type="button" id="radix-_R_ael5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.314</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Nikaṇṭha</div><ul class="ml-4 list-disc"><li class="italic">nges mgrin</li><li class="pt-1"><span class="font-tibetan text-base">ངེས་མགྲིན།</span></li><li class="italic">nikaṇṭha</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">ne gan</em>)</p></div></div></div></div><div id="3cc0410b-727f-4184-aca5-f15cdad3b8bd" class="relative scroll-mt-20"><button type="button" id="radix-_R_aet5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.315</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Nirmāṇarati</div><ul class="ml-4 list-disc"><li class="italic">’phrul dga’</li><li class="pt-1"><span class="font-tibetan text-base">འཕྲུལ་དགའ།</span></li><li class="italic">nirmāṇarati</li></ul><div class="glossary-instance-definition"><p class="definition">“Delight in Emanations.” The second highest paradise in the desire realm.</p></div></div></div></div><div id="bebe04fd-2b22-4637-89db-ae1cd69dffe1" class="relative scroll-mt-20"><button type="button" id="radix-_R_af55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.316</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">nirvāṇa</div><ul class="ml-4 list-disc"><li class="italic">mya ngan las ’das pa</li><li class="pt-1"><span class="font-tibetan text-base">མྱ་ངན་ལས་འདས་པ།</span></li><li class="italic">nirvāṇa</li></ul><div class="glossary-instance-definition"><p class="definition">In Sanskrit, the term <em class="foreign break text-sa" lang="sa-LATN">nirvāṇa</em> literally means “extinguishment” and the Tibetan <em class="foreign text-wy" lang="bo-LATN">mya ngan las ’das pa</em> literally means “gone beyond sorrow.” As a general term, it refers to the cessation of all suffering, afflicted mental states (<em class="foreign break text-sa" lang="sa-LATN">kleśa</em>), and causal processes (<em class="foreign break text-sa" lang="sa-LATN">karman</em>) that lead to rebirth and suffering in cyclic existence, as well as to the state in which all such rebirth and suffering has permanently ceased.</p><p class="definition">More specifically, three main types of nirvāṇa are identified. (1) The first type of nirvāṇa, called nirvāṇa with remainder (<em class="foreign break text-sa" lang="sa-LATN">sopadhiśeṣanirvāṇa</em>), is the state in which arhats or buddhas have attained awakening but are still dependent on the conditioned aggregates until their lifespan is exhausted. (2) At the end of life, given that there are no more causes for rebirth, these aggregates cease and no new aggregates arise. What occurs then is called nirvāṇa without remainder (<em class="foreign break text-sa" lang="sa-LATN"> anupadhiśeṣanirvāṇa</em>), which refers to the unconditioned element (<em class="foreign break text-sa" lang="sa-LATN">dhātu</em>) of nirvāṇa in which there is no remainder of the aggregates. (3) The Mahāyāna teachings distinguish the final nirvāṇa of buddhas from that of arhats, the nirvāṇa of arhats not being considered ultimate. The buddhas attain what is called nonabiding nirvāṇa (<em class="foreign break text-sa" lang="sa-LATN">apratiṣṭhitanirvāṇa</em>), which transcends the extremes of saṃsāra and nirvāṇa, i.e., existence and peace. This is the nirvāṇa that is the goal of the Mahāyāna path.</p></div></div></div></div><div id="60d12d7e-1f7e-4517-b2d1-5bae24cae7db" class="relative scroll-mt-20"><button type="button" id="radix-_R_afd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.317</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Nityodyukta</div><ul class="ml-4 list-disc"><li class="italic">rtag tu brtson pa</li><li class="pt-1"><span class="font-tibetan text-base">རྟག་ཏུ་བརྩོན་པ།</span></li><li class="italic">nityodyukta</li></ul><div class="glossary-instance-definition"><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">brtson ’grus yongs su ldan pa</em>)</p></div></div></div></div><div id="3b40a3c1-0d93-4bb7-a3ad-c5d0ab096f71" class="relative scroll-mt-20"><button type="button" id="radix-_R_afl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.318</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">non-returner</div><ul class="ml-4 list-disc"><li class="italic">phyir mi ’ong ba</li><li class="pt-1"><span class="font-tibetan text-base">ཕྱིར་མི་འོང་བ།</span></li><li class="italic">anāgāmin</li></ul><div class="glossary-instance-definition"><p class="definition">The third of the four attainments of śrāvakas, this term refers to a person who will no longer take rebirth in the desire realm (<em class="foreign break text-sa" lang="sa-LATN">kāmadhātu</em>), but either be reborn in the Pure Abodes (<em class="foreign break text-sa" lang="sa-LATN">śuddhāvāsa</em>) or reach the state of an arhat in their current lifetime. (<em class="distinct">Provisional 84000 definition. New definition forthcoming.</em>)</p></div></div></div></div><div id="89375010-20fa-46f9-a3aa-8db0788ca507" class="relative scroll-mt-20"><button type="button" id="radix-_R_aft5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.319</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">nut grass</div><ul class="ml-4 list-disc"><li class="italic">gla sgang</li><li class="pt-1"><span class="font-tibetan text-base">གླ་སྒང་།</span></li><li class="italic">musta</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign">Cyperus rotundus</em>. Its tubers are used in <span data-glossary-id="UT22084-089-013-2445">Āyurveda</span>. </p><p class="definition">(Toh 557: <em class="foreign text-wy" lang="bo-LATN">gas gang</em>)</p></div></div></div></div><div id="4cce357a-a5a4-4bef-8c8b-3341c68446c8" class="relative scroll-mt-20"><button type="button" id="radix-_R_ag55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.320</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">once-returner</div><ul class="ml-4 list-disc"><li class="italic">lan cig phyir ’ong ba</li><li class="pt-1"><span class="font-tibetan text-base">ལན་ཅིག་ཕྱིར་འོང་བ།</span></li><li class="italic">sakṛdāgāmin</li></ul><div class="glossary-instance-definition"><p>One who has achieved the second of the four levels of attainment on the śrāvaka path and who will attain liberation after only one more birth. (<em class="distinct">Provisional 84000 definition. New definition forthcoming.</em>)</p></div></div></div></div><div id="07a5c660-5d19-4b02-80cc-369f6e76c919" class="relative scroll-mt-20"><button type="button" id="radix-_R_agd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.321</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">orris root</div><ul class="ml-4 list-disc"><li class="italic">in+d+ra hasta</li><li class="pt-1"><span class="font-tibetan text-base">ཨིནྡྲ་ཧསྟ།</span></li><li class="italic">indrahasta</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign">Bletilla hyacinthina</em>, hyacinth orchid. See Ludvik 2007, p. 310. Or possibly <em class="foreign">Rhizoma iridis</em>. The root of the iris flower, specifically the Indian iris (<em class="foreign">Iris pallida</em>). The root is said to resemble an arm, while the leaves resemble swords, and therefore there is a folktale of its having originated from <span data-glossary-id="UT22084-089-013-2656">Indra</span> cutting off a <span data-glossary-id="UT22084-089-013-2555">yakṣa</span>’s arm.</p><p class="definition">(Toh 557: <em class="foreign text-wy" lang="bo-LATN">dbang po’i lag</em>)</p></div></div></div></div><div id="f05c4f1c-f3df-4e9f-98e0-4d3b8c1d31d9" class="relative scroll-mt-20"><button type="button" id="radix-_R_agl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.322</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Padma</div><ul class="ml-4 list-disc"><li class="italic">pad+mo</li><li class="pt-1"><span class="font-tibetan text-base">པདྨོ།</span></li><li class="italic">padma</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2503">nāga</span> king.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">pad ma</em>)</p></div></div></div></div><div id="6df1351f-0981-47ac-afca-0077283aa977" class="relative scroll-mt-20"><button type="button" id="radix-_R_agt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.323</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Padmā</div><ul class="ml-4 list-disc"><li class="italic">pe ma</li><li class="pt-1"><span class="font-tibetan text-base">པེ་མ།</span></li><li class="italic">padmā</li></ul><div class="glossary-instance-definition"><p class="definition">One of the names of Lakṣmī, also known as <span data-glossary-id="UT22084-089-013-3204">Śrī</span>.</p></div></div></div></div><div id="c4c98d59-9279-4737-96dc-efc6d1309e86" class="relative scroll-mt-20"><button type="button" id="radix-_R_ah55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.324</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Padmottara­suvarṇa­dhvaja</div><ul class="ml-4 list-disc"><li class="italic">pad+ma dam pa gser gyi rgyal mtshan</li><li class="pt-1"><span class="font-tibetan text-base">པདྨ་དམ་པ་གསེར་གྱི་རྒྱལ་མཚན།</span></li><li class="italic">padmottara­suvarṇa­dhvaja</li></ul><div class="glossary-instance-definition"><p class="definition">“Sublime Lotus Golden Banner.” The palace of the <span data-glossary-id="UT22084-089-013-3204">goddess Śrī</span>, also known as Lakṣmī.</p></div></div></div></div><div id="99488b70-58af-4e3f-9d14-0ed8afe93b2c" class="relative scroll-mt-20"><button type="button" id="radix-_R_ahd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.325</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">palash</div><ul class="ml-4 list-disc"><li class="italic">pa la sha</li><li class="pt-1"><span class="font-tibetan text-base">པ་ལ་ཤ།</span></li><li class="italic">palāśa</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign">Butea frondosa</em> or <em class="foreign">Butea monosperma</em>. A tree that grows up to 15 meters tall and has bright red flowers. Other names include flame of the forest, riddle tree, Judas tree, parrot tree, bastard teak, dhak (in Hindi), palas (in Hindi), porasum (in Tamil), and khakda (in Gujarati). There is a tradition of combining its leaves together to make a plate for food.</p><p class="definition">This is also known as <em class="foreign break text-sa" lang="sa-LATN">kiṃśuka</em>, which is translated in other sūtras as <em class="foreign text-wy" lang="bo-LATN">ne tso ci las grub pa</em>.</p></div></div></div></div><div id="a1890c4c-4745-469b-81b0-83beb8ef9e5e" class="relative scroll-mt-20"><button type="button" id="radix-_R_ahl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.326</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Pañcāla</div><ul class="ml-4 list-disc"><li class="italic">lnga len</li><li class="pt-1"><span class="font-tibetan text-base">ལྔ་ལེན།</span></li><li class="italic">pañcāla</li></ul><div class="glossary-instance-definition"><p class="definition">One of the fifteen lands in ancient India at the time of the Buddha. This was at the western end of the <span data-glossary-id="UT22084-089-013-3197">Ganges</span> basin, corresponding in the present time to an area in the western part of Uttar Pradesh.</p></div></div></div></div><div id="715f7321-d900-4d5c-9a42-76f2c0565587" class="relative scroll-mt-20"><button type="button" id="radix-_R_aht5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.327</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Pañcaśikha</div><ul class="ml-4 list-disc"><li class="italic">zur phud lnga can</li><li class="pt-1"><span class="font-tibetan text-base">ཟུར་ཕུད་ལྔ་ཅན།</span></li><li class="italic">pañcaśikha</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2486">gandharva</span> said to live on <span data-glossary-id="UT22084-089-013-2916">Gandhamādana</span> Mountain, on the central peak of five peaks, at the source of the <span data-glossary-id="UT22084-089-013-3197">Ganges</span>. In the early sūtras he acts as a messenger between the <span data-glossary-id="UT22084-089-013-2471">devas</span> and the Buddha. He is sometimes said to be a form of <span data-glossary-id="UT22084-089-013-2739">Mañjuśrī</span> or historically to have been his original identity. </p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">mgo lnga</em>)</p></div></div></div></div><div id="c375bb0c-451a-4d51-8ab9-7d150e7f88ce" class="relative scroll-mt-20"><button type="button" id="radix-_R_ai55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.328</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Pāñcika</div><ul class="ml-4 list-disc"><li class="italic">lngas rtsen</li><li class="pt-1"><span class="font-tibetan text-base">ལྔས་རྩེན།</span></li><li class="italic">pāñcika</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">pañ ts i ka</em>)</p></div></div></div></div><div id="e4cf94ae-483b-44c6-9bab-efb770053ad6" class="relative scroll-mt-20"><button type="button" id="radix-_R_aid5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.329</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Paranirmita­vaśavartin</div><ul class="ml-4 list-disc"><li class="italic">gzhan ’phrul dbang byed</li><li class="pt-1"><span class="font-tibetan text-base">གཞན་འཕྲུལ་དབང་བྱེད།</span></li><li class="italic">paranirmita­vaśavartin</li></ul><div class="glossary-instance-definition"><p class="definition">“Power Over the Emanations of Others.” The highest paradise in the desire realm.</p></div></div></div></div><div id="09fe7948-20b9-408c-869d-71e3d970390a" class="relative scroll-mt-20"><button type="button" id="radix-_R_ail5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.330</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Parīttābha</div><ul class="ml-4 list-disc"><li class="italic">’od chung</li><li class="pt-1"><span class="font-tibetan text-base">འོད་ཆུང་།</span></li><li class="italic">parīttābha</li></ul><div class="glossary-instance-definition"><p class="definition">“Lesser Light.” The lowest of the three paradises that correspond to the second <span data-glossary-id="UT22084-089-013-2564">dhyāna</span> in the form realm. The lowest paradise that is never destroyed at the end of a kalpa, but continues through all kalpas. In other texts translated as <em class="foreign text-wy" lang="bo-LATN">snang ba chung ngu</em>.</p></div></div></div></div><div id="249ddf15-b2a4-4012-a907-5f3ff0ad90be" class="relative scroll-mt-20"><button type="button" id="radix-_R_ait5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.331</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Parīttaśubha</div><ul class="ml-4 list-disc"><li class="italic">dge chung</li><li class="pt-1"><span class="font-tibetan text-base">དགེ་ཆུང་།</span></li><li class="italic">parīttaśubha</li></ul><div class="glossary-instance-definition"><p class="definition">“Lesser Goodness.” The lowest of the three paradises that correspond to the third <span data-glossary-id="UT22084-089-013-2564">dhyāna</span> in the form realm.</p></div></div></div></div><div id="6b9b7665-ee51-41cd-833b-74b4cbfb3e7e" class="relative scroll-mt-20"><button type="button" id="radix-_R_aj55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.332</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">perfections</div><ul class="ml-4 list-disc"><li class="italic">pha rol tu phyin pa</li><li class="pt-1"><span class="font-tibetan text-base">ཕ་རོལ་ཏུ་ཕྱིན་པ།</span></li><li class="italic">pāramitā</li></ul><div class="glossary-instance-definition"><p class="definition">This term is used to refer to the main trainings of a bodhisattva. Because these trainings, when brought to perfection, lead one to transcend <span data-glossary-id="UT22084-089-013-2583">saṃsāra</span> and reach the full awakening of a buddha, they receive the Sanskrit name <em class="foreign break text-sa" lang="sa-LATN">pāramitā</em>, meaning “perfection” or “gone to the farther shore.” They are usually listed as six: generosity, correct conduct (or discipline), patience, diligence, meditation (or concentration), and wisdom; four additional perfections are often added to this, totalling ten perfections: skillful methods, prayer, strength, and knowledge. </p><p class="definition">For a presentation of each one according to the view of this sūtra, see <a href="https://read.84000.co/translation/toh555#UT22084-089-012-1077" target="UT22084-089-012.html" data-pointer-type="id">6.6</a>–<a href="https://read.84000.co/translation/toh555#UT22084-089-012-1129" target="UT22084-089-012.html" data-pointer-type="id">6.27</a>.</p></div></div></div></div><div id="47cf2030-d18d-4774-b6c7-77f890ad8da4" class="relative scroll-mt-20"><button type="button" id="radix-_R_ajd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.333</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Piṅgala</div><ul class="ml-4 list-disc"><li class="italic">dmar ser</li><li class="pt-1"><span class="font-tibetan text-base">དམར་སེར།</span></li><li class="italic">piṅgala</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">zas sbyin</em>)</p></div></div></div></div><div id="6238d630-313e-4fe0-9fe5-8646ed29a756" class="relative scroll-mt-20"><button type="button" id="radix-_R_ajl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.334</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Pinnacle of Lords</div><ul class="ml-4 list-disc"><li class="italic">dbang po’i tog</li><li class="pt-1"><span class="font-tibetan text-base">དབང་པོའི་ཏོག</span></li></ul><div class="glossary-instance-definition"><p class="definition">The father of <span data-glossary-id="UT22084-089-013-2619">Balendraketu</span> and a king in the distant past.</p></div></div></div></div><div id="18df3892-84a2-4760-8104-00e27677a9f3" class="relative scroll-mt-20"><button type="button" id="radix-_R_ajt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.335</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Powerful Bestower</div><ul class="ml-4 list-disc"><li class="italic">dbang po sbyin</li><li class="pt-1"><span class="font-tibetan text-base">དབང་པོ་སྦྱིན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2496">Licchavī</span> youth.</p></div></div></div></div><div id="028700d0-fa97-434c-a088-a916f6def3c0" class="relative scroll-mt-20"><button type="button" id="radix-_R_ak55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.336</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Powerful King of Elephants</div><ul class="ml-4 list-disc"><li class="italic">spos kyi glang po che mthu stobs rgyal po</li><li class="pt-1"><span class="font-tibetan text-base">སྤོས་ཀྱི་གླང་པོ་ཆེ་མཐུ་སྟོབས་རྒྱལ་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2487">garuḍa</span> king.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">spos kyi rgyal po che’i byin gyi mthu dang ldan pa</em>)</p></div></div></div></div><div id="52ea6881-4383-4b08-a074-1e566dc75917" class="relative scroll-mt-20"><button type="button" id="radix-_R_akd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.337</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">powers</div><ul class="ml-4 list-disc"><li class="italic">dbang po</li><li class="pt-1"><span class="font-tibetan text-base">དབང་པོ།</span></li><li class="italic">indriya</li></ul><div class="glossary-instance-definition"><p class="definition">Faith, mindfulness, diligence, <span data-glossary-id="UT22084-089-013-2593">samādhi</span>, and wisdom.</p></div></div></div></div><div id="372422ef-df74-4afe-bd53-c41e064c575d" class="relative scroll-mt-20"><button type="button" id="radix-_R_akl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.338</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Prabhājvala</div><ul class="ml-4 list-disc"><li class="italic">’od ’bar</li><li class="pt-1"><span class="font-tibetan text-base">འོད་འབར།</span></li><li class="italic">prabhājvala</li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p></div></div></div></div><div id="29eb7209-2410-4d6b-89df-5558af86ccd7" class="relative scroll-mt-20"><button type="button" id="radix-_R_akt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.339</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Prahrāda</div><ul class="ml-4 list-disc"><li class="italic">dbang gzhan</li><li class="pt-1"><span class="font-tibetan text-base">དབང་གཞན།</span></li><li class="italic">prahrāda</li></ul><div class="glossary-instance-definition"><p class="definition">An <span data-glossary-id="UT22084-089-013-2559">asura</span> king who waged a thousand-year war against the <span data-glossary-id="UT22084-089-013-2471">devas</span> and was for a time victorious. He was the grandfather of <span data-glossary-id="UT22084-089-013-2620">Bali</span>. Also known as Prahlādana.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">rab dga’</em>)</p></div></div></div></div><div id="6fa6b4f4-343d-4d66-a05d-59f9edc85045" class="relative scroll-mt-20"><button type="button" id="radix-_R_al55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.340</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Prajāpati</div><ul class="ml-4 list-disc"><li class="italic">skye dgu</li><li class="pt-1"><span class="font-tibetan text-base">སྐྱེ་དགུ</span></li><li class="italic">prajāpati</li></ul><div class="glossary-instance-definition"><p class="definition">A Vedic deity who is seen particularly as being the god of animals, especially cattle, which he is said to have created.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">’jig rten mgon po</em>)</p></div></div></div></div><div id="303ac9fe-1464-4e57-8021-6591732057f8" class="relative scroll-mt-20"><button type="button" id="radix-_R_ald5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.341</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Pramudita</div><ul class="ml-4 list-disc"><li class="italic">rab dga’</li><li class="pt-1"><span class="font-tibetan text-base">རབ་དགའ།</span></li><li class="italic">pramudita</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2471">deva</span>.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">yid dga’ ba</em>)</p></div></div></div></div><div id="f86b3e7c-b287-4987-aa34-84f2d9c8230e" class="relative scroll-mt-20"><button type="button" id="radix-_R_all5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.342</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Praṇālin</div><ul class="ml-4 list-disc"><li class="italic">yur ba can</li><li class="pt-1"><span class="font-tibetan text-base">ཡུར་བ་ཅན།</span></li><li class="italic">praṇālin</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king.</p></div></div></div></div><div id="cdbeb76c-5e86-4899-be00-879b88b310cb" class="relative scroll-mt-20"><button type="button" id="radix-_R_alt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.343</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Prasanna­vadanotpala­gandha­kūṭa</div><ul class="ml-4 list-disc"><li class="italic">rab tu dang ba’i zhal ut+pa la’i dri brtsegs pa</li><li class="pt-1"><span class="font-tibetan text-base">རབ་ཏུ་དང་བའི་ཞལ་ཨུཏྤ་ལའི་དྲི་བརྩེགས་པ།</span></li><li class="italic">prasanna­vadanotpala­gandha­kūṭa</li></ul><div class="glossary-instance-definition"><p class="definition">The name of ten thousand future buddhas.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">zhal dang spyan rnam par dag cing ut pa la’i dri’i ri mo</em>)</p></div></div></div></div><div id="dd537b63-172f-4115-ac04-ef342e1774b7" class="relative scroll-mt-20"><button type="button" id="radix-_R_am55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.344</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">pratyekabuddha</div><ul class="ml-4 list-disc"><li class="italic">rang sangs rgyas</li><li class="pt-1"><span class="font-tibetan text-base">རང་སངས་རྒྱས།</span></li><li class="italic">pratyekabuddha</li></ul><div class="glossary-instance-definition"><p class="definition">Literally, “buddha for oneself” or “solitary realizer.” Someone who, in his or her last life, attains awakening entirely through their own contemplation, without relying on a teacher. Unlike the awakening of a fully realized buddha (<em class="foreign break text-sa" lang="sa-LATN">samyaksambuddha</em>), the accomplishment of a pratyeka­buddha is not regarded as final or ultimate. They attain realization of the nature of dependent origination, the selflessness of the person, and a partial realization of the selflessness of phenomena, by observing the suchness of all that arises through interdependence. This is the result of progress in previous lives but, unlike a buddha, they do not have the necessary merit, compassion or motivation to teach others. They are named as “rhinoceros-like” (<em class="foreign break text-sa" lang="sa-LATN">khaḍgaviṣāṇakalpa</em>) for their preference for staying in solitude or as “congregators” (<em class="foreign break text-sa" lang="sa-LATN">vargacārin</em>) when their preference is to stay among peers.</p></div></div></div></div><div id="d13a3ce1-ffe3-46c4-a837-83256ffbde12" class="relative scroll-mt-20"><button type="button" id="radix-_R_amd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.345</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Pratyeka­buddha­yāna</div><ul class="ml-4 list-disc"><li class="italic">rang sangs rgyas kyi theg pa</li><li class="pt-1"><span class="font-tibetan text-base">རང་སངས་རྒྱས་ཀྱི་ཐེག་པ།</span></li><li class="italic">pratyeka­buddha­yāna</li></ul><div class="glossary-instance-definition"><p class="definition">The vehicle comprising the teaching of the <span data-glossary-id="UT22084-089-013-2578">pratyekabuddhas</span>.</p></div></div></div></div><div id="c45f701f-ba33-433e-a819-da5b21d02331" class="relative scroll-mt-20"><button type="button" id="radix-_R_aml5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.346</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Precious Cloud Sandalwood Cool Body</div><ul class="ml-4 list-disc"><li class="italic">sprin chen rin po che tsan+dan dri bsil sku</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲིན་ཆེན་རིན་པོ་ཆེ་ཙནྡན་དྲི་བསིལ་སྐུ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">sprin chen rin po che’i tsan dan sku rnam par bsil ba</em>)</p></div></div></div></div><div id="7eb37dc1-ba1f-4f18-ac93-39b3b807c51d" class="relative scroll-mt-20"><button type="button" id="radix-_R_amt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.347</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">preta</div><ul class="ml-4 list-disc"><li class="italic">yi dags</li><li class="pt-1"><span class="font-tibetan text-base">ཡི་དགས།</span></li><li class="italic">preta</li></ul><div class="glossary-instance-definition"><p class="definition">One of the five or six classes of sentient beings, into which beings are born as the karmic fruition of past miserliness. As the term in Sanskrit means “the departed,” they are analogous to the ancestral spirits of Vedic tradition, the <em class="foreign break text-sa" lang="sa-LATN">pitṛ</em>s, who starve without the offerings of descendants. It is also commonly translated as “hungry ghost” or “starving spirit,” as in the Chinese <em class="foreign text-zh" lang="zh">餓鬼</em> <em class="foreign">e gui</em>.</p><p class="definition">They are sometimes said to reside in the realm of Yama, but are also frequently described as roaming charnel grounds and other inhospitable or frightening places along with piśācas and other such beings. They are particularly known to suffer from great hunger and thirst and the inability to acquire sustenance. Detailed descriptions of their realm and experience, including a list of the thirty-six classes of pretas, can be found in <cite class="title text-en" lang="en">The Application of Mindfulness of the Sacred Dharma</cite>, Toh 287, <a target="_blank" href="https://read.84000.co/translation/toh287.html#UT22084-068-021-1672" title="2.­1281">2.­1281</a>– <a target="_blank" href="https://read.84000.co/translation/toh287.html#UT22084-068-021-1902" title="2.1482">2.1482</a>.</p></div></div></div></div><div id="25a3eed9-94cb-4bf5-a1a3-940b7ab18675" class="relative scroll-mt-20"><button type="button" id="radix-_R_an55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.348</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Prophesied Attainment</div><ul class="ml-4 list-disc"><li class="italic">lung bstan mchog thob</li><li class="pt-1"><span class="font-tibetan text-base">ལུང་བསྟན་མཆོག་ཐོབ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">gong du lung bstan pa thob pa</em>)</p></div></div></div></div><div id="ec992896-0df3-497e-a56a-d3f3d932aa28" class="relative scroll-mt-20"><button type="button" id="radix-_R_and5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.349</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">proximate kleśa</div><ul class="ml-4 list-disc"><li class="italic">nye ba’i nyon mongs pa</li><li class="pt-1"><span class="font-tibetan text-base">ཉེ་བའི་ཉོན་མོངས་པ།</span></li><li class="italic">upakleśa</li></ul><div class="glossary-instance-definition"><p>The subsidiary afflictive emotions that arise in dependence upon the six root afflictive emotions (attachment, hatred, pride, ignorance, doubt, and wrong view); they are (1) anger (<em class="foreign break text-sa" lang="sa-LATN">krodha</em>, <em class="foreign text-wy" lang="bo-LATN">khro ba</em>), (2) enmity/malice (<em class="foreign break text-sa" lang="sa-LATN">upanāha</em>, <em class="foreign text-wy" lang="bo-LATN">’khon ’dzin</em>), (3) concealment (<em class="foreign break text-sa" lang="sa-LATN">mrakśa</em>, <em class="foreign text-wy" lang="bo-LATN">’chab pa</em>), (4) outrage (<em class="foreign break text-sa" lang="sa-LATN">pradāsa</em>, <em class="foreign text-wy" lang="bo-LATN">’tshig pa</em>), (5) jealousy (<em class="foreign break text-sa" lang="sa-LATN">īrśya</em>, <em class="foreign text-wy" lang="bo-LATN">phrag dog</em>), (6) miserliness (<em class="foreign break text-sa" lang="sa-LATN">matsarya</em>, <em class="foreign text-wy" lang="bo-LATN">ser sna</em>), (7) deceit (<em class="foreign break text-sa" lang="sa-LATN"><span>māyā</span></em>, <em class="foreign text-wy" lang="bo-LATN">sgyu</em>), (8) dishonesty (<em class="foreign break text-sa" lang="sa-LATN">śāṭhya</em>, <em class="foreign text-wy" lang="bo-LATN">g.yo</em>), (9) haughtiness (<em class="foreign break text-sa" lang="sa-LATN">mada</em>, <em class="foreign text-wy" lang="bo-LATN">rgyags pa</em>), (10) harmfulness (<em class="foreign break text-sa" lang="sa-LATN">vihiṃsa</em>, <em class="foreign text-wy" lang="bo-LATN">rnam par ’tshe ba</em>), (11) shamelessness (<em class="foreign break text-sa" lang="sa-LATN">āhrīkya</em>, <em class="foreign text-wy" lang="bo-LATN">ngo tsha med pa</em>), (12) non-consideration (<em class="foreign break text-sa" lang="sa-LATN">anapatrāpya</em>, <em class="foreign text-wy" lang="bo-LATN">khril med pa</em>), (13) lack of faith (<em class="foreign break text-sa" lang="sa-LATN">aśraddhya</em>, <em class="foreign text-wy" lang="bo-LATN">ma dad pa</em>), (14) laziness (<em class="foreign break text-sa" lang="sa-LATN">kausīdya</em>, <em class="foreign text-wy" lang="bo-LATN">le lo</em>), (15) non-conscientiousness (<em class="foreign break text-sa" lang="sa-LATN">pramāda</em>, <em class="foreign text-wy" lang="bo-LATN">bag med pa</em>), (16) forgetfulness (<em class="foreign break text-sa" lang="sa-LATN">muśitasmṛtitā</em>, <em class="foreign text-wy" lang="bo-LATN">brjed nges</em>), (17) non-introspection (<em class="foreign break text-sa" lang="sa-LATN">asaṃprajanya</em>, <em class="foreign text-wy" lang="bo-LATN">shes bzhin ma yin pa</em>), (18) dullness (<em class="foreign break text-sa" lang="sa-LATN">nigmagṇa</em>, <em class="foreign text-wy" lang="bo-LATN">bying ba</em>), (19) agitation (<em class="foreign break text-sa" lang="sa-LATN">auddhatya</em>, <em class="foreign text-wy" lang="bo-LATN">rgod pa</em>), and (20) distraction (<em class="foreign break text-sa" lang="sa-LATN">vikṣepa</em>, <em class="foreign text-wy" lang="bo-LATN">rnam g.yeng</em>) (Rigzin 329, 129).</p></div></div></div></div><div id="5fbb4aaa-7ae4-42ed-970d-7cae35c749e6" class="relative scroll-mt-20"><button type="button" id="radix-_R_anl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.350</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Puṇya­kusuma­prabha</div><ul class="ml-4 list-disc"><li class="italic">bsod nams kyi me tog ’od</li><li class="pt-1"><span class="font-tibetan text-base">བསོད་ནམས་ཀྱི་མེ་ཏོག་འོད།</span></li><li class="italic">puṇya­kusuma­prabha</li></ul><div class="glossary-instance-definition"><p class="definition">Name of the park where the <span data-glossary-id="UT22084-089-013-3204">goddess Śrī</span> dwells, not far from <span data-glossary-id="UT22084-089-013-2902">Alakāvati</span>, the kingdom of the great king <span data-glossary-id="UT22084-089-013-2847">Vaiśravaṇa</span>.</p></div></div></div></div><div id="f0afc359-857c-4aed-8a82-ffcf584a2306" class="relative scroll-mt-20"><button type="button" id="radix-_R_ant5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.351</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Puṇyaprabha</div><ul class="ml-4 list-disc"><li class="italic">bsod nams ’od</li><li class="pt-1"><span class="font-tibetan text-base">བསོད་ནམས་འོད།</span></li><li class="italic">puṇyaprabha</li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p></div></div></div></div><div id="dea36e66-14ea-474b-a4b9-c8798c86f974" class="relative scroll-mt-20"><button type="button" id="radix-_R_ao55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.352</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Puṇyaprasava</div><ul class="ml-4 list-disc"><li class="italic">bsod nams skyes pa</li><li class="pt-1"><span class="font-tibetan text-base">བསོད་ནམས་སྐྱེས་པ།</span></li><li class="italic">puṇyaprasava</li></ul><div class="glossary-instance-definition"><p class="definition">“Generating Merit.” In the Sarvāstivāda tradition, the second highest of the three paradises that correspond to the fourth <span data-glossary-id="UT22084-089-013-2564">dhyāna</span> in the form realm. Translated in other texts as <em class="foreign text-wy" lang="bo-LATN">bsod nams ’phel ba</em>, “Increasing Merit.”</p></div></div></div></div><div id="e521677b-1169-437b-a622-dfb127298b42" class="relative scroll-mt-20"><button type="button" id="radix-_R_aod5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.353</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Pure Ethics</div><ul class="ml-4 list-disc"><li class="italic">tshul khrims rnam dag</li><li class="pt-1"><span class="font-tibetan text-base">ཚུལ་ཁྲིམས་རྣམ་དག</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">tshul khrims rnam par dag pa</em>)</p></div></div></div></div><div id="4ae4e2a0-3747-45cc-b7cf-dc83a010cd64" class="relative scroll-mt-20"><button type="button" id="radix-_R_aol5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.354</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Pūrṇabhadra</div><ul class="ml-4 list-disc"><li class="italic">gang ba bzang po</li><li class="pt-1"><span class="font-tibetan text-base">གང་བ་བཟང་པོ།</span></li><li class="italic">pūrṇabhadra</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> lord.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">rdzogs bzang</em>)</p></div></div></div></div><div id="bc0f96a8-febc-490d-b82e-87d25162c38f" class="relative scroll-mt-20"><button type="button" id="radix-_R_aot5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.355</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Puṣya</div><ul class="ml-4 list-disc"><li class="italic">rgyal ba</li><li class="pt-1"><span class="font-tibetan text-base">རྒྱལ་བ།</span></li><li class="italic">puṣya</li></ul><div class="glossary-instance-definition"><p class="definition">One of the twenty-eight asterisms or constellations that the sun passes through during the course of a year, which are “lunar mansions” in the plane of the sky. It is composed of the three star systems: Gamma Cancri, Delta Cancri, and Theta Cancri. In the Western zodiac it is equivalent to the very end of Cancer and nearly half of Leo‍—in other words, the end of July and the first part of August.</p></div></div></div></div><div id="f1d6b802-7d28-4c82-8c84-d5a20ec67b20" class="relative scroll-mt-20"><button type="button" id="radix-_R_ap55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.356</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Rādhā</div><ul class="ml-4 list-disc"><li class="italic">dga’ mo</li><li class="pt-1"><span class="font-tibetan text-base">དགའ་མོ།</span></li><li class="italic">rādhā</li></ul><div class="glossary-instance-definition"><p class="definition">An incarnation of a goddess as a milkmaid, who became Kṛṣṇa’s lover.</p><p class="definition">(Toh 556 Degé: <em class="foreign text-wy" lang="bo-LATN">rgan’ mo</em>.)</p></div></div></div></div><div id="2c62c2ea-8732-43ed-8b33-ab1995d4eef8" class="relative scroll-mt-20"><button type="button" id="radix-_R_apd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.357</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Radiance of a Hundred Suns’ Illuminating Essence</div><ul class="ml-4 list-disc"><li class="italic">nyi ma brgya’i ’od zer snang ba’i snying po</li><li class="pt-1"><span class="font-tibetan text-base">ཉི་མ་བརྒྱའི་འོད་ཟེར་སྣང་བའི་སྙིང་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2587">tathāgata</span>.</p><p class="definition">(Toh 555: <em class="foreign break text-sa" lang="sa-LATN">Suvarṇa­śata­prabhā­garbha</em>; <em class="foreign text-wy" lang="bo-LATN">gser brgya’i ’od kyi rnying po</em>)</p></div></div></div></div><div id="c0ea2402-0c69-4659-8881-0d7acb1573c6" class="relative scroll-mt-20"><button type="button" id="radix-_R_apl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.358</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Radiant Flower Display</div><ul class="ml-4 list-disc"><li class="italic">me tog ’od bkod</li><li class="pt-1"><span class="font-tibetan text-base">མེ་ཏོག་འོད་བཀོད།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">me tog bkod pa’i ’od</em>)</p></div></div></div></div><div id="d345ac3f-e986-476d-baf1-33ccaea674a7" class="relative scroll-mt-20"><button type="button" id="radix-_R_apt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.359</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Rāhu</div><ul class="ml-4 list-disc"><li class="italic">sgra gcan</li><li class="pt-1"><span class="font-tibetan text-base">སྒྲ་གཅན།</span></li><li class="italic">rāhu</li></ul><div class="glossary-instance-definition"><p class="definition">An <span data-glossary-id="UT22084-089-013-2559">asura</span> king said to cause eclipses.</p></div></div></div></div><div id="2cc28aa3-b932-4e89-9496-b9c925f9a9ff" class="relative scroll-mt-20"><button type="button" id="radix-_R_aq55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.360</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Rāhula</div><ul class="ml-4 list-disc"><li class="italic">sgra gcan, sgra gcan zin</li><li class="pt-1"><span class="font-tibetan text-base">སྒྲ་གཅན་ཟིན།, སྒྲ་གཅན།</span></li><li class="italic">Rāhula</li></ul><div class="glossary-instance-definition"><p class="definition"><span data-glossary-id="UT22084-089-013-2797">Śākyamuni</span> Buddha’s son who became the first novice monk and a prominent member of his monastic <span data-glossary-id="UT22084-089-013-2522">saṅgha</span>.</p></div></div></div></div><div id="8a64da85-ad7e-4c47-b376-c981f1c2a4b2" class="relative scroll-mt-20"><button type="button" id="radix-_R_aqd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.361</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Rājagṛha</div><ul class="ml-4 list-disc"><li class="italic">rgyal po’i khab</li><li class="pt-1"><span class="font-tibetan text-base">རྒྱལ་པོའི་ཁབ།</span></li><li class="italic">rājagṛha</li></ul><div class="glossary-instance-definition"><p class="definition">The ancient capital of Magadha prior to its relocation to Pāṭaliputra during the Mauryan dynasty, Rājagṛha is one of the most important locations in Buddhist history. The literature tells us that the Buddha and his saṅgha spent a considerable amount of time in residence in and around Rājagṛha‍—in nearby places, such as the Vulture Peak Mountain (Gṛdhrakūṭaparvata), a major site of the Mahāyāna sūtras, and the Bamboo Grove (Veṇuvana)‍—enjoying the patronage of King Bimbisāra and then of his son King Ajātaśatru. Rājagṛha is also remembered as the location where the first Buddhist monastic council was held after the Buddha Śākyamuni passed into parinirvāṇa. Now known as Rajgir and located in the modern Indian state of Bihar.</p></div></div></div></div><div id="7e5f6c6d-de35-47b5-9bbf-53cefcb94baf" class="relative scroll-mt-20"><button type="button" id="radix-_R_aql5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.362</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">rākṣasa</div><ul class="ml-4 list-disc"><li class="italic">srin po</li><li class="pt-1"><span class="font-tibetan text-base">སྲིན་པོ།</span></li><li class="italic">rākṣasa</li></ul><div class="glossary-instance-definition"><p>A class of nonhuman beings that are often, but certainly not always, considered demonic in the Buddhist tradition. They are often depicted as flesh-eating monsters who haunt frightening places and are ugly and evil-natured with a yearning for human flesh, and who additionally have miraculous powers, such as being able to change their appearance.</p></div></div></div></div><div id="7dd7cd0e-93b0-4530-9a32-1b6ba6067f09" class="relative scroll-mt-20"><button type="button" id="radix-_R_aqt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.363</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ralpachen</div><ul class="ml-4 list-disc"><li class="italic">ral pa can</li><li class="pt-1"><span class="font-tibetan text-base">རལ་པ་ཅན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A king of Tibet, born ca. 806. His formal name was Tritsuk Detsen (<em class="foreign text-wy" lang="bo-LATN">khri gtsug lde btsan</em>), and he reigned from 815 to 838.</p></div></div></div></div><div id="6415d3d1-05d3-48b0-850d-ca82906dff98" class="relative scroll-mt-20"><button type="button" id="radix-_R_ar55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.364</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">rasāyana</div><ul class="ml-4 list-disc"><li class="italic">sman bcud kyis len</li><li class="pt-1"><span class="font-tibetan text-base">སྨན་བཅུད་ཀྱིས་ལེན།</span></li><li class="italic">rasāyana</li></ul><div class="glossary-instance-definition"><p class="definition">The extraction of the elixir of life from herbs or minerals.</p></div></div></div></div><div id="64c9a95c-ea88-4be7-be2c-d794bc29461c" class="relative scroll-mt-20"><button type="button" id="radix-_R_ard5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.365</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratibala</div><ul class="ml-4 list-disc"><li class="italic">dga’ ba’i stobs</li><li class="pt-1"><span class="font-tibetan text-base">དགའ་བའི་སྟོབས།</span></li><li class="italic">ratibala</li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p></div></div></div></div><div id="e084d98c-6609-427a-ada5-7a8b6d1be56c" class="relative scroll-mt-20"><button type="button" id="radix-_R_arl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.366</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratnagarbha</div><ul class="ml-4 list-disc"><li class="italic">rin chen snying po</li><li class="pt-1"><span class="font-tibetan text-base">རིན་ཆེན་སྙིང་པོ།</span></li><li class="italic">ratnagarbha</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2496">Licchavī</span> youth.</p></div></div></div></div><div id="98732aab-365a-4b36-af84-0d2d40338ccd" class="relative scroll-mt-20"><button type="button" id="radix-_R_art5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.367</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratnagarbha</div><ul class="ml-4 list-disc"><li class="italic">rin chen snying po</li><li class="pt-1"><span class="font-tibetan text-base">རིན་ཆེན་སྙིང་པོ།</span></li><li class="italic">ratnagarbha</li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p></div></div></div></div><div id="667c83e6-4afe-4dd5-9432-17eb785f0183" class="relative scroll-mt-20"><button type="button" id="radix-_R_as55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.368</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratnakeśa</div><ul class="ml-4 list-disc"><li class="italic">rin chen skra</li><li class="pt-1"><span class="font-tibetan text-base">རིན་ཆེན་སྐྲ།</span></li><li class="italic">ratnakeśa</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">rin chen gtsug phud</em>)</p></div></div></div></div><div id="c10c0c1a-4fb8-494d-916f-0269e31c11bc" class="relative scroll-mt-20"><button type="button" id="radix-_R_asd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.369</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratnaketu</div><ul class="ml-4 list-disc"><li class="italic">rin chen tog</li><li class="pt-1"><span class="font-tibetan text-base">རིན་ཆེན་ཏོག</span></li><li class="italic">ratnaketu</li></ul><div class="glossary-instance-definition"><p class="definition">The principal buddha of the southern direction.</p><p class="definition">See also Toh 555, <a href="https://read.84000.co/translation/toh555#UT22084-089-012-3853" target="UT22084-089-012.html" data-pointer-type="id">g.376</a> .</p></div></div></div></div><div id="0a6bdcb0-1cf8-4a20-a26c-ff2e2a9892bc" class="relative scroll-mt-20"><button type="button" id="radix-_R_asl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.370</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratnaketu</div><ul class="ml-4 list-disc"><li class="italic">rin po che’i tog</li><li class="pt-1"><span class="font-tibetan text-base">རིན་པོ་ཆེའི་ཏོག</span></li></ul><div class="glossary-instance-definition"><p class="definition">One of the bodhisattvas present at <span data-glossary-id="UT22084-089-013-2917">Vulture Peak</span>.</p><p class="definition">In Toh 555 the bodhisattva’s name is Ratnadhvaja (<em class="foreign text-wy" lang="bo-LATN">rin po che’i rgyal mtshan</em>).</p></div></div></div></div><div id="c0f4fdd1-04a4-488d-af7b-df79bcf467c2" class="relative scroll-mt-20"><button type="button" id="radix-_R_ast5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.371</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratna­kusuma­guṇa­sāgara­vaiḍūrya­kanaka­giri­suvarṇa­kāñcana­prabhāsaśrī</div><ul class="ml-4 list-disc"><li class="italic">rin chen me tog yon tan rgya mtsho bai DUr+ya dang gser gyi ri kha dog bzang po gser du snang ba’i dpal</li><li class="pt-1"><span class="font-tibetan text-base">རིན་ཆེན་མེ་ཏོག་ཡོན་ཏན་རྒྱ་མཚོ་བཻ་ཌཱུརྱ་དང་གསེར་གྱི་རི་ཁ་དོག་བཟང་པོ་གསེར་དུ་སྣང་བའི་དཔལ།</span></li><li class="italic">ratna­kusuma­guṇa­sāgara­vaiḍūrya­kanaka­giri­suvarṇa­kāñcana­prabhāsaśrī</li></ul><div class="glossary-instance-definition"><p class="definition">(Toh 555: <em class="foreign break text-sa" lang="sa-LATN">Vaiḍūrya­kanaka­giri­ratna­kusuma­prabhā­śrīguṇa­sāgara</em>; <em class="foreign text-wy" lang="bo-LATN">bai DUr+ya dang gser gyi ri bo rin po che’i me tog snang ba spal gyi yon tan rgya mtsho</em>)</p></div></div></div></div><div id="61017ef1-caab-44fb-8a78-5283a71571ef" class="relative scroll-mt-20"><button type="button" id="radix-_R_at55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.372</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratnaprabha</div><ul class="ml-4 list-disc"><li class="italic">rin chen ’od</li><li class="pt-1"><span class="font-tibetan text-base">རིན་ཆེན་འོད།</span></li><li class="italic">ratnaprabha</li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p></div></div></div></div><div id="029b03ef-f419-4162-9af1-46d6a28c3a9f" class="relative scroll-mt-20"><button type="button" id="radix-_R_atd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.373</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratnārci</div><ul class="ml-4 list-disc"><li class="italic">rin chen ’od ’phro</li><li class="pt-1"><span class="font-tibetan text-base">རིན་ཆེན་འོད་འཕྲོ།</span></li><li class="italic">ratnārci</li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p></div></div></div></div><div id="216fea15-b9dd-4757-8088-4c244086c3b3" class="relative scroll-mt-20"><button type="button" id="radix-_R_atl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.374</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratnārci</div><ul class="ml-4 list-disc"><li class="italic">rin chen ’od ’phro</li><li class="pt-1"><span class="font-tibetan text-base">རིན་ཆེན་འོད་འཕྲོ།</span></li><li class="italic">ratnārci</li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p></div></div></div></div><div id="0fad7036-66c0-4254-a572-211f8ffb4464" class="relative scroll-mt-20"><button type="button" id="radix-_R_att5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.375</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratnaśikhin</div><ul class="ml-4 list-disc"><li class="italic">rin chen gtsug tor can</li><li class="pt-1"><span class="font-tibetan text-base">རིན་ཆེན་གཙུག་ཏོར་ཅན།</span></li><li class="italic">ratnaśikhin</li></ul><div class="glossary-instance-definition"><p class="definition">A buddha in the distant past.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">rin chen gtsug phud</em>)</p></div></div></div></div><div id="f34c08f4-c583-42a8-9bc4-4eba6c7e3dfd" class="relative scroll-mt-20"><button type="button" id="radix-_R_au55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.376</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratnoccaya</div><ul class="ml-4 list-disc"><li class="italic">rin chen sogs pa</li><li class="pt-1"><span class="font-tibetan text-base">རིན་ཆེན་སོགས་པ།</span></li><li class="italic">ratnoccaya</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2474">dharmabhāṇaka</span> in the distant past who eventually became the Buddha <span data-glossary-id="UT22084-089-013-2604">Akṣobhya</span>.</p><p class="definition">(Yongle, Lithang, Peking, Narthang, and Choné: <em class="foreign text-wy" lang="bo-LATN">rin chen sogs</em>, <em class="foreign text-wy" lang="bo-LATN">rin chen sogs pa</em>. Toh 555: <em class="foreign text-wy" lang="bo-LATN">rin chen brtsegs pa</em>)</p></div></div></div></div><div id="910f589b-d40b-472b-bb24-fb5d9d315dbe" class="relative scroll-mt-20"><button type="button" id="radix-_R_aud5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.377</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">realgar</div><ul class="ml-4 list-disc"><li class="italic">ni ldong ros</li><li class="pt-1"><span class="font-tibetan text-base">ནི་ལྡོང་རོས།</span></li><li class="italic">manaḥśilā</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign">Arsenic sulphide</em>, which consists of bright orange-red soft crystals, is also called “ruby sulphur” and “ruby of arsenic.” A number of Sanskrit synonyms include <em class="foreign break text-sa" lang="sa-LATN">yavāgraja</em>, <em class="foreign break text-sa" lang="sa-LATN">pākya</em>, <em class="foreign break text-sa" lang="sa-LATN">manoguptā</em>, <em class="foreign break text-sa" lang="sa-LATN">nāgajihivikā</em>, <em class="foreign break text-sa" lang="sa-LATN">golā</em>, <em class="foreign break text-sa" lang="sa-LATN">śilā</em>, <em class="foreign break text-sa" lang="sa-LATN">kunṭī</em>, and <em class="foreign break text-sa" lang="sa-LATN">naipālī</em>. </p></div></div></div></div><div id="454abb50-cb5e-4b1c-b6cb-ee32ddd710e9" class="relative scroll-mt-20"><button type="button" id="radix-_R_aul5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.378</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Renowned King Virtuous Stainless Light</div><ul class="ml-4 list-disc"><li class="italic">dge ’od dri ma med par grags pa’i rgyal po</li><li class="pt-1"><span class="font-tibetan text-base">དགེ་འོད་དྲི་མ་མེད་པར་གྲགས་པའི་རྒྱལ་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">legs ’od dri med grags pa’i rgyal po</em>)</p></div></div></div></div><div id="75043ae2-050e-46ec-92e8-35e7c85e2bf2" class="relative scroll-mt-20"><button type="button" id="radix-_R_aut5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.379</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">River Holder</div><ul class="ml-4 list-disc"><li class="italic">klung ’dzin</li><li class="pt-1"><span class="font-tibetan text-base">ཀླུང་འཛིན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2503">nāga</span> king.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">chu’i rgyu ’dzin</em>)</p></div></div></div></div><div id="2529a08b-439a-4a18-afb2-06da36ba7bc6" class="relative scroll-mt-20"><button type="button" id="radix-_R_av55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.380</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Royal Light</div><ul class="ml-4 list-disc"><li class="italic">rgyal po ’od</li><li class="pt-1"><span class="font-tibetan text-base">རྒྱལ་པོ་འོད།</span></li><li class="italic">śataraśmi</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2503">nāga</span> king.</p></div></div></div></div><div id="1dbcd19e-bf08-4064-bb95-2da8bedfaff5" class="relative scroll-mt-20"><button type="button" id="radix-_R_avd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.381</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">ṛṣi</div><ul class="ml-4 list-disc"><li class="italic">drang srong</li><li class="pt-1"><span class="font-tibetan text-base">དྲང་སྲོང་།</span></li><li class="italic">ṛṣi</li></ul><div class="glossary-instance-definition"><p>An ancient Indian spiritual title, often translated as “sage” or “seer.” The title is particularly used for divinely inspired individuals credited with creating the foundations of Indian culture. The term is also applied to Śākyamuni and other realized Buddhist figures.</p></div></div></div></div><div id="727c3a9f-2dae-46b4-89e7-d5f8bedeb247" class="relative scroll-mt-20"><button type="button" id="radix-_R_avl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.382</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ruciraketu</div><ul class="ml-4 list-disc"><li class="italic">mdzes pa’i tog</li><li class="pt-1"><span class="font-tibetan text-base">མཛེས་པའི་ཏོག</span></li><li class="italic">ruciraketu</li></ul><div class="glossary-instance-definition"><p class="definition">The name of a bodhisattva.</p></div></div></div></div><div id="7006432b-e193-40f7-aa2f-4ff61df35bd1" class="relative scroll-mt-20"><button type="button" id="radix-_R_avt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.383</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ruciraketu</div><ul class="ml-4 list-disc"><li class="italic">mdzes pa’i tog</li><li class="pt-1"><span class="font-tibetan text-base">མཛེས་པའི་ཏོག</span></li><li class="italic">ruciraketu</li></ul><div class="glossary-instance-definition"><p class="definition">The name of a prince. Son of the king <span data-glossary-id="UT22084-089-013-2619">Balendraketu</span>.</p></div></div></div></div><div id="86a25f84-5d03-4120-8da2-a789bbc11c74" class="relative scroll-mt-20"><button type="button" id="radix-_R_b055anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.384</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Rūpyaketu</div><ul class="ml-4 list-disc"><li class="italic">dngul tog</li><li class="pt-1"><span class="font-tibetan text-base">དངུལ་ཏོག</span></li><li class="italic">rūpyaketu</li></ul><div class="glossary-instance-definition"><p class="definition">The older son of the bodhisattva <span data-glossary-id="UT22084-089-013-2790">Ruciraketu</span>.</p></div></div></div></div><div id="fdc66fbb-9edb-4f2f-b926-cb8dd58dcb62" class="relative scroll-mt-20"><button type="button" id="radix-_R_b0d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.385</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Rūpyaprabha</div><ul class="ml-4 list-disc"><li class="italic">dngul ’od</li><li class="pt-1"><span class="font-tibetan text-base">དངུལ་འོད།</span></li><li class="italic">rūpyaprabha</li></ul><div class="glossary-instance-definition"><p class="definition">The younger son of the bodhisattva <span data-glossary-id="UT22084-089-013-2790">Ruciraketu</span>.</p></div></div></div></div><div id="8b1b7220-94d9-4967-a2c0-e5a4a7d2dab9" class="relative scroll-mt-20"><button type="button" id="radix-_R_b0l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.386</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sadāprarudita</div><ul class="ml-4 list-disc"><li class="italic">rtag tu ngu</li><li class="pt-1"><span class="font-tibetan text-base">རྟག་ཏུ་ངུ།</span></li><li class="italic">sadāprarudita</li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva famous for his quest for the Dharma and for his devotion to the teacher. It is told that Sadāprarudita, in order to make offerings to the bodhisattva Dharmodgata and request the Prajñāpāramitā teachings, sets out to sell his own flesh and blood. After receiving a first set of teachings, Sadāprarudita waits seven years for the bodhisattva Dharmodgata, his teacher, to emerge from meditation. When he receives signs this is about to happen, he wishes to prepare the ground for the teachings by settling the dust. Māra makes all the water disappear, so Sadāprarudita decides to use his own blood to settle the dust. He is said to be practicing in the presence of Buddha Bhīṣma­garjita­nirghoṣa­svara. His name means "Ever Weeping", on account of the numerous tears he shed until he found the teachings. </p><p class="definition">His story is told in detail by the Buddha in <cite class="title text-en" lang="en"><a target="_blank" href="https://read.84000.co/translation/toh10.html" title="The Perfection of Wisdom in Eighteen Thousand Lines">The Perfection of Wisdom in Eighteen Thousand Lines</a></cite> (Toh 10, ch. 85–86), and can be found quoted in several works, such as <cite class="title text-en" lang="en">The Words of My Perfect Teacher</cite> (<cite class="title text-wy" lang="bo-LATN">kun bzang bla ma’i zhal lung</cite>) by Patrul Rinpoche.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">rtag tu bshums</em>)</p></div></div></div></div><div id="952ee94a-e97f-483f-bcf1-c7d4ce088802" class="relative scroll-mt-20"><button type="button" id="radix-_R_b0t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.387</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">saffron</div><ul class="ml-4 list-disc"><li class="italic">gur gum</li><li class="pt-1"><span class="font-tibetan text-base">གུར་གུམ།</span></li><li class="italic">kuṅkuma</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign">Crocus sativus</em>.</p></div></div></div></div><div id="13ba4dc3-c711-4a17-bd8e-194dfd420d8c" class="relative scroll-mt-20"><button type="button" id="radix-_R_b155anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.388</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sāgara</div><ul class="ml-4 list-disc"><li class="italic">rgya mtsho</li><li class="pt-1"><span class="font-tibetan text-base">རྒྱ་མཚོ།</span></li><li class="italic">sāgara</li></ul><div class="glossary-instance-definition"><p class="definition">The principal <span data-glossary-id="UT22084-089-013-2503">nāga</span> king in <cite class="title text-en" lang="en">The King of Samādhis Sūtra</cite> and <cite class="title text-en" lang="en">The Questions of the Nāga King Sāgara</cite>. This is also said to be another name for Vaṛuna, the god of the oceans.</p></div></div></div></div><div id="17d04c49-8e95-41c0-b028-a1848108ba0d" class="relative scroll-mt-20"><button type="button" id="radix-_R_b1d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.389</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sāgara</div><ul class="ml-4 list-disc"><li class="italic">rgya mtsho</li><li class="pt-1"><span class="font-tibetan text-base">རྒྱ་མཚོ།</span></li><li class="italic">sāgara</li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p></div></div></div></div><div id="eef17539-251c-4ba2-bd32-f92a5d6e4a56" class="relative scroll-mt-20"><button type="button" id="radix-_R_b1l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.390</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">sage</div><ul class="ml-4 list-disc"><li class="italic">thub pa</li><li class="pt-1"><span class="font-tibetan text-base">ཐུབ་པ།</span></li><li class="italic">muni</li></ul><div class="glossary-instance-definition"><p class="definition">A title that, like “buddha,” is given to those who have attained realization through their own contemplation and not by divine revelation.</p></div></div></div></div><div id="48821165-db0c-449c-8bc7-b185d4941fd3" class="relative scroll-mt-20"><button type="button" id="radix-_R_b1t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.391</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sahā</div><ul class="ml-4 list-disc"><li class="italic">mi mjed</li><li class="pt-1"><span class="font-tibetan text-base">མི་མཇེད།</span></li><li class="italic">sahā</li></ul><div class="glossary-instance-definition"><p class="definition">Indian Buddhist name for either the four-continent world in which the Buddha <span data-glossary-id="UT22084-089-013-2797">Śākyamuni</span> appeared, or a universe of a thousand million such worlds. The name Sahā possibly derives from the Sanskrit √<em class="foreign break text-sa" lang="sa-LATN">sah</em>, “to bear, endure, or withstand.” It is often interpreted as alluding to the inhabitants of this world having to endure suffering. The Tibetan translation, <em class="foreign text-wy" lang="bo-LATN">mi mjed</em>, follows along the same lines. It literally means “not unbearable,” in the sense that beings here are able to bear the suffering they experience. </p></div></div></div></div><div id="30470857-9228-4b50-ad00-ff8c913dc02a" class="relative scroll-mt-20"><button type="button" id="radix-_R_b255anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.392</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Śākyamuni</div><ul class="ml-4 list-disc"><li class="italic">shAkya thub pa</li><li class="pt-1"><span class="font-tibetan text-base">ཤཱཀྱ་ཐུབ་པ།</span></li><li class="italic">śākyamuni</li></ul><div class="glossary-instance-definition"><p class="definition">An epithet for the historical Buddha, Siddhārtha Gautama: he was a <em class="foreign break text-sa" lang="sa-LATN">muni</em> (“sage”) from the Śākya clan. He is counted as the fourth of the first four buddhas of the present Good Eon, the other three being Krakucchanda, Kanakamuni, and Kāśyapa. He will be followed by Maitreya, the next buddha in this eon.</p></div></div></div></div><div id="39dcd9b4-ca83-4d6e-b1de-0a82f1b693f0" class="relative scroll-mt-20"><button type="button" id="radix-_R_b2d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.393</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">sal</div><ul class="ml-4 list-disc"><li class="italic">sA la</li><li class="pt-1"><span class="font-tibetan text-base">སཱ་ལ།</span></li><li class="italic">sāla, śāla</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign">Shorea robusta</em>. The dominant tree in the forests where it occurs.</p></div></div></div></div><div id="46e996f3-5f00-47cf-bf5d-2ee88dbbb2ea" class="relative scroll-mt-20"><button type="button" id="radix-_R_b2l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.394</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Śālendra­dhvajāgravatī</div><ul class="ml-4 list-disc"><li class="italic">sA la’i dbang po mthon po’i rgyal mtshan</li><li class="pt-1"><span class="font-tibetan text-base">སཱ་ལའི་དབང་པོ་མཐོན་པོའི་རྒྱལ་མཚན།</span></li><li class="italic">śālendra­dhvajāgravatī</li></ul><div class="glossary-instance-definition"><p class="definition">A world realm in the distant future.</p></div></div></div></div><div id="5c76a316-06d8-45cc-9036-0b289b210d69" class="relative scroll-mt-20"><button type="button" id="radix-_R_b2t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.395</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">samādhi</div><ul class="ml-4 list-disc"><li class="italic">ting nge ’dzin</li><li class="pt-1"><span class="font-tibetan text-base">ཏིང་ངེ་འཛིན།</span></li><li class="italic">samādhi</li></ul><div class="glossary-instance-definition"><p class="definition">In a general sense, <em class="foreign break text-sa" lang="sa-LATN">samādhi</em> can describe a number of different meditative states. In the Mahāyāna literature, in particular in the Prajñāpāramitā sūtras, we find extensive lists of different samādhis, numbering over one hundred.</p><p class="definition">In a more restricted sense, and when understood as a mental state, <em class="foreign break text-sa" lang="sa-LATN">samādhi</em> is defined as the one-pointedness of the mind (<em class="foreign break text-sa" lang="sa-LATN">cittaikāgratā</em>), the ability to remain on the same object over long periods of time. The <cite class="title text-en" lang="en">Drajor Bamponyipa</cite> (<cite class="title text-wy" lang="bo-LATN">sgra sbyor bam po gnyis pa</cite>) commentary on the <cite class="title break text-sa" lang="sa-LATN">Mahāvyutpatti</cite> explains the term <em class="foreign break text-sa" lang="sa-LATN">samādhi</em> as referring to the instrument through which mind and mental states “get collected,” i.e., it is by the force of samādhi that the continuum of mind and mental states becomes collected on a single point of reference without getting distracted.</p></div></div></div></div><div id="0402a752-9049-4d64-a5f8-f7e2c73b0e8a" class="relative scroll-mt-20"><button type="button" id="radix-_R_b355anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.396</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Samantabhadra</div><ul class="ml-4 list-disc"><li class="italic">kun tu bzang po</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་ཏུ་བཟང་པོ།</span></li><li class="italic">samantabhadra</li></ul><div class="glossary-instance-definition"><p class="definition">Presently classed as one of the eight principal bodhisattvas, he is distinct from the primordial buddha with the same name in the Tibetan Nyingma tradition. He is prominent in <cite class="title text-en" lang="en"><a target="_blank" href="https://read.84000.co/translation/toh44-45.html" title="The Stem Array">The Stem Array</a></cite> (<cite class="title break text-sa" lang="sa-LATN">Gaṇḍavyūha</cite>, Toh 44-45), and also in <cite class="title text-en" lang="en"><a target="_blank" href="https://read.84000.co/translation/toh113.html" title="The White Lotus of the Good Dharma">The White Lotus of the Good Dharma</a></cite> (Toh 113, <cite class="title break text-sa" lang="sa-LATN">Saddharma­puṇḍarīka</cite>) and <cite class="title text-en" lang="en">The White Lotus of Great Compassion</cite> (Toh 111, <cite class="title break text-sa" lang="sa-LATN">Mahā­karuṇā­puṇḍarīka­sūtra</cite>). </p></div></div></div></div><div id="2bc815a0-ca9f-450d-88d4-59bea4f6f61e" class="relative scroll-mt-20"><button type="button" id="radix-_R_b3d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.397</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Samantaprabha</div><ul class="ml-4 list-disc"><li class="italic">kun tu ’od</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་ཏུ་འོད།</span></li><li class="italic">samantaprabha</li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p></div></div></div></div><div id="d62fa8e6-a65c-43c3-8962-1f5f9822fa34" class="relative scroll-mt-20"><button type="button" id="radix-_R_b3l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.398</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Samantāvabhāsa</div><ul class="ml-4 list-disc"><li class="italic">kun tu snang ba</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་ཏུ་སྣང་བ།</span></li><li class="italic">samantāvabhāsa</li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p></div></div></div></div><div id="cba81b20-4ff3-4081-82ab-0587f3e6e48c" class="relative scroll-mt-20"><button type="button" id="radix-_R_b3t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.399</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Samantāvalokiteśvara</div><ul class="ml-4 list-disc"><li class="italic">kun tu spyan ras gzigs dbang phyug</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་ཏུ་སྤྱན་རས་གཟིགས་དབང་ཕྱུག</span></li><li class="italic">samantāvalokiteśvara</li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">kun tu spyan ras gzigs kyi dbang po</em>)</p></div></div></div></div><div id="a56b0539-1a6a-490e-bb85-5444d16ee137" class="relative scroll-mt-20"><button type="button" id="radix-_R_b455anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.400</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">samāpatti</div><ul class="ml-4 list-disc"><li class="italic">snyoms par ’jug pa</li><li class="pt-1"><span class="font-tibetan text-base">སྙོམས་པར་འཇུག་པ།</span></li><li class="italic">samāpatti</li></ul><div class="glossary-instance-definition"><p class="definition">The Sanskrit literally means “attainment,” and is used to refer specifically to meditative attainment and to particular meditative states. The Tibetan translators interpreted it as <em class="foreign break text-sa" lang="sa-LATN">sama-āpatti</em>, which suggests the idea of “equal” or “level”; however, they also parsed it as <em class="foreign break text-sa" lang="sa-LATN">sam-āpatti</em>, in which case it would have the sense of “concentration” or “absorption,” much like <em class="foreign break text-sa" lang="sa-LATN">samādhi</em>, but with the added sense of “attainment.”</p></div></div></div></div><div id="400c6243-9437-40e0-801b-1a346d491d92" class="relative scroll-mt-20"><button type="button" id="radix-_R_b4d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.401</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Saṃjñeya</div><ul class="ml-4 list-disc"><li class="italic">yang dag shes</li><li class="pt-1"><span class="font-tibetan text-base">ཡང་དག་ཤེས།</span></li><li class="italic">saṃjñeya</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> general.</p></div></div></div></div><div id="92bc860e-35a2-4273-9615-133b0c3534a4" class="relative scroll-mt-20"><button type="button" id="radix-_R_b4l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.402</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">saṃsāra</div><ul class="ml-4 list-disc"><li class="italic">’khor ba</li><li class="pt-1"><span class="font-tibetan text-base">འཁོར་བ།</span></li><li class="italic">saṃsāra</li></ul><div class="glossary-instance-definition"><p>A state of involuntary existence conditioned by afflicted mental states and the imprint of past actions, characterized by suffering in a cycle of life, death, and rebirth. On its reversal, the contrasting state of nirvāṇa is attained, free from suffering and the processes of rebirth.</p></div></div></div></div><div id="277591cf-3f67-44f3-8f87-e43dfb047a68" class="relative scroll-mt-20"><button type="button" id="radix-_R_b4t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.403</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Saṃvara</div><ul class="ml-4 list-disc"><li class="italic">bde mchog</li><li class="pt-1"><span class="font-tibetan text-base">བདེ་མཆོག</span></li><li class="italic">saṃvara</li></ul><div class="glossary-instance-definition"><p class="definition">An <span data-glossary-id="UT22084-089-013-2559">asura</span> king.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">sdom po pa</em>)</p></div></div></div></div><div id="6750ea4d-1f76-48b8-a24b-eef4eaada4de" class="relative scroll-mt-20"><button type="button" id="radix-_R_b555anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.404</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">samyaksaṃbuddha</div><ul class="ml-4 list-disc"><li class="italic">yang dag par rdzogs pa’i sangs rgyas</li><li class="pt-1"><span class="font-tibetan text-base">ཡང་དག་པར་རྫོགས་པའི་སངས་རྒྱས།</span></li><li class="italic">samyaksaṃbuddha</li></ul><div class="glossary-instance-definition"><p class="definition">“Perfectly realized one.” A buddha who teaches the Dharma, as opposed to a <span data-glossary-id="UT22084-089-013-2578">pratyekabuddha</span>, who does not teach.</p></div></div></div></div><div id="400ee81c-f76e-4dee-ae22-6914b5fc3df8" class="relative scroll-mt-20"><button type="button" id="radix-_R_b5d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.405</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">sandalwood</div><ul class="ml-4 list-disc"><li class="italic">tsan+dan</li><li class="pt-1"><span class="font-tibetan text-base">ཙནྡན།</span></li><li class="italic">candana</li></ul></div></div></div><div id="7078fbd0-e398-4d44-b061-a6b5fe6bfce4" class="relative scroll-mt-20"><button type="button" id="radix-_R_b5l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.406</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">saṅgha</div><ul class="ml-4 list-disc"><li class="italic">dge ’dun</li><li class="pt-1"><span class="font-tibetan text-base">དགེ་འདུན།</span></li><li class="italic">saṅgha</li></ul><div class="glossary-instance-definition"><p>Though often specifically reserved for the monastic community, this term can be applied to any of the four Buddhist communities‍—monks, nuns, laymen, and laywomen‍—as well as to identify the different groups of practitioners, like the community of bodhisattvas or the community of śrāvakas. It is also the third of the Three Jewels (<em class="foreign">triratna</em>) of Buddhism: the Buddha, the Teaching, and the Community. </p></div></div></div></div><div id="5320ab53-5217-4169-ac5b-a1778de71ca2" class="relative scroll-mt-20"><button type="button" id="radix-_R_b5t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.407</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Śāradvatīputra, Śāriputra</div><ul class="ml-4 list-disc"><li class="italic">shA ri’i bu</li><li class="pt-1"><span class="font-tibetan text-base">ཤཱ་རིའི་བུ།</span></li><li class="italic">śāriputra</li></ul><div class="glossary-instance-definition"><p class="definition">One of the principal śrāvaka disciples of the Buddha, he was renowned for his discipline and for having been praised by the Buddha as foremost of the wise (often paired with Maudgalyā­yana, who was praised as foremost in the capacity for miraculous powers). His father, Tiṣya, to honor Śāriputra’s mother, Śārikā, named him Śāradvatīputra, or, in its contracted form, Śāriputra, meaning “Śārikā’s Son.”</p></div></div></div></div><div id="068fbf99-e394-467f-a59c-45b4bcdd2f78" class="relative scroll-mt-20"><button type="button" id="radix-_R_b655anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.408</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sarasvatī</div><ul class="ml-4 list-disc"><li class="italic">dbyangs can</li><li class="pt-1"><span class="font-tibetan text-base">དབྱངས་ཅན།</span></li><li class="italic">sarasvatī</li></ul><div class="glossary-instance-definition"><p class="definition">The goddess of wisdom, learning, and music.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">spobs pa’i lha mo</em>)</p></div></div></div></div><div id="a3fad492-87b4-42e1-aa6f-ae960e703af1" class="relative scroll-mt-20"><button type="button" id="radix-_R_b6d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.409</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sarva­sattva­priya­darśana</div><ul class="ml-4 list-disc"><li class="italic">sems can thams cad kyis mthong na dga’ ba</li><li class="pt-1"><span class="font-tibetan text-base">སེམས་ཅན་ཐམས་ཅད་ཀྱིས་མཐོང་ན་དགའ་བ།</span></li><li class="italic">sarva­sattva­priya­darśana</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2496">Licchavī</span> youth.</p></div></div></div></div><div id="9ab40a47-4d4d-4d5d-87aa-20e5a3d546e5" class="relative scroll-mt-20"><button type="button" id="radix-_R_b6l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.410</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sātāgiri</div><ul class="ml-4 list-disc"><li class="italic">bde ba’i ri nyid</li><li class="pt-1"><span class="font-tibetan text-base">བདེ་བའི་རི་ཉིད།</span></li><li class="italic">sātāgiri</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">bde ba’i ri</em>)</p></div></div></div></div><div id="5a923304-4bac-471e-9911-98cbbdf4aa50" class="relative scroll-mt-20"><button type="button" id="radix-_R_b6t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.411</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Śatakiraṇa</div><ul class="ml-4 list-disc"><li class="italic">’od zer brgya pa</li><li class="pt-1"><span class="font-tibetan text-base">འོད་ཟེར་བརྒྱ་པ།</span></li><li class="italic">śatakiraṇa</li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p></div></div></div></div><div id="a14bf14e-0326-4f01-b932-42c84f2a12ed" class="relative scroll-mt-20"><button type="button" id="radix-_R_b755anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.412</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Satamapati</div><ul class="ml-4 list-disc"><li class="italic">rgyun gyi bdag po</li><li class="pt-1"><span class="font-tibetan text-base">རྒྱུན་གྱི་བདག་པོ།</span></li><li class="italic">satamapati</li></ul><div class="glossary-instance-definition"><p class="definition">A god who is the king of lightning in the northern direction.</p></div></div></div></div><div id="8c2e38c1-2d4a-406f-8c9d-169cc9a9ce9c" class="relative scroll-mt-20"><button type="button" id="radix-_R_b7d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.413</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">sensation</div><ul class="ml-4 list-disc"><li class="italic">tshor ba</li><li class="pt-1"><span class="font-tibetan text-base">ཚོར་བ།</span></li><li class="italic">vedanā</li></ul><div class="glossary-instance-definition"><p class="definition">The seventh of the <span data-glossary-id="UT22084-089-013-3213">twelve phases of dependent origination</span> and the second of the <span data-glossary-id="UT22084-089-013-2569">five skandhas</span>. It refers to pleasant, unpleasant, or neutral sensations as a result of sensory experiences. </p></div></div></div></div><div id="64108a80-563a-4b78-bf0e-440bb3fb9855" class="relative scroll-mt-20"><button type="button" id="radix-_R_b7l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.414</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">seven jewels, seven precious materials</div><ul class="ml-4 list-disc"><li class="italic">rin po che sna bdun, rin po che sna bdun</li><li class="pt-1"><span class="font-tibetan text-base">རིན་པོ་ཆེ་སྣ་བདུན།, རིན་པོ་ཆེ་སྣ་བདུན།</span></li><li class="italic">saptaratna, saptaratna</li><li>七寶</li></ul><div class="glossary-instance-definition"><p class="definition">When associated with the seven heavenly bodies, and therefore the seven days of the week, these are ruby for the sun, moonstone or pearl for the moon, coral for Mars, emerald for Mercury, yellow sapphire for Jupiter, diamond for Venus, and blue sapphire for Saturn. There are variant lists not associated with the heavenly bodies but retaining the number seven, which include gold, silver, and so on. In association with a <span data-glossary-id="UT22084-089-013-2460">cakravartin</span>, the seven jewels can refer, according to the Abhidharma, to his magical wheel, elephant, horse, wish-fulfilling jewel, queen, minister, and leading householder. In the Tibetan mandala-offering practice, the householder is replaced by a general.</p></div></div></div></div><div id="980831a1-2468-404c-ad42-07a23c9c08ce" class="relative scroll-mt-20"><button type="button" id="radix-_R_b7t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.415</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">seven jewels, seven precious materials</div><ul class="ml-4 list-disc"><li class="italic">rin po che sna bdun, rin po che sna bdun</li><li class="pt-1"><span class="font-tibetan text-base">རིན་པོ་ཆེ་སྣ་བདུན།, རིན་པོ་ཆེ་སྣ་བདུན།</span></li><li class="italic">saptaratna, saptaratna</li><li>七寶</li></ul><div class="glossary-instance-definition"><p class="definition">The set of seven precious materials or substances includes a range of precious metals and gems, but their exact list varies. The set often consists of gold, silver, beryl, crystal, red pearls, emeralds, and white coral, but may also contain lapis lazuli, ruby, sapphire, chrysoberyl, diamonds, etc. The term is frequently used in the sūtras to exemplify preciousness, wealth, and beauty, and can describe treasures, offering materials, or the features of architectural structures such as stūpas, palaces, thrones, etc. The set is also used to describe the beauty and prosperity of buddha realms and the realms of the gods.</p><p class="definition">In other contexts, the term <em class="foreign break text-sa" lang="sa-LATN">saptaratna</em> can also refer to the seven precious possessions of a cakravartin or to a set of seven precious moral qualities. </p></div></div></div></div><div id="bfa97d91-51df-4818-ad10-1c95ce31d633" class="relative scroll-mt-20"><button type="button" id="radix-_R_b855anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.416</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">shami</div><ul class="ml-4 list-disc"><li class="italic">sha myi</li><li class="pt-1"><span class="font-tibetan text-base">ཤ་མྱི།</span></li><li class="italic">śamī</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign">Prosopis cineraria</em>. A tree believed to be auspicious due to the power of its purification properties.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">sha mi</em>; Toh 556 <em class="foreign text-wy" lang="bo-LATN">sha myi</em>)</p></div></div></div></div><div id="76159604-dc51-4698-8a9a-1871f7e1dd7b" class="relative scroll-mt-20"><button type="button" id="radix-_R_b8d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.417</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Shigatsé</div><ul class="ml-4 list-disc"><li class="italic">gzhis ka rtse</li><li class="pt-1"><span class="font-tibetan text-base">གཞིས་ཀ་རྩེ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">The principal town in the Tsang region of central Tibet, which was the capital during a period of Tibetan history.</p></div></div></div></div><div id="625a1e94-fc39-4df9-ae39-8ee2142344b5" class="relative scroll-mt-20"><button type="button" id="radix-_R_b8l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.418</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Siṃha</div><ul class="ml-4 list-disc"><li class="italic">seng ge</li><li class="pt-1"><span class="font-tibetan text-base">སེང་གེ</span></li><li class="italic">siṃha</li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p></div></div></div></div><div id="b3c43172-2126-4462-9b9e-11e5c8d64828" class="relative scroll-mt-20"><button type="button" id="radix-_R_b8t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.419</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Siṃhamati</div><ul class="ml-4 list-disc"><li class="italic">seng ge’i blo gros</li><li class="pt-1"><span class="font-tibetan text-base">སེང་གེའི་བློ་གྲོས།</span></li><li class="italic">siṃhamati</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2496">Licchavī</span> youth.</p></div></div></div></div><div id="5e66749d-11b9-45b4-8fed-bcae48244a80" class="relative scroll-mt-20"><button type="button" id="radix-_R_b955anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.420</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">sixty qualities</div><ul class="ml-4 list-disc"><li class="italic">yan lag drug cu</li><li class="pt-1"><span class="font-tibetan text-base">ཡན་ལག་དྲུག་ཅུ།</span></li><li class="italic">ṣaṣṭyaṅga, ṣaṣṭāṅga</li></ul><div class="glossary-instance-definition"><p class="definition">The Buddha’s speech is said to have sixty aspects and sometimes sixty-four. The list of sixty, as given in Maitreyanātha’s <cite class="title break text-sa" lang="sa-LATN">Mahāyāna­sūtrālaṃkāra</cite>, are (1) ripening, (2) smooth, (3) direct, (4) cogent, (5) correct, (6) stainless, (7) clear, (8) harmonious, (9) proper, (10) undefeatable, (11) meaningful, (12) taming, (13) gentle, (14) kind, (15) completely taming, (16) pleasing, (17) refreshing, (18) soothing, (19) gladdening, (20) blissful, (21) fulfilling, (22) worthwhile, (23) meaningful, (24) comprehensive, (25) reassuring, (26) inspiring, (27) enlightening, (28) instructive, (29) logical, (30) pertinent, (31) exact, (32) powerful, (33) fearless, (34) unfathomable, (35) majestic, (36) melodious, (37) sustaining, (38) long-lasting, (39) auspicious, (40) authoritative, (41) exhortative, (42) selfless, (43) confident, (44) omniscient, (45) whole, (46) complete, (47) certain, (48) desireless, (49) exhilarating, (50) pervasive, (51) stimulating, (52) continuous, (53) consistent, (54) multilingual, (55) adaptive, (56) reliable, (57) timely, (58) calm, (59) pervasive, and (60) perfecting.</p></div></div></div></div><div id="6e470d0b-0f89-42d5-ad54-4622553843c8" class="relative scroll-mt-20"><button type="button" id="radix-_R_b9d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.421</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Skanda</div><ul class="ml-4 list-disc"><li class="italic">skem byed</li><li class="pt-1"><span class="font-tibetan text-base">སྐེམ་བྱེད།</span></li><li class="italic">skanda</li></ul><div class="glossary-instance-definition"><p class="definition">The Indian god of war.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">phrag chen</em>)</p></div></div></div></div><div id="19dac541-d922-4290-aa47-4be78357c62d" class="relative scroll-mt-20"><button type="button" id="radix-_R_b9l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.422</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Soma</div><ul class="ml-4 list-disc"><li class="italic">zla ba</li><li class="pt-1"><span class="font-tibetan text-base">ཟླ་བ།</span></li><li class="italic">soma</li></ul><div class="glossary-instance-definition"><p class="definition">The deity of the moon.</p></div></div></div></div><div id="93204a84-a54f-4198-8bc5-b03b248b26cd" class="relative scroll-mt-20"><button type="button" id="radix-_R_b9t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.423</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">spikenard</div><ul class="ml-4 list-disc"><li class="italic">na la da</li><li class="pt-1"><span class="font-tibetan text-base">ན་ལ་ད།</span></li><li class="italic">nalada</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign">Nardostachys jatamansi</em>. Also called “nard,” “nardin,” and “muskroot.” It is of the <span data-glossary-id="UT22084-089-013-2548">valerian</span> family and grows in the Himalayas. Its rhizome is the source of an aromatic, amber-colored oil.</p><p class="definition">Bagchi edition: <em class="foreign break text-sa" lang="sa-LATN">narada</em>.</p></div></div></div></div><div id="df2147ef-e586-4828-a111-730705966794" class="relative scroll-mt-20"><button type="button" id="radix-_R_ba55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.424</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">śrāvaka</div><ul class="ml-4 list-disc"><li class="italic">nyan thos</li><li class="pt-1"><span class="font-tibetan text-base">ཉན་ཐོས།</span></li><li class="italic">śrāvaka</li></ul><div class="glossary-instance-definition"><p class="definition">The Sanskrit term <em class="foreign break text-sa" lang="sa-LATN">śrāvaka</em>, and the Tibetan <em class="foreign text-wy" lang="bo-LATN">nyan thos</em>, both derived from the verb “to hear,” are usually defined as “those who <em class="emph">hear</em> the teaching from the Buddha and <em class="emph">make it heard</em> to others.” Primarily this refers to those disciples of the Buddha who aspire to attain the state of an arhat seeking their own liberation and nirvāṇa. They are the practitioners of the first turning of the wheel of the Dharma on the four noble truths, who realize the suffering inherent in saṃsāra and focus on understanding that there is no independent self. By conquering afflicted mental states (<em class="foreign break text-sa" lang="sa-LATN">kleśa</em>), they liberate themselves, attaining first the stage of stream enterers at the path of seeing, followed by the stage of once-returners who will be reborn only one more time, and then the stage of non-returners who will no longer be reborn into the desire realm. The final goal is to become an arhat. These four stages are also known as the “four results of spiritual practice.”</p></div></div></div></div><div id="5641abdb-7597-4af2-b321-32243b48023b" class="relative scroll-mt-20"><button type="button" id="radix-_R_bad5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.425</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Śrāvakayāna</div><ul class="ml-4 list-disc"><li class="italic">nyan thos kyi theg pa</li><li class="pt-1"><span class="font-tibetan text-base">ཉན་ཐོས་ཀྱི་ཐེག་པ།</span></li><li class="italic">śrāvakayāna</li></ul><div class="glossary-instance-definition"><p class="definition">The vehicle comprising the teaching of the <span data-glossary-id="UT22084-089-013-2585">śrāvakas</span>.</p></div></div></div></div><div id="d0faa71d-cf10-4af9-9944-d1f6d407ec7b" class="relative scroll-mt-20"><button type="button" id="radix-_R_bal5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.426</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Śrīmatī</div><ul class="ml-4 list-disc"><li class="italic">dpal gyi blo gros</li><li class="pt-1"><span class="font-tibetan text-base">དཔལ་གྱི་བློ་གྲོས།</span></li><li class="italic">śrīmatī</li></ul><div class="glossary-instance-definition"><p class="definition">A name of <span data-glossary-id="UT22084-089-013-2773">Rādhā</span>, Kṛṣṇa’s consort.</p></div></div></div></div><div id="437eab6e-fa0e-4159-8aa1-a47cb71f978e" class="relative scroll-mt-20"><button type="button" id="radix-_R_bat5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.427</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">state of infinite space</div><ul class="ml-4 list-disc"><li class="italic">nam mkha’ mtha’ yas skye mched</li><li class="pt-1"><span class="font-tibetan text-base">ནམ་མཁའ་མཐའ་ཡས་སྐྱེ་མཆེད།</span></li><li class="italic">ākāśānantyāyatana</li></ul><div class="glossary-instance-definition"><p class="definition"> The lowest of the four formless realms. See also “<span><span data-glossary-id="UT22084-089-013-3269">state</span></span>.”</p></div></div></div></div><div id="388d691f-5388-41b1-9238-fe830205744c" class="relative scroll-mt-20"><button type="button" id="radix-_R_bb55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.428</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">state of neither perception nor nonperception</div><ul class="ml-4 list-disc"><li class="italic">’du shes med ’du shes med min skye mched</li><li class="pt-1"><span class="font-tibetan text-base">འདུ་ཤེས་མེད་འདུ་ཤེས་མེད་མིན་སྐྱེ་མཆེད།</span></li><li class="italic">naiva­saṃjñānāsaṃjñāyatana</li></ul><div class="glossary-instance-definition"><p class="definition"> The highest of the four formless realms. See also “<span><span data-glossary-id="UT22084-089-013-3269">state</span></span>.”</p></div></div></div></div><div id="442e2644-9880-4ee9-bd97-4a2ba40ee989" class="relative scroll-mt-20"><button type="button" id="radix-_R_bbd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.429</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">state of nothingness</div><ul class="ml-4 list-disc"><li class="italic">ci yang med pa’i skye mched</li><li class="pt-1"><span class="font-tibetan text-base">ཅི་ཡང་མེད་པའི་སྐྱེ་མཆེད།</span></li><li class="italic">ākiṃcanyāyatana</li></ul><div class="glossary-instance-definition"><p class="definition"> The second highest of the four formless realms. See also “<span><span data-glossary-id="UT22084-089-013-3269">state</span></span>.”</p></div></div></div></div><div id="bd878677-78cd-4364-85ee-3e508a30c7b3" class="relative scroll-mt-20"><button type="button" id="radix-_R_bbl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.430</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">state, āyatana</div><ul class="ml-4 list-disc"><li class="italic">skye mched, skye mched</li><li class="pt-1"><span class="font-tibetan text-base">སྐྱེ་མཆེད།, སྐྱེ་མཆེད།</span></li><li class="italic">āyatana, āyatana</li></ul><div class="glossary-instance-definition"><p class="definition">These can be listed as twelve or as six sense sources (sometimes also called sense fields, bases of cognition, or simply āyatanas).</p><p class="definition">In the context of epistemology, it is one way of describing experience and the world in terms of twelve sense sources, which can be divided into inner and outer sense sources, namely: (1–2) eye and form, (3–4) ear and sound, (5–6) nose and odor, (7–8) tongue and taste, (9–10) body and touch, (11–12) mind and mental phenomena.</p><p class="definition">In the context of the twelve links of dependent origination, only six sense sources are mentioned, and they are the inner sense sources (identical to the six faculties) of eye, ear, nose, tongue, body, and mind.</p></div></div></div></div><div id="b32adfdb-914a-4a80-b4cd-3cbf780b84e0" class="relative scroll-mt-20"><button type="button" id="radix-_R_bbt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.431</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">state, āyatana</div><ul class="ml-4 list-disc"><li class="italic">skye mched, skye mched</li><li class="pt-1"><span class="font-tibetan text-base">སྐྱེ་མཆེད།, སྐྱེ་མཆེད།</span></li><li class="italic">āyatana, āyatana</li></ul><div class="glossary-instance-definition"><p class="definition">This term has various meanings according to context. Here in this sūtra it is used to refer to the four meditative states associated with the formless realm: (1) infinite space, (2) infinite consciousness, (3) nothingness, and (4) neither perception nor nonperception. In the context of epistemology, it is one way of describing experience and the world in terms of twelve sense sources, which can be divided into inner and outer sense sources, namely: (1–2) eye and form, (3–4) ear and sound, (5–6) nose and odor, (7–8) tongue and taste, (9–10) body and touch, (11–12) mind and mental phenomena. In the context of the twelve links of <span data-glossary-id="UT22084-089-013-2562">dependent origination</span>, only six sense sources are mentioned, and they are the inner sense sources (identical to the six faculties) of eye, ear, nose, tongue, body, and mind.</p></div></div></div></div><div id="7878c162-9932-4033-817a-a187455f69fd" class="relative scroll-mt-20"><button type="button" id="radix-_R_bc55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.432</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">stream entrant</div><ul class="ml-4 list-disc"><li class="italic">rgyun du zhugs pa</li><li class="pt-1"><span class="font-tibetan text-base">རྒྱུན་དུ་ཞུགས་པ།</span></li><li class="italic">srotāpanna</li></ul><div class="glossary-instance-definition"><p class="definition">The first of four stages of spiritual accomplishment on the <span data-glossary-id="UT22084-089-013-2585">śrāvaka</span> path: stream entrant, <span data-glossary-id="UT22084-089-013-2507">once-returner</span>, <span data-glossary-id="UT22084-089-013-2505">non-returner</span>, and <span data-glossary-id="UT22084-089-013-2437">arhat</span>.</p></div></div></div></div><div id="9af9193f-e035-4a78-adc7-61f45871dcc8" class="relative scroll-mt-20"><button type="button" id="radix-_R_bcd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.433</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">strengths</div><ul class="ml-4 list-disc"><li class="italic">stobs</li><li class="pt-1"><span class="font-tibetan text-base">སྟོབས།</span></li><li class="italic">bala</li></ul><div class="glossary-instance-definition"><p class="definition">The five strengths are a stronger form of the five <span data-glossary-id="UT22084-089-013-2512">powers</span>: faith, mindfulness, diligence, <span data-glossary-id="UT22084-089-013-2593">samādhi</span>, and wisdom.</p></div></div></div></div><div id="f1a638a0-fac3-4272-826c-78a7878aef14" class="relative scroll-mt-20"><button type="button" id="radix-_R_bcl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.434</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Śubhakṛtsna</div><ul class="ml-4 list-disc"><li class="italic">dge rgyas</li><li class="pt-1"><span class="font-tibetan text-base">དགེ་རྒྱས།</span></li><li class="italic">śubhakṛtsna</li></ul><div class="glossary-instance-definition"><p class="definition">“Vast Goodness.” The highest of the three paradises that correspond to the third <span data-glossary-id="UT22084-089-013-2564">dhyāna</span> in the form realm.</p></div></div></div></div><div id="348e5ece-c5b0-40aa-8f93-06125a732a72" class="relative scroll-mt-20"><button type="button" id="radix-_R_bct5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.435</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sūciroma</div><ul class="ml-4 list-disc"><li class="italic">khab kyi spu</li><li class="pt-1"><span class="font-tibetan text-base">ཁབ་ཀྱི་སྤུ།</span></li><li class="italic">sūciroma</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">khab spu</em>)</p></div></div></div></div><div id="bf5045b0-2845-4c6a-9cef-e937ac0a87ab" class="relative scroll-mt-20"><button type="button" id="radix-_R_bd55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.436</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sudarśana</div><ul class="ml-4 list-disc"><li class="italic">shin tu mthong ba</li><li class="pt-1"><span class="font-tibetan text-base">ཤིན་ཏུ་མཐོང་བ།</span></li><li class="italic">sudarśana</li></ul><div class="glossary-instance-definition"><p class="definition">In the Sarvāstivāda tradition, this is the second highest of the <span data-glossary-id="UT22084-089-013-2938">Śuddhāvāsa</span> paradises, the highest paradises in the form realm. In this sūtra it is the fourth highest.</p></div></div></div></div><div id="de453836-a26d-4b71-8e67-40cceb227126" class="relative scroll-mt-20"><button type="button" id="radix-_R_bdd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.437</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Śuddhāvāsa</div><ul class="ml-4 list-disc"><li class="italic">gtsang ma’i gnas</li><li class="pt-1"><span class="font-tibetan text-base">གཙང་མའི་གནས།</span></li><li class="italic">śuddhāvāsa</li></ul><div class="glossary-instance-definition"><p class="definition">The five Pure Abodes are the highest heavens of the Form Realm (<em class="foreign break text-sa" lang="sa-LATN">rūpadhātu</em>). They are called “pure abodes” because ordinary beings (<em class="foreign break text-sa" lang="sa-LATN">pṛthagjana</em>; <em class="foreign text-wy" lang="bo-LATN">so so’i skye bo</em>) cannot be born there; only those who have achieved the fruit of a non-returner (<em class="foreign break text-sa" lang="sa-LATN">anāgāmin</em>; <em class="foreign text-wy" lang="bo-LATN">phyir mi ’ong</em>) can be born there. A summary presentation of them is found in the third chapter of Vasubandhu's <cite class="title text-en" lang="en">Abhidharmakośa</cite>, although they are repeatedly mentioned as a set in numerous sūtras, tantras, and vinaya texts.</p><p class="definition">The five Pure Abodes are the last five of the seventeen levels of the Form Realm. Specifically, they are the last five of the eight levels of the upper Form Realm‍—which corresponds to the fourth meditative concentration (<em class="foreign break text-sa" lang="sa-LATN">dhyāna</em>; <em class="foreign text-wy" lang="bo-LATN">bsam gtan</em>)‍—all of which are described as “immovable” (<em class="foreign break text-sa" lang="sa-LATN">akopya</em>; <em class="foreign text-wy" lang="bo-LATN">mi g.yo ba</em>) since they are never destroyed during the cycles of the destruction and reformation of a world system. In particular, the five are Abṛha (<em class="foreign text-wy" lang="bo-LATN">mi che ba</em>), the inferior heaven; Atapa (<em class="foreign text-wy" lang="bo-LATN">mi gdung ba</em>), the heaven of no torment; Sudṛśa (<em class="foreign text-wy" lang="bo-LATN">gya nom snang</em>), the heaven of sublime appearances; Sudarśana (<em class="foreign text-wy" lang="bo-LATN">shin tu mthong</em>), the heaven of the most beautiful to behold; and Akaniṣṭha (<em class="foreign text-wy" lang="bo-LATN">’og min</em>), the highest heaven.</p><p class="definition">Yaśomitra explains their names, stating: (1) because those who abide there can only remain for a fixed amount of time, before they are plucked out (<em class="foreign break text-sa" lang="sa-LATN">√bṛh</em>, <em class="foreign break text-sa" lang="sa-LATN">bṛṃhanti</em>) of that heaven, or because it is not as extensive (<em class="foreign break text-sa" lang="sa-LATN">abṛṃhita</em>) as the others in the pure realms, that heaven is called the inferior heaven (<em class="foreign break text-sa" lang="sa-LATN">abṛha</em>; <em class="foreign text-wy" lang="bo-LATN">mi che ba</em>); (2) since the afflictions can no longer torment (<em class="foreign break text-sa" lang="sa-LATN">√tap</em>, <em class="foreign break text-sa" lang="sa-LATN">tapanti</em>) those who reside there because of their having attained a particular samādhi, or because their state of mind is virtuous, they no longer torment (<em class="foreign break text-sa" lang="sa-LATN">√tap</em>, <em class="foreign break text-sa" lang="sa-LATN">tāpayanti</em>) others, this heaven, consequently, is called the heaven of no torment (<em class="foreign break text-sa" lang="sa-LATN">atapa</em>; <em class="foreign text-wy" lang="bo-LATN">mi gdung ba</em>); (3) since those who reside there have exceptional (<em class="foreign break text-sa" lang="sa-LATN">suṣṭhu</em>) vision because what they see (<em class="foreign break text-sa" lang="sa-LATN">√dṛś</em>, <em class="foreign break text-sa" lang="sa-LATN">darśana</em>) is utterly pure, that heaven is called the heaven of sublime appearances (<em class="foreign break text-sa" lang="sa-LATN">sudṛśa</em>; <em class="foreign text-wy" lang="bo-LATN">gya nom snang</em>); (4) because those who reside there are beautiful gods, that heaven is called the heaven of the most beautiful to behold (<em class="foreign break text-sa" lang="sa-LATN">sudarśana</em>; <em class="foreign text-wy" lang="bo-LATN">shin tu mthong</em>); and (5) since it is not lower (<em class="foreign break text-sa" lang="sa-LATN">na kaniṣṭhā</em>) than any other heaven because there is no other place superior to it, this heaven is called the highest heaven (<em class="foreign break text-sa" lang="sa-LATN">akaniṣṭha</em>; <em class="foreign text-wy" lang="bo-LATN">’og min</em>) since it is the uppermost.</p></div></div></div></div><div id="6f508ca8-b999-4554-856e-650eaec70528" class="relative scroll-mt-20"><button type="button" id="radix-_R_bdl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.438</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Śuddhodana</div><ul class="ml-4 list-disc"><li class="italic">zas gtsang ma</li><li class="pt-1"><span class="font-tibetan text-base">ཟས་གཙང་མ།</span></li><li class="italic">śuddhodana</li></ul><div class="glossary-instance-definition"><p class="definition">The Buddha <span data-glossary-id="UT22084-089-013-2797">Śākyamuni</span>’s father.</p></div></div></div></div><div id="68413d98-a056-4ae8-bf53-224ad36d306b" class="relative scroll-mt-20"><button type="button" id="radix-_R_bdt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.439</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">śūdra</div><ul class="ml-4 list-disc"><li class="italic">dmangs rigs</li><li class="pt-1"><span class="font-tibetan text-base">དམངས་རིགས།</span></li><li class="italic">śūdra</li></ul><div class="glossary-instance-definition"><p class="definition">The fourth and lowest of the classes in the caste system of India. It generally covers the laboring class.</p></div></div></div></div><div id="01673bc8-ccbe-403e-a4b2-b55e5aef7f9a" class="relative scroll-mt-20"><button type="button" id="radix-_R_be55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.440</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sudṛśa</div><ul class="ml-4 list-disc"><li class="italic">gya nom snang ba</li><li class="pt-1"><span class="font-tibetan text-base">གྱ་ནོམ་སྣང་བ།</span></li><li class="italic">sudṛśa</li></ul><div class="glossary-instance-definition"><p class="definition">“Perfect Light.” In the Sarvāstivāda tradition, this is the third highest of the five <span data-glossary-id="UT22084-089-013-2938">Śuddhāvāsa</span> paradises, the highest paradises in the form realm. In this sūtra it is the lowest of those five.</p></div></div></div></div><div id="050f5da2-dcf4-4ad2-bc60-89c89c98922d" class="relative scroll-mt-20"><button type="button" id="radix-_R_bed5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.441</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">sugata</div><ul class="ml-4 list-disc"><li class="italic">bde bar gshegs pa</li><li class="pt-1"><span class="font-tibetan text-base">བདེ་བར་གཤེགས་པ།</span></li><li class="italic">sugata</li></ul><div class="glossary-instance-definition"><p class="definition">One of the standard epithets of the buddhas. A recurrent explanation offers three different meanings for <em class="foreign break text-sa" lang="sa-LATN">su-</em> that are meant to show the special qualities of “accomplishment of one’s own purpose” (<em class="foreign break text-sa" lang="sa-LATN">svārthasampad</em>) for a complete buddha. Thus, the Sugata is “well” gone, as in the expression <em class="foreign break text-sa" lang="sa-LATN">su-rūpa</em> (“having a good form”); he is gone “in a way that he shall not come back,” as in the expression <em class="foreign break text-sa" lang="sa-LATN">su-naṣṭa-jvara</em> (“a fever that has utterly gone”); and he has gone “without any remainder” as in the expression <em class="foreign break text-sa" lang="sa-LATN">su-pūrṇa-ghaṭa</em> (“a pot that is completely full”). According to Buddhaghoṣa, the term means that the way the Buddha went (Skt. <em class="foreign break text-sa" lang="sa-LATN">gata</em>) is good (Skt. <em class="foreign break text-sa" lang="sa-LATN">su</em>) and where he went (Skt. <em class="foreign break text-sa" lang="sa-LATN">gata</em>) is good (Skt. <em class="foreign break text-sa" lang="sa-LATN">su</em>).</p></div></div></div></div><div id="f2049d91-f20d-4a00-a733-972944b9d52f" class="relative scroll-mt-20"><button type="button" id="radix-_R_bel5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.442</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sukhavihāra</div><ul class="ml-4 list-disc"><li class="italic">bde bar gnas pa</li><li class="pt-1"><span class="font-tibetan text-base">བདེ་བར་གནས་པ།</span></li><li class="italic">sukhavihāra</li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">(Toh 555: <em class="foreign break text-sa" lang="sa-LATN">Saṃtiṣṭha</em>; <em class="foreign text-wy" lang="bo-LATN">rab gnas</em>)</p></div></div></div></div><div id="86d5ef47-0af7-4d6d-8c11-c3dccbfa1da0" class="relative scroll-mt-20"><button type="button" id="radix-_R_bet5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.443</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sumati</div><ul class="ml-4 list-disc"><li class="italic">legs pa’i blo gros</li><li class="pt-1"><span class="font-tibetan text-base">ལེགས་པའི་བློ་གྲོས།</span></li><li class="italic">sumati</li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">Toh 556: <em class="foreign text-wy" lang="bo-LATN">dge ba’i blo gros</em>.</p></div></div></div></div><div id="d8f48c95-f1b6-425c-b5d0-bd902e9411e3" class="relative scroll-mt-20"><button type="button" id="radix-_R_bf55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.444</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Supratiṣṭha</div><ul class="ml-4 list-disc"><li class="italic">rab tu gnas pa</li><li class="pt-1"><span class="font-tibetan text-base">རབ་ཏུ་གནས་པ།</span></li><li class="italic">supratiṣṭha</li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva. </p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">shin tu bde bar gnas pa</em>)</p></div></div></div></div><div id="8dea9c46-4905-4030-b702-1ab457e61509" class="relative scroll-mt-20"><button type="button" id="radix-_R_bfd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.445</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Supreme Auspicious Essence</div><ul class="ml-4 list-disc"><li class="italic">bkra shis mchog gi snying po</li><li class="pt-1"><span class="font-tibetan text-base">བཀྲ་ཤིས་མཆོག་གི་སྙིང་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2496">Licchavī</span> youth.</p></div></div></div></div><div id="dc16ab92-7a7c-4e90-8abc-f8ce14a8b5d3" class="relative scroll-mt-20"><button type="button" id="radix-_R_bfl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.446</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Supreme Incense Heap</div><ul class="ml-4 list-disc"><li class="italic">spos mchog brtsegs</li><li class="pt-1"><span class="font-tibetan text-base">སྤོས་མཆོག་བརྩེགས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p><p class="definition">(Toh 555 Degé: <em class="foreign text-wy" lang="bo-LATN">spobs brtsegs</em>; Yongle, Peking, and Narthang: <em class="foreign text-wy" lang="bo-LATN">spos brtsegs</em>; Lithang and Choné: <em class="foreign text-wy" lang="bo-LATN">stobs brtse</em>)</p></div></div></div></div><div id="0877cae5-5ea3-4a25-8aa3-9f47522b3b1b" class="relative scroll-mt-20"><button type="button" id="radix-_R_bft5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.447</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Supreme King</div><ul class="ml-4 list-disc"><li class="italic">rab mchog rgyal po</li><li class="pt-1"><span class="font-tibetan text-base">རབ་མཆོག་རྒྱལ་པོ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">mchog tu rnam par rgyal ba’i rgyal po</em>)</p></div></div></div></div><div id="0a170ec8-9eb8-4594-8345-b7f9936fdc9a" class="relative scroll-mt-20"><button type="button" id="radix-_R_bg55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.448</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sureśvaraprabha</div><ul class="ml-4 list-disc"><li class="italic">lha’i dbang phyug ’od</li><li class="pt-1"><span class="font-tibetan text-base">ལྷའི་དབང་ཕྱུག་འོད།</span></li><li class="italic">sureśvaraprabha</li></ul><div class="glossary-instance-definition"><p class="definition">A king in the distant past.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">lha’i dbang phyug gi ’od</em>)</p></div></div></div></div><div id="44fa9175-aaf7-4670-b903-6d70f88ca762" class="relative scroll-mt-20"><button type="button" id="radix-_R_bgd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.449</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sūrya</div><ul class="ml-4 list-disc"><li class="italic">nyi ma</li><li class="pt-1"><span class="font-tibetan text-base">ཉི་མ།</span></li><li class="italic">sūrya</li></ul><div class="glossary-instance-definition"><p class="definition">The god of the sun.</p></div></div></div></div><div id="54456864-d1dc-483b-94d0-386ff25da1fd" class="relative scroll-mt-20"><button type="button" id="radix-_R_bgl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.450</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sūryamitra</div><ul class="ml-4 list-disc"><li class="italic">gnyen bshes</li><li class="pt-1"><span class="font-tibetan text-base">གཉེན་བཤེས།</span></li><li class="italic">sūryamitra</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king.</p><p class="definition">(Perhaps the orginal Tibetan was <em class="foreign text-wy" lang="bo-LATN">nyi bshes</em>. Lithang and Peking &amp; Toh 557: <em class="foreign text-wy" lang="bo-LATN">gnyis bshes</em>; Yongle: <em class="foreign text-wy" lang="bo-LATN">gnyi bshes</em>; Toh 555: <em class="foreign text-wy" lang="bo-LATN">nyi ma’i gnyen</em>)</p></div></div></div></div><div id="d655a04b-2ac7-4d10-acee-1b88384f0055" class="relative scroll-mt-20"><button type="button" id="radix-_R_bgt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.451</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sūryaprabha</div><ul class="ml-4 list-disc"><li class="italic">nyi ’od</li><li class="pt-1"><span class="font-tibetan text-base">ཉི་འོད།</span></li><li class="italic">sūryaprabha</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2471">deva</span>.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">nyi ma’i ’od</em>)</p></div></div></div></div><div id="ae898b58-2dc2-43ff-85f2-9bafc1a11815" class="relative scroll-mt-20"><button type="button" id="radix-_R_bh55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.452</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Susaṃbhava</div><ul class="ml-4 list-disc"><li class="italic">legs par byung ba</li><li class="pt-1"><span class="font-tibetan text-base">ལེགས་པར་བྱུང་བ།</span></li><li class="italic">susaṃbhava</li></ul><div class="glossary-instance-definition"><p class="definition">The Buddha’s previous life as a <span data-glossary-id="UT22084-089-013-2460">cakravartin</span> in the distant past.</p></div></div></div></div><div id="15d67d13-69b9-4055-897a-83c059ac8009" class="relative scroll-mt-20"><button type="button" id="radix-_R_bhd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.453</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sustaining the Saṅgha</div><ul class="ml-4 list-disc"><li class="italic">dge ’dun skyong</li><li class="pt-1"><span class="font-tibetan text-base">དགེ་འདུན་སྐྱོང་།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2496">Licchavī</span> youth.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">dge ’dun skyabs</em>)</p></div></div></div></div><div id="3d7b0e37-5f21-432a-ac79-2133c0980cb8" class="relative scroll-mt-20"><button type="button" id="radix-_R_bhl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.454</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Suvarṇabhujendra</div><ul class="ml-4 list-disc"><li class="italic">gser gyi lag pa’i dbang po</li><li class="pt-1"><span class="font-tibetan text-base">གསེར་གྱི་ལག་པའི་དབང་པོ།</span></li><li class="italic">suvarṇabhujendra</li></ul><div class="glossary-instance-definition"><p class="definition">A king in the distant past.</p></div></div></div></div><div id="5e065464-7882-44d3-823b-59e5beed659f" class="relative scroll-mt-20"><button type="button" id="radix-_R_bht5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.455</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Suvarṇa­jambu­dhvaja­kāñcanābha</div><ul class="ml-4 list-disc"><li class="italic">gser ’dzam bu’i gser gyi rgyal mtshan gyi ’od</li><li class="pt-1"><span class="font-tibetan text-base">གསེར་འཛམ་བུའི་གསེར་གྱི་རྒྱལ་མཚན་གྱི་འོད།</span></li><li class="italic">suvarṇa­jambu­dhvaja­kāñcanābha</li></ul><div class="glossary-instance-definition"><p class="definition">A buddha in the distant future who is <span data-glossary-id="UT22084-089-013-2791">Rūpyaketu</span>, the son of <span data-glossary-id="UT22084-089-013-2790">Ruciraketu</span>, in the time of <span data-glossary-id="UT22084-089-013-2797">Śākyamuni</span>.</p><p class="definition">(Toh 555: <em class="foreign break text-sa" lang="sa-LATN"><span data-glossary-id="UT22084-089-013-2838">Suvarṇa­ratnākaracchatra­kūṭa</span></em>; <em class="foreign text-wy" lang="bo-LATN">gser dang rin po che’i ri bo’i rgyal po</em>)</p></div></div></div></div><div id="d9d688dd-9c9f-4b69-8166-367dbcaf0390" class="relative scroll-mt-20"><button type="button" id="radix-_R_bi55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.456</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Suvarṇaprabhā</div><ul class="ml-4 list-disc"><li class="italic">gser du snang ba</li><li class="pt-1"><span class="font-tibetan text-base">གསེར་དུ་སྣང་བ།</span></li><li class="italic">suvarṇaprabhā</li></ul><div class="glossary-instance-definition"><p class="definition">A world realm in the distant future.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">gser ’od</em>)</p></div></div></div></div><div id="fb2c1956-a770-4cde-bbf9-4bd70acff182" class="relative scroll-mt-20"><button type="button" id="radix-_R_bid5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.457</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Suvarṇa­prabhā­garbha</div><ul class="ml-4 list-disc"><li class="italic">gser du snang ba’i snying po</li><li class="pt-1"><span class="font-tibetan text-base">གསེར་དུ་སྣང་བའི་སྙིང་པོ།</span></li><li class="italic">suvarṇa­prabhā­garbha</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2587">tathāgata</span>.</p></div></div></div></div><div id="17603ac3-863b-4d62-9530-a81ecf966e19" class="relative scroll-mt-20"><button type="button" id="radix-_R_bil5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.458</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Suvarṇa­prabhāsottama</div><ul class="ml-4 list-disc"><li class="italic">gser ’od dam pa</li><li class="pt-1"><span class="font-tibetan text-base">གསེར་འོད་དམ་པ།</span></li><li class="italic">suvarṇa­prabhāsottama</li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva with the same name as the title of the sūtra.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">gser gyi ’od</em>)</p></div></div></div></div><div id="f7f116d5-a109-4e86-94e5-ac4c3be955cf" class="relative scroll-mt-20"><button type="button" id="radix-_R_bit5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.459</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Suvarṇa­puṣpa­jvala­raśmi­ketu</div><ul class="ml-4 list-disc"><li class="italic">gser gyi me tog ’bar ba’i ’od zer gyi tog</li><li class="pt-1"><span class="font-tibetan text-base">གསེར་གྱི་མེ་ཏོག་འབར་བའི་འོད་ཟེར་གྱི་ཏོག</span></li><li class="italic">suvarṇa­puṣpa­jvala­raśmi­ketu</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2587">tathāgata</span>. </p><p class="definition">(Toh 555: <em class="foreign break text-sa" lang="sa-LATN">Suvarṇa­puṣpa­raśmi­dhvaja</em>; <em class="foreign text-wy" lang="bo-LATN">gser gyi me tog ’od zer rgyal mtshan</em>)</p></div></div></div></div><div id="65b2f20f-7c74-4ee1-bc62-41574f376841" class="relative scroll-mt-20"><button type="button" id="radix-_R_bj55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.460</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Suvarṇa­ratnākaracchatra­kūṭa</div><ul class="ml-4 list-disc"><li class="italic">gser dang rin po che’i ’byung gnas gdugs brtsegs, gser ri rin chen ’byung gnas gdugs brtsegs</li><li class="pt-1"><span class="font-tibetan text-base">གསེར་དང་རིན་པོ་ཆེའི་འབྱུང་གནས་གདུགས་བརྩེགས།, གསེར་རི་རིན་ཆེན་འབྱུང་གནས་གདུགས་བརྩེགས།</span></li><li class="italic">suvarṇa­ratnākaracchatra­kūṭa</li></ul><div class="glossary-instance-definition"><p class="definition">A buddha in the distant future who is the bodhisattva <span data-glossary-id="UT22084-089-013-2790">Ruciraketu</span> in the time of <span data-glossary-id="UT22084-089-013-2797">Śākyamuni</span>. </p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">gser gdugs rin po che brtsegs pa</em>)</p></div></div></div></div><div id="0108e28b-5bcb-4ce4-826d-644d60fed1fc" class="relative scroll-mt-20"><button type="button" id="radix-_R_bjd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.461</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Svarṇakeśin</div><ul class="ml-4 list-disc"><li class="italic">gser ’dra’i skra</li><li class="pt-1"><span class="font-tibetan text-base">གསེར་འདྲའི་སྐྲ།</span></li><li class="italic">svarṇakeśin</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">su bar na dang ke śa</em> (incorrectly dividing the name into two names))</p></div></div></div></div><div id="36e894c5-d3e2-47b6-b319-d843a8cf6a87" class="relative scroll-mt-20"><button type="button" id="radix-_R_bjl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.462</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">sweet flag</div><ul class="ml-4 list-disc"><li class="italic">shu dag</li><li class="pt-1"><span class="font-tibetan text-base">ཤུ་དག</span></li><li class="italic">vacā</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign">Acorus calamus</em>. A plant of marshes and wetlands, native to India. There are a number of variant Sanskrit names for this plant. Its leaves, stem, and roots are used in Āyurvedic medicine.</p></div></div></div></div><div id="e73562d6-15c5-4706-82c3-8f843ccfec58" class="relative scroll-mt-20"><button type="button" id="radix-_R_bjt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.463</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">tathāgata</div><ul class="ml-4 list-disc"><li class="italic">de bzhin gshegs pa</li><li class="pt-1"><span class="font-tibetan text-base">དེ་བཞིན་གཤེགས་པ།</span></li><li class="italic">tathāgata</li></ul><div class="glossary-instance-definition"><p class="definition">A frequently used synonym for <em class="emph">buddha</em>. According to different explanations, it can be read as <em class="foreign break text-sa" lang="sa-LATN">tathā-gata</em>, literally meaning “one who has thus gone,” or as <em class="foreign break text-sa" lang="sa-LATN">tathā-āgata</em>, “one who has thus come.” <em class="foreign break text-sa" lang="sa-LATN">Gata</em>, though literally meaning “gone,” is a past passive participle used to describe a state or condition of existence. <em class="foreign break text-sa" lang="sa-LATN">Tatha­(tā)</em>, often rendered as “suchness” or “thusness,” is the quality or condition of things as they really are, which cannot be conveyed in conceptual, dualistic terms. Therefore, this epithet is interpreted in different ways, but in general it implies one who has departed in the wake of the buddhas of the past, or one who has manifested the supreme awakening dependent on the reality that does not abide in the two extremes of existence and quiescence. It is also often used as a specific epithet of the Buddha Śākyamuni.</p></div></div></div></div><div id="e1835138-8dd9-4be2-b440-10fe21a3124c" class="relative scroll-mt-20"><button type="button" id="radix-_R_bk55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.464</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">ten strengths</div><ul class="ml-4 list-disc"><li class="italic">stobs bcu</li><li class="pt-1"><span class="font-tibetan text-base">སྟོབས་བཅུ།</span></li><li class="italic">daśabala</li></ul><div class="glossary-instance-definition"><p class="definition">The ten <span data-glossary-id="UT22084-089-013-2530">strengths</span> are (1) the knowledge of what is possible; (2) the knowledge of the ripening of karma; (3) the knowledge of the variety of aspirations; (4) the knowledge of the variety of natures; (5) the knowledge of the different levels of capabilities; (6) the knowledge of the destinations of all paths of rebirth; (7) the knowledge of various states of meditation; (8) the knowledge of remembering previous lives; (9) the knowledge of deaths and rebirths; and (10) the knowledge of the cessation of <span data-glossary-id="UT22084-089-013-2470">defilements</span>.</p></div></div></div></div><div id="7834a906-6b84-466f-bd06-44338770f988" class="relative scroll-mt-20"><button type="button" id="radix-_R_bkd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.465</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">the state of infinite consciousness</div><ul class="ml-4 list-disc"><li class="italic">rnam shes mtha’ yas skye mched</li><li class="pt-1"><span class="font-tibetan text-base">རྣམ་ཤེས་མཐའ་ཡས་སྐྱེ་མཆེད།</span></li><li class="italic">vijñānānantyāyatana</li></ul><div class="glossary-instance-definition"><p class="definition">The third highest of the four formless realms. See also “<span><span data-glossary-id="UT22084-089-013-3269">state</span></span>.”</p></div></div></div></div><div id="8af2c1e1-946c-4ad3-8e62-2af9c556a10d" class="relative scroll-mt-20"><button type="button" id="radix-_R_bkl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.466</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Thief of All Beings’ Splendor</div><ul class="ml-4 list-disc"><li class="italic">sems can kun gyi gzi ’phrog ma</li><li class="pt-1"><span class="font-tibetan text-base">སེམས་ཅན་ཀུན་གྱི་གཟི་འཕྲོག་མ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A fierce goddess.</p><p class="definition">(Toh 555 and Toh 557: <em class="foreign text-wy" lang="bo-LATN">sems can kun gyi mdangs ’phrog ma</em>)</p></div></div></div></div><div id="63cafe4c-eba9-4989-a3c0-11ac3d24ef23" class="relative scroll-mt-20"><button type="button" id="radix-_R_bkt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.467</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">thirty-two signs</div><ul class="ml-4 list-disc"><li class="italic">mtshan sum cu rtsa gnyis</li><li class="pt-1"><span class="font-tibetan text-base">མཚན་སུམ་ཅུ་རྩ་གཉིས།</span></li><li class="italic">dvātriṃśalakṣaṇa, dvātriṃśallakṣaṇa</li></ul><div class="glossary-instance-definition"><p class="definition">These are the thirty-two major physical of marks of a great being, namely a buddha or a universal monarch. These are complemented by <span data-glossary-id="UT22084-089-013-2566">eighty features</span>.</p></div></div></div></div><div id="7015a5ba-934e-44c1-9e77-244de7b7c93a" class="relative scroll-mt-20"><button type="button" id="radix-_R_bl55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.468</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">three bodies</div><ul class="ml-4 list-disc"><li class="italic">sku gsum</li><li class="pt-1"><span class="font-tibetan text-base">སྐུ་གསུམ།</span></li><li class="italic">trikāya</li></ul><div class="glossary-instance-definition"><p class="definition">The three kāyas, or bodies, are the <span data-glossary-id="UT22084-089-013-2475">Dharma body</span>, <span data-glossary-id="UT22084-089-013-2520">enjoyment body</span>, and <span data-glossary-id="UT22084-089-013-2504">emanation body</span>.</p></div></div></div></div><div id="278e0920-e973-43fd-9ff8-bee92154851b" class="relative scroll-mt-20"><button type="button" id="radix-_R_bld5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.469</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">three knowledges</div><ul class="ml-4 list-disc"><li class="italic">rig pa gsum</li><li class="pt-1"><span class="font-tibetan text-base">རིག་པ་གསུམ།</span></li><li class="italic">traividya</li></ul><div class="glossary-instance-definition"><p class="definition">Knowledge through divine sight (<em class="foreign text-wy" lang="bo-LATN">lha’i mig gi shes pa</em>), knowledge through remembering past lives (<em class="foreign text-wy" lang="bo-LATN">sngon gyi gnas rjes su dran pa’i rig pa</em>), and the knowledge that <span data-glossary-id="UT22084-089-013-2470">defilements</span> have ceased (<em class="foreign text-wy" lang="bo-LATN">zag pa zad pa’i rig pa</em>). </p></div></div></div></div><div id="5ce97104-9d23-45ca-84a6-2dbb47a60a00" class="relative scroll-mt-20"><button type="button" id="radix-_R_bll5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.470</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">three worlds</div><ul class="ml-4 list-disc"><li class="italic">’jig rten gsum</li><li class="pt-1"><span class="font-tibetan text-base">འཇིག་རྟེན་གསུམ།</span></li><li class="italic">trailokya</li></ul><div class="glossary-instance-definition"><p class="definition">The three realms of desire, form, and formlessness.</p></div></div></div></div><div id="37aad8a1-ee19-486a-b8cf-4a279d99ca14" class="relative scroll-mt-20"><button type="button" id="radix-_R_blt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.471</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Tip of Brilliant, Precious, Pure Fire</div><ul class="ml-4 list-disc"><li class="italic">dri ma med par ’bar ba rin chen ’od zer snang ba’i tog</li><li class="pt-1"><span class="font-tibetan text-base">དྲི་མ་མེད་པར་འབར་བ་རིན་ཆེན་འོད་ཟེར་སྣང་བའི་ཏོག</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2587">tathāgata</span>.</p><p class="definition">(Toh 555: <em class="foreign break text-sa" lang="sa-LATN">Vimala­raśmi­ratna­ketu</em>; <em class="foreign text-wy" lang="bo-LATN">dri ma med pa’i ’od zer rin po che’i tog</em>. Toh 557: <em class="foreign break text-sa" lang="sa-LATN">Vimala­jvālā­ratna­suvarṇa­raśmi­prabhā­śikhin</em>; <em class="foreign text-wy" lang="bo-LATN">dri ma med par ’bar ba rin chen gser gyi ’od zer snang ba’i rtog</em>. Sanskrit ms.: <em class="foreign break text-sa" lang="sa-LATN"><span data-glossary-id="UT22084-089-013-2786">Ratnaśikhin</span></em>)</p></div></div></div></div><div id="4b2c2119-6dd4-4607-afda-9c0ea3cd6860" class="relative scroll-mt-20"><button type="button" id="radix-_R_bm55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.472</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">tīrthika</div><ul class="ml-4 list-disc"><li class="italic">mu stegs can</li><li class="pt-1"><span class="font-tibetan text-base">མུ་སྟེགས་ཅན།</span></li><li class="italic">tīrthika</li></ul><div class="glossary-instance-definition"><p class="definition">Those of other religious or philosophical orders, contemporary with the early Buddhist order, including Jains, Jaṭilas, Ājīvikas, and Cārvākas. Tīrthika (“forder”) literally translates as “one belonging to or associated with (possessive suffix <em class="foreign break text-sa" lang="sa-LATN">–ika</em>) stairs for landing or for descent into a river,” or “a bathing place,” or “a place of pilgrimage on the banks of sacred streams” (Monier-Williams). The term may have originally referred to temple priests at river crossings or fords where travelers propitiated a deity before crossing. The Sanskrit term seems to have undergone metonymic transfer in referring to those able to ford the turbulent river of saṃsāra (as in the Jain tīrthaṅkaras, “ford makers”), and it came to be used in Buddhist sources to refer to teachers of rival religious traditions. The Sanskrit term is closely rendered by the Tibetan <em class="foreign text-wy" lang="bo-LATN">mu stegs pa</em>: “those on the steps (<em class="foreign text-wy" lang="bo-LATN">stegs pa</em>) at the edge (<em class="foreign text-wy" lang="bo-LATN">mu</em>).”</p></div></div></div></div><div id="fb356f46-3c64-4256-8c64-7d0c8d24f7ba" class="relative scroll-mt-20"><button type="button" id="radix-_R_bmd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.473</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Trāyastriṃśa</div><ul class="ml-4 list-disc"><li class="italic">sum cu rtsa gsum pa</li><li class="pt-1"><span class="font-tibetan text-base">སུམ་ཅུ་རྩ་གསུམ་པ།</span></li><li class="italic">trāyastriṃśa</li></ul><div class="glossary-instance-definition"><p class="definition">The paradise of <span data-glossary-id="UT22084-089-013-2796">Śakra</span>, also known as <span data-glossary-id="UT22084-089-013-2656">Indra</span>, on the summit of <span data-glossary-id="UT22084-089-013-2940">Sumeru</span>. The name means “Thirty-Three,” from the thirty-three principal deities that dwell there. The fifth highest of the six paradises in the desire realm.</p></div></div></div></div><div id="15fc18c2-88b8-4b6b-80b5-7b16a0dc9174" class="relative scroll-mt-20"><button type="button" id="radix-_R_bml5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.474</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">trichiliocosm</div><ul class="ml-4 list-disc"><li class="italic">stong gsum, stong gsum gyi stong chen po’i rjig rten gyi khams</li><li class="pt-1"><span class="font-tibetan text-base">སྟོང་གསུམ་གྱི་སྟོང་ཆེན་པོའི་རྗིག་རྟེན་གྱི་ཁམས།, སྟོང་གསུམ།</span></li><li class="italic">tri­sāhasra­mahā­sāhasra­loka­dhātu</li></ul><div class="glossary-instance-definition"><p class="definition">The largest universe described in Buddhist cosmology. This term, in Abhidharma cosmology, refers to 1,000<sup>³</sup> world systems, i.e., 1,000 “dichiliocosms” or “two thousand great thousand world realms” (<em class="foreign break text-sa" lang="sa-LATN">dvi­sāhasra­mahā­sāhasra­lokadhātu</em>), which are in turn made up of 1,000 first-order world systems, each with its own Mount Sumeru, continents, sun and moon, etc.</p></div></div></div></div><div id="4203fb7e-7856-4620-9067-849b57cb0e05" class="relative scroll-mt-20"><button type="button" id="radix-_R_bmt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.475</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Trisong Detsen</div><ul class="ml-4 list-disc"><li class="italic">’khri srong lde btsan</li><li class="pt-1"><span class="font-tibetan text-base">འཁྲི་སྲོང་ལྡེ་བཙན།</span></li></ul><div class="glossary-instance-definition"><p class="definition">King of Tibet who reigned ca. 742/55–798/804 <span class="small-caps">ᴄᴇ</span>.</p></div></div></div></div><div id="65ca5a2a-58f4-48a7-875d-4c857644ce4b" class="relative scroll-mt-20"><button type="button" id="radix-_R_bn55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.476</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Tuṣita</div><ul class="ml-4 list-disc"><li class="italic">dga’ ldan</li><li class="pt-1"><span class="font-tibetan text-base">དགའ་ལྡན།</span></li><li class="italic">tuṣita</li></ul><div class="glossary-instance-definition"><p class="definition">Tuṣita (or sometimes Saṃtuṣita), literally “Joyous” or “Contented,” is one of the six heavens of the desire realm (<em class="foreign break text-sa" lang="sa-LATN">kāmadhātu</em>). In standard classifications, such as the one in the <cite class="title break text-sa" lang="sa-LATN">Abhidharmakośa</cite>, it is ranked as the fourth of the six counting from below. This god realm is where all future buddhas are said to dwell before taking on their final rebirth prior to awakening. There, the Buddha Śākyamuni lived his preceding life as the bodhisattva Śvetaketu. When departing to take birth in this world, he appointed the bodhisattva Maitreya, who will be the next buddha of this eon, as his Dharma regent in Tuṣita. For an account of the Buddha’s previous life in Tuṣita, see <cite class="title text-en" lang="en">The Play in Full</cite> (Toh 95), <a target="_blank" href="https://read.84000.co/translation/UT22084-046-001.html#UT22084-046-001-68" title="2.12">2.12</a>, and for an account of Maitreya’s birth in Tuṣita and a description of this realm, see <cite class="title text-en" lang="en"><a target="_blank" href="https://read.84000.co/translation/toh199.html" title="The Sūtra on Maitreya’s Birth in the Heaven of Joy">The Sūtra on Maitreya’s Birth in the Heaven of Joy</a></cite>, (Toh 199).</p></div></div></div></div><div id="75361058-6742-4076-af23-8648a2692c65" class="relative scroll-mt-20"><button type="button" id="radix-_R_bnd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.477</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">twelve forms of the teaching</div><ul class="ml-4 list-disc"><li class="italic">gsung rab yan lag bcu gnyis</li><li class="pt-1"><span class="font-tibetan text-base">གསུང་རབ་ཡན་ལག་བཅུ་གཉིས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">The classification of all aspects of the Buddha’s teachings into twelve types: <em class="foreign break text-sa" lang="sa-LATN">sūtra</em>, <em class="foreign break text-sa" lang="sa-LATN">geya</em>, <span class="ignore"><em class="foreign break text-sa" lang="sa-LATN">vyākaraṇa</em></span>, <em class="foreign break text-sa" lang="sa-LATN">gāthā</em>, <em class="foreign break text-sa" lang="sa-LATN">udāna</em>, <em class="foreign break text-sa" lang="sa-LATN">nidāna</em>, <em class="foreign break text-sa" lang="sa-LATN">avadāna</em>, <em class="foreign break text-sa" lang="sa-LATN">itivṛttaka</em>, <em class="foreign break text-sa" lang="sa-LATN">jātaka</em>, <em class="foreign break text-sa" lang="sa-LATN">vaipulya</em>, <em class="foreign break text-sa" lang="sa-LATN">adbhutadharma</em>, and <em class="foreign break text-sa" lang="sa-LATN">upadeśa</em>. </p></div></div></div></div><div id="58885000-c069-48fe-8aa1-4a45303f548a" class="relative scroll-mt-20"><button type="button" id="radix-_R_bnl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.478</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">twelve phases of dependent origination</div><ul class="ml-4 list-disc"><li class="italic">rten cing ’brel bar ’byung ba yan lag bcu gnyis</li><li class="pt-1"><span class="font-tibetan text-base">རྟེན་ཅིང་འབྲེལ་བར་འབྱུང་བ་ཡན་ལག་བཅུ་གཉིས།</span></li><li class="italic">dvādaśāṅga­pratītya­samutpāda</li></ul><div class="glossary-instance-definition"><p class="definition">The principle of dependent origination asserts that nothing exists independently of other factors, the reason for this being that things and events come into existence only by dependence on the aggregation of multiple causes and conditions. In general, the processes of cyclic existence, through which the external world and the sentient beings within it revolve in a continuous cycle of suffering, propelled by the propensities of past actions and their interaction with afflicted mental states, originate dependent on the sequential unfolding of twelve links: (1) fundamental ignorance, (2) formative predispositions, (3) consciousness, (4) name and form, (5) sense field, (6) sensory contact, (7) sensation, (8) craving, (9) grasping, (10) rebirth process, (11) actual birth, (12) aging and death. It is through deliberate reversal of these twelve links that one can succeed in bringing the whole cycle to an end.</p></div></div></div></div><div id="74dca416-c548-475c-b1ec-23b1692ad82a" class="relative scroll-mt-20"><button type="button" id="radix-_R_bnt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.479</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">ultimately real</div><ul class="ml-4 list-disc"><li class="italic">yongs su grub pa</li><li class="pt-1"><span class="font-tibetan text-base">ཡོངས་སུ་གྲུབ་པ།</span></li><li class="italic">pariniṣpanna</li></ul><div class="glossary-instance-definition"><p class="definition">The direct perception of the nature of the mind and its objects. An alternative translation is “the absolute.” One of the three natures that are a central philosophy of the Yogācāra tradition.</p></div></div></div></div><div id="4bcdfbef-2fa4-4c4a-943e-2b78601af192" class="relative scroll-mt-20"><button type="button" id="radix-_R_bo55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.480</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Umādevī</div><ul class="ml-4 list-disc"><li class="italic">lha mo u ma</li><li class="pt-1"><span class="font-tibetan text-base">ལྷ་མོ་ཨུ་མ།</span></li><li class="italic">umādevī</li></ul><div class="glossary-instance-definition"><p class="definition">A goddess. </p></div></div></div></div><div id="7a0c5ff1-a4b7-4c1d-a4b8-be615a683340" class="relative scroll-mt-20"><button type="button" id="radix-_R_bod5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.481</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Unobstructed Appearance of the Light of a Lion’s Ornament</div><ul class="ml-4 list-disc"><li class="italic">seng ge’i tog gi ’od zer snang ba thogs pa med pa</li><li class="pt-1"><span class="font-tibetan text-base">སེང་གེའི་ཏོག་གི་འོད་ཟེར་སྣང་བ་ཐོགས་པ་མེད་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A bodhisattva.</p><p class="definition">Yongle and Peking: <em class="foreign text-wy" lang="bo-LATN">seng ge’i tog ’od zer snang ba thogs pa med pa</em>.</p></div></div></div></div><div id="03ad7ca4-c671-415b-87a1-864d8faa7a9c" class="relative scroll-mt-20"><button type="button" id="radix-_R_bol5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.482</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">upādhyāya</div><ul class="ml-4 list-disc"><li class="italic">mkhan po</li><li class="pt-1"><span class="font-tibetan text-base">མཁན་པོ།</span></li><li class="italic">upādhyāya</li></ul><div class="glossary-instance-definition"><p class="definition">In India, a person’s particular preceptor within the monastic tradition, guiding that person for the taking of full vows and the maintenance of conduct and practice. The Tibetan translation <em class="foreign text-wy" lang="bo-LATN">mkhan po</em> has also come to mean “a learned scholar,” the equivalent of a <em class="foreign break text-sa" lang="sa-LATN">paṇḍita</em>, but that is not the intended meaning in the sūtras. </p></div></div></div></div><div id="7bfd1347-20b7-4f5f-8bde-38f29e3b7402" class="relative scroll-mt-20"><button type="button" id="radix-_R_bot5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.483</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Upananda</div><ul class="ml-4 list-disc"><li class="italic">nye dga’ bo</li><li class="pt-1"><span class="font-tibetan text-base">ཉེ་དགའ་བོ།</span></li><li class="italic">upananda</li></ul><div class="glossary-instance-definition"><p>One of eight mythological nāga kings. The story of the two nāga kings Upananda and Nanda and their taming by the Buddha and Maudgalyāyana is told in the <cite class="title break text-sa" lang="sa-LATN">Vinayavibhaṅga</cite> (Toh 3, Degé vol. 6, <em class="foreign text-wy" lang="bo-LATN">’dul ba</em>, <em class="foreign text-wy" lang="bo-LATN">ja</em>, F.221.a–224.a).</p></div></div></div></div><div id="2bdf3bc7-527a-47ec-b8b5-58b49e2d27d2" class="relative scroll-mt-20"><button type="button" id="radix-_R_bp55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.484</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">upāsaka</div><ul class="ml-4 list-disc"><li class="italic">dge bsnyen</li><li class="pt-1"><span class="font-tibetan text-base">དགེ་བསྙེན།</span></li><li class="italic">upāsaka</li></ul><div class="glossary-instance-definition"><p class="definition">A man who has taken the layperson’s vows.</p></div></div></div></div><div id="4c34c0f5-37c5-4d26-8dd8-41e42b1dbeaa" class="relative scroll-mt-20"><button type="button" id="radix-_R_bpd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.485</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">upāsikā</div><ul class="ml-4 list-disc"><li class="italic">dge bsnyen ma</li><li class="pt-1"><span class="font-tibetan text-base">དགེ་བསྙེན་མ།</span></li><li class="italic">upāsikā</li></ul><div class="glossary-instance-definition"><p class="definition">A woman who has taken the layperson’s vows.</p></div></div></div></div><div id="8d0903a2-f477-4f84-8692-b3cb32af25e1" class="relative scroll-mt-20"><button type="button" id="radix-_R_bpl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.486</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">ūrṇā</div><ul class="ml-4 list-disc"><li class="italic">mdzod spu</li><li class="pt-1"><span class="font-tibetan text-base">མཛོད་སྤུ།</span></li><li class="italic">ūrṇā</li></ul><div class="glossary-instance-definition"><p>One of the thirty-two marks of a great being. It consists of a soft, long, fine, coiled white hair between the eyebrows capable of emitting an intense bright light. Literally, the Sanskrit ūrṇā means “wool hair,” and kośa means “treasure.”</p></div></div></div></div><div id="e21d2a6c-d330-45b8-b200-1358ce48bd11" class="relative scroll-mt-20"><button type="button" id="radix-_R_bpt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.487</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Uruvilva­kāśyapa</div><ul class="ml-4 list-disc"><li class="italic">ltang rgyas ’od srung</li><li class="pt-1"><span class="font-tibetan text-base">ལྟང་རྒྱས་འོད་སྲུང་།</span></li><li class="italic">uruvilva­kāśyapa</li></ul><div class="glossary-instance-definition"><p class="definition">The brother of <span data-glossary-id="UT22084-089-013-2651">Gayākāśyapa</span> and <span data-glossary-id="UT22084-089-013-2745">Nadīkāśyapa</span>. A practitioner of fire offering at Uruvilva (Bodhgayā), he and his five hundred pupils were converted to becoming <span data-glossary-id="UT22084-089-013-2450">bhikṣus</span> of the Buddha. He and his brothers and their students were the third group to become followers of the Buddha after his enlightenment.</p></div></div></div></div><div id="169da212-d4f0-4402-9743-ef8193e94f46" class="relative scroll-mt-20"><button type="button" id="radix-_R_bq55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.488</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vairocana</div><ul class="ml-4 list-disc"><li class="italic">rnam par snang mdzad</li><li class="pt-1"><span class="font-tibetan text-base">རྣམ་པར་སྣང་མཛད།</span></li><li class="italic">vairocana</li></ul></div></div></div><div id="b34c94aa-14b1-4eaf-adf1-2c486d729f7d" class="relative scroll-mt-20"><button type="button" id="radix-_R_bqd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.489</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vaiśravaṇa</div><ul class="ml-4 list-disc"><li class="italic">rnam thos kyi bu</li><li class="pt-1"><span class="font-tibetan text-base">རྣམ་ཐོས་ཀྱི་བུ།</span></li><li class="italic">vaiśravaṇa</li></ul><div class="glossary-instance-definition"><p class="definition">As one of the <span data-glossary-id="UT22084-089-013-2867">Four Mahārājas</span> he is the lord of the northern region of the world and the northern continent, though in early Buddhism he is the lord of the far north of India and beyond. Also known as Kubera, he is the lord of the <span data-glossary-id="UT22084-089-013-2555">yakṣas</span> and a lord of wealth.</p></div></div></div></div><div id="53fbb1f3-7ac3-4b87-b11b-b36093229f9b" class="relative scroll-mt-20"><button type="button" id="radix-_R_bql5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.490</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">vaiśya</div><ul class="ml-4 list-disc"><li class="italic">rje’u rigs</li><li class="pt-1"><span class="font-tibetan text-base">རྗེའུ་རིགས།</span></li><li class="italic">vaiśya</li></ul><div class="glossary-instance-definition"><p class="definition">The third of the four classes in the Indian caste system. It generally includes merchants and farmers.</p></div></div></div></div><div id="d173b57a-c45c-4a6b-8354-3934f81db9d6" class="relative scroll-mt-20"><button type="button" id="radix-_R_bqt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.491</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vajra Guard</div><ul class="ml-4 list-disc"><li class="italic">rdo rje skyong</li><li class="pt-1"><span class="font-tibetan text-base">རྡོ་རྗེ་སྐྱོང་།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2496">Licchavī</span> youth.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">rdo rje skyabs</em>)</p></div></div></div></div><div id="1585b1ef-2bd9-48cf-a525-2d94ef5009c5" class="relative scroll-mt-20"><button type="button" id="radix-_R_br55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.492</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vajra­guhyakādhipati</div><ul class="ml-4 list-disc"><li class="italic">rdo rje gsang bdag</li><li class="pt-1"><span class="font-tibetan text-base">རྡོ་རྗེ་གསང་བདག</span></li><li class="italic">vajra­guhyakādhipati</li></ul><div class="glossary-instance-definition"><p class="definition">One of the names of Kubera, the god of wealth, meaning “Lightning Lord of the Guhyakas,” or “treasure guardian.” In the tantra tradition, Guhyapati, “Lord of Secrets,” became a title of <span data-glossary-id="UT22084-089-013-2850">Vajrapāṇi</span>.</p></div></div></div></div><div id="aa8dbe14-0268-4087-bb0e-b23d4f172ad7" class="relative scroll-mt-20"><button type="button" id="radix-_R_brd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.493</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vajrapāṇi</div><ul class="ml-4 list-disc"><li class="italic">lag na rdo rje</li><li class="pt-1"><span class="font-tibetan text-base">ལག་ན་རྡོ་རྗེ།</span></li><li class="italic">vajrapāṇi</li></ul><div class="glossary-instance-definition"><p class="definition">Vajrapāṇi means “Wielder of the Vajra.” In the Pali canon, he appears as a yakṣa guardian in the retinue of the Buddha. In the Mahāyāna scriptures he is a bodhisattva and one of the “eight close sons of the Buddha.” In the tantras, he is also regarded as an important Buddhist deity and instrumental in the transmission of tantric scriptures. </p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">rdo rje’i thal mo</em>)</p></div></div></div></div><div id="9dfe53ed-6bc5-40bf-a98b-426653bc2a2f" class="relative scroll-mt-20"><button type="button" id="radix-_R_brl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.494</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vajraprākāra</div><ul class="ml-4 list-disc"><li class="italic">rdo rje’i ’byung gnas</li><li class="pt-1"><span class="font-tibetan text-base">རྡོ་རྗེའི་འབྱུང་གནས།</span></li><li class="italic">vajraprākāra</li></ul><div class="glossary-instance-definition"><p class="definition">A mountain.</p></div></div></div></div><div id="01d79f9d-969f-40f5-9ed9-aace04146db4" class="relative scroll-mt-20"><button type="button" id="radix-_R_brt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.495</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">valerian</div><ul class="ml-4 list-disc"><li class="italic">rgya spos</li><li class="pt-1"><span class="font-tibetan text-base">རྒྱ་སྤོས།</span></li><li class="italic">tagara</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign">Valeriana wallichii</em>. Specifically, Indian valerian, also known as <em class="foreign break text-sa" lang="sa-LATN">tagara</em> and <em class="foreign break text-sa" lang="sa-LATN">tagar</em>.</p></div></div></div></div><div id="d0d8412d-d993-4a5d-9a68-ec95c31fb0a5" class="relative scroll-mt-20"><button type="button" id="radix-_R_bs55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.496</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vāli</div><ul class="ml-4 list-disc"><li class="italic">’khri byed</li><li class="pt-1"><span class="font-tibetan text-base">འཁྲི་བྱེད།</span></li><li class="italic">vāli|</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king.</p></div></div></div></div><div id="46a03f56-b8a6-4364-815a-c46fe1c8c186" class="relative scroll-mt-20"><button type="button" id="radix-_R_bsd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.497</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Varāṅga</div><ul class="ml-4 list-disc"><li class="italic">yan lag mchog</li><li class="pt-1"><span class="font-tibetan text-base">ཡན་ལག་མཆོག</span></li><li class="italic">varāṅga</li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p></div></div></div></div><div id="32b540ca-3edf-4b2f-991d-e6fcfc940b08" class="relative scroll-mt-20"><button type="button" id="radix-_R_bsl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.498</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Varaprabha</div><ul class="ml-4 list-disc"><li class="italic">’od mchog</li><li class="pt-1"><span class="font-tibetan text-base">འོད་མཆོག</span></li><li class="italic">varaprabha</li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p></div></div></div></div><div id="62f42c0e-d91a-46e3-b023-18e6aa4e1559" class="relative scroll-mt-20"><button type="button" id="radix-_R_bst5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.499</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Varṣādhipati</div><ul class="ml-4 list-disc"><li class="italic">char pa’i bdag po</li><li class="pt-1"><span class="font-tibetan text-base">ཆར་པའི་བདག་པོ།</span></li><li class="italic">varṣādhipati</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2555">yakṣa</span> king. The name means “Lord of Rain.”</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">char pa’i dbang po</em>)</p></div></div></div></div><div id="a26cc09a-abe6-47e9-944d-9590174c2948" class="relative scroll-mt-20"><button type="button" id="radix-_R_bt55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.500</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Varuṇa</div><ul class="ml-4 list-disc"><li class="italic">chu lha</li><li class="pt-1"><span class="font-tibetan text-base">ཆུ་ལྷ།</span></li><li class="italic">varuṇa</li></ul><div class="glossary-instance-definition"><p class="definition">The name of the deity of water. In the Vedas, Varuṇa is an important deity and in particular the deity of the sky, but in later Indian tradition he is the god of only the water and the underworld. The Tibetan does not attempt to translate his name but instead has “god of water.” </p></div></div></div></div><div id="dd792a30-125e-4ad5-9418-22092de2cd82" class="relative scroll-mt-20"><button type="button" id="radix-_R_btd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.501</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vāṣpa</div><ul class="ml-4 list-disc"><li class="italic">rlangs pa</li><li class="pt-1"><span class="font-tibetan text-base">རླངས་པ།</span></li><li class="italic">Bāṣpa, Vāṣpa</li></ul><div class="glossary-instance-definition"><p class="definition">He was one of the five companions of <span data-glossary-id="UT22084-089-013-2797">Śākyamuni</span> in asceticism and later one of his first five pupils, attaining the state of a <span data-glossary-id="UT22084-089-013-2529">stream entrant</span>. </p></div></div></div></div><div id="bbcb4b9b-c780-4212-8ca1-b692c23b70e7" class="relative scroll-mt-20"><button type="button" id="radix-_R_btl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.502</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vasu</div><ul class="ml-4 list-disc"><li class="italic">ba su</li><li class="pt-1"><span class="font-tibetan text-base">བ་སུ།</span></li><li class="italic">vasu</li></ul><div class="glossary-instance-definition"><p class="definition">The name of a goddess, identified as the sister of <span data-glossary-id="UT22084-089-013-2687">Mahādeva</span>.</p></div></div></div></div><div id="67bf2141-0183-41e2-9b1b-d99b7afa1f04" class="relative scroll-mt-20"><button type="button" id="radix-_R_btt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.503</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vāsuki</div><ul class="ml-4 list-disc"><li class="italic">nor rgyas</li><li class="pt-1"><span class="font-tibetan text-base">ནོར་རྒྱས།</span></li><li class="italic">vāsuki</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2503">nāga</span> king, well known in Indian mythology as being the serpent coiled around <span data-glossary-id="UT22084-089-013-2940">Meru</span> that was used to churn the ocean at the origin of the world. </p></div></div></div></div><div id="3e4d8365-1139-4dd3-bcb0-5e315926fc79" class="relative scroll-mt-20"><button type="button" id="radix-_R_bu55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.504</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vāyu</div><ul class="ml-4 list-disc"><li class="italic">rlung</li><li class="pt-1"><span class="font-tibetan text-base">རླུང་།</span></li><li class="italic">vāyu</li></ul><div class="glossary-instance-definition"><p class="definition">The god of the air and the winds.</p></div></div></div></div><div id="8877bcd2-0685-49fb-bc77-d4fbb309e71a" class="relative scroll-mt-20"><button type="button" id="radix-_R_bud5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.505</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vemacitra</div><ul class="ml-4 list-disc"><li class="italic">thags zangs</li><li class="pt-1"><span class="font-tibetan text-base">ཐགས་ཟངས།</span></li><li class="italic">vemacitra</li></ul><div class="glossary-instance-definition"><p class="definition">The king of the <span data-glossary-id="UT22084-089-013-2559">asuras</span>. Also translated as <em class="foreign text-wy" lang="bo-LATN">bzang ris</em>.</p><p class="definition">Degé Toh 556, Peking, Narthang and Lhasa: <em class="foreign text-wy" lang="bo-LATN">thag bzangs</em>. Degé Toh 557: <em class="foreign text-wy" lang="bo-LATN">thag bzangs</em>.</p></div></div></div></div><div id="36789778-dfff-49f5-919b-5ef4da528975" class="relative scroll-mt-20"><button type="button" id="radix-_R_bul5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.506</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Venerable</div><ul class="ml-4 list-disc"><li class="italic">tshe dang ldan pa</li><li class="pt-1"><span class="font-tibetan text-base">ཚེ་དང་ལྡན་པ།</span></li><li class="italic">āyuṣmat</li></ul><div class="glossary-instance-definition"><p>A respectful form of address between monks, and also between lay companions of equal standing. It literally means “one who has a [long] life.”</p></div></div></div></div><div id="1b1e99da-21ed-4210-ac9c-8e048a470c51" class="relative scroll-mt-20"><button type="button" id="radix-_R_but5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.507</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">vetāla</div><ul class="ml-4 list-disc"><li class="italic">ro langs</li><li class="pt-1"><span class="font-tibetan text-base">རོ་ལངས།</span></li><li class="italic">vetāla</li></ul><div class="glossary-instance-definition"><p class="definition">A class of beings that typically haunt charnel grounds and enter into and animate corpses. Hence, the Tibetan translation means “risen corpse.”</p></div></div></div></div><div id="e3b20cb4-6f07-49d9-a014-0f298e77705c" class="relative scroll-mt-20"><button type="button" id="radix-_R_bv55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.508</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">vetiver</div><ul class="ml-4 list-disc"><li class="italic">u shi ra</li><li class="pt-1"><span class="font-tibetan text-base">ཨུ་ཤི་ར།</span></li><li class="italic">uśīra</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign">Andropogon muricatus</em>, <em class="foreign">Andropogon zizanioides</em>. A type of grass. </p></div></div></div></div><div id="8301c1cb-1410-43db-baa6-735291ab31c2" class="relative scroll-mt-20"><button type="button" id="radix-_R_bvd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.509</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vibhūṣita</div><ul class="ml-4 list-disc"><li class="italic">shin tu brgyan</li><li class="pt-1"><span class="font-tibetan text-base">ཤིན་ཏུ་བརྒྱན།</span></li><li class="italic">vibhūṣita</li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p></div></div></div></div><div id="4b99845d-79aa-49c7-ac0c-9dab285dddf7" class="relative scroll-mt-20"><button type="button" id="radix-_R_bvl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.510</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">vidyāmantra</div><ul class="ml-4 list-disc"><li class="italic">rig pa’i gsang sngags, rig sngags</li><li class="pt-1"><span class="font-tibetan text-base">རིག་པའི་གསང་སྔགས།, རིག་སྔགས།</span></li><li class="italic">vidyāmantra</li></ul><div class="glossary-instance-definition"><p class="definition">A type of incantation or spell used to accomplish a ritual goal. This can be associated with either ordinary attainments or those whose goal is awakening.</p></div></div></div></div><div id="493a67ab-dcbf-4e3e-855a-c49ffde8f018" class="relative scroll-mt-20"><button type="button" id="radix-_R_bvt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.511</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vidyutprabha</div><ul class="ml-4 list-disc"><li class="italic">glog ’od</li><li class="pt-1"><span class="font-tibetan text-base">གློག་འོད།</span></li><li class="italic">vidyutprabha</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-089-013-2503">nāga</span> king.</p></div></div></div></div><div id="75c946eb-d5f8-4076-b501-0a27636b15cd" class="relative scroll-mt-20"><button type="button" id="radix-_R_c055anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.512</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vimalaprabhā</div><ul class="ml-4 list-disc"><li class="italic">dri ma med pa’i ’od</li><li class="pt-1"><span class="font-tibetan text-base">དྲི་མ་མེད་པའི་འོད།</span></li><li class="italic">vimalaprabhā</li></ul><div class="glossary-instance-definition"><p class="definition">The future realm where five hundred thousand <span data-glossary-id="UT22084-089-013-2450">bhikṣus</span> in the Buddha’s <span data-glossary-id="UT22084-089-013-2522">saṅgha</span> will become buddhas.</p></div></div></div></div><div id="e5d8ecb7-0147-46b5-9d97-17b7ed06cd4a" class="relative scroll-mt-20"><button type="button" id="radix-_R_c0d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.513</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">vinaya</div><ul class="ml-4 list-disc"><li class="italic">’dul ba</li><li class="pt-1"><span class="font-tibetan text-base">འདུལ་བ།</span></li><li class="italic">vinaya</li></ul></div></div></div><div id="e8ba371d-c0e9-433d-b790-44db8459ce2e" class="relative scroll-mt-20"><button type="button" id="radix-_R_c0l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.514</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vindhya</div><ul class="ml-4 list-disc"><li class="italic">bin dhu</li><li class="pt-1"><span class="font-tibetan text-base">བིན་དྷུ།</span></li><li class="italic">vindhya</li></ul><div class="glossary-instance-definition"><p class="definition">A series of mountain ranges that extend across central India. The usual translation is <em class="foreign text-wy" lang="bo-LATN">bigs byed</em>.</p></div></div></div></div><div id="ebfd449d-b733-4c85-a12f-ae45b26e399c" class="relative scroll-mt-20"><button type="button" id="radix-_R_c0t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.515</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Virajadhvajā</div><ul class="ml-4 list-disc"><li class="italic">rdul med pa’i rgyal mtshan</li><li class="pt-1"><span class="font-tibetan text-base">རྡུལ་མེད་པའི་རྒྱལ་མཚན།</span></li><li class="italic">virajadhvajā</li></ul><div class="glossary-instance-definition"><p class="definition">A world realm in the distant future.</p></div></div></div></div><div id="18be2255-0ed5-4db9-9d71-15b7069c04f9" class="relative scroll-mt-20"><button type="button" id="radix-_R_c155anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.516</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Virtue of Light</div><ul class="ml-4 list-disc"><li class="italic">’od dge</li><li class="pt-1"><span class="font-tibetan text-base">འོད་དགེ</span></li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p></div></div></div></div><div id="81ed76f6-e8c3-449e-b1bd-dfd1e3751283" class="relative scroll-mt-20"><button type="button" id="radix-_R_c1d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.517</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Virūḍhaka</div><ul class="ml-4 list-disc"><li class="italic">’phags skyes po</li><li class="pt-1"><span class="font-tibetan text-base">འཕགས་སྐྱེས་པོ།</span></li><li class="italic">virūḍhaka</li></ul><div class="glossary-instance-definition"><p class="definition">One of the <span data-glossary-id="UT22084-089-013-2867">Four Mahārājas</span>, he is the guardian of the southern direction and the lord of the <span data-glossary-id="UT22084-089-013-2573">kumbhāṇḍas</span>.</p></div></div></div></div><div id="cc4bedf3-722d-478c-a51b-f63ec54cb6f5" class="relative scroll-mt-20"><button type="button" id="radix-_R_c1l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.518</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Virūpākṣa</div><ul class="ml-4 list-disc"><li class="italic">mig mi bzang</li><li class="pt-1"><span class="font-tibetan text-base">མིག་མི་བཟང་།</span></li><li class="italic">virūpākṣa</li></ul><div class="glossary-instance-definition"><p class="definition">One of the <span data-glossary-id="UT22084-089-013-2867">Four Mahārājas</span>, he is the guardian of the western direction and the lord of the <span data-glossary-id="UT22084-089-013-2503">nāgas</span>.</p></div></div></div></div><div id="decffb01-a15a-4366-a8c4-9633d0e0f8a9" class="relative scroll-mt-20"><button type="button" id="radix-_R_c1t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.519</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Viśālaśrī</div><ul class="ml-4 list-disc"><li class="italic">yangs pa’i dpal</li><li class="pt-1"><span class="font-tibetan text-base">ཡངས་པའི་དཔལ།</span></li><li class="italic">viśālaśrī</li></ul><div class="glossary-instance-definition"><p class="definition">A buddha.</p></div></div></div></div><div id="612fe3c1-7f5f-4186-aec2-263fa9964f75" class="relative scroll-mt-20"><button type="button" id="radix-_R_c255anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.520</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Viṣṇu</div><ul class="ml-4 list-disc"><li class="italic">’jug sel</li><li class="pt-1"><span class="font-tibetan text-base">འཇུག་སེལ།</span></li><li class="italic">viṣṇu</li></ul><div class="glossary-instance-definition"><p class="definition">One of the primary gods of the Brahmanical tradition, he is associated with the preservation and continuance of the universe.</p><p class="definition">(Toh 555: <em class="foreign text-wy" lang="bo-LATN">khyab ’jug</em>)</p></div></div></div></div><div id="bbb9e0c6-80e9-4879-ad0d-7c85f53bda98" class="relative scroll-mt-20"><button type="button" id="radix-_R_c2d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.521</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vulture Peak</div><ul class="ml-4 list-disc"><li class="italic">bya rgod kyi phung po’i ri, bya rgod phung po</li><li class="pt-1"><span class="font-tibetan text-base">བྱ་རྒོད་ཀྱི་ཕུང་པོའི་རི།, བྱ་རྒོད་ཕུང་པོ།</span></li><li class="italic">gṛdhrakūṭa, gṛdhra­kūṭa­parvata</li></ul><div class="glossary-instance-definition"><p>The Gṛdhra­kūṭa, literally Vulture Peak, was a hill located in the kingdom of Magadha, in the vicinity of the ancient city of Rājagṛha (modern-day Rajgir, in the state of Bihar, India), where the Buddha bestowed many sūtras, especially the Great Vehicle teachings, such as the Prajñāpāramitā sūtras. It continues to be a sacred pilgrimage site for Buddhists to this day.</p></div></div></div></div><div id="4ab87917-09a8-4fc8-86f0-bcf3470b170a" class="relative scroll-mt-20"><button type="button" id="radix-_R_c2l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.522</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vyākaraṇa</div><ul class="ml-4 list-disc"><li class="italic">lung ston pa</li><li class="pt-1"><span class="font-tibetan text-base">ལུང་སྟོན་པ།</span></li><li class="italic">vyākaraṇa</li></ul><div class="glossary-instance-definition"><p class="definition">The <span data-glossary-id="UT22084-089-013-2457">brahmin</span> master, interlocutor in <cite class="title text-en" lang="en">The Sūtra of the Sublime Golden Light</cite>. See also <a href="end-notes.xhtml#UT22084-089-013-274" data-pointer-type="id">n.62</a>.</p></div></div></div></div><div id="4f990e63-9af4-4bbd-92b5-c2d339ca0f46" class="relative scroll-mt-20"><button type="button" id="radix-_R_c2t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.523</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Waning Light</div><ul class="ml-4 list-disc"><li class="italic">’od nyams pa</li><li class="pt-1"><span class="font-tibetan text-base">འོད་ཉམས་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">A god who is the king of lightning in the western direction.</p></div></div></div></div><div id="e1ac7ae9-aee8-4af8-93a8-b2b50197e211" class="relative scroll-mt-20"><button type="button" id="radix-_R_c355anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.524</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">white beryl</div><ul class="ml-4 list-disc"><li class="italic">bai DUr+ya</li><li class="pt-1"><span class="font-tibetan text-base">བཻ་ཌཱུརྱ།</span></li><li class="italic">veruli</li></ul><div class="glossary-instance-definition"><p class="definition">Goshenite: pure beryl without the impurities that give it its various colors.</p></div></div></div></div><div id="85557c47-a055-487c-b292-5fafd9983925" class="relative scroll-mt-20"><button type="button" id="radix-_R_c3d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.525</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">white water lilies, white water lily</div><ul class="ml-4 list-disc"><li class="italic">ku mu da</li><li class="pt-1"><span class="font-tibetan text-base">ཀུ་མུ་ད།</span></li><li class="italic">kumuda</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign">Nymphaea pubescens</em>. The night-blossoming water lily, sometimes referred to as a “night lotus.” It can be white, pink, or red.</p></div></div></div></div><div id="c43d5a58-fb85-4e3a-afc6-f0a682651a64" class="relative scroll-mt-20"><button type="button" id="radix-_R_c3l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.526</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">world guardians</div><ul class="ml-4 list-disc"><li class="italic">’jig rten skyong ba</li><li class="pt-1"><span class="font-tibetan text-base">འཇིག་རྟེན་སྐྱོང་བ།</span></li><li class="italic">lokapāla</li></ul><div class="glossary-instance-definition"><p class="definition">A set of deities, each guarding a certain direction. Most commonly these are <span data-glossary-id="UT22084-089-013-2656">Indra</span> (<span data-glossary-id="UT22084-089-013-2796">Śakra</span>) for the east, Agni for the southeast, <span data-glossary-id="UT22084-089-013-2866">Yama</span> for the south, <span data-glossary-id="UT22084-089-013-2826">Sūrya</span> or Nirṛti for the southwest, <span data-glossary-id="UT22084-089-013-2854">Varuṇa</span> for the west, <span data-glossary-id="UT22084-089-013-2858">Vāyu</span> (Pavana) for the northwest, Kubera for the north, and <span data-glossary-id="UT22084-089-013-2817">Soma</span> (Candra), Iśāni, or Pṛthivī for the northeast.</p></div></div></div></div><div id="b4640039-6b60-4eb6-8695-1c0153d43a37" class="relative scroll-mt-20"><button type="button" id="radix-_R_c3t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.527</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">yakṣa</div><ul class="ml-4 list-disc"><li class="italic">gnod sbyin</li><li class="pt-1"><span class="font-tibetan text-base">གནོད་སྦྱིན།</span></li><li class="italic">yakṣa</li></ul><div class="glossary-instance-definition"><p class="definition">A class of nonhuman beings who inhabit forests, mountainous areas, and other natural spaces, or serve as guardians of villages and towns, and may be propitiated for health, wealth, protection, and other boons, or controlled through magic. According to tradition, their homeland is in the north, where they live under the rule of the Great King Vaiśravaṇa.</p><p class="definition"> Several members of this class have been deified as gods of wealth (these include the just-mentioned Vaiśravaṇa) or as bodhisattva generals of yakṣa armies, and have entered the Buddhist pantheon in a variety of forms, including, in tantric Buddhism, those of wrathful deities.</p></div></div></div></div><div id="1e26e678-33c0-4607-8c82-26972918a7b9" class="relative scroll-mt-20"><button type="button" id="radix-_R_c455anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.528</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">yakṣiṇī</div><ul class="ml-4 list-disc"><li class="italic">gnod sbyin mo</li><li class="pt-1"><span class="font-tibetan text-base">གནོད་སྦྱིན་མོ།</span></li><li class="italic">yakṣiṇī</li></ul><div class="glossary-instance-definition"><p class="definition">A female <span data-glossary-id="UT22084-089-013-2555">yakṣa</span>. </p></div></div></div></div><div id="a2732adf-5a36-4094-8b21-eea5ae281056" class="relative scroll-mt-20"><button type="button" id="radix-_R_c4d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.529</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Yama</div><ul class="ml-4 list-disc"><li class="italic">gshin rje</li><li class="pt-1"><span class="font-tibetan text-base">གཤིན་རྗེ།</span></li><li class="italic">yama</li></ul><div class="glossary-instance-definition"><p class="definition">The lord of death.</p></div></div></div></div><div id="99305b1b-4231-4b37-abf3-3eae59c96480" class="relative scroll-mt-20"><button type="button" id="radix-_R_c4l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.530</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Yāma</div><ul class="ml-4 list-disc"><li class="italic">’thab bral</li><li class="pt-1"><span class="font-tibetan text-base">འཐབ་བྲལ།</span></li><li class="italic">yāma</li></ul><div class="glossary-instance-definition"><p class="definition">The third highest of the six paradises in the desire realm. Its name means “Free of Conflict.”</p></div></div></div></div><div id="a19e5bbe-8501-4ef7-acae-78182289d957" class="relative scroll-mt-20"><button type="button" id="radix-_R_c4t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.531</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">yojana</div><ul class="ml-4 list-disc"><li class="italic">dpag tshad</li><li class="pt-1"><span class="font-tibetan text-base">དཔག་ཚད།</span></li><li class="italic">yojana</li></ul><div class="glossary-instance-definition"><p class="definition">The longest unit of distance in classical India. The lack of a uniform standard for the smaller units means that there is no precise equivalent, especially as its theoretical length tended to increase over time. Therefore, it can indicate a distance of between four and ten miles.</p></div></div></div></div></div></div></div><div data-state="inactive" data-orientation="horizontal" role="tabpanel" aria-labelledby="radix-_R_2npftt6btb_-trigger-bibliography" id="radix-_R_2npftt6btb_-content-bibliography" tabindex="0" data-slot="tabs-content" class="mt-2 ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 pb-8 data-[state=inactive]:hidden"><div class="flex flex-col w-full"><div id="bibliography" class="relative scroll-mt-20"><button type="button" id="radix-_R_2nanpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4 @c/sidebar:mt-5 mt-6">b.</button><div class="passage pl-6 @c/sidebar:pl-4"><h2 class="font-serif font-light text-primary scroll-m-20 text-xl @c/sidebar:mt-4 mt-6 @c/sidebar:pb-2 pb-3 @c/sidebar:text-left text-center section-title">Bibliography</h2></div></div><div class="mt-3 flex flex-col gap-6"><div class="flex flex-col gap-4"><div id="Primary Sources in Tibetan and Chinese-0" class="relative scroll-mt-20"><button type="button" id="radix-_R_ad7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4 @c/sidebar:mt-0.5 mt-4">b.1</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="text-secondary font-sans text-base font-bold">Primary Sources in Tibetan and Chinese</div></div></div><div id="934db7e1-c7b1-4f02-85b1-32b943976ff5" class="relative scroll-mt-20"><button type="button" id="radix-_R_2cd7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.1.1</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p><em>gser ’od dam pa’i mdo</em>. Toh 555, Degé Kangyur vol. 89 (rgyud ’bum, pa), folios 19.a–151a. English translation <em><a href="https://read.84000.co/translation/toh555">The Sūtra of the Sublime Golden Light (1)</a></em> 2023.</p></div></div></div><div id="f5556d52-436b-4c38-9f4b-78c9fbdd8d63" class="relative scroll-mt-20"><button type="button" id="radix-_R_2kd7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.1.2</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p><em>gser ’od dam pa mdo sde’i dbang po’i rgyal po zhes bya ba theg pa chen po’i mdo</em> (<em>Suvarṇa­prabhāsottama­sūtrendra­rājanāma­mahāyāna­sūtra</em>). Toh 556, Degé Kangyur vol. 89 (rgyud ’bum, pa), folios 151.b–273.a.</p></div></div></div><div id="fe86650a-2a94-437d-839a-2328f14ddf8a" class="relative scroll-mt-20"><button type="button" id="radix-_R_2sd7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.1.3</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p><em>gser ’od dam pa mdo sde’i dbang po’i rgyal po zhes bya ba theg pa chen po’i mdo</em> (<em>Suvarṇa­prabhāsottama­sūtrendra­rāja­nāma­mahāyāna­sūtra</em>). Toh 557, Degé Kangyur vol. 90 (rgyud ’bum, pha), folios 1.a–62.a. English translation <em><a href="https://read.84000.co/translation/toh557">The Sūtra of the Sublime Golden Light (3)</a></em> 2024.</p></div></div></div><div id="7af7515b-d3ca-4c5a-8a1b-9e9ead85ed27" class="relative scroll-mt-20"><button type="button" id="radix-_R_34d7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.1.4</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p><em>Hebu jin guangming</em> <em>合部金光明經</em>. Taishō 664 (<a href="https://cbetaonline.dila.edu.tw/en/T0664">CBETA</a>, <a href="https://21dzk.l.u-tokyo.ac.jp/SAT2018/T0664.html">SAT</a>). (Translation of <em>Suvarṇa­prabhāsottama­sūtra</em> by Bao Gui <em>寶貴</em>).</p></div></div></div><div id="71f2442a-530f-43d5-803b-ab6eb9d38103" class="relative scroll-mt-20"><button type="button" id="radix-_R_3cd7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.1.5</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p><em>Jin guangming jin</em> <em>金光明經</em>. Taishō 663 (<a href="https://cbetaonline.dila.edu.tw/en/T0663">CBETA</a>, <a href="https://21dzk.l.u-tokyo.ac.jp/SAT2018/T0663.html">SAT</a>). (Translation of <em>Suvarṇa­prabhāsottama­sūtra</em> by Dharmakṣema, a.k.a. Tan Wuchen <em>曇無讖</em>).</p></div></div></div><div id="bf2047fc-ee67-4246-8377-da6f6decb39c" class="relative scroll-mt-20"><button type="button" id="radix-_R_3kd7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.1.6</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p><em>Jin guangming zuisheng wang jin</em> <em>金光明最勝王經</em>. Taishō 665 (<a href="https://cbetaonline.dila.edu.tw/en/T0665">CBETA</a>, <a href="https://21dzk.l.u-tokyo.ac.jp/SAT2018/T0665.html">SAT</a>). (Translation of <em>Suvarṇa­prabhāsottama­sūtra</em> by Yijing <em>義淨</em>).</p></div></div></div></div><div class="flex flex-col gap-4"><div id="Secondary References—Kangyur-1" class="relative scroll-mt-20"><button type="button" id="radix-_R_al7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4 @c/sidebar:mt-0.5 mt-4">b.2</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="text-secondary font-sans text-base font-bold">Secondary References—Kangyur</div></div></div><div id="477b2040-6b9b-4043-a076-37ea67f26c94" class="relative scroll-mt-20"><button type="button" id="radix-_R_2cl7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.2.1</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p><em>dkyil ’khor thams cad kyi spyi’i cho ga gsang ba’i rgyud</em> (<em>Sarva­maṇḍala­sāmānyavidhi­guhya­tantra</em>). Toh 806, Degé Kangyur vol. 96 (rgyud, wa), folios 141.a–167.b. </p></div></div></div><div id="155afcc2-599d-482a-a8b4-c4b9c8de30bc" class="relative scroll-mt-20"><button type="button" id="radix-_R_2kl7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.2.2</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p><em>’jam dpal gyi rtsa ba’i rgyud</em> (<em>Mañjuśrīmūlakalpa</em>). Toh 543, Degé Kangyur vol.88 (rgyud, na), folios 105.a–351.a. English translation <em><a href="https://read.84000.co/translation/toh543">The Root Manual of the Rites of Mañjuśrī</a></em> 2020.</p></div></div></div><div id="6fd8e1a7-d2d5-42d0-82bd-a0508b96140d" class="relative scroll-mt-20"><button type="button" id="radix-_R_2sl7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.2.3</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p><em>’od srung kyi le’u zhes bya ba theg pa chen po’i mdo</em> (<em>Kāśyapa­parivarta­nāma­mahāyāna­sūtra</em>). Toh 87, Degé Kangyur vol. 44 (dkon brtsegs, cha), folios 119.b–151.b. </p></div></div></div><div id="8b688c99-eae5-4093-823c-74f455eaa014" class="relative scroll-mt-20"><button type="button" id="radix-_R_34l7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.2.4</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p><em>ral pa gyen brdzes kyi rtog pa chen po byang chub sems dpa’ chen po’i rnam par ’phrul pa le’u rab ’byams las bcom ldan ’das ma ’phags ma sgrol ma’i rtsa ba’i rtog pa zhes bya ba</em> (<em>Ūrdhvajaṭā­mahā­kalpa­mahā­bodhi­sattva­vikurvaṇa­paṭalavisarā bhagavatī ārya­tārā­mūla­kalpa­nāma</em>). Toh 724, Degé Kangyur vol. 93 (rgyud, tsa), folios 205.b–311.a, and vol. 94 (rgyud, tsha), folios 1.a–200.a.</p></div></div></div><div id="e04e9d32-5841-4be3-9550-33e3d55a2710" class="relative scroll-mt-20"><button type="button" id="radix-_R_3cl7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.2.5</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p><em>blo gros mi zad pas zhus pa zhes bya ba theg pa chen po’i mdo</em> (<em>Akṣaya­mati­paripṛcchā­nāma­mahāyāna­sūtra</em>). Toh 89, Degé Kangyur vol. 44 (dkon brtsegs, cha), folios 175.b–182.b.</p></div></div></div><div id="efbef59b-abd4-4b2f-8325-182b3457e08a" class="relative scroll-mt-20"><button type="button" id="radix-_R_3kl7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.2.6</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p><em>lang kar gshegs pa’i theg pa chen po’i mdo</em> (<em>Laṅkāvatāra­mahāyāna­sūtra</em>). Toh 107, Degé Kangyur vol. 49 (mdo sde, ca), folios 56.a–191.b.</p></div></div></div><div id="d8f46541-456e-41a4-9666-67cc169c47ba" class="relative scroll-mt-20"><button type="button" id="radix-_R_3sl7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.2.7</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p><em>las kyi sgrib pa gcod pa zhes bya ba theg pa chen po’i mdo</em> (<em>Karmā­varaṇa­prati­praśrabdhi­nāma­mahāyāna­sūtra</em>). Toh 219, Degé Kangyur vol. 62 (mdo sde, tsha), folios 297.b–307.a. English translation <em><a href="https://read.84000.co/translation/toh219">Putting an End to Karmic Obscurations</a></em> 2024.</p></div></div></div></div><div class="flex flex-col gap-4"><div id="Secondary References—Tengyur-2" class="relative scroll-mt-20"><button type="button" id="radix-_R_at7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4 @c/sidebar:mt-0.5 mt-4">b.3</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="text-secondary font-sans text-base font-bold">Secondary References—Tengyur</div></div></div><div id="2eeb42ec-d659-4366-bab3-8d856b6b5664" class="relative scroll-mt-20"><button type="button" id="radix-_R_gct7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.1</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Ajitaśrībhadra. <em>dga’ ba’i bshes gnyen gyi rtogs pa</em> (<em>Nandamitrāvadāna</em>). Toh 4146, Degé Tengyur vol. 269 (’dul ba, su), folios 240.a–244.b.</p></div></div></div><div id="10ff20c0-e5e4-4b0d-9c42-f55e2b661a9e" class="relative scroll-mt-20"><button type="button" id="radix-_R_gkt7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.2</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Ānandagarbha. <em>rdo rje dbyings kyi dkyil ’khor chen po’i cho ga rdo rje thams cad ’byungs ba</em> (<em>Vajra­dhātu­mahā­maṇḍalopāyikā­sarva­vajrodaya</em>). Toh 2516, Degé Tengyur vol. 62 (rgyud, ku), folios 1.a–50.a.</p></div></div></div><div id="b2a04aa3-05de-4334-bba4-10ef13960b26" class="relative scroll-mt-20"><button type="button" id="radix-_R_gst7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.3</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Anonymous. <em>rgyal po gser gyi lag pa’i smon lam</em> (<em>Rāja­suvarṇa­bhuja­praṇidhāna</em>). Toh 4380, Degé Tengyur vol. 309 (sna tshogs, nyo), folios 309b–310a.</p></div></div></div><div id="ef0e8b02-1791-45fe-b001-191d983e32ab" class="relative scroll-mt-20"><button type="button" id="radix-_R_h4t7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.4</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Anonymous. <em>’jam pa’i rdo rje ’byung ba’i dkyil ’khor gyi cho ga sems can thams cad kyi bde ba bskyed pa</em> (<em>Mañju­vajrodaya­maṇḍalopāyikā­sarva­sattva­hitāvahā</em>). Toh 2590, Degé Tengyur vol. 65 (rgyud, ngu), folios 225.a–274.a.</p></div></div></div><div id="a116f427-0d4c-45a1-9a9b-b7bde4f2bf0f" class="relative scroll-mt-20"><button type="button" id="radix-_R_hct7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.5</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Anonymous. <em>gser ’od dam pa mdo sde dbang po’i smon lam</em> (<em>Suvarṇa­prabhāsottama­sūtrendra­praṇidhāna</em>). Toh 4379, Degé Tengyur vol. 309 (sna tshogs, nyo), folios 304.b–309.b.</p></div></div></div><div id="0e617ff9-af9d-44f5-97ce-6c6d0a869208" class="relative scroll-mt-20"><button type="button" id="radix-_R_hkt7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.6</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Āryadeva. <em>spyod pa bsdud pa’i sgron ma</em> (<em>Caryāmelāpaka­pradīpa</em>). Toh 1803, Degé Tengyur vol. 65 (rgyud, ngi), folios 57.a–106.b.</p></div></div></div><div id="73f7a6e3-5abe-49b3-9001-37dac774892d" class="relative scroll-mt-20"><button type="button" id="radix-_R_hst7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.7</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Bhavya. <em>dbu ma rin po che’i sgron ma</em> (<em>Madhyamaka­ratna­pradīpa</em>). Toh 3854, Degé Tengyur vol. 199 (dbu ma, tsha), folios 259.b–289.a.</p></div></div></div><div id="ba30bb24-c5dd-4cad-808d-4e70f947288b" class="relative scroll-mt-20"><button type="button" id="radix-_R_i4t7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.8</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Bhavyakīrti. <em>sgron ma gsal bar byed pa dgongs pa rab gsal zhes bya ba bshad pa’i ti ka</em> (<em>Pradīpoddyotanābhisaṁdhi­prakāśikā­nāma­vyākhyā­ṭīkā</em>). Toh 1793, Degé Tengyur vols. 32–33 (rgyud, ki), folios 1.b–292.a, and (rgyud, khi), folios 1.b–155.a.</p></div></div></div><div id="198741bf-b279-4f02-b2ed-8ae04f7f12d1" class="relative scroll-mt-20"><button type="button" id="radix-_R_ict7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.9</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Bodhisattva. <em>kun nas sgor ’jug pa’i ’od zer gtsug tor dri ma med par snang ba’i gzungs bklag cing chod rten brgya rtsa brgyad dam mchod rten lnga gdab pa’i cho ga mdo sde las btus pa</em> (<em>Samanta­mukha­praveśa­raśmi­vimaloṣṇīṣa­prabhāsa­dhāraṇī­vacana­sūtrāntoddhṛtāṣṭottara­śata­caityāntara­pañca­caitya­nirvapaṇa­vidhi</em>). Toh 3068, Degé Tengyur vol. 74 (rgyud, pu), folios 140.a–153.a.</p></div></div></div><div id="1199ff28-d0bd-4179-b627-0fdbb4435ecd" class="relative scroll-mt-20"><button type="button" id="radix-_R_ikt7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.10</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Buddhānandagarbha. <em>de bzhin gshegs pa dgra bcom pa yang dag par rdzogs pa’i sangs rgyas ngan song thams cad yongs su sbyong ba gzi brjid kyi rgyal po zhes bya ba’i bshad pa</em> (<em>Sarva­durgati­pariśodhana­tejorāja­tathāgatārhat­samyaksaṃbuddha­nāma­kalpa­ṭīkā</em>). Toh 2628, Degé Tengyur vol. 68 (rgyud, ju), folios 1.a–97.a.</p></div></div></div><div id="77fbcefe-4600-43c6-88b3-83b8323a8678" class="relative scroll-mt-20"><button type="button" id="radix-_R_ist7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.11</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Dharmakīrtiśrī. <em>shes rab kyi pha rol tu phyin pa’i man ngag gi bstan bcos mngon par rtogs pa’i rgyan zhes bya ba’i ’grel pa rtogs par dka’ ba’i snang ba zhes bya ba’i ’grel bshad</em> (<em>Abhisamayālaṃkāra­nāma­prajñā­pāramitopadeśa­śāstra­vṛtti­durbodhāloka­nāma­ṭīkā</em>). Toh 3794, Degé Tengyur vol. 86 (sher phyin, ja), folios 140.b–254.a.</p></div></div></div><div id="d5f766b6-dc21-4e30-9ef1-5f764348984c" class="relative scroll-mt-20"><button type="button" id="radix-_R_j4t7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.12</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Dharmamitra. <em>shes rab kyi pha rol tu phyin pa’i man ngag gi bstan bcos mngon par rtogs pa’i rgyan gyi tshig le’ur byas pa’i ’grel bshad tshig rab tu gsal ba</em> (<em>Abhisamayālaṃkāra­kārikā­prajñā­pāramitopadeśa­śāstra­ṭīkāprasphuṭapadā</em>). Toh 3796, Degé Tengyur vol. 87 (sher phyin, nya), folios 1.a–110.a.</p></div></div></div><div id="b9edabf4-a5a6-40d4-81b9-18623c9d4b35" class="relative scroll-mt-20"><button type="button" id="radix-_R_jct7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.13</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Dīpaṁkaraśrījñāna. <em>dbu ma’i man ngag rin po che’i za ma tog kha phye ba zhes bya ba</em> (<em>Ratna­karaṇḍodghāṭa­nāma­madhyamakopadeśa</em>). Toh 3930, Degé Tengyur vol. 212 (dbu ma, ki), folios 96.b–116.b.</p></div></div></div><div id="b80c2c6e-ebef-4d6e-9a34-978e8bcfe6f8" class="relative scroll-mt-20"><button type="button" id="radix-_R_jkt7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.14</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Dīpaṁkaraśrījñāna. <em>byang chub lam gyi sgron ma’i dka’ ’grel</em> (<em>Bodhi­mārga­pradīpa­pañjikā</em>). Toh 3948, Degé Tengyur vol. 213 (mdo ’grel, khi), folios 241.a–293.a.</p></div></div></div><div id="a4789f4b-7aed-411a-ace9-239b4a86c9b1" class="relative scroll-mt-20"><button type="button" id="radix-_R_jst7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.15</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Dīpaṁkaraśrījñāna. <em>mngon par rtogs pa rnam par ’byed pa zhes bya ba</em> (<em>Abhisamaya­vibhaṅga­nāma</em>). Toh 1490, Degé Tengyur vol. 22 (rgyud, zha), folios 186.a–202.b.</p></div></div></div><div id="2421c194-4f01-411b-b61b-74be20e569e7" class="relative scroll-mt-20"><button type="button" id="radix-_R_k4t7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.16</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Ekādaśanirghoṣa. <em>rdo rje ’chang chen po’i lam gyi rim pa’i man ngag bdud rtsi gsang ba</em> (<em>Mahā­vajra­dhara­patha­kramopadeśāmṛta­guhya</em>). Toh 1823, Degé Tengyur vol. 35 (rgyud, ngi), folios 267.b–278.a.</p></div></div></div><div id="efca091a-4839-4769-b187-5eb4adbecf1b" class="relative scroll-mt-20"><button type="button" id="radix-_R_kct7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.17</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Haribhadra. <em>shes rab kyi pha rol tu phyin pa brgyad stong pa’i bshad pa mngon par rtogs pa’i rgyan gyi snang ba</em> (<em>Aṣṭa­sāhasrikā­prajñā­pāramitā­vyākhyānābhi­samayālaṃkārāloka</em>). Toh 3791, Degé Tengyur vol. 85 (sher phyin, cha), folios 1.a–341.a.</p></div></div></div><div id="d23a6da7-79e8-426f-9460-7e725d6322db" class="relative scroll-mt-20"><button type="button" id="radix-_R_kkt7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.18</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Kāmadhenu. <em>ngan song thams cad yongs su sbyong ba gzi brjid kyi rgyal po zhes bya ba cho ga zhib mo’i rgyal po chen po’i rgya cher ’grel pa</em> (<em>Sarva­durgati­pariśodhana­tejorāja­nāma­mahā­kalpa­rāja­ṭīkā</em>). Toh 2625, Degé Tengyur vol. 666 (rgyud, cu), folios 231.a–341.a.</p></div></div></div><div id="7ef13d93-00c8-4c75-b201-ad6fc109ea71" class="relative scroll-mt-20"><button type="button" id="radix-_R_kst7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.19</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Mañjuśrīkīrti. <em>’jam dpal gyi mtshan yang dag par brjod pa’i rgya cher bshad pa</em> (<em>Mañjuśrī­nāma­saṃgīti­ṭīkā</em>). Toh 2534, Degé Tengyur vol. 63 (gyud, khu), folios 115.b–301.a.</p></div></div></div><div id="4d151250-3eb0-4a41-bc37-e9473f0a30ed" class="relative scroll-mt-20"><button type="button" id="radix-_R_l4t7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.20</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Paltsek (dpal brtsegs). <em>gsung rab rin po che’i gtam rgyud dang shA kya’i rabs rgyud</em>. Toh 4357, Degé Tengyur vol. 306 (sna tshogs, co), folios 239.a–377.a.</p></div></div></div><div id="d8d55cd6-8195-4853-a547-813c2c876bfb" class="relative scroll-mt-20"><button type="button" id="radix-_R_lct7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.21</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Paltsek (dpal brtsegs). <em>pho brang stod thang lhan dkar gyi chos ’gyur ro cog gi dkar chag</em>. Toh 4364, Degé Tengyur vol. 308 (sna tshogs, jo), folios 294.b–310.a.</p></div></div></div><div id="4f938f52-c9df-4a22-8664-1ddf2e642301" class="relative scroll-mt-20"><button type="button" id="radix-_R_lkt7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.22</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Pramuditākaravarman. <em>gsang ba ’dus pa rgyud kyi rgyal po’i bshad pa zla ba’i ’od zer</em> (<em>Guhya­samāja­tantra­rāja­ṭīkā­candra­prabhā</em>). Toh 1852, Degé Tengyur vol. 41 (rgyud, thi), folios 120.a–313.a.</p></div></div></div><div id="218b0f60-5c2f-40e0-8a84-d92be1a346be" class="relative scroll-mt-20"><button type="button" id="radix-_R_lst7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.23</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Sahajalalita. <em>kun nas sgor ’jug pa’i ’od zer gtsug tor dri ma med par snang ba de bzhin gshegs pa thams cad kyi snying po dang dam tshig la rnam par blta ba zhes bya ba’i gzungs kyi rnam par bshad pa</em> (<em>Samanta­mukha­praveśa­raśmi­vimaloṣṇīṣa­prabhāsa­sarva­tathāgata­hṛdaya­samayavilokita­nāma­dhāraṇī­vṛtti</em>). Toh 2688, Degé Tengyur vol. 71 (rgyud, thu), folios 269.a–320.b.</p></div></div></div><div id="b70901da-c7d7-417b-9bb3-ac65c527e9e5" class="relative scroll-mt-20"><button type="button" id="radix-_R_m4t7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.24</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Śāntideva. <em>bslab pa kun las btus pa</em> (<em>Śikṣāsamuccaya</em>). Toh 3940, Degé Tengyur vol. 111 (dbu ma, khi), folios 3.a–194.b.</p></div></div></div><div id="016ec1aa-a34c-4bc8-9158-77cf9633aea2" class="relative scroll-mt-20"><button type="button" id="radix-_R_mct7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.25</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Sthiramati. <em>rgyan dam pa sna tshogs rim par phye ba bkod pa</em> (<em>Paramālaṃkāra­viśva­paṭala­vyūha</em>). Toh 2661, Degé Tengyur vol. 68 (rgyud, ju), folios 317.a–339.a.</p></div></div></div><div id="cff30114-45f1-4ad5-a44c-3518c7ec5c0a" class="relative scroll-mt-20"><button type="button" id="radix-_R_mkt7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.26</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Vairocanarakṣita. <em>bslab pa me tog snye ma</em> (<em>Śikṣā­kusuma­mañjarī</em>). Toh 3943, Degé Tengyur vol. 213 (dbu ma, khi), folios 196.a–217.a.</p></div></div></div><div id="b5f1dcc8-c9d1-4f7c-ac15-da6a719f445f" class="relative scroll-mt-20"><button type="button" id="radix-_R_mst7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.27</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Various authors. <em>bye brag tu rtogs par byed pa [chen po]</em> (<em>Mahāvyutpatti*</em>). Toh 4346, Degé Tengyur vol. 306 (sna tshogs, co), folios 1.a–131.a.</p></div></div></div><div id="8b238683-0480-4e70-b4ef-3c342834905f" class="relative scroll-mt-20"><button type="button" id="radix-_R_n4t7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.28</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Various authors. <em>sgra sbyor bam po gnyis pa</em>. Toh 4347, Degé Tengyur vol. 306 (sna tshogs, co), folios 131.b–160.a.</p></div></div></div><div id="224b4639-6ed8-4004-abe6-08681787e949" class="relative scroll-mt-20"><button type="button" id="radix-_R_nct7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.29</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Vinayadatta. <em>sgyu ’phrul chen mo’i dkyil ’khor gyi cho ga bla ma’i zhal snga’i man ngag</em> (<em>Gurūpadeśa­nāma­mahā­māyā­maṇḍalopāyikā</em>). Toh 1645, Degé Tengyur vol. 25 (rgyud, ya), folios 290.a–309.a.</p></div></div></div><div id="13d069f6-3ccb-47ab-af06-e638c05be4ea" class="relative scroll-mt-20"><button type="button" id="radix-_R_nkt7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.30</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Vitapāda. <em>gsang ba ’dus pa’i dkyil ’khor gyi sgrub pa’i thabs rnam par bshad pa</em> (<em>Guhya­samāja­maṇḍalopāyikā­ṭīkā</em>). Toh 1873, Degé Tengyur vol. 43 (rgyud, ni), folios 178.b–219.a.</p></div></div></div><div id="401eb5d0-8084-4094-96fe-8855771b9318" class="relative scroll-mt-20"><button type="button" id="radix-_R_nst7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.31</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Wönch’ük (Wen tsheg). <em>dgongs pa zab mo nges par ’grel pa’i mdo rgya cher ’grel pa</em> (<em>Gambhīra­saṁdhi­nirmocana­sūtra­ṭīkā</em>). Toh 4016, Degé Tengyur vol. 220 (mdo ’grel, ti), folios 1.b–291.a; vol. 221 (mdo ’grel, thi), folios 1.b–272.a; and vol. 222 (mdo ’grel, di), folios 1.b–175.a.</p></div></div></div><div id="90c42f55-6051-4950-8361-b5bed54d460e" class="relative scroll-mt-20"><button type="button" id="radix-_R_o4t7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.32</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Yeshe Dé (ye shes sde). <em>lang kar gshegs pa zhes bya ba theg pa chen po’i mdo’i ’grel pa de bzhin gshegs pa’i snying po’i rgyan</em> (<em>Laṅkāvatāra­nāma­mahā­yāna­sūtra­vṛtti­tathāgata­hṛdayālaṃkāra</em>), Toh 4019, Degé Tengyur vol. 224 (mdo ’grel, pi), folios 1.a–310.a.</p></div></div></div></div><div class="flex flex-col gap-4"><div id="Other References in Tibetan-3" class="relative scroll-mt-20"><button type="button" id="radix-_R_b57anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4 @c/sidebar:mt-0.5 mt-4">b.4</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="text-secondary font-sans text-base font-bold">Other References in Tibetan</div></div></div><div id="ef0eae1a-b52f-44bf-9bea-0dbc9467a034" class="relative scroll-mt-20"><button type="button" id="radix-_R_2d57anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.4.1</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Kalzang Dolma (skal bzang sgrol ma). <em>lo tsA ba ’gos chos grub dang khong gi ’gyur rtsom mdo mdzangs blun gyi lo tsA’i thabs rtsal skor la dpyad pa</em>. In <em>krung go’i bod kyi shes rig</em>, vol. 77, pp. 31–53. Beijing: krung go’i bod kyi shes rig dus deb khang, 2007.</p></div></div></div><div id="f61fe264-29b2-4347-9d39-dff8341c2e35" class="relative scroll-mt-20"><button type="button" id="radix-_R_2l57anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.4.2</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Lotsawa Gö Chödrup (lo tsā ba ’gos chos grub). In <em>gangs ljongs skad gnyis smra ba du ma’i ’gyur byang blo gsal dga’ skyed</em>, pp. 17–18. Xining: kan lho bod rigs rang skyong khul rtsom sgyur cu’u, 1983.</p></div></div></div><div id="260c5409-adf6-452f-9587-71978ef66c0d" class="relative scroll-mt-20"><button type="button" id="radix-_R_2t57anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.4.3</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Ngawang Lobsang Choden (nga dbang blo bzang chos ldan). <em>’phags pa gser ’od dam pa mdo sde’i dbang po’i rgyal po’i ’don thabs cho ga</em> (<em>A Rite That Is a Method for Reciting the Noble Sūtra of the Sublime Golden Light</em>), s.n. s.l. n.d.</p></div></div></div><div id="14e4c6d0-3be1-4924-b299-0f2bc002d762" class="relative scroll-mt-20"><button type="button" id="radix-_R_3557anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.4.4</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Pema Karpo (pad ma dkar po). <em>gser ’od dam pa nas gsungs pa’i bshags pa</em>. In <em>The Collected Works of Kun-mkhyen padma dkar po</em>, vol. 9 (ta), pp. 519–24. Darjeeling: kargyu sungrab nyamso khang, 1973–74.</p></div></div></div></div><div class="flex flex-col gap-4"><div id="Other References in English and Other Languages-4" class="relative scroll-mt-20"><button type="button" id="radix-_R_bd7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4 @c/sidebar:mt-0.5 mt-4">b.5</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="text-secondary font-sans text-base font-bold">Other References in English and Other Languages</div></div></div><div id="7dae85a7-5ac9-4b86-a885-4265a9fa3f5d" class="relative scroll-mt-20"><button type="button" id="radix-_R_4dd7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.5.1</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Bagchi, S., ed. <em>Suvarṇa­prabhāsa­sūtram</em>. Darbhanga: The Mithila Institute, 1967. Digital Sanskrit Buddhist Canon.</p></div></div></div><div id="4f5cadad-252f-4a54-a5f2-a4c4f4fb8b7e" class="relative scroll-mt-20"><button type="button" id="radix-_R_4ld7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.5.2</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Banerjee, Radha. <em>Suvarṇa­prabhāsottama­sūtra</em>. London: British Library, 2006. http://idp.bl.uk/downloads/GoldenLight.pdf.</p></div></div></div><div id="fa40517d-d8a9-4fca-b8a8-ee77542ac49c" class="relative scroll-mt-20"><button type="button" id="radix-_R_4td7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.5.3</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Buswell Jr., Robert E., and Donald Lopez Jr. <em>The Princeton Dictionary of Buddhism</em>. Princeton University Press, 2014.</p></div></div></div><div id="87adf5f5-8a26-42bf-a77f-cc61f87fec40" class="relative scroll-mt-20"><button type="button" id="radix-_R_55d7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.5.4</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Di, Guan. “The Sanskrit Fragments Preserved in Arthur M. Sackler Museum of Peking University.” <em>Annual Report of the Research Institute for Advanced Buddhology at Soka University for the Academic Year 2013</em>, vol. XVII (Tokyo Soka University, 2014): 109–18.</p></div></div></div><div id="6c68bda4-7a67-48d7-8a7c-5b07b98c4f03" class="relative scroll-mt-20"><button type="button" id="radix-_R_5dd7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.5.5</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Lewis, Todd T. “Contributions to the Study of Popular Buddhism: The Newar Buddhist Festival of Guṃlā Dharma.” <em>Journal of the International Association of Buddhist Studies</em> 16, no. 2 (Winter 1993): 309–54.</p></div></div></div><div id="b49c532c-84c7-439c-8cfe-c341ad37f398" class="relative scroll-mt-20"><button type="button" id="radix-_R_5ld7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.5.6</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Nanjio Bunyiu, Idzumi Hokei. <em>The Suvarṇaprabhāsa Sūtra: A Mahāyāna Text Called “The Golden Splendour.”</em> Kyoto: The Eastern Buddhist Society, 1931.</p></div></div></div><div id="96047346-9d89-4945-83be-b478931751f4" class="relative scroll-mt-20"><button type="button" id="radix-_R_5td7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.5.7</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Nobel, Johannes (1937). <em>Suvarṇabhāsottama­sūtra. Das Goldglanz-Sūtra: ein Sanskrit text des Mahāyāna-Buddhismus. Nach den Handschriften und mit Hilfe der tibetischen und chinesischen Übertragungen</em>. Leipzig: Harrassowitz.</p></div></div></div><div id="6c80d1e7-7c86-4a4f-863b-e6bda2caddec" class="relative scroll-mt-20"><button type="button" id="radix-_R_65d7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.5.8</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Nobel, Johannes (1944). <em>Suvarṇa­bhāsottama­sūtra. Das Goldglanz-Sūtra: ein Sanskrit text des Mahāyāna-Buddhismus. Die Tibetischen Überstzungen mit einem Wörterbuch</em>. Leiden: E. J. Brill.</p></div></div></div><div id="71fc045b-30f6-4d9d-852a-43f490d73aa5" class="relative scroll-mt-20"><button type="button" id="radix-_R_6dd7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.5.9</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Nobel, Johannes (1944, 1950). <em>Suvarṇabhāsottamasūtra. Das Goldglanz-Sūtra: ein Sanskrit text des Mahāyāna-Buddhismus. Die Tibetishcen Überstzungen mit einem Wörterbuch</em>. 2 vols. Leiden: E. J. Brill.</p></div></div></div><div id="090d4597-3630-4601-9fe7-6e0668cdd37e" class="relative scroll-mt-20"><button type="button" id="radix-_R_6ld7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.5.10</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Radich, Michael (2014). “On the Sources, Style and Authorship of Chapters of the Synoptic Suvarṇaprabhasa-sūtra T644 Ascribed to Paramārtha (Part 1).” <em>Annual Report of the Research Institute for Advanced Buddhology at Soka University for the Academic Year 2013</em>, vol. XVII (Tokyo Soka University, 2014): 207–44. </p></div></div></div><div id="662ae333-110e-437e-b22b-b1a0b1c76d00" class="relative scroll-mt-20"><button type="button" id="radix-_R_6td7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.5.11</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Radich, Michael (2016). “Tibetan Evidence for the Sources of Chapters of the Synoptic Suvarṇa-prabhāsottama-sūtra T 664 A Ascribed to Paramārtha.” <em>Buddhist Studies Review</em> 32.2 (2015): 245–70. Sheffield, UK: Equinox Publishing.</p></div></div></div><div id="fc9df657-f2f2-4809-af4b-fa0c29adbd93" class="relative scroll-mt-20"><button type="button" id="radix-_R_75d7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.5.12</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Tanaka, Kimiaki. <em>An Illustrated History of the Mandala From Its Genesis to the Kālacakratantra</em>. Somerville, MA: Wisdom Publications, 2018.</p></div></div></div><div id="20e5e864-d629-49b9-9ae7-0a03653ccf3d" class="relative scroll-mt-20"><button type="button" id="radix-_R_7dd7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.5.13</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Tyomkin, E. N. “Unique Sanskrit Fragments of ‘The Sūtra of Golden Light’ in the Manuscript Collection of the St. Petersburg Branch of the Institute of Oriental Studies.” In <em>Manuscripta Orientalia</em> vol. 1, no. 1 (July 1995): 29–38. St. Petersburg: Russian Academy of Sciences.</p></div></div></div><div id="c952097f-6d34-44a4-b50a-37baba98885c" class="relative scroll-mt-20"><button type="button" id="radix-_R_7ld7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.5.14</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Yuama, Akira. “The Golden Light in Central Asia.” In <em>Annual Report of the International Research Institute for Advanced Buddhology at Soka University for the Academic Year 2003</em> (Tokyo: Soka University, 2004): 3–32.</p></div></div></div></div><div class="flex flex-col gap-4"><div id="Translations-5" class="relative scroll-mt-20"><button type="button" id="radix-_R_bl7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4 @c/sidebar:mt-0.5 mt-4">b.6</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="text-secondary font-sans text-base font-bold">Translations</div></div></div><div id="187eb87b-1594-4803-9015-42602ca039e6" class="relative scroll-mt-20"><button type="button" id="radix-_R_1dl7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.6.1</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Emmerick, R. E. <em>The Sūtra of Golden Light</em>. Oxford: The Pali Text Society, 2004.</p></div></div></div><div id="521beb98-4d81-4021-b27e-6a294061c19c" class="relative scroll-mt-20"><button type="button" id="radix-_R_1ll7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.6.2</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Foundation for the Preservation of the Mahayana Tradition (FPMT). <em><a href="https://fpmt.org/education/prayers-and-practice-materials/sutras/golden-light-sutra/download/">Sutra of Golden Light, 21-Chapter</a></em>.</p></div></div></div><div id="6f385b4f-ec0d-417e-8101-4662fc648025" class="relative scroll-mt-20"><button type="button" id="radix-_R_1tl7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.6.3</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Nobel, Johannes. <em>Suvarṇa­prabhāsottama­sūtra, Das Goldglanz-Sutra, ein Sanskrittext des Mahayana Buddhismus. I-Tsing’s chinesische Version und ihre Übersetzung</em>. Leiden: E. J. Brill, 1958.</p></div></div></div></div></div></div></div><div data-state="inactive" data-orientation="horizontal" role="tabpanel" aria-labelledby="radix-_R_2npftt6btb_-trigger-abbreviations" id="radix-_R_2npftt6btb_-content-abbreviations" tabindex="0" data-slot="tabs-content" class="mt-2 ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 data-[state=inactive]:hidden"><div class="h-0"></div><div></div><div class="h-0"></div><div class="flex flex-col gap-4 pb-8"><div class="flex gap-5"><div class="animate-pulse rounded-md bg-foreground/10 h-6 w-6"></div><div class="animate-pulse rounded-md bg-foreground/10 h-32 grow"></div></div><div class="flex gap-5"><div class="animate-pulse rounded-md bg-foreground/10 h-6 w-6"></div><div class="animate-pulse rounded-md bg-foreground/10 h-32 grow"></div></div><div class="flex gap-5"><div class="animate-pulse rounded-md bg-foreground/10 h-6 w-6"></div><div class="animate-pulse rounded-md bg-foreground/10 h-32 grow"></div></div></div></div></div></div></div></div></div><script>$RS("S:5","P:5")</script><script>self.__next_f.push([1,"54:I[916077,[\"/_next/static/chunks/2fb4b456dae69409.js?dpl=dpl_C4kSSWFdt51TZQpmuYtxXgHAunY1\",\"/_next/static/chunks/6165fecb8e0eae36.js?dpl=dpl_C4kSSWFdt51TZQpmuYtxXgHAunY1\",\"/_next/static/chunks/1cfd6a6ab8fe5d2f.js?dpl=dpl_C4kSSWFdt51TZQpmuYtxXgHAunY1\",\"/_next/static/chunks/15d7387d42764915.js?dpl=dpl_C4kSSWFdt51TZQpmuYtxXgHAunY1\"],\"ReaderBodyPanel\"]\n"])</script><script>self.__next_f.push([1,"17:[\"$\",\"$L54\",null,{\"titles\":[{\"uuid\":\"848b6fe8-af27-44cd-bd12-dadbf8609d40\",\"title\":\"The Sūtra of the Sublime Golden Light (2)\",\"language\":\"en\",\"type\":\"mainTitle\"},{\"uuid\":\"8d792f1f-3be2-4b85-965f-23c99dd9c0ea\",\"title\":\"Suvarṇa­prabhāsottama­sūtra\",\"language\":\"Sa-Ltn\",\"type\":\"mainTitle\"},{\"uuid\":\"99356adc-b703-44fa-a6ff-f57b3c4f39c6\",\"title\":\"གསེར་འོད་དམ་པའི་མདོ།\",\"language\":\"bo\",\"type\":\"mainTitle\"},{\"uuid\":\"cb3892ea-abd2-4592-8ce9-4f0471f9f3c0\",\"title\":\"gser ’od dam pa’i mdo\",\"language\":\"Bo-Ltn\",\"type\":\"mainTitle\"},{\"uuid\":\"08772a97-1469-421c-9b3f-3355b8da0578\",\"title\":\"Suvarṇa­prabhāsottama­sūtrendra­rāja\",\"language\":\"Sa-Ltn\",\"type\":\"otherTitle\"},{\"uuid\":\"9d98b4d3-537b-4bea-befc-1e4a8f8eed09\",\"title\":\"Ārya­suvarṇa­prabhāsottama­sūtrendra­rāja­nāma­mahāyāna­sūtra\",\"language\":\"Sa-Ltn\",\"type\":\"otherTitle\"},{\"uuid\":\"84e4a990-a744-4eab-8e84-3dc8f9717828\",\"title\":\"gser ’od mdo sde’i dbang po’i rgyal po’i mdo/\",\"language\":\"Bo-Ltn\",\"type\":\"otherTitle\"},{\"uuid\":\"99f19482-6e71-477e-ac5b-f685da8bf154\",\"title\":\"’phags pa gser ’od dam pa mdo sde’i dbang po’i rgyal po zhes bya ba theg pa chen po’i mdo/\",\"language\":\"Bo-Ltn\",\"type\":\"otherTitle\"},{\"uuid\":\"8c20fe5b-0f9f-463a-b05a-5cd57d5cab47\",\"title\":\"《金光​明​尊勝​王​經》\",\"language\":\"zh\",\"type\":\"otherTitle\"},{\"uuid\":\"d0ed5f03-f9cf-493e-896c-d531fe7d1d1a\",\"title\":\"The Noble Mahāyāna Sūtra “The Lord King of Sūtras, The Sublime Golden Light”\",\"language\":\"en\",\"type\":\"longTitle\"},{\"uuid\":\"2d330939-71bc-4806-a6e7-ccd6fb85d7f1\",\"title\":\"Āryasuvarṇa­prabhāsottama­sūtrendra­rāja­nāma­mahāyāna­sūtra\",\"language\":\"Sa-Ltn\",\"type\":\"longTitle\"},{\"uuid\":\"143db65e-b04a-4cbd-95d7-2f9e974a0977\",\"title\":\"འཕགས་པ་གསེར་འོད་དམ་པ་མདོ་སྡེའི་དབང་པོའི་རྒྱལ་པོ་ཞེས་བྱ་བ་ཐེག་པ་ཆེན་པོའི་མདོ།\",\"language\":\"bo\",\"type\":\"longTitle\"},{\"uuid\":\"75547e4e-4644-4ac2-afb0-1473b52da617\",\"title\":\"’phags pa gser ’od dam pa mdo sde’i dbang po’i rgyal po zhes bya ba theg pa chen po’i mdo\",\"language\":\"Bo-Ltn\",\"type\":\"longTitle\"},{\"uuid\":\"377376fb-a586-429c-9e27-27dd8cdff003\",\"title\":\"Toh 556\",\"language\":\"en\",\"type\":\"toh\"}],\"frontMatter\":[{\"type\":\"passage\",\"attrs\":{\"uuid\":\"ad17c2d7-9eb7-4a2a-9a59-69f2f6296f57\",\"sort\":2,\"type\":\"summaryHeader\",\"label\":\"s.\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":2,\"start\":0,\"end\":7,\"uuid\":\"2abb6e32-7f25-4399-bd6a-d1f65b5927d7\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"Summary\",\"attrs\":{\"start\":0,\"end\":7}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"83458cef-f961-44de-b401-d9f930242164\",\"sort\":4,\"type\":\"summary\",\"label\":\"s.1\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":535,\"uuid\":\"83458cef-f961-44de-b401-d9f930242164\"},\"content\":[{\"type\":\"text\",\"text\":\"The Sūtra of the Sublime Golden Light \",\"attrs\":{\"start\":0,\"end\":38},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"7969ab86-c19f-4a97-a9ab-29f6f6f242aa\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"has held great importance in Buddhism for its instructions on the purification of karma. In particular, much of the sūtra is specifically addressed to monarchs and thus has been significant for rulers‍—not only in India but also in China, Japan, Mongolia, and elsewhere‍—who wished to ensure the well-being of their nations through such purification. Reciting and internalizing this sūtra is understood to be efficacious for personal purification and also for the welfare of a state and the world.\",\"attrs\":{\"start\":38,\"end\":535}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"54260002-ba18-4e32-9a6e-8a36c5e7c7b6\",\"sort\":7,\"type\":\"summary\",\"label\":\"s.2\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":567,\"uuid\":\"54260002-ba18-4e32-9a6e-8a36c5e7c7b6\"},\"content\":[{\"type\":\"text\",\"text\":\"In this sūtra, the bodhisattva \",\"attrs\":{\"start\":0,\"end\":31}},{\"type\":\"text\",\"text\":\"Ruciraketu\",\"attrs\":{\"start\":31,\"end\":41},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"727c3a9f-2dae-46b4-89e7-d5f8bedeb247\",\"uuid\":\"f28c4d32-930e-403d-ab6d-595d7aac2694\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" has a dream in which a prayer of confession emanates from a shining golden drum. He relates the prayer to the Buddha, and a number of deities then vow to protect it and its adherents. The ruler’s devotion to the sūtra is emphasized as important if the nation is to benefit. Toward the end of the sūtra are two well-known narratives of the Buddha’s previous lives: the account of the physician \",\"attrs\":{\"start\":41,\"end\":435}},{\"type\":\"text\",\"text\":\"Jalavāhana\",\"attrs\":{\"start\":435,\"end\":445},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"57f0f961-6f2b-495c-bf32-21720f0875d5\",\"uuid\":\"40da5c1a-b7b6-49de-8150-f3c61f91c722\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", who saves and blesses numerous fish, and that of Prince \",\"attrs\":{\"start\":445,\"end\":503}},{\"type\":\"text\",\"text\":\"Mahāsattva\",\"attrs\":{\"start\":503,\"end\":513},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d1c7dfac-7376-48af-bc36-07491c77e7ac\",\"uuid\":\"3a1a0f84-064b-4b4c-9437-6580f0fcd7b8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", who gives his body to a hungry tigress and her cubs.\",\"attrs\":{\"start\":513,\"end\":567}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"8552df49-3832-4827-923e-f768db6dd0e1\",\"sort\":15,\"type\":\"summary\",\"label\":\"s.3\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":192,\"uuid\":\"8552df49-3832-4827-923e-f768db6dd0e1\"},\"content\":[{\"type\":\"text\",\"text\":\"This is the second-longest version of \",\"attrs\":{\"start\":0,\"end\":38}},{\"type\":\"text\",\"text\":\"The Sūtra of the Sublime Golden Light \",\"attrs\":{\"start\":38,\"end\":76},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"44527add-6ea5-44d3-a613-40be57ac8f3c\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"preserved in the Kangyur. It comprises twenty-nine chapters and was translated into Tibetan primarily from Sanskrit.\",\"attrs\":{\"start\":76,\"end\":192}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"7cbd1c1d-9888-45cc-8800-7c890d0ae4ea\",\"sort\":19,\"type\":\"acknowledgmentHeader\",\"label\":\"ac.\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":2,\"start\":0,\"end\":16,\"uuid\":\"50de538d-7a04-4342-8b9f-769c0069246e\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"Acknowledgements\",\"attrs\":{\"start\":0,\"end\":16}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"a0096bd6-44b1-48f7-bce2-2148fe6bb8e7\",\"sort\":21,\"type\":\"acknowledgment\",\"label\":\"ac.1\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":364,\"uuid\":\"a0096bd6-44b1-48f7-bce2-2148fe6bb8e7\"},\"content\":[{\"type\":\"text\",\"text\":\"This text was translated by Peter Alan Roberts, who translated the text from Tibetan into English and wrote the introduction. Ling Lung Chen and Wang Chipan were consultants for the Chinese versions of the sūtra. Emily Bower was the project manager and editor. Tracy Davis was the initial copyeditor. Thanks to Michael Radich for sharing his research on the sūtra.\",\"attrs\":{\"start\":0,\"end\":364}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"b0d8d647-60a5-4d75-a647-62e8b1bc5813\",\"sort\":23,\"type\":\"acknowledgment\",\"label\":\"ac.2\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":392,\"uuid\":\"b0d8d647-60a5-4d75-a647-62e8b1bc5813\"},\"content\":[{\"type\":\"text\",\"text\":\"The translation was completed under the patronage and supervision of 84000: Translating the Words of the Buddha. Rory Lindsay edited the translation and the introduction, and Xiaolong Diao, Ting Lee Ling, and H. S. Sum Cheuk Shing checked the translation against the Chinese sources. Ven. Konchog Norbu copyedited the text, and Sameer Dhingra was in charge of the digital publication process.\",\"attrs\":{\"start\":0,\"end\":392}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"7f7e0357-7daa-407b-b62f-0810360d5895\",\"sort\":25,\"type\":\"acknowledgment\",\"label\":\"ac.3\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":123,\"uuid\":\"7f7e0357-7daa-407b-b62f-0810360d5895\"},\"content\":[{\"type\":\"text\",\"text\":\"The translation of this text has been made possible through the generous sponsorship of E E, May-E, Minda, and Chung-Da Ho.\",\"attrs\":{\"start\":0,\"end\":123}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"7ef295ec-593e-4c96-b51f-72f295d2a8ab\",\"sort\":27,\"type\":\"introductionHeader\",\"label\":\"i.\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":2,\"start\":0,\"end\":12,\"uuid\":\"e34e74b6-7e93-4719-b8e8-52f5bf10ec4b\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"Introduction\",\"attrs\":{\"start\":0,\"end\":12}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"fba59dc7-f583-489e-86ec-1ab7fc2faa0d\",\"sort\":29,\"type\":\"introduction\",\"label\":\"i.1\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":487,\"uuid\":\"fba59dc7-f583-489e-86ec-1ab7fc2faa0d\"},\"content\":[{\"type\":\"text\",\"text\":\"The Sūtra of the Sublime Golden Light \",\"attrs\":{\"start\":0,\"end\":38},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"5b324d44-a52b-459c-8e2a-26563e3fd886\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"has held great importance in Buddhism for its instructions on the purification of karma. In particular, much of the sūtra is specifically addressed to monarchs, and thus it has been significant for rulers‍—not only in India but also in China, Japan, Mongolia, and elsewhere‍—who wished to ensure the well-being of their nations. It is understood to be efficacious for personal purification and beneficial for the welfare of a state and of the world.\",\"attrs\":{\"start\":38,\"end\":487}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"ddf289f6-ffb3-40cf-88ad-2b5750f5e150\",\"sort\":32,\"type\":\"introduction\",\"label\":\"i.2\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":428,\"uuid\":\"ddf289f6-ffb3-40cf-88ad-2b5750f5e150\"},\"content\":[{\"type\":\"text\",\"text\":\"The work translated here is the twenty-nine-chapter version (hereafter referenced as Toh 556) of \",\"attrs\":{\"start\":0,\"end\":97}},{\"type\":\"text\",\"text\":\"The Sūtra of the Sublime Golden Light.\",\"attrs\":{\"start\":97,\"end\":135},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"7d25f39e-2987-4d69-8c56-e6a6221b51da\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" There are also the twenty-one-chapter (hereafter referenced as Toh 557)\",\"attrs\":{\"start\":135,\"end\":207},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"476716b6-73b6-4d25-86d1-2a2a464fa670\",\"label\":\"1\",\"uuid\":\"71ea0f66-6b24-4069-84c7-045e3df7581a\",\"start\":207,\"end\":207,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" and thirty-one-chapter (hereafter referenced as Toh 555)\",\"attrs\":{\"start\":207,\"end\":264},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"fd14b65c-ff91-42cf-aa09-4fbf2b37d00b\",\"label\":\"2\",\"uuid\":\"9d6bb388-a9b9-47a0-b3e5-fcb0181c1fab\",\"start\":264,\"end\":264,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" versions. Both Toh 556 and Toh 557 were translated into Tibetan from Sanskrit, so almost the entirety of Toh 557 is present in an identical translation in Toh 556.\",\"attrs\":{\"start\":264,\"end\":428}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"c4b5a055-44b3-4448-b424-597bd228d9a2\",\"sort\":40,\"type\":\"introduction\",\"label\":\"i.3\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":300,\"uuid\":\"c4b5a055-44b3-4448-b424-597bd228d9a2\"},\"content\":[{\"type\":\"text\",\"text\":\"This sūtra’s principal chapter is the fourth, which describes the lay bodhisattva \",\"attrs\":{\"start\":0,\"end\":82}},{\"type\":\"text\",\"text\":\"Ruciraketu\",\"attrs\":{\"start\":82,\"end\":92},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"727c3a9f-2dae-46b4-89e7-d5f8bedeb247\",\"uuid\":\"d8035cfc-9ff7-476e-80af-31b083ea7f89\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" having a dream in which he sees a brightly shining golden drum. When a \",\"attrs\":{\"start\":92,\"end\":164}},{\"type\":\"text\",\"text\":\"brahmin\",\"attrs\":{\"start\":164,\"end\":171},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41a01c6c-e7cf-4689-b3bb-4cdb181c88b6\",\"uuid\":\"fbc897f0-1d52-4bfc-b5c3-903b803d9129\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" beats the drum, \",\"attrs\":{\"start\":171,\"end\":188}},{\"type\":\"text\",\"text\":\"Ruciraketu\",\"attrs\":{\"start\":188,\"end\":198},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"727c3a9f-2dae-46b4-89e7-d5f8bedeb247\",\"uuid\":\"50bc8846-4ad8-410b-bb41-5609edb1cfbd\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" hears in the drumbeats a hundred-verse prayer, and he subsequently recites that prayer to the Buddha.\",\"attrs\":{\"start\":198,\"end\":300}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"32af298a-11ec-48c2-ba40-6dfcd99b1d4a\",\"sort\":48,\"type\":\"introduction\",\"label\":\"i.4\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":427,\"uuid\":\"32af298a-11ec-48c2-ba40-6dfcd99b1d4a\"},\"content\":[{\"type\":\"text\",\"text\":\"Most of the following chapters are concerned with encouraging the recitation of this prayer and of the sūtra itself. They describe how various divine beings in this world revere the sūtra and promise to protect it and its adherents. These include the \",\"attrs\":{\"start\":0,\"end\":251}},{\"type\":\"text\",\"text\":\"Four Mahārājas\",\"attrs\":{\"start\":251,\"end\":265},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"772224d0-971a-49ab-8f56-49664a2477ad\",\"uuid\":\"85696ea1-4f0a-44a9-8640-d32f75ef82df\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"; \",\"attrs\":{\"start\":265,\"end\":267}},{\"type\":\"text\",\"text\":\"Dṛḍhā\",\"attrs\":{\"start\":267,\"end\":272},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"61a9d519-40bc-47f2-8204-a84f6ee5ef65\",\"uuid\":\"14775175-92b8-4cf9-9447-5898c2bb80c3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", who is the goddess of the earth; \",\"attrs\":{\"start\":272,\"end\":307}},{\"type\":\"text\",\"text\":\"Sarasvatī\",\"attrs\":{\"start\":307,\"end\":316},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"068fbf99-e394-467f-a59c-45b4bcdd2f78\",\"uuid\":\"29154c17-6f82-4192-98b3-42262bfc7e4c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the goddess of wisdom, learning, and music; \",\"attrs\":{\"start\":316,\"end\":362}},{\"type\":\"text\",\"text\":\"Śrī\",\"attrs\":{\"start\":362,\"end\":365},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b42cf2c8-dbcd-4d9d-a3cb-65927ccdbde0\",\"uuid\":\"928ff5da-11ce-4406-b5b6-46c47498daac\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the goddess of good fortune; and the \",\"attrs\":{\"start\":365,\"end\":404}},{\"type\":\"text\",\"text\":\"yakṣa\",\"attrs\":{\"start\":404,\"end\":409},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b4640039-6b60-4eb6-8695-1c0153d43a37\",\"uuid\":\"fe6b7063-712e-4301-b73a-e9ec2a0c1609\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" general \",\"attrs\":{\"start\":409,\"end\":418}},{\"type\":\"text\",\"text\":\"Saṃjñeya\",\"attrs\":{\"start\":418,\"end\":426},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"400c6243-9437-40e0-801b-1a346d491d92\",\"uuid\":\"ab9f20ac-d5d2-4b73-87a0-f911d2d7f869\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":426,\"end\":427}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"8d6daba2-13ee-4f88-9d27-1d41dfee345b\",\"sort\":62,\"type\":\"introduction\",\"label\":\"i.5\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":455,\"uuid\":\"8d6daba2-13ee-4f88-9d27-1d41dfee345b\"},\"content\":[{\"type\":\"text\",\"text\":\"This sūtra emphasizes its importance for kings. It states that if they honor the reciters of this sūtra and arrange for its recitation and teaching, then their reign and their kingdom will prosper. They will avoid such calamities as invasion, famine, and so on. The sūtra also warns that if they fail to show such devotion, there will be disastrous results for both them and their kingdoms. Chapter 20 is dedicated to the subject of how to be a good king.\",\"attrs\":{\"start\":0,\"end\":455}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"f51e0ff3-ac60-4deb-ae42-7cfe7303c115\",\"sort\":64,\"type\":\"introduction\",\"label\":\"i.6\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":733,\"uuid\":\"f51e0ff3-ac60-4deb-ae42-7cfe7303c115\"},\"content\":[{\"type\":\"text\",\"text\":\"There are also chapters that deal with doctrine. Chapter 2 presents the view that a buddha never dies and so never passes into \",\"attrs\":{\"start\":0,\"end\":127}},{\"type\":\"text\",\"text\":\"nirvāṇa\",\"attrs\":{\"start\":127,\"end\":134},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bebe04fd-2b22-4637-89db-ae1cd69dffe1\",\"uuid\":\"39663c79-7d0a-4b9d-ab18-a5c47754e1ea\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Therefore, there is no body and no physical relics of his body after his cremation, and so the Dharma never ceases to be taught. The passing of a buddha and the extinction of the Dharma are solely illusory manifestations, skillful methods to inspire beings to practice and to provide them with relics as objects for their devotion. The longer versions of the sūtra also contain chapter 3 (not present in Toh 557), which describes the nature of the \",\"attrs\":{\"start\":134,\"end\":584}},{\"type\":\"text\",\"text\":\"three bodies\",\"attrs\":{\"start\":584,\"end\":596},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7015a5ba-934e-44c1-9e77-244de7b7c93a\",\"uuid\":\"ded26b91-c956-414f-8655-1b34f84f1f52\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and chapter 6, which describes the ten bodhisattva \",\"attrs\":{\"start\":596,\"end\":649}},{\"type\":\"text\",\"text\":\"bhūmis\",\"attrs\":{\"start\":649,\"end\":655},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ff1e1864-2411-4b97-a56d-bfd1b395dc48\",\"uuid\":\"583cc821-bc17-47ff-9333-78e697ce8ff0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (also not present in Toh 557). Chapters 9 and 10 teach the view of emptiness.\",\"attrs\":{\"start\":655,\"end\":733}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"f9802a6d-16af-46c9-8d3e-eae14d4f524d\",\"sort\":72,\"type\":\"introduction\",\"label\":\"i.7\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":654,\"uuid\":\"f9802a6d-16af-46c9-8d3e-eae14d4f524d\"},\"content\":[{\"type\":\"text\",\"text\":\"Toward the end, there are two narratives that describe previous lives of the Buddha. Chapters 24 and 25 describe the physician \",\"attrs\":{\"start\":0,\"end\":127}},{\"type\":\"text\",\"text\":\"Jalavāhana\",\"attrs\":{\"start\":127,\"end\":137},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"57f0f961-6f2b-495c-bf32-21720f0875d5\",\"uuid\":\"ea51d054-dc16-4580-a28c-73ea96a5b6fe\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", who, as a result of performing Dharma recitations while standing in a lake, ensured the rebirth of ten thousand fish into the paradise of \",\"attrs\":{\"start\":137,\"end\":277}},{\"type\":\"text\",\"text\":\"Trāyastriṃśa\",\"attrs\":{\"start\":277,\"end\":289},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"fb356f46-3c64-4256-8c64-7d0c8d24f7ba\",\"uuid\":\"adfd87a8-14f5-4839-84ab-14724ef27dff\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". In the preceding chapter, these same ten thousand \",\"attrs\":{\"start\":289,\"end\":341}},{\"type\":\"text\",\"text\":\"devas\",\"attrs\":{\"start\":341,\"end\":346},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a09787ca-2952-4bf6-a04c-bde6f4cf3e40\",\"uuid\":\"b20bb473-92b1-4446-a55d-bb4cc144defd\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" receive the prophecy of their buddhahood. When the goddess of the Bodhi tree objects that they have not accomplished the necessary bodhisattva conduct in past lives to receive such a prophecy, the Buddha explains that this was unnecessary because they had devotion to this \",\"attrs\":{\"start\":346,\"end\":620}},{\"type\":\"text\",\"text\":\"Sūtra of the Sublime Golden Light.\",\"attrs\":{\"start\":620,\"end\":654},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"b6f40a8a-a7da-4773-befa-aa43433c8aad\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"66ac446b-cc79-48c9-be93-074b830b13ef\",\"sort\":82,\"type\":\"introduction\",\"label\":\"i.8\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":428,\"uuid\":\"66ac446b-cc79-48c9-be93-074b830b13ef\"},\"content\":[{\"type\":\"text\",\"text\":\"The other past-life narrative, which is given in chapter 26, is one of the most famous in Buddhist literature‍—that of the prince who gives his body to a hungry tigress and her cubs. An interesting feature of the story in this sūtra is that much of the narrative is dedicated to an evocative description of the intense grief of parents who have lost their child, emphasizing the sorrow that the prince’s action has brought them.\",\"attrs\":{\"start\":0,\"end\":428}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"14c7bb90-c7cb-4a4e-a2e4-b8269b048c66\",\"sort\":83,\"type\":\"introductionHeader\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":3,\"start\":0,\"end\":15,\"uuid\":\"67fb7eaf-9b22-43ec-b01e-e756dd13802a\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"Tantric Rituals\",\"attrs\":{\"start\":0,\"end\":15}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"940c248b-a573-4b2f-b405-022c13e5da92\",\"sort\":85,\"type\":\"introduction\",\"label\":\"i.9\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":564,\"uuid\":\"940c248b-a573-4b2f-b405-022c13e5da92\"},\"content\":[{\"type\":\"text\",\"text\":\"As with other late \",\"attrs\":{\"start\":0,\"end\":19}},{\"type\":\"text\",\"text\":\"Mahāyāna\",\"attrs\":{\"start\":19,\"end\":27},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f3fbdf9c-f5a6-4a60-81fa-8e8615d622e0\",\"uuid\":\"514eafa5-5cfc-4654-a5a2-5440b488cc03\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" sūtras in which there is an emphasis on ritual, this text is classified in the Kangyur as a tantra, specifically as a Kriyā tantra, a class of tantras in which there is an emphasis on external ritual. The sūtra contains a description of how such rituals should be performed, and there are also passages that include lists of ingredients to place in a bath, along with mantras to recite while bathing, in order to achieve purification. Toh 556 and Toh 555 also supply a number of \",\"attrs\":{\"start\":27,\"end\":507}},{\"type\":\"text\",\"text\":\"dhāraṇīs\",\"attrs\":{\"start\":507,\"end\":515},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c161a89c-8874-435b-a0cf-5dda3a665750\",\"uuid\":\"2a7e0e82-2b94-42f2-a978-b50d8d3daf6b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" to be recited in order to gain specific results.\",\"attrs\":{\"start\":515,\"end\":564}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"14fe7ab8-f1c7-4cb4-b1c3-382a7a00e09f\",\"sort\":91,\"type\":\"introduction\",\"label\":\"i.10\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":794,\"uuid\":\"14fe7ab8-f1c7-4cb4-b1c3-382a7a00e09f\"},\"content\":[{\"type\":\"text\",\"text\":\"One can also see that the seed of the later \",\"attrs\":{\"start\":0,\"end\":44}},{\"type\":\"text\",\"text\":\"maṇḍalas\",\"attrs\":{\"start\":44,\"end\":52},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f9c67828-6608-4634-8a72-a6c7b1e85991\",\"uuid\":\"5e9e6bf4-2dc1-4e2f-987d-cdbc61e942c8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of the five buddha families is in this sūtra, for in chapters 2 and 3, buddhas of the four directions appear to a layman who has a visionary dream. They include \",\"attrs\":{\"start\":52,\"end\":214}},{\"type\":\"text\",\"text\":\"Akṣobhya\",\"attrs\":{\"start\":214,\"end\":222},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"15b53e78-cf61-4aec-86bd-5380bbcb3129\",\"uuid\":\"5f48dc10-28a5-4ed9-9bb7-9597adcc2e2a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" from the east and \",\"attrs\":{\"start\":222,\"end\":241}},{\"type\":\"text\",\"text\":\"Amitābha\",\"attrs\":{\"start\":241,\"end\":249},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b4043124-016c-46e7-b162-8a823ecbce68\",\"uuid\":\"dfd90af1-c2e2-4b3c-b776-60a7e87f2824\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" from the west, both buddhas and their realms already established in the Buddhist tradition with specific sūtras dedicated to them. There also appear the buddhas \",\"attrs\":{\"start\":249,\"end\":411}},{\"type\":\"text\",\"text\":\"Ratnaketu\",\"attrs\":{\"start\":411,\"end\":420},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c10c0c1a-4fb8-494d-916f-0269e31c11bc\",\"uuid\":\"32f560b5-aa92-462e-ae66-6f3bad05b534\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" from the south and \",\"attrs\":{\"start\":420,\"end\":440}},{\"type\":\"text\",\"text\":\"Dundubhisvara\",\"attrs\":{\"start\":440,\"end\":453},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"49c93315-1451-4874-87c0-974a619ab4e8\",\"uuid\":\"4e166b8f-914c-4562-8066-0c0cd9063ace\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" from the north, who in later tantras are usually named Ratnasaṃbhava and Amoghasiddhi. In this sūtra, the central buddha in terms of these directions would be \",\"attrs\":{\"start\":453,\"end\":613}},{\"type\":\"text\",\"text\":\"Śākyamuni\",\"attrs\":{\"start\":613,\"end\":622},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"30470857-9228-4b50-ad00-ff8c913dc02a\",\"uuid\":\"9d630529-72d9-4be4-8e95-f63989f25d8c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" himself. In the \",\"attrs\":{\"start\":622,\"end\":639}},{\"type\":\"text\",\"text\":\"Buddhāvataṃsaka Sūtra \",\"attrs\":{\"start\":639,\"end\":661},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"701879b1-5e97-46c5-8334-89a78c10e70e\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"he is referred to as \",\"attrs\":{\"start\":661,\"end\":682}},{\"type\":\"text\",\"text\":\"Vairocana\",\"attrs\":{\"start\":682,\"end\":691},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"169da212-d4f0-4402-9743-ef8193e94f46\",\"uuid\":\"14f98874-4c2d-49ed-9172-ed94c8a51b0a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", as the Buddha \",\"attrs\":{\"start\":691,\"end\":707}},{\"type\":\"text\",\"text\":\"Vairocana\",\"attrs\":{\"start\":707,\"end\":716},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"169da212-d4f0-4402-9743-ef8193e94f46\",\"uuid\":\"9ebe9fd9-0f43-47ef-99db-a0795ad56fb7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is the buddha who manifests as all the buddhas throughout this \",\"attrs\":{\"start\":716,\"end\":780}},{\"type\":\"text\",\"text\":\"trichiliocosm\",\"attrs\":{\"start\":780,\"end\":793},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"15fc18c2-88b8-4b6b-80b5-7b16a0dc9174\",\"uuid\":\"f876a0e3-5fd1-4b94-a970-d8299d1d7c00\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":793,\"end\":794}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"62ff6066-b425-41b8-b544-6094b3eaef80\",\"sort\":112,\"type\":\"introductionHeader\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":3,\"start\":0,\"end\":46,\"uuid\":\"73f73830-acfa-482f-a947-31172d9d09d3\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"The Sūtra of the Sublime Golden Light \",\"attrs\":{\"start\":0,\"end\":38},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"265226f7-2148-4402-884b-04655a8f559a\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"in India\",\"attrs\":{\"start\":38,\"end\":46}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"b6ba7304-430a-4c35-9135-0e4c69fa862a\",\"sort\":115,\"type\":\"introduction\",\"label\":\"i.11\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1056,\"uuid\":\"b6ba7304-430a-4c35-9135-0e4c69fa862a\"},\"content\":[{\"type\":\"text\",\"text\":\"A version of \",\"attrs\":{\"start\":0,\"end\":13}},{\"type\":\"text\",\"text\":\"The Sūtra of the Sublime Golden Light \",\"attrs\":{\"start\":13,\"end\":51},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"4da5bfb1-192a-4e52-8df8-a5eccb0fb45f\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"existed in India by the early fifth century \",\"attrs\":{\"start\":51,\"end\":95}},{\"type\":\"text\",\"text\":\"ᴄᴇ\",\"attrs\":{\"start\":95,\"end\":97},\"marks\":[{\"type\":\"smallCaps\",\"attrs\":{\"start\":95,\"end\":97,\"uuid\":\"e0f6b9b9-ec18-4315-b4a1-eb2fb2d8c8e0\",\"type\":\"span\",\"textStyle\":\"small-caps\"}}]},{\"type\":\"text\",\"text\":\", when it was translated into Chinese by Dharmakṣema (385–433) in 420, in a form that corresponds to the fragments of its translation into old Khotanese. The author of \",\"attrs\":{\"start\":97,\"end\":265}},{\"type\":\"text\",\"text\":\"Precious Lamp of the Middle Way\",\"attrs\":{\"start\":265,\"end\":296},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"dea517ab-8478-429d-b86d-7ec94cc7b846\",\"lang\":\"en\",\"type\":\"inlineTitle\",\"start\":265,\"end\":0}},{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"c2906cd5-5b1e-4327-ae55-f40de6705508\",\"label\":\"3\",\"uuid\":\"f13a4e09-adf2-472f-a7c1-ffbcf72034ab\",\"start\":296,\"end\":296,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":296,\"end\":297},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"dea517ab-8478-429d-b86d-7ec94cc7b846\",\"lang\":\"en\",\"type\":\"inlineTitle\",\"start\":296,\"end\":0}}]},{\"type\":\"text\",\"text\":\"mentions that \",\"attrs\":{\"start\":297,\"end\":311}},{\"type\":\"text\",\"text\":\"The Sūtra of the Sublime Golden Light \",\"attrs\":{\"start\":311,\"end\":349},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"b0a31463-38d7-4339-9665-79a988503fea\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"contains profound teachings in the section on the absence of relics, this passage being within the chapter on the lifespan of the Buddha. The sūtra’s significance in later Indian Buddhism is evident from the three tantras\",\"attrs\":{\"start\":349,\"end\":570},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"4034bf31-9104-489f-bc51-ac13d0735edd\",\"label\":\"4\",\"uuid\":\"89555cc8-49ec-432e-9336-20dac3744dce\",\"start\":570,\"end\":570,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" and ten commentaries\",\"attrs\":{\"start\":570,\"end\":591},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"c7c26a57-a38b-4921-ac3b-1dbdf95d913a\",\"label\":\"5\",\"uuid\":\"3eea1a88-9f93-46b2-9b79-44ab4a2e9772\",\"start\":591,\"end\":591,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" that specify that it should be the text recited in one of the four directions when performing a \",\"attrs\":{\"start\":591,\"end\":688}},{\"type\":\"text\",\"text\":\"maṇḍala\",\"attrs\":{\"start\":688,\"end\":695},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f9c67828-6608-4634-8a72-a6c7b1e85991\",\"uuid\":\"5305c005-18d7-4c46-a790-c9ab1a95f2c8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" rite. There are also five other texts in the Tengyur that emphasize the importance and status of \",\"attrs\":{\"start\":695,\"end\":793}},{\"type\":\"text\",\"text\":\"The Sūtra of the Sublime Golden Light \",\"attrs\":{\"start\":793,\"end\":831},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"46837dd2-cc61-4fa4-bff0-5e94fdb7e535\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"and its recitation,\",\"attrs\":{\"start\":831,\"end\":850},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"f9402630-1b4f-4b29-9618-e998e6e9883e\",\"label\":\"6\",\"uuid\":\"1017d6c7-5369-490f-8782-c25fb5de59c5\",\"start\":850,\"end\":850,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" including Śāntideva’s eighth-century \",\"attrs\":{\"start\":850,\"end\":888}},{\"type\":\"text\",\"text\":\"Compendium of Training \",\"attrs\":{\"start\":888,\"end\":911},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"c828f389-6cff-46f3-bbc8-449d8c46b1ef\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"in which he provides two extracts from the sūtra that should be recited. There are also two recitation texts composed of extracts from the sūtra.\",\"attrs\":{\"start\":911,\"end\":1056},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"8865b0c8-44cb-4caa-a84c-c247077d4c5c\",\"label\":\"7\",\"uuid\":\"0638eb5d-1ff6-428a-af83-a3a27ac9c130\",\"start\":1056,\"end\":1056,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"33651175-baef-4552-9ead-3eab1dbe9e17\",\"sort\":139,\"type\":\"introduction\",\"label\":\"i.12\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":446,\"uuid\":\"33651175-baef-4552-9ead-3eab1dbe9e17\"},\"content\":[{\"type\":\"text\",\"text\":\"In addition to its importance for rites and recitations, the text is quoted on doctrinal points in Indian commentaries. Passages indicating that the Buddha never dies, leaves no relics, and that the Dharma never ceases are quoted in six texts,\",\"attrs\":{\"start\":0,\"end\":243},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"537d23cc-f237-45cf-9738-52c2b0e3c26c\",\"label\":\"8\",\"uuid\":\"9f509788-0957-46c4-b0b9-4226ab0b21cd\",\"start\":243,\"end\":243,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" two of which\",\"attrs\":{\"start\":243,\"end\":256},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"baeb732f-1fa0-49cf-9cda-d67b81f8242e\",\"label\":\"9\",\"uuid\":\"70755dd9-eac9-48ec-88c1-b59994a71114\",\"start\":256,\"end\":256,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" cite the delightful verse that describes the impossibility of there being buddha relics, stating that there will be a buddha relic only when a ladder to the moon is built from rabbit horns.\",\"attrs\":{\"start\":256,\"end\":446}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"d447dcb7-ab2f-4af8-bfcb-df1608769529\",\"sort\":145,\"type\":\"introduction\",\"label\":\"i.13\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":273,\"uuid\":\"d447dcb7-ab2f-4af8-bfcb-df1608769529\"},\"content\":[{\"type\":\"text\",\"text\":\"The descriptions of buddha nature and the nature of the bodies of a buddha, which are only in Toh 555 and Toh 556, are quoted in two texts in the Tengyur, one written in Tibetan and one translated from Sanskrit by Rinchen Sangpo,\",\"attrs\":{\"start\":0,\"end\":229},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"d500af8a-bb6d-4980-b338-b5e094d869e6\",\"label\":\"10\",\"uuid\":\"3c282a7c-ff5e-4641-b990-9c845101646d\",\"start\":229,\"end\":229,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" although nothing is known about the author.\",\"attrs\":{\"start\":229,\"end\":273}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"2bfd30cc-8563-4b69-953b-e2a8a465df6c\",\"sort\":149,\"type\":\"introduction\",\"label\":\"i.14\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":199,\"uuid\":\"2bfd30cc-8563-4b69-953b-e2a8a465df6c\"},\"content\":[{\"type\":\"text\",\"text\":\"In Newar Buddhism, this sūtra became and remains one of the nine principal sūtras called “the nine Dharmas,”\",\"attrs\":{\"start\":0,\"end\":108},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"262f5d19-288c-489f-843f-c97ecc9348e1\",\"label\":\"11\",\"uuid\":\"e8830c51-204e-4c1d-b56d-06472ae7c5b9\",\"start\":108,\"end\":108,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" which are considered to be the most important lengthy sūtras to be recited and offered to.\",\"attrs\":{\"start\":108,\"end\":199}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"776fabcf-5387-4401-8db8-8355ddbdd72a\",\"sort\":153,\"type\":\"introduction\",\"label\":\"i.15\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":234,\"uuid\":\"776fabcf-5387-4401-8db8-8355ddbdd72a\"},\"content\":[{\"type\":\"text\",\"text\":\"Sanskrit manuscripts of this sūtra survived as fragments discovered in Chinese Central Asia (Xinjiang) and as entire texts in Nepal, where the title is \",\"attrs\":{\"start\":0,\"end\":152}},{\"type\":\"text\",\"text\":\"Suvarṇa­bhāsottama,\",\"attrs\":{\"start\":152,\"end\":171},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"6213a06e-c145-4d8c-866d-96343133dd3e\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" with \",\"attrs\":{\"start\":171,\"end\":177}},{\"type\":\"text\",\"text\":\"bhāsa\",\"attrs\":{\"start\":177,\"end\":182},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":177,\"end\":182,\"uuid\":\"387f4999-e1f1-4512-82f2-20f53f1e8a6c\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" being a synonym for \",\"attrs\":{\"start\":182,\"end\":203}},{\"type\":\"text\",\"text\":\"prabhāsa\",\"attrs\":{\"start\":203,\"end\":211},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":203,\"end\":211,\"uuid\":\"ce246f2b-9ace-40b3-9768-f2ad284823d3\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", both meaning “light.”\",\"attrs\":{\"start\":211,\"end\":234}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"14c1f809-5e6f-4023-bbe8-3659b4c8fb28\",\"sort\":161,\"type\":\"introduction\",\"label\":\"i.16\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":299,\"uuid\":\"14c1f809-5e6f-4023-bbe8-3659b4c8fb28\"},\"content\":[{\"type\":\"text\",\"text\":\"The Sanskrit text of the sūtra was first edited in 1898, in Calcutta, India, by S. C. Das and S. C. Shastri. That was followed by the edition by B. Nanjio and H. Idzumi in Japan in 1931, and by the edition by Johannes Nobel (1887–1960) in 1937. This translation refers to the 1967 S. Bagchi edition.\",\"attrs\":{\"start\":0,\"end\":299}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"058f6ac4-fed6-4e7c-9928-52e2aa8574a9\",\"sort\":162,\"type\":\"introductionHeader\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":3,\"start\":0,\"end\":23,\"uuid\":\"b08f19b2-17bd-40e0-97d2-144a645dffb6\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"The Sūtra outside India\",\"attrs\":{\"start\":0,\"end\":23}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"96737276-738e-458d-82d2-efbaa61a9a3d\",\"sort\":164,\"type\":\"introduction\",\"label\":\"i.17\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":384,\"uuid\":\"96737276-738e-458d-82d2-efbaa61a9a3d\"},\"content\":[{\"type\":\"text\",\"text\":\"The widespread popularity of this sūtra outside India is also evident from its translation not only into Tibetan and Chinese but also from Sanskrit into Khotanese; from Chinese into Tibetan, Sogdian, Uighur, Tangut, and Manchu; and from Tibetan into Mongolian. Its importance continues in recent times, with new translations directly from Sanskrit into Mongolian, Oirat, and Japanese.\",\"attrs\":{\"start\":0,\"end\":384}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"124828eb-15d5-4bc6-89fb-22e125380297\",\"sort\":166,\"type\":\"introduction\",\"label\":\"i.18\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1017,\"uuid\":\"124828eb-15d5-4bc6-89fb-22e125380297\"},\"content\":[{\"type\":\"text\",\"text\":\"There are three surviving translations of \",\"attrs\":{\"start\":0,\"end\":42}},{\"type\":\"text\",\"text\":\"The Sūtra of the Sublime Golden Light \",\"attrs\":{\"start\":42,\"end\":80},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"e65e6138-9987-4abf-957c-a3499f22ef8b\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"in Chinese. The earliest of these was translated by Dharmakṣema (385–433). He was an Indian who came to China in 414, living first in Dunhuang. Then in 420 he went to Guzang, the capital of Northern Liang, one of the sixteen independent states of that time, situated in what is now the Gansu region in China’s northwest. There he studied Chinese and engaged in translation under the patronage of Juqu Mengxun (368–433), the ruler of Northern Liang. He also had the reputation of being “a master of spells.” As a result of that reputation, Juqu Mengxun, toward the end of his reign, became afraid that Dharmakṣema might be used against him by his adversaries and so he had him assassinated.\",\"attrs\":{\"start\":80,\"end\":769},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"b06b66ff-e9ec-4272-a358-2509d924fa32\",\"label\":\"12\",\"uuid\":\"cf927d80-88c2-4a85-ad05-003698596836\",\"start\":769,\"end\":769,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" Nobel believed that the Sanskrit in its present form is not earlier than the mid-fifth century and that Dharmakṣema translated from an earlier version. This opinion appears to be supported by the Sanskrit manuscript fragments discovered in Khotan.\",\"attrs\":{\"start\":769,\"end\":1017},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"a9b5e8b4-9e14-4f48-98ed-16822d1703c4\",\"label\":\"13\",\"uuid\":\"c54c6d72-07fd-492d-aaea-b8b8c3cb3c74\",\"start\":1017,\"end\":1017,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"1a322690-f00f-4c05-aebc-b47f468f2ddd\",\"sort\":173,\"type\":\"introduction\",\"label\":\"i.19\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":381,\"uuid\":\"1a322690-f00f-4c05-aebc-b47f468f2ddd\"},\"content\":[{\"type\":\"text\",\"text\":\"The second surviving translation into Chinese is that by Bao Gui in 597. It is an amalgam of earlier translations that no longer exist and four chapters that were translated by Paramārtha (499–569). As there is no surviving Sanskrit for the additional chapters in the Chinese and Tibetan, Michael Radich has examined the evidence as to whether they are Indian or Chinese in origin.\",\"attrs\":{\"start\":0,\"end\":381}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"6e0659e3-5124-4082-8aea-859cc2cbc049\",\"sort\":175,\"type\":\"introduction\",\"label\":\"i.20\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":661,\"uuid\":\"6e0659e3-5124-4082-8aea-859cc2cbc049\"},\"content\":[{\"type\":\"text\",\"text\":\"The third translation was by Yijing (635–713), which was published in 703. Because of its clarity and writing style, this version became popular in China and was itself translated into Tibetan in the early ninth century. Yijing’s translation, compared to the Sanskrit and the Tibetan translation from Sanskrit, is freer, to the extent that Emmerick has stated it could not be used to reconstruct the original Sanskrit.\",\"attrs\":{\"start\":0,\"end\":418},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"db61cb28-ccd5-4ac8-939e-b38494ce46e1\",\"label\":\"14\",\"uuid\":\"efea77fd-ccef-49ef-8ce4-6e1b6c9e1f90\",\"start\":418,\"end\":418,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" Yijing spent thirty years in India and Sumatra and returned to China in 695. He brought with him four hundred Sanskrit texts, including \",\"attrs\":{\"start\":418,\"end\":555}},{\"type\":\"text\",\"text\":\"The Sūtra of the Sublime Golden Light,\",\"attrs\":{\"start\":555,\"end\":593},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"5524970a-cd6d-4a6f-9ae9-2cc3a9b8dd33\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" and spent the first decade of the seventh century translating them.\",\"attrs\":{\"start\":593,\"end\":661},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"e697d551-82ab-4c5a-a58b-1c11cec5d2dc\",\"label\":\"15\",\"uuid\":\"084ebd49-29a8-4c3d-9a4b-3a12d553cf68\",\"start\":661,\"end\":661,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"a52c3980-2af5-4459-b1a4-db2f36296a14\",\"sort\":182,\"type\":\"introduction\",\"label\":\"i.21\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":619,\"uuid\":\"a52c3980-2af5-4459-b1a4-db2f36296a14\"},\"content\":[{\"type\":\"text\",\"text\":\"The Mogao caves of Dunhuang, which were sealed in the eleventh century, contained a great number of manuscripts of the sūtra, particularly those of Yijing’s translation into Chinese. The sūtra became popular for its teachings on freeing oneself from the effects of bad karma. For example, Yijing’s Chinese translation (and the Uighur and Tangut versions derived from it) has a preface that states how the sūtra saved Zhang Judao, ruler of Tangut, from going to hell because he had slaughtered cattle for a big feast. This narrative is illustrated in a twelfth-century Tangut woodcut that is preserved in St. Petersburg.\",\"attrs\":{\"start\":0,\"end\":619},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"3ae9cbde-692b-484a-a289-110e4e1a4092\",\"label\":\"16\",\"uuid\":\"9e16d044-c2cc-43ac-a6cf-c46f37260255\",\"start\":619,\"end\":619,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"40d1c84c-0dd9-4880-b443-9e7843e95c89\",\"sort\":185,\"type\":\"introduction\",\"label\":\"i.22\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":190,\"uuid\":\"40d1c84c-0dd9-4880-b443-9e7843e95c89\"},\"content\":[{\"type\":\"text\",\"text\":\"The sūtra was of particular importance to monarchs, and starting in seventh-century Japan, the ritual of reciting this sūtra was considered important to perform for the benefit of the state.\",\"attrs\":{\"start\":0,\"end\":190}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"6d567487-25cb-435d-9e18-b02e2dd1ba0f\",\"sort\":186,\"type\":\"introductionHeader\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":3,\"start\":0,\"end\":18,\"uuid\":\"49858bcb-f1b2-4c96-b357-98b2d84a53de\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"The Sūtra in Tibet\",\"attrs\":{\"start\":0,\"end\":18}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"b48c8d5c-c108-4a2c-a210-b68ef99d6c6b\",\"sort\":188,\"type\":\"introduction\",\"label\":\"i.23\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":344,\"uuid\":\"b48c8d5c-c108-4a2c-a210-b68ef99d6c6b\"},\"content\":[{\"type\":\"text\",\"text\":\"Toh 557 does not list its translators in the colophon. Toh 556 (the version translated here) was produced by \",\"attrs\":{\"start\":0,\"end\":109}},{\"type\":\"text\",\"text\":\"Jinamitra\",\"attrs\":{\"start\":109,\"end\":118},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b654fd57-78ef-498c-b735-47932a5790ca\",\"uuid\":\"5b1b9e3f-5705-43e2-91ec-a59aee20b82c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", Śilendrabodhi, and Yeshé Dé in the early ninth century. Almost the entirety of Toh 557 is present word for word in Toh 556, so they either incorporated an earlier translation or extracted the shorter version from the longer.\",\"attrs\":{\"start\":118,\"end\":344}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"ddc86298-22cd-4a65-bc2e-6d8e7ba3008c\",\"sort\":192,\"type\":\"introduction\",\"label\":\"i.24\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":380,\"uuid\":\"ddc86298-22cd-4a65-bc2e-6d8e7ba3008c\"},\"content\":[{\"type\":\"text\",\"text\":\"By contrast, Toh 555 is a translation made by Gö Chödrup of Yijing’s Chinese version in the early ninth century. The Tibetan is clearer and more readable than in the other two versions, perhaps because it is less constrained by conforming to the Sanskrit, but also because the Chinese was a freer translation from the Sanskrit, which was done purposely to enhance its readability.\",\"attrs\":{\"start\":0,\"end\":380}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"eb2acf92-b2e0-49b7-8b81-fde62f33a896\",\"sort\":194,\"type\":\"introduction\",\"label\":\"i.25\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":454,\"uuid\":\"eb2acf92-b2e0-49b7-8b81-fde62f33a896\"},\"content\":[{\"type\":\"text\",\"text\":\"There are some Tibetan texts included in the Tengyur that were authored by Tibetan translators active in the early ninth century. The translator Kawa Paltsek quotes from the passages describing the \",\"attrs\":{\"start\":0,\"end\":198}},{\"type\":\"text\",\"text\":\"Dharma body\",\"attrs\":{\"start\":198,\"end\":209},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"0a6167f8-dde3-4a27-9610-5a006a6f7516\",\"uuid\":\"8ae22d7c-3353-4d07-9f99-975388d21fca\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and the Buddha not leaving any relics because he has no body with bones and blood.\",\"attrs\":{\"start\":209,\"end\":292},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"b85dcbd2-859d-43a9-85fb-f17db8455a26\",\"label\":\"17\",\"uuid\":\"a821f30f-2db8-4381-bba2-10f034e3bccd\",\"start\":292,\"end\":292,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" Yeshé Dé wrote a text that has a number of references to this sūtra’s teaching on the \",\"attrs\":{\"start\":292,\"end\":379}},{\"type\":\"text\",\"text\":\"three bodies\",\"attrs\":{\"start\":379,\"end\":391},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7015a5ba-934e-44c1-9e77-244de7b7c93a\",\"uuid\":\"6c7fb464-6087-4990-808a-4bf5d4f5ae94\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of a buddha, buddha nature, and the description of the \",\"attrs\":{\"start\":391,\"end\":447}},{\"type\":\"text\",\"text\":\"bhūmis\",\"attrs\":{\"start\":447,\"end\":453},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ff1e1864-2411-4b97-a56d-bfd1b395dc48\",\"uuid\":\"81f8c3d9-284a-4f5a-b273-25fc4b7077e1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":453,\"end\":454},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"bc801eef-22be-4632-9b52-2a724a93f5c0\",\"label\":\"18\",\"uuid\":\"035bd9c7-b2ac-458c-85e0-f5fbf875028c\",\"start\":454,\"end\":454,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"a7d1327b-0627-4efe-adb8-d48be6078650\",\"sort\":205,\"type\":\"introduction\",\"label\":\"i.26\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":359,\"uuid\":\"a7d1327b-0627-4efe-adb8-d48be6078650\"},\"content\":[{\"type\":\"text\",\"text\":\"Dīpaṁkaraśrījñāna, also known as Atiśa, whose pupils founded the influential Kadampa tradition in Tibet, is the author of three of the texts in the Tengyur that refer to this sūtra, including his most famous work, \",\"attrs\":{\"start\":0,\"end\":214}},{\"type\":\"text\",\"text\":\"A Lamp for the Path to Enlightenment,\",\"attrs\":{\"start\":214,\"end\":251},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"928346b0-9735-49b2-9228-73d9ce8ed027\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" which contains an encouragement to use the sūtra’s prayer both for purification and as a dedication prayer.\",\"attrs\":{\"start\":251,\"end\":359}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"da12800c-45d0-46e1-8015-03efb2775a15\",\"sort\":209,\"type\":\"introduction\",\"label\":\"i.27\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":914,\"uuid\":\"da12800c-45d0-46e1-8015-03efb2775a15\"},\"content\":[{\"type\":\"text\",\"text\":\"The commentary in the Tengyur that quotes from the sūtra more than any other‍—twenty times in all‍—is the translation by Gö Chödrup of \",\"attrs\":{\"start\":0,\"end\":135}},{\"type\":\"text\",\"text\":\"An Extensive Commentary on the Sūtra that Elucidates the Profound Intention \",\"attrs\":{\"start\":135,\"end\":211},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"5ce6d888-6f12-4041-b0f9-3064169e800e\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"by the Korean monk Wŏnch’ŭk\",\"attrs\":{\"start\":211,\"end\":238},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"131f5605-1a6a-4e88-8dbf-cce9b5c6186d\",\"label\":\"19\",\"uuid\":\"136756c4-30de-4668-a0a7-1cf3df733a9c\",\"start\":238,\"end\":238,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" (613–96), who had migrated to China. This commentary by Wŏnch’ŭk in Tibetan translation became a particular influence on the thought of Tsongkhapa, the founder of the Gelukpa school.\",\"attrs\":{\"start\":238,\"end\":421},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"d244b45e-0410-490a-84fe-86e1bb0dbb50\",\"label\":\"20\",\"uuid\":\"730c370a-84dd-47d5-92ce-68ad836c0cee\",\"start\":421,\"end\":421,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" The sūtra has been quoted by great masters in all the schools of Tibetan Buddhism and extracts from it were published in Tibet as numerous standalone texts‍—not only the confession prayer but also other chapters, such as the treatise on kingship. Its continuing significance is indicated by Pema Karpo (1527–92), the hierarch of the Drukpa Kagyü school, composing a confession prayer extracted from \",\"attrs\":{\"start\":421,\"end\":821}},{\"type\":\"text\",\"text\":\"The Sūtra of the Sublime Golden Light \",\"attrs\":{\"start\":821,\"end\":859},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"05ddb0cf-3aa6-47c9-b36b-06dde9a5b082\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"at the request of Döndrup Dorjé, the ruler of \",\"attrs\":{\"start\":859,\"end\":905}},{\"type\":\"text\",\"text\":\"Shigatsé\",\"attrs\":{\"start\":905,\"end\":913},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"76159604-dc51-4698-8a9a-1871f7e1dd7b\",\"uuid\":\"64b78851-e762-4e55-8d86-ed3f74cd1f1e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":913,\"end\":914}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"fd89091d-a9c3-4cb9-8ab5-908a56746152\",\"sort\":221,\"type\":\"introduction\",\"label\":\"i.28\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":152,\"uuid\":\"fd89091d-a9c3-4cb9-8ab5-908a56746152\"},\"content\":[{\"type\":\"text\",\"text\":\"An example of the way the sūtra was recited in Tibet is found in a version compiled by Ngawang Lobsang Chöden (1642–1714), the second Changkya Rinpoché.\",\"attrs\":{\"start\":0,\"end\":152}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"1500ff0f-36a9-4ad3-b409-1f187d537401\",\"sort\":222,\"type\":\"introductionHeader\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":3,\"start\":0,\"end\":22,\"uuid\":\"514054d6-7a57-4897-aac2-46e43fea8cda\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"Comparing the Versions\",\"attrs\":{\"start\":0,\"end\":22}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"a6dd6c5e-b3ec-43f8-b5a9-a3c0f577d208\",\"sort\":224,\"type\":\"introduction\",\"label\":\"i.29\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":407,\"uuid\":\"a6dd6c5e-b3ec-43f8-b5a9-a3c0f577d208\"},\"content\":[{\"type\":\"text\",\"text\":\"Toh 556 and Toh 557 were both translated into Tibetan from Sanskrit. Chapter 4 in Toh 556 is the equivalent of chapters 3 and 4 in Toh 557; chapters 9 and 10 in Toh 556 are the equivalent of chapter 6 in Toh 557; and chapters 11 and 12 in Toh 556 are the equivalent of chapter 12 in Toh 557. There are seven additional chapters in Toh 556 that are not found in Toh 557: chapters 3, 5, 6, 13, 14, 17, and 28.\",\"attrs\":{\"start\":0,\"end\":407}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"9acb29e8-fbcd-4831-90ce-974dd33eba96\",\"sort\":226,\"type\":\"introduction\",\"label\":\"i.30\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1035,\"uuid\":\"9acb29e8-fbcd-4831-90ce-974dd33eba96\"},\"content\":[{\"type\":\"text\",\"text\":\"Chapter 5 is almost entirely composed of the contents of \",\"attrs\":{\"start\":0,\"end\":57}},{\"type\":\"text\",\"text\":\"Putting an End to Karmic Obscurations \",\"attrs\":{\"start\":57,\"end\":95},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"1c7b6d32-0134-4a32-9582-e4c1f7aa9adc\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"(\",\"attrs\":{\"start\":95,\"end\":96}},{\"type\":\"text\",\"text\":\"Toh 219)\",\"attrs\":{\"start\":96,\"end\":104},\"marks\":[{\"type\":\"internalLink\",\"attrs\":{\"uuid\":\"22e28e88-024e-4fed-a648-d1f35d27d618\",\"href\":\"/entity/work/1b140160-94c8-4ade-a29c-14c64f5deb66\",\"entity\":\"1b140160-94c8-4ade-a29c-14c64f5deb66\",\"type\":\"work\",\"toh\":null,\"linkToh\":\"toh219\"}}]},{\"type\":\"text\",\"text\":\", differing only in its introduction and conclusion. Toh 556’s chapter 5 is identical in its translation to the sūtra as it appears in the Kangyur. Even where there are some minor differences between this chapter 5 and the sūtra in the Degé Kangyur versions, those discrepancies do not exist in earlier Kangyurs. The translators of \",\"attrs\":{\"start\":104,\"end\":436}},{\"type\":\"text\",\"text\":\"Putting an End to Karmic Obscurations \",\"attrs\":{\"start\":436,\"end\":474},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"1ddc43a7-db8f-4bfe-b3fb-666047230e43\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"were \",\"attrs\":{\"start\":474,\"end\":479}},{\"type\":\"text\",\"text\":\"Jinamitra\",\"attrs\":{\"start\":479,\"end\":488},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b654fd57-78ef-498c-b735-47932a5790ca\",\"uuid\":\"1dfcbb95-9f82-42af-882b-f6d886b89e83\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", Dānaśīla, and Yeshé Dé, and their translation appears to have been incorporated into the translation of this twenty-nine-chapter \",\"attrs\":{\"start\":488,\"end\":619}},{\"type\":\"text\",\"text\":\"Sūtra of the Sublime Golden Light.\",\"attrs\":{\"start\":619,\"end\":653},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"eaa3fc69-49c1-413c-9a6d-3db65e06c5a4\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" Chapter 6 primarily comprises \",\"attrs\":{\"start\":653,\"end\":684}},{\"type\":\"text\",\"text\":\"The Sūtra of Akṣayamati’s Questions \",\"attrs\":{\"start\":684,\"end\":720},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"558aa9dd-8bee-4c23-8328-dfb4a9c8deb6\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"(Toh 89), without the introductory setting and with additional verses and an extra conclusion. That sūtra was translated by Silendrabodhi and Yeshé Dé, and their translation has been incorporated word-for-word into this translation of \",\"attrs\":{\"start\":720,\"end\":955}},{\"type\":\"text\",\"text\":\"The Sūtra of the Sublime Golden Light \",\"attrs\":{\"start\":955,\"end\":993},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"db66fac3-414e-46ec-9e43-1c245dd5e2e0\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"by \",\"attrs\":{\"start\":993,\"end\":996}},{\"type\":\"text\",\"text\":\"Jinamitra\",\"attrs\":{\"start\":996,\"end\":1005},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b654fd57-78ef-498c-b735-47932a5790ca\",\"uuid\":\"8bf64c55-d89c-4a2c-b909-dcc7a8e964e0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", Nalendrabodhi, and Yeshé Dé.\",\"attrs\":{\"start\":1005,\"end\":1035}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"c9b38149-57e7-49fd-a3d8-9a78492eefb9\",\"sort\":246,\"type\":\"introduction\",\"label\":\"i.31\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":441,\"uuid\":\"c9b38149-57e7-49fd-a3d8-9a78492eefb9\"},\"content\":[{\"type\":\"text\",\"text\":\"Only the Sanskrit that is equivalent to Toh 557 survives. It divides the equivalent of chapter 10 in the Tibetan version into two, separating the homage to buddhas and bodhisattvas into its own small chapter. However, its final chapter is divided into two in the Tibetan, resulting in both having twenty-one chapters. There is no surviving Sanskrit for additional passages within the chapters or for the seven additional chapters in Toh 556.\",\"attrs\":{\"start\":0,\"end\":441}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"7ec8a2fa-598e-4ebc-b8ac-58b0b2bf9f13\",\"sort\":248,\"type\":\"introduction\",\"label\":\"i.32\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":307,\"uuid\":\"7ec8a2fa-598e-4ebc-b8ac-58b0b2bf9f13\"},\"content\":[{\"type\":\"text\",\"text\":\"Toh 556 appears to preserve passages that were lost from Toh 557. For example, chapter 12 in Toh 557, “The King’s Treatise,” begins abruptly: “At that time…,” having evidently lost the introductory narrative‍—present in the equivalent chapter (chapter 20) in Toh 556‍—that sets the action in a distant past.\",\"attrs\":{\"start\":0,\"end\":307}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"9bdd390a-1016-430b-b5f9-b872bdd5048a\",\"sort\":250,\"type\":\"introduction\",\"label\":\"i.33\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":431,\"uuid\":\"9bdd390a-1016-430b-b5f9-b872bdd5048a\"},\"content\":[{\"type\":\"text\",\"text\":\"Toh 555 was translated into Tibetan from Chinese.\",\"attrs\":{\"start\":0,\"end\":49},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"bcc2523c-aac1-483c-bbbb-9d74a38c7d8d\",\"label\":\"21\",\"uuid\":\"59dbb1f6-f845-4764-bc81-faeec9f1e7c1\",\"start\":49,\"end\":49,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" The source text was Yijing’s seventh-century translation from Sanskrit into Chinese, and therefore the translation differs throughout, even though the content is essentially the same. There are many passages that are actually shorter versions of those in the translations from Sanskrit. Its greater length compared to Toh 556 is primarily due to the addition of chapters 29 and 30.\",\"attrs\":{\"start\":49,\"end\":431}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"0d3ddce6-f43d-48a8-9b88-50329991381e\",\"sort\":253,\"type\":\"introductionHeader\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":3,\"start\":0,\"end\":35,\"uuid\":\"746064ad-395d-4bd1-af5d-2970fc916c2d\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"Translations into Western Languages\",\"attrs\":{\"start\":0,\"end\":35}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"f9dbedaf-021f-4785-90ef-5e3347ca8bfc\",\"sort\":255,\"type\":\"introduction\",\"label\":\"i.34\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":276,\"uuid\":\"f9dbedaf-021f-4785-90ef-5e3347ca8bfc\"},\"content\":[{\"type\":\"text\",\"text\":\"In 1958, Nobel published a German translation based on Yijing’s Chinese text. In 1970, Ronald Emmerick produced an English translation of the Sanskrit. In 2007, Zopa Rinpoche’s FPMT (Foundation for the Preservation of the Mahayana Tradition) produced a translation of Toh 557.\",\"attrs\":{\"start\":0,\"end\":276}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"ca457d98-5c9b-4b19-a8c9-f2a5af23faa3\",\"sort\":256,\"type\":\"introductionHeader\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":3,\"start\":0,\"end\":57,\"uuid\":\"2cd7fc9f-fb0f-4a71-8905-e2303da3f4d9\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"Detailed Summary of \",\"attrs\":{\"start\":0,\"end\":20}},{\"type\":\"text\",\"text\":\"The Sūtra of the Sublime Golden Light\",\"attrs\":{\"start\":20,\"end\":57},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"b096e428-39fb-478e-b158-9e57f46f8b7a\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"0b02f579-667d-4b6b-adef-2a9eed9c15c5\",\"sort\":258,\"type\":\"introductionHeader\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":4,\"start\":0,\"end\":27,\"uuid\":\"f28bbf13-ca4c-4cc1-9722-0dd6d960e5c2\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"Chapter 1: The Introduction\",\"attrs\":{\"start\":0,\"end\":27}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"1df1a2f7-04d9-4584-9e99-b26fa7a61f4c\",\"sort\":260,\"type\":\"introduction\",\"label\":\"i.35\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":245,\"uuid\":\"1df1a2f7-04d9-4584-9e99-b26fa7a61f4c\"},\"content\":[{\"type\":\"text\",\"text\":\"The Buddha is on \",\"attrs\":{\"start\":0,\"end\":17}},{\"type\":\"text\",\"text\":\"Vulture Peak\",\"attrs\":{\"start\":17,\"end\":29},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bbb9e0c6-80e9-4879-ad0d-7c85f53bda98\",\"uuid\":\"fc80d6b7-31b3-4fb2-8fdd-384509e924f4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" Mountain at \",\"attrs\":{\"start\":29,\"end\":42}},{\"type\":\"text\",\"text\":\"Rājagṛha\",\"attrs\":{\"start\":42,\"end\":50},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8a64da85-ad7e-4c47-b376-c981f1c2a4b2\",\"uuid\":\"da0d6171-7994-4243-a14c-32dd28904485\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" with a great assembly of \",\"attrs\":{\"start\":50,\"end\":76}},{\"type\":\"text\",\"text\":\"bhikṣus\",\"attrs\":{\"start\":76,\"end\":83},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5365d0e6-91d5-4ce8-8796-a14339d6e504\",\"uuid\":\"deefb016-fb84-4842-a9db-7fc1dab308d9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", bodhisattvas, and deities. He states that he will teach a sūtra that will free beings from various worldly sufferings through its being recited and listened to.\",\"attrs\":{\"start\":83,\"end\":245}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"a1f44a28-cbfb-4eba-9290-c75419b2d0e8\",\"sort\":267,\"type\":\"introductionHeader\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":4,\"start\":0,\"end\":56,\"uuid\":\"6c29b7f1-c922-4d23-9a5f-70de48936f0e\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"Chapter 2: The Teaching of the Lifespan of the Tathāgata\",\"attrs\":{\"start\":0,\"end\":56}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"4716005d-b3b6-4f2f-8f2a-71978a9a32c3\",\"sort\":269,\"type\":\"introduction\",\"label\":\"i.36\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":582,\"uuid\":\"4716005d-b3b6-4f2f-8f2a-71978a9a32c3\"},\"content\":[{\"type\":\"text\",\"text\":\"In the town of \",\"attrs\":{\"start\":0,\"end\":15}},{\"type\":\"text\",\"text\":\"Rājagṛha\",\"attrs\":{\"start\":15,\"end\":23},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8a64da85-ad7e-4c47-b376-c981f1c2a4b2\",\"uuid\":\"ef71ce2a-bf0c-4c33-aa29-669dd00e2178\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the bodhisattva \",\"attrs\":{\"start\":23,\"end\":41}},{\"type\":\"text\",\"text\":\"Ruciraketu\",\"attrs\":{\"start\":41,\"end\":51},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"727c3a9f-2dae-46b4-89e7-d5f8bedeb247\",\"uuid\":\"be55d6c5-c0dc-4a6f-9554-438add4183c8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" wonders why the Buddha has only an eighty-year lifespan if he has no bad karma. His house miraculously transforms, and the buddhas of the four directions appear and tell him that the Buddha’s lifespan is, in fact, inconceivably long. \",\"attrs\":{\"start\":51,\"end\":286}},{\"type\":\"text\",\"text\":\"Ruciraketu\",\"attrs\":{\"start\":286,\"end\":296},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"727c3a9f-2dae-46b4-89e7-d5f8bedeb247\",\"uuid\":\"9ca3110e-45b7-4296-aea2-83b06610c2ea\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" goes to \",\"attrs\":{\"start\":296,\"end\":305}},{\"type\":\"text\",\"text\":\"Vulture Peak\",\"attrs\":{\"start\":305,\"end\":317},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bbb9e0c6-80e9-4879-ad0d-7c85f53bda98\",\"uuid\":\"c8f99ef3-8bb2-4f10-a97b-96158d8e7aab\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and tells the Buddha what occurred. The buddhas of the four directions appear on \",\"attrs\":{\"start\":317,\"end\":399}},{\"type\":\"text\",\"text\":\"Vulture Peak\",\"attrs\":{\"start\":399,\"end\":411},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bbb9e0c6-80e9-4879-ad0d-7c85f53bda98\",\"uuid\":\"37dbc489-e5e5-4878-85db-a99b11ece18d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and request the Buddha to teach \",\"attrs\":{\"start\":411,\"end\":444}},{\"type\":\"text\",\"text\":\"The Sūtra of the Sublime Golden Light.\",\"attrs\":{\"start\":444,\"end\":482},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"2578f461-4f95-4be4-a5dc-24965771ca40\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" The Buddha states that he continues to teach on \",\"attrs\":{\"start\":482,\"end\":531}},{\"type\":\"text\",\"text\":\"Vulture Peak\",\"attrs\":{\"start\":531,\"end\":543},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bbb9e0c6-80e9-4879-ad0d-7c85f53bda98\",\"uuid\":\"669a3a52-3bd6-4e93-950d-64f0caf8e848\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and only appears to pass into \",\"attrs\":{\"start\":543,\"end\":574}},{\"type\":\"text\",\"text\":\"nirvāṇa\",\"attrs\":{\"start\":574,\"end\":581},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bebe04fd-2b22-4637-89db-ae1cd69dffe1\",\"uuid\":\"9d2b6bb4-b657-4ab5-8b9a-fd53408c49b4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":581,\"end\":582}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"397b2f54-139f-4925-b9cd-db7e949c02f1\",\"sort\":287,\"type\":\"introduction\",\"label\":\"i.37\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":444,\"uuid\":\"397b2f54-139f-4925-b9cd-db7e949c02f1\"},\"content\":[{\"type\":\"text\",\"text\":\"The \",\"attrs\":{\"start\":0,\"end\":4}},{\"type\":\"text\",\"text\":\"Kauṇḍinya\",\"attrs\":{\"start\":4,\"end\":13},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"aa2c2a31-ffdb-4887-a677-972a8ec87ca3\",\"uuid\":\"4589570f-8146-4593-9e5a-b218665d5c06\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":13,\"end\":14}},{\"type\":\"text\",\"text\":\"brahmin\",\"attrs\":{\"start\":14,\"end\":21},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41a01c6c-e7cf-4689-b3bb-4cdb181c88b6\",\"uuid\":\"ec7e133f-4d4b-4303-9a50-31369d041fb2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":21,\"end\":22}},{\"type\":\"text\",\"text\":\"Vyākaraṇa\",\"attrs\":{\"start\":22,\"end\":31},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4ab87917-09a8-4fc8-86f0-bcf3470b170a\",\"uuid\":\"99401d46-645f-4bbf-ac63-57fb03ef3dd3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" asks to be given a relic when the Buddha passes away so that he might make offerings to it. A young man says to the \",\"attrs\":{\"start\":31,\"end\":148}},{\"type\":\"text\",\"text\":\"Kauṇḍinya\",\"attrs\":{\"start\":148,\"end\":157},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"aa2c2a31-ffdb-4887-a677-972a8ec87ca3\",\"uuid\":\"97fe98a0-2dad-41ee-8d54-d366e4fc518b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":157,\"end\":158}},{\"type\":\"text\",\"text\":\"brahmin\",\"attrs\":{\"start\":158,\"end\":165},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41a01c6c-e7cf-4689-b3bb-4cdb181c88b6\",\"uuid\":\"6aa34d2a-150f-4f53-ae66-68f8b0203f73\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" that the Buddha will not pass away and there will never be relics. The \",\"attrs\":{\"start\":165,\"end\":237}},{\"type\":\"text\",\"text\":\"Kauṇḍinya\",\"attrs\":{\"start\":237,\"end\":246},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"aa2c2a31-ffdb-4887-a677-972a8ec87ca3\",\"uuid\":\"b737d52d-ab57-4f37-8282-a259d6d88ebe\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":246,\"end\":247}},{\"type\":\"text\",\"text\":\"brahmin\",\"attrs\":{\"start\":247,\"end\":254},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41a01c6c-e7cf-4689-b3bb-4cdb181c88b6\",\"uuid\":\"ff0edb4b-7e7d-484e-b66a-865e41dd7b23\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" states that he knew this but made his request so that this truth would be revealed, and that the appearance of passing away and leaving relics is simply a skillful method to benefit beings.\",\"attrs\":{\"start\":254,\"end\":444}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"4bed7d2b-29b4-435b-bdaa-540113d13b32\",\"sort\":303,\"type\":\"introduction\",\"label\":\"i.38\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":215,\"uuid\":\"4bed7d2b-29b4-435b-bdaa-540113d13b32\"},\"content\":[{\"type\":\"text\",\"text\":\"Ruciraketu\",\"attrs\":{\"start\":0,\"end\":10},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"727c3a9f-2dae-46b4-89e7-d5f8bedeb247\",\"uuid\":\"f94cd25f-f9a6-48c4-bb88-05c14b871119\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" then asks why it is taught that buddhas pass away and leave relics. The Buddha states that this is a teaching with an implied meaning, and he then teaches on four sets of the true \",\"attrs\":{\"start\":10,\"end\":191}},{\"type\":\"text\",\"text\":\"nirvāṇa\",\"attrs\":{\"start\":191,\"end\":198},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bebe04fd-2b22-4637-89db-ae1cd69dffe1\",\"uuid\":\"20445157-b243-44af-be3c-3814753039b6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s ten qualities.\",\"attrs\":{\"start\":198,\"end\":215}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"e12e6af2-1249-4443-a0df-6adc08fe701b\",\"sort\":308,\"type\":\"introduction\",\"label\":\"i.39\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":81,\"uuid\":\"e12e6af2-1249-4443-a0df-6adc08fe701b\"},\"content\":[{\"type\":\"text\",\"text\":\"Then the four buddhas vanish, and \",\"attrs\":{\"start\":0,\"end\":34}},{\"type\":\"text\",\"text\":\"Ruciraketu\",\"attrs\":{\"start\":34,\"end\":44},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"727c3a9f-2dae-46b4-89e7-d5f8bedeb247\",\"uuid\":\"df0e401d-f068-488b-ae85-b2268499918f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" returns to his seat in the assembly.\",\"attrs\":{\"start\":44,\"end\":81}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"04d43c07-5249-4f23-b32a-23266e6580eb\",\"sort\":311,\"type\":\"introductionHeader\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":4,\"start\":0,\"end\":50,\"uuid\":\"7da9e795-99f1-428c-b7fe-80bef32296c9\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"Chapter 3: The Differentiation of the Three Bodies\",\"attrs\":{\"start\":0,\"end\":50}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"bf997caf-9691-4cb3-b518-432b910f5589\",\"sort\":313,\"type\":\"introduction\",\"label\":\"i.40\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":895,\"uuid\":\"bf997caf-9691-4cb3-b518-432b910f5589\"},\"content\":[{\"type\":\"text\",\"text\":\"This chapter is not included in Toh 557. In response to a question from the bodhisattva \",\"attrs\":{\"start\":0,\"end\":88}},{\"type\":\"text\",\"text\":\"Ākāśagarbha\",\"attrs\":{\"start\":88,\"end\":99},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b78f2e81-fa8d-4312-a7a1-86949f89ddfd\",\"uuid\":\"c3a61d06-7344-4192-afcb-c26ea01427ef\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the Buddha describes the \",\"attrs\":{\"start\":99,\"end\":126}},{\"type\":\"text\",\"text\":\"three bodies\",\"attrs\":{\"start\":126,\"end\":138},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7015a5ba-934e-44c1-9e77-244de7b7c93a\",\"uuid\":\"d0c21d82-dffb-49fb-8405-0b9d2b117a8f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"‍—the \",\"attrs\":{\"start\":138,\"end\":144}},{\"type\":\"text\",\"text\":\"Dharma body\",\"attrs\":{\"start\":144,\"end\":155},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"0a6167f8-dde3-4a27-9610-5a006a6f7516\",\"uuid\":\"2a324979-8d28-4c93-8e1b-7ae96366697d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":155,\"end\":157}},{\"type\":\"text\",\"text\":\"enjoyment body\",\"attrs\":{\"start\":157,\"end\":171},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1e7fa671-a07c-41c2-ac36-bd729926ac4d\",\"uuid\":\"971ba9b6-c07e-4849-9c56-8acc78e123a7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and \",\"attrs\":{\"start\":171,\"end\":177}},{\"type\":\"text\",\"text\":\"emanation body\",\"attrs\":{\"start\":177,\"end\":191},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c73b5e86-3fdb-4c2c-8a69-e6b7e4c5cbe9\",\"uuid\":\"262f9c78-2a30-4c70-98e0-bfc52d6ffd01\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"‍—that complete buddhahood comprises. The \",\"attrs\":{\"start\":191,\"end\":233}},{\"type\":\"text\",\"text\":\"emanation body\",\"attrs\":{\"start\":233,\"end\":247},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c73b5e86-3fdb-4c2c-8a69-e6b7e4c5cbe9\",\"uuid\":\"1a40b910-6b45-4d1d-9599-7c135721e246\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is the manifestation of various kinds of bodies of individuals in accordance with the various situations of beings. The \",\"attrs\":{\"start\":247,\"end\":368}},{\"type\":\"text\",\"text\":\"enjoyment body\",\"attrs\":{\"start\":368,\"end\":382},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1e7fa671-a07c-41c2-ac36-bd729926ac4d\",\"uuid\":\"04372f26-c4d7-473e-a164-15a22f0e3da8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is the manifestation of perfect bodies that teach the ultimate truth to bodhisattvas. Neither of these bodies, however, has ultimate reality, whereas the \",\"attrs\":{\"start\":382,\"end\":537}},{\"type\":\"text\",\"text\":\"Dharma body\",\"attrs\":{\"start\":537,\"end\":548},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"0a6167f8-dde3-4a27-9610-5a006a6f7516\",\"uuid\":\"29d3d0e6-f48c-432c-a77f-bc335b27a39b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is the ultimate, featureless, true nature that is the basis of the other two bodies, which appear spontaneously without thought and can be described as having both permanent and impermanent qualities. The Buddha gives various analogies to describe them. He also describes the progress to buddhahood through the ten \",\"attrs\":{\"start\":548,\"end\":864}},{\"type\":\"text\",\"text\":\"bhūmis\",\"attrs\":{\"start\":864,\"end\":870},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ff1e1864-2411-4b97-a56d-bfd1b395dc48\",\"uuid\":\"7c2bf062-eb5c-4eef-842e-e9fc40885797\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and the ten \",\"attrs\":{\"start\":870,\"end\":883}},{\"type\":\"text\",\"text\":\"perfections\",\"attrs\":{\"start\":883,\"end\":894},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"6b9b7665-ee51-41cd-833b-74b4cbfb3e7e\",\"uuid\":\"e7cc9ac0-1ad5-49fe-954d-ca7fdf01eb92\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":894,\"end\":895}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"1bcfa3af-e348-4ebb-a3fa-8293082128ac\",\"sort\":335,\"type\":\"introduction\",\"label\":\"i.41\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":141,\"uuid\":\"1bcfa3af-e348-4ebb-a3fa-8293082128ac\"},\"content\":[{\"type\":\"text\",\"text\":\"Then \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"Ākāśagarbha\",\"attrs\":{\"start\":5,\"end\":16},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b78f2e81-fa8d-4312-a7a1-86949f89ddfd\",\"uuid\":\"b8dc697e-0ae7-4c9d-8347-1af24c705232\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and others in the assembly describe four benefits that come to a land where \",\"attrs\":{\"start\":16,\"end\":93}},{\"type\":\"text\",\"text\":\"The Sūtra of the Sublime Golden Light \",\"attrs\":{\"start\":93,\"end\":131},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"6753f1d8-116d-4b5b-b19d-744f969f938f\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"is taught.\",\"attrs\":{\"start\":131,\"end\":141}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"57ce4824-11b3-4959-956f-10f080dd65e7\",\"sort\":340,\"type\":\"introductionHeader\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":4,\"start\":0,\"end\":36,\"uuid\":\"f1cc1727-f9aa-4f5f-bef4-9d461874bf0a\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"Chapter 4: The Confession in a Dream\",\"attrs\":{\"start\":0,\"end\":36}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"728aaa0f-6928-41ce-bb23-40ff04093510\",\"sort\":342,\"type\":\"introduction\",\"label\":\"i.42\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":56,\"uuid\":\"728aaa0f-6928-41ce-bb23-40ff04093510\"},\"content\":[{\"type\":\"text\",\"text\":\"This chapter corresponds to chapters 3 and 4 in Toh 557.\",\"attrs\":{\"start\":0,\"end\":56}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"9add9db0-9381-45eb-bbd8-1042e310f2a5\",\"sort\":344,\"type\":\"introduction\",\"label\":\"i.43\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":226,\"uuid\":\"9add9db0-9381-45eb-bbd8-1042e310f2a5\"},\"content\":[{\"type\":\"text\",\"text\":\"In his home in \",\"attrs\":{\"start\":0,\"end\":15}},{\"type\":\"text\",\"text\":\"Rājagṛha\",\"attrs\":{\"start\":15,\"end\":23},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8a64da85-ad7e-4c47-b376-c981f1c2a4b2\",\"uuid\":\"0ecb7764-8bda-49e1-8ff0-0515a53844d6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the bodhisattva \",\"attrs\":{\"start\":23,\"end\":41}},{\"type\":\"text\",\"text\":\"Ruciraketu\",\"attrs\":{\"start\":41,\"end\":51},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"727c3a9f-2dae-46b4-89e7-d5f8bedeb247\",\"uuid\":\"f9f471d5-3f94-4946-b9ff-0f74a79aa00d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" dreams of a \",\"attrs\":{\"start\":51,\"end\":64}},{\"type\":\"text\",\"text\":\"brahmin\",\"attrs\":{\"start\":64,\"end\":71},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41a01c6c-e7cf-4689-b3bb-4cdb181c88b6\",\"uuid\":\"c82c445a-fbe0-46cd-af40-9b8053d22391\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" beating a golden drum from which come a number of verses that he is able to remember. He goes to the Buddha on \",\"attrs\":{\"start\":71,\"end\":183}},{\"type\":\"text\",\"text\":\"Vulture Peak\",\"attrs\":{\"start\":183,\"end\":195},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bbb9e0c6-80e9-4879-ad0d-7c85f53bda98\",\"uuid\":\"38376b07-8b15-42f5-8505-9c0c58b96f55\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" to repeat those verses to him.\",\"attrs\":{\"start\":195,\"end\":226}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"12d1d0f4-5c9e-4e5c-bfb3-fb00d1d79836\",\"sort\":354,\"type\":\"introduction\",\"label\":\"i.44\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":370,\"uuid\":\"12d1d0f4-5c9e-4e5c-bfb3-fb00d1d79836\"},\"content\":[{\"type\":\"text\",\"text\":\"He begins by describing the dream in verse and then repeats the verses he heard, which begin with a prayer for the verses to benefit all beings. Then there are verses for the confession of past bad actions followed by a praise of the Buddha, a prayer that beings be freed from suffering, and finally the dedication of merit so that the reciter will attain enlightenment.\",\"attrs\":{\"start\":0,\"end\":370}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"4e358b8f-b73f-4a19-989b-616732e35671\",\"sort\":355,\"type\":\"introductionHeader\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":4,\"start\":0,\"end\":53,\"uuid\":\"c28f2603-eba2-41b9-8bbf-85d6546d5f41\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"Chapter 5: The End of the Continuum of Creating Karma\",\"attrs\":{\"start\":0,\"end\":53}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"60b84048-d7c4-4eb1-b601-991faed08fa2\",\"sort\":357,\"type\":\"introduction\",\"label\":\"i.45\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1183,\"uuid\":\"60b84048-d7c4-4eb1-b601-991faed08fa2\"},\"content\":[{\"type\":\"text\",\"text\":\"This chapter is absent in Toh 557, and it is primarily composed of a word-for-word repetition, apart from the introduction and conclusion, of \",\"attrs\":{\"start\":0,\"end\":142}},{\"type\":\"text\",\"text\":\"Putting an End to Karmic Obscurations \",\"attrs\":{\"start\":142,\"end\":180},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"b164ba24-1327-4ad3-98b8-62179e74e203\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"(Toh 219). Light rays radiate from the Buddha, bringing happiness to all beings in the lower existences. On seeing that light, \",\"attrs\":{\"start\":180,\"end\":307}},{\"type\":\"text\",\"text\":\"Śakra\",\"attrs\":{\"start\":307,\"end\":312},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"10d9ccbb-4514-4ab1-9c19-578c6d5f6f4c\",\"uuid\":\"62bd799a-9613-44c6-8559-3220cbb28dab\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and other deities come to the Buddha. When the deities are gathered, the Buddha’s principal human disciple, \",\"attrs\":{\"start\":312,\"end\":421}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":421,\"end\":430},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5320ab53-5217-4169-ac5b-a1778de71ca2\",\"uuid\":\"4e1420fc-2301-4ee5-b29b-9c89797455d8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", asks the Buddha how to confess their previous bad actions. The Buddha gives a recitation that should be done three times over the course of the day and three times at night in order for the deities to free themselves of karmic obscuration and to attain whatever is aspired to‍—from rebirth in a good human family or various paradises to the attainment of ultimate wisdom. The Buddha explains that they should also recite the words of rejoicing in the good actions of others, requesting the buddhas in all worlds to teach the Dharma, and requesting them to not pass away. The Buddha states that this creates greater merit than any other kind of Dharma practice and that they should recite a dedication of their merit to the enlightenment of all beings.\",\"attrs\":{\"start\":430,\"end\":1183}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"9b0e1e18-91b3-478e-a03f-740dec76531a\",\"sort\":365,\"type\":\"introduction\",\"label\":\"i.46\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":596,\"uuid\":\"9b0e1e18-91b3-478e-a03f-740dec76531a\"},\"content\":[{\"type\":\"text\",\"text\":\"Then the assembly promises to promulgate this sūtra, and \",\"attrs\":{\"start\":0,\"end\":57}},{\"type\":\"text\",\"text\":\"Śakra\",\"attrs\":{\"start\":57,\"end\":62},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"10d9ccbb-4514-4ab1-9c19-578c6d5f6f4c\",\"uuid\":\"a83622d4-65b1-45c9-90fa-d0fe812eb7c1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" states that this sūtra can bring an end to the obscurations of karma. In response, the Buddha describes a buddha in the distant past named \",\"attrs\":{\"start\":62,\"end\":202}},{\"type\":\"text\",\"text\":\"Great Mass of Light\",\"attrs\":{\"start\":202,\"end\":221},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"3c825a14-1bd0-4316-ab08-ba32150f5d52\",\"uuid\":\"2ed0a685-be45-4958-b890-7e2b2923611b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and a woman named \",\"attrs\":{\"start\":221,\"end\":240}},{\"type\":\"text\",\"text\":\"Gaṅgadevī\",\"attrs\":{\"start\":240,\"end\":249},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9e8dcefa-ed96-45be-8284-93d779464b51\",\"uuid\":\"0c8181f2-d617-4416-8352-185b7ad71b01\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" who received this very teaching from \",\"attrs\":{\"start\":249,\"end\":287}},{\"type\":\"text\",\"text\":\"Great Mass of Light\",\"attrs\":{\"start\":287,\"end\":306},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"3c825a14-1bd0-4316-ab08-ba32150f5d52\",\"uuid\":\"02341c41-368c-4380-ba4b-15faf82aef9d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Through her dedication to it, she was subsequently always reborn as a man until she became a buddha by the name of \",\"attrs\":{\"start\":306,\"end\":423}},{\"type\":\"text\",\"text\":\"Ratnārci\",\"attrs\":{\"start\":423,\"end\":431},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"216fea15-b9dd-4757-8088-4c244086c3b3\",\"uuid\":\"a6c48c3f-de4d-4d95-afc1-5e3a28da9471\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". \",\"attrs\":{\"start\":431,\"end\":433}},{\"type\":\"text\",\"text\":\"Ratnārci\",\"attrs\":{\"start\":433,\"end\":441},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"216fea15-b9dd-4757-8088-4c244086c3b3\",\"uuid\":\"4ef806bf-e660-42c8-af92-aef8c40db17f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" teaches in a realm a vast distance away in the east, in the present time. Any woman who hears the name of this buddha will no longer be reborn as a woman.\",\"attrs\":{\"start\":441,\"end\":596}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"1e4cfe0d-2db8-4fe8-91fe-a33c974ae1cf\",\"sort\":379,\"type\":\"introduction\",\"label\":\"i.47\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":213,\"uuid\":\"1e4cfe0d-2db8-4fe8-91fe-a33c974ae1cf\"},\"content\":[{\"type\":\"text\",\"text\":\"The Buddha then describes the four benefits to a king, the four benefits to his ministers, the four benefits to mendicants, and the four benefits to \",\"attrs\":{\"start\":0,\"end\":149}},{\"type\":\"text\",\"text\":\"brahmins\",\"attrs\":{\"start\":149,\"end\":157},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41a01c6c-e7cf-4689-b3bb-4cdb181c88b6\",\"uuid\":\"ded0e149-109e-4634-8a1b-b0ad487a02d1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" that result from this sūtra being taught in their land.\",\"attrs\":{\"start\":157,\"end\":213}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"3763b076-0861-4941-a583-d0f83fb9e2bc\",\"sort\":383,\"type\":\"introduction\",\"label\":\"i.48\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":167,\"uuid\":\"3763b076-0861-4941-a583-d0f83fb9e2bc\"},\"content\":[{\"type\":\"text\",\"text\":\"Then \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"Śakra\",\"attrs\":{\"start\":5,\"end\":10},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"10d9ccbb-4514-4ab1-9c19-578c6d5f6f4c\",\"uuid\":\"a1535a7b-8d52-4f86-b7c3-2a609cdeb495\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and the others state that the Dharma will last in the world only as long as this sūtra does, and the Buddha concurs and encourages its reading and practice.\",\"attrs\":{\"start\":10,\"end\":167}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"9e42f92f-7f63-45e4-8565-cfde971135cc\",\"sort\":386,\"type\":\"introductionHeader\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":4,\"start\":0,\"end\":41,\"uuid\":\"83726c4e-19a5-4ae9-a9e8-b603295f8968\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"Chapter 6: The Purification of the Bhūmis\",\"attrs\":{\"start\":0,\"end\":41}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"7c9faeb1-6feb-48b5-95ed-52dbd2443c67\",\"sort\":388,\"type\":\"introduction\",\"label\":\"i.49\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":530,\"uuid\":\"7c9faeb1-6feb-48b5-95ed-52dbd2443c67\"},\"content\":[{\"type\":\"text\",\"text\":\"This chapter is absent in Toh 557. It is \",\"attrs\":{\"start\":0,\"end\":41}},{\"type\":\"text\",\"text\":\"The Sūtra of Akṣayamati’s Questions \",\"attrs\":{\"start\":41,\"end\":77},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"1799dfd4-2d67-48d2-87e8-509ca4beb1bc\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"(Toh 89) but without the introduction and with additional verses. The list of \",\"attrs\":{\"start\":77,\"end\":155}},{\"type\":\"text\",\"text\":\"dhāraṇīs\",\"attrs\":{\"start\":155,\"end\":163},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c161a89c-8874-435b-a0cf-5dda3a665750\",\"uuid\":\"1dc2a0b1-b817-4743-af09-a23f7b9df4aa\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", of which only the names are given in that sūtra, are given in full in \",\"attrs\":{\"start\":163,\"end\":235}},{\"type\":\"text\",\"text\":\"The Sūtra of the Sublime Golden Light \",\"attrs\":{\"start\":235,\"end\":273},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"416a29e4-8d20-4562-b35c-388713e693ba\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\"together with their benefits. Also, \",\"attrs\":{\"start\":273,\"end\":309}},{\"type\":\"text\",\"text\":\"Brahmā\",\"attrs\":{\"start\":309,\"end\":315},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"0ea2394f-1cfc-4258-a798-9a6eb4c60b62\",\"uuid\":\"2e3e1e6f-d644-4c7b-9784-227568929f2a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is added as an interlocutor, and there is an extra conclusion following the one given in \",\"attrs\":{\"start\":315,\"end\":405}},{\"type\":\"text\",\"text\":\"The Sūtra of Akṣayamati’s Questions.\",\"attrs\":{\"start\":405,\"end\":441},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"c045dbc6-0ba8-4ea8-af7e-4b5c7d2a13f8\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" In Toh 555, the corresponding chapter is called “The \",\"attrs\":{\"start\":441,\"end\":495}},{\"type\":\"text\",\"text\":\"Dhāraṇīs\",\"attrs\":{\"start\":495,\"end\":503},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c161a89c-8874-435b-a0cf-5dda3a665750\",\"uuid\":\"c272524f-e062-4d60-afbc-3c1d4787915e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of Complete Purification.”\",\"attrs\":{\"start\":503,\"end\":530}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"28364595-2ea3-4b28-b200-a71566854367\",\"sort\":404,\"type\":\"introduction\",\"label\":\"i.50\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":184,\"uuid\":\"28364595-2ea3-4b28-b200-a71566854367\"},\"content\":[{\"type\":\"text\",\"text\":\"In this chapter, \",\"attrs\":{\"start\":0,\"end\":17}},{\"type\":\"text\",\"text\":\"Akṣayamati\",\"attrs\":{\"start\":17,\"end\":27},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"497e05ef-9c9d-4cee-bb86-157997d6046f\",\"uuid\":\"88b933bb-bd1d-4f6e-aa39-2bfc86f58595\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" asks the Buddha what is meant by the term \",\"attrs\":{\"start\":27,\"end\":70}},{\"type\":\"text\",\"text\":\"bodhicitta\",\"attrs\":{\"start\":70,\"end\":80},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":70,\"end\":80,\"uuid\":\"8ecf16d6-3c97-47f4-bdd8-9ac1d4ed66df\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", “the enlightenment mind,” because the mind is not said to be an object of perception in enlightenment.\",\"attrs\":{\"start\":80,\"end\":184}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"e30892c2-f16d-4666-8ed8-e1b9a056fea9\",\"sort\":410,\"type\":\"introduction\",\"label\":\"i.51\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":291,\"uuid\":\"e30892c2-f16d-4666-8ed8-e1b9a056fea9\"},\"content\":[{\"type\":\"text\",\"text\":\"The Buddha states that there is no reality to such designations but there are the ten stages of the development of bodhicitta through the ten \",\"attrs\":{\"start\":0,\"end\":142}},{\"type\":\"text\",\"text\":\"perfections\",\"attrs\":{\"start\":142,\"end\":153},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"6b9b7665-ee51-41cd-833b-74b4cbfb3e7e\",\"uuid\":\"413f2f54-a781-4c47-9e5a-48d2e22edb60\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". The Buddha then describes ten qualities that each of these \",\"attrs\":{\"start\":153,\"end\":214}},{\"type\":\"text\",\"text\":\"perfections\",\"attrs\":{\"start\":214,\"end\":225},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"6b9b7665-ee51-41cd-833b-74b4cbfb3e7e\",\"uuid\":\"65edb2b5-897b-451e-a119-a2ef79e623dd\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" possesses, and he describes what is meant by the term \",\"attrs\":{\"start\":225,\"end\":280}},{\"type\":\"text\",\"text\":\"perfection\",\"attrs\":{\"start\":280,\"end\":290},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":280,\"end\":290,\"uuid\":\"5e26fd02-fe76-4648-8603-5a20f0211adf\",\"type\":\"span\",\"textStyle\":\"distinct\"}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":290,\"end\":291}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"0bd02baf-afec-48d4-8b97-e5ae012bbfdd\",\"sort\":418,\"type\":\"introduction\",\"label\":\"i.52\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":308,\"uuid\":\"0bd02baf-afec-48d4-8b97-e5ae012bbfdd\"},\"content\":[{\"type\":\"text\",\"text\":\"He then describes the omens that precede each of the ten \",\"attrs\":{\"start\":0,\"end\":57}},{\"type\":\"text\",\"text\":\"bhūmis\",\"attrs\":{\"start\":57,\"end\":63},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ff1e1864-2411-4b97-a56d-bfd1b395dc48\",\"uuid\":\"45e4ee09-b7f7-470c-b007-e8dd951c60c7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the reason for the names of each of those \",\"attrs\":{\"start\":63,\"end\":107}},{\"type\":\"text\",\"text\":\"bhūmis\",\"attrs\":{\"start\":107,\"end\":113},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ff1e1864-2411-4b97-a56d-bfd1b395dc48\",\"uuid\":\"94840ade-8d28-49f7-a8e9-888972501f2f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the two kinds of ignorance that obscure each of the ten \",\"attrs\":{\"start\":113,\"end\":171}},{\"type\":\"text\",\"text\":\"bhūmis\",\"attrs\":{\"start\":171,\"end\":177},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ff1e1864-2411-4b97-a56d-bfd1b395dc48\",\"uuid\":\"7031d6cd-2496-484a-aa4f-6fc525b25994\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the perfection attained on each \",\"attrs\":{\"start\":177,\"end\":211}},{\"type\":\"text\",\"text\":\"bhūmi\",\"attrs\":{\"start\":211,\"end\":216},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ff1e1864-2411-4b97-a56d-bfd1b395dc48\",\"uuid\":\"9b158e37-c552-410f-9851-c95ff43912db\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and the \",\"attrs\":{\"start\":216,\"end\":226}},{\"type\":\"text\",\"text\":\"samādhi\",\"attrs\":{\"start\":226,\"end\":233},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5c76a316-06d8-45cc-9036-0b289b210d69\",\"uuid\":\"f5d6f433-68ec-4226-9a29-c6c8ae13e6dd\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" that causes the development of each of the ten developments of bodhicitta.\",\"attrs\":{\"start\":233,\"end\":308}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"e8990f55-12e4-4c4a-9334-f2615a3026b0\",\"sort\":430,\"type\":\"introduction\",\"label\":\"i.53\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":110,\"uuid\":\"e8990f55-12e4-4c4a-9334-f2615a3026b0\"},\"content\":[{\"type\":\"text\",\"text\":\"The Buddha next gives the \",\"attrs\":{\"start\":0,\"end\":26}},{\"type\":\"text\",\"text\":\"dhāraṇī\",\"attrs\":{\"start\":26,\"end\":33},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c161a89c-8874-435b-a0cf-5dda3a665750\",\"uuid\":\"6c81c190-dfc1-4d03-8ae3-eee97b17d3c0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" mantra that is obtained on each \",\"attrs\":{\"start\":33,\"end\":66}},{\"type\":\"text\",\"text\":\"bhūmi\",\"attrs\":{\"start\":66,\"end\":71},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ff1e1864-2411-4b97-a56d-bfd1b395dc48\",\"uuid\":\"33eca964-8ed4-48e9-a43f-373e0ddcebe4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and explains what it protects against.\",\"attrs\":{\"start\":71,\"end\":110}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"3a475952-ead3-425f-a1a3-d85e9bff2ecb\",\"sort\":436,\"type\":\"introduction\",\"label\":\"i.54\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":152,\"uuid\":\"3a475952-ead3-425f-a1a3-d85e9bff2ecb\"},\"content\":[{\"type\":\"text\",\"text\":\"Then the bodhisattva \",\"attrs\":{\"start\":0,\"end\":21}},{\"type\":\"text\",\"text\":\"Unobstructed Appearance of the Light of a Lion’s Ornament\",\"attrs\":{\"start\":21,\"end\":78},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7a0c5ff1-a4b7-4c1d-a4b8-be615a683340\",\"uuid\":\"ea8d6a43-1deb-473b-b39d-cbcadaa9c5cc\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" praises in verse the ultimate nature and relative activity of the Buddha.\",\"attrs\":{\"start\":78,\"end\":152}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"38d31875-0b32-47b3-8d7e-e73b4927ac56\",\"sort\":440,\"type\":\"introduction\",\"label\":\"i.55\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":321,\"uuid\":\"38d31875-0b32-47b3-8d7e-e73b4927ac56\"},\"content\":[{\"type\":\"text\",\"text\":\"After this, the great king of \",\"attrs\":{\"start\":0,\"end\":30}},{\"type\":\"text\",\"text\":\"Brahmā devas\",\"attrs\":{\"start\":30,\"end\":42},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ef9c1ac5-e9a9-4aad-886d-0b0ddf8d8dde\",\"uuid\":\"f8a0fb52-8d0e-42d3-a215-a681b69264b1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" praises \",\"attrs\":{\"start\":42,\"end\":51}},{\"type\":\"text\",\"text\":\"The Sūtra of the Sublime Golden Light,\",\"attrs\":{\"start\":51,\"end\":89},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"e1228d9d-e098-46cc-a76b-0922417ef403\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" and the Buddha states that only those with great merit can hear it and that those who hear it will obtain the \",\"attrs\":{\"start\":89,\"end\":200}},{\"type\":\"text\",\"text\":\"dhāraṇīs\",\"attrs\":{\"start\":200,\"end\":208},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c161a89c-8874-435b-a0cf-5dda3a665750\",\"uuid\":\"32cdc285-192b-468f-8d7b-57ecd624c0a6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and gain the ultimate result. The assembly promises to gather where this sūtra is taught and to aid its teacher.\",\"attrs\":{\"start\":208,\"end\":321}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"b5888bb0-021f-4e01-b463-9419c2063e0f\",\"sort\":447,\"type\":\"introductionHeader\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":4,\"start\":0,\"end\":87,\"uuid\":\"5fc0383f-7004-4129-b03c-51578fa2e0dd\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"Chapter 7: A Praise of All the Realms of the Past, Future, and Present Samyaksaṃbuddhas\",\"attrs\":{\"start\":0,\"end\":87}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"6d6bc914-f6ee-418b-818e-f7e649ee6f81\",\"sort\":449,\"type\":\"introduction\",\"label\":\"i.56\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":203,\"uuid\":\"6d6bc914-f6ee-418b-818e-f7e649ee6f81\"},\"content\":[{\"type\":\"text\",\"text\":\"This is the equivalent of chapter 5 in Toh 557. The Buddha repeats to a goddess a praise of the buddhas in thirty-seven verses, made by a king in the distant past who has now been reborn as that goddess.\",\"attrs\":{\"start\":0,\"end\":203}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"cb2a21a5-81e7-4146-b45a-d0c19aa925d7\",\"sort\":450,\"type\":\"introductionHeader\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":4,\"start\":0,\"end\":36,\"uuid\":\"6d4e9cf8-075e-4feb-9552-c635c43d32ba\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"Chapter 8: The Dhāraṇī Called \",\"attrs\":{\"start\":0,\"end\":30}},{\"type\":\"text\",\"text\":\"Golden\",\"attrs\":{\"start\":30,\"end\":36},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":30,\"end\":36,\"uuid\":\"26c44868-af29-4824-b3ec-754cda517005\",\"type\":\"span\",\"textStyle\":\"distinct\"}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"92f02b26-ad33-46ff-a2c4-f8e946e1f7d8\",\"sort\":453,\"type\":\"introduction\",\"label\":\"i.57\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":34,\"uuid\":\"92f02b26-ad33-46ff-a2c4-f8e946e1f7d8\"},\"content\":[{\"type\":\"text\",\"text\":\"This chapter is absent in Toh 557.\",\"attrs\":{\"start\":0,\"end\":34}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"1717323b-c9ce-4f5b-acdc-5f41171a789a\",\"sort\":455,\"type\":\"introduction\",\"label\":\"i.58\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":515,\"uuid\":\"1717323b-c9ce-4f5b-acdc-5f41171a789a\"},\"content\":[{\"type\":\"text\",\"text\":\"The Buddha tells the bodhisattva \",\"attrs\":{\"start\":0,\"end\":33}},{\"type\":\"text\",\"text\":\"Sukhavihāra\",\"attrs\":{\"start\":33,\"end\":44},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f2049d91-f20d-4a00-a733-972944b9d52f\",\"uuid\":\"da8974d2-0ef8-4f94-be63-baf0f68a3de0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" that in order to make offerings to the buddhas of the past, present, and future, one should have the \",\"attrs\":{\"start\":44,\"end\":146}},{\"type\":\"text\",\"text\":\"dhāraṇī\",\"attrs\":{\"start\":146,\"end\":153},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c161a89c-8874-435b-a0cf-5dda3a665750\",\"uuid\":\"7639463b-0e45-4594-b98f-c54b3b52ecb5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" called \",\"attrs\":{\"start\":153,\"end\":161}},{\"type\":\"text\",\"text\":\"golden\",\"attrs\":{\"start\":161,\"end\":167},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":161,\"end\":167,\"uuid\":\"fc018db9-43db-4bad-b71f-1a7a5ba0a760\",\"type\":\"span\",\"textStyle\":\"distinct\"}}]},{\"type\":\"text\",\"text\":\". Its practitioner should first perform a specific recitation of homage to certain buddhas and bodhisattvas. Then the \",\"attrs\":{\"start\":167,\"end\":285}},{\"type\":\"text\",\"text\":\"dhāraṇī\",\"attrs\":{\"start\":285,\"end\":292},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c161a89c-8874-435b-a0cf-5dda3a665750\",\"uuid\":\"d40c1efb-96a3-4359-abba-183b46757d11\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", which is the mother of all buddhas, will fulfill all wishes and will bring protection. Fifteen days of practice in isolation should accomplish one’s wishes; otherwise, one should continue until one’s wishes are fulfilled.\",\"attrs\":{\"start\":292,\"end\":515}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"e6ece830-1fdd-400a-9fb6-7de22c8013b0\",\"sort\":464,\"type\":\"introductionHeader\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":4,\"start\":0,\"end\":20,\"uuid\":\"9355b1e5-9219-4724-9771-d4847eb8bc85\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"Chapter 9: Emptiness\",\"attrs\":{\"start\":0,\"end\":20}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"a1e53646-6b8b-4293-879f-33e54e04d02c\",\"sort\":466,\"type\":\"introduction\",\"label\":\"i.59\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":47,\"uuid\":\"a1e53646-6b8b-4293-879f-33e54e04d02c\"},\"content\":[{\"type\":\"text\",\"text\":\"This is the equivalent of chapter 6 in Toh 557.\",\"attrs\":{\"start\":0,\"end\":47}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"26513afc-98be-4720-836c-51103a914ce3\",\"sort\":468,\"type\":\"introduction\",\"label\":\"i.60\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":221,\"uuid\":\"26513afc-98be-4720-836c-51103a914ce3\"},\"content\":[{\"type\":\"text\",\"text\":\"The Buddha recites verses that describe emptiness, which, he states, he has taught extensively in other sūtras. He describes how he has practiced the path for a long time and that it is impossible to calculate his wisdom.\",\"attrs\":{\"start\":0,\"end\":221}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"5782c4bc-04bf-4ccb-aa4a-77c01a2aca29\",\"sort\":469,\"type\":\"introductionHeader\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":4,\"start\":0,\"end\":55,\"uuid\":\"8dd7d0cd-d27c-422b-9153-8850fcf6564d\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"Chapter 10: Fulfilling Wishes on the Basis of Emptiness\",\"attrs\":{\"start\":0,\"end\":55}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"8addace1-4fe9-49e9-accf-221ae05f0938\",\"sort\":471,\"type\":\"introduction\",\"label\":\"i.61\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":34,\"uuid\":\"8addace1-4fe9-49e9-accf-221ae05f0938\"},\"content\":[{\"type\":\"text\",\"text\":\"This chapter is absent in Toh 557.\",\"attrs\":{\"start\":0,\"end\":34}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"2cb213e1-7557-4216-9187-b374050347c4\",\"sort\":473,\"type\":\"introduction\",\"label\":\"i.62\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":476,\"uuid\":\"2cb213e1-7557-4216-9187-b374050347c4\"},\"content\":[{\"type\":\"text\",\"text\":\"The goddess \",\"attrs\":{\"start\":0,\"end\":12}},{\"type\":\"text\",\"text\":\"Ratnārcī\",\"attrs\":{\"start\":12,\"end\":20},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b3d5a0e8-79a4-40e4-9579-4fa540e5bf12\",\"uuid\":\"f34b7c2e-f6f9-4fa3-afdd-0367f9319006\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" asks the Buddha about the equanimity of bodhisattva conduct. The Buddha teaches that the dharmadhātu, or \",\"attrs\":{\"start\":20,\"end\":126}},{\"type\":\"text\",\"text\":\"Dharma realm\",\"attrs\":{\"start\":126,\"end\":138},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"0bb9956b-39a4-4769-a0f3-f1ae1a69f236\",\"uuid\":\"4f3e5f20-fafa-4ac5-a259-6870837a2a85\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", is beyond the extremes of existence and nonexistence. He explains that the \",\"attrs\":{\"start\":138,\"end\":215}},{\"type\":\"text\",\"text\":\"five skandhas\",\"attrs\":{\"start\":215,\"end\":228},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9bf44f16-bce8-4db4-bca7-98441af92d5b\",\"uuid\":\"b1b9504d-3d1d-4a19-a052-ce074addf5b2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" are neither separate from nor one with the \",\"attrs\":{\"start\":228,\"end\":272}},{\"type\":\"text\",\"text\":\"Dharma realm\",\"attrs\":{\"start\":272,\"end\":284},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"0bb9956b-39a4-4769-a0f3-f1ae1a69f236\",\"uuid\":\"583db582-be99-47c1-b679-12aa183e3297\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", otherwise everyone would already be enlightened or never be able to attain enlightenment. Therefore, bodhisattva conduct does not eliminate the relative and is never apart from the ultimate.\",\"attrs\":{\"start\":284,\"end\":476}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"9689b8f8-d728-4178-8a60-31acd60d6501\",\"sort\":483,\"type\":\"introduction\",\"label\":\"i.63\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":412,\"uuid\":\"9689b8f8-d728-4178-8a60-31acd60d6501\"},\"content\":[{\"type\":\"text\",\"text\":\"Then \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"Brahmā\",\"attrs\":{\"start\":5,\"end\":11},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"0ea2394f-1cfc-4258-a798-9a6eb4c60b62\",\"uuid\":\"52970ebf-69ec-4011-b40f-4ed43ecb4eb6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" asks \",\"attrs\":{\"start\":11,\"end\":17}},{\"type\":\"text\",\"text\":\"Ratnārcī\",\"attrs\":{\"start\":17,\"end\":25},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b3d5a0e8-79a4-40e4-9579-4fa540e5bf12\",\"uuid\":\"dff9125c-357b-4298-9475-36817ee6ac25\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" how she could possibly accomplish this. She states that if she can do so, then all beings will become golden, and there will be a divine rain of flowers and divine music. This instantly occurs, and \",\"attrs\":{\"start\":25,\"end\":224}},{\"type\":\"text\",\"text\":\"Ratnārcī\",\"attrs\":{\"start\":224,\"end\":232},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b3d5a0e8-79a4-40e4-9579-4fa540e5bf12\",\"uuid\":\"86647c37-5b83-4f15-9ace-6d0489356bec\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s body transforms, becoming identical to that of \",\"attrs\":{\"start\":232,\"end\":282}},{\"type\":\"text\",\"text\":\"Brahmā\",\"attrs\":{\"start\":282,\"end\":288},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"0ea2394f-1cfc-4258-a798-9a6eb4c60b62\",\"uuid\":\"5c845692-ff69-4e25-92d5-b9a697061a3d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". \",\"attrs\":{\"start\":288,\"end\":290}},{\"type\":\"text\",\"text\":\"Ratnārcī\",\"attrs\":{\"start\":290,\"end\":298},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b3d5a0e8-79a4-40e4-9579-4fa540e5bf12\",\"uuid\":\"c9db517f-bcf4-41ae-bdf1-6a74aa9743b7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" describes to \",\"attrs\":{\"start\":298,\"end\":312}},{\"type\":\"text\",\"text\":\"Brahmā\",\"attrs\":{\"start\":312,\"end\":318},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"0ea2394f-1cfc-4258-a798-9a6eb4c60b62\",\"uuid\":\"98bca811-d43a-4fd1-8f2c-5c3e41c23256\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" how to practice bodhisattva conduct while knowing it has no reality, like a magical illusion.\",\"attrs\":{\"start\":318,\"end\":412}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"232eb79c-7b73-4741-89a5-c9ff1be125f1\",\"sort\":497,\"type\":\"introduction\",\"label\":\"i.64\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":255,\"uuid\":\"232eb79c-7b73-4741-89a5-c9ff1be125f1\"},\"content\":[{\"type\":\"text\",\"text\":\"Following this, the Buddha tells \",\"attrs\":{\"start\":0,\"end\":33}},{\"type\":\"text\",\"text\":\"Brahmā\",\"attrs\":{\"start\":33,\"end\":39},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"0ea2394f-1cfc-4258-a798-9a6eb4c60b62\",\"uuid\":\"d86e23ff-ecfd-45de-bc36-f73864998eff\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" to practice as \",\"attrs\":{\"start\":39,\"end\":55}},{\"type\":\"text\",\"text\":\"Ratnārcī\",\"attrs\":{\"start\":55,\"end\":63},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b3d5a0e8-79a4-40e4-9579-4fa540e5bf12\",\"uuid\":\"2d223583-4dd1-4583-8d8c-00e362df35bb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" has. \",\"attrs\":{\"start\":63,\"end\":69}},{\"type\":\"text\",\"text\":\"Brahmā\",\"attrs\":{\"start\":69,\"end\":75},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"0ea2394f-1cfc-4258-a798-9a6eb4c60b62\",\"uuid\":\"e5e10675-6e8d-493b-ae9d-5fa8e8760074\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and his entourage bow down to the now male bodhisattva \",\"attrs\":{\"start\":75,\"end\":131}},{\"type\":\"text\",\"text\":\"Ratnārcī\",\"attrs\":{\"start\":131,\"end\":139},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b3d5a0e8-79a4-40e4-9579-4fa540e5bf12\",\"uuid\":\"9155c8d5-b317-4935-9e98-d9bd5d874db8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". The Buddha prophesies that in the future \",\"attrs\":{\"start\":139,\"end\":182}},{\"type\":\"text\",\"text\":\"Ratnārcī\",\"attrs\":{\"start\":182,\"end\":190},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b3d5a0e8-79a4-40e4-9579-4fa540e5bf12\",\"uuid\":\"682aadfa-c031-4a1b-a963-07c9154ff800\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" will be a buddha named \",\"attrs\":{\"start\":190,\"end\":214}},{\"type\":\"text\",\"text\":\"Essence of Illustrious Precious Radiance\",\"attrs\":{\"start\":214,\"end\":254},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"87dd20a5-cd48-4889-821e-a7e8257b068b\",\"uuid\":\"99404868-a1dd-4383-8cbc-19ec6d368157\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":254,\"end\":255}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"8c9b94c4-485f-4888-a48d-4880d890fdb6\",\"sort\":511,\"type\":\"introduction\",\"label\":\"i.65\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":223,\"uuid\":\"8c9b94c4-485f-4888-a48d-4880d890fdb6\"},\"content\":[{\"type\":\"text\",\"text\":\"Five hundred thousand \",\"attrs\":{\"start\":0,\"end\":22}},{\"type\":\"text\",\"text\":\"bhikṣus\",\"attrs\":{\"start\":22,\"end\":29},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5365d0e6-91d5-4ce8-8796-a14339d6e504\",\"uuid\":\"c8da7f7f-9016-4c37-961a-776d618501e7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in the assembly attain an irreversible state, and the Buddha prophesies that in the distant future they will all become buddhas at the same time, all having the name \",\"attrs\":{\"start\":29,\"end\":196}},{\"type\":\"text\",\"text\":\"King Array of Pure Prayers\",\"attrs\":{\"start\":196,\"end\":222},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"70014dd8-67ec-4be2-9261-1c8857a47732\",\"uuid\":\"c38c4100-ae9d-493c-ab1b-308e6e0bbbbf\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":222,\"end\":223}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"a3ca9a13-eada-4e39-b07c-18ed80b36187\",\"sort\":517,\"type\":\"introduction\",\"label\":\"i.66\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":215,\"uuid\":\"a3ca9a13-eada-4e39-b07c-18ed80b36187\"},\"content\":[{\"type\":\"text\",\"text\":\"The Buddha then tells \",\"attrs\":{\"start\":0,\"end\":22}},{\"type\":\"text\",\"text\":\"Brahmā\",\"attrs\":{\"start\":22,\"end\":28},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"0ea2394f-1cfc-4258-a798-9a6eb4c60b62\",\"uuid\":\"366c89de-d210-404d-8ab6-ac43845115aa\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of the great power of \",\"attrs\":{\"start\":28,\"end\":51}},{\"type\":\"text\",\"text\":\"The Sūtra of the Sublime Golden Light,\",\"attrs\":{\"start\":51,\"end\":89},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"7d35bfa6-7cd2-4aa7-a906-1d993325b858\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" and also that he himself had practiced and taught it in his previous lives, and that if it vanishes so will all other sūtras.\",\"attrs\":{\"start\":89,\"end\":215}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"6f8ea5bf-3292-4bd1-bca1-35f9ac78b3f1\",\"sort\":523,\"type\":\"introduction\",\"label\":\"i.67\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":90,\"uuid\":\"6f8ea5bf-3292-4bd1-bca1-35f9ac78b3f1\"},\"content\":[{\"type\":\"text\",\"text\":\"All the \",\"attrs\":{\"start\":0,\"end\":8}},{\"type\":\"text\",\"text\":\"devas\",\"attrs\":{\"start\":8,\"end\":13},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a09787ca-2952-4bf6-a04c-bde6f4cf3e40\",\"uuid\":\"6d559b61-e586-4351-9e83-e7c400d45dc1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" promise to protect the sūtra, its teachers, and the land where it is taught.\",\"attrs\":{\"start\":13,\"end\":90}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"5c794b83-9fca-4681-94d9-904ddc9a19e4\",\"sort\":526,\"type\":\"introductionHeader\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":4,\"start\":0,\"end\":57,\"uuid\":\"40dab61b-0e57-482e-b9a9-2ec5a17f2111\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"Chapter 11: The Four Mahārājas Look Upon Devas and Humans\",\"attrs\":{\"start\":0,\"end\":57}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"31f91b11-3ccf-43f7-a0f2-80ddd12d56a2\",\"sort\":528,\"type\":\"introduction\",\"label\":\"i.68\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":74,\"uuid\":\"31f91b11-3ccf-43f7-a0f2-80ddd12d56a2\"},\"content\":[{\"type\":\"text\",\"text\":\"This and the following chapter are the equivalent of chapter 7 in Toh 557.\",\"attrs\":{\"start\":0,\"end\":74}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"eb339ccc-8742-4177-aee4-4c9f242876f3\",\"sort\":530,\"type\":\"introduction\",\"label\":\"i.69\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":347,\"uuid\":\"eb339ccc-8742-4177-aee4-4c9f242876f3\"},\"content\":[{\"type\":\"text\",\"text\":\"The \",\"attrs\":{\"start\":0,\"end\":4}},{\"type\":\"text\",\"text\":\"Four Mahārājas\",\"attrs\":{\"start\":4,\"end\":18},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"772224d0-971a-49ab-8f56-49664a2477ad\",\"uuid\":\"9fda38b3-194d-488a-bac8-2f3af7798d11\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the protectors of the world, describe the sūtra as overcoming all calamities and how it benefits them through its being taught. They describe themselves as protectors of the world and promise that they will protect whoever teaches and recites this sūtra and will dispel problems for the king of that country and its population.\",\"attrs\":{\"start\":18,\"end\":347}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"afe39fb6-bea0-46df-920f-c36d49638e42\",\"sort\":533,\"type\":\"introductionHeader\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":4,\"start\":0,\"end\":50,\"uuid\":\"bc6298dc-a523-49af-aa40-42c28e2d4b89\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"Chapter 12: The Four Mahārājas Protecting the Land\",\"attrs\":{\"start\":0,\"end\":50}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"b805045e-88b4-4fef-bbcd-b7759b83c1b9\",\"sort\":535,\"type\":\"introduction\",\"label\":\"i.70\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":418,\"uuid\":\"b805045e-88b4-4fef-bbcd-b7759b83c1b9\"},\"content\":[{\"type\":\"text\",\"text\":\"The \",\"attrs\":{\"start\":0,\"end\":4}},{\"type\":\"text\",\"text\":\"Four Mahārājas\",\"attrs\":{\"start\":4,\"end\":18},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"772224d0-971a-49ab-8f56-49664a2477ad\",\"uuid\":\"c7a4703a-2d89-4f5e-9b73-9c6562f0c19f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and the Buddha describe the miraculous events that occur in the paradises when a king engages in the ritual of venerating the sūtra, and how all buddhas will congratulate him and prophesy his buddhahood. The Mahārājas describe how a king who wishes his realm to prosper and be happy should be devoted to the sūtra, and then they praise the Buddha in verse, and the Buddha praises the sūtra in verse.\",\"attrs\":{\"start\":18,\"end\":418}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"d1d448bb-fa31-4387-b339-c59ab2733684\",\"sort\":538,\"type\":\"introductionHeader\",\"label\":\"\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":4,\"start\":0,\"end\":40,\"uuid\":\"c906d624-9dfa-46b2-bf6b-2d63e6fdac62\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"Chapter 13: The Dhāraṇī of Nonattachment\",\"attrs\":{\"start\":0,\"end\":40}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"302ab528-28e8-4d73-98ed-e10b33a10e91\",\"sort\":540,\"type\":\"introduction\",\"label\":\"i.71\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":34,\"uuid\":\"302ab528-28e8-4d73-98ed-e10b33a10e91\"},\"content\":[{\"type\":\"text\",\"text\":\"This chapter is absent in Toh 557.\",\"attrs\":{\"start\":0,\"end\":34}}]}]}],\"body\":[{\"type\":\"passage\",\"attrs\":{\"uuid\":\"a82df9ea-98c5-4c0e-8420-2d065b03ab43\",\"sort\":910,\"type\":\"translationHeader\",\"label\":null,\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":2,\"start\":0,\"end\":15,\"uuid\":\"ffb9843c-9ab0-4091-81a7-5e44155811b1\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"The Translation\",\"attrs\":{\"start\":0,\"end\":15}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"cc4008dc-58f9-4d41-b3bc-0c91a79c5d55\",\"sort\":911,\"type\":\"translation\",\"label\":\"tr.\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"start\":0,\"end\":25,\"uuid\":\"56e4aaf7-fd50-42c4-b4d6-18dac402ca0c\",\"level\":2,\"class\":\"body-title-honorific\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"5c448014-0e71-4b4a-a10b-f92ba1a8fbbc\"},\"content\":[{\"type\":\"text\",\"text\":\"The Noble Mahāyāna Sūtra \",\"attrs\":{\"start\":0,\"end\":25}}]},{\"type\":\"heading\",\"attrs\":{\"start\":25,\"end\":74,\"uuid\":\"6e58fb40-0c64-44fe-bb46-b1f5c93b0c96\",\"level\":2,\"class\":\"body-title-main\"},\"content\":[{\"typ