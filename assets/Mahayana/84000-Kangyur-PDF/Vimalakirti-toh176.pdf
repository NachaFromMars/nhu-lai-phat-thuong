":{\"start\":803,\"end\":805}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"eaa8c8ea-a497-4170-bf7a-2acba55f1513\",\"sort\":2419,\"type\":\"translation\",\"label\":\"3.18\",\"alignments\":{\"toh176\":{\"folioUuid\":\"00ce652f-87e2-449e-bffa-b1f99ac6f588\",\"toh\":\"toh176\",\"tibetan\":\"བསྟན་པ་འདི་དེ་ལས་ཐོས་ནས་བཅོམ་ལྡན་འདས་དེ་ལ་བདག་གིས་ཇི་སྐད་བཤད། ཇི་སྐད་སྨྲ། ཇི་ལྟར་བགྱི་སྙམ་སྟེ། ཕྱོགས་བཅུ་མུན་པར་གྱུར་ནས་བདག་གིས་ལྷུང་བཟེད་དེ་ཡང་བོར་ཏེ་ཁྱིམ་ནས་སླར་འབྱུང་བར་བགྱིས་ན་ལིད་ཙ་\\nབཱི་དྲི་མ་མེད་པར་གྲགས་པ་བདག་ལ་འདི་སྐད་ཅེས་མཆིའོ། །བཙུན་པ་རབ་འབྱོར་ཡི་གེ་དག་ལ་མ་འཇིགས་པར་ལྷུང་བཟེད་འདི་ལོང་ཤིག །བཙུན་པ་རབ་འབྱོར་འདི་ཇི་སྙམ་དུ་སེམས། གལ་ཏེ་དེ་བཞིན་གཤེགས་པའི་སྤྲུལ་པ་ལ་དེ་སྐད་བྱས་ན་དེ་ཇི་སྐྲག་པར་འགྱུར་རམ་\",\"folioNumber\":187,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":433,\"uuid\":\"eaa8c8ea-a497-4170-bf7a-2acba55f1513\"},\"content\":[{\"type\":\"text\",\"text\":\"“\",\"attrs\":{\"start\":0,\"end\":1}},{\"type\":\"text\",\"text\":\"Lord\",\"attrs\":{\"start\":1,\"end\":5},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41c623b8-3d94-4f8e-b2c5-1d7a5f5af6d3\",\"uuid\":\"12fe53e0-5ee5-44b2-a895-1129887ae8bb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", when I heard these words of the \",\"attrs\":{\"start\":5,\"end\":39}},{\"type\":\"text\",\"text\":\"Licchavi\",\"attrs\":{\"start\":39,\"end\":47},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"33770a73-e8ab-4ffb-9409-eb25bda5915d\",\"uuid\":\"b7462062-8457-4272-bdf7-612a48229a92\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":47,\"end\":48}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":48,\"end\":59},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"2384fb0c-d9b6-4153-aad9-ef72f40de757\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", I wondered what I should say and what I should do, but I was totally in the dark. Leaving the bowl, I was about to leave the house when the \",\"attrs\":{\"start\":59,\"end\":201}},{\"type\":\"text\",\"text\":\"Licchavi\",\"attrs\":{\"start\":201,\"end\":209},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"33770a73-e8ab-4ffb-9409-eb25bda5915d\",\"uuid\":\"efa9bd3e-5323-436c-9316-37568db2c5c0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":209,\"end\":210}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":210,\"end\":221},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"6bf57330-04e2-4715-8fa5-8abad2fd0aca\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" said to me, ‘Reverend \",\"attrs\":{\"start\":221,\"end\":244}},{\"type\":\"text\",\"text\":\"Subhūti\",\"attrs\":{\"start\":244,\"end\":251},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b5412ab5-da28-47a8-aaf4-65be6e28d7d4\",\"uuid\":\"2d3ff083-2906-42d9-b4e3-c0086740a7f8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", do not fear these words, and pick up your bowl. What do you think, reverend \",\"attrs\":{\"start\":251,\"end\":329}},{\"type\":\"text\",\"text\":\"Subhūti\",\"attrs\":{\"start\":329,\"end\":336},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b5412ab5-da28-47a8-aaf4-65be6e28d7d4\",\"uuid\":\"d009647e-90e8-4269-bd6f-6668f9c0b488\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"? If it were an \",\"attrs\":{\"start\":336,\"end\":352}},{\"type\":\"text\",\"text\":\"incarnation\",\"attrs\":{\"start\":352,\"end\":363},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9472c5e-2a0d-4ba9-80dc-8f56944f1752\",\"uuid\":\"8f309be5-3122-4aeb-96f4-e065a3ecef42\",\"toh\":null}},{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"68c435d9-5dbe-459c-bb70-f962271ec774\",\"label\":\"70\",\"uuid\":\"12fa0b5f-e4be-4d4f-ab1a-a62f5bc60e2a\",\"start\":363,\"end\":363,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" created by the \",\"attrs\":{\"start\":363,\"end\":379}},{\"type\":\"text\",\"text\":\"Tathāgata\",\"attrs\":{\"start\":379,\"end\":388},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e708dad0-3dd7-49b0-8de3-b2e34b3f8d08\",\"uuid\":\"2a66abf1-16df-4123-925c-47528c54a3ba\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" who spoke thus to you, would you be afraid?’\",\"attrs\":{\"start\":388,\"end\":433}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"4998f6d8-efb4-4097-9865-6d9a04410028\",\"sort\":2440,\"type\":\"translation\",\"label\":\"3.19\",\"alignments\":{\"toh176\":{\"folioUuid\":\"00ce652f-87e2-449e-bffa-b1f99ac6f588\",\"toh\":\"toh176\",\"tibetan\":\"བདག་གིས་\\nདེ་ལ་རིགས་ཀྱི་བུ་དེ་ལྟ་མ་ཡིན་ནོ་ཞེས་བགྱིས་སོ། །དེས་བདག་ལ་སྨྲས་པ། བཙུན་པ་རབ་འབྱོར་སྒྱུ་མ་སྤྲུལ་པའི་རང་བཞིན་གྱི་ཆོས་ཐམས་ཅད་ལ་སྐྲག་པར་མ་བྱེད་ཅིག །དེ་ཅིའི་ཕྱིར་ཞེ་ན། ཚིག་དེ་དག་ཐམས་ཅད་ཀྱང་དེའི་རང་བཞིན་ཏེ། དེ་ལྟར་མཁས་པ་དག་ཡི་གེ་རྣམས་ལ་[F.187.b]ཡང་མི་ཆགས་ཤིང་དེ་དག་ལ་སྐྲག་པར་མི་བྱེད་པའི་ཕྱིར་རོ། །དེ་ཅིའི་ཕྱིར་ཞེ་ན། ཡི་གེ་དེ་དག་ཐམས་ཅད་ནི་ཡི་གེ་མེད་པ་སྟེ། རྣམ་པར་གྲོལ་བ་ནི་མ་གཏོགས་སོ། །ཆོས་ཐམས་ཅད་ནི་རྣམ་པར་གྲོལ་བའི་མཚན་ཉིད་དོ། །\",\"folioNumber\":187,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":383,\"uuid\":\"4998f6d8-efb4-4097-9865-6d9a04410028\"},\"content\":[{\"type\":\"text\",\"text\":\"“I answered, ‘No indeed, noble sir!’ He then said, ‘Reverend \",\"attrs\":{\"start\":0,\"end\":61}},{\"type\":\"text\",\"text\":\"Subhūti\",\"attrs\":{\"start\":61,\"end\":68},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b5412ab5-da28-47a8-aaf4-65be6e28d7d4\",\"uuid\":\"39be41eb-daeb-48f1-80e9-7e3094db379a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the nature of all things is like illusion, like a magical \",\"attrs\":{\"start\":68,\"end\":128}},{\"type\":\"text\",\"text\":\"incarnation\",\"attrs\":{\"start\":128,\"end\":139},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9472c5e-2a0d-4ba9-80dc-8f56944f1752\",\"uuid\":\"1da44647-12b5-4e81-9c41-522bee5d411a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". So you should not fear them. Why? All words also have that nature, and thus the wise are not attached to words, nor do they fear them. Why? All language does not ultimately exist, except as \",\"attrs\":{\"start\":139,\"end\":331}},{\"type\":\"text\",\"text\":\"liberation\",\"attrs\":{\"start\":331,\"end\":341},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1f6de051-60d0-418f-9255-9634be3f22b8\",\"uuid\":\"6f2b9939-d94f-488f-8d8a-0e1926b38398\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". The nature of all things is \",\"attrs\":{\"start\":341,\"end\":371}},{\"type\":\"text\",\"text\":\"liberation\",\"attrs\":{\"start\":371,\"end\":381},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1f6de051-60d0-418f-9255-9634be3f22b8\",\"uuid\":\"f10ba9ea-122d-4e99-b9a4-57f95802e53e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".’\",\"attrs\":{\"start\":381,\"end\":383},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"59e712e7-4a41-46eb-a0b5-be13fe3cbb56\",\"label\":\"71\",\"uuid\":\"2eea75f4-8d57-4df8-8859-7e9bb72bf0a1\",\"start\":383,\"end\":383,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"d0078cb3-fcd1-44b5-95ef-4026850425c7\",\"sort\":2455,\"type\":\"translation\",\"label\":\"3.20\",\"alignments\":{\"toh176\":{\"folioUuid\":\"6ce1d047-2208-44b6-9281-c15632334a95\",\"toh\":\"toh176\",\"tibetan\":\"བསྟན་པ་འདི་བཤད་པ་ན་ལྷའི་བུ་ཉིས་བརྒྱ་ཆོས་རྣམས་\\nལ་ཆོས་ཀྱི་མིག་རྡུལ་མེད་ཅིང་དྲི་མ་དང་བྲལ་བ་རྣམ་པར་དག་གོ། །ལྷའི་བུ་ལྔ་བརྒྱ་ནི་རྗེས་སུ་འཐུན་པའི་བཟོད་པ་ཐོབ་པར་གྱུར་ཏོ། བདག་ཀྱང་སྤོབས་པ་མ་མཆིས་པར་གྱུར་ནས་དེ་ལ་སླར་ལན་ལྡོན་པའི་རྔོ་མི་ཐོགས་ཏེ། བཅོམ་ལྡན་འདས་དེའི་སླད་དུ་བདག་སྐྱེས་བུ་དམ་པ་དེའི་བྲོ་འདྲི་\\nཞིང་མཆི་བར་མི་སྤྲོའོ། །\",\"folioNumber\":187,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":358,\"uuid\":\"d0078cb3-fcd1-44b5-95ef-4026850425c7\"},\"content\":[{\"type\":\"text\",\"text\":\"“When \",\"attrs\":{\"start\":0,\"end\":6}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":6,\"end\":17},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"798ae4ca-f92b-41ec-9638-f2ebe8ebc465\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" had discoursed in this way, two hundred gods obtained the pure doctrinal vision in regard to all things, without obscurity or defilement, and five hundred gods obtained the conformative tolerance. As for me, I was speechless and unable to respond to him. Therefore, \",\"attrs\":{\"start\":17,\"end\":284}},{\"type\":\"text\",\"text\":\"Lord\",\"attrs\":{\"start\":284,\"end\":288},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41c623b8-3d94-4f8e-b2c5-1d7a5f5af6d3\",\"uuid\":\"5579e281-f6b1-4e65-a124-72f1e26f2ee8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", I am reluctant to go to this good man to inquire about his illness.”\",\"attrs\":{\"start\":288,\"end\":358}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"f6e5557c-4f2c-4b56-a31e-24fc27e9c042\",\"sort\":2461,\"type\":\"translation\",\"label\":\"3.21\",\"alignments\":{\"toh176\":{\"folioUuid\":\"6ce1d047-2208-44b6-9281-c15632334a95\",\"toh\":\"toh176\",\"tibetan\":\"དེ་ནས་བཅོམ་ལྡན་འདས་ཀྱིས་ཚེ་དང་ལྡན་པ་བྱམས་མའི་བུ་གང་པོ་ལ་བཀའ་སྩལ་པ། གང་པོ་ཁྱོད་ལིད་ཙ་བཱི་དྲི་མ་མེད་པར་གྲགས་པའི་ནད་འདྲིར་སོང་ཤིག །གང་པོས་ཀྱང་གསོལ་པ། བཅོམ་ལྡན་འདས་བདག་སྐྱེས་བུ་དམ་པ་དེའི་བྲོ་འདྲི་ཞིང་མཆི་\\nབར་མི་སྤྲོའོ། །དེ་ཅིའི་སླད་དུ་ཞེ་ན། བཅོམ་ལྡན་འདས་བདག་གིས་མངོན་པར་འཚལ་བ་དུས་གཅིག་ན། ནགས་ཚལ་ཆེན་པོའི་ས་ཕྱོགས་ཤིག་ན་ལས་དང་པོ་པའི་དགེ་སློང་དག་ལ་ཆོས་སྟོན་ཅིང་མཆིས་ན་ལིད་ཙ་བཱི་དྲི་མ་མེད་པར་གྲགས་པ་དེར་མཆིས་ནས་བདག་ལ་འདི་སྐད་ཅེས་\\nམཆིའོ། །བཙུན་པ་གང་པོ་སྙོམས་པར་ཞུགས་ཏེ་དགེ་སློང་འདི་དག་གི་སེམས་ལྟོས་ལ་ཆོས་སྟོན་ཅིག །རིན་པོ་ཆེའི་སྣོད་ཆེན་པོར་ཟན་རུལ་མ་བླུགས་ཤིག །དགེ་སློང་འདི་དག་གི་བསམ་པ་ཇི་ལྟ་བུ་ཤེས་པར་གྱིས་ལ་ནོར་བུ་རིན་པོ་ཆེ་བཻ་དཱུརྱ་མཆིང་བུའི་ནོར་བུ་དང་མཚུངས་པར་མ་བྱེད་\\nཅིག །\",\"folioNumber\":187,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":132,\"uuid\":\"abc3ac48-c9ee-43eb-8a4f-51b154c2a85f\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"bfcad945-4e4f-40ad-91df-e110ca3aa513\"},\"content\":[{\"type\":\"text\",\"text\":\"The \",\"attrs\":{\"start\":0,\"end\":4}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":4,\"end\":10},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"103b6606-17f0-4b40-aa7a-72b2ec704e36\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" then said to the venerable \",\"attrs\":{\"start\":10,\"end\":38}},{\"type\":\"text\",\"text\":\"Pūrṇa­maitrāyaṇī­putra\",\"attrs\":{\"start\":38,\"end\":60},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b95c7876-5459-44f6-86d0-2ff03ab2e84d\",\"uuid\":\"7bf77ade-9410-4fa9-ac98-52f847cdab31\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\",\",\"attrs\":{\"start\":60,\"end\":61},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"6feac2bb-f8a9-497b-92f0-9a97a77a1eb5\",\"label\":\"72\",\"uuid\":\"e18c0d97-7fa7-45eb-896d-118ed86aab6a\",\"start\":61,\"end\":61,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" “\",\"attrs\":{\"start\":61,\"end\":63}},{\"type\":\"text\",\"text\":\"Pūrṇa\",\"attrs\":{\"start\":63,\"end\":68},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a952daa2-b766-4a8f-a19e-633af3c5e6e2\",\"uuid\":\"5b81bf68-67ad-4590-bfab-efef09b20b14\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", go to the \",\"attrs\":{\"start\":68,\"end\":80}},{\"type\":\"text\",\"text\":\"Licchavi\",\"attrs\":{\"start\":80,\"end\":88},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"33770a73-e8ab-4ffb-9409-eb25bda5915d\",\"uuid\":\"a9c971f1-e661-4e20-8dd9-22ea339c1e86\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":88,\"end\":89}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":89,\"end\":100},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"6aa04d5d-ad0d-4a9f-b2b2-4f434ed95ea9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" to inquire about his illness.” \",\"attrs\":{\"start\":100,\"end\":132}}]},{\"type\":\"paragraph\",\"attrs\":{\"start\":132,\"end\":652,\"uuid\":\"39b2e902-0cb6-4868-aaa5-adb95d79a8b1\"},\"content\":[{\"type\":\"text\",\"text\":\"Pūrṇa\",\"attrs\":{\"start\":132,\"end\":137},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a952daa2-b766-4a8f-a19e-633af3c5e6e2\",\"uuid\":\"de2a7db9-15a8-4349-acaa-27bda137d85d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" replied, “\",\"attrs\":{\"start\":137,\"end\":148}},{\"type\":\"text\",\"text\":\"Lord\",\"attrs\":{\"start\":148,\"end\":152},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41c623b8-3d94-4f8e-b2c5-1d7a5f5af6d3\",\"uuid\":\"b20719b0-09dd-4dff-9b13-ece3add10d3e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", I am indeed reluctant to go to this good man to inquire about his illness. Why? \",\"attrs\":{\"start\":152,\"end\":234}},{\"type\":\"text\",\"text\":\"Lord\",\"attrs\":{\"start\":234,\"end\":238},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41c623b8-3d94-4f8e-b2c5-1d7a5f5af6d3\",\"uuid\":\"fd2b6727-afbc-422f-abf8-49fe354c09d7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", I remember one day, when I was teaching the \",\"attrs\":{\"start\":238,\"end\":284}},{\"type\":\"text\",\"text\":\"Dharma\",\"attrs\":{\"start\":284,\"end\":290},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c08db6f5-393e-4ec4-bf72-4043e53b3129\",\"uuid\":\"67787233-a7fe-4e39-afa8-2a9fbf6ae8b2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" to some young monks in the great forest, the \",\"attrs\":{\"start\":290,\"end\":336}},{\"type\":\"text\",\"text\":\"Licchavi\",\"attrs\":{\"start\":336,\"end\":344},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"33770a73-e8ab-4ffb-9409-eb25bda5915d\",\"uuid\":\"b15387ac-af97-4cf9-bfb8-5e1fecc54032\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":344,\"end\":345}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":345,\"end\":356},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"2f4d3c06-0f76-4336-845a-ef24f8b18831\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" came there and said to me, ‘Reverend \",\"attrs\":{\"start\":356,\"end\":394}},{\"type\":\"text\",\"text\":\"Pūrṇa\",\"attrs\":{\"start\":394,\"end\":399},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a952daa2-b766-4a8f-a19e-633af3c5e6e2\",\"uuid\":\"2263ac4e-5b01-4fe4-b0dc-c55617993e85\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", first concentrate yourself, regard the minds of these young \",\"attrs\":{\"start\":399,\"end\":461}},{\"type\":\"text\",\"text\":\"bhikṣus\",\"attrs\":{\"start\":461,\"end\":468},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"700a47fd-7018-450b-b636-4ceaea2b8574\",\"uuid\":\"85125ae2-3650-4cf6-921d-9caa2e8c0b96\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and then teach them the \",\"attrs\":{\"start\":468,\"end\":494}},{\"type\":\"text\",\"text\":\"Dharma\",\"attrs\":{\"start\":494,\"end\":500},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c08db6f5-393e-4ec4-bf72-4043e53b3129\",\"uuid\":\"99bd80f1-ae91-4acb-85dc-e0486a6de25a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"! Do not put rotten food into a jeweled bowl! First understand the inclinations of these monks, and do not confuse priceless sapphires with glass beads!\",\"attrs\":{\"start\":500,\"end\":652}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"d069e614-66b0-46dd-bd30-8f29c474bc44\",\"sort\":2493,\"type\":\"translation\",\"label\":\"3.22\",\"alignments\":{\"toh176\":{\"folioUuid\":\"6ce1d047-2208-44b6-9281-c15632334a95\",\"toh\":\"toh176\",\"tibetan\":\"བཙུན་པ་གང་པོ་སེམས་ཅན་གྱི་དབང་པོ་དག་ལ་མ་བརྟགས་པར་ཉི་ཚེ་བའི་དབང་པོ་ཉེ་བར་མ་སྒྲུབ་ཤིག །རྨ་མེད་པ་ལ་རྨ་མ་དབྱུང་ཤིག །ལམ་ཆེན་པོར་འཇུག་པར་འདོད་པ་སྲང་དོག་པར་མ་གཟུད་ཅིག །རྒྱ་མཚོ་ཆེན་པོ་བ་ལང་གི་རྨིག་རྗེས་སུ་མ་བླུགས་ཤིག །རི་རབ་\\nཡུངས་འབྲུའི་ནང་དུ་མ་གཞུག་ཤིག །ཉི་མའི་འོད་སྲིན་བུ་མེ་ཁྱེར་གྱིས་མ་བཟློག་ཤིག །སེང་གེའི་སྒྲ་སྒྲོགས་པར་འདོད་པ་རྣམས་ཝའི་སྒྲ་ལ་མ་གཟུད་ཅིག །\",\"folioNumber\":187,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":517,\"uuid\":\"d069e614-66b0-46dd-bd30-8f29c474bc44\"},\"content\":[{\"type\":\"text\",\"text\":\"“ ‘Reverend \",\"attrs\":{\"start\":0,\"end\":12}},{\"type\":\"text\",\"text\":\"Pūrṇa\",\"attrs\":{\"start\":12,\"end\":17},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a952daa2-b766-4a8f-a19e-633af3c5e6e2\",\"uuid\":\"5161e68f-d26e-4ef0-89e1-a062fb6e4678\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", without examining the spiritual faculties of living beings, do not presume upon the one-sidedness of their faculties; do not wound those who are without wounds; do not impose a narrow path upon those who aspire to a great path; do not try to pour the great ocean into the hoof-print of an ox; do not try to put Mount \",\"attrs\":{\"start\":17,\"end\":336}},{\"type\":\"text\",\"text\":\"Sumeru\",\"attrs\":{\"start\":336,\"end\":342},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"6399a2f2-b35d-4507-a09f-efeccb434a76\",\"uuid\":\"d9e6dd5e-9767-46fd-9cbe-59d7a6e5932f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" into a grain of mustard; do not confuse the brilliance of the sun with the light of a glowworm; and do not expose those who admire the roar of a lion to the howl of a jackal!\",\"attrs\":{\"start\":342,\"end\":517}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"9b136297-2d57-466b-b8ff-f20b22a46b13\",\"sort\":2499,\"type\":\"translation\",\"label\":\"3.23\",\"alignments\":{\"toh176\":{\"folioUuid\":\"6ce1d047-2208-44b6-9281-c15632334a95\",\"toh\":\"toh176\",\"tibetan\":\"བཙུན་པ་གང་པོ་དགེ་སློང་འདི་དག་ཐམས་ཅད་ནི་ཐེག་པ་ཆེན་པོ་ལ་ཡང་དག་པར་ཞུགས་པ་ལས་བྱང་ཆུབ་ཀྱི་སེམས་སྟོར་བ་[F.188.a]ཤ་སྟག་སྟེ། བཙུན་པ་གང་པོ་འདི་དག་ལ་ཉན་ཐོས་ཀྱི་ཐེག་པ་མ་བསྟན་ཅིག །ཉན་ཐོས་ཀྱི་ཐེག་པ་ནི་ཡང་དག་པ་མ་ཡིན་ཏེ། སེམས་ཅན་གྱི་དབང་པོའི་རིམ་པ་ཤེས་པ་ལ་ཉན་ཐོས་འདི་དག་ནི་ཁོ་བོས་དམུས་ལོང་དང་འདྲ་བ་སྙམ་བྱེད་དོ། །\",\"folioNumber\":187,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":350,\"uuid\":\"9b136297-2d57-466b-b8ff-f20b22a46b13\"},\"content\":[{\"type\":\"text\",\"text\":\"“ ‘Reverend \",\"attrs\":{\"start\":0,\"end\":12}},{\"type\":\"text\",\"text\":\"Pūrṇa\",\"attrs\":{\"start\":12,\"end\":17},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a952daa2-b766-4a8f-a19e-633af3c5e6e2\",\"uuid\":\"d2790e82-0f47-4343-a114-dac260201ff3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", all these monks were formerly engaged in the \",\"attrs\":{\"start\":17,\"end\":64}},{\"type\":\"text\",\"text\":\"Mahāyāna\",\"attrs\":{\"start\":64,\"end\":72},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"99607e52-e246-4905-b531-6e6d7ccfd7b7\",\"uuid\":\"0f8d5855-5bc4-4160-82a2-1e52343c7d70\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" but have forgotten the spirit of enlightenment. So do not instruct them in the \",\"attrs\":{\"start\":72,\"end\":152}},{\"type\":\"text\",\"text\":\"Disciple Vehicle\",\"attrs\":{\"start\":152,\"end\":168},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cc35d4b8-9151-485e-9199-cf5d9d646538\",\"uuid\":\"cdb5554b-fbe1-4b78-a2bb-3a6f93058472\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". The \",\"attrs\":{\"start\":168,\"end\":174}},{\"type\":\"text\",\"text\":\"Disciple Vehicle\",\"attrs\":{\"start\":174,\"end\":190},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cc35d4b8-9151-485e-9199-cf5d9d646538\",\"uuid\":\"c6344e76-c36b-4208-a76a-ca8888f5e5f0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is not ultimately valid, and you disciples are like men blind from birth, in regard to recognition of the degrees of the spiritual faculties of living beings.’\",\"attrs\":{\"start\":190,\"end\":350}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"19f31be8-eb4b-4bd7-9610-ea4c37f84de2\",\"sort\":2513,\"type\":\"translation\",\"label\":\"3.24\",\"alignments\":{\"toh176\":{\"folioUuid\":\"b407a734-73e9-497a-8433-c7740e6413e7\",\"toh\":\"toh176\",\"tibetan\":\"དེ་ནས་ལིད་ཙ་བཱི་དྲི་མ་\\nམེད་པར་གྲགས་པ་དེའི་ཚེ་ཇི་ལྟར་དགེ་སློང་དེ་དག་སྔོན་གྱི་གནས་རྣམ་པ་མང་པོ་རྗེས་སུ་དྲན་པར་འགྱུར་བ་དེ་ལྟ་བུའི་ཏིང་ངེ་འཛིན་ལ་སྙོམས་པར་ཞུགས་ནས། དེ་དག་ལ་ཡང་དག་པར་རྫོགས་པའི་བྱང་ཆུབ་ཀྱི་ཕྱིར་སངས་རྒྱས་ལྔ་བརྒྱ་ལ་བསྙེན་བཀུར་བྱས་པའི་དགེ་བའི་རྩ་བ་དང་ལྡན་པ་སྟེ། \\nདེ་དག་གི་བྱང་ཆུབ་ཀྱི་སེམས་དེ་ཡང་མངོན་དུ་གྱུར་ནས་དེ་དག་སྐྱེས་བུ་དམ་པ་དེའི་རྐང་པ་ལ་མགོ་བོས་ཕྱག་འཚལ་ཏེ། ཐལ་མོ་སྦྱར་བར་གྱུར་པ་དང་། དེས་ཡང་དེ་དག་ལ་བླ་ན་མེད་པ་ཡང་དག་པར་རྫོགས་པར་བྱང་ཆུབ་ལས་ཕྱིར་མི་ལྡོག་པར་འགྱུར་བ་དེ་ལྟ་བུའི་ཆོས་བསྟན་ནས། བཅོམ་\\nལྡན་འདས་བདག་གིས་འདི་སྙམ་དུ་བསམས་སོ། །ཉན་ཐོས་ཀྱིས་ཕ་རོལ་གྱི་སེམས་དང་བསམ་པ་མ་བརྟགས་པར་སུ་ལ་ཡང་ཆོས་མི་བསྟན་ཏོ། །དེ་ཅིའི་སླད་དུ་ཞེ་ན། ཉན་ཐོས་ལ་ནི་སེམས་ཅན་ཐམས་ཅད་ཀྱི་དབང་པོ་མཆོག་དང་མཆོག་མ་ལགས་པ་ལ་མཁས་པ་\\nཡང་མ་མཆིས། ཇི་ལྟར་དེ་བཞིན་གཤེགས་པ་དགྲ་བཅོམ་པ་ཡང་དག་པར་རྫོགས་པའི་སངས་རྒྱས་བཞིན་དུ་རྟག་ཏུ་མཉམ་པར་བཞག་པ་ཡང་མ་ལགས་སོ་སྙམ་བགྱིད་དེ། བཅོམ་ལྡན་འདས་དེའི་སླད་དུ་བདག་སྐྱེས་བུ་དམ་པ་དེའི་བྲོ་འདྲི་ཞིང་མཆི་བར་མི་སྤྲོའོ། །\",\"folioNumber\":188,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1014,\"uuid\":\"19f31be8-eb4b-4bd7-9610-ea4c37f84de2\"},\"content\":[{\"type\":\"text\",\"text\":\"“At that moment, the \",\"attrs\":{\"start\":0,\"end\":21}},{\"type\":\"text\",\"text\":\"Licchavi\",\"attrs\":{\"start\":21,\"end\":29},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"33770a73-e8ab-4ffb-9409-eb25bda5915d\",\"uuid\":\"5487eccf-02e8-4ba7-bc5e-5a121a55fcc