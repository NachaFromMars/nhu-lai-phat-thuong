":null}}]},{\"type\":\"text\",\"text\":\" to inquire about his illness.” \",\"attrs\":{\"start\":95,\"end\":127}}]},{\"type\":\"paragraph\",\"attrs\":{\"start\":127,\"end\":1156,\"uuid\":\"f7ec3d9b-2231-4596-8933-97643f3afab3\"},\"content\":[{\"type\":\"text\",\"text\":\"Kātyāyana\",\"attrs\":{\"start\":127,\"end\":136},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8effe26b-2996-454f-98a2-3e0cda7b9569\",\"uuid\":\"f34fc58f-e4a4-4837-bf3e-cc6e6dd35698\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" replied, “\",\"attrs\":{\"start\":136,\"end\":147}},{\"type\":\"text\",\"text\":\"Lord\",\"attrs\":{\"start\":147,\"end\":151},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41c623b8-3d94-4f8e-b2c5-1d7a5f5af6d3\",\"uuid\":\"1cd48dd4-8857-478e-97b9-354b1af79628\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", I am indeed reluctant to go to that good man to inquire about his illness. Why? \",\"attrs\":{\"start\":151,\"end\":233}},{\"type\":\"text\",\"text\":\"Lord\",\"attrs\":{\"start\":233,\"end\":237},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41c623b8-3d94-4f8e-b2c5-1d7a5f5af6d3\",\"uuid\":\"66c1ea39-bba7-4467-a27a-18c3dc275a05\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", I remember one day when, after the \",\"attrs\":{\"start\":237,\"end\":274}},{\"type\":\"text\",\"text\":\"Lord\",\"attrs\":{\"start\":274,\"end\":278},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41c623b8-3d94-4f8e-b2c5-1d7a5f5af6d3\",\"uuid\":\"0296accb-6392-4606-a3ee-e11c8f661497\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" had given some brief instruction to the monks, I was defining the expressions of that discourse by teaching the meaning of impermanence, suffering, selflessness, and peace,\",\"attrs\":{\"start\":278,\"end\":451},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"a286a7b9-bfe8-440c-a525-ffa64e11fe14\",\"label\":\"75\",\"uuid\":\"1a6cacfe-59fd-4595-a3c5-f6