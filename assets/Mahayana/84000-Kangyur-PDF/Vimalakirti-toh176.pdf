36af63-0e0f-42b4-b131-9c3bcf48e8b2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and the ten thousand other \",\"attrs\":{\"start\":298,\"end\":326}},{\"type\":\"text\",\"text\":\"Brahmās\",\"attrs\":{\"start\":326,\"end\":333},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"dec71e18-7976-488d-9b81-73734580c4be\",\"uuid\":\"0f6dc0a1-8675-4fbf-86e1-aaa12af2babe\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" who accompanied him illuminated the place with their radiance and, having bowed their heads at my feet, withdrew to one side and asked me, ‘Reverend \",\"attrs\":{\"start\":333,\"end\":483}},{\"type\":\"text\",\"text\":\"Aniruddha\",\"attrs\":{\"start\":483,\"end\":492},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"16a55775-56db-4c97-b4ea-04f04e755e72\",\"uuid\":\"85b34600-4268-448a-af28-ca6fc6d78577\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", you have been proclaimed by the \",\"attrs\":{\"start\":492,\"end\":526}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":526,\"end\":532},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"4ba45ee2-a00f-4fd2-a63a-3ebf107e95b0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" to be the foremost among those who possess the \",\"attrs\":{\"start\":532,\"end\":580}},{\"type\":\"text\",\"text\":\"divine eye\",\"attrs\":{\"start\":580,\"end\":590},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"75a91ffb-ff79-483c-bf2e-bc68d02dc1e6\",\"uuid\":\"0504081f-ce0a-41cd-ab6e-d8291aa9b76b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". To what distance does the divine vision of the venerable \",\"attrs\":{\"start\":590,\"end\":649}},{\"type\":\"text\",\"text\":\"Aniruddha\",\"attrs\":{\"start\":649,\"end\":658},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"16a55775-56db-4c97-b4ea-04f04e755e72\",\"uuid\":\"3da340be-a31c-4b4c-8b0a-5131b6544b83\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" extend?’ I answered, ‘Friends, I see the entire billion-world galactic universe of the \",\"attrs\":{\"start\":658,\"end\":746}},{\"type\":\"text\",\"text\":\"Lord\",\"attrs\":{\"start\":746,\"end\":750},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41c623b8-3d94-4f8e-b2c5-1d7a5f5af6d3\",\"uuid\":\"d1f4b178-42ed-4af0-a8c6-f6ab22ae8c24\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":750,\"end\":751}},{\"type\":\"text\",\"text\":\"Śākyamuni\",\"attrs\":{\"start\":751,\"end\":760},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4dde3f3a-6487-4806-890b-da311468effb\",\"uuid\":\"dcb0e982-f1bd-433e-97e8-93b3d4a1440d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" just as plainly as a man of ordinary vision sees a myrobalan nut on the palm of his hand.’ When I had said these words, the \",\"attrs\":{\"start\":760,\"end\":885}},{\"type\":\"text\",\"text\":\"Licchavi\",\"attrs\":{\"start\":885,\"end\":893},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"33770a73-e8ab-4ffb-9409-eb25bda5915d\",\"uuid\":\"b2e554df-76f2-44cf-bc31-1e9aa2377379\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":893,\"end\":894}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":894,\"end\":905},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"ac0a28bf-55bf-4ce8-b90b-08d0adfaffec\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" came there and, having bowed his head at my feet, said to me, ‘Reverend \",\"attrs\":{\"start\":905,\"end\":978}},{\"type\":\"text\",\"text\":\"Aniruddha\",\"attrs\":{\"start\":978,\"end\":987},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"16a55775-56db-4c97-b4ea-04f04e755e72\",\"uuid\":\"345159f5-bc3d-40a4-96bc-75db8de946fb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", is your \",\"attrs\":{\"start\":987,\"end\":997}},{\"type\":\"text\",\"text\":\"divine eye\",\"attrs\":{\"start\":997,\"end\":1007},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"75a91ffb-ff79-483c-bf2e-bc68d02dc1e6\",\"uuid\":\"dd32eed8-9908-4817-8254-b16c520716ae\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" compounded in nature? Or is it uncompounded in nature? If it is compounded in nature, it is the same as the \",\"attrs\":{\"start\":1007,\"end\":1116}},{\"type\":\"text\",\"text\":\"superknowledges\",\"attrs\":{\"start\":1116,\"end\":1131},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"6b6440dd-6d95-46dd-9c77-9f9241f4e84a\",\"uuid\":\"617f1675-29d6-4b85-b2f8-48d21cf3eb93\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of the \",\"attrs\":{\"start\":1131,\"end\":1139}},{\"type\":\"text\",\"text\":\"outsiders\",\"attrs\":{\"start\":1139,\"end\":1148},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b121c9a5-7c63-4bc5-be7a-4f7ac29b7113\",\"uuid\":\"3329d678-77db-4211-8dda-aad468eddc17\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". If it is uncompounded in nature, then it is not constructed and, as such, is incapable of seeing.\",\"attrs\":{\"start\":1148,\"end\":1247},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"bd32b3ea-ab29-40eb-b052-8c6ae44e3b69\",\"label\":\"79\",\"uuid\":\"4e98328c-3265-4f08-b40c-6f3f5509ca10\",\"start\":1247,\"end\":1247,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" Then, how do you see, O elder?’\",\"attrs\":{\"start\":1247,\"end\":1279}}]}]}]}]\n"])</script><div hidden id="S:2"><div dir="ltr" data-orientation="horizontal" data-slot="tabs" class="flex flex-col gap-2 px-12 w-full"><div class="sticky top-0.75 -mt-28 z-10 w-full overflow-x-auto text-center"><div role="tablist" aria-orientation="horizontal" data-slot="tabs-list" class="bg-background gap-1 sm:gap-3 h-10 items-center justify-center sm:p-1 w-fit inline-flex" tabindex="-1" data-orientation="horizontal" style="ou