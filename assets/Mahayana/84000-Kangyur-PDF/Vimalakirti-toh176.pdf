"attrs\":{\"glossary\":\"6399a2f2-b35d-4507-a09f-efeccb434a76\",\"uuid\":\"a321728c-67fb-4849-9262-a203f5cba70c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", you are unmoved by honor or scorn. \",\"attrs\":{\"start\":18,\"end\":55}}],\"attrs\":{\"start\":0,\"end\":55,\"uuid\":\"f8062856-c542-4536-bd1d-efa92f06e427\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"You love moral beings and immoral beings equally. \",\"attrs\":{\"start\":55,\"end\":105}}],\"attrs\":{\"start\":55,\"end\":105,\"uuid\":\"8644fab5-0fa3-42fb-8be0-8fd74ea55542\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"Poised in equanimity, your mind is like the sky. \",\"attrs\":{\"start\":105,\"end\":154}}],\"attrs\":{\"start\":105,\"end\":154,\"uuid\":\"36b66a56-7af6-4d34-8cde-49b211e4802b\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"Who would not honor such a precious jewel of a being?\",\"attrs\":{\"start\":154,\"end\":207},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"1b41ff0b-8bb1-46a8-b1cc-5d53e5367d86\",\"label\":\"31\",\"uuid\":\"5c7f8866-8373-4bcc-bd4a-7d3897ffd19c\",\"start\":207,\"end\":207,\"location\":\"end\",\"toh\":null}]}}]}],\"attrs\":{\"start\":154,\"end\":207,\"uuid\":\"11e9d72c-445c-42f9-846c-4ec87ad1be22\"}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"0bee22ea-2d91-4f34-ad93-693fea482d01\",\"sort\":1120,\"type\":\"translation\",\"label\":\"1.24\",\"alignments\":{\"toh176\":{\"folioUuid\":\"8e274345-1a21-4f8b-a352-cfc3fbcfb4fd\",\"toh\":\"toh176\",\"tibetan\":\"ཐུབ་པ་ཆེན་པོ་འཁོར་རྣམས་འདུས་པ་འདི་དག་\\nནི། །ཁྱོད་ཀྱི་ཞལ་དུ་རབ་ཏུ་དད་པའི་ཡིད་ཀྱིས་ལྟ། །ཐམས་ཅད་ཀྱིས་ཀྱང་རྒྱལ་བ་རང་གི་མདུན་གནས་མཐོང་། །དེ་ནི་རྒྱལ་བའི་མ་འདྲེས་སངས་རྒྱས་མཚན་ལགས་སོ། །\",\"folioNumber\":178,\"volumeNumber\":60}}},\"content\":[{\"type\":\"lineGroup\",\"attrs\":{\"start\":0,\"end\":207,\"uuid\":\"744c068d-f56e-4d52-a2a1-390947474081\"},\"content\":[{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"“Great Sage, in all these multitudes gathered here, \",\"attrs\":{\"start\":0,\"end\":52}}],\"attrs\":{\"start\":0,\"end\":52,\"uuid\":\"3bb683f7-de3f-4f68-b166-18d8be28b5ce\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"Who look upon your countenance with hearts sincere in faith, \",\"attrs\":{\"start\":52,\"end\":113}}],\"attrs\":{\"start\":52,\"end\":113,\"uuid\":\"3aa742d5-9cad-4223-abbf-d5377f94e911\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"Each being beholds the Victor, as if just before him. \",\"attrs\":{\"start\":113,\"end\":167}}],\"attrs\":{\"start\":113,\"end\":167,\"uuid\":\"06b9014e-246a-4392-869b-c4911509628b\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"This is a special quality of the \",\"attrs\":{\"start\":167,\"end\":200}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":200,\"end\":206},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"186a4003-ca13-4a39-8965-3e259f14aaa2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":206,\"end\":207},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"441704b0-66bd-4f42-a3cf-babee904075c\",\"label\":\"32\",\"uuid\":\"41d9fa38-3e26-49f6-9427-02d5735a2d65\",\"start\":207,\"end\":207,\"location\":\"end\",\"toh\":null}]}}]}],\"attrs\":{\"start\":167,\"end\":207,\"uuid\":\"dbfb6c93-d775-4996-a462-1d43088bf538\"}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"7b7420f1-6d4d-4b30-b26c-b3fbfc575f5d\",\"sort\":1131,\"type\":\"translation\",\"label\":\"1.25\",\"alignments\":{\"toh176\":{\"folioUuid\":\"8e274345-1a21-4f8b-a352-cfc3fbcfb4fd\",\"toh\":\"toh176\",\"tibetan\":\"བཅོམ་ལྡན་འདས་ཀྱི་གསུང་གཅིག་རབ་ཏུ་ཕྱུང་བ་ཡང་། །འཁོར་རྣམས་ཀྱིས་ནི་གསུང་ལ་ཐ་དད་རྣམ་པར་རིག །\\nའགྲོ་བ་དག་གིས་རང་གི་དོན་བཞིན་རྣམ་རིག་པ། །དེ་ནི་རྒྱལ་བའི་མ་འདྲེས་སངས་རྒྱས་མཚན་ལགས་སོ། །\",\"folioNumber\":178,\"volumeNumber\":60}}},\"content\":[{\"type\":\"lineGroup\",\"attrs\":{\"start\":0,\"end\":207,\"uuid\":\"ff0eabc9-7d98-4631-b715-6e43f1f97da5\"},\"content\":[{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"“Although the \",\"attrs\":{\"start\":0,\"end\":14}},{\"type\":\"text\",\"text\":\"Lord\",\"attrs\":{\"start\":14,\"end\":18},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41c623b8-3d94-4f8e-b2c5-1d7a5f5af6d3\",\"uuid\":\"872d6356-3c7a-4e3a-8068-e496115c591a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" speaks with but one voice, \",\"attrs\":{\"start\":18,\"end\":46}}],\"attrs\":{\"start\":0,\"end\":46,\"uuid\":\"a2c26101-2447-4fb0-9f54-cc5ff19aac30\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"Those present perceive that same voice differently, \",\"attrs\":{\"start\":46,\"end\":98}}],\"attrs\":{\"start\":46,\"end\":98,\"uuid\":\"3b2cd4a6-34ba-4b67-a98c-f43727649c12\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"And each understands in his own language according to his own needs. \",\"attrs\":{\"start\":98,\"end\":167}}],\"attrs\":{\"start\":98,\"end\":167,\"uuid\":\"39a9e3c3-1152-485a-a8db-a11b42b0e464\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"This is a special quality of the \",\"attrs\":{\"start\":167,\"end\":200}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":200,\"end\":206},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"6175fee4-255c-4ae7-97ab-bb4178ef5e9f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":206,\"end\":207},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"3b8c2754-8a34-4703-bb32-eb78b138b554\",\"label\":\"33\",\"uuid\":\"9512a2dd-2d0d-431f-9da6-a0173ec4dfcc\",\"start\":207,\"end\":207,\"location\":\"end\",\"toh\":null}]}}]}],\"attrs\":{\"start\":167,\"end\":207,\"uuid\":\"1cddb0f5-a5b6-4d9e-8b85-ef1ca2eada87\"}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"15632d98-16a4-4cf3-a25c-6d