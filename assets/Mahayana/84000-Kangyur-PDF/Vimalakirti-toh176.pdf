\"text\",\"text\":\".\",\"attrs\":{\"start\":210,\"end\":211}}],\"attrs\":{\"start\":171,\"end\":211,\"uuid\":\"aec2d284-bb75-4c5e-a43a-9aca0d4d0387\"}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"6dd745a7-8044-41db-97bb-7d36c626bd84\",\"sort\":1156,\"type\":\"translation\",\"label\":\"1.27\",\"alignments\":{\"toh176\":{\"folioUuid\":\"8e274345-1a21-4f8b-a352-cfc3fbcfb4fd\",\"toh\":\"toh176\",\"tibetan\":\"སྟོབས་བཅུ་འདྲེན་པའི་རྩལ་མངའ་ཁྱོད་ལ་ཕྱག་འཚལ་ལོ། །འཇིགས་པ་མི་མངའ་འཇིགས་བྲལ་ཁྱོད་ལ་ཕྱག་འཚལ་ལོ། །མ་འདྲེས་པ་ཡི་ཆོས་རྣམས་ངེས་པར་རབ་རྟོགས་པ། །འགྲོ་བ་ཐམས་ཅད་འདྲེན་པ་ཁྱོད་ལ་ཕྱག་འཚལ་ལོ། །\",\"folioNumber\":178,\"volumeNumber\":60}}},\"content\":[{\"type\":\"lineGroup\",\"attrs\":{\"start\":0,\"end\":207,\"uuid\":\"ab689958-beca-43fb-aaf0-92fa7831a258\"},\"content\":[{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"“We bow to you who command the force of leadership and the \",\"attrs\":{\"start\":0,\"end\":59}},{\"type\":\"text\",\"text\":\"ten powers\",\"attrs\":{\"start\":59,\"end\":69},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a72b2685-e31f-4aed-adff-8c13405c1c9f\",\"uuid\":\"9a078e9b-d220-48c0-a19b-defeae00b536\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"! \",\"attrs\":{\"start\":69,\"end\":71}}],\"attrs\":{\"start\":0,\"end\":71,\"uuid\":\"17b49643-f4de-42f0-ad56-9a40ace21f3f\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"We bow to you who are dauntless, knowing no fear! \",\"attrs\":{\"start\":71,\"end\":121}}],\"attrs\":{\"start\":71,\"end\":121,\"uuid\":\"0f6b756a-ebd5-4638-b6a9-dde72c1500bf\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"We bow to you, leader of all living beings, \",\"attrs\":{\"start\":121,\"end\":165}}],\"attrs\":{\"start\":121,\"end\":165,\"uuid\":\"8b55e77b-f508-477a-839b-ec9df30e7333\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"Who fully manifests the special qualities!\",\"attrs\":{\"start\":165,\"end\":207}}],\"attrs\":{\"start\":165,\"end\":207,\"uuid\":\"c8687dd4-92b7-4aff-9f74-018443fd6245\"}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"116bfcc1-a620-4a17-a45b-4a7413f56727\",\"sort\":1166,\"type\":\"translation\",\"label\":\"1.28\",\"alignments\":{\"toh176\":{\"folioUuid\":\"8e274345-1a21-4f8b-a352-cfc3fbcfb4fd\",\"toh\":\"toh176\",\"tibetan\":\"ཀུན་\\nཏུ་སྦྱོར་བའི་བཅིངས་པ་གཅོད་ལ་ཕྱག་འཚལ་ལོ། །ཕ་རོལ་ཕྱིན་ནས་སྐམ་ལ་བཞུགས་ལ་ཕྱག་འཚལ་ལོ། །དུབ་པའི་འགྲོ་བ་སྒྲོལ་བ་ཁྱོད་ལ་ཕྱག་འཚལ་ལོ། །འཁོར་བའི་འགྲོ་བར་མི་གནས་པ་ལ་ཕྱག་འཚལ་ལོ། །\",\"folioNumber\":178,\"volumeNumber\":60}}},\"content\":[{\"type\":\"lineGroup\",\"attrs\":{\"start\":0,\"end\":212,\"uuid\":\"083ea039-bd2c-4c1d-9aa0-8553b598bf68\"},\"content\":[{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"“We bow to you who have cut the bondage of all fetters! \",\"attrs\":{\"start\":0,\"end\":56}}],\"attrs\":{\"start\":0,\"end\":56,\"uuid\":\"d557b1ff-d096-4cf4-8e19-a4a43c30ffce\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"We bow to you who, having gone beyond, stand on firm ground! \",\"attrs\":{\"start\":56,\"end\":117}}],\"attrs\":{\"start\":56,\"end\":117,\"uuid\":\"776330dc-6e3e-4453-adb6-21023c5b1484\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"We bow to you who save the suffering beings! \",\"attrs\":{\"start\":117,\"end\":162}}],\"attrs\":{\"start\":117,\"end\":162,\"uuid\":\"d3380a70-0191-487f-9973-0ccd60a05230\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"We bow to you who do not remain in the migrations!\",\"attrs\":{\"start\":162,\"end\":212}}],\"attrs\":{\"start\":162,\"end\":212,\"uuid\":\"bc9c8e6c-bcba-4463-86d5-ac3fba73b5a9\"}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"880cff62-5d74-4041-ae07-81333d54f45d\",\"sort\":1174,\"type\":\"translation\",\"label\":\"1.29\",\"alignments\":{\"toh176\":{\"folioUuid\":\"8e274345-1a21-4f8b-a352-cfc3fbcfb4fd\",\"toh\":\"toh176\",\"tibetan\":\"སེམས་ཅན་རྣམས་དང་འགྲོ་བར་ཞུགས་ཤིང་ཀུན་འགྲོགས་ཀྱང་། །\\nའགྲོ་བ་ཐམས་ཅད་ལས་ནི་རྣམ་པར་གྲོལ་བའི་ཐུགས། །པད་མ་དག་ནི་ཆུ་སྐྱེས་ཆུ་ཡིས་ཡོང་མི་གོས། །ཐུབ་པའི་པད་མས་སྟོང་པ་ཉིད་ནི་ངེས་པར་བསྒོམས། །\",\"folioNumber\":178,\"volumeNumber\":60}}},\"content\":[{\"type\":\"lineGroup\",\"attrs\":{\"start\":0,\"end\":236,\"uuid\":\"294d71ee-456a-4069-a657-c28744a5b806\"},\"content\":[{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"“You associate with living beings by frequenting their migrations, \",\"attrs\":{\"start\":0,\"end\":67}}],\"attrs\":{\"start\":0,\"end\":67,\"uuid\":\"d796f289-6d69-4b50-8788-342bfd7fdf60\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"Yet your mind is liberated from all migrations. \",\"attrs\":{\"start\":67,\"end\":115}}],\"attrs\":{\"start\":67,\"end\":115,\"uuid\":\"d1d5c419-122e-440f-b2ca-e435058f4860\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"Just as the lotus, born of mud, is not tainted thereby, \",\"attrs\":{\"start\":115,\"end\":171}}],\"attrs\":{\"start\":115,\"end\":171,\"uuid\":\"c126a226-2288-40c5-b398-80fa037a3a75\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"So the lotus of the \",\"attrs\":{\"start\":171,\"end\":191}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":191,\"end\":197},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"ccaa50e3-b739-4f77-ab7c-85bc2bf7ab4a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" preserves the realization of \",\"attrs\":{\"start\":197,\"end\":227}},{\"type\":\"text\",\"text\":\"voidness\",\"attrs\":{\"start\":227,\"end\":235},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e74ef65c-8fc8-4dbf-9bba-7326d6b5d34d\",\"uuid\":\"db6c6524-37bb-407a-bfd1-09cf6fda4c9f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":235,\"end\":236}}],\"attrs\":{\"start\":171,\"end\":236,\"uuid\":\"4365b5e1-e056-4370-9628-87ecbdf36a40\"}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"91c5d4be-a2fd-43d0-8486-0111b590f