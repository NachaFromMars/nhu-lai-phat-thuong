ce\",\"attrs\":{\"glossary\":\"2370c8e3-79cc-4eab-bc82-33939081f558\",\"uuid\":\"ae75bd27-3f77-4a35-8a64-c896cd54e858\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" constitute the “\",\"attrs\":{\"start\":107,\"end\":124}},{\"type\":\"text\",\"text\":\"tathāgata\",\"attrs\":{\"start\":124,\"end\":133},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e708dad0-3dd7-49b0-8de3-b2e34b3f8d08\",\"uuid\":\"8d03bbce-f2ba-44fc-a080-81d2200feac4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"-family” (itself an important tantric concept), and Mahākaśyapa that only those guilty of the \",\"attrs\":{\"start\":133,\"end\":227}},{\"type\":\"text\",\"text\":\"five deadly sins\",\"attrs\":{\"start\":227,\"end\":243},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b3f27308-d8e9-4edd-b1de-2bb77c99ef3a\",\"uuid\":\"7dba63c8-523e-46e4-90c3-7d3ca80a5282\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" can conceive the spirit‌ of \",\"attrs\":{\"start\":243,\"end\":272}},{\"type\":\"text\",\"text\":\"enlightenment\",\"attrs\":{\"start\":272,\"end\":285},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"62f923c5-8dfa-4620-8dec-7bb032231bf7\",\"uuid\":\"fb1dbf30-ebe5-4735-a9fc-83e7ff6fcd92\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"‌. The \",\"attrs\":{\"start\":285,\"end\":292}},{\"type\":\"text\",\"text\":\"Guhyasamāja\",\"attrs\":{\"start\":292,\"end\":303},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"0336d796-c92f-4ee9-b972-f03bbf925cd8\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" (V.4) states: “Even those who have committed great sins, such as the \",\"attrs\":{\"start\":303,\"end\":373}},{\"type\":\"text\",\"text\":\"five deadly sins\",\"attrs\":{\"start\":373,\"end\":389},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b3f27308-d8e9-4edd-b1de-2bb77c99ef3a\",\"uuid\":\"794c1d48-dae9-4124-ae08-89bdf798fb81\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", will succeed on the \",\"attrs\":{\"start\":389,\"end\":411}},{\"type\":\"text\",\"text\":\"buddha\",\"attrs\":{\"start\":411,\"end\":417},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"42ccc9fd-ec30-4b15-a99e-207d67295d4c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"-vehicle, there in the great ocean of the \",\"attrs\":{\"start\":417,\"end\":459}},{\"type\":\"text\",\"text\":\"Mahāyāna\",\"attrs\":{\"start\":459,\"end\":467},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"99607e52-e246-4905-b531-6e6d7ccfd7b7\",\"uuid\":\"f4f7c4d3-94ad-4a35-9ad0-7207abfc971d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"” (\",\"attrs\":{\"start\":467,\"end\":470}},{\"type\":\"text\",\"text\":\"ānantarya­prabhṛtayaḥ mahā­pāpakṛto ’pi ca | siddhyante buddhāydne ’smin mahā­yāna­mahodadhau ||\",\"attrs\":{\"start\":470,\"end\":566},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":470,\"end\":566,\"uuid\":\"52e95a64-1785-4eae-b8e6-b97ca119b710\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"). It then goes on to list in \",\"attrs\":{\"start\":566,\"end\":596}},{\"type\":\"text\",\"text\":\"Vimala­kīrti­nirdeśa\",\"attrs\":{\"start\":596,\"end\":616},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"b692dbed-d38c-4af1-8891-be02128967ac\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" fashion all sorts of terrible crimes of lust and hatred, ending with the phrase that such “a mentally nondualistic, intelligent person’s buddhahood is attained” (\",\"attrs\":{\"start\":616,\"end\":779}},{\"type\":\"text\",\"text\":\"siddhyate tasya buddhatvaṃ nirvi­kalpasya dhīmataḥ ||\",\"attrs\":{\"start\":779,\"end\":832},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":779,\"end\":832,\"uuid\":\"44a73b7a-6daa-43a9-a1bf-82acd92f006f\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\").\",\"attrs\":{\"start\":832,\"end\":834}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"bbba684d-4a0b-4150-aaad-cda81a27a1c7\",\"sort\":9697,\"type\":\"endnotes\",\"label\":\"n.7\",\"alignments\":{},\"references\":[{\"content\":\"$30\",\"label\":\"i.14\",\"sort\":468,\"type\":\"introduction\",\"uuid\":\"42361cd6-1ee2-4db2-a1a4-50323649b665\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-36\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":280,\"uuid\":\"bbba684d-4a0b-4150-aaad-cda81a27a1c7\"},\"content\":[{\"type\":\"text\",\"text\":\"See \",\"attrs\":{\"start\":0,\"end\":4}},{\"type\":\"text\",\"text\":\"7.17\",\"attrs\":{\"start\":4,\"end\":8},\"marks\":[{\"type\":\"internalLink\",\"attrs\":{\"uuid\":\"76d5c5df-5045-4be6-9f2d-c6b0b87a9c6c\",\"href\":\"/entity/passage/de4c718b-7ef9-4aeb-a7b9-3dfcc6776fd5\",\"entity\":\"de4c718b-7ef9-4aeb-a7b9-3dfcc6776fd5\",\"type\":\"passage\",\"toh\":null,\"isSameWork\":true,\"subtype\":\"translation\"}}]},{\"type\":\"text\",\"text\":\". In the tantric male-female symbolism of the \",\"attrs\":{\"start\":8,\"end\":54}},{\"type\":\"text\",\"text\":\"Guhyasamāja\",\"attrs\":{\"start\":54,\"end\":65},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"2d08bd04-9738-4af6-921c-2dcbe3ae9c60\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" and other \",\"attrs\":{\"start\":65,\"end\":76}},{\"type\":\"text\",\"text\":\"tantras\",\"attrs\":{\"start\":76,\"end\":83},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"140c4504-5fe9-4a99-b7e9-b25cb2395c1a\",\"uuid\":\"32f7f04a-99ee-4baf-93f6-4f78069a9da4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the female consort is called the “\",\"attrs\":{\"start\":83,\"end\":119}},{\"type\":\"text\",\"text\":\"Wisdom\",\"attrs\":{\"start\":119,\"end\":125},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"38971298-6f62-48f0-b271-36261568d441\",\"uuid\":\"45c45470-bad6-4bec-b04e-33c8ae93ee3c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"” (\",\"attrs\":{\"start\":125,\"end\":128}},{\"type\":\"text\",\"text\":\"prajña\",\"attrs\":{\"start\":128,\"end\":134},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":128,\"end\":134,\"uuid\":\"92ee6f5d-e509-4db1-b882-8cfddcb540b9\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\") and the male the “Liberative Technique” (\",\"attrs\":{\"start\":134,\"end\":177}},{\"type\":\"text\",\"text\":\"upāya\",\"attrs\":{\"start\":177,\"end\":182},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":177,\"end\":182,\"uuid\":\"a788b1e0-f101-4a98-a69f-a9cd8bd9e32f\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"), and the bell (\",\"attrs\":{\"start\":182,\"end\":199}},{\"type\":\"text\",\"text\":\"ghaṅṭa\",\"attrs\":{\"start\":199,\"end\":205},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":199,\"end\":205,\"uuid\":\"e54f1727-90bd-4f96-9c0a-c4680ed3e531\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\") and diamond-scepter (vajra) also symbolize female and male, respectively.\",\"attrs\":{\"start\":205,\"end\":280}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"d25f6f98-8dab-43d9-8bc6-5666de0eb0fb\",\"sort\":9713,\"type\":\"endnotes\",\"label\":\"n.8\",\"alignments\":{},\"references\":[{\"content\":\"$31\",\"label\":\"i.14\",\"sort\":468,\"type\":\"introduction\",\"uuid\":\"42361cd6-1ee2-4db2-a1a4-50323649b665\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-36\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":153,\"uuid\":\"d25f6f98-8dab-43d9-8bc6-5666de0eb0fb\"},\"content\":[{\"type\":\"text\",\"text\":\"See \",\"attrs\":{\"start\":0,\"end\":4}},{\"type\":\"text\",\"text\":\"5.17\",\"attrs\":{\"start\":4,\"end\":8},\"marks\":[{\"type\":\"internalLink\",\"attrs\":{\"uuid\":\"49b86fad-d489-4009-8436-8af4c935a3a7\",\"href\":\"/entity/passage/190dca87-b1b1-4760-87d1-6bc3e5e09150\",\"entity\":\"190dca87-b1b1-4760-87d1-6bc3e5e09150\",\"type\":\"passage\",\"toh\":null,\"isSameWork\":true,\"subtype\":\"translation\"}}]},{\"type\":\"text\",\"text\":\". This type of yogic power is classified as a lesser attainment (\",\"attrs\":{\"start\":8,\"end\":73}},{\"type\":\"text\",\"text\":\"siddhi\",\"attrs\":{\"start\":73,\"end\":79},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":73,\"end\":79,\"uuid\":\"f2086f25-f788-43dc-8c79-a0d950e12cf7\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"), the superior attainment being buddhahood, in all tantric methodologies.\",\"attrs\":{\"start\":79,\"end\":153}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"97ce0e5c-3f4a-43a3-9706-b27b61480577\",\"sort\":9719,\"type\":\"endnotes\",\"label\":\"n.9\",\"alignments\":{},\"references\":[{\"content\":\"$32\",\"label\":\"i.14\",\"sort\":468,\"type\":\"introduction\",\"uuid\":\"42361cd6-1ee2-4db2-a1a4-50323649b665\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-36\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":380,\"uuid\":\"97ce0e5c-3f4a-43a3-9706-b27b61480577\"},\"content\":[{\"type\":\"text\",\"text\":\"See \",\"attrs\":{\"start\":0,\"end\":4}},{\"type\":\"text\",\"text\":\"6.30\",\"attrs\":{\"start\":4,\"end\":8},\"marks\":[{\"type\":\"internalLink\",\"attrs\":{\"uuid\":\"33e8dc86-173c-452e-97b4-89a1b078c4c5\",\"href\":\"/entity/passage/114b1915-c608-4d3f-91d4-ef439740a452\",\"entity\":\"114b1915-c608-4d3f-91d4-ef439740a452\",\"type\":\"passage\",\"toh\":null,\"isSameWork\":true,\"subtype\":\"translation\"}}]},{\"type\":\"text\",\"text\":\". The \",\"attrs\":{\"start\":8,\"end\":14}},{\"type\":\"text\",\"text\":\"Guhyasamāja\",\"attrs\":{\"start\":14,\"end\":25},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"927948ad-b20c-4f46-8dc2-ac8fb10ecc84\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" elaborates the symbolism of the “Five \",\"attrs\":{\"start\":25,\"end\":64}},{\"type\":\"text\",\"text\":\"Tathāgatas\",\"attrs\":{\"start\":64,\"end\":74},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e708dad0-3dd7-49b0-8de3-b2e34b3f8d08\",\"uuid\":\"f8022573-dd0d-429c-b2ac-bbcc723f6780\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\",” the leaders of the \",\"attrs\":{\"start\":74,\"end\":96}},{\"type\":\"text\",\"text\":\"tathāgata\",\"attrs\":{\"start\":96,\"end\":105},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e708dad0-3dd7-49b0-8de3-b2e34b3f8d08\",\"uuid\":\"7417f64e-f0a5-4091-8461-549b347fefda\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"-families, who are usually called Vairocana, \",\"attrs\":{\"start\":105,\"end\":150}},{\"type\":\"text\",\"text\":\"Amitābha\",\"attrs\":{\"start\":150,\"end\":158},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f4f18382-cdf8-419b-b267-5fcdb5b97804\",\"uuid\":\"4f20b9c5-3bd3-478c-9618-3f638315534a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":158,\"end\":160}},{\"type\":\"text\",\"text\":\"Akṣobhya\",\"attrs\":{\"start\":160,\"end\":168},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"230b32ae-e885-45ea-9324-b646974f8fa5\",\"uuid\":\"96cb7632-baed-4456-98ab-d82f052d3de1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", Ratnasaṃbhava, and Amoghasiddhi, and thus correspond to the \",\"attrs\":{\"start\":168,\"end\":230}},{\"type\":\"text\",\"text\":\"tathāgatas\",\"attrs\":{\"start\":230,\"end\":240},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e708dad0-3dd7-49b0-8de3-b2e34b3f8d08\",\"uuid\":\"28e4c3db-c9e2-4c2a-980a-106a5a5d7af9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" listed by the goddess too closely to be merely coincidentally related. \",\"attrs\":{\"start\":240,\"end\":312}},{\"type\":\"text\",\"text\":\"Tathāgata­guhyaka,\",\"attrs\":{\"start\":312,\"end\":330},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"e0f9513e-4d2a-4cb8-8303-e7fe868641d0\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" further, is a subtitle of the \",\"attrs\":{\"start\":330,\"end\":361}},{\"type\":\"text\",\"text\":\"Guhyasamāja\",\"attrs\":{\"start\":361,\"end\":372},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"8a6940b7-41e5-4f27-87c7-90bf7e47c9f4\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" itself.\",\"attrs\":{\"start\":372,\"end\":380}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"2e7a6186-7277-4c17-9e89-51ea1a7e4397\",\"sort\":9739,\"type\":\"endnotes\",\"label\":\"n.10\",\"alignments\":{},\"references\":[{\"content\":\"$33\",\"label\":\"i.14\",\"sort\":468,\"type\":\"introduction\",\"uuid\":\"42361cd6-1ee2-4db2-a1a4-50323649b665\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-36\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":276,\"uuid\":\"2e7a6186-7277-4c17-9e89-51ea1a7e4397\"},\"content\":[{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":0,\"end\":11},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"72df49a7-bd69-43a4-9517-c56c77029ce6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s special relation to the \",\"attrs\":{\"start\":11,\"end\":38}},{\"type\":\"text\",\"text\":\"Tathāgata\",\"attrs\":{\"start\":38,\"end\":47},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e708dad0-3dd7-49b0-8de3-b2e34b3f8d08\",\"uuid\":\"c28340cf-3a64-42a6-85ff-d38b1ce2f436\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":47,\"end\":48}},{\"type\":\"text\",\"text\":\"Akṣobhya\",\"attrs\":{\"start\":48,\"end\":56},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"230b32ae-e885-45ea-9324-b646974f8fa5\",\"uuid\":\"6325833f-a9ca-4c2e-a471-71d07ba28b89\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (see \",\"attrs\":{\"start\":56,\"end\":62}},{\"type\":\"text\",\"text\":\"11.9\",\"attrs\":{\"start\":62,\"end\":66},\"marks\":[{\"type\":\"internalLink\",\"attrs\":{\"uuid\":\"1513636a-9fec-42bf-ad9a-09e44e21b1a0\",\"href\":\"/entity/passage/834cc36f-0c41-4175-93be-2beb795f1ba7\",\"entity\":\"834cc36f-0c41-4175-93be-2beb795f1ba7\",\"type\":\"passage\",\"toh\":null,\"isSameWork\":true,\"subtype\":\"translation\"}}]},{\"type\":\"text\",\"text\":\") is highly significant in this context, as \",\"attrs\":{\"start\":66,\"end\":110}},{\"type\":\"text\",\"text\":\"Akṣobhya\",\"attrs\":{\"start\":110,\"end\":118},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"230b32ae-e885-45ea-9324-b646974f8fa5\",\"uuid\":\"be68b347-8126-44c2-b3ae-e151e00dece0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is central among the “Five \",\"attrs\":{\"start\":118,\"end\":146}},{\"type\":\"text\",\"text\":\"Tathāgatas\",\"attrs\":{\"start\":146,\"end\":156},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e708dad0-3dd7-49b0-8de3-b2e34b3f8d08\",\"uuid\":\"616c9870-c733-4a4c-a199-eb7d1b0098be\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\",” occupying the heart in the esoteric methodology which locates the five in the five important spots in the human body.\",\"attrs\":{\"start\":156,\"end\":276}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"45312eee-52cc-488c-a67a-6ded82f100a8\",\"sort\":9752,\"type\":\"endnotes\",\"label\":\"n.11\",\"alignments\":{},\"references\":[{\"content\":\"$34\",\"label\":\"i.15\",\"sort\":553,\"type\":\"introduction\",\"uuid\":\"9f59f0bc-5f2a-4092-9528-b3710786c35b\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-37\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":135,\"uuid\":\"45312eee-52cc-488c-a67a-6ded82f100a8\"},\"content\":[{\"type\":\"text\",\"text\":\"Also transliterated Yen Fo-t’iao; his translation, like some of the other early translations, has not survived. See Lamotte p 2 \",\"attrs\":{\"start\":0,\"end\":128}},{\"type\":\"text\",\"text\":\"et seq\",\"attrs\":{\"start\":128,\"end\":134},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":128,\"end\":134,\"uuid\":\"64744595-ea69-4952-bb5c-738bef5c501d\",\"type\":\"span\",\"textStyle\":\"emphasis\"}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":134,\"end\":135}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"000bce1f-49be-4a4e-8ab5-926dd238b12b\",\"sort\":9756,\"type\":\"endnotes\",\"label\":\"n.12\",\"alignments\":{},\"references\":[{\"content\":\"$35\",\"label\":\"i.15\",\"sort\":553,\"type\":\"introduction\",\"uuid\":\"9f59f0bc-5f2a-4092-9528-b3710786c35b\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-37\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":201,\"uuid\":\"000bce1f-49be-4a4e-8ab5-926dd238b12b\"},\"content\":[{\"type\":\"text\",\"text\":\"The other Tibetan translation (or translations) by unknown translators surviving only in some of the fragments found at Dunhuang; these fragments may represent two different versions. See Lamotte p 19.\",\"attrs\":{\"start\":0,\"end\":201}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"046975d3-8a0e-4a4b-9eff-a0965892f948\",\"sort\":9758,\"type\":\"endnotes\",\"label\":\"n.13\",\"alignments\":{},\"references\":[{\"content\":\"$36\",\"label\":\"i.15\",\"sort\":553,\"type\":\"introduction\",\"uuid\":\"9f59f0bc-5f2a-4092-9528-b3710786c35b\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-37\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":17,\"uuid\":\"046975d3-8a0e-4a4b-9eff-a0965892f948\"},\"content\":[{\"type\":\"text\",\"text\":\"See \",\"attrs\":{\"start\":0,\"end\":4}},{\"type\":\"text\",\"text\":\"bibliography\",\"attrs\":{\"start\":4,\"end\":16},\"marks\":[{\"type\":\"internalLink\",\"attrs\":{\"uuid\":\"a6aa4c25-6f66-4c15-9aaa-f29541ab5b19\",\"href\":\"/entity/passage/3bcd73e1-afec-4e2f-9b43-4ca1bc36480a\",\"entity\":\"3bcd73e1-afec-4e2f-9b43-4ca1bc36480a\",\"type\":\"passage\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":16,\"end\":17}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"04455931-6938-4014-b817-b0250d6c2696\",\"sort\":9762,\"type\":\"endnotes\",\"label\":\"n.14\",\"alignments\":{},\"references\":[{\"content\":\"Thus did I hear on a single occasion. The Lord Buddha was in residence in the garden of Āmrapālī, in the city of Vaiśālī, attended by a great gathering. Of bhikṣus there were eight thousand, all arhats. They were free from impurities and afflictions, and all had attained self-mastery. Their minds were entirely liberated by perfect knowledge. They were calm and dignified, like royal elephants. They had accomplished their work, done what they had to do, cast off their burdens, attained their goals, and totally destroyed the bonds of existence. Their true knowledge had made their minds entirely free. They all had attained the utmost perfection of every form of control over their minds.\",\"label\":\"1.2\",\"sort\":618,\"type\":\"translation\",\"uuid\":\"e7af7864-267e-45ba-8701-d0197961a7e8\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-41\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":174,\"uuid\":\"04455931-6938-4014-b817-b0250d6c2696\"},\"content\":[{\"type\":\"text\",\"text\":\"This list of qualities of the \",\"attrs\":{\"start\":0,\"end\":30}},{\"type\":\"text\",\"text\":\"noble disciples\",\"attrs\":{\"start\":30,\"end\":45},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"0f06ed1e-e4b7-40e4-acd7-d58e27e71907\",\"uuid\":\"99aa5a89-9815-4f34-a435-9527bb4f9ddc\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":45,\"end\":47}},{\"type\":\"text\",\"text\":\"āryāśravāka\",\"attrs\":{\"start\":47,\"end\":58},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":47,\"end\":58,\"uuid\":\"8cacc605-1764-473c-99f9-a39447098e72\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\") is absent in the Chinese of K and X. It is, however, frequently found in \",\"attrs\":{\"start\":58,\"end\":133}},{\"type\":\"text\",\"text\":\"Mahāyāna\",\"attrs\":{\"start\":133,\"end\":141},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"99607e52-e246-4905-b531-6e6d7ccfd7b7\",\"uuid\":\"696175da-ea5d-471b-9dfd-29ce71cb6a49\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":141,\"end\":142}},{\"type\":\"text\",\"text\":\"sūtras\",\"attrs\":{\"start\":142,\"end\":148},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c65438ed-99d8-45cc-bc87-72f8f617eea5\",\"uuid\":\"00ba29a1-45ed-4c3d-af88-5f96ea9eea5e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (see Lamotte, p 98, n 2).\",\"attrs\":{\"start\":148,\"end\":174}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"5cb78ab3-7bab-4412-a1ec-7a8642d4b29f\",\"sort\":9772,\"type\":\"endnotes\",\"label\":\"n.15\",\"alignments\":{},\"references\":[{\"content\":\"Of bodhisattvas there were thirty-two thousand, great spiritual heroes who were universally acclaimed. They were dedicated through the penetrating activity of their great superknowledges and were sustained by the grace of the Buddha. Guardians of the city of Dharma, they upheld the true doctrine, and their great teachings resounded like the lion’s roar throughout the ten directions. Without having to be asked, they were the natural spiritual benefactors of all living beings. They maintained unbroken the succession of the Three Jewels, conquering devils and foes and overwhelming all critics.\",\"label\":\"1.3\",\"sort\":637,\"type\":\"translation\",\"uuid\":\"1de2ed05-edeb-43c0-b980-f7c0447fa835\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-42\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":57,\"uuid\":\"5cb78ab3-7bab-4412-a1ec-7a8642d4b29f\"},\"content\":[{\"type\":\"text\",\"text\":\"This phrase is absent in Tib. but is included in K and X.\",\"attrs\":{\"start\":0,\"end\":57}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"fa3bb793-c052-4e95-81be-abd50b798f83\",\"sort\":9774,\"type\":\"endnotes\",\"label\":\"n.16\",\"alignments\":{},\"references\":[{\"content\":\"Their mindfulness, intelligence, realization, meditation, retention, and eloquence all were perfected. They were free of all obscurations and emotional involvements, living in liberation without impediment. They were totally dedicated through the transcendences of generosity; subdued, unwavering, and sincere morality; tolerance; effort; meditation; wisdom; skill in liberative art; commitment; power; and gnosis. They had attained the intuitive tolerance of the ultimate incomprehensibility and unborn nature of all things. They turned the irreversible wheel of the Dharma. They were stamped with the insignia of signlessness.\",\"label\":\"1.4\",\"sort\":655,\"type\":\"translation\",\"uuid\":\"13fb1fb2-3a2e-4282-9042-7bec9f1cf717\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-43\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":109,\"uuid\":\"fa3bb793-c052-4e95-81be-abd50b798f83\"},\"content\":[{\"type\":\"text\",\"text\":\"The ten transcendences (\",\"attrs\":{\"start\":0,\"end\":24}},{\"type\":\"text\",\"text\":\"daśapāramitaḥ\",\"attrs\":{\"start\":24,\"end\":37},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":24,\"end\":37,\"uuid\":\"db4c5baf-3975-4532-8f33-f9c053c295a4\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"), which correspond to the ten stages (\",\"attrs\":{\"start\":37,\"end\":76}},{\"type\":\"text\",\"text\":\"daśabhūmayaḥ\",\"attrs\":{\"start\":76,\"end\":88},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":76,\"end\":88,\"uuid\":\"5f967451-9295-4cd9-be75-9019d02c47dd\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\") of the \",\"attrs\":{\"start\":88,\"end\":97}},{\"type\":\"text\",\"text\":\"bodhisattva\",\"attrs\":{\"start\":97,\"end\":108},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c72eb4f3-700e-454d-996e-5ccdba29e6be\",\"uuid\":\"c6341097-3e81-4b04-aba7-465f8e4f9eaa\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":108,\"end\":109}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"2abcd874-bad4-4693-a4b8-2e715b6893ae\",\"sort\":9782,\"type\":\"endnotes\",\"label\":\"n.17\",\"alignments\":{},\"references\":[{\"content\":\"Their mindfulness, intelligence, realization, meditation, retention, and eloquence all were perfected. They were free of all obscurations and emotional involvements, living in liberation without impediment. They were totally dedicated through the transcendences of generosity; subdued, unwavering, and sincere morality; tolerance; effort; meditation; wisdom; skill in liberative art; commitment; power; and gnosis. They had attained the intuitive tolerance of the ultimate incomprehensibility and unborn nature of all things. They turned the irreversible wheel of the Dharma. They were stamped with the insignia of signlessness.\",\"label\":\"1.4\",\"sort\":655,\"type\":\"translation\",\"uuid\":\"13fb1fb2-3a2e-4282-9042-7bec9f1cf717\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-43\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":231,\"uuid\":\"2abcd874-bad4-4693-a4b8-2e715b6893ae\"},\"content\":[{\"type\":\"text\",\"text\":\"According to the Degé and Stok Palace Kangyurs, which correspond to the Sanskrit text’s \",\"attrs\":{\"start\":0,\"end\":88}},{\"type\":\"text\",\"text\":\"anu­palambhānutpattika­dharma­kṣānti-samanvāgataiḥ.\",\"attrs\":{\"start\":88,\"end\":139},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":88,\"end\":139,\"uuid\":\"60094763-424a-4a13-a32d-65dca4a56fed\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" The Yongle, Lithang, Peking, Narthang, Cone, and Lhasa Kangyurs all omit \",\"attrs\":{\"start\":139,\"end\":213}},{\"type\":\"text\",\"text\":\"dang mi skye ba’i\",\"attrs\":{\"start\":213,\"end\":230},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":213,\"end\":230,\"uuid\":\"80f57043-e443-42dd-9b39-a75fa7ab3848\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":230,\"end\":231}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"d69ff26c-fc62-4d34-8032-002625e1034b\",\"sort\":9788,\"type\":\"endnotes\",\"label\":\"n.18\",\"alignments\":{},\"references\":[{\"content\":\"Their voices were perfect in diction and resonance, and versatile in speaking all languages. They had penetrated the profound principle of relativity and had destroyed the persistence of the instinctual mental habits underlying all convictions concerning finitude and infinitude. They spoke fearlessly, like lions, sounding the thunder of the magnificent teaching. Unequaled, they surpassed all measure. They were the best captains for the voyage of discovery of the treasures of the Dharma, the stores of merit and wisdom.\",\"label\":\"1.6\",\"sort\":705,\"type\":\"translation\",\"uuid\":\"aa43c73f-2bbf-441f-aa80-6e32943a1af3\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-45\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":509,\"uuid\":\"d69ff26c-fc62-4d34-8032-002625e1034b\"},\"content\":[{\"type\":\"text\",\"text\":\"Tib. \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"mtha’ dang mtha’ med par lta ba’i bag chags kyi mtshams sbyor ba kun bcod pa\",\"attrs\":{\"start\":5,\"end\":81},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":5,\"end\":81,\"uuid\":\"a2535103-e14c-488a-8bb9-a48e8c7e30dd\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"; Skt. \",\"attrs\":{\"start\":81,\"end\":88}},{\"type\":\"text\",\"text\":\"antānanta­dṛṣṭi­vāsanābhi­saṃdhi­samucchedaka\",\"attrs\":{\"start\":88,\"end\":133},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":88,\"end\":133,\"uuid\":\"861ae1a0-1d83-417b-8870-9827157fc5cf\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\". “Convictions concerning finitude” refers to two sorts of extremism, absolutism and nihilism, and “convictions concerning infinitude” refers to convictions that hypostatize \",\"attrs\":{\"start\":133,\"end\":307}},{\"type\":\"text\",\"text\":\"voidness\",\"attrs\":{\"start\":307,\"end\":315},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e74ef65c-8fc8-4dbf-9bba-7326d6b5d34d\",\"uuid\":\"81ff3ca9-ecb7-46e5-bed4-64808a9bbe8e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (i.e., infinity, etc.) as a self-existent entity. Thus the \",\"attrs\":{\"start\":315,\"end\":375}},{\"type\":\"text\",\"text\":\"bodhisattvas\",\"attrs\":{\"start\":375,\"end\":387},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c72eb4f3-700e-454d-996e-5ccdba29e6be\",\"uuid\":\"1943e823-121a-49d5-a27c-fa8869d493ec\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" are said here to have realized, even on the subconscious level, both the \",\"attrs\":{\"start\":387,\"end\":461}},{\"type\":\"text\",\"text\":\"voidness\",\"attrs\":{\"start\":461,\"end\":469},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e74ef65c-8fc8-4dbf-9bba-7326d6b5d34d\",\"uuid\":\"5407c5e7-edf5-4b60-b0ee-d854a50f9bb1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of things and the \",\"attrs\":{\"start\":469,\"end\":488}},{\"type\":\"text\",\"text\":\"voidness of voidness\",\"attrs\":{\"start\":488,\"end\":508},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4ee3fa2c-4160-40ac-ad4c-1bf7f218e1ef\",\"uuid\":\"9b0e378f-4bef-4e49-aafb-7c0d9c3c938b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":508,\"end\":509}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"09db4fac-b26a-4270-8fa7-f794bf612776\",\"sort\":9804,\"type\":\"endnotes\",\"label\":\"n.19\",\"alignments\":{},\"references\":[{\"content\":\"These bodhisattvas were named: Samadarśin, Sama­viṣama­darśin, Samādhi­vikurvaṇa­rāja, Dharmeśvara, Dharmaketu, Prabhāketu, Prabhāvyūha, Ratnavyūha, Mahāvyūha, Pratibhāna­kūṭa, Ratnakūṭa, Ratnapāṇi, Ratna­mudrā­hasta, Nityotkṣipta­hasta, Nityotpalakṛta­hasta, Nityotkaṇṭhita, Nitya­prahasita­pramuditendriya, Prāmodyarāja, Devarāja, Praṇidhi­prayāta­prāpta, Prati­saṃvit­praṇāda­prāpta, Gaganagañja, Ratnolkā­dhārin, Ratnavīra, Ratnananda, Ratnaśrī, Indrajāla, Jālinīprabha, Anārambaṇa­dhyāyin, Prajñākūta, Ratnajaha, Mārapramardin, Vidyuddeva, Vikurvaṇarāja, Lakṣaṇa­kūṭa­samatikrānta, Siṃha­ghoṣābhigarjita­śvara, Śaila­śikhara­saṃghaṭṭana­rāja, Gandhahastin, Gaja­gandha­hastin, Satatodyukta, Anikṣiptadhura, Sumati, Sujāta, Padmaśrī­garbha, Padmavyūha, Avalokiteśvara, Mahā­sthāma­prāpta, Brahmajāla, Ratnayaṣṭin, Mārajit, Kṣetralaṃkṛta, Maṇi­ratnacchattra, Suvarnacūḍa, Maṇicūḍa, Maitreya, Mañjuśrī­kumāra­bhūta, and so forth, with the remainder of the thirty-two thousand.\",\"label\":\"1.10\",\"sort\":747,\"type\":\"translation\",\"uuid\":\"7c195da2-ce63-4c41-98fa-17d919984789\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-49\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":450,\"uuid\":\"09db4fac-b26a-4270-8fa7-f794bf612776\"},\"content\":[{\"type\":\"text\",\"text\":\"The list has been revised to ensure that the names match those in the Sanskrit text, although there are a few differences in order and content. For exhaustive references concerning the presence of some of these \",\"attrs\":{\"start\":0,\"end\":211}},{\"type\":\"text\",\"text\":\"bodhisattvas\",\"attrs\":{\"start\":211,\"end\":223},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c72eb4f3-700e-454d-996e-5ccdba29e6be\",\"uuid\":\"592aaa34-0efb-44d6-a884-c19940e5eb44\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in other \",\"attrs\":{\"start\":223,\"end\":233}},{\"type\":\"text\",\"text\":\"Mahāyāna\",\"attrs\":{\"start\":233,\"end\":241},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"99607e52-e246-4905-b531-6e6d7ccfd7b7\",\"uuid\":\"00b7b795-546e-4153-98a0-fb27f5d00a73\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":241,\"end\":242}},{\"type\":\"text\",\"text\":\"sūtras\",\"attrs\":{\"start\":242,\"end\":248},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c65438ed-99d8-45cc-bc87-72f8f617eea5\",\"uuid\":\"84ae0378-b4bb-4a2b-8a7f-b77fc25a23de\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", see Lamotte, pp 100-102, ns. 12-33. The Chinese lists in K and X vary somewhat; see Luk, pp 3-4, for K; and Lamotte, p 102, for X. For information about the more well-known \",\"attrs\":{\"start\":248,\"end\":423}},{\"type\":\"text\",\"text\":\"bodhisattvas\",\"attrs\":{\"start\":423,\"end\":435},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c72eb4f3-700e-454d-996e-5ccdba29e6be\",\"uuid\":\"d614fd35-6b62-49f0-b8b7-15078ec46778\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", see glossary.\",\"attrs\":{\"start\":435,\"end\":450}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"7ad322e9-57b8-4368-a7a2-0697df942e09\",\"sort\":9814,\"type\":\"endnotes\",\"label\":\"n.20\",\"alignments\":{},\"references\":[{\"content\":\"Thereupon, the Licchavi bodhisattva Ratnākara, with five hundred Licchavi youths, each holding a precious parasol made of seven different kinds of jewels, came forth from the city of Vaiśālī and presented himself at the grove of Āmrapālī. Each approached the Buddha, bowed at his feet, circumambulated him clockwise seven times, laid down his precious parasol in offering, and withdrew to one side.\",\"label\":\"1.13\",\"sort\":924,\"type\":\"translation\",\"uuid\":\"a25ce25a-c5b6-415f-9286-dd8caa67cd24\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-52\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":399,\"uuid\":\"7ad322e9-57b8-4368-a7a2-0697df942e09\"},\"content\":[{\"type\":\"text\",\"text\":\"Tib. \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"dkon mchog ’byung gnas\",\"attrs\":{\"start\":5,\"end\":27},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":5,\"end\":27,\"uuid\":\"d38a36a7-00bf-4ac4-9004-772b89c5fe26\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" (lit. “Jewel-Mine”). The Chinese versions give his name as “Jewel-Ray” (\",\"attrs\":{\"start\":27,\"end\":100}},{\"type\":\"text\",\"text\":\"Ratnarāśi\",\"attrs\":{\"start\":100,\"end\":109},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":100,\"end\":109,\"uuid\":\"0ace42ee-6e4a-4079-b0da-c57381ab4ea7\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"), although the Skt. \",\"attrs\":{\"start\":109,\"end\":130}},{\"type\":\"text\",\"text\":\"Ratnākara\",\"attrs\":{\"start\":130,\"end\":139},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":130,\"end\":139,\"uuid\":\"d5017b38-191b-4852-80e7-79fb88183cb6\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2f400df3-fb3c-4bd3-85ce-4b223afd1aad\",\"uuid\":\"523699c6-fe3e-4e57-8057-43ea825cb5c9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is supported by his appearance in a number of other \",\"attrs\":{\"start\":139,\"end\":192}},{\"type\":\"text\",\"text\":\"Mahāyāna\",\"attrs\":{\"start\":192,\"end\":200},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"99607e52-e246-4905-b531-6e6d7ccfd7b7\",\"uuid\":\"81a1d57c-848a-46c7-87b1-f13d5cce9a0b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":200,\"end\":201}},{\"type\":\"text\",\"text\":\"sūtras\",\"attrs\":{\"start\":201,\"end\":207},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c65438ed-99d8-45cc-bc87-72f8f617eea5\",\"uuid\":\"794a760e-63e7-49f1-8e60-98c3ac36fcc4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", where he is also identified as a \",\"attrs\":{\"start\":207,\"end\":242}},{\"type\":\"text\",\"text\":\"Licchavi\",\"attrs\":{\"start\":242,\"end\":250},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"33770a73-e8ab-4ffb-9409-eb25bda5915d\",\"uuid\":\"3a20287f-798e-4f0b-83ff-b5cf8b86e91b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", a merchant’s son, and a great \",\"attrs\":{\"start\":250,\"end\":282}},{\"type\":\"text\",\"text\":\"bodhisattva\",\"attrs\":{\"start\":282,\"end\":293},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c72eb4f3-700e-454d-996e-5ccdba29e6be\",\"uuid\":\"7d914c63-adc2-4cc1-bcdb-812346c40b52\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of the tenth stage, as well as by the Sanskrit manuscript. For full references, see Lamotte, p 103, n 38.\",\"attrs\":{\"start\":293,\"end\":399}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"775bac5e-4a34-4441-b430-d2d60db94baf\",\"sort\":9830,\"type\":\"endnotes\",\"label\":\"n.21\",\"alignments\":{},\"references\":[{\"content\":\"Thereupon, the Licchavi bodhisattva Ratnākara, with five hundred Licchavi youths, each holding a precious parasol made of seven different kinds of jewels, came forth from the city of Vaiśālī and presented himself at the grove of Āmrapālī. Each approached the Buddha, bowed at his feet, circumambulated him clockwise seven times, laid down his precious parasol in offering, and withdrew to one side.\",\"label\":\"1.13\",\"sort\":924,\"type\":\"translation\",\"uuid\":\"a25ce25a-c5b6-415f-9286-dd8caa67cd24\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-52\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":125,\"uuid\":\"775bac5e-4a34-4441-b430-d2d60db94baf\"},\"content\":[{\"type\":\"text\",\"text\":\"The jewels were gold, silver, pearl, sapphire, ruby, emerald, and diamond, although various sources alter this list slightly.\",\"attrs\":{\"start\":0,\"end\":125}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"5f2b46b6-8f0f-4728-8dd0-cf909beb8bf4\",\"sort\":9832,\"type\":\"endnotes\",\"label\":\"n.22\",\"alignments\":{},\"references\":[{\"content\":\"$37\",\"label\":\"1.14\",\"sort\":946,\"type\":\"translation\",\"uuid\":\"52e6b12f-6803-4c92-bddc-d4a7b9a8feed\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-53\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":398,\"uuid\":\"5f2b46b6-8f0f-4728-8dd0-cf909beb8bf4\"},\"content\":[{\"type\":\"text\",\"text\":\"Skt. \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"tri­sāhasra­mahā­sāhasra­loka­dhātu\",\"attrs\":{\"start\":5,\"end\":40},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":5,\"end\":40,\"uuid\":\"06e9d786-507a-4077-8133-dc8ffc6e3d9c\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\". The term “\",\"attrs\":{\"start\":40,\"end\":52}},{\"type\":\"text\",\"text\":\"galaxy\",\"attrs\":{\"start\":52,\"end\":58},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b5e7eaef-2698-4621-9922-144a0ad94264\",\"uuid\":\"f309dd7b-de25-4680-8209-97d058aadfc2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"” was chosen to evoke the sense of inconceivable scope intended by the original Skt. term, as such cosmological terms were never aimed at material precision, but rather at triggering an imaginative vision of inconceivable cosmic immensity. I have modified the following catalogue of objects and places to conform to a more modern cosmology.\",\"attrs\":{\"start\":58,\"end\":398}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"2279b6bc-516e-4a39-b3df-dda3ce1e1fbd\",\"sort\":9838,\"type\":\"endnotes\",\"label\":\"n.23\",\"alignments\":{},\"references\":[{\"content\":\"$38\",\"label\":\"1.14\",\"sort\":946,\"type\":\"translation\",\"uuid\":\"52e6b12f-6803-4c92-bddc-d4a7b9a8feed\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-53\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":381,\"uuid\":\"2279b6bc-516e-4a39-b3df-dda3ce1e1fbd\"},\"content\":[{\"type\":\"text\",\"text\":\"This list of mountains, according to Lamotte (p 104, n 41), occurs in other \",\"attrs\":{\"start\":0,\"end\":76}},{\"type\":\"text\",\"text\":\"Mahāyāna\",\"attrs\":{\"start\":76,\"end\":84},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"99607e52-e246-4905-b531-6e6d7ccfd7b7\",\"uuid\":\"bc08b988-a54b-4b72-8f37-5bcc9765dc43\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":84,\"end\":85}},{\"type\":\"text\",\"text\":\"sūtras\",\"attrs\":{\"start\":85,\"end\":91},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c65438ed-99d8-45cc-bc87-72f8f617eea5\",\"uuid\":\"9e0b05d1-75fa-46b8-b0c3-83d0157b30cf\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" but does not correspond to usual Buddhist cosmology, except for the fact that \",\"attrs\":{\"start\":91,\"end\":170}},{\"type\":\"text\",\"text\":\"Sumeru\",\"attrs\":{\"start\":170,\"end\":176},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"6399a2f2-b35d-4507-a09f-efeccb434a76\",\"uuid\":\"4fdcc9b1-b917-4b4a-b684-364ffabd9693\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", mentioned first, is in the center (of each world) and Mount \",\"attrs\":{\"start\":176,\"end\":238}},{\"type\":\"text\",\"text\":\"Cakravāḍa\",\"attrs\":{\"start\":238,\"end\":247},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7c4012a3-9741-43c6-8bcc-3e5bf7439e6f\",\"uuid\":\"db51089f-d986-4f6c-b26c-9cfdeacf9d7d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", actually a mountain range, is mentioned and surrounds each world of four continents. This list is first in the order of the Tibetan.\",\"attrs\":{\"start\":247,\"end\":381}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"eacae560-a60b-4cc5-a4fb-db45da1c3b73\",\"sort\":9848,\"type\":\"endnotes\",\"label\":\"n.24\",\"alignments\":{},\"references\":[{\"content\":\"“Pure are your eyes, broad and beautiful, like the petals of a blue lotus. Pure is your thought, having discovered the supreme transcendence of all trances. Immeasurable is the ocean of your virtues, the accumulation of your good deeds. You affirm the path of peace. O Great Ascetic, obeisance to you!\",\"label\":\"1.16\",\"sort\":1014,\"type\":\"translation\",\"uuid\":\"feb3cc34-8b3e-4e33-b261-f5a6d59982c3\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-55\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":442,\"uuid\":\"eacae560-a60b-4cc5-a4fb-db45da1c3b73\"},\"content\":[{\"type\":\"text\",\"text\":\"Tib. \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"zhi gnas pha rol phyin mchog brnyes\",\"attrs\":{\"start\":5,\"end\":40},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":5,\"end\":40,\"uuid\":\"618c9c7a-1b67-4fff-9fe5-16610525f817\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"; Skt. \",\"attrs\":{\"start\":40,\"end\":47}},{\"type\":\"text\",\"text\":\"śamathā­pāramitāgraprāpta\",\"attrs\":{\"start\":47,\"end\":72},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":47,\"end\":72,\"uuid\":\"1b8bd840-f347-4930-9647-0b28d27724df\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\". \",\"attrs\":{\"start\":72,\"end\":74}},{\"type\":\"text\",\"text\":\"Śamathā\",\"attrs\":{\"start\":74,\"end\":81},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":74,\"end\":81,\"uuid\":\"77602a8b-24c3-4384-bcc2-d2f67e7ff30b\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" can be adequately rendered “\",\"attrs\":{\"start\":81,\"end\":110}},{\"type\":\"text\",\"text\":\"mental quiescence\",\"attrs\":{\"start\":110,\"end\":127},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5e339443-19eb-4ac1-8ec2-9c364443dd1c\",\"uuid\":\"2daf4b00-36ca-47a0-a891-db3b22ef1484\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"” when it refers in general to one of the two main types of \",\"attrs\":{\"start\":127,\"end\":187}},{\"type\":\"text\",\"text\":\"Mahāyāna\",\"attrs\":{\"start\":187,\"end\":195},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"99607e52-e246-4905-b531-6e6d7ccfd7b7\",\"uuid\":\"18c67bdc-22d0-468a-a3fe-3dc850c46402\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":195,\"end\":196}},{\"type\":\"text\",\"text\":\"meditation\",\"attrs\":{\"start\":196,\"end\":206},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"72ea6449-0c42-401c-bff0-be87bffdfd07\",\"uuid\":\"de3103cb-76f7-4e70-a6e9-35cd5866c021\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"; the other is “\",\"attrs\":{\"start\":206,\"end\":222}},{\"type\":\"text\",\"text\":\"transcendental analysis\",\"attrs\":{\"start\":222,\"end\":245},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"6cf08752-1b1f-4a66-a9c7-a593246c380d\",\"uuid\":\"7b413eb2-1bba-42da-a2e1-b2bf0995e5e5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"” or “analytic insight” (\",\"attrs\":{\"start\":245,\"end\":270}},{\"type\":\"text\",\"text\":\"vipaśyana\",\"attrs\":{\"start\":270,\"end\":279},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":270,\"end\":279,\"uuid\":\"29683831-8718-4628-8715-c86d9512403e\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"). In this verse, however, \",\"attrs\":{\"start\":279,\"end\":306}},{\"type\":\"text\",\"text\":\"Ratnākara\",\"attrs\":{\"start\":306,\"end\":315},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2f400df3-fb3c-4bd3-85ce-4b223afd1aad\",\"uuid\":\"73004b0a-3a75-42f7-aba2-85549d22bd32\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" refers to it in its aspect of final attainment; hence “trance” best conveys the sense of extreme one-pointed fixation of mind.\",\"attrs\":{\"start\":315,\"end\":442}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"c5a85dc7-e629-473b-9696-529e0c80500e\",\"sort\":9868,\"type\":\"endnotes\",\"label\":\"n.25\",\"alignments\":{},\"references\":[{\"content\":\"“Leader, bull of men, we behold the revelation of your miracle. The superb and radiant fields of the sugatas appear before us, And your extensive spiritual teachings that lead to immortality Make themselves heard throughout the whole reach of space.\",\"label\":\"1.17\",\"sort\":1023,\"type\":\"translation\",\"uuid\":\"4886cae5-ff59-491b-9f9a-92c369997e94\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-56\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":186,\"uuid\":\"c5a85dc7-e629-473b-9696-529e0c80500e\"},\"content\":[{\"type\":\"text\",\"text\":\"Tib. \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"skyes bu’i khyu mchog\",\"attrs\":{\"start\":5,\"end\":26},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":5,\"end\":26,\"uuid\":\"bcbcdecc-dd75-48bc-8c7e-02ac35ad2f03\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"; Skt. \",\"attrs\":{\"start\":26,\"end\":33}},{\"type\":\"text\",\"text\":\"puruṣarṣabha\",\"attrs\":{\"start\":33,\"end\":45},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":33,\"end\":45,\"uuid\":\"e5c6ae9f-082a-4317-9fd1-35f65283d23b\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\". This common epithet of the \",\"attrs\":{\"start\":45,\"end\":74}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":74,\"end\":80},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"fc557e2f-7cb9-4f33-b849-9c061a3e294f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" contains the simile comparing him to the chief bull of a herd of cattle because of his power and majesty.\",\"attrs\":{\"start\":80,\"end\":186}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"edcd3498-8471-4594-95e7-4d1e922302f1\",\"sort\":9876,\"type\":\"endnotes\",\"label\":\"n.26\",\"alignments\":{},\"references\":[{\"content\":\"“Leader, bull of men, we behold the revelation of your miracle. The superb and radiant fields of the sugatas appear before us, And your extensive spiritual teachings that lead to immortality Make themselves heard throughout the whole reach of space.\",\"label\":\"1.17\",\"sort\":1023,\"type\":\"translation\",\"uuid\":\"4886cae5-ff59-491b-9f9a-92c369997e94\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-56\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":181,\"uuid\":\"edcd3498-8471-4594-95e7-4d1e922302f1\"},\"content\":[{\"type\":\"text\",\"text\":\"Tib. \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"’chi med ’gro\",\"attrs\":{\"start\":5,\"end\":18},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":5,\"end\":18,\"uuid\":\"2eb740e2-0bc7-4635-8561-5abcd3dabb90\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"; Skt. \",\"attrs\":{\"start\":18,\"end\":25}},{\"type\":\"text\",\"text\":\"amṛtaga\",\"attrs\":{\"start\":25,\"end\":32},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":25,\"end\":32,\"uuid\":\"fa4915a3-b31c-4202-98f9-f69094bb7ff2\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" (lit. “goes to deathlessness”). The \",\"attrs\":{\"start\":32,\"end\":69}},{\"type\":\"text\",\"text\":\"buddhas\",\"attrs\":{\"start\":69,\"end\":76},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"8c3a111f-4db4-48a1-85c5-b98f7cb393ec\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’ teachings lead to \",\"attrs\":{\"start\":76,\"end\":96}},{\"type\":\"text\",\"text\":\"nirvāṇa\",\"attrs\":{\"start\":96,\"end\":103},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bc870b0a-74dc-452b-ab38-74618df3c1c1\",\"uuid\":\"f3de9ec6-ee7c-40a3-a1be-0d9016661980\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"; in \",\"attrs\":{\"start\":103,\"end\":108}},{\"type\":\"text\",\"text\":\"nirvāṇa\",\"attrs\":{\"start\":108,\"end\":115},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bc870b0a-74dc-452b-ab38-74618df3c1c1\",\"uuid\":\"c5b84f4a-c21d-4780-8e78-db91af30539b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" there is no birth, and where there is no birth there is no death.\",\"attrs\":{\"start\":115,\"end\":181}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"9d7e05a8-e6fa-4f44-97e0-516f8ade1522\",\"sort\":9888,\"type\":\"endnotes\",\"label\":\"n.27\",\"alignments\":{},\"references\":[{\"content\":\"“Dharma-King, you rule with the Dharma your supreme Dharma-kingdom, And thereby bestow the treasures of the Dharma upon all living beings. Expert in the deep analysis of things, you teach their ultimate meaning. Sovereign Lord of Dharma, obeisance to you!\",\"label\":\"1.18\",\"sort\":1036,\"type\":\"translation\",\"uuid\":\"a7f875ea-f271-4182-8704-0f7f41667db6\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-57\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":610,\"uuid\":\"9d7e05a8-e6fa-4f44-97e0-516f8ade1522\"},\"content\":[{\"type\":\"text\",\"text\":\"The subtle difference here between Tib. and Ch. of K and X is noteworthy. Tib. causally relates “deep analysis of things” (Skt. \",\"attrs\":{\"start\":0,\"end\":128}},{\"type\":\"text\",\"text\":\"dharma­prabedha\",\"attrs\":{\"start\":128,\"end\":143},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":128,\"end\":143,\"uuid\":\"9a08b24a-6423-44df-a584-37aa5a48534a\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\") to the teaching of their \",\"attrs\":{\"start\":143,\"end\":170}},{\"type\":\"text\",\"text\":\"ultimate\",\"attrs\":{\"start\":170,\"end\":178},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"784c8158-9e46-4484-9152-e0d06cd46afc\",\"uuid\":\"3b70d2f5-fdfe-440a-9840-559173f7ca76\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" meaning, which accords with the Indo-Tibetan emphasis on “\",\"attrs\":{\"start\":178,\"end\":237}},{\"type\":\"text\",\"text\":\"transcendental analysis\",\"attrs\":{\"start\":237,\"end\":260},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"6cf08752-1b1f-4a66-a9c7-a593246c380d\",\"uuid\":\"72ffe9a2-2b8b-49df-9bcf-5d317431867e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"” (\",\"attrs\":{\"start\":260,\"end\":263}},{\"type\":\"text\",\"text\":\"vipaśyana\",\"attrs\":{\"start\":263,\"end\":272},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":263,\"end\":272,\"uuid\":\"1b201c97-a904-4616-b741-225722314d00\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\") as indispensable for realization of the \",\"attrs\":{\"start\":272,\"end\":314}},{\"type\":\"text\",\"text\":\"ultimate\",\"attrs\":{\"start\":314,\"end\":322},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"784c8158-9e46-4484-9152-e0d06cd46afc\",\"uuid\":\"af61218f-ed82-4534-9b01-3c61fa035a92\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" nature of things. Ch. (both K and X) puts the two (analysis and the \",\"attrs\":{\"start\":322,\"end\":391}},{\"type\":\"text\",\"text\":\"ultimate\",\"attrs\":{\"start\":391,\"end\":399},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"784c8158-9e46-4484-9152-e0d06cd46afc\",\"uuid\":\"119dc8f4-e714-4381-bb6a-49f6b4980dfb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\") in opposition, saying, “(You are) expert in analysis of the nature of all things, (\",\"attrs\":{\"start\":399,\"end\":484}},{\"type\":\"text\",\"text\":\"yet\",\"attrs\":{\"start\":484,\"end\":487},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":484,\"end\":487,\"uuid\":\"35a0fe94-859c-4935-80a9-0debfe7d236a\",\"type\":\"span\",\"textStyle\":\"emphasis\"}}]},{\"type\":\"text\",\"text\":\" are) unmoved with respect to the \",\"attrs\":{\"start\":487,\"end\":521}},{\"type\":\"text\",\"text\":\"ultimate\",\"attrs\":{\"start\":521,\"end\":529},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"784c8158-9e46-4484-9152-e0d06cd46afc\",\"uuid\":\"87d1e5dc-9d92-4dec-a03e-771d3ec7d8af\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" meaning, (as you have) already attained sovereignty with respect to all things.”\",\"attrs\":{\"start\":529,\"end\":610}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"5e51243a-014e-4fdf-bab7-ec2d325785b3\",\"sort\":9906,\"type\":\"endnotes\",\"label\":\"n.28\",\"alignments\":{},\"references\":[{\"content\":\"“All these things arise dependently, from causes, Yet they are neither existent nor nonexistent. Therein is neither ego, nor experiencer, nor doer, Yet no action, good or evil, loses its effects. Such is your teaching.\",\"label\":\"1.19\",\"sort\":1059,\"type\":\"translation\",\"uuid\":\"a3af57be-b163-4c9e-8281-2816063edeaf\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-58\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":222,\"uuid\":\"5e51243a-014e-4fdf-bab7-ec2d325785b3\"},\"content\":[{\"type\":\"text\",\"text\":\"The fact about Buddhist doctrine that most baffled ancient critics is that the cause and effect of \",\"attrs\":{\"start\":0,\"end\":99}},{\"type\":\"text\",\"text\":\"karma\",\"attrs\":{\"start\":99,\"end\":104},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b50a8fcc-a5eb-409b-96d4-a5872524e192\",\"uuid\":\"3ef9dfcc-36dd-461f-bd49-d7fa38a15879\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" operates without any ego principle to link the doer of an action and the experiencer of that action’s karmic effects.\",\"attrs\":{\"start\":104,\"end\":222}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"da9741fa-e92e-438b-817d-8e78dfdcdcfc\",\"sort\":9910,\"type\":\"endnotes\",\"label\":\"n.29\",\"alignments\":{},\"references\":[{\"content\":\"“O Śākyamuni, conquering the powerful host of Māra, You found peace, immortality, and the happiness of that supreme enlightenment That is not realized by any among the outsiders, Though they arrest their feeling, thought, and mental processes.\",\"label\":\"1.20\",\"sort\":1069,\"type\":\"translation\",\"uuid\":\"373819cd-bb7f-4f12-a5f1-7e8e02e68645\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-59\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":459,\"uuid\":\"da9741fa-e92e-438b-817d-8e78dfdcdcfc\"},\"content\":[{\"type\":\"text\",\"text\":\"The Tibetan grammar leaves it ambiguous as to whether the absence of feeling, etc., refers to \",\"attrs\":{\"start\":0,\"end\":94}},{\"type\":\"text\",\"text\":\"enlightenment\",\"attrs\":{\"start\":94,\"end\":107},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"62f923c5-8dfa-4620-8dec-7bb032231bf7\",\"uuid\":\"21073b45-7086-4b81-a92b-eea6f700e453\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" or to the \",\"attrs\":{\"start\":107,\"end\":118}},{\"type\":\"text\",\"text\":\"outsiders\",\"attrs\":{\"start\":118,\"end\":127},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b121c9a5-7c63-4bc5-be7a-4f7ac29b7113\",\"uuid\":\"d2ee5935-6300-436c-803b-bf5d810218c6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". K and X indicate the former, but we have chosen the latter to avoid characterizing supreme \",\"attrs\":{\"start\":127,\"end\":220}},{\"type\":\"text\",\"text\":\"enlightenment\",\"attrs\":{\"start\":220,\"end\":233},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"62f923c5-8dfa-4620-8dec-7bb032231bf7\",\"uuid\":\"f08f16bd-0c26-486a-86ca-c23454fd3a63\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" as a mere “nonthought,” etc., since it obviously transcends all polarities. Further, it is in keeping with the tenor of the \",\"attrs\":{\"start\":233,\"end\":358}},{\"type\":\"text\",\"text\":\"sūtra\",\"attrs\":{\"start\":358,\"end\":363},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c65438ed-99d8-45cc-bc87-72f8f617eea5\",\"uuid\":\"db7f7ece-ec7e-467c-bbed-145a94dbfdcf\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" to distinguish between \",\"attrs\":{\"start\":363,\"end\":387}},{\"type\":\"text\",\"text\":\"enlightenment\",\"attrs\":{\"start\":387,\"end\":400},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"62f923c5-8dfa-4620-8dec-7bb032231bf7\",\"uuid\":\"702629c0-6c43-449d-9ed1-3453bae72521\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and the mere attainment of even the most advanced \",\"attrs\":{\"start\":400,\"end\":451}},{\"type\":\"text\",\"text\":\"samādhi\",\"attrs\":{\"start\":451,\"end\":458},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"12140d8a-6833-4267-9463-c0922ba5a70b\",\"uuid\":\"7ae95034-e46a-4906-afb3-6187d7c9df77\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":458,\"end\":459}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"9a4488c6-92c8-4f8b-ba21-6b5b7e308c6e\",\"sort\":9924,\"type\":\"endnotes\",\"label\":\"n.30\",\"alignments\":{},\"references\":[{\"content\":\"“O Wonderful King of Dharma, you turned the wheel of Dharma before men and gods, With its threefold revolution, its manifold aspects, Its extreme peace, and its purity of nature; And thereby the Three Jewels were revealed.\",\"label\":\"1.21\",\"sort\":1085,\"type\":\"translation\",\"uuid\":\"619e2264-f801-422d-a19d-52061cdb54b4\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-60\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1145,\"uuid\":\"9a4488c6-92c8-4f8b-ba21-6b5b7e308c6e\"},\"content\":[{\"type\":\"text\",\"text\":\"Tib. \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"lan gsum bzlas pa chos kyi ’khor lo rnam mang po\",\"attrs\":{\"start\":5,\"end\":53},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":5,\"end\":53,\"uuid\":\"bfd54370-eaaa-4d8d-9c65-35088c50c3bd\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\". Although neither Skt. nor Tib. mention the aspects as “twelve,” Lamotte supplies this from the occurrence of the formula in other \",\"attrs\":{\"start\":53,\"end\":185}},{\"type\":\"text\",\"text\":\"sūtras\",\"attrs\":{\"start\":185,\"end\":191},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c65438ed-99d8-45cc-bc87-72f8f617eea5\",\"uuid\":\"1ca1778b-22c0-41a6-8302-86664a158bd1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", where the three revolutions correspond respectively to the paths of insight (\",\"attrs\":{\"start\":191,\"end\":270}},{\"type\":\"text\",\"text\":\"darśana­mārga\",\"attrs\":{\"start\":270,\"end\":283},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":270,\"end\":283,\"uuid\":\"3bed5651-74d5-40aa-8f26-6b4a2f55cb51\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"), \",\"attrs\":{\"start\":283,\"end\":286}},{\"type\":\"text\",\"text\":\"meditation\",\"attrs\":{\"start\":286,\"end\":296},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"72ea6449-0c42-401c-bff0-be87bffdfd07\",\"uuid\":\"83c597e7-b60f-4c95-976a-aa0da74514ea\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":296,\"end\":298}},{\"type\":\"text\",\"text\":\"bhāvanā­mārga\",\"attrs\":{\"start\":298,\"end\":311},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":298,\"end\":311,\"uuid\":\"dde74396-0356-4efe-95b0-a9247c1fa68a\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"), and mastery (\",\"attrs\":{\"start\":311,\"end\":327}},{\"type\":\"text\",\"text\":\"aśaikṣa­marga\",\"attrs\":{\"start\":327,\"end\":340},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":327,\"end\":340,\"uuid\":\"ed153086-d25e-4e3d-91e6-bf944757700c\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"), each revolution having four aspects corresponding to the Four \",\"attrs\":{\"start\":340,\"end\":405}},{\"type\":\"text\",\"text\":\"Noble\",\"attrs\":{\"start\":405,\"end\":410},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"335e47c2-eb5f-458f-89d8-346e929bc433\",\"uuid\":\"145eb03d-dbbe-4f7b-9c24-3f5c201899bf\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" Truths. The first revolution involves recognition of each truth, the second thorough knowledge of each, and the third complete realization of each. See Lamotte, p 107, n 49; \",\"attrs\":{\"start\":410,\"end\":585}},{\"type\":\"text\",\"text\":\"Mahāvyutpatti\",\"attrs\":{\"start\":585,\"end\":598},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"3ddac8d9-fd38-447b-a7be-9e52cc212005\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\", nos. 1309-1324. However, since there is no mention of the “twelve aspects,” but rather “many aspects,” it is possible that what is referred to is the three doctrines of the \",\"attrs\":{\"start\":598,\"end\":773}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":773,\"end\":779},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"dc0237ca-2d60-4024-8fe0-f29de50729c8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" elaborated in the \",\"attrs\":{\"start\":779,\"end\":798}},{\"type\":\"text\",\"text\":\"Saṃdhi­nirmocana­sūtra\",\"attrs\":{\"start\":798,\"end\":820},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"4ba3b2c7-1d6f-4538-a664-29638d6bc457\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\",\"start\":798,\"end\":0}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bce502de-187d-4fc2-a938-fe32a4604973\",\"uuid\":\"70481b86-9866-4f5b-9a38-e23c3f142ccc\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", also known as the “Three Turnings of the Wheel of \",\"attrs\":{\"start\":820,\"end\":872}},{\"type\":\"text\",\"text\":\"Dharma\",\"attrs\":{\"start\":872,\"end\":878},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c08db6f5-393e-4ec4-bf72-4043e53b3129\",\"uuid\":\"eb251ae5-7751-4441-887e-47015f1ae039\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"”; namely, the \",\"attrs\":{\"start\":878,\"end\":893}},{\"type\":\"text\",\"text\":\"Disciple Vehicle\",\"attrs\":{\"start\":893,\"end\":909},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cc35d4b8-9151-485e-9199-cf5d9d646538\",\"uuid\":\"42bcf80a-a5a1-4de6-8eb1-0ad08cf46266\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" teaching of the Four \",\"attrs\":{\"start\":909,\"end\":931}},{\"type\":\"text\",\"text\":\"Noble\",\"attrs\":{\"start\":931,\"end\":936},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"335e47c2-eb5f-458f-89d8-346e929bc433\",\"uuid\":\"f63178e6-fd3c-488d-91fc-ab55ca566c2d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" Truths, the \",\"attrs\":{\"start\":936,\"end\":949}},{\"type\":\"text\",\"text\":\"Mādhyamika\",\"attrs\":{\"start\":949,\"end\":959},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"08688fff-c9ad-4aaa-83ac-1792ad208fff\",\"uuid\":\"fb86db45-1446-4710-a0b3-2fd3300ae92b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" teaching of Transcendent \",\"attrs\":{\"start\":959,\"end\":985}},{\"type\":\"text\",\"text\":\"Wisdom\",\"attrs\":{\"start\":985,\"end\":991},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"38971298-6f62-48f0-b271-36261568d441\",\"uuid\":\"c0ceedc9-980f-4bc8-b68e-e963ef0a1030\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and the \",\"attrs\":{\"start\":991,\"end\":1001}},{\"type\":\"text\",\"text\":\"Vijñānavāda\",\"attrs\":{\"start\":1001,\"end\":1012},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cda360b1-68ed-4f1f-a2b2-b87d209292db\",\"uuid\":\"436f3b0c-b8f2-4a16-a29f-1f0bf38f3d8e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" teaching of “Fine Discrimination Between Existence and Nonexistence” (see Lamotte’s \",\"attrs\":{\"start\":1012,\"end\":1097}},{\"type\":\"text\",\"text\":\"Saṃdhinirmocana sūtra\",\"attrs\":{\"start\":1097,\"end\":1118},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"ee6e5be0-75cf-4f82-a1ff-4b009f7694b5\",\"lang\":\"Zh-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\", VII, no. 30, pp 85, 206).\",\"attrs\":{\"start\":1118,\"end\":1145}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"1b41ff0b-8bb1-46a8-b1cc-5d53e5367d86\",\"sort\":9960,\"type\":\"endnotes\",\"label\":\"n.31\",\"alignments\":{},\"references\":[{\"content\":\"“Like Mount Sumeru, you are unmoved by honor or scorn. You love moral beings and immoral beings equally. Poised in equanimity, your mind is like the sky. Who would not honor such a precious jewel of a being?\",\"label\":\"1.23\",\"sort\":1109,\"type\":\"translation\",\"uuid\":\"11cf18ec-6ae5-40aa-a894-547f82023db0\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-62\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":611,\"uuid\":\"1b41ff0b-8bb1-46a8-b1cc-5d53e5367d86\"},\"content\":[{\"type\":\"text\",\"text\":\"After this verse, there are two verses in K and X, not in Tib. or Skt. For verses in K, see Luk, p 7, lines 3-10, and McRae, p 73, verses 9-10; for X see Lamotte, p 108. Since X tends to be more consistent with Tib., I will translate X: “The \",\"attrs\":{\"start\":0,\"end\":242}},{\"type\":\"text\",\"text\":\"billion-world galaxy\",\"attrs\":{\"start\":242,\"end\":262},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b5e7eaef-2698-4621-9922-144a0ad94264\",\"uuid\":\"8d97d607-9659-4077-9365-cd6cb0ebf6c4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", with its realms of gods and dragons, appears in the little parasols offered to the \",\"attrs\":{\"start\":262,\"end\":347}},{\"type\":\"text\",\"text\":\"Lord\",\"attrs\":{\"start\":347,\"end\":351},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41c623b8-3d94-4f8e-b2c5-1d7a5f5af6d3\",\"uuid\":\"4fe2c9c3-e374-4c4f-b264-8c65e0a16c02\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"; thus we bow to his vision, knowledge, and mass of virtues. The \",\"attrs\":{\"start\":351,\"end\":416}},{\"type\":\"text\",\"text\":\"Lord\",\"attrs\":{\"start\":416,\"end\":420},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41c623b8-3d94-4f8e-b2c5-1d7a5f5af6d3\",\"uuid\":\"e2afa6b9-416a-4d65-ba9a-651c0af9b37f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" displays the worlds to us with this miracle‍—they all are like a play of lights, as all bear witness in astonishment. Obeisance to the \",\"attrs\":{\"start\":420,\"end\":556}},{\"type\":\"text\",\"text\":\"Lord\",\"attrs\":{\"start\":556,\"end\":560},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41c623b8-3d94-4f8e-b2c5-1d7a5f5af6d3\",\"uuid\":\"92e9ab37-614c-4b1e-bc4e-a7233b2050a9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of \",\"attrs\":{\"start\":560,\"end\":564}},{\"type\":\"text\",\"text\":\"ten powers\",\"attrs\":{\"start\":564,\"end\":574},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a72b2685-e31f-4aed-adff-8c13405c1c9f\",\"uuid\":\"98b1b18c-d00f-4621-bf64-c12c3c80ebb4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", endowed with knowledge and vision.”\",\"attrs\":{\"start\":574,\"end\":611}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"441704b0-66bd-4f42-a3cf-babee904075c\",\"sort\":9972,\"type\":\"endnotes\",\"label\":\"n.32\",\"alignments\":{},\"references\":[{\"content\":\"“Great Sage, in all these multitudes gathered here, Who look upon your countenance with hearts sincere in faith, Each being beholds the Victor, as if just before him. This is a special quality of the Buddha.\",\"label\":\"1.24\",\"sort\":1120,\"type\":\"translation\",\"uuid\":\"0bee22ea-2d91-4f34-ad93-693fea482d01\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-63\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":222,\"uuid\":\"441704b0-66bd-4f42-a3cf-babee904075c\"},\"content\":[{\"type\":\"text\",\"text\":\"Skt. \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"āveṇika­buddha­lakṣaṇa\",\"attrs\":{\"start\":5,\"end\":27},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":5,\"end\":27,\"uuid\":\"6223c606-009a-49ed-b6a0-9a2651d97e63\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\". This and the subsequent two verses (Chap. 3) illustrate some of the special \",\"attrs\":{\"start\":27,\"end\":105}},{\"type\":\"text\",\"text\":\"buddha\",\"attrs\":{\"start\":105,\"end\":111},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"f26d3601-e204-40d2-aca1-f03a58bc2c81\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"-qualities, which total eighteen (see glossary “\",\"attrs\":{\"start\":111,\"end\":159}},{\"type\":\"text\",\"text\":\"eighteen special qualities of the Buddha\",\"attrs\":{\"start\":159,\"end\":199},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"22d552c8-644d-4406-b1ba-f2d731fff0c3\",\"uuid\":\"888f90c8-9fea-4581-903e-2f4a8a889e7e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"” for a complete list).\",\"attrs\":{\"start\":199,\"end\":222}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"3b8c2754-8a34-4703-bb32-eb78b138b554\",\"sort\":9980,\"type\":\"endnotes\",\"label\":\"n.33\",\"alignments\":{},\"references\":[{\"content\":\"“Although the Lord speaks with but one voice, Those present perceive that same voice differently, And each understands in his own language according to his own needs. This is a special quality of the Buddha.\",\"label\":\"1.25\",\"sort\":1131,\"type\":\"translation\",\"uuid\":\"7b7420f1-6d4d-4b30-b26c-b3fbfc575f5d\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-64\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":586,\"uuid\":\"3b8c2754-8a34-4703-bb32-eb78b138b554\"},\"content\":[{\"type\":\"text\",\"text\":\"This verse in Tib. and Skt. appears to be expanded into two verses in K and X: “The \",\"attrs\":{\"start\":0,\"end\":84}},{\"type\":\"text\",\"text\":\"Lord\",\"attrs\":{\"start\":84,\"end\":88},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41c623b8-3d94-4f8e-b2c5-1d7a5f5af6d3\",\"uuid\":\"3fee3357-1c21-4f20-acea-64cd54ebf1f1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" speaks with but one voice, but all beings, each according to his kind, gain understanding, each thinking that the \",\"attrs\":{\"start\":88,\"end\":203}},{\"type\":\"text\",\"text\":\"Lord\",\"attrs\":{\"start\":203,\"end\":207},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41c623b8-3d94-4f8e-b2c5-1d7a5f5af6d3\",\"uuid\":\"6828425f-d37d-46b9-944c-2062ca754506\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" speaks his own language. This is a special quality of the \",\"attrs\":{\"start\":207,\"end\":266}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":266,\"end\":272},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"bef869df-da7b-47b0-bc25-2eb810031af2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". The \",\"attrs\":{\"start\":272,\"end\":278}},{\"type\":\"text\",\"text\":\"Lord\",\"attrs\":{\"start\":278,\"end\":282},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41c623b8-3d94-4f8e-b2c5-1d7a5f5af6d3\",\"uuid\":\"4d762aaf-4844-4891-affd-83037cb84d0c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" speaks with but one voice, but all beings, each according to his own ability, act upon it, and each derives his appropriate benefit. This is a special quality of the \",\"attrs\":{\"start\":282,\"end\":449}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":449,\"end\":455},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"92241b40-0a74-4485-8c21-fe9ca5492087\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".” For K see Luk, p 7, and McRae, p 74. For an interesting discussion of the speech of the \",\"attrs\":{\"start\":455,\"end\":546}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":546,\"end\":552},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"6ba18b43-8f37-4aa4-8194-edc4462d86b5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", see Lamotte, pp 109-110, 11. 52.\",\"attrs\":{\"start\":552,\"end\":586}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"1510a714-cfbe-4fec-b769-2997cc506f6c\",\"sort\":9994,\"type\":\"endnotes\",\"label\":\"n.34\",\"alignments\":{},\"references\":[{\"content\":\"“You nullify all signs in all things everywhere. You are not subject to any wish for anything at all. The miraculous power of the buddhas is inconceivable. We bow to you, who stand nowhere, like infinite space.”\",\"label\":\"1.30\",\"sort\":1186,\"type\":\"translation\",\"uuid\":\"91c5d4be-a2fd-43d0-8486-0111b590f94e\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-69\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":183,\"uuid\":\"1510a714-cfbe-4fec-b769-2997cc506f6c\"},\"content\":[{\"type\":\"text\",\"text\":\"This and the preceding two lines ascribe to the \",\"attrs\":{\"start\":0,\"end\":48}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":48,\"end\":54},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"5e059424-df23-4c0a-a1aa-aeb3e9f129f3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" the attainment of the three doors of \",\"attrs\":{\"start\":54,\"end\":92}},{\"type\":\"text\",\"text\":\"liberation\",\"attrs\":{\"start\":92,\"end\":102},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1f6de051-60d0-418f-9255-9634be3f22b8\",\"uuid\":\"09fb1a1d-6798-4ca9-abd7-0470637bc0e1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\": \",\"attrs\":{\"start\":102,\"end\":104}},{\"type\":\"text\",\"text\":\"voidness\",\"attrs\":{\"start\":104,\"end\":112},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e74ef65c-8fc8-4dbf-9bba-7326d6b5d34d\",\"uuid\":\"e5eadc17-39c2-4c05-abc1-606819c006b5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":112,\"end\":114}},{\"type\":\"text\",\"text\":\"śūnyatā\",\"attrs\":{\"start\":114,\"end\":121},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1ede53af-8161-4358-9902-76ff3144ae49\",\"uuid\":\"f53c6aa8-8ded-4560-9fee-e6eb0fbffd50\",\"toh\":null,\"start\":114,\"end\":0}},{\"type\":\"italic\",\"attrs\":{\"start\":114,\"end\":121,\"uuid\":\"12763581-4c8b-4b6e-bdaa-22bedb9f7803\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"), \",\"attrs\":{\"start\":121,\"end\":124}},{\"type\":\"text\",\"text\":\"signlessness\",\"attrs\":{\"start\":124,\"end\":136},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7d73e343-f69c-4e58-b34d-11a2174e7d7a\",\"uuid\":\"0471836c-7be0-4cbf-a165-766446a2e378\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":136,\"end\":138}},{\"type\":\"text\",\"text\":\"animittatā\",\"attrs\":{\"start\":138,\"end\":148},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":138,\"end\":148,\"uuid\":\"ca81830d-4c81-49ad-824e-61329b5e5716\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"), and \",\"attrs\":{\"start\":148,\"end\":155}},{\"type\":\"text\",\"text\":\"wishlessness\",\"attrs\":{\"start\":155,\"end\":167},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9c3e4b37-8479-4dee-a2a4-dc01c83a6254\",\"uuid\":\"62cd54ba-a5e6-4b17-83c3-c7bc31eebdd9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":167,\"end\":169}},{\"type\":\"text\",\"text\":\"apraṇihitatā\",\"attrs\":{\"start\":169,\"end\":181},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":169,\"end\":181,\"uuid\":\"a5505a12-e9dd-4d67-b0b4-4d917932ca84\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\").\",\"attrs\":{\"start\":181,\"end\":183}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"45e98c4d-e214-4c91-a91d-a97d8f77a955\",\"sort\":10012,\"type\":\"endnotes\",\"label\":\"n.35\",\"alignments\":{},\"references\":[{\"content\":\"Then, the young Licchavi Ratnākara, having celebrated the Buddha with these verses, further addressed him, “Lord, these five hundred young Licchavis are truly on their way to unexcelled, perfect enlightenment, and they have asked what is the bodhisattvas’ purification of the buddhafield. Please, Lord, explain to them the bodhisattvas’ purification of the buddhafield!”\",\"label\":\"1.31\",\"sort\":1197,\"type\":\"translation\",\"uuid\":\"a05f12ef-a319-4ca1-a7a3-f0d769436bcc\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-70\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":981,\"uuid\":\"45e98c4d-e214-4c91-a91d-a97d8f77a955\"},\"content\":[{\"type\":\"text\",\"text\":\"Tib. \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"byang chub sems dpa’ rnams kyi sangs rgyas kyi zhing yongs su dag pa\",\"attrs\":{\"start\":5,\"end\":73},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":5,\"end\":73,\"uuid\":\"5998e0ee-b0d7-4895-aa49-14b0d37409b0\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"; Skt. \",\"attrs\":{\"start\":73,\"end\":80}},{\"type\":\"text\",\"text\":\"bodhi­sattvāṇam buddha­kṣetra­pari­śuddhi\",\"attrs\":{\"start\":80,\"end\":121},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":80,\"end\":121,\"uuid\":\"6c8a089b-6f7d-439b-ac4c-20686227ac19\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\". Although the explanations given by the \",\"attrs\":{\"start\":121,\"end\":162}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":162,\"end\":168},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"594bdef9-1dab-411f-a6a2-e92fabf6ec74\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" obviate the need for discussion of the meaning of this term, it is worthwhile to note that this concept is the logical corollary of the \",\"attrs\":{\"start\":168,\"end\":305}},{\"type\":\"text\",\"text\":\"bodhisattva\",\"attrs\":{\"start\":305,\"end\":316},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c72eb4f3-700e-454d-996e-5ccdba29e6be\",\"uuid\":\"aaf6f3be-69e9-44b2-b62c-86c2e36dc7d7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s conception of \",\"attrs\":{\"start\":316,\"end\":333}},{\"type\":\"text\",\"text\":\"enlightenment\",\"attrs\":{\"start\":333,\"end\":346},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"62f923c5-8dfa-4620-8dec-7bb032231bf7\",\"uuid\":\"3707af05-93a6-4153-b638-9564f7f2c864\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\": that it be attained for the sake of all sentient beings as well as for his own sake. Thus, the \",\"attrs\":{\"start\":346,\"end\":443}},{\"type\":\"text\",\"text\":\"bodhisattva\",\"attrs\":{\"start\":443,\"end\":454},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c72eb4f3-700e-454d-996e-5ccdba29e6be\",\"uuid\":\"e57d9222-2b17-4fcc-828d-7ae6cf7bf933\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s quest for \",\"attrs\":{\"start\":454,\"end\":467}},{\"type\":\"text\",\"text\":\"enlightenment\",\"attrs\":{\"start\":467,\"end\":480},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"62f923c5-8dfa-4620-8dec-7bb032231bf7\",\"uuid\":\"77b3ec0c-2787-457c-8e90-a0c3250d42b2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" does not involve merely his own development, although that is of course primary; it must also involve his cultivation of a whole “field” of living beings, those who, through karmic interconnection, have destinies intertwined with his, occupying the same worlds as he, etc. Hence, his purification of a \",\"attrs\":{\"start\":480,\"end\":783}},{\"type\":\"text\",\"text\":\"buddhafield\",\"attrs\":{\"start\":783,\"end\":794},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1e5e85e8-4767-46b1-874e-5f1396a67ee6\",\"uuid\":\"b1567602-c061-4363-b39b-5e8fd4167100\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is a mode of expressing his ambition to cultivate a whole world or universe while he cultivates himself, so that he and his field of living beings may reach \",\"attrs\":{\"start\":794,\"end\":952}},{\"type\":\"text\",\"text\":\"enlightenment\",\"attrs\":{\"start\":952,\"end\":965},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"62f923c5-8dfa-4620-8dec-7bb032231bf7\",\"uuid\":\"2e86de49-88e3-4fa3-b1c3-dbddec73f2dc\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" simultaneously.\",\"attrs\":{\"start\":965,\"end\":981}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"a8981f61-4b9b-4514-a308-18511379349e\",\"sort\":10032,\"type\":\"endnotes\",\"label\":\"n.36\",\"alignments\":{},\"references\":[{\"content\":\"“For example, Ratnākara, should one wish to build in empty space, one might go ahead in spite of the fact that it is not possible to build or to adorn anything in empty space. In just the same way, should a bodhisattva, who knows full well that all things are like empty space, wish to build a buddhafield in order to develop living beings, he might go ahead, in spite of the fact that it is not possible to build or to adorn a buddhafield in empty space.\",\"label\":\"1.34\",\"sort\":1284,\"type\":\"translation\",\"uuid\":\"1877a795-d97f-46ac-ab6a-dc6b3cb70c10\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-73\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":2264,\"uuid\":\"a8981f61-4b9b-4514-a308-18511379349e\"},\"content\":[{\"type\":\"text\",\"text\":\"K and X differ here quite radically. X: “For example, sons, if one should wish to construct a palace in an unoccupied place and then adorn it, he could do so freely and without hindrance, but if he wished to build it in empty space itself, he could never succeed. In the same way, the \",\"attrs\":{\"start\":0,\"end\":285}},{\"type\":\"text\",\"text\":\"bodhisattva\",\"attrs\":{\"start\":285,\"end\":296},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c72eb4f3-700e-454d-996e-5ccdba29e6be\",\"uuid\":\"10c2aef1-1ced-4a43-92af-8386c6abc470\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", although he knows that all things are like empty space, produces pure qualities, for the development and benefit of living beings. That is the \",\"attrs\":{\"start\":296,\"end\":441}},{\"type\":\"text\",\"text\":\"buddhafield\",\"attrs\":{\"start\":441,\"end\":452},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1e5e85e8-4767-46b1-874e-5f1396a67ee6\",\"uuid\":\"ef8a12fc-5135-4657-8f58-1667ec71c9e6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" which he embraces. To embrace a \",\"attrs\":{\"start\":452,\"end\":485}},{\"type\":\"text\",\"text\":\"buddhafield\",\"attrs\":{\"start\":485,\"end\":496},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1e5e85e8-4767-46b1-874e-5f1396a67ee6\",\"uuid\":\"ce7413a2-8b95-416e-b34d-283f2a9dde9d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in this way is not like building in empty space.” K: “It is as if a man wished to build a building in a vacant place‍—he could do so without difficulty. But (if he wished to do it) in empty space, he could not succeed. Likewise, the \",\"attrs\":{\"start\":496,\"end\":730}},{\"type\":\"text\",\"text\":\"bodhisattva\",\"attrs\":{\"start\":730,\"end\":741},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c72eb4f3-700e-454d-996e-5ccdba29e6be\",\"uuid\":\"dce5c88e-831e-4e79-b09f-642d1bb889b8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", in order to cultivate all living beings, wants to embrace a \",\"attrs\":{\"start\":741,\"end\":803}},{\"type\":\"text\",\"text\":\"buddhafield\",\"attrs\":{\"start\":803,\"end\":814},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1e5e85e8-4767-46b1-874e-5f1396a67ee6\",\"uuid\":\"828b8038-d6b0-4253-b5f8-bc3f934439af\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". One who thus wishes to embrace a \",\"attrs\":{\"start\":814,\"end\":849}},{\"type\":\"text\",\"text\":\"buddhafield\",\"attrs\":{\"start\":849,\"end\":860},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1e5e85e8-4767-46b1-874e-5f1396a67ee6\",\"uuid\":\"f1b0f1e7-fe91-4e51-a517-caa0950c6b0c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (does not do so) in the void.” The first impulse of the translator is to resort to the Ch. versions in the interest of simplicity and ease, since the simile there is much more clearly drawn: vacant lot = living beings, empty space = any sort of materialistic notion about a \",\"attrs\":{\"start\":860,\"end\":1135}},{\"type\":\"text\",\"text\":\"buddhafield\",\"attrs\":{\"start\":1135,\"end\":1146},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1e5e85e8-4767-46b1-874e-5f1396a67ee6\",\"uuid\":\"0f4c8af4-f69a-43a8-be98-cd2784353956\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"; \",\"attrs\":{\"start\":1146,\"end\":1148}},{\"type\":\"text\",\"text\":\"ergo\",\"attrs\":{\"start\":1148,\"end\":1152},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":1148,\"end\":1152,\"uuid\":\"9be205e3-7d4d-402a-a24e-9a2c7009db26\",\"type\":\"span\",\"textStyle\":\"emphasis\"}}]},{\"type\":\"text\",\"text\":\" building on solid needs of living beings succeeds, and any other way fails. However, upon reflection, what does the \",\"attrs\":{\"start\":1152,\"end\":1269}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":1269,\"end\":1275},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"9ac3b5a4-4c93-4459-9a68-def93e4dc5ef\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" wish to convey in this example? Are not living beings and their needs and purposes just as ultimately empty as “all things”? Would not the concretization of the benefit of living beings violate the definition of liberative technique integrated with \",\"attrs\":{\"start\":1275,\"end\":1525}},{\"type\":\"text\",\"text\":\"wisdom\",\"attrs\":{\"start\":1525,\"end\":1531},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"38971298-6f62-48f0-b271-36261568d441\",\"uuid\":\"9b52fb2c-fb95-4cd7-9495-4f536bb71c19\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" given by \",\"attrs\":{\"start\":1531,\"end\":1541}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":1541,\"end\":1552},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"af40b9ad-873c-444c-8c45-63ae00f7d2dd\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" himself (see \",\"attrs\":{\"start\":1552,\"end\":1566}},{\"type\":\"text\",\"text\":\"4.22\",\"attrs\":{\"start\":1566,\"end\":1570},\"marks\":[{\"type\":\"internalLink\",\"attrs\":{\"uuid\":\"fb5b45a5-c41c-4f6a-9bff-8c721c0e09e9\",\"href\":\"/entity/passage/4dd6542b-23c6-4882-858d-b0f7279d6f43\",\"entity\":\"4dd6542b-23c6-4882-858d-b0f7279d6f43\",\"type\":\"passage\",\"toh\":null,\"isSameWork\":true,\"subtype\":\"translation\"}}]},{\"type\":\"text\",\"text\":\")? Is it not more fitting to understand the \",\"attrs\":{\"start\":1570,\"end\":1614}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":1614,\"end\":1620},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"a112eadf-09e4-4dec-bcfe-ee233e1a0214\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" here as telling us not to concretize any mundane aims, however beneficial, but that the \",\"attrs\":{\"start\":1620,\"end\":1709}},{\"type\":\"text\",\"text\":\"bodhisattva\",\"attrs\":{\"start\":1709,\"end\":1720},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c72eb4f3-700e-454d-996e-5ccdba29e6be\",\"uuid\":\"5f2bf3ae-b40d-4aac-841c-dacd7c018b59\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s \",\"attrs\":{\"start\":1720,\"end\":1723}},{\"type\":\"text\",\"text\":\"great compassion\",\"attrs\":{\"start\":1723,\"end\":1739},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"dc1f3a82-a37b-47bc-a900-9c62a98401cb\",\"uuid\":\"2b95fd21-13b7-43e5-bf4f-db502824f0a5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" must always adhere to the \",\"attrs\":{\"start\":1739,\"end\":1766}},{\"type\":\"text\",\"text\":\"wisdom\",\"attrs\":{\"start\":1766,\"end\":1772},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"38971298-6f62-48f0-b271-36261568d441\",\"uuid\":\"f7b63780-9195-4624-b53c-4c8ca09e34b2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" that sees the ephemerality of all purposive notions, constructed or constructive? When we undertake something we know to be essentially impossible, through the sheer intensity of compassion, do we not enter the realm of \",\"attrs\":{\"start\":1772,\"end\":1993}},{\"type\":\"text\",\"text\":\"inconceivability\",\"attrs\":{\"start\":1993,\"end\":2009},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"dc39b632-2a80-43b2-8eec-3bd2a37aa05c\",\"uuid\":\"cd75eaab-3737-437a-8add-caf9cfc47b3b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"? Finally, may not the \",\"attrs\":{\"start\":2009,\"end\":2032}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":2032,\"end\":2038},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"e0c3cc85-9f75-4b14-8e83-26504c0078d4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" be speaking in tune with his own subsequent miraculous display, as he demonstrates the actual possibility for him, no less than for space-age technology, of building a pure \",\"attrs\":{\"start\":2038,\"end\":2212}},{\"type\":\"text\",\"text\":\"buddhafield\",\"attrs\":{\"start\":2212,\"end\":2223},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1e5e85e8-4767-46b1-874e-5f1396a67ee6\",\"uuid\":\"56a8ef22-1fab-41e0-b50a-98f017a6f29d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in the empty space of \",\"attrs\":{\"start\":2223,\"end\":2246}},{\"type\":\"text\",\"text\":\"ultimate\",\"attrs\":{\"start\":2246,\"end\":2254},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"784c8158-9e46-4484-9152-e0d06cd46afc\",\"uuid\":\"ee1eaef2-ffb9-40e0-957f-cb47ada92c4e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":2254,\"end\":2255}},{\"type\":\"text\",\"text\":\"voidness\",\"attrs\":{\"start\":2255,\"end\":2263},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e74ef65c-8fc8-4dbf-9bba-7326d6b5d34d\",\"uuid\":\"420bc0ca-3cff-4cfc-9e24-83824a7bc4f7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"?\",\"attrs\":{\"start\":2263,\"end\":2264}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"8ead764f-b82a-4a90-be3a-64e35ba4e7f3\",\"sort\":10076,\"type\":\"endnotes\",\"label\":\"n.37\",\"alignments\":{},\"references\":[{\"content\":\"“A bodhisattva’s buddhafield is a field of virtuous application. When he attains enlightenment, living beings who live by all virtuous principles will be born in his buddhafield. “A bodhisattva’s buddhafield is the magnificence of the conception of the spirit of enlightenment. When he attains enlightenment, living beings who are actually participating in the Mahāyāna will be born in his buddhafield.\",\"label\":\"1.36\",\"sort\":1324,\"type\":\"translation\",\"uuid\":\"cd54f16e-6817-4276-a341-11a82b162b4a\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-75\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":206,\"uuid\":\"8ead764f-b82a-4a90-be3a-64e35ba4e7f3\"},\"content\":[{\"type\":\"text\",\"text\":\"X changes the order of these four to conception, \",\"attrs\":{\"start\":0,\"end\":49}},{\"type\":\"text\",\"text\":\"positive thought\",\"attrs\":{\"start\":49,\"end\":65},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e2d62fe8-36f7-47bd-9cda-305b2c1b66eb\",\"uuid\":\"c21971c9-3cbe-4df8-a251-fcc509ece352\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", virtuous application, and \",\"attrs\":{\"start\":65,\"end\":93}},{\"type\":\"text\",\"text\":\"high resolve\",\"attrs\":{\"start\":93,\"end\":105},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9e965ab3-84e2-4b05-873f-324b2f5ca383\",\"uuid\":\"458cb2a6-90f3-45ec-84fb-cfc4c9687055\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Either order is quite acceptable, since the four work together throughout the \",\"attrs\":{\"start\":105,\"end\":185}},{\"type\":\"text\",\"text\":\"bodhisattva\",\"attrs\":{\"start\":185,\"end\":196},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c72eb4f3-700e-454d-996e-5ccdba29e6be\",\"uuid\":\"faa578e9-445a-456a-bf6e-fda164aea2d3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s career.\",\"attrs\":{\"start\":196,\"end\":206}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"676f54dd-ec1a-4b4b-9ace-4f48062cd743\",\"sort\":10084,\"type\":\"endnotes\",\"label\":\"n.38\",\"alignments\":{},\"references\":[{\"content\":\"“A bodhisattva’s buddhafield consists of his personal observance of the basic precepts and his restraint in blaming others for their transgressions. When he attains enlightenment, even the word ‘crime’ will never be mentioned in his buddhafield. “A bodhisattva’s buddhafield is the purity of the path of the ten virtues. When he attains enlightenment, living beings who are secure in long life, great in wealth, chaste in conduct, enhanced by true speech, soft-spoken, free of divisive intrigues and adroit in reconciling factions, enlightening in their conversations, free of envy, free of malice, and endowed with perfect views will be born in his buddhafield.\",\"label\":\"1.43\",\"sort\":1499,\"type\":\"translation\",\"uuid\":\"db143765-0a0c-4ae2-b365-44d4176dcbeb\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-82\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":341,\"uuid\":\"676f54dd-ec1a-4b4b-9ace-4f48062cd743\"},\"content\":[{\"type\":\"text\",\"text\":\"This phrase is taken from K (it is absent in Tib., Skt. and X) because it rounds out the list of \",\"attrs\":{\"start\":0,\"end\":97}},{\"type\":\"text\",\"text\":\"ten virtues\",\"attrs\":{\"start\":97,\"end\":108},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c3747e64-0286-4485-9ae2-6c8123a8cdc6\",\"uuid\":\"0c5a66a5-5788-44a3-88ae-18b4977110e5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", being the counterpart of the sin known as “frivolous speech.” “Free of divisive intrigues and adroit in reconciling factions” basically describes one virtue, the opposite of “backbiting” (see glossary “\",\"attrs\":{\"start\":108,\"end\":312}},{\"type\":\"text\",\"text\":\"ten sins\",\"attrs\":{\"start\":312,\"end\":320},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a4e54557-1252-4772-8e09-48968f0d335a\",\"uuid\":\"0c737592-e7c0-4c05-b7de-76e93759391f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"” and “\",\"attrs\":{\"start\":320,\"end\":327}},{\"type\":\"text\",\"text\":\"ten virtues\",\"attrs\":{\"start\":327,\"end\":338},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c3747e64-0286-4485-9ae2-6c8123a8cdc6\",\"uuid\":\"d7cb5221-b4d4-4617-897d-0bf3f890005e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"”).\",\"attrs\":{\"start\":338,\"end\":341}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"4b350533-21c5-4fec-949e-ef653d7e1c54\",\"sort\":10092,\"type\":\"endnotes\",\"label\":\"n.39\",\"alignments\":{},\"references\":[{\"content\":\"“Thus, noble son, just as is the bodhisattva’s production of the spirit of enlightenment, so is his positive thought. And just as is his positive thought, so is his virtuous application. “His virtuous application is tantamount to his high resolve; his high resolve is tantamount to his determination; his determination is tantamount to his practice; his practice is tantamount to his total dedication; his total dedication is tantamount to his liberative art; his liberative art is tantamount to his development of living beings; and his development of living beings is tantamount to the purity of his buddhafield.\",\"label\":\"1.44\",\"sort\":1530,\"type\":\"translation\",\"uuid\":\"36a38ed2-d1a7-4061-b9e4-4f5d42f46a44\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-83\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":239,\"uuid\":\"4b350533-21c5-4fec-949e-ef653d7e1c54\"},\"content\":[{\"type\":\"text\",\"text\":\"This step of “development…” is included in the progression by both K and X, and, since it makes more explicit the transition from liberative technique to the \",\"attrs\":{\"start\":0,\"end\":158}},{\"type\":\"text\",\"text\":\"buddhafield\",\"attrs\":{\"start\":158,\"end\":169},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1e5e85e8-4767-46b1-874e-5f1396a67ee6\",\"uuid\":\"ad279ee1-31e7-4b7c-8625-1e600b322d4a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" itself, we have included it (although it is absent in Tib. and Skt.).\",\"attrs\":{\"start\":169,\"end\":239}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"30a1373d-cb1d-4f45-9b73-63e3af35597b\",\"sort\":10097,\"type\":\"endnotes\",\"label\":\"n.40\",\"alignments\":{},\"references\":[{\"content\":\"Thereupon, magically influenced by the Buddha, the venerable Śāriputra had this thought: “If the buddhafield is pure only to the extent that the mind of the bodhisattva is pure, then, when Śākyamuni Buddha was engaged in the career of the bodhisattva, his mind must have been impure. Otherwise, how could this buddhafield appear to be so impure?”\",\"label\":\"1.46\",\"sort\":1571,\"type\":\"translation\",\"uuid\":\"4c284176-88e1-4e2c-94ec-087c59b12378\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-85\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":890,\"uuid\":\"30a1373d-cb1d-4f45-9b73-63e3af35597b\"},\"content\":[{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":0,\"end\":9},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4da7d125-a1b8-4820-b50f-9de69a2ab346\",\"uuid\":\"a431affa-8e60-42dc-884c-35b69d78fb0e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" was one of the foremost disciples of the \",\"attrs\":{\"start\":9,\"end\":51}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":51,\"end\":57},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"d9ba73df-aec0-4f54-9148-b8fd3aec6c21\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", especially renowned in \",\"attrs\":{\"start\":57,\"end\":82}},{\"type\":\"text\",\"text\":\"Disciple Vehicle\",\"attrs\":{\"start\":82,\"end\":98},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cc35d4b8-9151-485e-9199-cf5d9d646538\",\"uuid\":\"b452dcab-b9da-4ec2-8dac-0cd2b4f96977\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" texts for his \",\"attrs\":{\"start\":98,\"end\":113}},{\"type\":\"text\",\"text\":\"wisdom\",\"attrs\":{\"start\":113,\"end\":119},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"38971298-6f62-48f0-b271-36261568d441\",\"uuid\":\"750d369a-2def-415f-83de-3926ac8c6596\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"; he was called “foremost of the wise” (\",\"attrs\":{\"start\":119,\"end\":159}},{\"type\":\"text\",\"text\":\"prajñāvatām agrya\",\"attrs\":{\"start\":159,\"end\":176},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":159,\"end\":176,\"uuid\":\"a81df7fb-c43f-465b-8b3c-a23e8f8aae35\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"). In this \",\"attrs\":{\"start\":176,\"end\":187}},{\"type\":\"text\",\"text\":\"sūtra\",\"attrs\":{\"start\":187,\"end\":192},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c65438ed-99d8-45cc-bc87-72f8f617eea5\",\"uuid\":\"d7da4f75-e7b6-451b-97cf-8f214438b668\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", as well as in other \",\"attrs\":{\"start\":192,\"end\":214}},{\"type\":\"text\",\"text\":\"Mahāyāna\",\"attrs\":{\"start\":214,\"end\":222},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"99607e52-e246-4905-b531-6e6d7ccfd7b7\",\"uuid\":\"63737577-14f1-43e5-be9e-904b1ef5c159\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":222,\"end\":223}},{\"type\":\"text\",\"text\":\"sūtras\",\"attrs\":{\"start\":223,\"end\":229},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c65438ed-99d8-45cc-bc87-72f8f617eea5\",\"uuid\":\"9f4d4b59-cb4f-4fb8-8844-cb388281107f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", he becomes the “fall guy” par excellence, as he is often inclined to express the \",\"attrs\":{\"start\":229,\"end\":312}},{\"type\":\"text\",\"text\":\"Disciple Vehicle\",\"attrs\":{\"start\":312,\"end\":328},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cc35d4b8-9151-485e-9199-cf5d9d646538\",\"uuid\":\"e3b22863-a6a0-4dba-927f-20e79a750040\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" point of \",\"attrs\":{\"start\":328,\"end\":338}},{\"type\":\"text\",\"text\":\"view\",\"attrs\":{\"start\":338,\"end\":342},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"706840df-0c20-4c5d-94a4-6b4383506ee4\",\"uuid\":\"9d497612-1ea8-49e9-85e2-c2032c0fcdaf\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", which is then roundly rejected by the \",\"attrs\":{\"start\":342,\"end\":382}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":382,\"end\":388},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"543c5955-1f06-4456-ae84-ff77bfcf726c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", by \",\"attrs\":{\"start\":388,\"end\":393}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":393,\"end\":404},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"df04034b-afad-4c03-9808-6acadcac596c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", or by one of the \",\"attrs\":{\"start\":404,\"end\":423}},{\"type\":\"text\",\"text\":\"bodhisattvas\",\"attrs\":{\"start\":423,\"end\":435},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c72eb4f3-700e-454d-996e-5ccdba29e6be\",\"uuid\":\"179fea31-965b-447d-b5fb-b98e0e650998\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". In fairness to him, it is often noted that the petty thoughts that arise in his mind, for which he is severely criticized, are caused to arise there by the magical influence of the \",\"attrs\":{\"start\":435,\"end\":618}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":618,\"end\":624},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"5ddbff65-87cb-4cef-baab-8f69c0856dba\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" or of \",\"attrs\":{\"start\":624,\"end\":631}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":631,\"end\":642},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"03f43d3a-0eff-4240-8c46-22cfd25e79ed\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", so that a thought that may be entertained by numerous members of the assembly may be brought into the open and rejected. He serves therefore as an archetype of the disciple personality and need not be condemned as exceptionally obtuse personally.\",\"attrs\":{\"start\":642,\"end\":890}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"5f6e822c-64f4-4023-955b-fd9eb14caf14\",\"sort\":10128,\"type\":\"endnotes\",\"label\":\"n.41\",\"alignments\":{},\"references\":[{\"content\":\"Thereby, thirty-two thousand living beings purified their immaculate, undistorted Dharma-eye in regard to all things. The eight thousand bhikṣus were liberated from their mental defilements, attaining the state of nongrasping. And the eighty-four thousand living beings who were devoted to the grandeur of the buddhafield, having understood that all things are by nature but magical creations, all conceived in their own minds the spirit of unexcelled, totally perfect enlightenment.\",\"label\":\"1.56\",\"sort\":1753,\"type\":\"translation\",\"uuid\":\"0469a0cd-b8e5-4b38-86e4-7300ceec1e9f\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-95\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":57,\"uuid\":\"5f6e822c-64f4-4023-955b-fd9eb14caf14\"},\"content\":[{\"type\":\"text\",\"text\":\"See glossary “\",\"attrs\":{\"start\":0,\"end\":14}},{\"type\":\"text\",\"text\":\"conception of the spirit of enlightenment\",\"attrs\":{\"start\":14,\"end\":55},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2eb83d5b-bb6f-440e-afdb-f8f67ee62aec\",\"uuid\":\"ad683b52-a940-4fab-8772-32f6e9b8a71c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".”\",\"attrs\":{\"start\":55,\"end\":57}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"07dda027-0666-4a64-8331-4b3f412502bc\",\"sort\":10132,\"type\":\"endnotes\",\"label\":\"n.42\",\"alignments\":{},\"references\":[{\"content\":\"His wealth was inexhaustible for the purpose of sustaining the poor and the helpless. He observed a pure morality in order to protect the immoral. He maintained tolerance and self-control in order to reconcile beings who were angry, cruel, violent, and brutal. He blazed with energy in order to inspire people who were lazy. He maintained concentration, mindfulness, and meditation in order to sustain the mentally troubled. He attained decisive wisdom in order to sustain the foolish.\",\"label\":\"2.2\",\"sort\":1807,\"type\":\"translation\",\"uuid\":\"2956f6fb-5a6c-453c-91c1-9f922fce28a1\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-97\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":68,\"uuid\":\"07dda027-0666-4a64-8331-4b3f412502bc\"},\"content\":[{\"type\":\"text\",\"text\":\"Thus, his conduct and knowledge conformed to the six transcendences.\",\"attrs\":{\"start\":0,\"end\":68}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"ee3a8500-15b3-4d2d-a58e-c8e270851117\",\"sort\":10134,\"type\":\"endnotes\",\"label\":\"n.43\",\"alignments\":{},\"references\":[{\"content\":\"He wore the white clothes of the layman, yet lived impeccably like a religious devotee. He lived at home, but remained aloof from the realm of desire, the realm of pure matter, and the immaterial realm. He had a son, a wife, and female attendants, yet always maintained continence. He appeared to be surrounded by servants, yet lived in solitude. He appeared to be adorned with ornaments, yet always was endowed with the auspicious signs and marks. He seemed to eat and drink, yet always took nourishment from the taste of meditation. He made his appearance at the fields of sports and in the casinos, but his aim was always to mature those people who were attached to games and gambling. He visited the fashionable outsider teachers, yet always kept unswerving loyalty to the Buddha. He understood the mundane and transcendental sciences and esoteric practices, yet always took pleasure in the delights of the Dharma. He mixed in all crowds, yet was respected as foremost of all.\",\"label\":\"2.3\",\"sort\":1822,\"type\":\"translation\",\"uuid\":\"480c72bb-2dd9-4d9b-8f4b-66abc7c5d444\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-1\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":235,\"uuid\":\"ee3a8500-15b3-4d2d-a58e-c8e270851117\"},\"content\":[{\"type\":\"text\",\"text\":\"Tib. \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"’jig rten dang ’jig rten las ’das pa’i gsang sngags dang bstan bcos\",\"attrs\":{\"start\":5,\"end\":72},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":5,\"end\":72,\"uuid\":\"9ad04356-73a6-48f0-b451-0ede061c585d\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"; Skt. \",\"attrs\":{\"start\":72,\"end\":79}},{\"type\":\"text\",\"text\":\"laukika­lokottara­mantra­śāstra\",\"attrs\":{\"start\":79,\"end\":110},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":79,\"end\":110,\"uuid\":\"02811cb3-5da3-4df1-8fb6-fd5e098afbdd\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\". This is a possible reference to tantric practices, but it is missing in both K and X, who mention only “mundane practices.”\",\"attrs\":{\"start\":110,\"end\":235}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"fcb6fa1c-d444-4e3d-9eb5-38b002ba8723\",\"sort\":10141,\"type\":\"endnotes\",\"label\":\"n.44\",\"alignments\":{},\"references\":[{\"content\":\"He wore the white clothes of the layman, yet lived impeccably like a religious devotee. He lived at home, but remained aloof from the realm of desire, the realm of pure matter, and the immaterial realm. He had a son, a wife, and female attendants, yet always maintained continence. He appeared to be surrounded by servants, yet lived in solitude. He appeared to be adorned with ornaments, yet always was endowed with the auspicious signs and marks. He seemed to eat and drink, yet always took nourishment from the taste of meditation. He made his appearance at the fields of sports and in the casinos, but his aim was always to mature those people who were attached to games and gambling. He visited the fashionable outsider teachers, yet always kept unswerving loyalty to the Buddha. He understood the mundane and transcendental sciences and esoteric practices, yet always took pleasure in the delights of the Dharma. He mixed in all crowds, yet was respected as foremost of all.\",\"label\":\"2.3\",\"sort\":1822,\"type\":\"translation\",\"uuid\":\"480c72bb-2dd9-4d9b-8f4b-66abc7c5d444\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-1\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":95,\"uuid\":\"fcb6fa1c-d444-4e3d-9eb5-38b002ba8723\"},\"content\":[{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":0,\"end\":11},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"c57b8c3e-8065-426d-be8d-1dc771a4f959\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is here shown as the embodiment of the practice of “\",\"attrs\":{\"start\":11,\"end\":64}},{\"type\":\"text\",\"text\":\"reconciliation of dichotomies\",\"attrs\":{\"start\":64,\"end\":93},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b1f05db9-7380-4a8c-b8c2-ff2145a720b9\",\"uuid\":\"1903984f-364a-4a3f-b74f-32eb6d544a2f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".”\",\"attrs\":{\"start\":93,\"end\":95}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"77d62825-ba77-41ca-9349-1a70ae6c7e96\",\"sort\":10146,\"type\":\"endnotes\",\"label\":\"n.45\",\"alignments\":{},\"references\":[{\"content\":\"In order to be in harmony with people, he associated with elders, with those of middle age, and with the young, yet always spoke in harmony with the Dharma. He engaged in all sorts of businesses, yet had no interest in profit or possessions. To educate living beings, he would appear at crossroads and on street corners, and to protect them he participated in government. To turn people away from the Individual Vehicle and to engage them in the Mahāyāna, he appeared among listeners and teachers of the Dharma. To develop children, he visited all the schools. To demonstrate the evils of desire, he even entered the brothels. To establish drunkards in correct mindfulness, he entered all the drinking-houses.\",\"label\":\"2.4\",\"sort\":1847,\"type\":\"translation\",\"uuid\":\"0eb036e3-a9e2-4ac9-92a8-625c4fbd1ca4\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-98\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":35,\"uuid\":\"77d62825-ba77-41ca-9349-1a70ae6c7e96\"},\"content\":[{\"type\":\"text\",\"text\":\"This sentence is absent in K and X.\",\"attrs\":{\"start\":0,\"end\":35}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"c264bea5-4b84-4e6f-893a-1042fa08b346\",\"sort\":10148,\"type\":\"endnotes\",\"label\":\"n.46\",\"alignments\":{},\"references\":[{\"content\":\"He was honored as the merchant among merchants because he demonstrated the priority of the Dharma. He was honored as the landlord among landlords because he renounced the aggressiveness of ownership. He was honored as the warrior among warriors because he cultivated endurance, determination, and fortitude. He was honored as the brahmin among brahmins because he suppressed pride, vanity, and arrogance. He was honored as the official among officials because he regulated the functions of government according to the Dharma. He was honored as the prince of princes because he reversed their attachment to royal pleasures and sovereign power. He was honored as a chamberlain in the royal harem because he brought the young ladies to spiritual maturity.\",\"label\":\"2.5\",\"sort\":1861,\"type\":\"translation\",\"uuid\":\"1bd64ef4-fc53-488a-8f31-d4605b708f9d\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-99\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":96,\"uuid\":\"c264bea5-4b84-4e6f-893a-1042fa08b346\"},\"content\":[{\"type\":\"text\",\"text\":\"Both K and X have, instead of this phrase, “because he taught them loyalty and filial devotion.”\",\"attrs\":{\"start\":0,\"end\":96}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"4fd37947-740d-4665-8adf-56eb78615009\",\"sort\":10150,\"type\":\"endnotes\",\"label\":\"n.47\",\"alignments\":{},\"references\":[{\"content\":\"He was compatible with ordinary people because he appreciated the excellence of ordinary merits. He was honored as the Śakra among Śakras because he showed them the temporality of their lordship. He was honored as the Brahmā among Brahmās because he showed them the special excellence of gnosis. He was honored as the Lokapāla among Lokapālas because he fostered the development of all living beings. Thus lived the Licchavi Vimalakīrti in the great city of Vaiśālī, endowed with an infinite knowledge of skill in liberative arts.\",\"label\":\"2.6\",\"sort\":1869,\"type\":\"translation\",\"uuid\":\"3994e359-f36e-4324-adfa-dba3e88937ee\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-100\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":196,\"uuid\":\"4fd37947-740d-4665-8adf-56eb78615009\"},\"content\":[{\"type\":\"text\",\"text\":\"Tib. \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"mi rtag par\",\"attrs\":{\"start\":5,\"end\":16},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":5,\"end\":16,\"uuid\":\"389c7d55-0f44-4e03-add4-d7b751c51303\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" is missing, but supplied by Lamotte (p 130) from the Dunhuang fragments, and also from K and X; it is supported, too, by the Sanskrit manuscript (\",\"attrs\":{\"start\":16,\"end\":163}},{\"type\":\"text\",\"text\":\"aiśvaryānityatva­saṃ­darśanāyau\",\"attrs\":{\"start\":163,\"end\":194},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":163,\"end\":194,\"uuid\":\"21b8d22c-4e01-462d-be29-b6e330a71764\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\").\",\"attrs\":{\"start\":194,\"end\":196}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"b345fefb-5ac0-49a1-965f-4188b6275ee3\",\"sort\":10156,\"type\":\"endnotes\",\"label\":\"n.48\",\"alignments\":{},\"references\":[{\"content\":\"“Friends, this body is so impermanent, fragile, unworthy of confidence, and feeble. It is so insubstantial, perishable, short-lived, painful, filled with diseases, and subject to changes. Thus, my friends, as this body is only a vessel of many sicknesses, wise men do not rely on it. This body is like a ball of foam, unable to bear any pressure. It is like a water bubble, not remaining very long. It is like a mirage, born from the appetites of the passions. It is like the trunk of the plantain tree, having no core. Alas! This body is like a machine, a nexus of bones and tendons. It is like a magical illusion, consisting of falsifications. It is like a dream, being an unreal vision. It is like a reflection, being the image of former actions. It is like an echo, being dependent on conditioning. It is like a cloud, being characterized by turbulence and dissolution. It is like a flash of lightning, being unstable, and decaying every moment. The body is ownerless, being the product of a variety of conditions.\",\"label\":\"2.8\",\"sort\":1914,\"type\":\"translation\",\"uuid\":\"654a6a8a-e2c7-4f95-88cb-51fed15ab589\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-102\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":365,\"uuid\":\"b345fefb-5ac0-49a1-965f-4188b6275ee3\"},\"content\":[{\"type\":\"text\",\"text\":\"These similes are famous in the \",\"attrs\":{\"start\":0,\"end\":32}},{\"type\":\"text\",\"text\":\"Disciple Vehicle\",\"attrs\":{\"start\":32,\"end\":48},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cc35d4b8-9151-485e-9199-cf5d9d646538\",\"uuid\":\"901260cb-e8d5-416a-abe8-40efffb20221\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" as well as \",\"attrs\":{\"start\":48,\"end\":60}},{\"type\":\"text\",\"text\":\"Mahāyāna\",\"attrs\":{\"start\":60,\"end\":68},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"99607e52-e246-4905-b531-6e6d7ccfd7b7\",\"uuid\":\"c7c597f3-9f76-41ac-b0e8-0e4cb983d7e3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". The fact of their presence in \",\"attrs\":{\"start\":68,\"end\":100}},{\"type\":\"text\",\"text\":\"Disciple Vehicle\",\"attrs\":{\"start\":100,\"end\":116},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cc35d4b8-9151-485e-9199-cf5d9d646538\",\"uuid\":\"11b4bafc-6c2e-46d4-9e01-370021ae08f7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" teachings was used by Prāṡangika philosophers such as \",\"attrs\":{\"start\":116,\"end\":171}},{\"type\":\"text\",\"text\":\"Buddhapālita\",\"attrs\":{\"start\":171,\"end\":183},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cfcbf167-1d29-491e-a45c-50dc1ab792ec\",\"uuid\":\"4d29bf9b-2d7f-495c-96a1-1601be79a97c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and \",\"attrs\":{\"start\":183,\"end\":188}},{\"type\":\"text\",\"text\":\"Candrakīrti\",\"attrs\":{\"start\":188,\"end\":199},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"42824ff1-0d92-401f-b331-ea16963f07b4\",\"uuid\":\"125ecfb4-c4b4-47f3-ad56-685453b5b0c3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", to prove that insubstantiality or selflessness of phenomena (\",\"attrs\":{\"start\":199,\"end\":262}},{\"type\":\"text\",\"text\":\"dharma­nairātmyā\",\"attrs\":{\"start\":262,\"end\":278},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":262,\"end\":278,\"uuid\":\"31e25215-b53d-4625-a821-eb0b552615b9\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\") was taught in the \",\"attrs\":{\"start\":278,\"end\":298}},{\"type\":\"text\",\"text\":\"Disciple Vehicle\",\"attrs\":{\"start\":298,\"end\":314},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cc35d4b8-9151-485e-9199-cf5d9d646538\",\"uuid\":\"78757f01-0beb-4aa7-9e80-6a2dc5eb214f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". For further references, see Lamotte, p 132, n 23.\",\"attrs\":{\"start\":314,\"end\":365}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"fc7ff723-e051-46b7-b84d-18d63596c136\",\"sort\":10172,\"type\":\"endnotes\",\"label\":\"n.49\",\"alignments\":{},\"references\":[{\"content\":\"“This body is inert, like the earth; selfless, like water; lifeless, like fire; impersonal, like the wind; and nonsubstantial, like space. This body is unreal, being a collocation of the four main elements. It is void, not existing as self or as self-possessed. It is inanimate, being like grass, trees, walls, clods of earth, and illusions. It is insensate, being driven like a windmill. It is filthy, being an agglomeration of pus and excrement. It is false, being fated to be broken and destroyed, in spite of being anointed and massaged. It is afflicted by the four hundred and four diseases. It is like an ancient well, constantly overwhelmed by old age. Its duration is never certain‍—certain only is its end in death. This body is a combination of aggregates, elements, and sense-media, which are comparable to murderers, poisonous snakes, and an empty town, respectively. Therefore, you should be repelled by such a body. You should despair of it and should arouse your admiration for the body of the Tathāgata.\",\"label\":\"2.9\",\"sort\":1920,\"type\":\"translation\",\"uuid\":\"64e240a1-76bf-4029-b1a3-8df275d06976\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-103\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":546,\"uuid\":\"fc7ff723-e051-46b7-b84d-18d63596c136\"},\"content\":[{\"type\":\"text\",\"text\":\"According to Lamotte, the four hundred and four diseases are classified with one hundred and one arising from each of four primary \",\"attrs\":{\"start\":0,\"end\":131}},{\"type\":\"text\",\"text\":\"elements\",\"attrs\":{\"start\":131,\"end\":139},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"dbc4a2e4-dbc7-475b-8ed0-c63412da4b68\",\"uuid\":\"9303201e-c100-4812-b834-5fa796950655\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". But according to the “eight branches” (\",\"attrs\":{\"start\":139,\"end\":180}},{\"type\":\"text\",\"text\":\"aṣṭāṇga\",\"attrs\":{\"start\":180,\"end\":187},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":180,\"end\":187,\"uuid\":\"cd664b8a-584f-487f-b72c-552958828417\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\") of Indian and Tibetan medicine, they arise from the three humors, \",\"attrs\":{\"start\":187,\"end\":255}},{\"type\":\"text\",\"text\":\"vāta\",\"attrs\":{\"start\":255,\"end\":259},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":255,\"end\":259,\"uuid\":\"97634f23-f8c5-4943-878f-77e5aff277fe\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":259,\"end\":261}},{\"type\":\"text\",\"text\":\"pitta\",\"attrs\":{\"start\":261,\"end\":266},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":261,\"end\":266,\"uuid\":\"9d511781-6eb7-4980-84b1-7055e30bca42\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", and \",\"attrs\":{\"start\":266,\"end\":272}},{\"type\":\"text\",\"text\":\"kapha\",\"attrs\":{\"start\":272,\"end\":277},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":272,\"end\":277,\"uuid\":\"245174da-db1f-4c87-8696-ae70172b6599\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" (vital airs, bile, and phlegm, Tib. \",\"attrs\":{\"start\":277,\"end\":314}},{\"type\":\"text\",\"text\":\"rlung mkhris bad kan gsum\",\"attrs\":{\"start\":314,\"end\":339},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":314,\"end\":339,\"uuid\":\"1df876f2-8fae-40ea-8bab-0288c62f2ec5\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"), when their balance becomes disturbed: i.e., one hundred and one from airs, one hundred and one from bile, one hundred and one from phlegm, and one hundred and one from unhealthy combinations of all three.\",\"attrs\":{\"start\":339,\"end\":546}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"563ed2e9-753d-4b0b-8ec5-1facb86e7906\",\"sort\":10186,\"type\":\"endnotes\",\"label\":\"n.50\",\"alignments\":{},\"references\":[{\"content\":\"“This body is inert, like the earth; selfless, like water; lifeless, like fire; impersonal, like the wind; and nonsubstantial, like space. This body is unreal, being a collocation of the four main elements. It is void, not existing as self or as self-possessed. It is inanimate, being like grass, trees, walls, clods of earth, and illusions. It is insensate, being driven like a windmill. It is filthy, being an agglomeration of pus and excrement. It is false, being fated to be broken and destroyed, in spite of being anointed and massaged. It is afflicted by the four hundred and four diseases. It is like an ancient well, constantly overwhelmed by old age. Its duration is never certain‍—certain only is its end in death. This body is a combination of aggregates, elements, and sense-media, which are comparable to murderers, poisonous snakes, and an empty town, respectively. Therefore, you should be repelled by such a body. You should despair of it and should arouse your admiration for the body of the Tathāgata.\",\"label\":\"2.9\",\"sort\":1920,\"type\":\"translation\",\"uuid\":\"64e240a1-76bf-4029-b1a3-8df275d06976\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-103\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":189,\"uuid\":\"563ed2e9-753d-4b0b-8ec5-1facb86e7906\"},\"content\":[{\"type\":\"text\",\"text\":\"Comparison of these three fundamental classifications of the psychophysical \",\"attrs\":{\"start\":0,\"end\":76}},{\"type\":\"text\",\"text\":\"elements\",\"attrs\":{\"start\":76,\"end\":84},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"dbc4a2e4-dbc7-475b-8ed0-c63412da4b68\",\"uuid\":\"81f7844e-45cb-4038-a9af-af2b28de93bc\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of a person to murderers, snakes, and an empty town is traditional. See \",\"attrs\":{\"start\":84,\"end\":157}},{\"type\":\"text\",\"text\":\"n.102\",\"attrs\":{\"start\":157,\"end\":162},\"marks\":[{\"type\":\"internalLink\",\"attrs\":{\"uuid\":\"7782f073-0102-40c6-bc11-823e323f015c\",\"href\":\"/entity/passage/91fe95c3-51ee-4319-89b4-726c726061ec\",\"entity\":\"91fe95c3-51ee-4319-89b4-726c726061ec\",\"type\":\"passage\",\"toh\":null,\"isSameWork\":true,\"subtype\":\"endnotes\"}}]},{\"type\":\"text\",\"text\":\", and Lamotte, p 136, n 28.\",\"attrs\":{\"start\":162,\"end\":189}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"05294a67-48f8-4b89-8def-e32c106109e6\",\"sort\":10192,\"type\":\"endnotes\",\"label\":\"n.51\",\"alignments\":{},\"references\":[{\"content\":\"$39\",\"label\":\"2.10\",\"sort\":1942,\"type\":\"translation\",\"uuid\":\"8fce92d2-9b04-4bcc-b9f4-a92ed26a4913\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-12\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":217,\"uuid\":\"05294a67-48f8-4b89-8def-e32c106109e6\"},\"content\":[{\"type\":\"text\",\"text\":\"Tib. has simply “born from merit and charity.” The translation here follows K. The store of merit culminates in the saṃbhogakāya, body of beatitude, and the store of \",\"attrs\":{\"start\":0,\"end\":166}},{\"type\":\"text\",\"text\":\"wisdom\",\"attrs\":{\"start\":166,\"end\":172},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"38971298-6f62-48f0-b271-36261568d441\",\"uuid\":\"5759556b-205a-4546-a734-22b3bd1b852f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" culminates in the dharmakāya, \",\"attrs\":{\"start\":172,\"end\":203}},{\"type\":\"text\",\"text\":\"ultimate\",\"attrs\":{\"start\":203,\"end\":211},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"784c8158-9e46-4484-9152-e0d06cd46afc\",\"uuid\":\"b40d16dc-a39d-4ff5-9f34-b504b0372ddb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" body.\",\"attrs\":{\"start\":211,\"end\":217}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"d5857ac0-09f6-451d-a183-b57005edba98\",\"sort\":10198,\"type\":\"endnotes\",\"label\":\"n.52\",\"alignments\":{},\"references\":[{\"content\":\"$3a\",\"label\":\"2.10\",\"sort\":1942,\"type\":\"translation\",\"uuid\":\"8fce92d2-9b04-4bcc-b9f4-a92ed26a4913\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-12\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":186,\"uuid\":\"d5857ac0-09f6-451d-a183-b57005edba98\"},\"content\":[{\"type\":\"text\",\"text\":\"Skt. \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"śīla\",\"attrs\":{\"start\":5,\"end\":9},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":5,\"end\":9,\"uuid\":\"e07d4260-44ff-44ff-9248-6506f05b3918\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":9,\"end\":11}},{\"type\":\"text\",\"text\":\"samādhi\",\"attrs\":{\"start\":11,\"end\":18},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"12140d8a-6833-4267-9463-c0922ba5a70b\",\"uuid\":\"85928531-4135-425f-9341-444885412b08\",\"toh\":null,\"start\":11,\"end\":0}},{\"type\":\"italic\",\"attrs\":{\"start\":11,\"end\":18,\"uuid\":\"69443bbf-b041-48fa-88f7-2c5f4e9e11b4\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":18,\"end\":20}},{\"type\":\"text\",\"text\":\"prajñā\",\"attrs\":{\"start\":20,\"end\":26},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":20,\"end\":26,\"uuid\":\"b3650646-d1f3-40c7-9168-25d321a86ef4\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":26,\"end\":28}},{\"type\":\"text\",\"text\":\"vimukti\",\"attrs\":{\"start\":28,\"end\":35},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":28,\"end\":35,\"uuid\":\"8b10dbdf-948b-4e0c-9c15-49b40d7b79f8\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", and \",\"attrs\":{\"start\":35,\"end\":41}},{\"type\":\"text\",\"text\":\"vimukti­jñāna­darśana\",\"attrs\":{\"start\":41,\"end\":62},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":41,\"end\":62,\"uuid\":\"b4e71f57-1439-4e40-9ae9-3b2702eef3c2\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" are the five \",\"attrs\":{\"start\":62,\"end\":76}},{\"type\":\"text\",\"text\":\"Dharma\",\"attrs\":{\"start\":76,\"end\":82},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c08db6f5-393e-4ec4-bf72-4043e53b3129\",\"uuid\":\"c2f74be3-eb5e-4123-9dc2-df4d55f0b12f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"-\",\"attrs\":{\"start\":82,\"end\":83}},{\"type\":\"text\",\"text\":\"aggregates\",\"attrs\":{\"start\":83,\"end\":93},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"95840062-0b03-40c7-ad24-49f28628a43e\",\"uuid\":\"f49cbe71-908f-45a3-8dab-630939a01916\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", or pure \",\"attrs\":{\"start\":93,\"end\":103}},{\"type\":\"text\",\"text\":\"aggregates\",\"attrs\":{\"start\":103,\"end\":113},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"95840062-0b03-40c7-ad24-49f28628a43e\",\"uuid\":\"4318f977-d795-4e34-992d-26c59ae91aed\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", or members of the \",\"attrs\":{\"start\":113,\"end\":133}},{\"type\":\"text\",\"text\":\"Dharma\",\"attrs\":{\"start\":133,\"end\":139},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c08db6f5-393e-4ec4-bf72-4043e53b3129\",\"uuid\":\"08cbb78e-08e9-4584-8b5c-fd313de2944d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"-body of the \",\"attrs\":{\"start\":139,\"end\":152}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":152,\"end\":158},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"007e06d8-4de5-4b78-88d0-98e64f29ac5b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (see Lamotte, p 139, n 30).\",\"attrs\":{\"start\":158,\"end\":186}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"8ea389dc-cb09-40bb-b627-0e970948aedc\",\"sort\":10220,\"type\":\"endnotes\",\"label\":\"n.53\",\"alignments\":{},\"references\":[{\"content\":\"$3b\",\"label\":\"2.10\",\"sort\":1942,\"type\":\"translation\",\"uuid\":\"8fce92d2-9b04-4bcc-b9f4-a92ed26a4913\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-12\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":782,\"uuid\":\"8ea389dc-cb09-40bb-b627-0e970948aedc\"},\"content\":[{\"type\":\"text\",\"text\":\"These are the two main types of \",\"attrs\":{\"start\":0,\"end\":32}},{\"type\":\"text\",\"text\":\"Mahāyāna\",\"attrs\":{\"start\":32,\"end\":40},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"99607e52-e246-4905-b531-6e6d7ccfd7b7\",\"uuid\":\"deefd33f-354b-4025-96f2-96b808a7af22\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":40,\"end\":41}},{\"type\":\"text\",\"text\":\"meditation\",\"attrs\":{\"start\":41,\"end\":51},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"72ea6449-0c42-401c-bff0-be87bffdfd07\",\"uuid\":\"f3383fbc-488c-4ee3-a205-f1ad31884206\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". The former corresponds to the fifth transcendence and includes all practices that cultivate one-pointedness of mind; the latter corresponds to the sixth transcendence, especially the analytic penetration to the realization of personal selflessness (\",\"attrs\":{\"start\":51,\"end\":302}},{\"type\":\"text\",\"text\":\"pudgala­nairātmya\",\"attrs\":{\"start\":302,\"end\":319},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":302,\"end\":319,\"uuid\":\"508557f3-133b-460c-9da6-90131bcec168\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\") and phenomenal selflessness (\",\"attrs\":{\"start\":319,\"end\":350}},{\"type\":\"text\",\"text\":\"dharma­nairātmya\",\"attrs\":{\"start\":350,\"end\":366},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":350,\"end\":366,\"uuid\":\"f20f3641-338d-4574-95b7-a3e914530052\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"), or \",\"attrs\":{\"start\":366,\"end\":372}},{\"type\":\"text\",\"text\":\"voidness\",\"attrs\":{\"start\":372,\"end\":380},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e74ef65c-8fc8-4dbf-9bba-7326d6b5d34d\",\"uuid\":\"b3fa6896-600b-40f3-9bbf-8027ab1c8bc8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". The latter is not so well known as the former, which is commonly considered to be the main type of \",\"attrs\":{\"start\":380,\"end\":481}},{\"type\":\"text\",\"text\":\"meditation\",\"attrs\":{\"start\":481,\"end\":491},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"72ea6449-0c42-401c-bff0-be87bffdfd07\",\"uuid\":\"846f27c3-5914-4254-b1f9-bed2d08ab28c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\": nondiscursive, one-pointed, etc. Nevertheless, it is said frequently in both \",\"attrs\":{\"start\":491,\"end\":570}},{\"type\":\"text\",\"text\":\"sūtras\",\"attrs\":{\"start\":570,\"end\":576},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c65438ed-99d8-45cc-bc87-72f8f617eea5\",\"uuid\":\"16cfbf97-a901-461a-94d5-45b093616fd3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and commentaries that without integrated practice of both, the higher stages of \",\"attrs\":{\"start\":576,\"end\":657}},{\"type\":\"text\",\"text\":\"enlightenment\",\"attrs\":{\"start\":657,\"end\":670},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"62f923c5-8dfa-4620-8dec-7bb032231bf7\",\"uuid\":\"b553e2d8-438a-4691-8a4a-209a62486474\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" will not be attained. For more details, see glossary (under “\",\"attrs\":{\"start\":670,\"end\":732}},{\"type\":\"text\",\"text\":\"mental quiescence\",\"attrs\":{\"start\":732,\"end\":749},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5e339443-19eb-4ac1-8ec2-9c364443dd1c\",\"uuid\":\"7637d4ff-96b6-4a7f-a53d-ddbd242905eb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"” and “\",\"attrs\":{\"start\":749,\"end\":756}},{\"type\":\"text\",\"text\":\"transcendental analysis\",\"attrs\":{\"start\":756,\"end\":779},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"6cf08752-1b1f-4a66-a9c7-a593246c380d\",\"uuid\":\"75938a65-e678-4281-a13c-9336c36bbcb7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"”).\",\"attrs\":{\"start\":779,\"end\":782}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"0a7f2cc2-9e9c-47fb-8f4a-9efdb888535e\",\"sort\":10242,\"type\":\"endnotes\",\"label\":\"n.54\",\"alignments\":{},\"references\":[{\"content\":\"$3c\",\"label\":\"2.10\",\"sort\":1942,\"type\":\"translation\",\"uuid\":\"8fce92d2-9b04-4bcc-b9f4-a92ed26a4913\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-12\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":154,\"uuid\":\"0a7f2cc2-9e9c-47fb-8f4a-9efdb888535e\"},\"content\":[{\"type\":\"text\",\"text\":\"Degé has \",\"attrs\":{\"start\":0,\"end\":9}},{\"type\":\"text\",\"text\":\"dben pa\",\"attrs\":{\"start\":9,\"end\":16},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":9,\"end\":16,\"uuid\":\"a2ff438c-2e5b-49bd-b095-4684d2eee641\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", isolation, but most of the other Kangyurs (including the Stok Palace) have \",\"attrs\":{\"start\":16,\"end\":93}},{\"type\":\"text\",\"text\":\"bden pa\",\"attrs\":{\"start\":93,\"end\":100},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":93,\"end\":100,\"uuid\":\"67d61353-20ae-4ed7-8c5f-263547c39392\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", truth, and this is confirmed by the Sanskrit, \",\"attrs\":{\"start\":100,\"end\":148}},{\"type\":\"text\",\"text\":\"satya\",\"attrs\":{\"start\":148,\"end\":153},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":148,\"end\":153,\"uuid\":\"9d2e0cb1-1377-47c1-965e-d01a3882eb2a\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":153,\"end\":154}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"bbaa6795-e203-4bf8-93c1-8611bd9ab06c\",\"sort\":10250,\"type\":\"endnotes\",\"label\":\"n.55\",\"alignments\":{},\"references\":[{\"content\":\"$3d\",\"label\":\"3.2\",\"sort\":2037,\"type\":\"translation\",\"uuid\":\"bb91a32a-9d2e-432a-85a6-c39b639408e7\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-107\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":697,\"uuid\":\"bbaa6795-e203-4bf8-93c1-8611bd9ab06c\"},\"content\":[{\"type\":\"text\",\"text\":\"Skt. \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"utsāhate\",\"attrs\":{\"start\":5,\"end\":13},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":5,\"end\":13,\"uuid\":\"32e5cbdf-5a29-4a98-b857-ca555e587d6b\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\". This has been translated most frequently in its meaning of “fitness, capacity,” as each of the monks and \",\"attrs\":{\"start\":13,\"end\":120}},{\"type\":\"text\",\"text\":\"bodhisattvas\",\"attrs\":{\"start\":120,\"end\":132},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c72eb4f3-700e-454d-996e-5ccdba29e6be\",\"uuid\":\"86673b59-cd08-490b-8b04-a1021a67a755\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" asked by the \",\"attrs\":{\"start\":132,\"end\":146}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":146,\"end\":152},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"7c4846f9-0fc7-46a9-bde8-1a919288d75f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" to visit \",\"attrs\":{\"start\":152,\"end\":162}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":162,\"end\":173},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"212e7d3a-b6aa-48e8-8e8e-d07b087c4d17\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" replies with the same phrase: “I am not fit…” or “I am not able…” However, from the Tibetan use of the word \",\"attrs\":{\"start\":173,\"end\":282}},{\"type\":\"text\",\"text\":\"spro ba\",\"attrs\":{\"start\":282,\"end\":289},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":282,\"end\":289,\"uuid\":\"3ac65a41-fbdc-4a27-9796-8e61b98a0527\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", which means to be enthusiastic, inspired, gladdened, I chose to interpret this in its meaning of enthusiasm, which in the negative gives “I am not enthusiastic…” or “I am reluctant….” That is, none of those asked by the \",\"attrs\":{\"start\":289,\"end\":511}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":511,\"end\":517},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"441f7c7d-410f-4eab-8b64-69dcfb3266ca\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" are actually pretending to be unable to visit \",\"attrs\":{\"start\":517,\"end\":564}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":564,\"end\":575},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"54ef20ed-1ba8-4b20-95ad-1467fe47c68e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"; they only plead their unwillingness, timidity, etc., in order to be excused by the \",\"attrs\":{\"start\":575,\"end\":660}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":660,\"end\":666},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"ef5fc602-e527-48ab-8a27-685d7a4a9915\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" from carrying out his command.\",\"attrs\":{\"start\":666,\"end\":697}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"ab58bcdd-ed89-4eec-b98a-a27405e3cead\",\"sort\":10269,\"type\":\"endnotes\",\"label\":\"n.56\",\"alignments\":{},\"references\":[{\"content\":\"$3e\",\"label\":\"3.2\",\"sort\":2037,\"type\":\"translation\",\"uuid\":\"bb91a32a-9d2e-432a-85a6-c39b639408e7\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-107\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":517,\"uuid\":\"ab58bcdd-ed89-4eec-b98a-a27405e3cead\"},\"content\":[{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":0,\"end\":11},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"5556d616-382b-4ceb-9d72-b953f93b04f1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" confounds \",\"attrs\":{\"start\":11,\"end\":22}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":22,\"end\":31},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4da7d125-a1b8-4820-b50f-9de69a2ab346\",\"uuid\":\"efb18224-e99c-40c1-a1e0-59d4a8fdf0c9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" by demanding of him the ability to reconcile dichotomies in actual practice, i.e., by rejecting \",\"attrs\":{\"start\":31,\"end\":128}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":128,\"end\":137},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4da7d125-a1b8-4820-b50f-9de69a2ab346\",\"uuid\":\"f26ffab0-abb1-4e63-aa52-9489c283c196\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s \",\"attrs\":{\"start\":137,\"end\":140}},{\"type\":\"text\",\"text\":\"Disciple Vehicle\",\"attrs\":{\"start\":140,\"end\":156},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cc35d4b8-9151-485e-9199-cf5d9d646538\",\"uuid\":\"f0db9000-25e7-4851-a85f-35437f393757\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" position and expecting him to follow the way of the \",\"attrs\":{\"start\":156,\"end\":209}},{\"type\":\"text\",\"text\":\"bodhisattva\",\"attrs\":{\"start\":209,\"end\":220},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c72eb4f3-700e-454d-996e-5ccdba29e6be\",\"uuid\":\"876fc479-a5ca-4acc-bfae-97ed4c027710\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". \",\"attrs\":{\"start\":220,\"end\":222}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":222,\"end\":231},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4da7d125-a1b8-4820-b50f-9de69a2ab346\",\"uuid\":\"f65e9b69-6383-43a2-82d2-372fed32686d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" reacts in the same way as the other monks and \",\"attrs\":{\"start\":231,\"end\":278}},{\"type\":\"text\",\"text\":\"bodhisattvas\",\"attrs\":{\"start\":278,\"end\":290},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c72eb4f3-700e-454d-996e-5ccdba29e6be\",\"uuid\":\"7b1a1455-1c26-4dbd-9ff8-b211b7f003dc\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in this chapter: he is overwhelmed and speechless, yet intuitively recognizes the rightness of \",\"attrs\":{\"start\":290,\"end\":386}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":386,\"end\":397},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"fdf7bf5d-feba-43da-b2b3-c8fd5cece799\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s statements. He can neither accept them and put them into practice nor reject them outright (see Lamotte, p 142, n 3).\",\"attrs\":{\"start\":397,\"end\":517}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"fee0655d-649d-44ce-af81-8d548fe7eb6b\",\"sort\":10287,\"type\":\"endnotes\",\"label\":\"n.57\",\"alignments\":{},\"references\":[{\"content\":\"The Buddha then said to the venerable Mahā­maudgalyāyana, “Maudgalyāyana, go to the Licchavi Vimalakīrti to inquire about his illness.” Maudgalyāyana replied, “Lord, I am indeed reluctant to go to the Licchavi Vimalakīrti to inquire about his illness. Why? I remember one day when I was teaching the Dharma to the householders in a square in the great city of Vaiśālī, and the Licchavi Vimalakīrti came along and said to me, ‘Reverend Maudgalyāyana, that is not the way to teach the Dharma to the householders in their white clothes. The Dharma must be taught according to reality.\",\"label\":\"3.4\",\"sort\":2112,\"type\":\"translation\",\"uuid\":\"b1eb9b34-6e15-40b3-b6a8-3083af29f2ba\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-109\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":570,\"uuid\":\"fee0655d-649d-44ce-af81-8d548fe7eb6b\"},\"content\":[{\"type\":\"text\",\"text\":\"Maudgalyāyana\",\"attrs\":{\"start\":0,\"end\":13},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8ae3a0a1-180a-4fc8-910a-cc2134148828\",\"uuid\":\"2ec4791c-6cb5-4bd1-9dab-f347709075b2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" was known as the “foremost of those endowed with miraculous powers” (\",\"attrs\":{\"start\":13,\"end\":83}},{\"type\":\"text\",\"text\":\"ṛddhimatāṃ agrya\",\"attrs\":{\"start\":83,\"end\":99},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":83,\"end\":99,\"uuid\":\"34fc61df-2819-4a3c-bf31-036f0b3f0341\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\") and was paired with \",\"attrs\":{\"start\":99,\"end\":121}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":121,\"end\":130},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4da7d125-a1b8-4820-b50f-9de69a2ab346\",\"uuid\":\"26c8a76b-8dc2-4c53-89ce-4dec4844cfcf\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" as one of the two leading disciples of the \",\"attrs\":{\"start\":130,\"end\":174}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":174,\"end\":180},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"00166a03-bd4e-43fe-bb6a-5265a03729bc\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". \",\"attrs\":{\"start\":180,\"end\":182}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":182,\"end\":193},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"22c15faf-9edb-4914-92d1-aade98da8698\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" chastises him basically for failing to use his “\",\"attrs\":{\"start\":193,\"end\":242}},{\"type\":\"text\",\"text\":\"wisdom\",\"attrs\":{\"start\":242,\"end\":248},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"38971298-6f62-48f0-b271-36261568d441\",\"uuid\":\"08ab8e77-f1ab-49f4-85b7-6e8980736086\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" eye,” his superknowledge of what is in others’ minds (\",\"attrs\":{\"start\":248,\"end\":303}},{\"type\":\"text\",\"text\":\"para­citta­jñāna\",\"attrs\":{\"start\":303,\"end\":319},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":303,\"end\":319,\"uuid\":\"229ca7ef-bb29-46b5-89ae-e4c9e865103c\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"), to determine that his listeners were willing and able to learn and understand the \",\"attrs\":{\"start\":319,\"end\":404}},{\"type\":\"text\",\"text\":\"Mahāyāna\",\"attrs\":{\"start\":404,\"end\":412},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"99607e52-e246-4905-b531-6e6d7ccfd7b7\",\"uuid\":\"b3462b42-7472-4d48-904a-478f1f6a3bf6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" teaching of the profound nature of reality, and for teaching them instead the \",\"attrs\":{\"start\":412,\"end\":491}},{\"type\":\"text\",\"text\":\"Disciple Vehicle\",\"attrs\":{\"start\":491,\"end\":507},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cc35d4b8-9151-485e-9199-cf5d9d646538\",\"uuid\":\"c91a9aa7-433a-4878-8365-5320ca04b972\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" teaching, with its one-sided emphasis on world-rejection, etc.\",\"attrs\":{\"start\":507,\"end\":570}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"eba9144c-afb1-4c13-bc8f-a7b71c652511\",\"sort\":10306,\"type\":\"endnotes\",\"label\":\"n.58\",\"alignments\":{},\"references\":[{\"content\":\"“ ‘The Dharma is peace and pacification, because it is free of desire. It does not become an object, because it is free of words and letters; it is inexpressible, and it transcends all movement of mind.\",\"label\":\"3.6\",\"sort\":2155,\"type\":\"translation\",\"uuid\":\"4474aa7b-62b8-4b1d-9d06-73be3b0b517f\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-111\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":94,\"uuid\":\"eba9144c-afb1-4c13-bc8f-a7b71c652511\"},\"content\":[{\"type\":\"text\",\"text\":\"Tib. \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"rlabs thams cad dang bral ba\",\"attrs\":{\"start\":5,\"end\":33},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":5,\"end\":33,\"uuid\":\"5d0bd3f0-3a5c-4f00-a2cd-060133ea67d6\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"; Skt. \",\"attrs\":{\"start\":33,\"end\":40}},{\"type\":\"text\",\"text\":\"sarvormivigata\",\"attrs\":{\"start\":40,\"end\":54},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":40,\"end\":54,\"uuid\":\"bfa38ea0-e2c4-4af1-981b-cde16ef02e19\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", lit. “free of all waves” (of thought).\",\"attrs\":{\"start\":54,\"end\":94}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"0ccf1c32-3174-4557-b9ef-faf2e58fc65e\",\"sort\":10312,\"type\":\"endnotes\",\"label\":\"n.59\",\"alignments\":{},\"references\":[{\"content\":\"“ ‘It permeates evenly all things, because all are included in the ultimate realm. It conforms to reality by means of the process of nonconformity. It abides at the reality-limit, for it is utterly without fluctuation. It is immovable, because it is independent of the six objects of sense. It is without coming and going, for it never stands still. It is comprised by voidness, it is remarkable through signlessness, and because of wishlessness it is free of presumption and repudiation. It is without establishment and rejection, without birth or destruction. It is without any fundamental consciousness, transcending the range of eye, ear, nose, tongue, body, and thought. It is without highness and lowness. It abides without movement or activity.\",\"label\":\"3.8\",\"sort\":2166,\"type\":\"translation\",\"uuid\":\"b903b728-168a-42ba-ac51-4eff9b8e4d33\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-113\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":705,\"uuid\":\"0ccf1c32-3174-4557-b9ef-faf2e58fc65e\"},\"content\":[{\"type\":\"text\",\"text\":\"Skt. \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"dharmadhātu\",\"attrs\":{\"start\":5,\"end\":16},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":5,\"end\":16,\"uuid\":\"bed159ac-5485-4e4d-a425-bbbc1b6a4471\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\". This is not the \",\"attrs\":{\"start\":16,\"end\":34}},{\"type\":\"text\",\"text\":\"dharma­dhātu\",\"attrs\":{\"start\":34,\"end\":46},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":34,\"end\":46,\"uuid\":\"5d221783-fcd0-4d8d-9324-fa8962071ed9\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" (phenomenal \",\"attrs\":{\"start\":46,\"end\":59}},{\"type\":\"text\",\"text\":\"element\",\"attrs\":{\"start\":59,\"end\":66},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"dbc4a2e4-dbc7-475b-8ed0-c63412da4b68\",\"uuid\":\"b64243f6-9bf5-473c-9b51-688651090f9d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\") included among the eighteen \",\"attrs\":{\"start\":66,\"end\":96}},{\"type\":\"text\",\"text\":\"elements\",\"attrs\":{\"start\":96,\"end\":104},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"dbc4a2e4-dbc7-475b-8ed0-c63412da4b68\",\"uuid\":\"cb11fd5c-ab80-4a11-8f90-23544c2a75a1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (see glossary). It is one of the five synonyms of \",\"attrs\":{\"start\":104,\"end\":155}},{\"type\":\"text\",\"text\":\"voidness\",\"attrs\":{\"start\":155,\"end\":163},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e74ef65c-8fc8-4dbf-9bba-7326d6b5d34d\",\"uuid\":\"de933bfd-529d-40ec-884b-bae31b8954ff\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" included in \",\"attrs\":{\"start\":163,\"end\":176}},{\"type\":\"text\",\"text\":\"Maitreya\",\"attrs\":{\"start\":176,\"end\":184},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7067dbc9-9833-4f0d-880c-f1b6f821805f\",\"uuid\":\"56fe3bcb-6926-44d0-9f56-cb61c23eada5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s \",\"attrs\":{\"start\":184,\"end\":187}},{\"type\":\"text\",\"text\":\"Madhyānta­vibhāga\",\"attrs\":{\"start\":187,\"end\":204},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"fec9b0f0-a7bd-48c3-8fd3-95b18ee7a432\",\"uuid\":\"87f9cfef-ea76-470a-80c8-d0e0c6e7d799\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", I, 15‍—\",\"attrs\":{\"start\":204,\"end\":213}},{\"type\":\"text\",\"text\":\"tathatā bhūtakoṭiśca ’nimittaṃ paramārthatā | dharma­dhātuśca paryāyāḥ śūnyatāyāḥ samāsataḥ ||\",\"attrs\":{\"start\":213,\"end\":307},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":213,\"end\":307,\"uuid\":\"6616f3ab-65d6-437d-ae79-c9b5bf8f717d\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"‍—where it is analyzed in a rather unusual way as “the \",\"attrs\":{\"start\":307,\"end\":362}},{\"type\":\"text\",\"text\":\"element\",\"attrs\":{\"start\":362,\"end\":369},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"dbc4a2e4-dbc7-475b-8ed0-c63412da4b68\",\"uuid\":\"90ed213c-6523-42a0-86e0-83a10efa5c3a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of \",\"attrs\":{\"start\":369,\"end\":373}},{\"type\":\"text\",\"text\":\"Dharma\",\"attrs\":{\"start\":373,\"end\":379},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c08db6f5-393e-4ec4-bf72-4043e53b3129\",\"uuid\":\"d7d64ba4-cfb8-4977-acca-3252014ec9ba\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", from which arise the \",\"attrs\":{\"start\":379,\"end\":402}},{\"type\":\"text\",\"text\":\"noble\",\"attrs\":{\"start\":402,\"end\":407},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"335e47c2-eb5f-458f-89d8-346e929bc433\",\"uuid\":\"13e895d9-63d7-461e-8bd2-9f89e6622205\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" qualities of the \",\"attrs\":{\"start\":407,\"end\":425}},{\"type\":\"text\",\"text\":\"arhats\",\"attrs\":{\"start\":425,\"end\":431},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8584345b-bf7d-481b-ac82-4146d2374b3c\",\"uuid\":\"f64b9c27-eaec-4aad-8b13-cbfc7f436e03\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"….” However, Tib. \",\"attrs\":{\"start\":431,\"end\":449}},{\"type\":\"text\",\"text\":\"dbyings\",\"attrs\":{\"start\":449,\"end\":456},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":449,\"end\":456,\"uuid\":\"30f21733-61d4-47a6-ba21-a2dc6bb54157\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" definitely indicates interpretation of \",\"attrs\":{\"start\":456,\"end\":496}},{\"type\":\"text\",\"text\":\"dhātu\",\"attrs\":{\"start\":496,\"end\":501},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":496,\"end\":501,\"uuid\":\"896eb4bc-b1fe-43cf-aa19-ecc28c0f5ba9\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" as space, realm, etc., rather than \",\"attrs\":{\"start\":501,\"end\":537}},{\"type\":\"text\",\"text\":\"element\",\"attrs\":{\"start\":537,\"end\":544},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"dbc4a2e4-dbc7-475b-8ed0-c63412da4b68\",\"uuid\":\"f1bf6b9d-3abb-43aa-ab15-aa3ddcfa135e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"; so, with the proviso that it is a synonym of \",\"attrs\":{\"start\":544,\"end\":591}},{\"type\":\"text\",\"text\":\"voidness\",\"attrs\":{\"start\":591,\"end\":599},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e74ef65c-8fc8-4dbf-9bba-7326d6b5d34d\",\"uuid\":\"2f9c3402-1543-4f99-b7ef-59eddd7a62ba\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", it is here translated “\",\"attrs\":{\"start\":599,\"end\":624}},{\"type\":\"text\",\"text\":\"ultimate realm\",\"attrs\":{\"start\":624,\"end\":638},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"fb139747-a249-489b-947e-79301865b6d6\",\"uuid\":\"28979cb9-b0ed-47b2-97ec-06d67c761764\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"” (i.e., no relative realm at all). See glossary, “\",\"attrs\":{\"start\":638,\"end\":689}},{\"type\":\"text\",\"text\":\"ultimate realm\",\"attrs\":{\"start\":689,\"end\":703},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"fb139747-a249-489b-947e-79301865b6d6\",\"uuid\":\"b7158151-29a0-4d09-b42e-6b39fa65d5f1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".”\",\"attrs\":{\"start\":703,\"end\":705}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"f41c433c-1737-4130-a3dc-b1567130c895\",\"sort\":10350,\"type\":\"endnotes\",\"label\":\"n.60\",\"alignments\":{},\"references\":[{\"content\":\"“ ‘It permeates evenly all things, because all are included in the ultimate realm. It conforms to reality by means of the process of nonconformity. It abides at the reality-limit, for it is utterly without fluctuation. It is immovable, because it is independent of the six objects of sense. It is without coming and going, for it never stands still. It is comprised by voidness, it is remarkable through signlessness, and because of wishlessness it is free of presumption and repudiation. It is without establishment and rejection, without birth or destruction. It is without any fundamental consciousness, transcending the range of eye, ear, nose, tongue, body, and thought. It is without highness and lowness. It abides without movement or activity.\",\"label\":\"3.8\",\"sort\":2166,\"type\":\"translation\",\"uuid\":\"b903b728-168a-42ba-ac51-4eff9b8e4d33\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-113\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":113,\"uuid\":\"f41c433c-1737-4130-a3dc-b1567130c895\"},\"content\":[{\"type\":\"text\",\"text\":\"This passage follows X quite closely, but K is somewhat different in details (see Luk, pp 21-22, or McRae, p 86).\",\"attrs\":{\"start\":0,\"end\":113}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"f4f79f36-1eb8-4ad0-9e5e-f3a501eca30c\",\"sort\":10352,\"type\":\"endnotes\",\"label\":\"n.61\",\"alignments\":{},\"references\":[{\"content\":\"“ ‘Therefore, you should teach the Dharma by keeping your mind on this. You should be adept in regard to the spiritual faculties of living beings. By means of the correct vision of the wisdom-eye, manifesting the great compassion, acknowledging the benevolent activity of the Buddha, purifying your intentions, and understanding the definitive expressions of the Dharma, you should teach the Dharma in order that the continuity of the Three Jewels may never be interrupted.’\",\"label\":\"3.10\",\"sort\":2199,\"type\":\"translation\",\"uuid\":\"a5bcee6a-296c-49f4-b1c9-9f8129e8de5d\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-115\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":357,\"uuid\":\"f4f79f36-1eb8-4ad0-9e5e-f3a501eca30c\"},\"content\":[{\"type\":\"text\",\"text\":\"This refers to those teachings (of \",\"attrs\":{\"start\":0,\"end\":35}},{\"type\":\"text\",\"text\":\"śūnyatā\",\"attrs\":{\"start\":35,\"end\":42},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1ede53af-8161-4358-9902-76ff3144ae49\",\"uuid\":\"4c2d0a87-50fa-4a58-9346-8e9d3da630e0\",\"toh\":null,\"start\":35,\"end\":0}},{\"type\":\"italic\",\"attrs\":{\"start\":35,\"end\":42,\"uuid\":\"ce23c1e1-9924-4782-94d1-a9e577e0770b\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", etc.) the \",\"attrs\":{\"start\":42,\"end\":54}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":54,\"end\":60},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"e07a015f-4e0b-4581-a1ab-12f6b88a5a4e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" reserves for disciples of greatest ability, definitive teachings (\",\"attrs\":{\"start\":60,\"end\":127}},{\"type\":\"text\",\"text\":\"nītārtha­vacana\",\"attrs\":{\"start\":127,\"end\":142},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":127,\"end\":142,\"uuid\":\"24e4c033-4e42-4b4d-9699-0a50e3e9c885\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\") as opposed to teaching meant to develop disciples (to the point when they can understand the definitive teachings), which are known as interpretable teachings (\",\"attrs\":{\"start\":142,\"end\":304}},{\"type\":\"text\",\"text\":\"neyārtha­vacana\",\"attrs\":{\"start\":304,\"end\":319},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":304,\"end\":319,\"uuid\":\"8b0e3415-81ce-46d9-8598-6ecffd5eb06e\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"). See glossary, “\",\"attrs\":{\"start\":319,\"end\":337}},{\"type\":\"text\",\"text\":\"definitive meaning\",\"attrs\":{\"start\":337,\"end\":355},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"635916eb-923d-4aff-a4c7-9f4516721120\",\"uuid\":\"4a67bc43-bc6c-440f-833b-3457720a0859\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".”\",\"attrs\":{\"start\":355,\"end\":357}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"8dfbe239-d02b-48b7-a51f-a35b17cb1b41\",\"sort\":10365,\"type\":\"endnotes\",\"label\":\"n.62\",\"alignments\":{},\"references\":[{\"content\":\"$3f\",\"label\":\"3.12\",\"sort\":2227,\"type\":\"translation\",\"uuid\":\"d68a041f-2ea3-42e9-b451-a930663c805e\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-117\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":570,\"uuid\":\"8dfbe239-d02b-48b7-a51f-a35b17cb1b41\"},\"content\":[{\"type\":\"text\",\"text\":\"Mahākāśyapa\",\"attrs\":{\"start\":0,\"end\":11},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cf40c4ec-f71c-47c7-bd39-47de5e6850b9\",\"uuid\":\"31a6afe7-786b-4239-b13b-bd8739d9abef\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" was known as “the foremost among the upholders of the ascetic practices” (\",\"attrs\":{\"start\":11,\"end\":86}},{\"type\":\"text\",\"text\":\"dhūta­guṇa­vādinām agraḥ\",\"attrs\":{\"start\":86,\"end\":110},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":86,\"end\":110,\"uuid\":\"3b8a8436-7fae-497a-8cbb-551fa68df4ce\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\") and was the \",\"attrs\":{\"start\":110,\"end\":124}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":124,\"end\":130},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"4c3df4a2-48fc-4fd9-a0a2-7dbfd9f4ead5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s successor as leader of the \",\"attrs\":{\"start\":130,\"end\":160}},{\"type\":\"text\",\"text\":\"saṅgha\",\"attrs\":{\"start\":160,\"end\":166},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"02725146-032e-4372-bc0f-78777524f0aa\",\"uuid\":\"5a2840ae-fd7b-424f-812f-92aea58430f3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" after the \",\"attrs\":{\"start\":166,\"end\":177}},{\"type\":\"text\",\"text\":\"parinirvāṇa\",\"attrs\":{\"start\":177,\"end\":188},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f3755f91-c27d-4968-894e-14796bd04545\",\"uuid\":\"e1617d3f-eb2b-4385-9715-78e1a490adcc\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Here he is engaged in one of the \",\"attrs\":{\"start\":188,\"end\":223}},{\"type\":\"text\",\"text\":\"twelve ascetic practices\",\"attrs\":{\"start\":223,\"end\":247},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f0e037b0-dfc3-4e05-94ad-bc0d2dfc2cfb\",\"uuid\":\"1662e6b4-c410-46a3-9668-11d7669eb585\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (see glossary), that of living on food begged as alms (\",\"attrs\":{\"start\":247,\"end\":303}},{\"type\":\"text\",\"text\":\"paiṇḍapātika\",\"attrs\":{\"start\":303,\"end\":315},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":303,\"end\":315,\"uuid\":\"5c7c271a-d315-4c44-a513-bddd587b7941\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"). Thus, in the very execution of his specialty he is scolded by \",\"attrs\":{\"start\":315,\"end\":380}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":380,\"end\":391},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"61d9a6d7-02ce-4beb-9abc-2014e3ecf9d8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", who points out to him that such practices are intrinsically worthless and are useful only if combined with the true equanimity reached through the \",\"attrs\":{\"start\":391,\"end\":540}},{\"type\":\"text\",\"text\":\"wisdom\",\"attrs\":{\"start\":540,\"end\":546},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"38971298-6f62-48f0-b271-36261568d441\",\"uuid\":\"447d85e3-bd75-4faf-9f2b-53375ebc6523\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" that realizes \",\"attrs\":{\"start\":546,\"end\":561}},{\"type\":\"text\",\"text\":\"voidness\",\"attrs\":{\"start\":561,\"end\":569},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e74ef65c-8fc8-4dbf-9bba-7326d6b5d34d\",\"uuid\":\"244d456f-5a96-454e-ac9c-4638ae36c9bf\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":569,\"end\":570}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"6af02c6c-f62c-46a3-bd57-ca27eef77d31\",\"sort\":10386,\"type\":\"endnotes\",\"label\":\"n.63\",\"alignments\":{},\"references\":[{\"content\":\"$40\",\"label\":\"3.12\",\"sort\":2227,\"type\":\"translation\",\"uuid\":\"d68a041f-2ea3-42e9-b451-a930663c805e\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-117\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":118,\"uuid\":\"6af02c6c-f62c-46a3-bd57-ca27eef77d31\"},\"content\":[{\"type\":\"text\",\"text\":\"Kāśyapa is favoring the poor here by depriving the rich of the chance to give food to him and thus benefit themselves.\",\"attrs\":{\"start\":0,\"end\":118}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"ea984ea7-9cbe-4123-83ac-4f896cc2e2a1\",\"sort\":10388,\"type\":\"endnotes\",\"label\":\"n.64\",\"alignments\":{},\"references\":[{\"content\":\"$41\",\"label\":\"3.12\",\"sort\":2227,\"type\":\"translation\",\"uuid\":\"d68a041f-2ea3-42e9-b451-a930663c805e\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-117\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":875,\"uuid\":\"ea984ea7-9cbe-4123-83ac-4f896cc2e2a1\"},\"content\":[{\"type\":\"text\",\"text\":\"Skt. \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"yo ’svabhāvo ’para­bhāvaś ca tad anujjvalitam | yad anujjvalitaṃ tan na śāmyati\",\"attrs\":{\"start\":5,\"end\":84},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":5,\"end\":84,\"uuid\":\"33c56f8f-2970-4cca-8837-6261d743a4e2\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\". His seemingly irrelevant statement, which occurs again in Vimala­kīrti’s speech to \",\"attrs\":{\"start\":84,\"end\":169}},{\"type\":\"text\",\"text\":\"Kātyāyana\",\"attrs\":{\"start\":169,\"end\":178},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8effe26b-2996-454f-98a2-3e0cda7b9569\",\"uuid\":\"a72ea781-1436-4c20-8ca0-30258b7a950c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":178,\"end\":180}},{\"type\":\"text\",\"text\":\"3.25\",\"attrs\":{\"start\":180,\"end\":184},\"marks\":[{\"type\":\"internalLink\",\"attrs\":{\"uuid\":\"a3850416-07e3-461d-a0c4-12664f598ed0\",\"href\":\"/entity/passage/e24677c7-627b-46ce-bef0-4d826f3dd634\",\"entity\":\"e24677c7-627b-46ce-bef0-4d826f3dd634\",\"type\":\"passage\",\"toh\":null,\"isSameWork\":true,\"subtype\":\"translation\"}}]},{\"type\":\"text\",\"text\":\"), is, in fact, highly relevant to the main \",\"attrs\":{\"start\":184,\"end\":228}},{\"type\":\"text\",\"text\":\"Disciple Vehicle\",\"attrs\":{\"start\":228,\"end\":244},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cc35d4b8-9151-485e-9199-cf5d9d646538\",\"uuid\":\"4a942566-e248-4155-b053-7fc1bcf03906\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" concern: the burning of the misery of the world, in which, they believe, man’s condition is like that of one whose head is ablaze. Hence their major preoccupation is to extinguish that fire, just as a burning man will seek water with a frantic intensity to save himself. Thus Vimala­kīrti is telling Mahā­kāśyapa and \",\"attrs\":{\"start\":244,\"end\":562}},{\"type\":\"text\",\"text\":\"Kātyāyana\",\"attrs\":{\"start\":562,\"end\":571},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8effe26b-2996-454f-98a2-3e0cda7b9569\",\"uuid\":\"36f0d73e-4e49-4f08-8571-8f0295b54781\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" that since they do not have intrinsic existence as \",\"attrs\":{\"start\":571,\"end\":623}},{\"type\":\"text\",\"text\":\"self\",\"attrs\":{\"start\":623,\"end\":627},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"6b47902b-462a-40ad-923c-f033caeaf1f2\",\"uuid\":\"6a23ebad-cf03-4a6c-97cd-3fd1e5d26afb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", or imparted existence as other in relationship to anything else, they do not really exist and, therefore, they cannot burn with the misery of the world and there is nothing to extinguish in \",\"attrs\":{\"start\":627,\"end\":819}},{\"type\":\"text\",\"text\":\"liberation\",\"attrs\":{\"start\":819,\"end\":829},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1f6de051-60d0-418f-9255-9634be3f22b8\",\"uuid\":\"2805f9c2-33f1-4c96-a3a5-bb0db628d711\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":829,\"end\":831}},{\"type\":\"text\",\"text\":\"nirvāṇa\",\"attrs\":{\"start\":831,\"end\":838},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"bc870b0a-74dc-452b-ab38-74618df3c1c1\",\"uuid\":\"535920d6-4555-4e7c-8fe9-7b58112d1a0d\",\"toh\":null,\"start\":831,\"end\":0}},{\"type\":\"italic\",\"attrs\":{\"start\":831,\"end\":838,\"uuid\":\"c5b10034-d09a-4f61-93fb-7b58508de427\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" literally meaning “extinguishment”).\",\"attrs\":{\"start\":838,\"end\":875}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"731107e5-1ede-4082-98a6-fcf0acd51e2e\",\"sort\":10406,\"type\":\"endnotes\",\"label\":\"n.65\",\"alignments\":{},\"references\":[{\"content\":\"$42\",\"label\":\"3.15\",\"sort\":2316,\"type\":\"translation\",\"uuid\":\"90ac06fd-a9b1-4c7a-8b8f-4b6dd4354d9d\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-120\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":425,\"uuid\":\"731107e5-1ede-4082-98a6-fcf0acd51e2e\"},\"content\":[{\"type\":\"text\",\"text\":\"Among \",\"attrs\":{\"start\":0,\"end\":6}},{\"type\":\"text\",\"text\":\"Subhūti\",\"attrs\":{\"start\":6,\"end\":13},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b5412ab5-da28-47a8-aaf4-65be6e28d7d4\",\"uuid\":\"0dcff204-858a-489f-b7e8-df9ee568a6a1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s other strong points, he was known as the “foremost among those worthy of offerings,” (\",\"attrs\":{\"start\":13,\"end\":102}},{\"type\":\"text\",\"text\":\"dakṣiṇeyānāṃ agraḥ\",\"attrs\":{\"start\":102,\"end\":120},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":102,\"end\":120,\"uuid\":\"6f4151ea-c581-4658-9525-7f70cac72b1a\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", see Lamotte, p 154, n 27). Thus \",\"attrs\":{\"start\":120,\"end\":154}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":154,\"end\":165},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"4efd7db2-1e9f-4f15-ac4b-90eb823f8761\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" challenges him precisely about his worthiness, defining it by testing \",\"attrs\":{\"start\":165,\"end\":236}},{\"type\":\"text\",\"text\":\"Subhūti\",\"attrs\":{\"start\":236,\"end\":243},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b5412ab5-da28-47a8-aaf4-65be6e28d7d4\",\"uuid\":\"2c454a60-ddd3-44dd-b308-3098876f5d65\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s equanimity in the face of all the most unworthy things he can think of and causing \",\"attrs\":{\"start\":243,\"end\":329}},{\"type\":\"text\",\"text\":\"Subhūti\",\"attrs\":{\"start\":329,\"end\":336},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b5412ab5-da28-47a8-aaf4-65be6e28d7d4\",\"uuid\":\"ec65b9b5-2daa-4a24-9339-c285ad30a676\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" to feel frightened and confused by his own adherence to dualities such as good and evil.\",\"attrs\":{\"start\":336,\"end\":425}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"822dddb5-e13c-4f8c-828a-9f386316347d\",\"sort\":10418,\"type\":\"endnotes\",\"label\":\"n.66\",\"alignments\":{},\"references\":[{\"content\":\"$43\",\"label\":\"3.15\",\"sort\":2316,\"type\":\"translation\",\"uuid\":\"90ac06fd-a9b1-4c7a-8b8f-4b6dd4354d9d\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-120\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":185,\"uuid\":\"822dddb5-e13c-4f8c-828a-9f386316347d\"},\"content\":[{\"type\":\"text\",\"text\":\"By “fruition,” \",\"attrs\":{\"start\":0,\"end\":15}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":15,\"end\":26},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"b85c8a98-0396-4bfb-9457-1446f4dd3722\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" means any of the culminating stages of realization attained by those who practice the teachings, such as the Four \",\"attrs\":{\"start\":26,\"end\":141}},{\"type\":\"text\",\"text\":\"Noble\",\"attrs\":{\"start\":141,\"end\":146},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"335e47c2-eb5f-458f-89d8-346e929bc433\",\"uuid\":\"94ec62fa-463b-42f2-973f-2409c6bcf76f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" Truths, the twofold selflessness, etc.\",\"attrs\":{\"start\":146,\"end\":185}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"10d285a5-efc0-4d1a-b86a-ab33020dad8a\",\"sort\":10424,\"type\":\"endnotes\",\"label\":\"n.67\",\"alignments\":{},\"references\":[{\"content\":\"$44\",\"label\":\"3.15\",\"sort\":2316,\"type\":\"translation\",\"uuid\":\"90ac06fd-a9b1-4c7a-8b8f-4b6dd4354d9d\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-120\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":377,\"uuid\":\"10d285a5-efc0-4d1a-b86a-ab33020dad8a\"},\"content\":[{\"type\":\"text\",\"text\":\"Tib.: \",\"attrs\":{\"start\":0,\"end\":6}},{\"type\":\"text\",\"text\":\"chos thams cad dang yang ldan la chos thams cad kyi ’du shes dang yang bral\",\"attrs\":{\"start\":6,\"end\":81},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":6,\"end\":81,\"uuid\":\"712a98ef-fa40-4803-8efd-09301eb18ed0\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\". The Skt. of the Potala MS reads \",\"attrs\":{\"start\":81,\"end\":115}},{\"type\":\"text\",\"text\":\"na sarva­dharma­samanvāgataś ca sarva­dharma­samadhigataś ca\",\"attrs\":{\"start\":115,\"end\":175},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":115,\"end\":175,\"uuid\":\"37d82a94-6011-4b42-98ce-a9ce09c7958e\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", but to accord with the Tib., which seems clearer and was presumably translated from a different MS, this would have to be emended to read \",\"attrs\":{\"start\":175,\"end\":315}},{\"type\":\"text\",\"text\":\"sarva­dharma­samanvāgataś ca na sarva­dharma­saṃjñāvigataś ca\",\"attrs\":{\"start\":315,\"end\":376},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":315,\"end\":376,\"uuid\":\"f067261d-342a-4a80-b846-77d4392d775c\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":376,\"end\":377}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"d1a5eb0d-7cde-44fc-97ee-43fb9a3bcd79\",\"sort\":10432,\"type\":\"endnotes\",\"label\":\"n.68\",\"alignments\":{},\"references\":[{\"content\":\"“ ‘Take this food, reverend Subhūti, if, entertaining all false views, you find neither extremes nor middle; if, bound up in the eight adversities, you do not obtain favorable conditions; if, assimilating the passions, you do not attain purification; if the dispassion of all living beings is your dispassion, reverend; if those who make offerings to you are not thereby purified; if those who offer you food, reverend, still fall into the three bad migrations; if you associate with all māras; if you entertain all passions; if the nature of passions is the nature of a reverend; if you have hostile feelings toward all living beings; if you despise all the buddhas; if you criticize all the teachings of the Buddha; if you do not rely on the saṅgha; and finally, if you never enter ultimate liberation.’\",\"label\":\"3.17\",\"sort\":2389,\"type\":\"translation\",\"uuid\":\"0f9aebde-2f57-499f-8a2c-603059538bff\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-122\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":459,\"uuid\":\"d1a5eb0d-7cde-44fc-97ee-43fb9a3bcd79\"},\"content\":[{\"type\":\"text\",\"text\":\"Tib. \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"nyon mongs pa med pa\",\"attrs\":{\"start\":5,\"end\":25},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":5,\"end\":25,\"uuid\":\"0afa82e5-8622-4fad-a917-3f850ed23096\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" (lit. “absence of \",\"attrs\":{\"start\":25,\"end\":44}},{\"type\":\"text\",\"text\":\"passions\",\"attrs\":{\"start\":44,\"end\":52},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2370c8e3-79cc-4eab-bc82-33939081f558\",\"uuid\":\"0c4c0e83-19ec-47f1-845b-565ee917b3cf\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\",” or \",\"attrs\":{\"start\":52,\"end\":58}},{\"type\":\"text\",\"text\":\"afflictions\",\"attrs\":{\"start\":58,\"end\":69},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"62aa0bc0-1ed1-49a6-b18e-9b0f37c6aeef\",\"uuid\":\"cf170f04-5d64-4771-b256-da656a1c9c98\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"). However, the Skt. here is \",\"attrs\":{\"start\":69,\"end\":98}},{\"type\":\"text\",\"text\":\"araṇa\",\"attrs\":{\"start\":98,\"end\":103},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":98,\"end\":103,\"uuid\":\"a6c9b1d0-80f5-4b17-bf46-2d14bb8bf1d3\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", and K and X use “nondisputation,” which is actually equivalent to dispassion, since the “struggle,” or “disputation,” referred to is internal, the turbulence of inner struggle of one prey to \",\"attrs\":{\"start\":103,\"end\":296}},{\"type\":\"text\",\"text\":\"passions\",\"attrs\":{\"start\":296,\"end\":304},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2370c8e3-79cc-4eab-bc82-33939081f558\",\"uuid\":\"482c9049-4235-4d65-86ab-d2480791e8f0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". This is perhaps more appropriate here, since \",\"attrs\":{\"start\":304,\"end\":351}},{\"type\":\"text\",\"text\":\"Subhūti\",\"attrs\":{\"start\":351,\"end\":358},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b5412ab5-da28-47a8-aaf4-65be6e28d7d4\",\"uuid\":\"5ac80bf3-ad1b-4eaa-880d-fe470bb10235\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" was renowned for his attainment of this state (see Lamotte, p 154, n 27; \",\"attrs\":{\"start\":358,\"end\":432}},{\"type\":\"text\",\"text\":\"araṇa­vihārīnām agro\",\"attrs\":{\"start\":432,\"end\":452},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":432,\"end\":452,\"uuid\":\"d50b11fa-effe-4747-9eb5-5f0b8f5bc49a\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", etc.)\",\"attrs\":{\"start\":452,\"end\":459}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"f77166c0-5561-4b33-8338-a385b5b3090c\",\"sort\":10448,\"type\":\"endnotes\",\"label\":\"n.69\",\"alignments\":{},\"references\":[{\"content\":\"“ ‘Take this food, reverend Subhūti, if, entertaining all false views, you find neither extremes nor middle; if, bound up in the eight adversities, you do not obtain favorable conditions; if, assimilating the passions, you do not attain purification; if the dispassion of all living beings is your dispassion, reverend; if those who make offerings to you are not thereby purified; if those who offer you food, reverend, still fall into the three bad migrations; if you associate with all māras; if you entertain all passions; if the nature of passions is the nature of a reverend; if you have hostile feelings toward all living beings; if you despise all the buddhas; if you criticize all the teachings of the Buddha; if you do not rely on the saṅgha; and finally, if you never enter ultimate liberation.’\",\"label\":\"3.17\",\"sort\":2389,\"type\":\"translation\",\"uuid\":\"0f9aebde-2f57-499f-8a2c-603059538bff\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-122\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":82,\"uuid\":\"f77166c0-5561-4b33-8338-a385b5b3090c\"},\"content\":[{\"type\":\"text\",\"text\":\"K and X: “if those who make offerings to you do not find in you a field of merit.”\",\"attrs\":{\"start\":0,\"end\":82}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"68c435d9-5dbe-459c-bb70-f962271ec774\",\"sort\":10450,\"type\":\"endnotes\",\"label\":\"n.70\",\"alignments\":{},\"references\":[{\"content\":\"“Lord, when I heard these words of the Licchavi Vimalakīrti, I wondered what I should say and what I should do, but I was totally in the dark. Leaving the bowl, I was about to leave the house when the Licchavi Vimalakīrti said to me, ‘Reverend Subhūti, do not fear these words, and pick up your bowl. What do you think, reverend Subhūti? If it were an incarnation created by the Tathāgata who spoke thus to you, would you be afraid?’\",\"label\":\"3.18\",\"sort\":2419,\"type\":\"translation\",\"uuid\":\"eaa8c8ea-a497-4170-bf7a-2acba55f1513\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-123\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":327,\"uuid\":\"68c435d9-5dbe-459c-bb70-f962271ec774\"},\"content\":[{\"type\":\"text\",\"text\":\"According to the \",\"attrs\":{\"start\":0,\"end\":17}},{\"type\":\"text\",\"text\":\"Mahāyāna\",\"attrs\":{\"start\":17,\"end\":25},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"99607e52-e246-4905-b531-6e6d7ccfd7b7\",\"uuid\":\"30d44dc4-d414-49c5-bf98-467eab06d37e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" understanding of the miraculous nature of the three bodies of the \",\"attrs\":{\"start\":25,\"end\":92}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":92,\"end\":98},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"6ec5516b-1e5c-46d6-a8aa-0d484f37edcf\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", especially the “\",\"attrs\":{\"start\":98,\"end\":116}},{\"type\":\"text\",\"text\":\"incarnation-body\",\"attrs\":{\"start\":116,\"end\":132},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"11384b0f-807e-4b8a-a7ef-a663577dfe40\",\"uuid\":\"c439d637-655a-46ac-b39b-75e1cb7e18ee\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"” (\",\"attrs\":{\"start\":132,\"end\":135}},{\"type\":\"text\",\"text\":\"nirmāṇakāya\",\"attrs\":{\"start\":135,\"end\":146},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":135,\"end\":146,\"uuid\":\"5b17ca15-92fc-4a99-87a3-7778a7aa60ca\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"), \",\"attrs\":{\"start\":146,\"end\":149}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":149,\"end\":160},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"856ba994-4960-4d60-8904-d02e025f97eb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" himself is an extremely likely candidate to be one of its operatives. Thus, one steeped in the \",\"attrs\":{\"start\":160,\"end\":256}},{\"type\":\"text\",\"text\":\"Mahāyāna\",\"attrs\":{\"start\":256,\"end\":264},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"99607e52-e246-4905-b531-6e6d7ccfd7b7\",\"uuid\":\"da9aaf4a-b378-4d7d-9a18-e1a613aa783a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" faith would see him here as being subtly playful with \",\"attrs\":{\"start\":264,\"end\":319}},{\"type\":\"text\",\"text\":\"Subhūti\",\"attrs\":{\"start\":319,\"end\":326},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b5412ab5-da28-47a8-aaf4-65be6e28d7d4\",\"uuid\":\"14967159-6e77-4c03-afc4-09f000d56957\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":326,\"end\":327}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"59e712e7-4a41-46eb-a0b5-be13fe3cbb56\",\"sort\":10466,\"type\":\"endnotes\",\"label\":\"n.71\",\"alignments\":{},\"references\":[{\"content\":\"“I answered, ‘No indeed, noble sir!’ He then said, ‘Reverend Subhūti, the nature of all things is like illusion, like a magical incarnation. So you should not fear them. Why? All words also have that nature, and thus the wise are not attached to words, nor do they fear them. Why? All language does not ultimately exist, except as liberation. The nature of all things is liberation.’\",\"label\":\"3.19\",\"sort\":2440,\"type\":\"translation\",\"uuid\":\"4998f6d8-efb4-4097-9865-6d9a04410028\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-124\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":740,\"uuid\":\"59e712e7-4a41-46eb-a0b5-be13fe3cbb56\"},\"content\":[{\"type\":\"text\",\"text\":\"Tib. \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"yi ge de dag thams cad ni yi ge med pa ste/ rnam par grol ba ni ma gtogs so/ chos thams cad ni rnam par grol ba’i mtshan nyid do\",\"attrs\":{\"start\":5,\"end\":133},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":5,\"end\":133,\"uuid\":\"2b7acf6a-f724-44ff-9582-5bfe357e156a\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\". K and X differ slightly, but essentially have the same meaning: “Language does not have an independent nature. When it is no more, there is \",\"attrs\":{\"start\":133,\"end\":275}},{\"type\":\"text\",\"text\":\"liberation\",\"attrs\":{\"start\":275,\"end\":285},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1f6de051-60d0-418f-9255-9634be3f22b8\",\"uuid\":\"6cc49644-eed1-4792-9194-a8f7f7b77e5c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".” In other words, no independent nature = ultimately nonexistent; it is no more = when the \",\"attrs\":{\"start\":285,\"end\":377}},{\"type\":\"text\",\"text\":\"ultimate\",\"attrs\":{\"start\":377,\"end\":385},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"784c8158-9e46-4484-9152-e0d06cd46afc\",\"uuid\":\"8df0571a-1ab9-48ef-86bd-835e8871463a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is realized; then \",\"attrs\":{\"start\":385,\"end\":404}},{\"type\":\"text\",\"text\":\"liberation\",\"attrs\":{\"start\":404,\"end\":414},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1f6de051-60d0-418f-9255-9634be3f22b8\",\"uuid\":\"d13c702b-9098-4944-907e-60fc2c5205de\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" = when even words are realized to be \",\"attrs\":{\"start\":414,\"end\":452}},{\"type\":\"text\",\"text\":\"liberation\",\"attrs\":{\"start\":452,\"end\":462},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1f6de051-60d0-418f-9255-9634be3f22b8\",\"uuid\":\"9e1f34d1-e4a7-429a-b5e9-53da2cd67ed4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", there is no more duality, and there is realization. Ch. stresses the experiential moment of pure \",\"attrs\":{\"start\":462,\"end\":561}},{\"type\":\"text\",\"text\":\"gnosis\",\"attrs\":{\"start\":561,\"end\":567},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"57f30533-44ff-42b7-a670-f57da1f54504\",\"uuid\":\"ccbdd065-96c5-4b97-96d3-f3722359b335\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of \",\"attrs\":{\"start\":567,\"end\":571}},{\"type\":\"text\",\"text\":\"voidness\",\"attrs\":{\"start\":571,\"end\":579},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e74ef65c-8fc8-4dbf-9bba-7326d6b5d34d\",\"uuid\":\"601cb318-6438-4376-acb0-cec1c7e94951\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Tib. expresses this \",\"attrs\":{\"start\":579,\"end\":601}},{\"type\":\"text\",\"text\":\"gnosis\",\"attrs\":{\"start\":601,\"end\":607},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"57f30533-44ff-42b7-a670-f57da1f54504\",\"uuid\":\"088d5d15-c964-49df-8b5f-71153a1c5a97\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" along with its nondual, postattainment \",\"attrs\":{\"start\":607,\"end\":647}},{\"type\":\"text\",\"text\":\"wisdom\",\"attrs\":{\"start\":647,\"end\":653},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"38971298-6f62-48f0-b271-36261568d441\",\"uuid\":\"948c2d4e-bbb5-4d37-9e9b-cff323175de7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":653,\"end\":655}},{\"type\":\"text\",\"text\":\"pṛṣṭhalabdha­jñāna\",\"attrs\":{\"start\":655,\"end\":673},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":655,\"end\":673,\"uuid\":\"f6e16ee1-ac91-4d3f-843e-279feb49cf49\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"). It is \",\"attrs\":{\"start\":673,\"end\":682}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":682,\"end\":693},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"5ffc6251-8bfd-4d1a-87c8-64f78392c96d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s last word on \",\"attrs\":{\"start\":693,\"end\":709}},{\"type\":\"text\",\"text\":\"nonduality\",\"attrs\":{\"start\":709,\"end\":719},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5bcad558-679e-41c8-a730-6e36945799b6\",\"uuid\":\"c93dbd6f-f792-4944-b01b-e89ddab2d300\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" to instruct \",\"attrs\":{\"start\":719,\"end\":732}},{\"type\":\"text\",\"text\":\"Subhūti\",\"attrs\":{\"start\":732,\"end\":739},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b5412ab5-da28-47a8-aaf4-65be6e28d7d4\",\"uuid\":\"5ea953ba-942e-4a45-b06b-6633173aa303\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":739,\"end\":740}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"6feac2bb-f8a9-497b-92f0-9a97a77a1eb5\",\"sort\":10495,\"type\":\"endnotes\",\"label\":\"n.72\",\"alignments\":{},\"references\":[{\"content\":\"The Buddha then said to the venerable Pūrṇa­maitrāyaṇī­putra, “Pūrṇa, go to the Licchavi Vimalakīrti to inquire about his illness.” Pūrṇa replied, “Lord, I am indeed reluctant to go to this good man to inquire about his illness. Why? Lord, I remember one day, when I was teaching the Dharma to some young monks in the great forest, the Licchavi Vimalakīrti came there and said to me, ‘Reverend Pūrṇa, first concentrate yourself, regard the minds of these young bhikṣus, and then teach them the Dharma! Do not put rotten food into a jeweled bowl! First understand the inclinations of these monks, and do not confuse priceless sapphires with glass beads!\",\"label\":\"3.21\",\"sort\":2461,\"type\":\"translation\",\"uuid\":\"f6e5557c-4f2c-4b56-a31e-24fc27e9c042\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-126\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":701,\"uuid\":\"6feac2bb-f8a9-497b-92f0-9a97a77a1eb5\"},\"content\":[{\"type\":\"text\",\"text\":\"Pūrṇa\",\"attrs\":{\"start\":0,\"end\":5},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a952daa2-b766-4a8f-a19e-633af3c5e6e2\",\"uuid\":\"4017c5d0-6bf1-4741-997c-a6536114ed35\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", “son of Maitrāyaṇī,” was known as “the foremost of expounders of the \",\"attrs\":{\"start\":5,\"end\":76}},{\"type\":\"text\",\"text\":\"Dharma\",\"attrs\":{\"start\":76,\"end\":82},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c08db6f5-393e-4ec4-bf72-4043e53b3129\",\"uuid\":\"5ba4fe87-217f-480e-9956-4bee1e001b28\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"” (\",\"attrs\":{\"start\":82,\"end\":85}},{\"type\":\"text\",\"text\":\"dharma­kathikānām agraḥ\",\"attrs\":{\"start\":85,\"end\":108},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":85,\"end\":108,\"uuid\":\"1274528f-4573-4ad4-829c-c0ce7983393e\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"; see Lamotte, p 160, n 42). According to the \",\"attrs\":{\"start\":108,\"end\":154}},{\"type\":\"text\",\"text\":\"Pāli\",\"attrs\":{\"start\":154,\"end\":158},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b0b04164-1cec-4c95-9c78-54e5889bc61c\",\"uuid\":\"138cba1a-24e2-49fc-82af-9a22088d22c2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" sources (as cited by Lamotte), this very incident, or one similar to it, resulted in five hundred young monks’ attainment of the state of \",\"attrs\":{\"start\":158,\"end\":297}},{\"type\":\"text\",\"text\":\"arhat\",\"attrs\":{\"start\":297,\"end\":302},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8584345b-bf7d-481b-ac82-4146d2374b3c\",\"uuid\":\"266a445a-7f01-4350-aca9-9f74b96977a8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". In any case, it can be assumed that \",\"attrs\":{\"start\":302,\"end\":340}},{\"type\":\"text\",\"text\":\"Pūrṇa\",\"attrs\":{\"start\":340,\"end\":345},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a952daa2-b766-4a8f-a19e-633af3c5e6e2\",\"uuid\":\"06ac0116-ef71-4b5f-82b6-dfbd3deae568\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" was often entrusted with the instruction of young monks, and it was just such an occasion on which \",\"attrs\":{\"start\":345,\"end\":445}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":445,\"end\":456},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"932ffb3d-9f6d-49bd-832d-4557dd7b2177\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" apprehended him. His reproaches are along the same line as those given to \",\"attrs\":{\"start\":456,\"end\":531}},{\"type\":\"text\",\"text\":\"Maudgalyāyana\",\"attrs\":{\"start\":531,\"end\":544},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8ae3a0a1-180a-4fc8-910a-cc2134148828\",\"uuid\":\"b83bd268-cf2a-4bc9-a352-962e9a4b68d7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", only more explicit, i.e., that the great disciples should not teach the \",\"attrs\":{\"start\":544,\"end\":618}},{\"type\":\"text\",\"text\":\"Dharma\",\"attrs\":{\"start\":618,\"end\":624},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c08db6f5-393e-4ec4-bf72-4043e53b3129\",\"uuid\":\"0f45aac2-e5c0-4b97-962e-d0a3562481ae\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" because they cannot recognize the affinity for the \",\"attrs\":{\"start\":624,\"end\":676}},{\"type\":\"text\",\"text\":\"Mahāyāna\",\"attrs\":{\"start\":676,\"end\":684},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"99607e52-e246-4905-b531-6e6d7ccfd7b7\",\"uuid\":\"1bbf000f-c8d7-47de-8e99-1c3c2527efdd\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in their pupils.\",\"attrs\":{\"start\":684,\"end\":701}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"8155277b-4152-462e-9a9e-fea03235db4c\",\"sort\":10516,\"type\":\"endnotes\",\"label\":\"n.73\",\"alignments\":{},\"references\":[{\"content\":\"“At that moment, the Licchavi Vimalakīrti entered into such a concentration that those monks were caused to remember their various former lives, in which they had produced the roots of virtue by serving five hundred buddhas for the sake of perfect enlightenment. As soon as their own spirits of enlightenment had become clear to them, they bowed at the feet of that good man and pressed their palms together in reverence. He taught them the Dharma, and they all attained the stage of irreversibility from unexcelled, perfect enlightenment. It occurred to me then, ‘The disciples, who do not know the thoughts or the inclinations of others, are not able to teach the Dharma to anyone. Why? These disciples are not expert in discerning the superiority and inferiority of the spiritual faculties of living beings, and they are not always in a state of concentration like the Tathāgata, the arhat, the perfectly accomplished Buddha.’ Therefore, Lord, I am reluctant to go to that good man to inquire about his health.”\",\"label\":\"3.24\",\"sort\":2513,\"type\":\"translation\",\"uuid\":\"19f31be8-eb4b-4bd7-9610-ea4c37f84de2\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-129\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":302,\"uuid\":\"8155277b-4152-462e-9a9e-fea03235db4c\"},\"content\":[{\"type\":\"text\",\"text\":\"This means they attained the eighth \",\"attrs\":{\"start\":0,\"end\":36}},{\"type\":\"text\",\"text\":\"bodhisattva\",\"attrs\":{\"start\":36,\"end\":47},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c72eb4f3-700e-454d-996e-5ccdba29e6be\",\"uuid\":\"a8875fe2-4aac-448e-a2b6-ad0d01c0fbae\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" stage, called “The Immovable,” where the \",\"attrs\":{\"start\":47,\"end\":89}},{\"type\":\"text\",\"text\":\"bodhisattva\",\"attrs\":{\"start\":89,\"end\":100},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c72eb4f3-700e-454d-996e-5ccdba29e6be\",\"uuid\":\"b830b953-a3cd-46fd-8c72-34512dab8847\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" becomes irreversible (\",\"attrs\":{\"start\":100,\"end\":123}},{\"type\":\"text\",\"text\":\"avaivartika\",\"attrs\":{\"start\":123,\"end\":134},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":123,\"end\":134,\"uuid\":\"a82ff041-740c-4549-85f1-c9cf5166a7bc\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\") and previous to which he is liable to regression, even to forgetting the \",\"attrs\":{\"start\":134,\"end\":209}},{\"type\":\"text\",\"text\":\"spirit of enlightenment\",\"attrs\":{\"start\":209,\"end\":232},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"86e40054-da64-4b71-8b79-a0ee822f4d48\",\"uuid\":\"191ed178-831c-482f-ae13-8d330cf35db5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" already conceived in former lifetimes, as in the case of these monks.\",\"attrs\":{\"start\":232,\"end\":302}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"9f1769ae-7675-4705-951a-5a6a3a4eb11c\",\"sort\":10527,\"type\":\"endnotes\",\"label\":\"n.74\",\"alignments\":{},\"references\":[{\"content\":\"$45\",\"label\":\"3.25\",\"sort\":2545,\"type\":\"translation\",\"uuid\":\"e24677c7-627b-46ce-bef0-4d826f3dd634\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-9\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":484,\"uuid\":\"9f1769ae-7675-4705-951a-5a6a3a4eb11c\"},\"content\":[{\"type\":\"text\",\"text\":\"Kātyāyana\",\"attrs\":{\"start\":0,\"end\":9},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8effe26b-2996-454f-98a2-3e0cda7b9569\",\"uuid\":\"03b36eb6-9acc-4832-a2d2-2df27ffe978e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" was renowned as the founder of the \",\"attrs\":{\"start\":9,\"end\":45}},{\"type\":\"text\",\"text\":\"Abhidharma\",\"attrs\":{\"start\":45,\"end\":55},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"ccc150b4-2233-4e01-a530-7cc6f0aec169\",\"uuid\":\"7ff8eb8c-603f-4694-90b8-9c7510ffe1d6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" tradition of analysis of the meaning of the \",\"attrs\":{\"start\":55,\"end\":100}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":100,\"end\":106},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"2f626084-e717-40cb-b985-39be19b93e1e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s discourses. He was pronounced by the \",\"attrs\":{\"start\":106,\"end\":146}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":146,\"end\":152},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"844c8cbb-6ab2-46b8-9bb3-71964b6190