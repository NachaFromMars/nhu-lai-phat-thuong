2fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"4d294df3-cdea-41a7-bf04-8f9eae2a898f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in the great city of \",\"attrs\":{\"start\":319,\"end\":341}},{\"type\":\"text\",\"text\":\"Vaiśālī\",\"attrs\":{\"start\":341,\"end\":348},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e9c61804-d922-4a99-88ea-836faa6fd3c4\",\"uuid\":\"bd0d1ebd-92e7-432f-b3f5-3e2f83eb2563\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", he took my bowl and filled it with some excellent food and said to me, ‘Reverend \",\"attrs\":{\"start\":348,\"end\":431}},{\"type\":\"text\",\"text\":\"Subhūti\",\"attrs\":{\"start\":431,\"end\":438},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b5412ab5-da28-47a8-aaf4-65be6e28d7d4\",\"uuid\":\"7e29c83a-aad9-46eb-adb9-6a07a5411d9a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", take this food if you understand the sameness of all things through the sameness of material objects, and if you understand the sameness of the qualities of the \",\"attrs\":{\"start\":438,\"end\":601}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":601,\"end\":607},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"9d417c9f-2c2d-41eb-b882-d2f18b392ae0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" through the sameness of all things. Take this food if, without abandoning desire, hatred, and folly, you can avoid association with them; if you can follow the path of the single way without ever disturbing the \",\"attrs\":{\"start\":607,\"end\":819}},{\"type\":\"text\",\"text\":\"egoistic views\",\"attrs\":{\"start\":819,\"end\":833},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e5d4433d-1e7d-4687-816e-334e3b4acd52\",\"uuid\":\"06cb52e3-5e23-472e-83ef-27936503db74\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"; if, neither conquering ignorance and the craving for existence, nor producing knowledge and \",\"attrs\":{\"start\":833,\"end\":927}},{\"type\":\"text\",\"text\":\"liberation\",\"attrs\":{\"start\":927,\"end\":937},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1f6de051-60d0-418f-9255-9634be3f22b8\",\"uuid\":\"8a15a35b-1155-43be-a982-8e259bbb64ba\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", your \",\"attrs\":{\"start\":937,\"end\":944}},{\"type\":\"text\",\"text\":\"liberation\",\"attrs\":{\"start\":944,\"end\":954},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1f6de051-60d0-418f-9255-9634be3f22b8\",\"uuid\":\"9e10ff01-7115-4ba6-874c-5e9f32322e76\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" being the same as the equality of the uninterruptible sins, you are neither liberated nor bound; if you do not see the four \",\"attrs\":{\"start\":954,\"end\":1079}},{\"type\":\"text\",\"text\":\"noble\",\"attrs\":{\"start\":1079,\"end\":1084},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"335e47c2-eb5f-458f-89d8-346e929bc433\",\"uuid\":\"795b4939-4128-4759-9121-18c991a45608\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" truths, yet are not one who “has not seen the truth”; if you are also neither “one who has attained fruition,”\",\"attrs\":{\"start\":1084,\"end\":1195},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"822dddb5-e13c-4f8c-828a-9f386316347d\",\"label\":\"66\",\"uuid\":\"5c732a6b-9d07-40a5-9a51-65706cf21add\",\"start\":1195,\"end\":1195,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" nor “an ordinary person,” while not having eliminated the qualities of “an ordinary person”; if you are not a \",\"attrs\":{\"start\":1195,\"end\":1306}},{\"type\":\"text\",\"text\":\"noble\",\"attrs\":{\"start\":1306,\"end\":1311},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"335e47c2-eb5f-458f-89d8-346e929bc433\",\"uuid\":\"7b536a4f-b07d-45eb-8acf-0dd101eefe3b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" one, and not a non-\",\"attrs\":{\"start\":1311,\"end\":1331}},{\"type\":\"text\",\"text\":\"noble\",\"attrs\":{\"start\":1331,\"end\":1336},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"335e47c2-eb5f-458f-89d8-346e929bc433\",\"uuid\":\"421a3215-d061-430a-8249-ea233c219203\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" one; and if, though you are in the presence of all things, you are free of any notion of “all things.”\",\"attrs\":{\"start\":1336,\"end\":1439},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"10d285a5-efc0-4d1a-b86a-ab33020dad8a\",\"label\":\"67\",\"uuid\":\"d6ceb360-27e2-450b-bb7f-8e37c0d59b08\",\"start\":1439,\"end\":1439,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"c1ddd230-1790-458f-8bc2-71625d081fd2\",\"sort\":2361,\"type\":\"translation\",\"label\":\"3.16\",\"alignments\":{\"toh176\":{\"folioUuid\":\"4e979ddb-27f3-4b2b-b4b7-e46442dd28b1\",\"toh\":\"toh176\",\"tibetan\":\"ཁྱོད་ཀྱིས་སྟོན་པ་ཡང་མ་མཐོང་། ཆོས་ཀྱང་མ་ཐོས། \\nདགེ་འདུན་ལའང་བསྙེན་བཀུར་མ་བྱས་ཤིང་སྟོན་པ་དྲུག་པོ་གང་ཡིན་པ་དེ་དག་འདི་ལྟ་སྟེ། འོད་སྲུང་རྫོགས་བྱེད་དང་། ཀུན་ཏུ་རྒྱུ་གནག་ལྷས་ཀྱི་བུ་དང་། སྨྲ་འདོད་ཀྱི་བུ་མོའི་བུ་ཡང་དག་རྒྱལ་བ་ཅན་དང་། ཀཱ་ཏྱའི་བུ་ནོག་ཅན་དང་། མི་ཕམ་སྐྲའི་ལ་བ་ཅན་དང་། གཅེར་[F.187.a]བུ་གཉེན་གྱི་བུ་དེ་དག་བཙུན་པའི་སྟོན་པ་ཡིན་ཏེ། དེ་དག་ལ་བརྟེན་ནས་ཁྱོད་རབ་ཏུ་བྱུང་ཞིང་། སྟོན་པ་དྲུག་པོ་དེ་དག་གར་འགྲོ་བར་འཕགས་པ་རབ་འབྱོར་ཡང་འགྲོ་ལ། \",\"folioNumber\":186,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":347,\"uuid\":\"c1ddd230-1790-458f-8bc2-71625d081fd2\"},\"content\":[{\"type\":\"text\",\"text\":\"“ ‘Take this food, reverend \",\"attrs\":{\"start\":0,\"end\":28}},{\"type\":\"text\",\"text\":\"Subhūti\",\"attrs\":{\"start\":28,\"end\":35},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b5412ab5-da28-47a8-aaf4-65be6e28d7d4\",\"uuid\":\"ab5d5793-0ba1-44c2-8017-4ffa562a5abb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", if, without seeing the