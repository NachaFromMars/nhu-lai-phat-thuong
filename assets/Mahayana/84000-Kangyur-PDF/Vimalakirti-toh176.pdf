xt\",\"text\":\" before men and gods, \",\"attrs\":{\"start\":59,\"end\":81}}],\"attrs\":{\"start\":0,\"end\":81,\"uuid\":\"4bd3a5d9-152a-4f49-a3ee-7fec88062417\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"With its threefold revolution, its manifold aspects,\",\"attrs\":{\"start\":81,\"end\":133},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"9a4488c6-92c8-4f8b-ba21-6b5b7e308c6e\",\"label\":\"30\",\"uuid\":\"2b8dc1bc-2bd5-4de3-807f-62914ac15681\",\"start\":133,\"end\":133,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":133,\"end\":134}}],\"attrs\":{\"start\":81,\"end\":134,\"uuid\":\"6d5d1d01-6774-427f-8b84-2111139ef7e6\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"Its extreme peace, and its purity of nature; \",\"attrs\":{\"start\":134,\"end\":179}}],\"attrs\":{\"start\":134,\"end\":179,\"uuid\":\"16e8cf43-a9c5-4e57-b9d5-fe72227dc0be\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"And thereby the Three Jewels were revealed.\",\"attrs\":{\"start\":179,\"end\":222}}],\"attrs\":{\"start\":179,\"end\":222,\"uuid\":\"1e0cca46-afba-4843-8a0c-35b9f411059f\"}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"b3265577-365b-47d4-9ded-eb8c55bdd3da\",\"sort\":1098,\"type\":\"translation\",\"label\":\"1.22\",\"alignments\":{\"toh176\":{\"folioUuid\":\"e36e306d-01a9-49b8-89fc-9eff457bdf7b\",\"toh\":\"toh176\",\"tibetan\":\"ཁྱོད་ཀྱིས་དཀོན་མཆོག་ཆོས་ཀྱིས་ལེགས་པར་གང་བཏུལ་བ། །དེ་དག་རྟོག་པ་མ་མཆིས་རྟག་པར་རབ་ཏུ་ཞི། །ཁྱོད་ནི་སྐྱེ་རྒ་ན་འཆི་མཐར་འབྱིན་སྨན་པའི་མཆོག །ཡོན་ཏན་རྒྱ་མཚོ་དཔག་མི་ལང་ལ་མགོས་ཕྱག་འཚལ། །\",\"folioNumber\":177,\"volumeNumber\":60}}},\"content\":[{\"type\":\"lineGroup\",\"attrs\":{\"start\":0,\"end\":225,\"uuid\":\"1152632b-2e93-4629-b81b-f7cdc7f71a5c\"},\"content\":[{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"“Those who are well disciplined by your precious \",\"attrs\":{\"start\":0,\"end\":49}},{\"type\":\"text\",\"text\":\