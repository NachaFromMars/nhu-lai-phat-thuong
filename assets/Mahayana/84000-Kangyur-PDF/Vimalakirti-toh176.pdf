ss="line-clamp-2">Abbreviations</span></div></div></div></div></div></div></div></div></div><script>$RS=function(a,b){a=document.getElementById(a);b=document.getElementById(b);for(a.parentNode.removeChild(a);a.firstChild;)b.parentNode.insertBefore(a.firstChild,b);b.parentNode.removeChild(b)};$RS("S:3","P:3")</script><script>self.__next_f.push([1,"1f:I[916077,[\"/_next/static/chunks/2fb4b456dae69409.js?dpl=dpl_C4kSSWFdt51TZQpmuYtxXgHAunY1\",\"/_next/static/chunks/6165fecb8e0eae36.js?dpl=dpl_C4kSSWFdt51TZQpmuYtxXgHAunY1\",\"/_next/static/chunks/1cfd6a6ab8fe5d2f.js?dpl=dpl_C4kSSWFdt51TZQpmuYtxXgHAunY1\",\"/_next/static/chunks/15d7387d42764915.js?dpl=dpl_C4kSSWFdt51TZQpmuYtxXgHAunY1\"],\"ReaderBodyPanel\"]\n20:Tf9d,"])</script><script>self.__next_f.push([1,"བྱང་ཆུབ་སེམས་དཔའ་མཉམ་པར་ལྟ་བ་ཞེས་བྱ་དང་། མཉམ་མི་མཉམ་ལྟ་བ་དང་། ཏིང་ངེ་འཛིན་རྣམ་པར་སྤྲུལ་པའི་རྒྱལ་པོ་དང་། ཆོས་ཀྱི་དབང་ཕྱུག་དང་། ཆོས་ཀྱི་ཏོག་དང་། \nའོད་ཀྱི་ཏོག་དང་། འོད་བཀོད་པ་དང་། རིན་པོ་ཆེ་བཀོད་པ་དང་། བཀོད་པ་ཆེན་པོ་དང་། སྤོབས་པ་བརྩེགས་པ་དང་། རིན་པོ་ཆེ་བརྩེགས་པ་དང་། ལག་ན་རིན་པོ་ཆེ་དང་། ལག་ན་ཕྱག་རྒྱ་རིན་པོ་ཆེ་དང་། རྟག་ཏུ་ལག་བརྐྱང་དང་། རྟག་ཏུ་ལག་བཏེག་དང་། རྟག་ཏུ་གདུང་དང་། \nརྟག་ཏུ་དགའ་དགོད་དབང་པོ་དང་། མཆོག་ཏུ་དགའ་བའི་རྒྱལ་པོ་དང་། ལྷའི་རྒྱལ་པོ་དང་། སྨོན་ལམ་ལ་ཞུགས་པས་ཕྱིན་པ་དང་། སོ་སོ་ཡང་དག་པར་རིག་པ་རབ་ཏུ་བསྒྲུབ་པ་ཐོབ་དང་། ནམ་མཁའི་མཛོད་དང་། རིན་ཆེན་སྒྲོན་མ་འཛིན་དང་། རིན་ཆེན་དཔའ་དང་། རིན་ཆེན་\nདགའ་བ་དང་། རིན་ཆེན་དཔལ་དང་། མིག་འཕྲུལ་ཅན་དང་། དྲ་བ་ཅན་གྱི་འོད་དང་། དམིགས་པ་མེད་པའི་བསམ་གཏན་དང་། ཤེས་རབ་བརྩེགས་དང་། རིན་ཆེན་གཏོང་དང་། བདུད་འཇོམས་དང་། གློག་གི་ལྷ་དང་། རྣམ་པར་འཕྲུལ་པའི་རྒྱལ་པོ་དང་། མཚན་བརྩེགས་\nཡང་དག་འདས་དང་། སེང་གེའི་ང་རོ་མངོན་པར་བསྒྲགས་པའི་དབྱངས་དང་། རིའི་རྩེ་མོ་ཀུན་ཏུ་འཇོམས་པའི་རྒྱལ་པོ་དང་། སྤོས་ཀྱི་གླང་པོ་ཆེ་དང་། སྤོས་ཀྱི་བ་གླང་གླང་པོ་ཆེ་དང་། རྟག་ཏུ་འབད་དང་། བརྩོན་པ་མི་འདོར་བ་དང་། རབ་ཀྱི་བློ་གྲོས་དང་། མཛེས་པར་སྐྱེས་དང་།[F.176.b]པད་མོའི་དཔལ་གྱི་སྙིང་པོ་དང་། པད་མོ་བཀོད་པ་དང་། སྤྱན་རས་གཟིགས་ཀྱི་དབང་ཕྱུག་དང་། མཐུ་ཆེན་ཐོབ་དང་། ཚངས་པའི་དྲ་བ་ཅན་དང་། རིན་ཆེན་གདན་དཀར་ཅན་དང་། བདུད་ལས་རྒྱལ་དང་། ཞིང་སྙོམས་བརྒྱན་དང་། ནོར་བུ་རིན་ཆེན་གདུགས་དང་། གཙུག་ན་གསེར་དང་། \nགཙུག་ན་ནོར་བུ་དང་། བྱམས་པ་དང་། འཇམ་དཔལ་གཞོན་ནུར་གྱུར་པ་དང་། དེ་དག་ལ་སོགས་པ་བྱང་ཆུབ་སེམས་དཔའ་སུམ་ཁྲི་ཉིས་སྟོང་ངོ་། །"])</script><script>self.__next_f.push([1,"21:T1060,"])</script><script>self.__next_f.push([1,"རིན་པོ་ཆེའི་གདུགས་དེ་དག་ཕུལ་མ་ཐག་ཏུ་དེའི་མོད་ལ་སངས་རྒྱས་ཀྱི་མཐུས་རིན་པོ་ཆེའི་གདུགས་དེ་དག་གཅིག་ཏུ་གྱུར་ཏེ། རིན་པོ་ཆེའི་གདུགས་དེས་སྟོང་གསུམ་གྱི་སྟོང་ཆེན་\nཔོའི་འཇིག་རྟེན་གྱི་ཁམས་འདི་ཐམས་ཅད་ཁེབས་པར་སྣང་ངོ་། །སྟོང་གསུམ་གྱི་སྟོང་ཆེན་པོའི་འཇིག་རྟེན་གྱི་ཁམས་ཀྱི་ཆུ་ཞེང་དེ་དག་ཀྱང་རིན་པོ་ཆེའི་གདུགས་ཆེན་པོ་དེ་ཉིད་ཀྱི་ནང་ན་སྣང་ངོ་། །སྟོང་གསུམ་གྱི་སྟོང་ཆེན་པོའི་འཇིག་རྟེན་གྱི་ཁམས་འདི་ན་རིའི་རྒྱལ་པོ་རི་རབ་གང་དག་ཡོད་\nཔ་རྣམས་དང་། གངས་རི་དང་། རི་བཏང་བཟུང་དང་། རི་བཏང་བཟུང་ཆེན་པོ་དང་། སྤོས་ཀྱི་ངད་ལྡན་དང་། རིན་པོ་ཆེའི་རི་དང་། རི་ནག་པོ་དང་། ཁོར་ཡུག་དང་། ཁོར་ཡུག་ཆེན་པོ་དང་། དེ་དག་ཐམས་ཅད་ཀྱང་རིན་པོ་ཆེའི་གདུགས་ཆེན་པོ་དེ་ཉིད་ཀྱི་ནང་ན་སྣང་ངོ་། །སྟོང་\nགསུམ་གྱི་སྟོང་ཆེན་པོའི་འཇིག་རྟེན་གྱི་ཁམས་འདི་ན་རྒྱ་མཚོ་ཆེན་པོ་གང་དག་ཡོད་པ་རྣམས་དང་། མཚོ་དང་། མཚེའུ་དང་། རྫིང་དང་། འབབ་ཆུ་དང་། ཆུ་བྲན་དང་། ལུ་མ་འབབ་པ་དེ་དག་ཐམས་ཅད་ཀྱང་རིན་པོ་ཆེའི་གདུགས་ཆེན་པོ་དེ་ཉིད་ཀྱི་ནང་ན་སྣང་ངོ་། །སྟོང་གསུམ་གྱི་སྟོང་ཆེན་པོའི་\nའཇིག་རྟེན་གྱི་ཁམས་འདི་ན་ཉི་མ་དང་ཟླ་བའི་གཞལ་མེད་ཁང་དང་། སྐར་མའི་གཟུགས་དང་། ལྷའི་གནས་དང་། ཀླུའི་གནས་དང་། གནོད་སྦྱིན་དང་། དྲི་ཟ་དང་། ལྷ་མ་ཡིན་དང་། ནམ་མཁའ་ལྡིང་དང་། མིའམ་ཅི་དང་། ལྟོ་འཕྱེ་ཆེན་པོའི་གནས་རྣམས་དང་། རྒྱལ་པོ་ཆེན་པོ་བཞིའི་\nགནས་དང་། གྲོང་དང་། གྲོར་ཁྱེར་དང་། གྲོང་རྡལ་དང་། ཡུལ་འཁོར་དང་། རྒྱལ་པོའི་ཕོ་བྲང་འཁོར་ཇི་སྙེད་ཡོད་པ་དེ་དག་ཐམས་ཅད་ཀྱང་རིན་པོ་ཆེའི་གདུགས་ཆེན་པོ་གཅིག་པོ་དེ་ཉིད་ཀྱི་ནང་ན་སྣང་ངོ་། །ཕྱོགས་བཅུའི་འཇིག་རྟེན་ན་སངས་རྒྱས་བཅོམ་ལྡན་འདས་རྣམས་ཀྱི་ཆོས་སྟོན་པ་\nགང་འབྱུང་བ་དེ་ཡང་རིན་པོ་ཆེའི་གདུགས་ཆེན་པོ་གཅིག་པོ་དེ་ལས་འབྱུང་བའི་སྒྲར་གྲག་གོ། །"])</script><script>self.__next_f.push([1,"22:Tc08,གྲོགས་པོ་དག་ལུས་འདི་ནི་འདི་ལྟར་\nམི་རྟག་པ། འདི་ལྟར་མི་བརྟན་པ། འདི་ལྟར་ཡིད་བརྟན་དུ་མི་རུང་བ། འདི་ལྟར་ཉམ་ཆུང་བ། འདི་ལྟར་སྙིང་པོ་མེད་པ། འདི་ལྟར་ཞིག་པ། འདི་ལྟར་ཡུན་ཐུང་བ། འདི་ལྟར་སྡུག་བསྔལ་བ། འདི་ལྟར་ནད་མང་བ། འདི་ལྟར་འགྱུར་བའི་ཆོས་ཅན་ནོ། །གྲོགས་པོ་\nདག་འདི་ལྟར་ལུས་འདི་ནི་ནད་མང་པོའི་སྣོད་དེ། མཁས་པས་དེ་ལ་གནས་པར་མི་བྱའོ། །གྲོགས་པོ་དག་ལུས་འདི་ནི་བཅང་མི་བཟོད་པ་སྟེ། དབུ་བ་རྡོས་པ་ལྟ་བུའོ། །ལུས་འདི་ནི་རིང་དུ་མི་གནས་པ་སྟེ། ཆུའི་ཆུ་བུར་ལྟ་བུའོ། །ལུས་འདི་ནི་ཉོན་མོངས་པའི་སྲེད་པ་ལས་བྱུང་བ་\nསྟེ། སྨིག་རྒྱུ་ལྟ་བུའོ། །ལུས་འདི་ནི་སྙིང་པོ་མེད་པ་སྟེ་ཆུ་ཤིང་གི་སྡོང་པོ་ལྟ་བུའོ། །ཀྱེ་མ་ལུས་འདི་ནི་རུས་པ་ལ་རྒྱུས་པས་སྦྲེལ་བ་སྟེ་འཁྲུལ་འཁོར་ལྟ་བུའོ། །ལུས་འདི་ནི་ཕྱིན་ཅི་ལོག་ལས་བྱུང་བ་སྟེ་སྒྱུ་མ་ལྟ་བུའོ། །ལུས་འདི་ནི་ཡང་དག་པ་མ་ཡིན་པ་མཐོང་བ་སྟེ་རྨི་ལམ་ལྟ་\nབུའོ། །ལུས་འདི་ནི་སྔོན་གྱི་ལས་ཀྱིས་གཟུགས་བརྙན་སྣང་བ་སྟེ་གཟུགས་བརྙན་ལྟ་བུའོ། །ལུས་འདི་ནི་རྐྱེན་ལ་རག་ལུས་པའི་ཕྱིར་བྲག་ཅ་ལྟ་བུའོ། །ལུས་འདི་ནི་སེམས་འཁྲུག་ཅིང་འགྱེས་པའི་མཚན་ཉིད་དེ་སྤྲིན་ལྟ་བུའོ། །ལུས་འདི་ནི་སྐད་ཅིག་ཏུ་འཇིག་པ་དང་ལྡན་ཞིང་མི་གནས་པ་སྟེ་\nགློག་དང་མཚུངས་སོ། །ལུས་འདི་ནི་རྐྱེན་སྣ་ཚོགས་ལས་བྱུང་བ་སྟེ་བདག་པོ་མེད་པའོ། །23:Tba4,གྲོགས་པོ་དག་དེ་བཞིན་གཤེགས་པའི་སྐུ་ནི་ཆོས་ཀྱི་སྐུ་སྟེ་ཡེ་ཤེས་ལས་སྐྱེས་པའོ། །དེ་བཞིན་གཤེགས་པའི་སྐུ་ནི་བསོད་ནམས་\nལས་སྐྱེས་པ། སྦྱིན་པ་ལས་སྐྱེས་པ། ཚུལ་ཁྲིམས་ལས་སྐྱེས་པ། ཏིང་ངེ་འཛིན་ལས་སྐྱེས་པ། ཤེས་རབ་ལས་སྐྱེས་པ། རྣམ་པར་གྲོལ་བ་ལས་སྐྱེས་པ། རྣམ་པར་གྲོལ་བའི་ཡེ་ཤེས་མཐོང་བ་ལས་སྐྱེས་པ། བྱམས་པ་དང་། སྙིང་རྗེ་དང་། དགའ་བ་དང་། བཏང་\nསྙོམས་ལས་སྐྱེས་པ། སྦྱིན་པ"])</script><script>self.__next_f.push([1,"་དང་། དུལ་བ་དང་། ཡང་དག་པར་སྡོམ་པ་ལས་སྐྱེས་པ། དགེ་བ་བཅུའི་ལས་ཀྱི་ལམ་ལས་སྐྱེས་པ། བཟོད་པ་དང་དེས་པ་ལས་སྐྱེས་པ། བརྩོན་འགྲུས་བརྟན་པའི་དགེ་བའི་རྩ་བ་ལས་སྐྱེས་པ། བསམ་གཏན་དང་། རྣམ་པར་ཐར་པ་\nདང་། ཏིང་ངེ་འཛིན་དང་། སྙོམས་པར་འཇུག་པ་ལས་སྐྱེས་པ། ཐོས་པ་དང་། ཤེས་རབ་དང་། ཐབས་ལས་སྐྱེས་པ། བྱང་ཆུབ་ཀྱི་ཕྱོགས་ཀྱི་ཆོས་སུམ་ཅུ་རྩ་བདུན་ལས་སྐྱེས་པ། ཞི་གནས་དང་ལྷག་མཐོང་ལས་སྐྱེས་པ། སྟོབས་བཅུ་ལས་སྐྱེས་པ། མི་འཇིགས་པ་བཞི་ལས་\nསྐྱེས་པ། སངས་རྒྱས་ཀྱི་ཆོས་མ་འདྲེས་པ་བཅྭ་བརྒྱད་ལས་སྐྱེས་པ། ཕ་རོལ་ཏུ་ཕྱིན་པ་ཐམས་ཅད་ལས་སྐྱེས་པ། མངོན་པར་ཤེས་པ་དང་རིག་པ་ལས་སྐྱེས་པ། མི་དགེ་བའི་ཆོས་ཐམས་ཅད་སྤོང་བ་ལས་སྐྱེས་པ། དགེ་བའི་ཆོས་ཐམས་ཅད་ཡང་དག་པར་སྡུད་པ་ལས་སྐྱེས་པ།[F.184.a]དབེན་པ་ལས་སྐྱེས་པ། ཡང་དག་པ་ཉིད་ལས་སྐྱེས་པ། བག་ཡོད་པ་ལས་སྐྱེས་པའོ། །24:T100e,"])</script><script>self.__next_f.push([1,"དེ་ནས་བཅོམ་ལྡན་འདས་ཀྱིས་ལིད་ཙ་བཱི་དྲི་མ་མེད་པར་གྲགས་པའི་སེམས་ཀྱི་རྟོག་པ་དེ་ལྟ་བུ་\nམཁྱེན་ནས་བཅོམ་ལྡན་འདས་ཀྱིས་ཚེ་དང་ལྡན་པ་ཤཱ་རིའི་བུ་ལ་བཀའ་སྩལ་པ། ཤཱ་རིའི་བུ་ཁྱོད་ལིད་ཙ་བཱི་དྲི་མ་མེད་པར་གྲགས་པའི་ནད་འདྲིར་སོང་ཤིག །དེ་སྐད་ཅེས་བཀའ་སྩལ་པ་དང་། བཅོམ་ལྡན་འདས་ལ་ཚེ་དང་ལྡན་པ་ཤཱ་རིའི་བུས་འདི་སྐད་ཅེས་གསོལ་ཏོ། །བཅོམ་ལྡན་\nའདས་བདག་ལིད་ཙ་བཱི་དྲི་མ་མེད་པར་གྲགས་པའི་བྲོ་འདྲི་ཞིང་མཆི་བར་མི་སྤྲོའོ། །དེ་ཅིའི་སླད་དུ་ཞེ་ན། བཅོམ་ལྡན་འདས་བདག་གིས་མངོན་པར་འཚལ་བ་དུས་གཅིག་ན། ཤིང་ཞིག་གི་དྲུང་ན་ནང་དུ་ཡང་དག་བཞག་པར་གྱུར་པ་ན་ལིད་ཙ་བཱི་དྲི་མ་མེད་པར་གྲགས་པ་ཡང་ཤིང་དེའི་དྲུང་ག་\nལ་བ་དེར་མཆིས་ནས་བདག་ལ་འདི་སྐད་ཅེས་མཆིའོ། །བཙུན་པ་ཤཱ་རིའི་བུ་ཇི་ལྟར་ཁྱོད་ཀྱིས་ནང་དུ་ཡང་དག་བཞག་པ་དེ་ལྟ་བུའི་ནང་དུ་ཡང་དག་འཇོག་པ་ལ་ནང་དུ་ཡང་དག་བཞག་པ་མི་བྱའོ། །ཇི་ལྟར་ཁམས་གསུམ་དུ་ལུས་དང་སེམས་མི་སྣང་བར་འགྱུར་བ་དེ་ལྟར་ནང་དུ་ཡང་དག་གཞག་[F.184.b]པར་གྱིས་ཤིག །ཇི་ལྟར་འགོག་པ་ལས་ཀྱང་མི་ལྡང་ཞིང་སྤྱོད་ལམ་ཀུན་དུ་ཡང་སྣང་བར་འགྱུར་བ་དེ་ལྟར་ནང་དུ་ཡང་དག་གཞག་པར་གྱིས་ཤིག །ཇི་ལྟར་ཐོབ་པའི་མཚན་ཉིད་ཀྱང་མི་འདོར་ལ་སོ་སོའི་སྐྱེ་བོའི་མཚན་ཉིད་དུ་ཡང་སྣང་བ་དེ་ལྟར་ནང་དུ་ཡང་དག་གཞག་པར་གྱིས་ཤིག །ཇི་ལྟར་ཁྱོད་\nཀྱི་སེམས་ནང་ན་ཡང་མི་འདུག་ལ་ཕྱི་རོལ་གྱི་གཟུགས་ལ་ཡང་མི་རྒྱུ་བ་དེ་ལྟར་ནང་དུ་ཡང་དག་གཞག་པར་གྱིས་ཤིག །ཇི་ལྟར་ལྟ་བར་གྱུར་པ་ཐམས་ཅད་ལ་ཡང་མི་གཡོ་ཞིང་བྱང་ཆུབ་ཀྱི་ཕྱོགས་ཀྱི་ཆོས་སུམ་ཅུ་རྩ་བདུན་རྣམས་ལ་ཡང་སྣང་བ་དེ་ལྟར་ནང་དུ་ཡང་དག་གཞག་པར་གྱིས་ཤིག །ཇི་ལྟར་\nའཁོར་བ་ན་སྤྱོད་པའི་ཉོན་མོངས་པ་རྣམས་ཀྱང་མི་སྤོང་ལ། མྱ་ངན་ལས་འདས་པ་ལ་ཡང་ཡང་དག་པར་གཞོལ་བར་འགྱུར་བ་དེ་ལྟར་ནང་དུ་ཡང་དག་གཞག་པར་གྱིས་ཤིག །"])</script><script>self.__next_f.push([1,"25:Tf31,དེ་ནས་བཅོམ་ལྡན་འདས་ཀྱིས་ཚེ་དང་ལྡན་པ་འོད་སྲུང་ཆེན་པོ་ལ་བཀའ་སྩལ་པ། འོད་སྲུང་ཁྱོད་ལིད་ཙ་བཱི་དྲི་མ་མེད་\nཔར་གྲགས་པའི་ནད་འདྲིར་སོང་ཤིག །འོད་སྲུང་ཆེན་པོས་ཀྱང་གསོལ་པ། བཅོམ་ལྡན་འདས་བདག་སྐྱེས་བུ་དམ་པ་དེའི་བྲོ་འདྲི་ཞིང་མཆི་བར་མི་སྤྲོའོ། །དེ་ཅིའི་སླད་དུ་ཞེ་ན། བདག་གིས་མངོན་པར་འཚལ་བ་དུས་གཅིག་ན། དབུལ་པོའི་སྲང་དུ་བསོད་སྙོམས་ལ་མཆིས་ན་ལིད་ཙ་བཱི་\nདྲི་མ་མེད་པར་གྲགས་པ་དེར་མཆིས་ནས་བདག་ལ་འདི་སྐད་ཅེས་མཆིའོ། །འདི་ལྟར་སེམས་ཅན་ཆེན་པོའི་ཁྱིམ་བཀོལ་ཏེ་དབུལ་པོའི་ཁྱིམ་རྣམས་སུ་འགྲོ་བ་ནི་བཙུན་པ་འོད་སྲུང་ཆེན་པོའི་བྱམས་པ་ཕྱོགས་གཅིག་པ་ཡིན་གྱི་བཙུན་པ་འོད་སྲུང་ཆེན་པོ་ཆོས་མཉམ་པ་ཉིད་ལ་གནས་པར་བྱའོ། །\nདུས་ཐམས་ཅད་དུ་སེམས་ཅན་ཐམས་ཅད་ལ་བསམས་ཏེ་བསོད་སྙོམས་བཙལ་བར་བྱའོ། །ཟས་མེད་པར་ཟས་བཙལ་བར་བྱའོ། །གཞན་གྱི་རིལ་པོར་འཛིན་པ་བཙལ་བའི་ཕྱིར་ཁྱོད་བསོད་སྙོམས་ལ་འགྲོ་བར་བྱའོ། །གྲོང་སྟོང་པར་བྱིན་གྱིས་བརླབས་ཏེ་ཁྱོད་གྲོང་དུ་འཇུག་པར་བྱའོ། །\nསྐྱེས་པ་དང་བུད་མེད་ཡོངས་སུ་སྨིན་པར་བྱ་བའི་ཕྱིར་ཁྱོད་གྲོང་ཁྱེར་དུ་འཇུག་པར་བྱའོ། །སངས་རྒྱས་ཀྱི་རིགས་ཀྱིས་ཁྱོད་ཁྱིམ་དུ་འགྲོ་བར་བྱའོ། །མི་ལེན་པས་བསོད་སྙོམས་བླང་བར་བྱའོ། །དམུས་ལོང་དང་མཚུངས་པར་གཟུགས་རྣམས་ལ་བལྟའོ། །བྲག་ཅ་དང་འདྲ་བར་སྒྲ་རྣམས་[F.186.a]མཉན་ཏོ། །རླུང་དང་མཚུངས་པར་དྲི་རྣམས་མནམ་མོ། །རྣམ་པར་རིག་པ་མེད་པས་རོ་རྣམས་མྱང་ངོ་། །ཡེ་ཤེས་ལ་རེག་པ་མེད་པས་རེག་བྱ་རྣམས་ལ་རེག་པར་བྱའོ། །སྒྱུ་མའི་སྐྱེས་བུའི་རྣམ་པར་རིག་པས་ཆོས་རྣམས་ལ་རིག་པར་བྱའོ། །གང་བདག་གི་དངོས་\nཔོ་དང་གཞན་གྱི་དངོས་པོ་མེད་པ་དེ་ནི་མི་འབར་བའོ། །གང་མི་འབར་བ་དེ་ནི་ཞི་བར་མི་འགྱུར་རོ། །26:Tedf,དེ་ནས་[F.186.b]བཅོམ་ལྡན་འདས་ཀྱིས་ཚེ་དང་ལྡན་པ་རབ་འབྱོར་ལ་བཀའ་སྩལ་པ། རབ་"])</script><script>self.__next_f.push([1,"འབྱོར་ཁྱོད་ལིད་ཙ་བཱི་དྲི་མ་མེད་པར་གྲགས་པའི་ནད་འདྲིར་སོང་ཤིག །རབ་འབྱོར་གྱིས་ཀྱང་གསོལ་པ། བཅོམ་ལྡན་འདས་བདག་སྐྱེས་བུ་དམ་པ་དེའི་བྲོ་འདྲི་ཞིང་འཆི་བར་མི་སྤྲོའོ། །དེ་ཅིའི་སླད་དུ་ཞེ་ན། བཅོམ་\nལྡན་འདས་བདག་གིས་མངོན་པར་འཚལ་བ་དུས་གཅིག་ན། ཡངས་པའི་གྲོང་ཁྱེར་ཆེན་པོར་ལིད་ཙ་བཱི་དྲི་མ་མེད་པར་གྲགས་པའི་ཁྱིམ་དུ་བསོད་སྙོམས་ལ་མཆིས་པ་དང་། ལིད་ཙ་བཱི་དྲི་མ་མེད་པར་གྲགས་པས་བདག་གི་ལྷུང་བཟེད་འཚལ་ནས་ཟས་བཟང་པོས་བཀང་སྟེ་འདི་སྐད་ཅེས་མཆིའོ། \nབཙུན་པ་རབ་འབྱོར་ཁྱོད་གལ་ཏེ་ཟང་ཟིང་གི་མཉམ་པ་ཉིད་ཀྱིས་ཆོས་ཐམས་ཅད་ཀྱི་མཉམ་པ་ཉིད་རྗེས་སུ་རྟོགས་ཤིང་། ཆོས་ཐམས་ཅད་ཀྱི་མཉམ་པ་ཉིད་ཀྱིས་སངས་རྒྱས་ཀྱི་ཆོས་ཀྱི་མཉམ་པ་ཉིད་རྗེས་སུ་རྟོགས་ན་གཟོད་བསོད་སྙོམས་འདི་ལོང་ཤིག །བཙུན་པ་རབ་འབྱོར་ཁྱོད་\nགལ་ཏེ་འདོད་ཆགས་དང་། ཞེ་སྡང་དང་། གཏི་མུག་ཀྱང་མ་སྤངས་ལ་དེ་དག་དང་ལྷན་ཅིག་ཏུ་ཡང་མི་གནས། གལ་ཏེ་འཇིག་ཚོགས་ལ་ལྟ་བའང་མ་བསྐྱོད་ལ་བགྲོད་པ་གཅིག་པའི་ལམ་དུ་ཡང་སོང་། ཁྱོད་ཀྱིས་མ་རིག་པ་དང་སྲིད་པའི་སྲེད་པ་ཡང་མ་བཅོམ་ལ་རིག་པ་དང་རྣམ་པར་\nགྲོལ་བ་ཡང་མ་སྐྱེད། མཚམས་མེད་པའི་མཉམ་པ་ཉིད་དང་། ཁྱོད་ཀྱི་རྣམ་པར་གྲོལ་བ་ཡང་མཚུངས། ཁྱོད་གྲོལ་བ་ཡང་མ་ཡིན་ལ་བཅིངས་པ་ཡང་མ་ཡིན། ཁྱོད་ཀྱིས་འཕགས་པའི་བདེན་པ་བཞི་འང་མ་མཐོང་ལ་བདེན་པ་མ་མཐོང་བ་ཡང་མ་ཡིན། འབྲས་བུ་ཐོབ་\nཔའང་མ་ཡིན་ལ་སོ་སོའི་སྐྱེ་བོའང་མ་ཡིན་སོ་སོའི་སྐྱེ་བོའི་ཆོས་ལས་ཀྱང་མ་ལོག །ཁྱོད་འཕགས་པའང་མ་ཡིན་ལ་མ་འཕགས་པའང་མ་ཡིན། ཆོས་ཐམས་ཅད་དང་ཡང་ལྡན་ལ་ཆོས་ཐམས་ཅད་ཀྱི་འདུ་ཤེས་དང་ཡང་བྲལ། 27:Tcae,དེ་ནས་བཅོམ་\nལྡན་འདས་ཀྱིས་ཚེ་དང་ལྡན་པ་ཀཱ་ཏྱའི་བུ་ཆེན་པོ་ལ་བཀའ་སྩལ་པ། ཀཱ་ཏྱའི་བུ་ཁྱོད་ལིད་ཙ་བཱི་དྲི་མ་མེད་པར་གྲགས་པའི་ནད་འདྲིར་སོང་ཤིག །ཀཱ་ཏྱའི་བུས་ཀྱང་གསོལ་པ། བ"])</script><script>self.__next_f.push([1,"ཅོམ་ལྡན་འདས་བདག་སྐྱེས་བུ་དམ་པ་དེའི་བྲོ་འདྲི་ཞིང་མཆི་བར་མི་སྤྲོའོ། །དེ་ཅིའི་སླད་དུ་ཞེ་ན། བཅོམ་\nལྡན་འདས་བདག་གིས་མངོན་པར་འཚལ་བ་དུས་གཅིག་ན། བཅོམ་ལྡན་འདས་ཀྱིས་དགེ་སློང་རྣམས་ལ་གདམས་པ་མདོར་བཀའ་སྩལ་ཏེ། མདོ་དེའི་ཚིག་གཏན་ལ་དབབ་པའི་སླད་དུ་བདག་གིས་འདི་ལྟ་སྟེ། མི་རྟག་པའི་དོན་དང་། སྡུག་བསྔལ་བའི་དོན་དང་། བདག་མེད་པའི་[F.188.b]དོན་དང་། ཞི་བའི་དོན་གྱི་ཆོས་བསྟན་ན་ལིད་ཙ་བཱི་དྲི་མ་མེད་པར་གྲགས་པ་དེར་མཆིས་ནས་བདག་ལ་འདི་སྐད་ཅེས་མཆིའོ། །བཙུན་པ་ཀཱ་ཏྱའི་བུ་ཆེན་པོ་རྒྱུ་བ་དང་བཅས་པ། སྐྱེ་བ་དང་བཅས་པ་འཇིག་པ་དང་ལྡན་པའི་ཆོས་ཉིད་མ་སྟོན་ཅིག །བཙུན་པ་ཀཱ་ཏྱའི་བུ་ཆེན་པོ་གང་\nཤིན་ཏུ་མ་སྐྱེས། མ་བསྐྱེད། སྐྱེད་པར་མི་འགྱུར། མ་འགགས། མི་འགག །འགག་པར་མི་འགྱུར་བ་དེ་ནི་མི་རྟག་པའི་དོན་ཏོ། གང་ཕུང་པོ་ལྔ་པོ་དག་ལ་སྟོང་པ་ཉིད་དུ་རྟོགས་པས་སྐྱེ་བ་མེད་པ་རྟོག་པའི་དོན་དེ་ནི་སྡུག་བསྔལ་གྱི་དོན་ཏོ། །གང་བདག་དང་བདག་མེད་པ་གཉིས་\nསུ་མེད་པ་ཉིད་དེ་ནི་བདག་མེད་པའི་དོན་ཏོ། །གང་རང་གི་ངོ་བོ་མེད་པ་དང་། གཞན་གྱི་ངོ་བོ་མེད་པ་དེ་ནི་མི་འབར་ཏེ། གང་མི་འབར་བ་དེ་ནི་ཞི་བར་མི་འགྱུར་ཞིང་། གང་རབ་ཏུ་མ་ཞི་བ་དེ་ནི་ཞི་བའི་དོན་ཏོ། །28:Tfae,བཅོམ་ལྡན་འདས་ཀྱིས་ཚེ་དང་ལྡན་པ་མ་འགགས་པ་ལ་བཀའ་སྩལ་པ། མ་འགགས་པ་ཁྱོད་ལིད་ཙ་བཱི་དྲི་མ་མེད་པར་གྲགས་པའི་ནད་འདྲིར་སོང་\nཤིག །མ་འགགས་པས་ཀྱང་གསོལ་པ། བཅོམ་ལྡན་འདས་བདག་སྐྱེས་བུ་དམ་པ་དེའི་བྲོ་འདྲི་ཞིང་མཆི་བར་མི་སྤྲོའོ། །དེ་ཅིའི་སླད་དུ་ཞེ་ན། བཅོམ་ལྡན་འདས་བདག་གིས་མངོན་པར་འཚལ་བ་དུས་གཅིག་ན། བདག་འཆག་ས་ཞིག་ན་འཆག་པ་དེར་ཚངས་པ་ཆེན་པོ་དགེ་\nབ་བཀོད་པ་ཞེས་བགྱི་བ་ཚངས་པ་ཁྲི་དང་ལྷན་ཅིག་ཕྱོགས་དེ་སྣང་བར་བགྱིས་ནས་བདག་ག་ལ་བ་དེར་མཆིས་ཏེ། བདག་གི་རྐང་པ་ལ་མགོ་བོས་ཕྱག་བགྱིས་ནས"])</script><script>self.__next_f.push([1,"་ཕྱོགས་གཅིག་ཏུ་འཁོད་དེ་བདག་ལ་འདི་སྐད་ཅེས་མཆིའོ། །བཙུན་པ་མ་འགགས་པ་ཁྱོད་བཅོམ་ལྡན་འདས་ཀྱིས་ལྷའི་\nམིག་ཅན་གྱི་མཆོག་ཏུ་གསུངས་ན། ཚེ་དང་ལྡན་པ་མ་འགགས་པའི་ལྷའི་མིག་གིས་ཇི་སྲིད་ཚུན་ཆད་མཐོང་། བདག་གིས་དེ་ལ་འདི་སྐད་ཅེས་བགྱིས་སོ། །གྲོགས་པོ་དག་ཁོ་བོས་ནི་བཅོམ་ལྡན་འདས་ཤཱཀྱ་ཐུབ་པའི་སངས་རྒྱས་ཀྱི་ཞིང་སྟོང་གསུམ་གྱི་སྟོང་ཆེན་པོའི་འཇིག་རྟེན་གྱི་[F.189.a]ཁམས་ནི་འདི་ལྟ་སྟེ། དཔེར་ན་སྐྱེས་བུ་མིག་དང་ལྡན་པའི་ལག་མཐིལ་དུ་སྐྱུ་རུ་རའི་འབྲས་བུ་བཞག་པ་བཞིན་དུ་མཐོང་ངོ་ཞེས་བཀའ་མཆིད་འདི་བགྱིས་པ་དང་། ལིད་ཙ་བཱི་དྲི་མ་མེད་པར་གྲགས་པ་ཕྱོགས་དེར་མཆིས་ཏེ། བདག་གི་རྐང་པ་ལ་མགོ་བོས་ཕྱག་བགྱིས་\nནས་བདག་ལ་འདི་སྐད་ཅེས་མཆིའོ། །བཙུན་པ་མ་འགགས་པའི་ལྷའི་མིག་མངོན་པར་འདུ་བྱེད་པའི་མཚན་ཉིད་དམ། འོན་ཏེ་མངོན་པར་འདུ་མི་བྱེད་པའི་མཚན་ཉིད་ཡིན། དེ་གལ་ཏེ་མངོན་པར་འདུ་བྱེད་པའི་མཚན་ཉིད་ཡིན་ན་ནི་ཕྱི་རོལ་གྱི་མངོན་པར་ཤེས་པ་ལྔ་དང་མཚུངས་སོ། །ཇི་\nསྟེ་མངོན་པར་འདུ་མི་བྱེད་པ་ཡིན་ན་ནི་མངོན་པར་འདུ་མི་བྱེད་པ་ནི་འདུས་མ་བྱས་པ་ཡིན་ཏེ། དེས་ནི་མཐོང་བར་མི་ནུས་ན་གནས་བརྟན་གྱིས་ཇི་ལྟར་མཐོང་ཞེས་མཆི་ནས་"])</script><script>self.__next_f.push([1,"17:[\"$\",\"$L1f\",null,{\"titles\":[{\"uuid\":\"f67afab4-5b93-469e-a245-e266fd6c4cec\",\"title\":\"Toh 176\",\"language\":\"en\",\"type\":\"toh\"},{\"uuid\":\"b707f3f2-9681-43bc-92a8-78535aeec6f7\",\"title\":\"dri med grags pas bstan pa\",\"language\":\"Bo-Ltn\",\"type\":\"mainTitle\"},{\"uuid\":\"41bf1050-cf9c-49be-92af-eff426fa7b3a\",\"title\":\"དྲི་མེད་གྲགས་པས་བསྟན་པ།\",\"language\":\"bo\",\"type\":\"mainTitle\"},{\"uuid\":\"1f383eb5-b1e2-45af-a8de-41a96f2dac25\",\"title\":\"The Teaching of Vimalakīrti\",\"language\":\"en\",\"type\":\"mainTitle\"},{\"uuid\":\"7aaea949-fb29-405d-9bb8-f30075325bf8\",\"title\":\"Vimala­kīrti­nirdeśa\",\"language\":\"Sa-Ltn\",\"type\":\"mainTitle\"},{\"uuid\":\"8dbaf24a-9052-42d8-9ef6-8e8a1f453a59\",\"title\":\"འཕགས་པ་དྲི་མ་མེད་པར་གྲགས་པས་བསྟན་པ་ཞེས་བྱ་བ་ཐེག་པ་ཆེན་པོའི་མདོ།\",\"language\":\"bo\",\"type\":\"longTitle\"},{\"uuid\":\"12c76a3d-0a81-48a3-9cfa-88a64f8fd135\",\"title\":\"’phags pa dri ma med par grags pas bstan pa zhes bya ba theg pa chen po’i mdo\",\"language\":\"Bo-Ltn\",\"type\":\"longTitle\"},{\"uuid\":\"35e2d35f-e728-43a4-bc2c-c3ad351f813f\",\"title\":\"The Noble Mahāyāna Sūtra “The Teaching of Vimalakīrti”\",\"language\":\"en\",\"type\":\"longTitle\"},{\"uuid\":\"f4f8105d-768d-417b-8c09-fb8fee478530\",\"title\":\"Ārya­vimala­kīrti­nirdeśa­nāma­mahā­yāna­sūtra\",\"language\":\"Sa-Ltn\",\"type\":\"longTitle\"}],\"frontMatter\":[{\"type\":\"passage\",\"attrs\":{\"uuid\":\"6ec8007b-cbc4-4261-a0b8-72366b4cb5d3\",\"sort\":2,\"type\":\"summaryHeader\",\"label\":\"s.\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":2,\"start\":0,\"end\":7,\"uuid\":\"08b06feb-9de9-4b91-af4c-31963c92bc9b\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"Summary\",\"attrs\":{\"start\":0,\"end\":7}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"b0103ff1-c252-47ab-9679-1507969ed142\",\"sort\":4,\"type\":\"summary\",\"label\":\"s.1\",\"alignments\":{}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":866,\"uuid\":\"b0103ff1-c252-47ab-9679-1507969ed142\"},\"content\":[{\"type\":\"text\",\"text\":\"While the \",\"attrs\":{\"start\":0,\"end\":10}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":10,\"end\":16},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"b37956ae-4d7b-4047-8257-ab0a0e8f24fb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is teaching outside the city of \",\"attrs\":{\"start\":16,\"end\":49}},{\"type\":\"text\",\"text\":\"Vaiśālī\",\"attrs\":{\"start\":49,\"end\":56},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e9c61804-d922-4a99-88ea-836faa6fd3c4\",\"uuid\":\"fdef8253-ad39-44cc-8ed8-0cccaeafdbf4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", a notable householder in the city‍—the great \",\"attrs\":{\"start\":56,\"end\":103}},{\"type\":\"text\",\"text\":\"bodhisattva\",\"attrs\":{\"start\":103,\"end\":114},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c72eb4f3-700e-454d-996e-5ccdba29e6be\",\"uuid\":\"2089ac93-5c16-4f11-981d-33b62f2ef3ac\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":114,\"end\":115}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":115,\"end\":126},\"marks\":[{\"type\":\"glossaryInstance\"