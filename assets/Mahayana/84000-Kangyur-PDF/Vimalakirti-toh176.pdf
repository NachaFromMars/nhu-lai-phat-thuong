-a821-7baabb2c0815\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" so that the mind neither settles within nor moves without toward external forms. You should absorb yourself in \",\"attrs\":{\"start\":1020,\"end\":1132}},{\"type\":\"text\",\"text\":\"contemplation\",\"attrs\":{\"start\":1132,\"end\":1145},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cec4c4b6-fd31-476f-b413-c84faa28d822\",\"uuid\":\"6a4b45c3-d581-401d-b3ce-efa414210401\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in such a way that the \",\"attrs\":{\"start\":1145,\"end\":1169}},{\"type\":\"text\",\"text\":\"thirty-seven aids to enlightenment\",\"attrs\":{\"start\":1169,\"end\":1203},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b5963753-f922-454c-a492-de9a236d39e5\",\"uuid\":\"31e8ee0f-c96f-4ddd-b74d-a63335ee7ed9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" are manifest without deviation toward any convictions. You should absorb yourself in \",\"attrs\":{\"start\":1203,\"end\":1289}},{\"type\":\"text\",\"text\":\"contemplation\",\"attrs\":{\"start\":1289,\"end\":1302},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cec4c4b6-fd31-476f-b413-c84faa28d822\",\"uuid\":\"829d542e-9654-4360-a953-d68fe4fcee60\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in such a way that you are released in \",\"attrs\":{\"start\":1302,\"end\":1342}},{\"type\":\"text\",\"text\":\"liberation\",\"attrs\":{\"start\":1342,\"end\":1352},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1f6de051-60d0-418f-9255-9634be3f22b8\",\"uuid\":\"fa2dcd70-6a57-459f-9863-f6c68d8fb329\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" without abandoning the \",\"attrs\":{\"start\":1352,\"end\":1376}},{\"type\":\"text\",\"text\":\"passions\",\"attrs\":{\"start\":1376,\"end\":1384},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2370c8e3-79cc-4eab-bc82-33939081f558\",\"uuid\":\"b68fe607-c3b1-40fb-b6da-077660e1fd84\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" that are the province of the world.\",\"attrs\":{\"start\":1384,\"end\":1420},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"ab58bcdd-ed89-4eec-b98a-a27405e3cead\",\"label\":\"56\",\"uuid\":\"ebbec74f-e0f7-445a-a812-54b017ccc161\",\"start\":1420,\"end\":1420,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"86a2a432-5c4a-40ac-97c9-6c35c7fb7801\",\"sort\":2099,\"type\":\"translation\",\"label\":\"3.3\",\"alignments\":{\"toh176\":{\"folioUuid\":\"d3e09623-46df-40cd-b8df-350cc293f56a\",\"toh\":\"toh176\",\"tibetan\":\"བཙུན་པ་ཤཱ་རིའི་བུ་གང་དག་དེ་ལྟར་ནང་དུ་ཡང་དག་གཞག་པ་ལ་ནང་དུ་ཡང་དག་འཇོག་ན་དེ་དག་ལ་བཅོམ་ལྡན་\\nའདས་ཀྱིས་ནང་དུ་ཡང་དག་འཇོག་པར་བཀའ་སྩལ་ཏོ་ཞེས་མཆི་ནས། བཅོམ་ལྡན་འདས་བདག་གིས་ཆོས་ཉིད་དེ་ཐོས་ནས་དེ་ལ་སླར་ཚིག་ལན་ལྡོན་པའི་རྔོ་མི་ཐོགས་ཤིང་ཅང་མི་མཆི་བར་འགྱུར་ཏེ། དེའི་སླད་དུ་བདག་སྐྱེས་བུ་དམ་པ་དེའི་བྲོ་འདྲི་ཞིང་མཆི་བར་མི་སྤྲོའོ། །\",\"folioNumber\":184,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":147,\"uuid\":\"7251f53c-c43e-4531-9374-3c9d321d3d0b\"},\"content\":[{\"type\":\"text\",\"text\":\"“ ‘Reverend \",\"attrs\":{\"start\":0,\"end\":12}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":12,\"end\":21},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4da7d125-a1b8-4820-b50f-9de69a2ab346\",\"uuid\":\"8fea6309-24cf-4d56-97d5-21a0235b0558\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", those who absorb themselves in \",\"attrs\":{\"start\":21,\"end\":54}},{\"type\":\"text\",\"text\":\"contemplation\",\"attrs\":{\"start\":54,\"end\":67},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cec4c4b6-fd31-476f-b413-c84faa28d822\",\"uuid\":\"24d5ecf1-10e5-4742-b121-6a2f1dc385cf\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in such a way are declared by the \",\"attrs\":{\"start\":67,\"end\":102}},{\"type\":\"text\",\"text\":\"Lord\",\"attrs\":{\"start\":102,\"end\":106},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41c623b8-3d94-4f8e-b2c5-1d7a5f5af6d3\",\"uuid\":\"edca3db4-1f57-4f6a-82a8-035aba426e2d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" to be truly absorbed in \",\"attrs\":{\"start\":106,\"end\":131}},{\"type\":\"text\",\"text\":\"contemplation\",\"attrs\":{\"start\":131,\"end\":144},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cec4c4b6-fd31-476f-b413-c84faa28d822\",\"uuid\":\"81038fd9-1d53-41ba-b980-3e2e62cb7362\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".’ \",\"attrs\":{\"start\":144,\"end\":147}}]},{\"type\":\"paragraph\",\"attrs\":{\"start\":147,\"end\":298,\"uuid\":\"2b25ff6f-9233-4e73-aac3-ee6280f5483c\"},\"content\":[{\"type\":\"text\",\"text\":\"“\",\"attrs\":{\"start\":147,\"end\":148}},{\"type\":\"text\",\"text\":\"Lord\",\"attrs\":{\"start\":148,\"end\":152},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41c623b8-3d94-4f8e-b2c5-1d7a5f5af6d3\",\"uuid\":\"f3add820-2fe6-4e80-8d3e-0782a9ca4927\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", when I heard this teaching, I was unable to reply and remained silent. Therefore, I am reluctant to go to ask that good man about his sickness.”\",\"attrs\":{\"start\":152,\"end\":298}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"b1eb9b34-6e15-40b3-b6a8-3083af29f2ba\",\"sort\":2112,\"type\":\"translation\",\"label\":\"3.4\",\"alignments\":{\"toh176\":{\"folioUuid\":\"d3e09623-46df-40cd-b8df-350cc293f56a\",\"toh\":\"toh176\",\"tibetan\":\"དེ་ནས་བཅོམ་\\nལྡན་འདས་ཀྱིས་ཚེ་དང་ལྡན་པ་མཽད་གལ་གྱི་བུ་ཆེན་པོ་ལ་བཀའ་སྩལ་པ། མཽད་གལ་གྱི་བུ་ཁྱོད་ལིད་ཙ་བཱི་དྲི་མ་མེད་པར་གྲགས་པའི་ནད་འདྲིར་སོང་ཤིག །མཽད་གལ་གྱི་བུས་ཀྱང་གསོལ་པ། བཅོམ་ལྡན་འདས་བདག་སྐྱེས་བུ་དམ་པ་དེའི་བྲོ་འདྲི་ཞིང་མཆི་བར་མི་སྤྲོའོ། །དེ་ཅིའི་སླད་དུ་ཞེ་ན། \\nབཅོམ་ལྡན་འདས་བདག་གིས་མངོན་པར་འཚལ་བ་དུས་གཅིག་ན། ཡངས་པའི་གྲོང་ཁྱེར་ཆེན་པོའི་སྲང་ཞིག་གི་སྒོ་ན་ཁྱིམ་བདག་རྣམས་ལ་བདག་ཆོས་སྟོན་ཅིང་མཆིས་པའི་དྲུང་དེར་ལིད་ཙ་བཱི་དྲི་མ་མེད་པར་གྲགས་པ་མཆིས་ནས་བདག་ལ་འདི་སྐད་ཅེས་མཆིའོ། །བཙུན་པ་མཽད་གལ་གྱི་བུ་ཇི་\\nལྟར་སྟོན་པ་ལྟར་ནི་ཁྱིམ་པ་གོས་དཀར་པོ་ཅན་རྣམས་ལ་དེ་ལྟར་ཆོས་མི་བསྟན་ཏོ། །བཙུན་པ་མཽད་གལ་གྱི་བུ་ཆོས་དེ་ཇི་ལྟ་བ་བཞིན་དུ་ཆོས་བསྟན་པར་བྱ་སྟེ། \",\"folioNumber\":184,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":136,\"uuid\":\"200e48cc-3fb8-4f2a-97b7-59741f840724\",\"hasLeadingSpace\":true,\"leadingSpaceUuid\":\"37dc8eb7-797e-4a45-8d18-87f43b7f8f3a\"},\"content\":[{\"type\":\"text\",\"text\":\"The \",\"attrs\":{\"start\":0,\"end\":4}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":4,\"end\":10},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"6c553c55-9d8b-49f7-8623-c34331859bb8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" then said to the venerable \",\"attrs\":{\"start\":10,\"end\":38}},{\"type\":\"text\",\"text\":\"Mahā­maudgalyāyana\",\"attrs\":{\"start\":38,\"end\":56},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5ba4353e-ee45-4137-8e61-ebf953ac0dbc\",\"uuid\":\"dcde8c58-2689-4046-bb3f-6d348eba0046\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", “\",\"attrs\":{\"start\":56,\"end\":59}},{\"type\":\"text\",\"text\":\"Maudgalyāyana\",\"attrs\":{\"start\":59,\"end\":72},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"8ae3a0a1-180a-4fc8-910a-cc2134148828\",\"uuid\":\"36f90737-90e5-4451-845e-ebd6ba20a59a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", go to the \",\"attrs\":{\"start\":72,\"end\":84}},{\"type\":\"text\",\"text\":\"Licchavi\",\"attrs\":{\"start\":84,\"end\":92},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"33770a73-e8ab-4ffb-9409-eb25bda5915d\",\"uuid\":\"17b5ed88-dfc0-4e23-aff0-60a9f2f650e7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":92,\"end\":93}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":93,\"end\":104},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-a