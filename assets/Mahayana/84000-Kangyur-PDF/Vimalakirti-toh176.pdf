་འདི་སྐད་ཅེས་བཀའ་སྩལ་ཏོ། །ཤཱ་རིའི་བུ་འདི་ཇི་སྙམ་དུ་སེམས། ཉི་མ་དང་ཟླ་བ་ཡོངས་སུ་མ་དག་གམ་ཅི་ན་དམུས་ལོང་དག་གིས་མི་མཐོང་། གསོལ་པ། བཅོམ་ལྡན་འདས་དེ་ལྟ་མ་ལགས་སོ། །དེ་ནི་དམུས་ལོང་གིས་ནོངས་ཀྱི་ཉི་མ་དང་ཟླ་བས་ནི་མ་ནོངས་སོ། །\",\"folioNumber\":180,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":185,\"uuid\":\"8820b7de-2a35-4876-9f31-4975d5eabeed\"},\"content\":[{\"type\":\"text\",\"text\":\"The \",\"attrs\":{\"start\":0,\"end\":4}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":4,\"end\":10},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"c307b06a-e283-4881-a240-3fae89ea2cbb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", aware of venerable \",\"attrs\":{\"start\":10,\"end\":31}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":31,\"end\":40},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4da7d125-a1b8-4820-b50f-9de69a2ab346\",\"uuid\":\"613f035b-18f3-4ec3-a748-bcc24944a1f6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s thoughts, said to him, “What do you think, \",\"attrs\":{\"start\":40,\"end\":86}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":86,\"end\":95},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4da7d125-a1b8-4820-b50f-9de69a2ab346\",\"uuid\":\"6a10ea9a-b09f-4b11-abc4-ece05262f624\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"? Is it because the sun and moon are impure that those blind from birth do not see them?” \",\"attrs\":{\"start\":95,\"end\":185}}]},{\"type\":\"paragraph\",\"attrs\":{\"start\":185,\"end\":304,\"uuid\":\"9c875ef3-09c4-4eba-8e9b-1e14b2c00c3b\"},\"content\":[{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":185,\"end\":194},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4da7d125-a1b8-4820-b50f-9de69a2ab346\",\"uuid\":\"a61c27b5-0c56-4f43-8333-5f7940a1aabb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" replied, “No, \",\"attrs\":{\"start\":194,\"end\":209}},{\"type\":\"text\",\"text\":\"Lord\",\"attrs\":{\"start\":209,\"end\":213},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41c623b8-3d94-4f8e-b2c5-1d7a5f5af6d3\",\"uuid\":\"add326d0-e20c-4533-9eff-df110c41ad88\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". It is not so. The fault lies with those blind from birth, and not with the sun and moon.”\",\"attrs\":{\"start\":213,\"end\":304}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"926da93c-faba-4a1d-8633-61f05113dab4\",\"sort\":1604,\"type\":\"translation\",\"label\":\"1.48\",\"alignments\":{\"toh176\":{\"folioUuid\":\"1d19dcbb-0926-4d70-b628-fa2f5ad55b70\",\"toh\":\"toh176\",\"tibetan\":\"བཀའ་\\nསྩལ་པ། ཤཱ་རིའི་བུ་དེ་བཞིན་དུ་སེམས་ཅན་ལ་ལས་དེ་བཞིན་གཤེགས་པའི་སངས་རྒྱས་ཀྱི་ཞིང་གི་ཡོན་ཏན་གྱི་རྒྱན་བཀོད་པ་མི་མཐོང་བ་དེ་ནི་སེམས་ཅན་རྣམས་ཀྱིས་མི་ཤེས་པས་ཉེས་ཀྱི་དེ་ལ་དེ་བཞིན་གཤེགས་པས་ཉེས་པ་ནི་མ་ཡིན་ནོ། །ཤཱ་རིའི་བུ་དེ་བཞིན་གཤེགས་པའི་སངས་རྒྱས་ཀྱི་ཞིང་ནི་\\nཡོངས་སུ་དག་མོད་ཀྱི་ཁྱོད་ཀྱིས་དེ་མི་མཐོང་ངོ་། །\",\"folioNumber\":180,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":310,\"uuid\":\"926da93c-faba-4a1d-8633-61f05113dab4\"},\"content\":[{\"type\":\"text\",\"text\":\"The \",\"attrs\":{\"start\":0,\"end\":4}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":4,\"end\":10},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"b55c5c48-bad6-40b1-812a-068a85dfe020\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" declared, “In the same way, \",\"attrs\":{\"start\":10,\"end\":39}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":39,\"end\":48},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4da7d125-a1b8-4820-b50f-9de69a2ab346\",\"uuid\":\"a8b60fe6-13e0-4a3e-a448-5629b6832800\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the fact that some living beings do not behold the splendid display of virtues of the 