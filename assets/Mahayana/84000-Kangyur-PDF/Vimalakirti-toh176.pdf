ྱི་ལྷ་དང་མི་རྣམས་འདི་སྙམ་དུ་སེམས་ཏེ། ཀྱེ་མའོ་[F.181.b]འདུ་བྱེད་འདི་དག་ནི་མི་རྟག་གོ་སྙམ་དུ་\",\"folioNumber\":181,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":230,\"uuid\":\"0ce37650-5126-4b87-9815-afba92da9c9e\"},\"content\":[{\"type\":\"text\",\"text\":\"Then, the \",\"attrs\":{\"start\":0,\"end\":10}},{\"type\":\"text\",\"text\":\"Lord\",\"attrs\":{\"start\":10,\"end\":14},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41c623b8-3d94-4f8e-b2c5-1d7a5f5af6d3\",\"uuid\":\"91c0b8ca-cb92-4693-82cd-155c3f9ba360\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" withdrew his miraculous power and at once the \",\"attrs\":{\"start\":14,\"end\":61}},{\"type\":\"text\",\"text\":\"buddhafield\",\"attrs\":{\"start\":61,\"end\":72},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1e5e85e8-4767-46b1-874e-5f1396a67ee6\",\"uuid\":\"a90199f2-8c65-4086-b2b7-215e385cc4f5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" was restored to its usual appearance. Then, both men and gods who subscribed to the \",\"attrs\":{\"start\":72,\"end\":157}},{\"type\":\"text\",\"text\":\"Disciple Vehicle\",\"attrs\":{\"start\":157,\"end\":173},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cc35d4b8-9151-485e-9199-cf5d9d646538\",\"uuid\":\"ac43afb9-7709-4f51-8976-5ed5034274e6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" thought, “Alas! All constructed things are impermanent.”\",\"attrs\":{\"start\":173,\"end\":230}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"0469a0cd-b8e5-4b38-86e4-7300ceec1e9f\",\"sort\":1753,\"type\":\"translation\",\"label\":\"1.56\",\"alignments\":{\"toh176\":{\"folioUuid\":\"db65dc76-f6c8-4ffd-a302-63495379a0a6\",\"toh\":\"toh176\",\"tibetan\":\"རིག་ནས་སྲོག་ཆགས་སུམ་ཁྲི་ཉིས་སྟོང་ཆོས་རྣམས་ལ་ཆོས་ཀྱི་མིག་རྡུལ་མེད་ཅིང་དྲི་མ་དང་བྲལ་བ་རྣམ་པར་དག་གོ། །དགེ་སློང་བརྒྱད་སྟོང་ནི་ལེན་པ་མེད་པར་ཟག་པ་རྣམས་ལས་སེམས་རྣམ་པར་གྲོལ་ལོ། །སངས་རྒྱས་ཀྱི་ཞིང་རྒྱ་ཆེན་པོ་ལ་མོས་པའི་\\nསྲོག་ཆགས་བརྒྱད་ཁྲི་བཞི་སྟོང་ཡང་ཆོས་ཐམས་ཅད་རྣམ་པར་བསྒྲུབས་པས་ཉེ་བར་གཞག་པའི་མཚན་ཉིད་དུ་རིག་ནས་བླ་ན་མེད་པ་ཡང་དག་པར་རྫོགས་པའི་བྱང་ཆུབ་ཏུ་སེམས་སྐྱེས་སོ། །སངས་རྒྱས་ཀྱི་ཞིང་ཡོངས་སུ་དག་པ་གླེང་གཞིའི་ལེའུ་སྟེ་དང་པོའོ།། །།\",\"folioNumber\":181,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":483,\"uuid\":\"0469a0cd-b8e5-4b38-86e4-7300ceec1e9f\"},\"content\":[{\"type\":\"text\",\"text\":\"Thereby, thirty-two thousand living beings purified their immaculate, undistorted \",\"attrs\":{\"start\":0,\"end\":82}},{\"type\":\"text\",\"text\":\"Dharma-eye\",\"attrs\":{\"start\":82,\"end\":92},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e6878b41-c299-40f7-bdcf-2a354e33818a\",\"uuid\":\"ad563cbd-1fbb-42c3-9bde-f1a51517f1ee\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in regard to all things. The eight thousand \",\"attrs\":{\"start\":92,\"end\":137}},{\"type\":\"text\",\"text\":\"bhikṣus\",\"attrs\":{\"start\":137,\"end\":144},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"700a47fd-7018-450b-b636-4ceaea2b8574\",\"uuid\":\"c57ca25f-048b-40db-9739-5f6b81065dee\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" were liberated from their mental defilements, attaining the state of nongrasping. And the eighty-four thousand living beings who were devoted to the grandeur of the \",\"attrs\":{\"start\":144,\"end\":310}},{\"type\":\"text\",\"text\":\"buddhafield\",\"attrs\":{\"start\":310,\"end\":321},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1e5e85e8-4767-46b1-874e-5f1396a67ee6\",\"uuid\":\"bae2d3e3-b8ca-4d9b-875a-4dba5486cb1a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", having understood that all things are by nature but magical creations, all conceived in their own minds the spirit of unexcelled, totally perfect \",\"attrs\":{\"start\":321,\"end\":469}},{\"type\":\"text\",\"text\":\"enlightenment\",\"attrs\":{\"start\":469,\"end\":482},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"62f923c5-8dfa-4620-8dec-7bb032231bf7\",\"uuid\":\"47ea0367-9daa-4443-a562-736d6780793a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":482,\"end\":483},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"5f6e822c-64f4-4023-955b-fd9eb14caf14\",\"label\":\"41\",\"uuid\":\"22ec2f0e-0f10-41cf-9c54-e7dbaf5c277a\",\"start\":483,\"end\":483,\"location\":\"end\",\"toh\":null}]}}]}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"223512b5-ef5a-436c-981c-54a0665a2378\",\"sort\":1763,\"type\":\"translationHeader\",\"label\":\"2.\",\"alignments\":{}},\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":3,\"start\":0,\"end\":47,\"uuid\":\"5e2e8752-e19e-475a-8a4f-a6240e4c6fe4\",\"class\":\"section-title\"},\"content\":[{\"type\":\"text\",\"text\":\"Chapter 2 Inconceivable Skill in Liberative Art\",\"attrs\":{\"start\":0,\"end\":47}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"2ea38b52-644a-4932-8a16-fe84b58eca61\",\"sort\":1767,\"type\":\"translation\",\"label\":\"2.1\",\"alignments\":{\"toh176\":{\"folioUuid\":\"db65dc76-f6c8-4ffd-a302-63495379a0a6\",\"toh\":\"toh176\",\"tibetan\":\"ཡང་དེའི་\\nཚེ་ཡངས་པའི་གྲོང་ཁྱེར་ཆེན་པོ་ན་ལིད་ཙ་བཱི་དྲི་མ་མེད་པར་གྲགས་པ་ཞེས་བྱ་བ་ཞིག་འདུག་སྟེ། སྔོན་གྱི་རྒྱལ་བ་ལ་ལྷག་པར་བྱ་བ་བྱས་ཤིང་དགེ་བའི་རྩ་བ་བསྐྱེད་པ། སངས་རྒྱས་མང་པོ་ལ་བསྙེན་བཀུར་བྱས་པ། བཟོད་པ་ཐོབ་པ། སྤོབས་པ་ཐོབ་པ། མངོན་པར་ཤེས་པ་\\nཆེན་པོས་རྣམ་པར་རྩེན་པ། གཟུངས་ཐོབ་པ། མི་འཇིགས་པ་ཐོབ་པ། བདུད་དང་ཕྱིར་རྒོལ་བ་བཅོམ་པ། ཆོས་ཀྱི་ཚུལ་ཟབ་མོ་ལ་ཤིན་ཏུ་ཞུགས་པ། ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ་ལས་ངེས་པར་བྱུང་བ། ཐབས་མཁས་པ་རྟོགས་པར་ཁོང་དུ་ཆུད་པ། སྤོབས་པ་དང་\\nལྡན་པ། སེམས་ཅན་གྱི་བསམ་པ་དང་སྤྱོད་པ་ལ་མཁས་པ། སེམས་ཅན་གྱི་དབང་པོ་མཆོག་དང་མཆོག་མ་ཡིན་པ་ཤེས་པ་ལས་ངེས་པར་བྱུང་བ་སོ་སོ་ཅི་རིགས་པར་ཆོས་སྟོན་པ། ཐེག་པ་ཆེན་པོ་འདི་ལ་བརྩོན་པར་བྱས་ཤིང་ཤེས་པར་བྱས་པ། ཤིན་ཏུ་བརྟགས་ཏེ་ལས་བྱེད་པ། \\nསངས་རྒྱས་ཀྱི་སྤྱོད་ལམ་ལ་གནས་པ། བློ་དམ་པ་རྒྱ་མཚོ་ལྟ་བུའི་རྗེས་སུ་ཞུགས་པ། སངས་རྒྱས་ཐམས་ཅད་ཀྱིས་བསྟོད་ཅིང་བཀུར་ཏེ་རབ་ཏུ་བསྔགས་པ། བརྒྱ་བྱིན་དང་། ཚངས་པ་དང་། འཇིག་རྟེན་སྐྱོང་བ་ཐམས་ཅད་ཀྱིས་ཕྱག་བྱས་པ་དེ་སེམས་ཅན་ཡོངས་སུ་སྨིན་པར་བྱ་བའི་ཕྱིར་\\nཐབས་ལ་མཁས་པས་ཡངས་པའི་གྲོང་ཁྱེར་ཆེན་པོ་ན་གནས་ཏེ། \",\"folioNumber\":181,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1225,\"uuid\":\"2ea38b52-644a-4932-8a16-fe84b58eca61\"},\"content\":[{\"type\":\"text\",\"text\":\"At that time, there lived in the great city of \",\"attrs\":{\"start\":0,\"end\":47}},{\"type\":\"text\",\"text\":\"Vaiśālī\",\"attrs\":{\"start\":47,\"end\":54},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e9c61804-d922-4a99-88ea-836faa6fd3c4\",\"uuid\":\"59c81554-51cf-4dcb-a31f-a9f80cda4426\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" a certain \",\"attrs\":{\"start\":54,\"end\":65}},{\"type\":\"text\",\"text\":\"Licchavi\",\"attrs\":{\"start\":65,\"end\":73},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"33770a73-e8ab-4ffb-9409-eb25bda5915d\",\"uuid\":\"2551543e-4e12-455c-8bc6-f0c6a3c998c7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":73,\"end\":75}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":75,\"end\":86},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"16875487-3a26-4e72-8031-b453b80861ff\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" by name. Having served the ancient \",\"attrs\":{\"start\":86,\"end\":122}},{\"type\":\"text\",\"text\":\"buddhas\",\"attrs\":{\"start\":122,\"end\":129},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"e95f0f83-7e5b-46b6-963c-39e3b9e9f902\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", he had generated the roots of virtue by honoring them and making offerings to them. He had attained tolerance as well as eloquence. He played with the great \",\"attrs\":{\"start\":129,\"end\":288}},{\"type\":\"text\",\"text\":\"superknowledges\",\"attrs\":{\"start\":288,\"end\":303},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"6b6440dd-6d95-46dd-9c77-9f9241f4e84a\",\"uuid\":\"351337fe-f3c5-4210-bebc-62ccde52b6ee\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". He had attained the power of \",\"attrs\":{\"start\":303,\"end\":334}},{\"type\":\"text\",\"text\":\"retention\",\"attrs\":{\"start\":334,\"end\":343},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e6cb9fdd-cfe1-4188-8cfb-b72314d72e94\",\"uuid\":\"237b6b6b-952f-4110-a8fd-6fe51f44c515\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and the \",\"attrs\":{\"start\":343,\"end\":352}},{\"type\":\"text\",\"text\":\"fearlessnesses\",\"attrs\":{\"start\":352,\"end\":366},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b8daff33-91de-4457-9d38-959adf13a079\",\"uuid\":\"1fdf63e1-7c45-4290-bde8-cb25ab401b77\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". He had conquered all demons and opponents. He had penetrated the profound way of the \",\"attrs\":{\"start\":366,\"end\":453}},{\"type\":\"text\",\"text\":\"Dharma\",\"attrs\":{\"start\":453,\"end\":459},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c08db6f5-393e-4ec4-bf72-4043e53b3129\",\"uuid\":\"28091504-522a-41c3-b214-fed42170a30d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". He was liberated through the transcendence of \",\"attrs\":{\"start\":459,\"end\":507}},{\"type\":\"text\",\"text\":\"wisdom\",\"attrs\":{\"start\":507,\"end\":513},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"38971298-6f62-48f0-b271-36261568d441\",\"uuid\":\"806432cb-4fe8-4061-badb-583efc1c7206\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Having integrated his realization with skill in \",\"attrs\":{\"start\":513,\"end\":563}},{\"type\":\"text\",\"text\":\"liberative art\",\"attrs\":{\"start\":563,\"end\":577},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7c541c84-ac9d-49ce-92dc-9b1f6912648d\",\"uuid\":\"4edff7ae-397c-43c9-9423-34f3058ab1e3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", he was expert in knowing the thoughts and actions of living beings. Knowing the strength or weakness of their faculties, and being gifted with unrivaled eloquence, he taught the \",\"attrs\":{\"start\":577,\"end\":757}},{\"type\":\"text\",\"text\":\"Dharma\",\"attrs\":{\"start\":757,\"end\":763},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c08db6f5-393e-4ec4-bf72-4043e53b3129\",\"uuid\":\"280e3093-aa13-4e37-8c27-59ab7d614747\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" appropriately to each. Having applied himself energetically to the \",\"attrs\":{\"start\":763,\"end\":831}},{\"type\":\"text\",\"text\":\"Mahāyāna\",\"attrs\":{\"start\":831,\"end\":839},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"99607e52-e246-4905-b531-6e6d7ccfd7b7\",\"uuid\":\"1524af5b-99ce-486c-8df8-d117010c255d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", he understood it and accomplished his tasks with great finesse. He lived with the deportment of a \",\"attrs\":{\"start\":839,\"end\":939}},{\"type\":\"text\",\"text\":\"buddha\",\"attrs\":{\"start\":939,\"end\":945},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"6f5e49c9-136e-4892-8ab7-b320539b2b4b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and his superior intelligence was as wide as an ocean. He was praised, honored, and commended by all the \",\"attrs\":{\"start\":945,\"end\":1052}},{\"type\":\"text\",\"text\":\"buddhas\",\"attrs\":{\"start\":1052,\"end\":1059},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"6ed82682-614c-49a4-8d6b-1c5275773a7c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and was respected by \",\"attrs\":{\"start\":1059,\"end\":1081}},{\"type\":\"text\",\"text\":\"Śakra\",\"attrs\":{\"start\":1081,\"end\":1086},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\