2688-4b01-a2f6-f805ea1e6955\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".”\",\"attrs\":{\"start\":83,\"end\":85}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"7baf6d92-2ac6-41b9-b820-9eeb8c84707d\",\"sort\":10554,\"type\":\"endnotes\",\"label\":\"n.77\",\"alignments\":{},\"references\":[{\"content\":\"$48\",\"label\":\"3.25\",\"sort\":2545,\"type\":\"translation\",\"uuid\":\"e24677c7-627b-46ce-bef0-4d826f3dd634\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-9\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":9,\"uuid\":\"7baf6d92-2ac6-41b9-b820-9eeb8c84707d\"},\"content\":[{\"type\":\"text\",\"text\":\"See \",\"attrs\":{\"start\":0,\"end\":4}},{\"type\":\"text\",\"text\":\"n.64\",\"attrs\":{\"start\":4,\"end\":8},\"marks\":[{\"type\":\"internalLink\",\"attrs\":{\"uuid\":\"cc45e2be-fde8-473e-b3d8-ac8a903c3f69\",\"href\":\"/entity/passage/ea984ea7-9cbe-4123-83ac-4f896cc2e2a1\",\"entity\":\"ea984ea7-9cbe-4123-83ac-4f896cc2e2a1\",\"type\":\"passage\",\"toh\":null,\"isSameWork\":true,\"subtype\":\"endnotes\"}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":8,\"end\":9}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"6d3a27a1-26e5-405e-86d8-ab6a62d1758a\",\"sort\":10559,\"type\":\"endnotes\",\"label\":\"n.78\",\"alignments\":{},\"references\":[{\"content\":\"$49\",\"label\":\"3.27\",\"sort\":2599,\"type\":\"translation\",\"uuid\":\"9eedde7f-8ec7-4c90-bc02-e2e2526246cd\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-131\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":135,\"uuid\":\"6d3a27a1-26e5-405e-86d8-ab6a62d1758a\"},\"content\":[{\"type\":\"text\",\"text\":\"Aniruddha\",\"attrs\":{\"start\":0,\"end\":9},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"16a55775-56db-4c97-b4ea-04f04e755e72\",\"uuid\":\"87ac427d-afd8-48af-ab09-30200be9977a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" was said to be “foremost among possessors of the \",\"attrs\":{\"start\":9,\"end\":59}},{\"type\":\"text\",\"text\":\"divine eye\",\"attrs\":{\"start\":59,\"end\":69},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"75a91ffb-ff79-483c-bf2e-bc68d02dc1e6\",\"uuid\":\"1a90fe7e-cd3f-40f7-871e-3dbe186b1d57\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"” (\",\"attrs\":{\"start\":69,\"end\":72}},{\"type\":\"text\",\"text\":\"agro divya­cakṣukānām\",\"attrs\":{\"start\":72,\"end\":93},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":72,\"end\":93,\"uuid\":\"bcaabbe2-fdd2-4b28-a935-c70076f7adf8\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"; see Lamotte, p 167, n 56, and glossary).\",\"attrs\":{\"start\":93,\"end\":135}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"bd32b3ea-ab29-40eb-b052-8c6ae44e3b69\",\"sort\":10566,\"type\":\"endnotes\",\"label\":\"n.79\",\"alignments\":{},\"references\":[{\"content\":\"$4a\",\"label\":\"3.27\",\"sort\":2599,\"type\":\"translation\",\"uuid\":\"9eedde7f-8ec7-4c90-bc02-e2e2526246cd\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-131\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":329,\"uuid\":\"bd32b3ea-ab29-40eb-b052-8c6ae44e3b69\"},\"content\":[{\"type\":\"text\",\"text\":\"This dilemma was more embarrassing to \",\"attrs\":{\"start\":0,\"end\":38}},{\"type\":\"text\",\"text\":\"Aniruddha\",\"attrs\":{\"start\":38,\"end\":47},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"16a55775-56db-4c97-b4ea-04f04e755e72\",\"uuid\":\"b10194a3-aa99-4a5a-b80a-190d8898a265\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" than confounding, since logically he could have answered that of course his \",\"attrs\":{\"start\":47,\"end\":124}},{\"type\":\"text\",\"text\":\"divine eye\",\"attrs\":{\"start\":124,\"end\":134},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"75a91ffb-ff79-483c-bf2e-bc68d02dc1e6\",\"uuid\":\"90d7de8c-7416-4ca6-9be8-a6351efa46a6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" was compounded, just like that of \",\"attrs\":{\"start\":134,\"end\":169}},{\"type\":\"text\",\"text\":\"outsider\",\"attrs\":{\"start\":169,\"end\":177},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b121c9a5-7c63-4bc5-be7a-4f7ac29b7113\",\"uuid\":\"0d32ef0e-5d30-451b-8fad-e98f2bb6610e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" adepts. \",\"attrs\":{\"start\":177,\"end\":186}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":186,\"end\":197},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"14cabfe4-cc13-4353-8076-5719fdaa83c7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" touched his pride in this critique; hence the dilemma he poses here bears only superficial resemblance to the \",\"attrs\":{\"start\":197,\"end\":308}},{\"type\":\"text\",\"text\":\"Mādhyamika\",\"attrs\":{\"start\":308,\"end\":318},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"08688fff-c9ad-4aaa-83ac-1792ad208fff\",\"uuid\":\"d40bec64-2e28-4ff3-b973-2bdb1417f2cc\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" dialectic.\",\"attrs\":{\"start\":318,\"end\":329}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"d58bd64b-62c0-41e5-ac0a-1dd9a5620046\",\"sort\":10579,\"type\":\"endnotes\",\"label\":\"n.80\",\"alignments\":{},\"references\":[{\"content\":\"The Buddha then said to the venerable Upāli, “Upāli, go to the Licchavi Vimalakīrti to inquire about his illness.” Upāli replied, “Lord, I am indeed reluctant to go to that good man to inquire about his illness. Why? Lord, I remember that one day there were two monks who had committed some infraction and were too ashamed to appear before the Lord, so they came to me and said, ‘Reverend Upāli, we have both committed an infraction but are too ashamed to appear before the Buddha. Venerable Upāli, kindly remove our anxieties by absolving us of these infractions.’\",\"label\":\"3.30\",\"sort\":2677,\"type\":\"translation\",\"uuid\":\"afd37808-b28d-4145-8c05-30b16a5c7155\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-134\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":168,\"uuid\":\"d58bd64b-62c0-41e5-ac0a-1dd9a5620046\"},\"content\":[{\"type\":\"text\",\"text\":\"Upāli\",\"attrs\":{\"start\":0,\"end\":5},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"3cdcaa9d-3979-4ae9-a327-19723393a25f\",\"uuid\":\"e99c3722-b146-41b1-917a-6cbb1d2dcc12\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" was especially well known as expert in \",\"attrs\":{\"start\":5,\"end\":45}},{\"type\":\"text\",\"text\":\"Vinaya\",\"attrs\":{\"start\":45,\"end\":51},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"59bb2f56-d05e-43d5-a5a0-fe73d5597c93\",\"uuid\":\"394a20d8-5e7b-4216-9f16-eafd9683b670\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the code of monastic discipline, and was its chief compiler after the \",\"attrs\":{\"start\":51,\"end\":123}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":123,\"end\":129},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"69c88447-c91b-4bb0-9a04-7c7b5e15cc4e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s \",\"attrs\":{\"start\":129,\"end\":132}},{\"type\":\"text\",\"text\":\"parinirvāṇa\",\"attrs\":{\"start\":132,\"end\":143},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f3755f91-c27d-4968-894e-14796bd04545\",\"uuid\":\"1c18e198-bc23-43c5-bdda-80ae0d8d2538\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (\",\"attrs\":{\"start\":143,\"end\":145}},{\"type\":\"text\",\"text\":\"vināya­dharāṇām agraḥ\",\"attrs\":{\"start\":145,\"end\":166},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":145,\"end\":166,\"uuid\":\"2e07c99b-994c-4830-b5c8-a80bf54e1011\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\").\",\"attrs\":{\"start\":166,\"end\":168}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"0b56a364-8dd9-4ca1-a49c-d857538cac08\",\"sort\":10590,\"type\":\"endnotes\",\"label\":\"n.81\",\"alignments\":{},\"references\":[{\"content\":\"The Buddha then said to the venerable Upāli, “Upāli, go to the Licchavi Vimalakīrti to inquire about his illness.” Upāli replied, “Lord, I am indeed reluctant to go to that good man to inquire about his illness. Why? Lord, I remember that one day there were two monks who had committed some infraction and were too ashamed to appear before the Lord, so they came to me and said, ‘Reverend Upāli, we have both committed an infraction but are too ashamed to appear before the Buddha. Venerable Upāli, kindly remove our anxieties by absolving us of these infractions.’\",\"label\":\"3.30\",\"sort\":2677,\"type\":\"translation\",\"uuid\":\"afd37808-b28d-4145-8c05-30b16a5c7155\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-134\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":482,\"uuid\":\"0b56a364-8dd9-4ca1-a49c-d857538cac08\"},\"content\":[{\"type\":\"text\",\"text\":\"Tib. \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"the tsom sol te bdag cag gnyis ltung ba las phyung shig\",\"attrs\":{\"start\":5,\"end\":60},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":5,\"end\":60,\"uuid\":\"9271d860-01dd-472e-a88c-42a42289dc8a\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" (lit. “remove our doubts and take us both out from the infraction”). The “absolution” consists in the senior monk’s listening to their confession and encouraging their resolution not to repeat the infraction. Thus he grants no dispensations in regard to the retributive effects and only gives them the opportunity to come to a new understanding and decision in their own minds. This is traditional in Buddhist discipline.\",\"attrs\":{\"start\":60,\"end\":482}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"5fb7772e-453c-4217-870a-56994a627a64\",\"sort\":10594,\"type\":\"endnotes\",\"label\":\"n.82\",\"alignments\":{},\"references\":[{\"content\":\"“ ‘Reverend Upāli, the minds of all living beings have that very nature. Reverend Upāli, conceptualization is total affliction, and not conceptualizing and not discriminating is their true nature. Misapprehension is total affliction, and non-misapprehension is their true nature. The presumption of self is total affliction, and selflessness is their true nature. Reverend Upāli, all things are without production, destruction, and duration, like magical illusions, clouds, and lightning; all things are evanescent, not remaining even for an instant; all things are like dreams, hallucinations, and unreal visions; all things are like the reflection of the moon in water and like a mirror-image; they are born of mental construction. Those who know this are called the true upholders of the discipline, and those disciplined in that way are indeed well disciplined.’ ”\",\"label\":\"3.34\",\"sort\":2733,\"type\":\"translation\",\"uuid\":\"3f7cd5d6-40b4-481a-bf4b-5c845c3aaf42\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-138\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":215,\"uuid\":\"5fb7772e-453c-4217-870a-56994a627a64\"},\"content\":[{\"type\":\"text\",\"text\":\"Skt. \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"vināyadhara\",\"attrs\":{\"start\":5,\"end\":16},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":5,\"end\":16,\"uuid\":\"5d2a4720-7aea-4365-b8d5-33a3445efc5f\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\". As usual, \",\"attrs\":{\"start\":16,\"end\":28}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":28,\"end\":39},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"fba093ee-59b2-4778-82dd-046e6d73a949\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" makes his point on the disciple’s home ground: \",\"attrs\":{\"start\":39,\"end\":87}},{\"type\":\"text\",\"text\":\"Upāli\",\"attrs\":{\"start\":87,\"end\":92},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"3cdcaa9d-3979-4ae9-a327-19723393a25f\",\"uuid\":\"a881b469-86dc-4db7-a54c-2db73b5a5057\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" was known as \",\"attrs\":{\"start\":92,\"end\":106}},{\"type\":\"text\",\"text\":\"vināya­dharāṇāṃ agraḥ\",\"attrs\":{\"start\":106,\"end\":127},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":106,\"end\":127,\"uuid\":\"082af4e7-1de0-4417-8d24-d193b4e6c288\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\", “foremost upholder of the discipline,” as the two monks mention in the next paragraph.\",\"attrs\":{\"start\":127,\"end\":215}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"37d63bf3-f31f-419e-a210-880b73e9f666\",\"sort\":10605,\"type\":\"endnotes\",\"label\":\"n.83\",\"alignments\":{},\"references\":[{\"content\":\"The Buddha then said to the venerable Rāhula, “Rāhula, go to the Licchavi Vimalakīrti to inquire about his illness.” Rāhula replied, “Lord, I am indeed reluctant to go to that good man to inquire about his illness. Why? Lord, I remember that one day many young Licchavi gentlemen came to the place where I was and said to me, ‘Reverend Rāhula, you are the son of the Lord, and, having renounced a kingdom of a universal monarch, you have left the world. What are the virtues and benefits you saw in leaving the world?’\",\"label\":\"3.37\",\"sort\":2778,\"type\":\"translation\",\"uuid\":\"4129d993-08a7-40d6-b747-e88d78b4036d\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-141\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":291,\"uuid\":\"37d63bf3-f31f-419e-a210-880b73e9f666\"},\"content\":[{\"type\":\"text\",\"text\":\"Rāhula\",\"attrs\":{\"start\":0,\"end\":6},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"5a2b5afb-3eda-4a81-9892-6c2e79d6fd75\",\"uuid\":\"7fc054ae-2779-4b80-a964-7be1a0d5148a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" was the actual son of the \",\"attrs\":{\"start\":6,\"end\":33}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":33,\"end\":39},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"f6a2b90e-8ea4-4b14-a3c7-db9470a1b6d4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and was admired in the \",\"attrs\":{\"start\":39,\"end\":63}},{\"type\":\"text\",\"text\":\"saṅgha\",\"attrs\":{\"start\":63,\"end\":69},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"02725146-032e-4372-bc0f-78777524f0aa\",\"uuid\":\"69a20e46-8f4e-4710-8988-c6320efc11b9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" as a renunciant and devotee because he forsook the throne to join the \",\"attrs\":{\"start\":69,\"end\":140}},{\"type\":\"text\",\"text\":\"saṅgha\",\"attrs\":{\"start\":140,\"end\":146},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"02725146-032e-4372-bc0f-78777524f0aa\",\"uuid\":\"93eb669f-c857-4d2e-8a02-fddb0d5555f9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" under his father. The \",\"attrs\":{\"start\":146,\"end\":169}},{\"type\":\"text\",\"text\":\"Pāli\",\"attrs\":{\"start\":169,\"end\":173},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b0b04164-1cec-4c95-9c78-54e5889bc61c\",\"uuid\":\"4f9e4991-cf95-49ac-9ef6-76cb3f7b1306\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" sources show him dubbed “foremost among those eager for training” (Skt. \",\"attrs\":{\"start\":173,\"end\":246}},{\"type\":\"text\",\"text\":\"śikṣākāmānam agro\",\"attrs\":{\"start\":246,\"end\":263},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":246,\"end\":263,\"uuid\":\"9b2b9375-765b-46f5-a91a-8df512f5086c\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"; see Lamotte, p 177, n 70).\",\"attrs\":{\"start\":263,\"end\":291}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"143059cb-cfa0-462f-a835-b905e636d975\",\"sort\":10618,\"type\":\"endnotes\",\"label\":\"n.84\",\"alignments\":{},\"references\":[{\"content\":\"$4b\",\"label\":\"3.38\",\"sort\":2806,\"type\":\"translation\",\"uuid\":\"806fe62a-aa0b-419a-8554-1b863d5c1c30\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-142\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":223,\"uuid\":\"143059cb-cfa0-462f-a835-b905e636d975\"},\"content\":[{\"type\":\"text\",\"text\":\"Tib. \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"thog ma’i dang tha’ ma’i mthar lta ba dang bral ba’o\",\"attrs\":{\"start\":5,\"end\":57},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":5,\"end\":57,\"uuid\":\"1a418ee3-282b-41c1-9f74-c176bf935b79\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\". K and X have instead: “Renunciation is beyond this, that, and in between, being above the sixty-two false \",\"attrs\":{\"start\":57,\"end\":165}},{\"type\":\"text\",\"text\":\"views\",\"attrs\":{\"start\":165,\"end\":170},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"706840df-0c20-4c5d-94a4-6b4383506ee4\",\"uuid\":\"f229e1ec-b45f-40e2-9813-e32d02061af2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".” The Skt. does not appear to include this sentence.\",\"attrs\":{\"start\":170,\"end\":223}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"ea1e9b98-3baf-436b-88d8-f60b4cdff23a\",\"sort\":10624,\"type\":\"endnotes\",\"label\":\"n.85\",\"alignments\":{},\"references\":[{\"content\":\"$4c\",\"label\":\"3.38\",\"sort\":2806,\"type\":\"translation\",\"uuid\":\"806fe62a-aa0b-419a-8554-1b863d5c1c30\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-142\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":650,\"uuid\":\"ea1e9b98-3baf-436b-88d8-f60b4cdff23a\"},\"content\":[{\"type\":\"text\",\"text\":\"Some verses of \",\"attrs\":{\"start\":0,\"end\":15}},{\"type\":\"text\",\"text\":\"Tsong Khapa\",\"attrs\":{\"start\":15,\"end\":26},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"62829850-6321-48fc-9648-fba6953c3139\",\"uuid\":\"11783107-89be-4744-9675-ba047c8e6276\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" summarize the \",\"attrs\":{\"start\":26,\"end\":41}},{\"type\":\"text\",\"text\":\"Mahāyāna\",\"attrs\":{\"start\":41,\"end\":49},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"99607e52-e246-4905-b531-6e6d7ccfd7b7\",\"uuid\":\"c7b7baaa-3c3d-47bf-a0dc-67f209cfd8c6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" “mind of renunciation” very aptly: “Reverse the interest in this life by thinking over again and again that leisure and opportunity (to practice the \",\"attrs\":{\"start\":49,\"end\":199}},{\"type\":\"text\",\"text\":\"Dharma\",\"attrs\":{\"start\":199,\"end\":205},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c08db6f5-393e-4ec4-bf72-4043e53b3129\",\"uuid\":\"6af996c5-d218-4739-9162-0397c2825884\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\") are hard to find and that there is no (fixed) duration of life. Reverse interest in the life hereafter by constantly meditating upon the inexorability of \",\"attrs\":{\"start\":205,\"end\":361}},{\"type\":\"text\",\"text\":\"karma\",\"attrs\":{\"start\":361,\"end\":366},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b50a8fcc-a5eb-409b-96d4-a5872524e192\",\"uuid\":\"99049585-9dbe-4dcc-90ff-f8814059619e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and the sufferings of the world. Through such \",\"attrs\":{\"start\":366,\"end\":413}},{\"type\":\"text\",\"text\":\"concentration\",\"attrs\":{\"start\":413,\"end\":426},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7c9b18c2-de43-42af-9b86-2cadc11acbf8\",\"uuid\":\"bce5e95c-5dcd-46ba-b3b0-c05431317ace\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", when there is not the slightest ambition, even for a split second, for even the greatest successes in the world, the mind of renunciation has arisen.” See G. Wangyal, \",\"attrs\":{\"start\":426,\"end\":595}},{\"type\":\"text\",\"text\":\"Door of Liberation\",\"attrs\":{\"start\":595,\"end\":613},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"18a07096-09c6-448d-8f7c-d6c5975984f1\",\"lang\":\"en\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\" (New York, Girodias, 1973), Chap. V.\",\"attrs\":{\"start\":613,\"end\":650}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"6b285b4f-4618-4e65-84c7-5939842c577b\",\"sort\":10644,\"type\":\"endnotes\",\"label\":\"n.86\",\"alignments\":{},\"references\":[{\"content\":\"“The young men complained, ‘But, householder, we have heard the Tathāgata declare that one should not renounce the world without the permission of one’s parents.’ “Vimalakīrti answered, ‘Young men, you should cultivate yourselves intensively to conceive the spirit of unexcelled, perfect enlightenment. That in itself will be your renunciation and high ordination!’\",\"label\":\"3.39\",\"sort\":2845,\"type\":\"translation\",\"uuid\":\"4916fabf-3350-4f38-b2c1-ff10dc0b01fb\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-143\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":299,\"uuid\":\"6b285b4f-4618-4e65-84c7-5939842c577b\"},\"content\":[{\"type\":\"text\",\"text\":\"Even after his explanation, the young men still confuse renunciation, a mental \",\"attrs\":{\"start\":0,\"end\":79}},{\"type\":\"text\",\"text\":\"concentration\",\"attrs\":{\"start\":79,\"end\":92},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7c9b18c2-de43-42af-9b86-2cadc11acbf8\",\"uuid\":\"f2f5b6ad-f16e-49b5-a0de-83c9e5091dcb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", with the mundane act of entering the monkhood. So \",\"attrs\":{\"start\":92,\"end\":144}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":144,\"end\":155},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"c0a6fb5d-daf6-4685-a707-c6fa29e676fc\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" has to remind them that the conception of the spirit‌ of \",\"attrs\":{\"start\":155,\"end\":213}},{\"type\":\"text\",\"text\":\"enlightenment\",\"attrs\":{\"start\":213,\"end\":226},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"62f923c5-8dfa-4620-8dec-7bb032231bf7\",\"uuid\":\"c52af353-b6a4-444e-b1db-138f1cad7f07\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"‌ is the true renunciation, not just a mere change of clothes and habits.\",\"attrs\":{\"start\":226,\"end\":299}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"4e6ba524-c21a-499a-b986-2bfaa157de80\",\"sort\":10652,\"type\":\"endnotes\",\"label\":\"n.87\",\"alignments\":{},\"references\":[{\"content\":\"“Thereupon, thirty-two of the Licchavi youths conceived the spirit of unexcelled, perfect enlightenment. Therefore, Lord, I am reluctant to go to that good man to inquire about his illness.”\",\"label\":\"3.40\",\"sort\":2857,\"type\":\"translation\",\"uuid\":\"622b1c5f-de04-4921-a7bf-6d3b8a23ea8d\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-144\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":96,\"uuid\":\"4e6ba524-c21a-499a-b986-2bfaa157de80\"},\"content\":[{\"type\":\"text\",\"text\":\"Tib. and Skt. have thirty-two hundred, but K and X have thirty-two, which seems more reasonable.\",\"attrs\":{\"start\":0,\"end\":96}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"b9927c4f-b418-4a64-aa7f-5516d39863d9\",\"sort\":10655,\"type\":\"endnotes\",\"label\":\"n.88\",\"alignments\":{},\"references\":[{\"content\":\"The Buddha then said to the venerable Ānanda, “Ānanda, go to the Licchavi Vimalakīrti to inquire about his illness.” Ānanda replied, “Lord, I am indeed reluctant to go to that good man to inquire about his illness. Why? Lord, I remember one day when the body of the Lord manifested some indisposition and he required some milk; I took the bowl and went to the door of the mansion of a great brahmin family. The Licchavi Vimalakīrti came there, and, having saluted me, said, ‘Reverend Ānanda, what are you doing on the threshold of this house with your bowl in your hand so early in the morning?’\",\"label\":\"3.41\",\"sort\":2867,\"type\":\"translation\",\"uuid\":\"a4079164-2897-4819-8b5e-26b4603e0a74\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-145\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":320,\"uuid\":\"b9927c4f-b418-4a64-aa7f-5516d39863d9\"},\"content\":[{\"type\":\"text\",\"text\":\"Ānanda\",\"attrs\":{\"start\":0,\"end\":6},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"240d1cab-1211-41e4-8623-ecceecfb763d\",\"uuid\":\"eb4f9630-d493-4c7d-a51a-2c08deea0c49\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" was renowned for many things: learning, mindfulness, steadfastness, etc., and was the second leader of the \",\"attrs\":{\"start\":6,\"end\":114}},{\"type\":\"text\",\"text\":\"saṅgha\",\"attrs\":{\"start\":114,\"end\":120},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"02725146-032e-4372-bc0f-78777524f0aa\",\"uuid\":\"bf3a37de-59bc-48f6-93b0-5b2d8fc9378d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" , after \",\"attrs\":{\"start\":120,\"end\":129}},{\"type\":\"text\",\"text\":\"Mahākāśyapa\",\"attrs\":{\"start\":129,\"end\":140},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cf40c4ec-f71c-47c7-bd39-47de5e6850b9\",\"uuid\":\"6f891efc-1ec1-4957-bd1f-f6e56a85e557\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". \",\"attrs\":{\"start\":140,\"end\":142}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":142,\"end\":153},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"6c733a2c-071e-4ef4-bd83-1cabf639a207\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" finds fault with him when he is being “foremost of attendants” (\",\"attrs\":{\"start\":153,\"end\":218}},{\"type\":\"text\",\"text\":\"aggo upaṭṭhākānām\",\"attrs\":{\"start\":218,\"end\":235},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":218,\"end\":235,\"uuid\":\"9870d5c0-e56b-4e73-891d-0059d6fc24d4\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"), caring for the \",\"attrs\":{\"start\":235,\"end\":253}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":253,\"end\":259},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"31ede415-65f5-433d-97f8-1d6067249522\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s apparent needs as he did faithfully for twenty-five years.\",\"attrs\":{\"start\":259,\"end\":320}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"5947a1bc-a2ea-4ba8-8218-ead457ebfbfb\",\"sort\":10668,\"type\":\"endnotes\",\"label\":\"n.89\",\"alignments\":{},\"references\":[{\"content\":\"The Buddha then said to the venerable Ānanda, “Ānanda, go to the Licchavi Vimalakīrti to inquire about his illness.” Ānanda replied, “Lord, I am indeed reluctant to go to that good man to inquire about his illness. Why? Lord, I remember one day when the body of the Lord manifested some indisposition and he required some milk; I took the bowl and went to the door of the mansion of a great brahmin family. The Licchavi Vimalakīrti came there, and, having saluted me, said, ‘Reverend Ānanda, what are you doing on the threshold of this house with your bowl in your hand so early in the morning?’\",\"label\":\"3.41\",\"sort\":2867,\"type\":\"translation\",\"uuid\":\"a4079164-2897-4819-8b5e-26b4603e0a74\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-145\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":103,\"uuid\":\"5947a1bc-a2ea-4ba8-8218-ead457ebfbfb\"},\"content\":[{\"type\":\"text\",\"text\":\"See Lamotte, p 183, n 77, for learned references to this incident in other sources, notably \",\"attrs\":{\"start\":0,\"end\":92}},{\"type\":\"text\",\"text\":\"Vatsasūtra\",\"attrs\":{\"start\":92,\"end\":102},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"0d2ae130-4b27-4319-a042-08c08359fba2\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\"}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":102,\"end\":103}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"c4db3ec1-ee61-461c-b3e1-d6370be4422c\",\"sort\":10672,\"type\":\"endnotes\",\"label\":\"n.90\",\"alignments\":{},\"references\":[{\"content\":\"“ ‘Reverend Ānanda, do not bring shame upon us, but go in silence, lest the outsider sectarians should hear your words. They would say, “For shame! The teacher of these people cannot even cure his own sicknesses. How then can he cure the sicknesses of others?” Reverend Ānanda, go then discreetly so that no one observes you.\",\"label\":\"3.44\",\"sort\":2927,\"type\":\"translation\",\"uuid\":\"530621e8-14b5-4214-b256-2c8a79c0c50d\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-148\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":368,\"uuid\":\"c4db3ec1-ee61-461c-b3e1-d6370be4422c\"},\"content\":[{\"type\":\"text\",\"text\":\"Tib. \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"gzhan mu stegs can spyod pa pa dang kun tu rgyu dang gcer bu pa dang tsho ba pa dag\",\"attrs\":{\"start\":5,\"end\":88},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":5,\"end\":88,\"uuid\":\"b0d6766f-7e30-4ca0-aeed-bf3f0e7c9153\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"; Skt. \",\"attrs\":{\"start\":88,\"end\":95}},{\"type\":\"text\",\"text\":\"anyatīrthika caraka parivrajaka nigranthājīvāḥ\",\"attrs\":{\"start\":95,\"end\":141},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":95,\"end\":141,\"uuid\":\"8426a8a1-fb88-4055-8903-092d194fdf9b\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\". I have simply rendered this “\",\"attrs\":{\"start\":141,\"end\":172}},{\"type\":\"text\",\"text\":\"outsider\",\"attrs\":{\"start\":172,\"end\":180},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b121c9a5-7c63-4bc5-be7a-4f7ac29b7113\",\"uuid\":\"743e3108-b462-4ee0-a6f8-0b2555009715\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" sectarians” so as not to burden the reader with irrelevant names, as this expression is a cliché for all the \",\"attrs\":{\"start\":180,\"end\":290}},{\"type\":\"text\",\"text\":\"outsider\",\"attrs\":{\"start\":290,\"end\":298},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b121c9a5-7c63-4bc5-be7a-4f7ac29b7113\",\"uuid\":\"815ca05c-cbc6-47a4-b8de-cfd190d76d07\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" groups occurring in other \",\"attrs\":{\"start\":298,\"end\":325}},{\"type\":\"text\",\"text\":\"Mahāyāna\",\"attrs\":{\"start\":325,\"end\":333},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"99607e52-e246-4905-b531-6e6d7ccfd7b7\",\"uuid\":\"16bdcf78-32f2-4825-97f1-7499ea351734\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":333,\"end\":334}},{\"type\":\"text\",\"text\":\"sūtras\",\"attrs\":{\"start\":334,\"end\":340},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c65438ed-99d8-45cc-bc87-72f8f617eea5\",\"uuid\":\"b7be7013-8e4f-4f77-956c-0918fc4fa897\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" (see Lamotte, p 186, n 81).\",\"attrs\":{\"start\":340,\"end\":368}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"8e1302ba-e851-487c-b9ec-22b9c39dde13\",\"sort\":10686,\"type\":\"endnotes\",\"label\":\"n.91\",\"alignments\":{},\"references\":[{\"content\":\"“When I had heard these words, I wondered if I had previously misheard and misunderstood the Buddha, and I was very much ashamed. Then I heard a voice from the sky: ‘Ānanda! The householder speaks to you truly. Nevertheless, since the Buddha has appeared during the time of the five corruptions, he disciplines living beings by acting lowly and humble. Therefore, Ānanda, do not be ashamed, and go and get the milk!’\",\"label\":\"3.46\",\"sort\":2953,\"type\":\"translation\",\"uuid\":\"e8eee67f-a1e6-4ae6-92d8-8645a8bf82d0\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-150\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":51,\"uuid\":\"8e1302ba-e851-487c-b9ec-22b9c39dde13\"},\"content\":[{\"type\":\"text\",\"text\":\"Voices from sky-gods are common in \",\"attrs\":{\"start\":0,\"end\":35}},{\"type\":\"text\",\"text\":\"Mahāyāna\",\"attrs\":{\"start\":35,\"end\":43},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"99607e52-e246-4905-b531-6e6d7ccfd7b7\",\"uuid\":\"ac91b99e-7405-4454-8d00-2556aec4498b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":43,\"end\":44}},{\"type\":\"text\",\"text\":\"sūtras\",\"attrs\":{\"start\":44,\"end\":50},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c65438ed-99d8-45cc-bc87-72f8f617eea5\",\"uuid\":\"621f4115-d817-481e-8922-8fca1e7025fb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":50,\"end\":51}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"3fae5fed-b7ce-4738-bcaa-aafeef19a336\",\"sort\":10692,\"type\":\"endnotes\",\"label\":\"n.92\",\"alignments\":{},\"references\":[{\"content\":\"“Lord, such was my conversation with the Licchavi Vimalakīrti, and therefore I am reluctant to go to that good man to inquire about his illness.” In the same way, the rest of the five hundred disciples were reluctant to go to the Licchavi Vimalakīrti, and each told the Buddha his own adventure, recounting all his conversations with the Licchavi Vimalakīrti.\",\"label\":\"3.47\",\"sort\":2964,\"type\":\"translation\",\"uuid\":\"74dc39c6-44fc-4e62-840f-a5e04de42819\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-151\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":112,\"uuid\":\"3fae5fed-b7ce-4738-bcaa-aafeef19a336\"},\"content\":[{\"type\":\"text\",\"text\":\"See Lamotte, p 186, n 82, for another version of this episode translated by \",\"attrs\":{\"start\":0,\"end\":76}},{\"type\":\"text\",\"text\":\"Kumārajīva\",\"attrs\":{\"start\":76,\"end\":86},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"05d4dcc1-b553-4d8a-b913-3d42e28773e0\",\"uuid\":\"357bdf91-b23d-4d5a-bf3a-de0104090b43\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in \",\"attrs\":{\"start\":86,\"end\":90}},{\"type\":\"text\",\"text\":\"Prajñā­pāramitopadeśa\",\"attrs\":{\"start\":90,\"end\":111},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"uuid\":\"6b2efc55-d389-4201-8c9b-04a486997b95\",\"lang\":\"Sa-Ltn\",\"type\":\"inlineTitle\",\"start\":90,\"end\":0}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"dfafe214-f0c6-40bc-a862-534f47ad0264\",\"uuid\":\"23b2810a-fcc5-40c3-b860-a3e8360406c5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":111,\"end\":112}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"66f5991e-f2ae-4cb0-b0dd-20c0e7f1d5e4\",\"sort\":10698,\"type\":\"endnotes\",\"label\":\"n.93\",\"alignments\":{},\"references\":[{\"content\":\"“Lord, such was my conversation with the Licchavi Vimalakīrti, and therefore I am reluctant to go to that good man to inquire about his illness.” In the same way, the rest of the five hundred disciples were reluctant to go to the Licchavi Vimalakīrti, and each told the Buddha his own adventure, recounting all his conversations with the Licchavi Vimalakīrti.\",\"label\":\"3.47\",\"sort\":2964,\"type\":\"translation\",\"uuid\":\"74dc39c6-44fc-4e62-840f-a5e04de42819\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-151\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":158,\"uuid\":\"66f5991e-f2ae-4cb0-b0dd-20c0e7f1d5e4\"},\"content\":[{\"type\":\"text\",\"text\":\"K and X start a new chapter at this point, while Tib. and Skt. include the disciples’ and \",\"attrs\":{\"start\":0,\"end\":90}},{\"type\":\"text\",\"text\":\"bodhisattvas\",\"attrs\":{\"start\":90,\"end\":102},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c72eb4f3-700e-454d-996e-5ccdba29e6be\",\"uuid\":\"d431891e-38e0-453a-a117-fab7aadbe19f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’ responses to the \",\"attrs\":{\"start\":102,\"end\":121}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":121,\"end\":127},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"53a85d19-6a9b-425b-8760-b4a0d9179299\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s request in a single chapter.\",\"attrs\":{\"start\":127,\"end\":158}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"94aa29cd-2fd1-4c5d-b202-aa564495bfec\",\"sort\":10704,\"type\":\"endnotes\",\"label\":\"n.94\",\"alignments\":{},\"references\":[{\"content\":\"The Buddha then said to the bodhisattva Maitreya, “Maitreya, go to the Licchavi Vimalakīrti to inquire about his illness.” Maitreya replied, “Lord, I am indeed reluctant to go to that good man to inquire about his illness. Why? Lord, I remember that one day I was engaged in a conversation with the gods of the Tuṣita heaven, the god Saṃtuṣita and his retinue, about the stage of nonregression of the great bodhisattvas. At that time, the Licchavi Vimalakīrti came there and addressed me as follows:\",\"label\":\"3.48\",\"sort\":2988,\"type\":\"translation\",\"uuid\":\"150299cf-fb5d-4704-b8b7-e2d58fd55bc3\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-152\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":169,\"uuid\":\"94aa29cd-2fd1-4c5d-b202-aa564495bfec\"},\"content\":[{\"type\":\"text\",\"text\":\"The characterization of \",\"attrs\":{\"start\":0,\"end\":24}},{\"type\":\"text\",\"text\":\"Maitreya\",\"attrs\":{\"start\":24,\"end\":32},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7067dbc9-9833-4f0d-880c-f1b6f821805f\",\"uuid\":\"60da33b4-bce4-485c-ab10-db5160554dc2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in \",\"attrs\":{\"start\":32,\"end\":36}},{\"type\":\"text\",\"text\":\"Mahāyāna\",\"attrs\":{\"start\":36,\"end\":44},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"99607e52-e246-4905-b531-6e6d7ccfd7b7\",\"uuid\":\"5769e615-ae21-47cd-bff1-88f9da76043b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":44,\"end\":45}},{\"type\":\"text\",\"text\":\"sūtras\",\"attrs\":{\"start\":45,\"end\":51},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c65438ed-99d8-45cc-bc87-72f8f617eea5\",\"uuid\":\"08aa9c90-1fd4-4891-84b5-60cb447057d8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is that of having a certain naiveté. Mañjusrī often chides him, and \",\"attrs\":{\"start\":51,\"end\":120}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":120,\"end\":131},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"71751ea4-4bcc-414b-a91d-8fc70a49ef04\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" does not let him rest on his laurels.\",\"attrs\":{\"start\":131,\"end\":169}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"a4ec8785-93a8-4ac0-9301-a4a7ce1c3030\",\"sort\":10714,\"type\":\"endnotes\",\"label\":\"n.95\",\"alignments\":{},\"references\":[{\"content\":\"$4d\",\"label\":\"3.50\",\"sort\":3043,\"type\":\"translation\",\"uuid\":\"41256fd6-f976-437c-9da8-17b287357d8b\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-154\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":633,\"uuid\":\"a4ec8785-93a8-4ac0-9301-a4a7ce1c3030\"},\"content\":[{\"type\":\"text\",\"text\":\"K and X give a different reading: “How then, \",\"attrs\":{\"start\":0,\"end\":45}},{\"type\":\"text\",\"text\":\"Maitreya\",\"attrs\":{\"start\":45,\"end\":53},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7067dbc9-9833-4f0d-880c-f1b6f821805f\",\"uuid\":\"f6900b64-a2cc-4aa1-82c0-3bd17b8a2f7a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", did you receive the prophecy of your attainment of buddhahood after only one more birth? Did you receive it as the reality of birth or as the reality of death? In the former case, this reality is uncreated, and in the latter case, it does not die.” As always, Ch. is less abstract than Tib., but both agree on the general tenor of \",\"attrs\":{\"start\":53,\"end\":386}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":386,\"end\":397},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"9198cb40-cf47-44fd-b824-2cfdddf060b5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s refutation of \",\"attrs\":{\"start\":397,\"end\":414}},{\"type\":\"text\",\"text\":\"Maitreya\",\"attrs\":{\"start\":414,\"end\":422},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7067dbc9-9833-4f0d-880c-f1b6f821805f\",\"uuid\":\"e588a095-e4bf-462c-971f-e81c68c14dc5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s acceptance of the prophecy as being valid on the \",\"attrs\":{\"start\":422,\"end\":474}},{\"type\":\"text\",\"text\":\"ultimate\",\"attrs\":{\"start\":474,\"end\":482},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"784c8158-9e46-4484-9152-e0d06cd46afc\",\"uuid\":\"7080a76c-ddfd-4e13-b5ff-bdca5842e079\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" level of reality (\",\"attrs\":{\"start\":482,\"end\":501}},{\"type\":\"text\",\"text\":\"paramārtha­satyatā\",\"attrs\":{\"start\":501,\"end\":519},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":501,\"end\":519,\"uuid\":\"f1e52a33-979c-4b26-a6ac-5a5d7cac442a\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"). On the question of the validity of prophecies on the superficial and \",\"attrs\":{\"start\":519,\"end\":591}},{\"type\":\"text\",\"text\":\"ultimate\",\"attrs\":{\"start\":591,\"end\":599},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"784c8158-9e46-4484-9152-e0d06cd46afc\",\"uuid\":\"a3d3ffe0-30d8-46dd-aec1-c51b68ed7dbe\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" levels, see Lamotte, p 189, n 89.\",\"attrs\":{\"start\":599,\"end\":633}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"35d72df0-74c0-4eb5-9a5a-8d8ca1cacc43\",\"sort\":10728,\"type\":\"endnotes\",\"label\":\"n.96\",\"alignments\":{},\"references\":[{\"content\":\"“ ‘Therefore, Maitreya, do not fool and delude these deities! No one abides in, or regresses from, enlightenment. Maitreya, you should introduce these deities to the repudiation of all discriminative constructions concerning enlightenment.\",\"label\":\"3.51\",\"sort\":3087,\"type\":\"translation\",\"uuid\":\"182d524c-1839-4c37-abf6-92e3d134292a\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-155\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":534,\"uuid\":\"35d72df0-74c0-4eb5-9a5a-8d8ca1cacc43\"},\"content\":[{\"type\":\"text\",\"text\":\"The thrust of \",\"attrs\":{\"start\":0,\"end\":14}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":14,\"end\":25},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"bbd96d58-8485-462b-8511-5debd4608848\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s instruction here is that “being enlightened” and “being unenlightened” are valid designations only on the superficial, designative, relative level of truth. “Discriminative construction” is that mental process that seeks to “absolutize” a relative thing, taking “ignorance” and “\",\"attrs\":{\"start\":25,\"end\":307}},{\"type\":\"text\",\"text\":\"enlightenment\",\"attrs\":{\"start\":307,\"end\":320},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"62f923c5-8dfa-4620-8dec-7bb032231bf7\",\"uuid\":\"4ce81d1e-9eae-433b-92f0-10b18f500d3b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"” as ultimately real things. Thus in all the subsequent negational descriptions of \",\"attrs\":{\"start\":320,\"end\":403}},{\"type\":\"text\",\"text\":\"enlightenment\",\"attrs\":{\"start\":403,\"end\":416},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"62f923c5-8dfa-4620-8dec-7bb032231bf7\",\"uuid\":\"3f0ac1ab-fedd-434d-8e61-6e3920e7e8f4\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the phrase “on the \",\"attrs\":{\"start\":416,\"end\":437}},{\"type\":\"text\",\"text\":\"ultimate\",\"attrs\":{\"start\":437,\"end\":445},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"784c8158-9e46-4484-9152-e0d06cd46afc\",\"uuid\":\"b5a53cce-51fc-4c33-b9fe-6d70eb4a6d63\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" level” may be understood to avert a nihilistic interpretation. See Introduction, \",\"attrs\":{\"start\":445,\"end\":527}},{\"type\":\"text\",\"text\":\"i.1\",\"attrs\":{\"start\":527,\"end\":530},\"marks\":[{\"type\":\"internalLink\",\"attrs\":{\"uuid\":\"a27d820b-b819-41ce-8ca7-fffd4d5afcb0\",\"href\":\"/entity/passage/43e82047-fa70-483c-8572-57d4674123fc\",\"entity\":\"43e82047-fa70-483c-8572-57d4674123fc\",\"type\":\"passage\",\"toh\":null,\"isSameWork\":true,\"subtype\":\"introduction\"}}]},{\"type\":\"text\",\"text\":\" ff.\",\"attrs\":{\"start\":530,\"end\":534}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"685decc5-e86c-42fd-a577-c7bedf60ad13\",\"sort\":10740,\"type\":\"endnotes\",\"label\":\"n.97\",\"alignments\":{},\"references\":[{\"content\":\"$4e\",\"label\":\"3.53\",\"sort\":3132,\"type\":\"translation\",\"uuid\":\"d4d95e7b-3575-46dc-b6bd-22d5a1791966\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-157\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":185,\"uuid\":\"685decc5-e86c-42fd-a577-c7bedf60ad13\"},\"content\":[{\"type\":\"text\",\"text\":\"Tib. \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"rnam par rig pa med pa\",\"attrs\":{\"start\":5,\"end\":27},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":5,\"end\":27,\"uuid\":\"ae031b37-4441-4ae7-b7a6-c75660fb8c60\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"; Skt. \",\"attrs\":{\"start\":27,\"end\":34}},{\"type\":\"text\",\"text\":\"avijñapti\",\"attrs\":{\"start\":34,\"end\":43},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":34,\"end\":43,\"uuid\":\"1d7c3736-4c0e-4aea-ba1d-59c306bc4fcf\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" (lit. “without means of cognition”). Again, it may be stressed that all these statements imply the qualification “ultimately” (\",\"attrs\":{\"start\":43,\"end\":171}},{\"type\":\"text\",\"text\":\"paramārthena\",\"attrs\":{\"start\":171,\"end\":183},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":171,\"end\":183,\"uuid\":\"30bef395-00b8-47a7-b563-06c86044d337\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\").\",\"attrs\":{\"start\":183,\"end\":185}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"90a4cffe-fc05-4859-9247-42f07fe1fef6\",\"sort\":10748,\"type\":\"endnotes\",\"label\":\"n.98\",\"alignments\":{},\"references\":[{\"content\":\"“ ‘It is the seat of interdependent origination, because it proceeds from the exhaustion of ignorance to the exhaustion of old age and death. It is the seat of eradication of all afflictions, because it is perfectly enlightened about the nature of reality. It is the seat of all living beings, because all living beings are without intrinsic identity. It is the seat of all things, because it is perfectly enlightened with regard to voidness.\",\"label\":\"3.59\",\"sort\":3251,\"type\":\"translation\",\"uuid\":\"8427d99d-6b2e-4b98-8fcf-e98a4c80ddea\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-163\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":915,\"uuid\":\"90a4cffe-fc05-4859-9247-42f07fe1fef6\"},\"content\":[{\"type\":\"text\",\"text\":\"K and X: “It is the seat of interdependent origination, because it is like infinite space.” Ch. thus takes \",\"attrs\":{\"start\":0,\"end\":107}},{\"type\":\"text\",\"text\":\"pratītya­samutpāda\",\"attrs\":{\"start\":107,\"end\":125},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":107,\"end\":125,\"uuid\":\"8347df4d-315a-4e91-b06e-aa57d9ebcb0d\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\" (see glossary “\",\"attrs\":{\"start\":125,\"end\":141}},{\"type\":\"text\",\"text\":\"dependent origination\",\"attrs\":{\"start\":141,\"end\":162},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"28a2831b-8ff3-473b-9ee3-6a0d997ccff0\",\"uuid\":\"c4409127-a8de-4c69-9437-5b94e3adad5e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"” and “\",\"attrs\":{\"start\":162,\"end\":169}},{\"type\":\"text\",\"text\":\"relativity\",\"attrs\":{\"start\":169,\"end\":179},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a53cd052-8393-4f2f-b18f-df2aff5c0cdb\",\"uuid\":\"19caea0b-ce2b-4b3b-a01d-1e048c0fdde8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"”) as equivalent to \",\"attrs\":{\"start\":179,\"end\":199}},{\"type\":\"text\",\"text\":\"śūnyatā\",\"attrs\":{\"start\":199,\"end\":206},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":199,\"end\":206,\"uuid\":\"c272ec9d-1a50-4451-b7f4-86c3a6c1ea71\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}},{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1ede53af-8161-4358-9902-76ff3144ae49\",\"uuid\":\"13cb67d9-2446-4587-bdc6-e321874c0545\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", which is correct as regards its \",\"attrs\":{\"start\":206,\"end\":240}},{\"type\":\"text\",\"text\":\"ultimate\",\"attrs\":{\"start\":240,\"end\":248},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"784c8158-9e46-4484-9152-e0d06cd46afc\",\"uuid\":\"60b83b38-5493-40de-88ac-2ed03800de98\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" nature. \",\"attrs\":{\"start\":248,\"end\":257}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":257,\"end\":268},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"3d92240e-2afa-4bf5-a7f0-e7347df80637\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" refers to the “\",\"attrs\":{\"start\":268,\"end\":284}},{\"type\":\"text\",\"text\":\"cessation\",\"attrs\":{\"start\":284,\"end\":293},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2c99efa2-82ea-426e-8c67-105bb43e05b5\",\"uuid\":\"b5096399-bf10-49fb-a17c-b75e5c0f2f20\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"-order” of the twelve links of origination: that is, stopping ignorance stops synthetic activity; stopping synthetic activity stops \",\"attrs\":{\"start\":293,\"end\":425}},{\"type\":\"text\",\"text\":\"consciousness\",\"attrs\":{\"start\":425,\"end\":438},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a8081b29-fd2e-425a-b8a0-900b375ccea0\",\"uuid\":\"cd205ade-e9ee-4ff6-a672-4169a2d2c324\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"; stopping \",\"attrs\":{\"start\":438,\"end\":449}},{\"type\":\"text\",\"text\":\"consciousness\",\"attrs\":{\"start\":449,\"end\":462},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a8081b29-fd2e-425a-b8a0-900b375ccea0\",\"uuid\":\"b6245b80-2161-460b-8475-1c1b160d09b8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" stops name-and-form; stopping name-and-form stops the six \",\"attrs\":{\"start\":462,\"end\":521}},{\"type\":\"text\",\"text\":\"sense-media\",\"attrs\":{\"start\":521,\"end\":532},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f63a28fa-eaa5-4aa0-bcc2-44bd9e6badcf\",\"uuid\":\"96c523a7-a2ce-435d-b872-bfb1410df7e9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"; stopping the \",\"attrs\":{\"start\":532,\"end\":547}},{\"type\":\"text\",\"text\":\"sense-media\",\"attrs\":{\"start\":547,\"end\":558},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f63a28fa-eaa5-4aa0-bcc2-44bd9e6badcf\",\"uuid\":\"bd45790e-f7d3-4c48-a940-de1148ea7129\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" stops contact; stopping contact stops \",\"attrs\":{\"start\":558,\"end\":597}},{\"type\":\"text\",\"text\":\"sensation\",\"attrs\":{\"start\":597,\"end\":606},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"3c9a7a89-0b91-478a-a4a4-f6730f0689f9\",\"uuid\":\"ff2d4492-8ae4-4372-8e0e-2b4e79bff6b2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"; stopping \",\"attrs\":{\"start\":606,\"end\":617}},{\"type\":\"text\",\"text\":\"sensation\",\"attrs\":{\"start\":617,\"end\":626},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"3c9a7a89-0b91-478a-a4a4-f6730f0689f9\",\"uuid\":\"ddbe6302-9fbe-4636-b63c-562a4f0e6f8d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" stops craving; stopping craving stops grasping; stopping grasping stops existence; stopping existence stops birth; and stopping birth stops old age and death. This is the sequence of realization of the twelvefold chain during the attainment of \",\"attrs\":{\"start\":626,\"end\":871}},{\"type\":\"text\",\"text\":\"enlightenment\",\"attrs\":{\"start\":871,\"end\":884},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"62f923c5-8dfa-4620-8dec-7bb032231bf7\",\"uuid\":\"fafc535a-cc65-4d35-85a3-67e63404c630\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" on the \",\"attrs\":{\"start\":884,\"end\":892}},{\"type\":\"text\",\"text\":\"seat of enlightenment\",\"attrs\":{\"start\":892,\"end\":913},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"aa890c43-17f7-413b-a41f-433bfc888126\",\"uuid\":\"8c82b9ab-f462-4aaf-b86c-9eb28cf668ec\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"‌.\",\"attrs\":{\"start\":913,\"end\":915}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"6e8e85c3-8fc3-445c-81b3-cd60683c6c7a\",\"sort\":10780,\"type\":\"endnotes\",\"label\":\"n.99\",\"alignments\":{},\"references\":[{\"content\":\"“ ‘Noble son, when bodhisattvas are thus endowed with the transcendences, the roots of virtue, the ability to develop living beings, and the incorporation of the holy Dharma, whether they lift up their feet or put them down, they all come from the seat of enlightenment. They come from the qualities of the Buddha, and stand on the qualities of the Buddha.’\",\"label\":\"3.61\",\"sort\":3275,\"type\":\"translation\",\"uuid\":\"26c7337e-13fb-4d7a-b4dd-8a0b0a9ce0db\",\"workUuid\":\"980238ba-2dd5-4416-a910-e237d343b3ac\",\"xmlId\":\"UT22084-060-005-165\",\"toh\":null,\"alignments\":[],\"annotations\":[]}]},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":192,\"uuid\":\"6e8e85c3-8fc3-445c-81b3-cd60683c6c7a\"},\"content\":[{\"type\":\"text\",\"text\":\"Tib. \",\"attrs\":{\"start\":0,\"end\":5}},{\"type\":\"text\",\"text\":\"dam pa’i chos yongs su ’dzin pa\",\"attrs\":{\"start\":5,\"end\":36},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":5,\"end\":36,\"uuid\":\"519d2eaf-7672-4855-bb85-680a71a72220\",\"type\":\"span\",\"lang\":\"Bo-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\"; Skt. \",\"attrs\":{\"start\":36,\"end\":43}},{\"type\":\"text\",\"text\":\"saddharma­saṃgraha\",\"attrs\":{\"start\":43,\"end\":61},\"marks\":[{\"type\":\"italic\",\"attrs\":{\"start\":43,\"end\":61,\"uuid\":\"c2be16f8-55b5-472e-abfc-d5bfcf54ad95\",\"type\":\"span\",\"lang\":\"Sa-Ltn\",\"textStyle\":\"foreign\"}}]},{\"type\":\"text\",\"text\":\". Here taken as “incorporation” in the sense of the \",\"attrs\":{\"start\":61,\"end\":113}},{\"type\":\"text\",\"text\":\"bodhisattva\",\"attrs\":{\"start\":113,\"end\":124},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c72eb4f3-700e-454d-996e-5ccdba29e6be\",\"uuid\":\"32626315-a495-4726-a285-05003fd9ac4d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"’s incorporation of the holy \",\"attrs\":{\"start\":124,\"end\":153}},{\"type\":\"text\",\"text\":\"Dharma\",\"attrs\":{\"start\":153,\"end\":159},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c08db6f5-393e-4ec4-bf72-4043e53b3129\",\"uuid\":\"f99d59cf-7e92-4748-a72d-fda50dd10801\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in all phases of his daily life.\",\"attrs\":{\"start\":159,\"end\":192}}]}]}],\"glossary\":[{\"uuid\":\"ccc150b4-2233-4e01-a530-7cc6f0aec169\",\"authority\":\"47fb5241-a816-4a41-9cab-35c2116593f3\",\"definition\":\"$4f\",\"names\":{\"english\":\"Abhidharma\",\"tibetan\":\"ཆོས་མངོན་པ།\",\"sanskrit\":\"abhidharma\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chos mngon pa\"}},{\"uuid\":\"ed2ba03e-ccf4-47ec-adef-dd0302550a97\",\"authority\":\"dde5a4d9-0435-4fa2-b405-e70e7ba270ed\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn important work written by \u003cspan data-glossary-id=\\\"UT22084-060-005-819\\\"\u003eVasubandhu\u003c/span\u003e, probably in the fourth century, as a critical compendium of the Abhidharmic science.\u003c/p\u003e\",\"names\":{\"english\":\"Abhi­dharma­kośa\",\"tibetan\":\"ཆོས་མངོན་པའི་མཛོད།\",\"sanskrit\":\"abhi­dharma­kośa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chos mngon pa’i mdzod\"}},{\"uuid\":\"1ce645a6-d4d1-4912-a8c2-9617e8932dd1\",\"authority\":\"43c14e68-bc34-45dc-849c-03bc8422e5e6\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eLit. “Intense Delight.” The universe, or \u003cspan data-glossary-id=\\\"UT22084-060-005-516\\\"\u003ebuddhafield\u003c/span\u003e of the \u003cspan data-glossary-id=\\\"UT22084-060-005-672\\\"\u003eTathāgata\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-060-005-697\\\"\u003eAkṣobhya\u003c/span\u003e, lying in the east beyond innumerable galaxies, whence \u003cspan data-glossary-id=\\\"UT22084-060-005-1257\\\"\u003eVimalakīrti\u003c/span\u003e came to reincarnate in our \u003cspan data-glossary-id=\\\"UT22084-060-005-841\\\"\u003eSahā\u003c/span\u003e universe.\u003c/p\u003e\",\"names\":{\"english\":\"Abhirati\",\"tibetan\":\"མངོན་པར་དགའ་བ།\",\"sanskrit\":\"abhirati\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mngon par dga’ ba\"}},{\"uuid\":\"920e3646-8f88-46a8-a034-6f9cd1a69c0d\",\"authority\":\"858948d2-b74d-41d5-9374-9dd328a5fc4c\",\"definition\":\"$50\",\"names\":{\"english\":\"absence of self\",\"tibetan\":\"བདག་མེད་པ།\",\"sanskrit\":\"anātmatā, nairātmya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bdag med pa\"}},{\"uuid\":\"a1e049fe-15a3-42ec-9ae6-63792aa4ffc6\",\"authority\":\"1b579d82-b45b-4056-8d73-1cd34a70a1b6\",\"definition\":\"$51\",\"names\":{\"english\":\"absorption, meditation\",\"tibetan\":\"སྙོམས་པར་འཇུག\",\"sanskrit\":\"samāpatti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"snyoms par ’jug\"}},{\"uuid\":\"72ea6449-0c42-401c-bff0-be87bffdfd07\",\"authority\":\"1b579d82-b45b-4056-8d73-1cd34a70a1b6\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee “\u003cspan data-glossary-id=\\\"UT22084-060-005-500\\\"\u003eabsorption\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"absorption, meditation\",\"tibetan\":\"སྙོམས་པར་འཇུག\",\"sanskrit\":\"samāpatti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"snyoms par ’jug\"}},{\"uuid\":\"62aa0bc0-1ed1-49a6-b18e-9b0f37c6aeef\",\"authority\":\"c87671dd-3ffd-410d-a94d-fca04ee8ccc2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eDesire, hatred and anger, dullness, pride, and jealousy, as well as all their derivatives, said to number 84,000. Also translated “\u003cspan data-glossary-id=\\\"UT22084-060-005-630\\\"\u003epassions\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"affliction, passion\",\"tibetan\":\"ཉོན་མོངས།, ཉོན་མོངས།\",\"sanskrit\":\"kleśa, kleśa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nyon mongs, nyon mongs\"}},{\"uuid\":\"2370c8e3-79cc-4eab-bc82-33939081f558\",\"authority\":\"c87671dd-3ffd-410d-a94d-fca04ee8ccc2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eDesire, hatred and anger, dullness, pride, and jealousy, as well as all their derivatives, said to number 84,000. Also translated “\u003cspan data-glossary-id=\\\"UT22084-060-005-501\\\"\u003eafflictions\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"affliction, passion\",\"tibetan\":\"ཉོན་མོངས།, ཉོན་མོངས།\",\"sanskrit\":\"kleśa, kleśa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nyon mongs, nyon mongs\"}},{\"uuid\":\"95840062-0b03-40c7-ad24-49f28628a43e\",\"authority\":\"befb80a6-3a70-411f-84f4-2016cc3a88fa\",\"definition\":\"$52\",\"names\":{\"english\":\"aggregate\",\"tibetan\":\"ཕུང་པོ།\",\"sanskrit\":\"skandha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"phung po\"}},{\"uuid\":\"82d9a387-35b2-40eb-9e17-30cb35396ea1\",\"authority\":\"d446af6c-b807-4c2d-ae67-641d4f0de5f9\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee “\u003cspan data-glossary-id=\\\"UT22084-060-005-676\\\"\u003ethirty-seven aids to enlightenment\u003c/span\u003e”\u003c/p\u003e\",\"names\":{\"english\":\"aids to enlightenment\",\"tibetan\":\"བྱང་ཆུབ་ཀྱི་ཕྱོགས་ཀྱི་ཆོས།\",\"sanskrit\":\"bodhi­pakṣika­dharma\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"byang chub kyi phyogs kyi chos\"}},{\"uuid\":\"6162f2ee-5256-4e0d-9fc5-edcb092f77d7\",\"authority\":\"bcf80cc0-d524-4ac8-b8b0-a0d531ffd617\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the six \u003cspan data-glossary-id=\\\"UT22084-060-005-627\\\"\u003eoutsider\u003c/span\u003e teachers defeated by the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e at \u003cspan data-glossary-id=\\\"UT22084-060-005-844\\\"\u003eŚrāvastī\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Ajita Keśakambala\",\"tibetan\":\"མི་ཕམ་སྒྲའི་ལ་བ་ཅན།\",\"sanskrit\":\"ajita keśakambala\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mi pham sgra’i la ba can\"}},{\"uuid\":\"ffde421f-3310-441c-9b2b-58906d7447c7\",\"authority\":\"e00c06d4-270e-464e-a57b-1a020464ad34\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe highest heaven of the form-world, where a \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003ebuddha\u003c/span\u003e always receives the anointment of the \u003cspan data-glossary-id=\\\"UT22084-060-005-683\\\"\u003eultimate\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-060-005-691\\\"\u003ewisdom\u003c/span\u003e, reaching there mentally from his \u003cspan data-glossary-id=\\\"UT22084-060-005-648\\\"\u003eseat of enlightenment\u003c/span\u003e under the Bodhi-tree.\u003c/p\u003e\",\"names\":{\"english\":\"Akaniṣṭha\",\"tibetan\":\"འོག་མིན།\",\"sanskrit\":\"akaniṣṭha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’og min\"}},{\"uuid\":\"9e2da1d0-a4aa-433e-aab2-ab4c9a510820\",\"authority\":\"7b13af11-a4ff-4496-9927-272636112225\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattva\u003c/span\u003e in the assembly at \u003cspan data-glossary-id=\\\"UT22084-060-005-1257\\\"\u003eVimalakīrti\u003c/span\u003e’s house, often figuring in other \u003cspan data-glossary-id=\\\"UT22084-060-005-605\\\"\u003eMahāyāna\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-060-005-670\\\"\u003esūtras\u003c/span\u003e, especially \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eAkṣayamati­nirdeśa­sūtra\u003c/cite\u003e. \u003c/p\u003e\",\"names\":{\"english\":\"Akṣayamati\",\"tibetan\":\"བློ་གྲོས་མི་ཟད་པ།\",\"sanskrit\":\"akṣayamati\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"blo gros mi zad pa\"}},{\"uuid\":\"230b32ae-e885-45ea-9324-b646974f8fa5\",\"authority\":\"cad43a0c-a53f-4f2e-8341-2a76e07dcb4a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e of the universe \u003cspan data-glossary-id=\\\"UT22084-060-005-824\\\"\u003eAbhirati\u003c/span\u003e, presiding over the eastern direction; also prominent in tantric works as one of the five dhyāni \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003ebuddhas\u003c/span\u003e, or \u003cspan data-glossary-id=\\\"UT22084-060-005-672\\\"\u003etathāgatas\u003c/span\u003e (see Lamotte, pp. 360-362, n. 9).\u003c/p\u003e\",\"names\":{\"english\":\"Akṣobhya\",\"tibetan\":\"མི་འཁྲུགས་པ།\",\"sanskrit\":\"akṣobhya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mi ’khrugs pa\"}},{\"uuid\":\"f4f18382-cdf8-419b-b267-5fcdb5b97804\",\"authority\":\"52456ea4-51a5-46fa-8f83-56abbc67c5c4\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e of boundless light; one of the five \u003cspan data-glossary-id=\\\"UT22084-060-005-672\\\"\u003eTathāgatas\u003c/span\u003e in Tantrism; a visitor in \u003cspan data-glossary-id=\\\"UT22084-060-005-1257\\\"\u003eVimalakīrti\u003c/span\u003e’s house, according to the goddess’s report.\u003c/p\u003e\",\"names\":{\"english\":\"Amitābha\",\"tibetan\":\"སྣང་བ་མཐའ་ཡས།\",\"sanskrit\":\"amitābha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"snang ba mtha’ yas\"}},{\"uuid\":\"837c2527-85cb-4a76-bf21-913ecb4a5d69\",\"authority\":\"b4532f04-05e2-4f2c-882c-ecb715efc1b4\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA courtesan of \u003cspan data-glossary-id=\\\"UT22084-060-005-848\\\"\u003eVaiśālī\u003c/span\u003e who gave her garden to the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e and his retinue, where they stay during the events of the \u003cspan data-glossary-id=\\\"UT22084-060-005-670\\\"\u003esūtra\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Āmrapālī\",\"tibetan\":\"ཨ་མྲ་སྲུང་བ།\",\"sanskrit\":\"āmrapālī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"a mra srung ba\"}},{\"uuid\":\"240d1cab-1211-41e4-8623-ecceecfb763d\",\"authority\":\"2c02baf4-0ece-4579-8f66-c49bcc21f21f\",\"definition\":\"$53\",\"names\":{\"english\":\"Ānanda\",\"tibetan\":\"ཀུན་དགའ་བོ།\",\"sanskrit\":\"ānanda\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kun dga’ bo\"}},{\"uuid\":\"0aca3d2b-9f37-4ab1-aec7-084006cafb82\",\"authority\":\"845eab9c-5279-4e62-ab17-88aae337ea51\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eLit. “infinite array of jewel-qualities.” A universe of \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-060-005-787\\\"\u003eRatnavyūha\u003c/span\u003e, also mentioned in the \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eLalita­vistara­sūtra\u003c/cite\u003e. \u003c/p\u003e\",\"names\":{\"english\":\"Ananta­guṇa­ratna­vyūha\",\"tibetan\":\"ཡོན་ཏན་རིན་ཆེན་མཐའ་ཡས་བཀོད་པ།\",\"sanskrit\":\"ananta­guṇa­ratna­vyūha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yon tan rin chen mtha’ yas bkod pa\"}},{\"uuid\":\"8d8f294c-e815-4e55-8049-80f4e6b89f5f\",\"authority\":\"18d96844-6dd8-43b7-95cb-3bba866c75d8\",\"definition\":\"\",\"names\":{\"english\":\"Anārambaṇa­dhyāyin\",\"tibetan\":\"དམིགས་པ་མེད་པའི་བསམ་གཏན།\",\"sanskrit\":\"anārambaṇa­dhyāyin\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dmigs pa med pa’i bsam gtan\"}},{\"uuid\":\"96cef1f6-a714-4f47-88ef-a5a912b3720d\",\"authority\":\"7f5c1186-ed32-4b9c-b588-467f1b504255\",\"definition\":\"\",\"names\":{\"english\":\"Anikṣiptadhura\",\"tibetan\":\"བརྩོན་པ་མི་འདོར་བ།\",\"sanskrit\":\"anikṣiptadhura\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"brtson pa mi ’dor ba\"}},{\"uuid\":\"16a55775-56db-4c97-b4ea-04f04e755e72\",\"authority\":\"dd800f86-676c-4b72-b850-913c527051b9\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-060-005-661\\\"\u003eśrāvaka\u003c/span\u003e disciple and cousin of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e who was famed for his meditative prowess and \u003cspan data-glossary-id=\\\"UT22084-060-005-669\\\"\u003esuperknowledges\u003c/span\u003e. See also \u003ca href=\\\"end-notes.xhtml#UT22084-060-005-940\\\" data-pointer-type=\\\"id\\\"\u003en.78\u003c/a\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Aniruddha\",\"tibetan\":\"མ་འགགས་པ།\",\"sanskrit\":\"aniruddha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ma ’gags pa\"}},{\"uuid\":\"8584345b-bf7d-481b-ac82-4146d2374b3c\",\"authority\":\"d95e6f28-87de-429e-b185-d12873ac760c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAccording to Buddhist tradition, one who has conquered his enemy \u003cspan data-glossary-id=\\\"UT22084-060-005-630\\\"\u003epassions\u003c/span\u003e (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003ekleśa-ari-hata\u003c/em\u003e) and reached the supreme purity. The term can refer to \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003ebuddhas\u003c/span\u003e as well as to those who have reached realization of the \u003cspan data-glossary-id=\\\"UT22084-060-005-662\\\"\u003eDisciple Vehicle\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"arhat\",\"tibetan\":\"དགྲ་བཅོམ་པ།\",\"sanskrit\":\"arhat\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dgra bcom pa\"}},{\"uuid\":\"8ab1dcbc-81ec-4de9-9896-d229ab475fc4\",\"authority\":\"4232ae77-cf85-4cde-b478-b511c160e924\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the great masters of Indian Buddhism. The main disciple of \u003cspan data-glossary-id=\\\"UT22084-060-005-753\\\"\u003eNāgārjuna\u003c/span\u003e, he lived in the early a.d. centuries and wrote numerous important works of \u003cspan data-glossary-id=\\\"UT22084-060-005-603\\\"\u003eMādhyamika\u003c/span\u003e philosophy.\u003c/p\u003e\",\"names\":{\"english\":\"Āryadeva\",\"tibetan\":\"འཕགས་པ་ལྷ།\",\"sanskrit\":\"āryadeva\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’phags pa lha\"}},{\"uuid\":\"f6fd6d29-a938-42f9-93ff-3a9bfead6c1e\",\"authority\":\"5604278a-b3d3-4f5b-9eab-c22fc5a40401\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThis great Indian philosopher lived in the fourth century and was the founder of the \u003cspan data-glossary-id=\\\"UT22084-060-005-687\\\"\u003eVijñānavāda\u003c/span\u003e, or “\u003cspan class=\\\"ignore\\\"\u003eConsciousness\u003c/span\u003e-Only,” school of \u003cspan data-glossary-id=\\\"UT22084-060-005-605\\\"\u003eMahāyāna\u003c/span\u003e Buddhism.\u003c/p\u003e\",\"names\":{\"english\":\"Āryāsaṅga\",\"tibetan\":\"ཐོགས་མེད།, འཕགས་པ་ཐོགས་མེད།\",\"sanskrit\":\"asaṅga, āryāsaṅga\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"thogs med, ’phags pa thogs med\"}},{\"uuid\":\"d998dae5-2058-4b49-8dff-5dc8ca681495\",\"authority\":\"e60dc0bf-a5ee-4107-8bc9-62d3df0a2b00\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eUniverse whence comes the \u003cspan data-glossary-id=\\\"UT22084-060-005-710\\\"\u003eBrahmā\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-060-005-805\\\"\u003eŚikhin\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Aśoka\",\"tibetan\":\"མྱ་ངན་མེད་པ།\",\"sanskrit\":\"aśoka\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mya ngan med pa\"}},{\"uuid\":\"92f37c52-4181-48ff-8345-2132611c4071\",\"authority\":\"32837dd6-edd0-49d4-b729-9e3e243c4fa1\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eTitan .\u003c/p\u003e\",\"names\":{\"english\":\"asura\",\"tibetan\":\"ལྷ་མ་ཡིན།\",\"sanskrit\":\"asura\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lha ma yin\"}},{\"uuid\":\"4288ecec-62d3-4cb7-98ba-da11e7949e29\",\"authority\":\"80ef4962-ce94-4865-a243-2109aea1045b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe thirty-two signs and the eighty marks of a superior being.\u003c/p\u003e\",\"names\":{\"english\":\"auspicious signs and marks\",\"tibetan\":\"མཚན་དང་དཔེ་བྱད་བཟང་པོ།\",\"sanskrit\":\"lakṣaṇānuvyañjana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mtshan dang dpe byad bzang po\"}},{\"uuid\":\"453b28f2-7da6-40ba-8cd2-772f8f6d626e\",\"authority\":\"0ecba1e9-f6bc-4e30-823b-34a3dc139974\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattva\u003c/span\u003e emblematic of the \u003cspan data-glossary-id=\\\"UT22084-060-005-574\\\"\u003egreat compassion\u003c/span\u003e; of great importance in Tibet as special protector of the religious \u003cspan class=\\\"ignore\\\"\u003elife\u003c/span\u003e of the country and in China, in female form, as Kwanyin, protectress of women, children, and animals.\u003c/p\u003e\",\"names\":{\"english\":\"Avalokiteśvara\",\"tibetan\":\"སྤྱན་རས་གཟིགས་ཀྱི་དབང་ཕྱུག\",\"sanskrit\":\"avalokiteśvara\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"spyan ras gzigs kyi dbang phyug\"}},{\"uuid\":\"1b1c26fc-4bc7-4931-98c7-990b354311fe\",\"authority\":\"f80d056f-e7df-4e9a-86b2-1869a7a403a2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThis vast \u003cspan data-glossary-id=\\\"UT22084-060-005-605\\\"\u003eMahāyāna\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-060-005-670\\\"\u003esūtra\u003c/span\u003e (also called the \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-060-005-851\\\"\u003eBuddhāvataṃsaka\u003c/span\u003e\u003c/cite\u003e) deals with the miraculous side of the \u003cspan data-glossary-id=\\\"UT22084-060-005-605\\\"\u003eMahāyāna\u003c/span\u003e. It is important in relation to the Vimalakīrtinirdeśa, since the latter’s fifth chapter, “The \u003cspan data-glossary-id=\\\"UT22084-060-005-586\\\"\u003eInconceivable Liberation\u003c/span\u003e,” is a highly abbreviated version of the essential teaching of the former.\u003c/p\u003e\",\"names\":{\"english\":\"Avataṃsaka\",\"tibetan\":\"ཕལ་པོ་ཆེ།\",\"sanskrit\":\"avataṃsaka\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"phal po che\"}},{\"uuid\":\"76486a80-1221-41fd-ba60-de89ee8525f0\",\"authority\":\"c34baa59-0055-46a9-95a5-f40846d284da\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe three \u003cspan class=\\\"ignore\\\"\u003ebad migrations\u003c/span\u003e are those of (1) denizens of hells, (2) inhabitants of the “limbo” of the \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003epretaloka\u003c/em\u003e, where one wanders as an insatiably hungry and thirsty wretch, and (3) animals, who are trapped in the pattern of mutual devouring (Tib. \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003egcig la gcig za\u003c/em\u003e).\u003c/p\u003e\",\"names\":{\"english\":\"bad migrations\",\"tibetan\":\"ངན་སོང་།\",\"sanskrit\":\"durgati\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ngan song\"}},{\"uuid\":\"526ff6d2-f868-424a-b128-8312e9a28d7c\",\"authority\":\"c0fc2af2-094e-4418-b5b6-4076fdf24c4a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThese \u003cspan class=\\\"ignore\\\"\u003ebasic precepts\u003c/span\u003e are five in number for the laity: (1) not killing, (2) not stealing, (3) chastity, (4) not lying, and (5) avoiding intoxicants. For monks, there are three or five more; avoidance of such things as perfumes, makeup, ointments, garlands, high beds, and afternoon meals.\u003c/p\u003e\",\"names\":{\"english\":\"basic precepts\",\"tibetan\":\"བསླབ་པའི་གཞི་རྣམས།\",\"sanskrit\":\"sikṣāpada\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bslab pa’i gzhi rnams\"}},{\"uuid\":\"31fe2706-f727-4ee8-b460-9b438431fd2c\",\"authority\":\"4a099edc-db38-46b2-85b7-5e2e6eace711\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eLit. “King of Healers.” In the story of \u003cspan data-glossary-id=\\\"UT22084-060-005-794\\\"\u003eŚākyamuni\u003c/span\u003e’s former \u003cspan class=\\\"ignore\\\"\u003elife\u003c/span\u003e in this \u003cspan data-glossary-id=\\\"UT22084-060-005-670\\\"\u003esūtra\u003c/span\u003e, he is the \u003cspan data-glossary-id=\\\"UT22084-060-005-672\\\"\u003etathāgata\u003c/span\u003e of the universe \u003cspan data-glossary-id=\\\"UT22084-060-005-742\\\"\u003eMahāvyūha\u003c/span\u003e, during the eon called \u003cspan data-glossary-id=\\\"UT22084-060-005-685\\\"\u003eVicaraṇa\u003c/span\u003e, who taught Prince \u003cspan data-glossary-id=\\\"UT22084-060-005-713\\\"\u003eCandracchattra\u003c/span\u003e about \u003cspan data-glossary-id=\\\"UT22084-060-005-537\\\"\u003eDharma\u003c/span\u003e-worship. In later Buddhism, this \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003ebuddha\u003c/span\u003e is believed to be the supernatural patron of healing and medicine. \u003c/p\u003e\",\"names\":{\"english\":\"Bhaiṣajyarāja\",\"tibetan\":\"སྨན་གྱི་རྒྱལ་པོ།\",\"sanskrit\":\"bhaiṣajyarāja\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sman gyi rgyal po\"}},{\"uuid\":\"088e4e49-b2dd-41a5-88bf-d32d42333ac2\",\"authority\":\"9391804a-2fe7-462d-993a-dca6d8ee9de8\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e(c. a.d. 400). A major Indian philosopher, a master of the \u003cspan data-glossary-id=\\\"UT22084-060-005-603\\\"\u003eMādhyamika\u003c/span\u003e school of Buddhism, who founded a sub-school known as Svātantrika.\u003c/p\u003e\",\"names\":{\"english\":\"Bhāvaviveka\",\"tibetan\":\"ལེགས་ལྡན་འབྱེད།\",\"sanskrit\":\"bhāvaviveka\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"legs ldan ’byed\"}},{\"uuid\":\"700a47fd-7018-450b-b636-4ceaea2b8574\",\"authority\":\"3f54b15a-ac9f-4ecb-82cf-bce1c48f4a11\",\"definition\":\"\u003cp\u003eThe term \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003ebhikṣu\u003c/em\u003e, often translated as “monk,” refers to the highest among the eight types of prātimokṣa vows that make one part of the Buddhist assembly. The Sanskrit term literally means “beggar” or “mendicant,” referring to the fact that Buddhist monks and nuns‍—like other ascetics of the time‍—subsisted on alms (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003ebhikṣā\u003c/em\u003e) begged from the laity. \u003c/p\u003e\u003cp\u003eIn the Tibetan tradition, which follows the Mūlasarvāstivāda Vinaya, a monk follows 253 rules as part of his moral discipline. A nun (\u003cem class=\\\"foreign\\\"\u003ebhikṣuṇī\u003c/em\u003e; \u003cem class=\\\"foreign\\\"\u003edge slong ma\u003c/em\u003e) follows 364 rules. A novice monk (\u003cem class=\\\"foreign\\\"\u003eśrāmaṇera\u003c/em\u003e; \u003cem class=\\\"foreign\\\"\u003edge tshul\u003c/em\u003e) or nun (\u003cem class=\\\"foreign\\\"\u003eśrāmaṇerikā\u003c/em\u003e; \u003cem class=\\\"foreign\\\"\u003edge tshul ma\u003c/em\u003e) follows thirty-six rules of moral discipline (although in other vinaya traditions novices typically follow only ten).\u003c/p\u003e\",\"names\":{\"english\":\"bhikṣu\",\"tibetan\":\"དགེ་སློང་།\",\"sanskrit\":\"bhikṣu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dge slong\"}},{\"uuid\":\"b5e7eaef-2698-4621-9922-144a0ad94264\",\"authority\":\"37ee8261-363c-4e10-b7f6-97e58067bd03\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eLit. “three-thousand-great-thousand-world realm.” Each of these is composed of one thousand realms, each of which contains one thousand realms, each of which contains one thousand realms = one thousand to the third power = one billion worlds.\u003c/p\u003e\",\"names\":{\"english\":\"billion-world galaxy, galaxy\",\"tibetan\":\"སྟོང་གསུམ་གྱི་སྟོང་ཆེན་པོའི་འཇིག་རྟེན་གྱི་ཁམས།\",\"sanskrit\":\"trisāhasra­mahā­sāhasra­loka­dhātu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"stong gsum gyi stong chen po’i ’jig rten gyi khams\"}},{\"uuid\":\"4031b212-ede8-469d-abc0-058f224db7a7\",\"authority\":\"f5d55d82-9151-44eb-bdf0-ad2bb2951dbd\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThis refers to the \u003cspan data-glossary-id=\\\"UT22084-060-005-683\\\"\u003eultimate\u003c/span\u003e nature of reality, to the fact that, ultimately, nothing has ever been produced or born nor will it ever be because birth and production can occur only on the relative, or superficial, level. Hence “\u003cspan class=\\\"ignore\\\"\u003ebirthlessness\u003c/span\u003e” is a synonym of “\u003cspan data-glossary-id=\\\"UT22084-060-005-689\\\"\u003evoidness\u003c/span\u003e,” “reality,” “absolute,” “\u003cspan data-glossary-id=\\\"UT22084-060-005-683\\\"\u003eultimate\u003c/span\u003e,” “infinity,” etc.\u003c/p\u003e\",\"names\":{\"english\":\"birthlessness\",\"tibetan\":\"མི་སྐྱེ་བ།\",\"sanskrit\":\"anutpādatva\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mi skye ba\"}},{\"uuid\":\"c72eb4f3-700e-454d-996e-5ccdba29e6be\",\"authority\":\"0254f753-e084-4cdc-9ac3-184aaad94610\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA living being who has produced the \u003cspan data-glossary-id=\\\"UT22084-060-005-659\\\"\u003espirit of enlightenment\u003c/span\u003e in himself and whose constant \u003cspan data-glossary-id=\\\"UT22084-060-005-531\\\"\u003ededication\u003c/span\u003e, lifetime after lifetime, is to attain the unexcelled, perfect \u003cspan data-glossary-id=\\\"UT22084-060-005-551\\\"\u003eenlightenment\u003c/span\u003e of Buddhahood.\u003c/p\u003e\",\"names\":{\"english\":\"bodhisattva\",\"tibetan\":\"བྱང་ཆུབ་སེམས་དཔའ།\",\"sanskrit\":\"bodhisattva\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"byang chub sems dpa’\"}},{\"uuid\":\"112b506f-d873-4d8a-8ec5-bee73fb350d5\",\"authority\":\"6e5dc81d-3c8a-493e-9a77-987aa0ef3895\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAlso translated “\u003cspan data-glossary-id=\\\"UT22084-060-005-683\\\"\u003eultimate\u003c/span\u003e body.”\u003c/p\u003e\",\"names\":{\"english\":\"body of Dharma\",\"tibetan\":\"ཆོས་ཀྱི་སྐུ།\",\"sanskrit\":\"dharmakāya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chos kyi sku\"}},{\"uuid\":\"dec71e18-7976-488d-9b81-73734580c4be\",\"authority\":\"db36127a-581c-4efe-9ebf-172706c136f8\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eCreator-\u003cspan class=\\\"ignore\\\"\u003elord\u003c/span\u003e of a universe, there being as many as there are universes, whose number is incalculable. Hence, in Buddhist belief, a title of a deity who has attained supremacy in a particular universe, rather than a personal name. For example, the \u003cspan class=\\\"ignore\\\"\u003eBrahmā\u003c/span\u003e of the \u003cspan data-glossary-id=\\\"UT22084-060-005-827\\\"\u003eAśoka\u003c/span\u003e universe is personally called \u003cspan data-glossary-id=\\\"UT22084-060-005-805\\\"\u003eŚikhin\u003c/span\u003e, to distinguish him from other \u003cspan class=\\\"ignore\\\"\u003eBrahmās\u003c/span\u003e. A \u003cspan class=\\\"ignore\\\"\u003eBrahmā\u003c/span\u003e resides at the summit of the \u003cspan data-glossary-id=\\\"UT22084-060-005-638\\\"\u003erealm of pure matter\u003c/span\u003e (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003erūpadhātu\u003c/em\u003e), and is thus higher in status than a \u003cspan data-glossary-id=\\\"UT22084-060-005-792\\\"\u003eŚakra\u003c/span\u003e. \u003c/p\u003e\",\"names\":{\"english\":\"Brahmā\",\"tibetan\":\"ཚངས་པ།\",\"sanskrit\":\"brahmā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"tshangs pa\"}},{\"uuid\":\"05c2f937-6192-471c-8d02-d3ab3b65f9b9\",\"authority\":\"13a4865e-ca9b-4b94-9d36-feeceb44096f\",\"definition\":\"\",\"names\":{\"english\":\"Brahmajāla\",\"tibetan\":\"ཚངས་པའི་དྲ་བ།\",\"sanskrit\":\"brahmajāla\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"tshangs pa’i dra ba\"}},{\"uuid\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"authority\":\"41b299ff-7692-40b4-bbb3-b6a64c9ffb73\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eLit. “awakened one.” Title of one who has attained the highest attainment possible for a living being. “The \u003cspan class=\\\"ignore\\\"\u003eBuddha\u003c/span\u003e” often designates \u003cspan data-glossary-id=\\\"UT22084-060-005-794\\\"\u003eŚākyamuni\u003c/span\u003e because he is the \u003cspan class=\\\"ignore\\\"\u003ebuddha\u003c/span\u003e mainly in charge of the \u003cspan data-glossary-id=\\\"UT22084-060-005-516\\\"\u003ebuddhafield\u003c/span\u003e of our \u003cspan data-glossary-id=\\\"UT22084-060-005-841\\\"\u003eSahā\u003c/span\u003e universe.\u003c/p\u003e\",\"names\":{\"english\":\"buddha\",\"tibetan\":\"སངས་རྒྱས།\",\"sanskrit\":\"buddha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sangs rgyas\"}},{\"uuid\":\"ed4d199e-c981-4efb-aad2-ce056fa1ca12\",\"authority\":\"8ec19746-24c5-4290-a05b-52b8408c2c37\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAncient name for the town in Bihar province, where the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e attained his highest \u003cspan data-glossary-id=\\\"UT22084-060-005-551\\\"\u003eenlightenment\u003c/span\u003e under the Bodhi-tree. Modern name, Bodhgaya.\u003c/p\u003e\",\"names\":{\"english\":\"Buddha Gaya\",\"tibetan\":\"\",\"sanskrit\":\"buddha gaya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"\"}},{\"uuid\":\"1e5e85e8-4767-46b1-874e-5f1396a67ee6\",\"authority\":\"2c0dbcf3-d460-4854-913c-ead660673eea\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eRoughly, a synonym for “universe,” although Buddhist cosmology contains many universes of different types and dimensions. “\u003cspan class=\\\"ignore\\\"\u003eBuddhafield\u003c/span\u003e” indicates, in regard to whatever type of world-sphere, that it is the field of influence of a particular \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e. For a detailed discussion of these concepts, see Lamotte, Appendice, Note I.\u003c/p\u003e\",\"names\":{\"english\":\"buddhafield\",\"tibetan\":\"སངས་རྒྱས་ཀྱི་ཞིང་།\",\"sanskrit\":\"buddhakṣetra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sangs rgyas kyi zhing\"}},{\"uuid\":\"cfcbf167-1d29-491e-a45c-50dc1ab792ec\",\"authority\":\"bd9892e4-ba03-4282-aeda-1a8d52719e12\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e(c. fourth century). A great \u003cspan data-glossary-id=\\\"UT22084-060-005-603\\\"\u003eMādhyamika\u003c/span\u003e master, who was later regarded as the founder of the \u003cspan data-glossary-id=\\\"UT22084-060-005-634\\\"\u003ePrāsaṅgika\u003c/span\u003e sub-school.\u003c/p\u003e\",\"names\":{\"english\":\"Buddhapālita\",\"tibetan\":\"སངས་རྒྱས་བསྐྱང་།\",\"sanskrit\":\"buddhapālita\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sangs rgyas bskyang\"}},{\"uuid\":\"c26f5079-af67-4548-b824-6f8d81f9dbb7\",\"authority\":\"3ca8ccba-8bc5-46c5-922f-b56bccfe7452\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee \u003cspan data-glossary-id=\\\"UT22084-060-005-850\\\"\u003eAvataṃsaka\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Buddhāvataṃsaka\",\"tibetan\":\"སངས་རྒྱས་ཕལ་པོ་ཆེ།\",\"sanskrit\":\"buddhāvataṃsaka\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sangs rgyas phal po che\"}},{\"uuid\":\"7c4012a3-9741-43c6-8bcc-3e5bf7439e6f\",\"authority\":\"5349bf73-7ea5-48da-a21b-ee83ceeb976a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA mountain in this \u003cspan data-glossary-id=\\\"UT22084-060-005-670\\\"\u003esūtra\u003c/span\u003e and many others; but, in systematized Buddhist cosmology, the name of the ring of mountains that surrounds the world.\u003c/p\u003e\",\"names\":{\"english\":\"Cakravāḍa\",\"tibetan\":\"ཁོར་ཡུག\",\"sanskrit\":\"cakravāḍa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"khor yug\"}},{\"uuid\":\"e221b979-e0ff-4bd4-a72c-89cad1a3699e\",\"authority\":\"43aacedb-ed86-41ce-b2a5-9cfd56e215d5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e(1) Chief of the \u003cspan data-glossary-id=\\\"UT22084-060-005-599\\\"\u003eLicchavi\u003c/span\u003e. (2) Son of the king \u003cspan data-glossary-id=\\\"UT22084-060-005-776\\\"\u003eRatnacchattra\u003c/span\u003e, mentioned in the former-\u003cspan class=\\\"ignore\\\"\u003elife\u003c/span\u003e story told by the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e to \u003cspan data-glossary-id=\\\"UT22084-060-005-792\\\"\u003eŚakra\u003c/span\u003e in Chapter 12.\u003c/p\u003e\",\"names\":{\"english\":\"Candracchattra\",\"tibetan\":\"ཟླ་གདུགས།\",\"sanskrit\":\"candracchattra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"zla gdugs\"}},{\"uuid\":\"42824ff1-0d92-401f-b331-ea16963f07b4\",\"authority\":\"e1f36927-38ea-4f46-acd8-263a89c0c1f6\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e(c. sixth century). The most important \u003cspan data-glossary-id=\\\"UT22084-060-005-603\\\"\u003eMādhyamika\u003c/span\u003e philosopher after \u003cspan data-glossary-id=\\\"UT22084-060-005-753\\\"\u003eNāgārjuna\u003c/span\u003e and \u003cspan data-glossary-id=\\\"UT22084-060-005-704\\\"\u003eĀryadeva\u003c/span\u003e, he refined the philosophical methods of the school to such a degree that later members of the tradition considered him one of the highest authorities on the subject of the profound nature of reality.\u003c/p\u003e\",\"names\":{\"english\":\"Candrakīrti\",\"tibetan\":\"ཟླ་བ་གྲགས་པ།\",\"sanskrit\":\"candrakīrti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"zla ba grags pa\"}},{\"uuid\":\"42fd6f14-c233-4682-a011-443faf537523\",\"authority\":\"d0c363c5-354e-416b-a457-e51f9c0ffe33\",\"definition\":\"$54\",\"names\":{\"english\":\"canon of the bodhisattvas\",\"tibetan\":\"བྱང་ཆུབ་སེམས་དཔའི་སྡེ་སྣོད།\",\"sanskrit\":\"bodhi­sattva­piṭaka\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"byang chub sems dpa’i sde snod\"}},{\"uuid\":\"2c99efa2-82ea-426e-8c67-105bb43e05b5\",\"authority\":\"1ade37e9-3ec6-43b4-9ff8-67935af5350e\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe third \u003cspan data-glossary-id=\\\"UT22084-060-005-505\\\"\u003eNoble\u003c/span\u003e Truth, equivalent to \u003cspan data-glossary-id=\\\"UT22084-060-005-621\\\"\u003enirvāṇa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"cessation\",\"tibetan\":\"འགོག་པ།\",\"sanskrit\":\"nirodha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’gog pa\"}},{\"uuid\":\"a289b9ae-5d56-46bd-9a95-0227c18b3226\",\"authority\":\"058bfc0a-5de5-4d9a-b65a-b573ec215a6d\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eChinese word for \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003edhyāna\u003c/em\u003e, which was adopted as the name of the school of \u003cspan data-glossary-id=\\\"UT22084-060-005-605\\\"\u003eMahāyāna\u003c/span\u003e practice founded by Bodhidharma, and later to become famous in the west as Zen.\u003c/p\u003e\",\"names\":{\"english\":\"Ch’an\",\"tibetan\":\"\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"\"}},{\"uuid\":\"34f0e6a4-28b4-49d9-ae71-234c4fa63529\",\"authority\":\"9b50a946-139b-491d-8fbc-8b2ea2bfbbaf\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eTibetan translator of this \u003cspan data-glossary-id=\\\"UT22084-060-005-670\\\"\u003esūtra\u003c/span\u003e in the ninth century, also well known for his collaboration in compiling the \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eMahāvyutpatti\u003c/cite\u003e (Skt.-Tib. dictionary). \u003c/p\u003e\",\"names\":{\"english\":\"Chönyi Tsültrim\",\"tibetan\":\"ཆོས་ཉིད་ཚུལ་ཁྲིམས།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chos nyid tshul khrims\"}},{\"uuid\":\"2eb83d5b-bb6f-440e-afdb-f8f67ee62aec\",\"authority\":\"6042da3b-420b-4b11-9f03-cf721f544dcf\",\"definition\":\"$55\",\"names\":{\"english\":\"conceive the spirit of enlightenment, conceiving the spirit of enlightenment, conception of the spirit of enlightenment\",\"tibetan\":\"བྱང་ཆུབ་ཀྱི་སེམས་བསྐྱེད་པ།\",\"sanskrit\":\"bodhi­cittotpāda\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"byang chub kyi sems bskyed pa\"}},{\"uuid\":\"7c9b18c2-de43-42af-9b86-2cadc11acbf8\",\"authority\":\"1f935435-8218-4738-a453-aac30854a2a5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee “\u003cspan data-glossary-id=\\\"UT22084-060-005-500\\\"\u003eabsorption\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"concentration, samādhi\",\"tibetan\":\"ཏིང་ངེ་འཛིན།, ཏིང་ངེ་འཛིན།\",\"sanskrit\":\"samādhi, samādhi\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ting nge ’dzin, ting nge ’dzin\"}},{\"uuid\":\"12140d8a-6833-4267-9463-c0922ba5a70b\",\"authority\":\"1f935435-8218-4738-a453-aac30854a2a5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-060-005-521\\\"\u003eConcentration\u003c/span\u003e of total mental equanimity which is such a powerful mental state it can be turned to accomplish amazing results.\u003c/p\u003e\",\"names\":{\"english\":\"concentration, samādhi\",\"tibetan\":\"ཏིང་ངེ་འཛིན།, ཏིང་ངེ་འཛིན།\",\"sanskrit\":\"samādhi, samādhi\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ting nge ’dzin, ting nge ’dzin\"}},{\"uuid\":\"9f1b9148-fd02-40f8-963c-c5aee1733bf6\",\"authority\":\"0c814657-de47-4ed1-980f-dfa4b965316e\",\"definition\":\"$56\",\"names\":{\"english\":\"conceptualization\",\"tibetan\":\"རྣམ་པར་རྟོག་པ།\",\"sanskrit\":\"vikalpa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rnam par rtog pa\"}},{\"uuid\":\"6d362ce6-8cff-4711-b6b4-f076e4737512\",\"authority\":\"23ebacd9-793c-491e-bb2e-097e5a2e47cc\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThis denotes a type of awareness of the most seemingly insignificant aspects of practical \u003cspan class=\\\"ignore\\\"\u003elife\u003c/span\u003e, an awareness derived as a consequence of the highest realization of the \u003cspan data-glossary-id=\\\"UT22084-060-005-683\\\"\u003eultimate\u003c/span\u003e nature of reality. As it is stated in the \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eAnavatapta­nāga­rāja­paripṛcchā­sūtra\u003c/cite\u003e (Toh 156), \u003ca href=\\\"https://read.84000.co/translation/toh156#UT22084-058-005-308\\\" target=\\\"UT22084-058-005.html\\\" data-pointer-type=\\\"id\\\"\u003e1.191\u003c/a\u003e: “He who realizes \u003cspan data-glossary-id=\\\"UT22084-060-005-689\\\"\u003evoidness\u003c/span\u003e, that person is consciously aware.” “\u003cspan data-glossary-id=\\\"UT22084-060-005-683\\\"\u003eUltimate\u003c/span\u003e realization,” far from obliterating the relative world, brings it into highly specific, albeit dreamlike, focus. \u003c/p\u003e\",\"names\":{\"english\":\"conscious awareness\",\"tibetan\":\"བག་ཡོད་པ།\",\"sanskrit\":\"apramāda\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bag yod pa\"}},{\"uuid\":\"a8081b29-fd2e-425a-b8a0-900b375ccea0\",\"authority\":\"d9e22f6a-0e6c-4cf5-a56f-5a3663b97238\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee “\u003cspan data-glossary-id=\\\"UT22084-060-005-502\\\"\u003eaggregate\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"consciousness\",\"tibetan\":\"རྣམ་ཤེས།\",\"sanskrit\":\"vijñāna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rnam shes\"}},{\"uuid\":\"cec4c4b6-fd31-476f-b413-c84faa28d822\",\"authority\":\"72b9bc1c-896f-4242-998d-15fd6a7a4b90\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee “\u003cspan data-glossary-id=\\\"UT22084-060-005-500\\\"\u003eabsorption\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"contemplation\",\"tibetan\":\"བསམ་གཏན།\",\"sanskrit\":\"dhyāna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bsam gtan\"}},{\"uuid\":\"802e1a5b-857b-432f-9274-35d3d2d8dbad\",\"authority\":\"f2162e87-1f19-4cb8-862d-7038b0ee7073\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe ancient cosmology maintained that the cosmos was encircled by an atmosphere of fierce winds of impenetrable intensity (see Lamotte, p. 255, n. 15).\u003c/p\u003e\",\"names\":{\"english\":\"cosmic wind-atmosphere\",\"tibetan\":\"རླུང་གི་དཀྱིལ་འཁོར།\",\"sanskrit\":\"vātamaṇḍalī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rlung gi dkyil ’khor\"}},{\"uuid\":\"500d0357-2bbe-4021-8b1b-35ac7932e50c\",\"authority\":\"c7fbd9bb-04ef-4498-8494-e5e13c6926f5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAnalytic \u003cspan data-glossary-id=\\\"UT22084-060-005-521\\\"\u003econcentration\u003c/span\u003e that gains insight into the nature of reality, synonymous with “\u003cspan data-glossary-id=\\\"UT22084-060-005-680\\\"\u003etranscendental analysis\u003c/span\u003e,” \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003evipaśyana\u003c/em\u003e (q.v.). \u003c/p\u003e\",\"names\":{\"english\":\"decisiveness\",\"tibetan\":\"ངེས་པར་སེམས་པ།\",\"sanskrit\":\"nidhyapti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nges par sems pa\"}},{\"uuid\":\"cc21647f-dc89-4cb3-b927-6cf2286d5f85\",\"authority\":\"af25965a-d479-4c7c-93d9-c7ca052e9cf8\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThis refers to the \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattva\u003c/span\u003e’s constant mindfulness of the fact that all his actions of whatever form contribute to his purpose of attaining \u003cspan data-glossary-id=\\\"UT22084-060-005-551\\\"\u003eenlightenment\u003c/span\u003e for the sake of himself and others, i.e., his conscious deferral of the merit accruing from any virtuous action as he eschews immediate reward in favor of \u003cspan data-glossary-id=\\\"UT22084-060-005-683\\\"\u003eultimate\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-060-005-551\\\"\u003eenlightenment\u003c/span\u003e for himself and all living beings.\u003c/p\u003e\",\"names\":{\"english\":\"dedication\",\"tibetan\":\"ཡོངས་སུ་བསྔོ་བ།\",\"sanskrit\":\"pariṇāmana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yongs su bsngo ba\"}},{\"uuid\":\"635916eb-923d-4aff-a4c7-9f4516721120\",\"authority\":\"d2218fd1-f9b6-4b89-ac32-e7ec36d8f877\",\"definition\":\"$57\",\"names\":{\"english\":\"definitive meaning\",\"tibetan\":\"ངེས་དོན།\",\"sanskrit\":\"nītārtha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nges don\"}},{\"uuid\":\"28a2831b-8ff3-473b-9ee3-6a0d997ccff0\",\"authority\":\"7c76567b-2f1b-4a24-a261-ff3975b05630\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee also “\u003cspan data-glossary-id=\\\"UT22084-060-005-640\\\"\u003erelativity\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"dependent origination, relativity\",\"tibetan\":\"རྟེན་ཅིང་འབྲེལ་བར་འབྱུང་བ།, རྟེན་ཅིང་འབྲེལ་བར་འབྱུང་བ།\",\"sanskrit\":\"pratītya­samutpāda, pratītya­samutpāda\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rten cing ’brel bar ’byung ba, rten cing ’brel bar ’byung ba\"}},{\"uuid\":\"a53cd052-8393-4f2f-b18f-df2aff5c0cdb\",\"authority\":\"7c76567b-2f1b-4a24-a261-ff3975b05630\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eIn most contexts, this term is properly translated by “\u003cspan data-glossary-id=\\\"UT22084-060-005-533\\\"\u003edependent origination\u003c/span\u003e.” But in the \u003cspan data-glossary-id=\\\"UT22084-060-005-603\\\"\u003eMādhyamika\u003c/span\u003e context, wherein the concept of the \u003cspan data-glossary-id=\\\"UT22084-060-005-683\\\"\u003eultimate\u003c/span\u003e nonorigination of all things is emphasized, “\u003cspan class=\\\"ignore\\\"\u003erelativity\u003c/span\u003e” better serves to convey the message that things exist only in relation to verbal designation and that nothing exists as an independent, \u003cspan class=\\\"ignore\\\"\u003eself\u003c/span\u003e-sufficient entity, even on the superficial level.\u003c/p\u003e\",\"names\":{\"english\":\"dependent origination, relativity\",\"tibetan\":\"རྟེན་ཅིང་འབྲེལ་བར་འབྱུང་བ།, རྟེན་ཅིང་འབྲེལ་བར་འབྱུང་བ།\",\"sanskrit\":\"pratītya­samutpāda, pratītya­samutpāda\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rten cing ’brel bar ’byung ba, rten cing ’brel bar ’byung ba\"}},{\"uuid\":\"4c9b50c9-505f-449a-b81d-0b5514591f15\",\"authority\":\"642d9569-90e5-40bb-ab55-d18c192fdfdd\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThis generally describes one who has reached the \u003cspan data-glossary-id=\\\"UT22084-060-005-505\\\"\u003enoble\u003c/span\u003e path, either in \u003cspan data-glossary-id=\\\"UT22084-060-005-662\\\"\u003eDisciple Vehicle\u003c/span\u003e or \u003cspan data-glossary-id=\\\"UT22084-060-005-605\\\"\u003eMahāyāna\u003c/span\u003e practice (see Lamotte, p. 115, n. 65).\u003c/p\u003e\",\"names\":{\"english\":\"destined for the ultimate\",\"tibetan\":\"ཡང་དག་པ་ཉིད་དུ་ངེས་པ།\",\"sanskrit\":\"samyaktvaniyata\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yang dag pa nyid du nges pa\"}},{\"uuid\":\"0fe01594-05ae-4d26-819d-47640d08397f\",\"authority\":\"5bd2f1c6-a3a4-455f-bf43-b860fed990b3\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThis is the stage attained by followers of the Hinayāna wherein they become determined for the attainment of \u003cspan data-glossary-id=\\\"UT22084-060-005-597\\\"\u003eliberation\u003c/span\u003e (\u003cspan data-glossary-id=\\\"UT22084-060-005-621\\\"\u003enirvāṇa\u003c/span\u003e, i.e., the \u003cspan data-glossary-id=\\\"UT22084-060-005-683\\\"\u003eultimate\u003c/span\u003e for them) in such a way as never to regress from their goals, and by \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattvas\u003c/span\u003e when they attain the holy path of insight. \u003c/p\u003e\",\"names\":{\"english\":\"destiny for the ultimate\",\"tibetan\":\"ངེས་པ་ལ་ཞུགས་པ།\",\"sanskrit\":\"niyāmāvakrānti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nges pa la zhugs pa\"}},{\"uuid\":\"5da0fca1-89b3-47cd-a4ec-fa7a4448696b\",\"authority\":\"87f6ed5d-68a9-4ddd-8744-81855f2d8943\",\"definition\":\"$58\",\"names\":{\"english\":\"deva\",\"tibetan\":\"ལྷ།\",\"sanskrit\":\"deva\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lha\"}},{\"uuid\":\"85e85193-24fb-4662-8b13-fda9ad0d4dbc\",\"authority\":\"8a98425c-f46d-4256-a3ea-5bbd3c82a79f\",\"definition\":\"\",\"names\":{\"english\":\"Devarāja\",\"tibetan\":\"ལྷའི་རྒྱལ་པོ།\",\"sanskrit\":\"devarāja\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lha’i rgyal po\"}},{\"uuid\":\"c08db6f5-393e-4ec4-bf72-4043e53b3129\",\"authority\":\"0a290d1b-bdbb-4cb8-9531-014e904c0894\",\"definition\":\"\u003cp\u003eThe term \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003edharma\u003c/em\u003e conveys ten different meanings, according to Vasubandhu’s \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eVyākhyā­yukti\u003c/cite\u003e. The primary meanings are as follows: the doctrine taught by the Buddha (Dharma); the ultimate reality underlying and expressed through the Buddha’s teaching (Dharma); the trainings that the Buddha’s teaching stipulates (dharmas); the various awakened qualities or attainments acquired through practicing and realizing the Buddha’s teaching (dharmas); qualities or aspects more generally, i.e., phenomena or phenomenal attributes (dharmas); and mental objects (dharmas).\u003c/p\u003e\",\"names\":{\"english\":\"Dharma\",\"tibetan\":\"ཆོས།\",\"sanskrit\":\"dharma\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chos\"}},{\"uuid\":\"79458ac8-a28e-44a0-88fa-1f9d3ee8f5df\",\"authority\":\"9e55f43b-726e-4415-b7c5-67d6da6eb945\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eCertain teachings are called “\u003cspan class=\\\"ignore\\\"\u003eDharma-doors\u003c/span\u003e” (or “\u003cspan data-glossary-id=\\\"UT22084-060-005-541\\\"\u003edoors of the Dharma\u003c/span\u003e”), as they provide access to the practice of the \u003cspan data-glossary-id=\\\"UT22084-060-005-537\\\"\u003eDharma\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Dharma-door, door of the Dharma, doors of the Dharma\",\"tibetan\":\"ཆོས་ཀྱི་སྒོ།, ཆོས་ཀྱི་སྒོ།\",\"sanskrit\":\"dharmamukha, dharmamukha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chos kyi sgo, chos kyi sgo\"}},{\"uuid\":\"5deb39e7-587e-4930-9b0d-5bcc72f42248\",\"authority\":\"9e55f43b-726e-4415-b7c5-67d6da6eb945\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee “\u003cspan data-glossary-id=\\\"UT22084-060-005-538\\\"\u003eDharma-door\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"Dharma-door, door of the Dharma, doors of the Dharma\",\"tibetan\":\"ཆོས་ཀྱི་སྒོ།, ཆོས་ཀྱི་སྒོ།\",\"sanskrit\":\"dharmamukha, dharmamukha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chos kyi sgo, chos kyi sgo\"}},{\"uuid\":\"e6878b41-c299-40f7-bdcf-2a354e33818a\",\"authority\":\"9472ffa8-5618-433a-99af-2eea011a6303\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the “five eyes,” representing superior insights of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003ebuddhas\u003c/span\u003e and \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattvas\u003c/span\u003e. The five eyes consist of five different faculties of vision: the physical eye (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003emāṃsa­cakṣu\u003c/em\u003e), the \u003cspan data-glossary-id=\\\"UT22084-060-005-540\\\"\u003edivine eye\u003c/span\u003e (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003edīvya­cakṣu\u003c/em\u003e), the \u003cspan data-glossary-id=\\\"UT22084-060-005-691\\\"\u003ewisdom\u003c/span\u003e eye (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eprajñā­cakṣu\u003c/em\u003e), the \u003cspan class=\\\"ignore\\\"\u003eDharma-eye\u003c/span\u003e (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003edharma­cakṣu\u003c/em\u003e), and the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e-eye (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003ebuddha­cakṣu\u003c/em\u003e).\u003c/p\u003e\",\"names\":{\"english\":\"Dharma-eye\",\"tibetan\":\"ཆོས་ཀྱི་མིག\",\"sanskrit\":\"dharmacakṣu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chos kyi mig\"}},{\"uuid\":\"c6774227-0962-4900-913a-671acc2c4c89\",\"authority\":\"d0231c60-ec46-4a93-8f99-9c004aa1f690\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattva\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Dharmaketu\",\"tibetan\":\"ཆོས་ཀྱི་ཏོག\",\"sanskrit\":\"dharmaketu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chos kyi tog\"}},{\"uuid\":\"472fcc2b-059e-4329-8799-3ace4d2cf0c7\",\"authority\":\"5384c396-cb73-4667-8b13-1953c7171ce1\",\"definition\":\"\",\"names\":{\"english\":\"Dharmeśvara\",\"tibetan\":\"ཆོས་ཀྱི་དབང་ཕྱུག\",\"sanskrit\":\"dharmeśvara\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chos kyi dbang phyug\"}},{\"uuid\":\"cc35d4b8-9151-485e-9199-cf5d9d646538\",\"authority\":\"e6df66ae-c114-4c40-8ef3-59f530380449\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe vehicle comprising the teaching of the \u003cspan data-glossary-id=\\\"UT22084-060-005-661\\\"\u003eśrāvakas\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Disciple Vehicle, Śrāvakayāna\",\"tibetan\":\"ཉན་ཐོས་ཀྱི་ཐེག་པ།\",\"sanskrit\":\"śrāvakayāna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nyan thos kyi theg pa\"}},{\"uuid\":\"75a91ffb-ff79-483c-bf2e-bc68d02dc1e6\",\"authority\":\"44490675-4065-4ace-9b94-f55b99d78a11\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the six “\u003cspan data-glossary-id=\\\"UT22084-060-005-669\\\"\u003esuperknowledges\u003c/span\u003e” (q.v.) as well as one of the “five eyes,” this is the supernormal ability to see to an unlimited distance, observe events on other worlds, see through mountains, etc. The five eyes consist of five different faculties of vision: the physical eye (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003emāṃsa­cakṣu\u003c/em\u003e), the \u003cspan class=\\\"ignore\\\"\u003edivine eye\u003c/span\u003e (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003edīvya­cakṣu\u003c/em\u003e), the \u003cspan data-glossary-id=\\\"UT22084-060-005-691\\\"\u003ewisdom\u003c/span\u003e eye (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eprajñā­cakṣu\u003c/em\u003e), the \u003cspan data-glossary-id=\\\"UT22084-060-005-539\\\"\u003eDharma-eye\u003c/span\u003e (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003edharma­cakṣu\u003c/em\u003e), and the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e-eye (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003ebuddha­cakṣu\u003c/em\u003e).\u003c/p\u003e\",\"names\":{\"english\":\"divine eye\",\"tibetan\":\"ལྷའི་མིག\",\"sanskrit\":\"divyacakṣu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lha’i mig\"}},{\"uuid\":\"a4956bd4-d143-4797-a25e-72aa2fc5d7ba\",\"authority\":\"9543abfb-5763-41d0-8ef8-bafd54c83dd2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e of the universe \u003cspan data-glossary-id=\\\"UT22084-060-005-837\\\"\u003eMarīci\u003c/span\u003e, located sixty-one universes away; mentioned also in other \u003cspan data-glossary-id=\\\"UT22084-060-005-605\\\"\u003eMahāyāna\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-060-005-670\\\"\u003esūtras\u003c/span\u003e, with the interesting coincidence that his teaching ceased at the moment \u003cspan data-glossary-id=\\\"UT22084-060-005-794\\\"\u003eŚākyamuni\u003c/span\u003e began teaching at Benares.\u003c/p\u003e\",\"names\":{\"english\":\"Duḥprasāha\",\"tibetan\":\"བཟོད་དཀའ།\",\"sanskrit\":\"duḥprasāha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bzod dka’\"}},{\"uuid\":\"e5d4433d-1e7d-4687-816e-334e3b4acd52\",\"authority\":\"62043aa4-c0d8-4cf1-8628-8c0fc29c5004\",\"definition\":\"$59\",\"names\":{\"english\":\"egoistic views\",\"tibetan\":\"འཇིག་ཚོགས་ལ་ལྟ་བ།\",\"sanskrit\":\"satkāyadṛṣṭi\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’jig tshogs la lta ba\"}},{\"uuid\":\"dbddf014-9e12-4bcf-a5de-608dd7b43c2c\",\"authority\":\"fee65798-f1d9-4da1-80cc-583748d79580\",\"definition\":\"$5a\",\"names\":{\"english\":\"eight liberations\",\"tibetan\":\"རྣམ་པར་ཐར་པ་བརྒྱད།\",\"sanskrit\":\"vimokṣa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rnam par thar pa brgyad\"}},{\"uuid\":\"e2e43e4a-7d5b-42ef-b212-1c512b123c6b\",\"authority\":\"6ad1090e-4daf-44e5-9a4b-28e1270a13f0\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThese consist of the exact opposites of the eight branches of the \u003cspan data-glossary-id=\\\"UT22084-060-005-547\\\"\u003eeightfold noble path\u003c/span\u003e (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eaṣṭāṅgikamārga\u003c/em\u003e). \u003c/p\u003e\",\"names\":{\"english\":\"eight perverse paths\",\"tibetan\":\"ལོག་པ་ཉིད་བརྒྱད།, ལོག་པ་བརྒྱད།\",\"sanskrit\":\"mithyātva\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"log pa brgyad, log pa nyid brgyad\"}},{\"uuid\":\"d0777c21-0a65-482f-99e1-8c59e27cb1f7\",\"authority\":\"a58116f1-5d03-4a0d-9894-c93a26b08b0a\",\"definition\":\"$5b\",\"names\":{\"english\":\"eighteen special qualities of a bodhisattva\",\"tibetan\":\"བྱང་ཆུབ་སེམས་དཔའི་ཆོས་མ་འདྲེས་པ་བཅོ་བརྒྱད།\",\"sanskrit\":\"aṣṭā­daśāveṇika­bodhi­sattva­dharma\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"byang chub sems dpa’i chos ma ’dres pa bco brgyad\"}},{\"uuid\":\"22d552c8-644d-4406-b1ba-f2d731fff0c3\",\"authority\":\"37a52b45-6ddb-41ac-ac30-a68bac9c0fab\",\"definition\":\"$5c\",\"names\":{\"english\":\"eighteen special qualities of the Buddha\",\"tibetan\":\"སངས་རྒྱས་ཀྱི་ཆོས་མ་འདྲེས་པ་བཅོ་བརྒྱད།\",\"sanskrit\":\"aṣṭā­daśāveṇika­buddha­dharma\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sangs rgyas kyi chos ma ’dres pa bco brgyad\"}},{\"uuid\":\"9ccf17fa-be73-442f-8de5-898a79eea2cf\",\"authority\":\"ccf427f1-a6cc-446b-91af-183c91173f91\",\"definition\":\"$5d\",\"names\":{\"english\":\"eightfold noble path\",\"tibetan\":\"འཕགས་པའི་ལམ་གྱི་ཡན་ལག་བརྒྱད།\",\"sanskrit\":\"āryāṣṭāṅga­mārga\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’phags pa’i lam gyi yan lag brgyad\"}},{\"uuid\":\"dbc4a2e4-dbc7-475b-8ed0-c63412da4b68\",\"authority\":\"e3685c95-a735-4cb3-a0e7-d0d5dc0b3295\",\"definition\":\"$5e\",\"names\":{\"english\":\"element\",\"tibetan\":\"ཁམས།, འབྱུང་བ་ཆེན་པོ།\",\"sanskrit\":\"dhātu, mahābhūta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"khams, ’byung ba chen po\"}},{\"uuid\":\"2894cd42-61c0-4809-b7f0-d6a6f5248637\",\"authority\":\"6e065713-5e0f-41dc-908b-5638ea658a48\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThis refers to the miraculous power of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e and \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattvas\u003c/span\u003e of a certain stage to emanate apparently living beings in order to develop and teach living beings. This power reaches its culmination in the \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003enirmāṇa­kayā\u003c/em\u003e, the “\u003cspan data-glossary-id=\\\"UT22084-060-005-582\\\"\u003eincarnation\u003c/span\u003e body,” which is one of the three bodies of buddhahood and includes all physical forms of all \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003ebuddhas\u003c/span\u003e, including \u003cspan data-glossary-id=\\\"UT22084-060-005-794\\\"\u003eŚākyamuni\u003c/span\u003e, whose sole function as \u003cspan data-glossary-id=\\\"UT22084-060-005-582\\\"\u003eincarnations\u003c/span\u003e is the development and \u003cspan data-glossary-id=\\\"UT22084-060-005-597\\\"\u003eliberation\u003c/span\u003e of living beings. \u003c/p\u003e\",\"names\":{\"english\":\"emanated incarnation, incarnation\",\"tibetan\":\"སྤྲུལ་པ།, སྤྲུལ་པ།\",\"sanskrit\":\"nirmāṇa, nirmāṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sprul pa, sprul pa\"}},{\"uuid\":\"b9472c5e-2a0d-4ba9-80dc-8f56944f1752\",\"authority\":\"6e065713-5e0f-41dc-908b-5638ea658a48\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee “\u003cspan data-glossary-id=\\\"UT22084-060-005-549\\\"\u003eemanated incarnation\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"emanated incarnation, incarnation\",\"tibetan\":\"སྤྲུལ་པ།, སྤྲུལ་པ།\",\"sanskrit\":\"nirmāṇa, nirmāṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sprul pa, sprul pa\"}},{\"uuid\":\"0e3b4cd3-64d5-4b41-a33a-86aa141f7277\",\"authority\":\"73d1ceda-eda2-4181-ad71-d9c09c063106\",\"definition\":\"$5f\",\"names\":{\"english\":\"emptiness, voidness, śūnyatā\",\"tibetan\":\"སྟོང་པ་ཉིད།, སྟོང་པ་ཉིད།, སྟོང་པ་ཉིད།\",\"sanskrit\":\"śūnyatā, śūnyatā, śūnyatā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"stong pa nyid, stong pa nyid, stong pa nyid\"}},{\"uuid\":\"1ede53af-8161-4358-9902-76ff3144ae49\",\"authority\":\"73d1ceda-eda2-4181-ad71-d9c09c063106\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-060-005-689\\\"\u003eVoidness\u003c/span\u003e, \u003cspan data-glossary-id=\\\"UT22084-060-005-550\\\"\u003eemptiness\u003c/span\u003e; specifically, the \u003cspan data-glossary-id=\\\"UT22084-060-005-550\\\"\u003eemptiness\u003c/span\u003e of absolute substance, truth, \u003cspan data-glossary-id=\\\"UT22084-060-005-579\\\"\u003eidentity\u003c/span\u003e, intrinsic reality, or \u003cspan data-glossary-id=\\\"UT22084-060-005-649\\\"\u003eself\u003c/span\u003e of all persons and things in the relative world, being quite opposed to any sort of absolute nothingness (see glossary, under “\u003cspan data-glossary-id=\\\"UT22084-060-005-550\\\"\u003eemptiness\u003c/span\u003e”).\u003c/p\u003e\",\"names\":{\"english\":\"emptiness, voidness, śūnyatā\",\"tibetan\":\"སྟོང་པ་ཉིད།, སྟོང་པ་ཉིད།, སྟོང་པ་ཉིད།\",\"sanskrit\":\"śūnyatā, śūnyatā, śūnyatā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"stong pa nyid, stong pa nyid, stong pa nyid\"}},{\"uuid\":\"e74ef65c-8fc8-4dbf-9bba-7326d6b5d34d\",\"authority\":\"73d1ceda-eda2-4181-ad71-d9c09c063106\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee “\u003cspan data-glossary-id=\\\"UT22084-060-005-550\\\"\u003eemptiness\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"emptiness, voidness, śūnyatā\",\"tibetan\":\"སྟོང་པ་ཉིད།, སྟོང་པ་ཉིད།, སྟོང་པ་ཉིད།\",\"sanskrit\":\"śūnyatā, śūnyatā, śūnyatā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"stong pa nyid, stong pa nyid, stong pa nyid\"}},{\"uuid\":\"62f923c5-8dfa-4620-8dec-7bb032231bf7\",\"authority\":\"56041e12-c29c-45ae-87d9-9db5682dc563\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThis word requires too much explanation for this glossary because, indeed, the whole \u003cspan data-glossary-id=\\\"UT22084-060-005-670\\\"\u003esūtra\u003c/span\u003e‍—and the whole of Buddhist literature‍—is explanatory of only this. Here we simply mention the translation equivalent.\u003c/p\u003e\",\"names\":{\"english\":\"enlightenment\",\"tibetan\":\"བྱང་ཆུབ།\",\"sanskrit\":\"bodhi\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"byang chub\"}},{\"uuid\":\"db2bd23e-00ed-4f18-9412-b132216e90b8\",\"authority\":\"59500d87-caef-443d-b4fd-96aa2bceb408\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe four are as follows: All compounded things are impermanent (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eanityāḥ sarva­saṃskārāḥ\u003c/em\u003e). All defiled things are suffering (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eduḥkhāh sarva­sāsravāḥ\u003c/em\u003e). All things are without \u003cspan data-glossary-id=\\\"UT22084-060-005-649\\\"\u003eself\u003c/span\u003e (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eanātmanāḥ sarva­dharmāḥ\u003c/em\u003e). \u003cspan data-glossary-id=\\\"UT22084-060-005-621\\\"\u003eNirvāṇa\u003c/span\u003e is peace (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eśāntaṃ nirvāṇaṃ\u003c/em\u003e). Also called “the \u003cspan class=\\\"ignore\\\"\u003efour insignia of the Dharma\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"epitomes of the Dharma, four epitomes, four epitomes of the Dharma, four insignia of the Dharma\",\"tibetan\":\"ཆོས་ཀྱི་ཕྱག་རྒྱ་བཞི།, བཀའ་རྟགས་ཀྱི་ཕྱག་རྒྱ་བཞི།\",\"sanskrit\":\"dharmoddāna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bka’ rtags kyi phyag rgya bzhi, chos kyi phyag rgya bzhi\"}},{\"uuid\":\"3d00be41-eb5a-4c3b-912f-ae0bfe367b16\",\"authority\":\"22bad529-e6a1-45e7-811a-1345329bd208\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eLit. “family” or “lineage of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e.” One becomes a member on the first \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattva\u003c/span\u003e stage. In another sense, all living beings belong to this exalted family because all have the capacity to wake up to \u003cspan data-glossary-id=\\\"UT22084-060-005-551\\\"\u003eenlightenment\u003c/span\u003e, conceiving its spirit within themselves and thenceforward seeking its realization (see \u003ca data-pointer-target=\\\"#chapter-7\\\" data-pointer-type=\\\"id\\\"\u003eChapter 7\u003c/a\u003e).\u003c/p\u003e\",\"names\":{\"english\":\"family of the Buddha\",\"tibetan\":\"སངས་རྒྱས་ཀྱི་རིགས།\",\"sanskrit\":\"buddhakula\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sangs rgyas kyi rigs\"}},{\"uuid\":\"e4e4b3ff-ee08-45e4-8dbf-92d67f110c14\",\"authority\":\"8dcd5e8f-935d-43ef-ac35-6fe4dc7f13e9\",\"definition\":\"$60\",\"names\":{\"english\":\"family of the tathāgatas, ‘family of the tathāgatas’\",\"tibetan\":\"དེ་བཞིན་གཤེགས་པའི་རིགས།\",\"sanskrit\":\"tathāgatagotra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"de bzhin gshegs pa’i rigs\"}},{\"uuid\":\"b8daff33-91de-4457-9d38-959adf13a079\",\"authority\":\"ec5082de-9d9b-4768-aae0-2ba0728cc37d\",\"definition\":\"$61\",\"names\":{\"english\":\"fearlessness, fearlessnesses\",\"tibetan\":\"མི་འཇིགས་པ།\",\"sanskrit\":\"vaiśāradya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mi ’jigs pa\"}},{\"uuid\":\"b0ed4425-d04a-4f93-95c0-8e4b57d5f2cf\",\"authority\":\"1a20df77-8fa9-4a91-86f7-68c768a784fb\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cspan class=\\\"ignore\\\"\u003eFemale attendants\u003c/span\u003e who normally assisted the wife of a wealthy householder.\u003c/p\u003e\",\"names\":{\"english\":\"female attendants\",\"tibetan\":\"སླས།\",\"sanskrit\":\"sahacāri\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"slas\"}},{\"uuid\":\"b3f27308-d8e9-4edd-b1de-2bb77c99ef3a\",\"authority\":\"e160e4b5-7694-4ac6-9a8d-a698f1b409e3\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eLit. “sins of immediate retribution [after death].” These five, all of which cause immediate rebirth in hell, are killing one’s father, killing one’s mother, killing an \u003cspan data-glossary-id=\\\"UT22084-060-005-504\\\"\u003earhat\u003c/span\u003e, breaking up the \u003cspan data-glossary-id=\\\"UT22084-060-005-646\\\"\u003esaṅgha\u003c/span\u003e, and causing, with evil intent, the \u003cspan data-glossary-id=\\\"UT22084-060-005-672\\\"\u003eTathāgata\u003c/span\u003e to bleed.\u003c/p\u003e\",\"names\":{\"english\":\"five deadly sins\",\"tibetan\":\"མཚམས་མེད་ལྔ།\",\"sanskrit\":\"ānantarya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mtshams med lnga\"}},{\"uuid\":\"aeb42ef6-d010-4ece-a211-3e3833694ff0\",\"authority\":\"83974342-771f-4e7d-93a3-c37b0766e512\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eVisibles, sound, scent, taste, and tangibles.\u003c/p\u003e\",\"names\":{\"english\":\"five desire objects\",\"tibetan\":\"འདོད་པའི་ཡོན་ཏན་ལྔ།\",\"sanskrit\":\"pañcakāmaguṇaḥ\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’dod pa’i yon tan lnga\"}},{\"uuid\":\"1d9e7927-3a63-4200-b1a4-996d9730efa2\",\"authority\":\"193a9c8a-3e79-46ec-9be2-00120d55f714\",\"definition\":\"\u003cp\u003eFive impediments to meditation (\u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ebsam gtan\u003c/em\u003e, \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003edhyāna\u003c/em\u003e): sensory desire (\u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003e’dod pa la ’dun pa\u003c/em\u003e, \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003ekāmacchanda\u003c/em\u003e), ill will (\u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003egnod sems\u003c/em\u003e, \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003evyāpāda\u003c/em\u003e), drowsiness and torpor (\u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ermugs pa dang gnyid\u003c/em\u003e, \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003estyānamiddha\u003c/em\u003e), agitation and regret (\u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ergod pa dang ’gyod pa\u003c/em\u003e, \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eauddhatya­kaukṛtya\u003c/em\u003e), and doubt (\u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ethe tshom\u003c/em\u003e, \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003evicikitsā\u003c/em\u003e).\u003c/p\u003e\",\"names\":{\"english\":\"five obscurations\",\"tibetan\":\"སྒྲིབ་པ་ལྔ།\",\"sanskrit\":\"nīvaraṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sgrib pa lnga\"}},{\"uuid\":\"b8fa8f2b-1b78-4cd1-b764-f677f3c421a2\",\"authority\":\"663c93aa-0b28-40da-9cb7-29526f18ddb8\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThese are the same as the \u003cspan data-glossary-id=\\\"UT22084-060-005-559\\\"\u003efive spiritual faculties\u003c/span\u003e, at a further stage of development.\u003c/p\u003e\",\"names\":{\"english\":\"five powers\",\"tibetan\":\"སྟོབས་ལྔ།\",\"sanskrit\":\"bala\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"stobs lnga\"}},{\"uuid\":\"c4d85259-d78b-44af-a837-0dff8e4422f1\",\"authority\":\"1c017260-18a6-4001-a4df-0b86adaae1a9\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThese are called “faculties” (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eindriya\u003c/em\u003e) by analogy, as they are considered as capacities to be developed: the spiritual faculties for faith (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eśraddhā\u003c/em\u003e), effort (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003evīrya\u003c/em\u003e), mindfulness (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003esmṛti\u003c/em\u003e), \u003cspan data-glossary-id=\\\"UT22084-060-005-521\\\"\u003econcentration\u003c/span\u003e (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-060-005-642\\\"\u003esamādhi\u003c/span\u003e\u003c/em\u003e), and \u003cspan data-glossary-id=\\\"UT22084-060-005-691\\\"\u003ewisdom\u003c/span\u003e (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eprajña\u003c/em\u003e). These are included in the \u003cspan data-glossary-id=\\\"UT22084-060-005-676\\\"\u003ethirty-seven aids to enlightenment\u003c/span\u003e. \u003c/p\u003e\",\"names\":{\"english\":\"five spiritual faculties\",\"tibetan\":\"དབང་པོ་ལྔ།\",\"sanskrit\":\"indriya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dbang po lnga\"}},{\"uuid\":\"99cbd2a0-b2ab-49e2-90c3-cf2f4370226f\",\"authority\":\"cde7da87-cf2c-413e-a7c3-172868f144e8\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe first basis of magical power consists of the energy from the conscious cultivation of \u003cspan data-glossary-id=\\\"UT22084-060-005-521\\\"\u003econcentration\u003c/span\u003e of will (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003echanda­samādhi­prahāṇa­saṃskāra­samanvāgataḥ\u003c/em\u003e). The second consists of the energy from the conscious cultivation of \u003cspan data-glossary-id=\\\"UT22084-060-005-521\\\"\u003econcentration\u003c/span\u003e of mind (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003ecitta‑\u003c/em\u003e). The third consists of \u003cspan data-glossary-id=\\\"UT22084-060-005-521\\\"\u003econcentration\u003c/span\u003e of effort (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003evīrya‑\u003c/em\u003e). The fourth consists of \u003cspan data-glossary-id=\\\"UT22084-060-005-521\\\"\u003econcentration\u003c/span\u003e of analysis (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003emīmāṃsa‑\u003c/em\u003e). These four form a part of the \u003cspan data-glossary-id=\\\"UT22084-060-005-676\\\"\u003ethirty-seven aids to enlightenment\u003c/span\u003e. \u003c/p\u003e\",\"names\":{\"english\":\"four bases of magical power\",\"tibetan\":\"རྫུ་འཕྲུལ་གྱི་རྐང་པ་བཞི།\",\"sanskrit\":\"ṛddhipāda\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rdzu ’phrul gyi rkang pa bzhi\"}},{\"uuid\":\"f4db2b9d-21ee-4f8d-bd01-e07a01cdcfc5\",\"authority\":\"1af81df3-440c-4c37-897c-30aeb9faf235\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThese are the stationing, or focusing, of mindfulness on the body, \u003cspan data-glossary-id=\\\"UT22084-060-005-651\\\"\u003esensations\u003c/span\u003e, the mind, and things. These four form a part of the \u003cspan data-glossary-id=\\\"UT22084-060-005-676\\\"\u003ethirty-seven aids to enlightenment\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"four foci of mindfulness\",\"tibetan\":\"དྲན་པ་ཉེ་བར་གཞག་པ།\",\"sanskrit\":\"smṛtyupasṭhāna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dran pa nye bar gzhag pa\"}},{\"uuid\":\"549eeb32-c375-4406-b20e-a04cfda32ca6\",\"authority\":\"b4dc4adf-3751-44c9-909b-5a535d9799ea\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eImmeasurable states, otherwise known as “pure abodes” (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003ebrahmā­vihāra\u003c/em\u003e). Immeasurable love arises from the wish for all living beings to have happiness and the cause of happiness. Immeasurable compassion arises from the wish for all living beings to be free from suffering and its cause. Immeasurable joy arises from the wish that living beings not be sundered from the supreme happiness of \u003cspan data-glossary-id=\\\"UT22084-060-005-597\\\"\u003eliberation\u003c/span\u003e. And immeasurable impartiality arises from the wish that the preceding‍—love, compassion, and joy‍—should apply equally to all living beings, without attachment to friend or hatred for enemy. \u003c/p\u003e\",\"names\":{\"english\":\"four immeasurables\",\"tibetan\":\"ཚད་མེད་བཞི།\",\"sanskrit\":\"catvāryapramāṇāni\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"tshad med bzhi\"}},{\"uuid\":\"91f74f01-6cd8-4a5e-8b20-7d6a23353d69\",\"authority\":\"907d8e58-4bcc-4dc3-b466-c744321bf96c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThese consist of mistaking what is impermanent for permanent; mistaking what is without \u003cspan data-glossary-id=\\\"UT22084-060-005-649\\\"\u003eself\u003c/span\u003e for \u003cspan class=\\\"ignore\\\"\u003eself\u003c/span\u003e-possessing; mistaking what is impure for pure; and mistaking what is miserable for happy.\u003c/p\u003e\",\"names\":{\"english\":\"four misapprehensions\",\"tibetan\":\"ཕྱིན་ཅི་ལོག་བཞི།\",\"sanskrit\":\"viparyāsa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"phyin ci log bzhi\"}},{\"uuid\":\"09cf908e-1345-4575-86f2-fd0bf0c0fcce\",\"authority\":\"7c21f767-496f-484a-b930-7749c104344a\",\"definition\":\"$62\",\"names\":{\"english\":\"four reliances\",\"tibetan\":\"རྟོན་པ་བཞི།\",\"sanskrit\":\"pratiśārana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rton pa bzhi\"}},{\"uuid\":\"01a4b527-b5af-468a-9e30-4adee8b44243\",\"authority\":\"92de6b42-9665-43a5-aa41-6ac96dd93fbe\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThese are effort not to initiate sins not yet arisen; effort to eliminate sins already arisen; effort to initiate virtues not yet arisen; and effort to consolidate, increase, and not deteriorate virtues already arisen. For our use of “effort” (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003esamyak­pradhāna\u003c/em\u003e) instead of lit. “abandonment” (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003esamyak­prahāna\u003c/em\u003e) see Dayal, p. 102 ff. These four form a part of the \u003cspan data-glossary-id=\\\"UT22084-060-005-676\\\"\u003ethirty-seven aids to enlightenment\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"four right efforts\",\"tibetan\":\"ཡང་དག་པར་སྤོང་བ་བཞི།\",\"sanskrit\":\"samyak­pradhāna, samyak­prahāṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yang dag par spong ba bzhi\"}},{\"uuid\":\"09a767b0-9237-4729-b8e7-f1b27198e5e2\",\"authority\":\"e1f66ce9-acd2-4e5b-aa87-db1236b8203f\",\"definition\":\"\",\"names\":{\"english\":\"Gaganagañja\",\"tibetan\":\"ནམ་མཁའི་མཛོད།\",\"sanskrit\":\"gaganagañja\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nam mkha’i mdzod\"}},{\"uuid\":\"218fb105-f276-48ec-b576-7cdc92d2b3f9\",\"authority\":\"b9952ea0-b9c3-4e71-beee-d5175f7aa5ad\",\"definition\":\"\",\"names\":{\"english\":\"Gaja­gandha­hastin\",\"tibetan\":\"སྤོས་ཀྱི་བ་གླང་གླང་པོ་ཆེ།\",\"sanskrit\":\"gaja­gandha­hastin\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"spos kyi ba glang glang po che\"}},{\"uuid\":\"f9f4f1c7-13b3-4110-9afc-cf4ed0a6085f\",\"authority\":\"f26b2d87-6789-4d54-be2e-f0a6378b96a0\",\"definition\":\"\",\"names\":{\"english\":\"Gandhahastin\",\"tibetan\":\"སྤོས་ཀྱི་གླང་པོ་ཆེ།\",\"sanskrit\":\"gandhahastin\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"spos kyi glang po che\"}},{\"uuid\":\"c1ffdb8b-41ce-4926-99ed-06daf4f00177\",\"authority\":\"f46d0f19-ab96-472f-a8d5-37b0679e92ff\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA mountain known for its incense trees.\u003c/p\u003e\",\"names\":{\"english\":\"Gandhamādana\",\"tibetan\":\"སྤོས་ཀྱི་ངད་ལྡན།\",\"sanskrit\":\"gandhamādana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"spos kyi ngad ldan\"}},{\"uuid\":\"dec6f90a-8d2e-4ef5-914c-698acd562891\",\"authority\":\"74461fd0-5ed8-4923-b6bb-16bb40dfa426\",\"definition\":\"\u003cp\u003eA class of generally benevolent nonhuman beings who inhabit the skies, sometimes said to inhabit fantastic cities in the clouds, and more specifically to dwell on the eastern slopes of Mount Meru, where they are ruled by the Great King Dhṛtarāṣṭra. They are most renowned as celestial musicians who serve the gods. In the Abhidharma, the term is also used to refer to the mental body assumed by sentient beings during the intermediate state between death and rebirth. Gandharvas are said to live on fragrances (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003egandha\u003c/em\u003e) in the desire realm, hence the Tibetan translation \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003edri za\u003c/em\u003e, meaning “scent eater.”\u003c/p\u003e\",\"names\":{\"english\":\"gandharva\",\"tibetan\":\"དྲི་ཟ།\",\"sanskrit\":\"gandharva\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dri za\"}},{\"uuid\":\"f307d5db-ad76-494a-9e50-4220c05407a8\",\"authority\":\"497ded22-653a-4b9f-b453-3b08c500400d\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eDeities who attend on the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e Sugandhakūta in the universe \u003cspan data-glossary-id=\\\"UT22084-060-005-842\\\"\u003eSarva­gandha­sugandhā\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Gandha­vyūhāhāra\",\"tibetan\":\"སྤོས་བཀོད་པའི་ཟས།\",\"sanskrit\":\"gandha­vyūhāhāra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"spos bkod pa’i zas\"}},{\"uuid\":\"f6620db3-953d-40c5-bb5d-2291ee6ff394\",\"authority\":\"d640a587-777b-4248-b9d8-311fb2ce993c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e of the universe \u003cspan data-glossary-id=\\\"UT22084-060-005-842\\\"\u003eSarva­gandha­sugandhā\u003c/span\u003e, from whom \u003cspan data-glossary-id=\\\"UT22084-060-005-1257\\\"\u003eVimalakīrti\u003c/span\u003e’s emanation-\u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattva\u003c/span\u003e obtains the vessel of ambrosial food that magically feeds the entire assembly without diminishing in the slightest.\u003c/p\u003e\",\"names\":{\"english\":\"Gandhottama­kūṭa\",\"tibetan\":\"སྤོས་མཆོག་བརྩེགས་པ།\",\"sanskrit\":\"gandhottama­kūṭa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"spos mchog brtsegs pa\"}},{\"uuid\":\"957e97aa-bb76-4d91-9d03-7f77b3582fd1\",\"authority\":\"ba7579fc-ce40-4ade-b704-5f7d033091cc\",\"definition\":\"\u003cp\u003eIn Indian mythology, the garuḍa is an eagle-like bird that is regarded as the king of all birds, normally depicted with a sharp, owl-like beak, often holding a snake, and with large and powerful wings. They are traditionally enemies of the nāgas. In the Vedas, they are said to have brought nectar from the heavens to earth. \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eGaruḍa\u003c/em\u003e can also be used as a proper name for a king of such creatures.\u003c/p\u003e\",\"names\":{\"english\":\"garuḍa\",\"tibetan\":\"ནམ་མཁའ་ལྡིང་།\",\"sanskrit\":\"garuḍa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nam mkha’ lding\"}},{\"uuid\":\"57f30533-44ff-42b7-a670-f57da1f54504\",\"authority\":\"41de0789-5ce0-4cf7-b975-7dafa09d7d9b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThis is knowledge of the nonconceptual and transcendental which is realized by those attaining higher stages.\u003c/p\u003e\",\"names\":{\"english\":\"gnosis\",\"tibetan\":\"ཡེ་ཤེས།\",\"sanskrit\":\"jñāna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ye shes\"}},{\"uuid\":\"8de0a524-74ca-4f51-8f2e-ba02b9f037a2\",\"authority\":\"ccf1d837-c138-401f-b29e-bc00f478ad23\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe “supernatural power” with which the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003ebuddhas\u003c/span\u003e sustain the \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattvas\u003c/span\u003e in their great efforts on behalf of living beings.\u003c/p\u003e\",\"names\":{\"english\":\"grace\",\"tibetan\":\"བྱིན་གྱིས་བརླབས།\",\"sanskrit\":\"adhiṣṭḥāna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"byin gyis brlabs\"}},{\"uuid\":\"dc1f3a82-a37b-47bc-a900-9c62a98401cb\",\"authority\":\"41184c2f-0181-4558-a348-a6bd6864067d\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThis refers to one of the two central qualities of \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003ebuddhas\u003c/span\u003e or high \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattvas\u003c/span\u003e: their feeling born of the wish for all living beings to be free of suffering and to attain the supreme happiness. It is important to note that this great compassion has nothing to do with any sentimental emotion such as that stimulated by such a reflection as “Oh, the poor creatures! How they are suffering!” On the contrary, great compassion is accompanied by the clear awareness that ultimately there are no such things as living beings, suffering, etc., in reality. Thus it is a sensitivity that does not entertain any dualistic notion of subject and object; indeed, such an unlimited sensitivity might best be termed “empathy.”\u003c/p\u003e\",\"names\":{\"english\":\"great compassion\",\"tibetan\":\"སྙིང་རྗེ་ཆེན་པོ།\",\"sanskrit\":\"mahākaruṇā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"snying rje chen po\"}},{\"uuid\":\"c1233550-43a1-4be4-9029-37b7e4e3f573\",\"authority\":\"288b67ff-2d30-4e8d-b0e8-a99f4a1a9893\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eIn an effort to maintain distinctions between Buddhism and Christianity, translators have used all sorts of euphemisms for this basic term. Granted, it is not the everyday “love” that means “to like”; it is still the altruistic love that is the finest inspiration of Christ’s teaching, as well as of the \u003cspan data-glossary-id=\\\"UT22084-060-005-605\\\"\u003eMahāyāna\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"great love\",\"tibetan\":\"བྱམས་པ་ཆེན་པོ།\",\"sanskrit\":\"mahāmaitrī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"byams pa chen po\"}},{\"uuid\":\"8f291152-70ba-4e56-9a1c-8d800b7f67e6\",\"authority\":\"a6c40c30-43ed-4634-9b0a-1d707dbc463f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThis translation follows the Tib. (lit. “great mind- hero”), whose translation from Skt. derives from the \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003elo tsā ba\u003c/em\u003e’s analysis of sattva as meaning “hero,” rather than simply “being.”\u003c/p\u003e\",\"names\":{\"english\":\"great spiritual hero\",\"tibetan\":\"སེམས་དཔའ་ཆེན་པོ།\",\"sanskrit\":\"mahāsattva\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sems dpa’ chen po\"}},{\"uuid\":\"9e965ab3-84e2-4b05-873f-324b2f5ca383\",\"authority\":\"2e3bf2dd-aa0e-45fc-9fb5-a8423ef8d50a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThis is a stage in the conception or initiation of the spirit‌ of \u003cspan data-glossary-id=\\\"UT22084-060-005-551\\\"\u003eenlightenment\u003c/span\u003e‌. It follows upon the \u003cspan data-glossary-id=\\\"UT22084-060-005-631\\\"\u003epositive thought\u003c/span\u003e, or aspiration to attain it, wherein the \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattva\u003c/span\u003e becomes filled with a lofty determination that he himself should attain \u003cspan data-glossary-id=\\\"UT22084-060-005-551\\\"\u003eenlightenment\u003c/span\u003e, that it is the only thing to do to solve his own problems as well as those of all living beings. This \u003cspan class=\\\"ignore\\\"\u003ehigh resolve\u003c/span\u003e reaches its most intense purity when the \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattva\u003c/span\u003e simultaneously attains the Path of Insight and the first \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattva\u003c/span\u003e-stage, the Stage of Joy. The translation follows Lamotte’s happy coinage “\u003cem class=\\\"foreign\\\"\u003ehaute résolution\u003c/em\u003e.” \u003c/p\u003e\",\"names\":{\"english\":\"high resolve\",\"tibetan\":\"ལྷག་པའི་བསམ་པ།\",\"sanskrit\":\"adhyāśaya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lhag pa’i bsam pa\"}},{\"uuid\":\"7a1f711c-1731-4ba1-a7b6-cd7a91751a85\",\"authority\":\"f1935ed0-dde8-489b-9272-1d2e52151e81\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe deities of this, the sixth level of the gods of the desire-realm, appropriate and enjoy the magical creations of others; hence their name, literally, “who assume control of the emanations of others.” Their abode contains all the wonders created elsewhere and is referred to as a standard of splendor.\u003c/p\u003e\",\"names\":{\"english\":\"highest deities\",\"tibetan\":\"གཞན་འཕྲུལ་དབང་བྱེད་ཀྱི་ལྷ།\",\"sanskrit\":\"para­nīrmita­vaśa­vartin\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gzhan ’phrul dbang byed kyi lha\"}},{\"uuid\":\"c66c5cc4-2a03-4fb4-a080-105299213002\",\"authority\":\"59c29bbf-813c-4d95-a27f-a6c0c4f5f7f0\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA mountain.\u003c/p\u003e\",\"names\":{\"english\":\"Himavat\",\"tibetan\":\"གངས་རི།\",\"sanskrit\":\"himavat\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gangs ri\"}},{\"uuid\":\"d4033e0d-7c54-4df4-859f-ee56603feb86\",\"authority\":\"da04a8fb-0625-43cd-8eef-26022aa33270\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eSvabhāva\u003c/em\u003e is usually rendered as “\u003cspan class=\\\"ignore\\\"\u003eself\u003c/span\u003e-nature,” sometimes as “own-being,” both of which have a certain literal validity. However, neither artificial term has any evocative power for the reader who has no familiarity with the original, and a term must be found that the reader can immediately relate to his own world to fulfill the function the original word had in its world. In our world of \u003cspan class=\\\"ignore\\\"\u003eidentities\u003c/span\u003e (national, racial, religious, personal, sexual, etc.), “\u003cspan class=\\\"ignore\\\"\u003eidentity\u003c/span\u003e” is a part of our makeup; thus, when we are taught the \u003cspan data-glossary-id=\\\"UT22084-060-005-683\\\"\u003eultimate\u003c/span\u003e absence of \u003cspan class=\\\"ignore\\\"\u003eidentity\u003c/span\u003e of all persons and things, it is easy to “identify” what is supposedly absent and hence to try to understand what that entails. \u003c/p\u003e\",\"names\":{\"english\":\"identities, identity\",\"tibetan\":\"རང་བཞིན།\",\"sanskrit\":\"svabhāva\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rang bzhin\"}},{\"uuid\":\"1c8dbaa1-d394-4fd6-b49d-203c0c3613e7\",\"authority\":\"733cb497-42ca-425f-8fc1-d746c0542a10\",\"definition\":\"$63\",\"names\":{\"english\":\"immaterial realm\",\"tibetan\":\"གཟུགས་མེད་ཁམས།\",\"sanskrit\":\"ārūpyadhātu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gzugs med khams\"}},{\"uuid\":\"e6cb9fdd-cfe1-4188-8cfb-b72314d72e94\",\"authority\":\"0baf976f-a73f-4674-bea3-56e3d670ba1a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe \u003cspan class=\\\"ignore\\\"\u003eincantations\u003c/span\u003e, or spells, are mnemonic formulas, possessed by advanced \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattvas\u003c/span\u003e, that contain a quintessence of their attainments, not simply magical charms‍—although the latter are included. The same term in Sanskrit and Tibetan also refers to a highly developed power present in \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattvas\u003c/span\u003e that is a process of memory and recall of detailed teachings, best translated “retention” in certain contexts. \u003c/p\u003e\",\"names\":{\"english\":\"incantation, retention\",\"tibetan\":\"གཟུངས།\",\"sanskrit\":\"dhāraṇī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gzungs\"}},{\"uuid\":\"11384b0f-807e-4b8a-a7ef-a663577dfe40\",\"authority\":\"9692559e-037d-4ec3-acf1-df2ebffe2597\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee “\u003cspan data-glossary-id=\\\"UT22084-060-005-549\\\"\u003eemanated incarnation\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"incarnation-body\",\"tibetan\":\"སྤྲུལ་པའི་སྐུ།\",\"sanskrit\":\"nirmāṇakāya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sprul pa’i sku\"}},{\"uuid\":\"2cd68d9f-da76-44be-a8e2-9c1463fce550\",\"authority\":\"a866d410-f67f-4517-949c-4d1d6e4aa5d2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThis refers to the \u003cspan data-glossary-id=\\\"UT22084-060-005-683\\\"\u003eultimate\u003c/span\u003e nature of things, which cannot be comprehended, grasped, etc., by the ordinary, conditioned, subjective mind. Hence it is significant that the realization of this nature is not couched in terms of understanding, or conviction, but in terms of tolerance (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003ekṣānti\u003c/em\u003e), as the grasping mind cannot grasp its \u003cspan data-glossary-id=\\\"UT22084-060-005-683\\\"\u003eultimate\u003c/span\u003e inability to grasp; it can only cultivate its tolerance of that inability. \u003c/p\u003e\",\"names\":{\"english\":\"incomprehensibility, nonperception\",\"tibetan\":\"མི་དམིགས་པ།, མི་དམིགས་པ།\",\"sanskrit\":\"anupalambha, anupalambha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mi dmigs pa, mi dmigs pa\"}},{\"uuid\":\"a7f0a1b7-f208-4ed3-bf1f-8e82c127ff0f\",\"authority\":\"a866d410-f67f-4517-949c-4d1d6e4aa5d2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThis refers to the mental openness cultivated by the \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattva\u003c/span\u003e who has reached a certain awareness of the nature of reality, in that he does not seek to perceive or apprehend any object or grasp any substance in anything; rather, he removes any static pretension of his mind to have grasped at any truth, conviction, or \u003cspan data-glossary-id=\\\"UT22084-060-005-686\\\"\u003eview\u003c/span\u003e (see also “\u003cspan data-glossary-id=\\\"UT22084-060-005-584\\\"\u003eincomprehensibility\u003c/span\u003e”).\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(See also \u003ca href=\\\"end-notes.xhtml#UT22084-060-005-986\\\" data-pointer-type=\\\"id\\\"\u003en.124\u003c/a\u003e).\u003c/p\u003e\",\"names\":{\"english\":\"incomprehensibility, nonperception\",\"tibetan\":\"མི་དམིགས་པ།, མི་དམིགས་པ།\",\"sanskrit\":\"anupalambha, anupalambha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mi dmigs pa, mi dmigs pa\"}},{\"uuid\":\"dc39b632-2a80-43b2-8eec-3bd2a37aa05c\",\"authority\":\"c179ecd8-786e-47c5-8322-970713cb6a70\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eLit. “unthinkability,” (on the part of a mind whose thinking is conditioned and bound by conceptual terms). This is essentially synonymous with “\u003cspan data-glossary-id=\\\"UT22084-060-005-584\\\"\u003eincomprehensibility\u003c/span\u003e” (see entry).\u003c/p\u003e\",\"names\":{\"english\":\"inconceivability\",\"tibetan\":\"བསམ་གྱིས་མི་ཁྱབ་པ།\",\"sanskrit\":\"acintyatā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bsam gyis mi khyab pa\"}},{\"uuid\":\"9a3baeed-29d1-4683-bcd7-3c2f8f64c953\",\"authority\":\"fd25e088-8660-4bff-8092-3d6589a76ed5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cspan class=\\\"ignore\\\"\u003eInconceivable liberation\u003c/span\u003e of the \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattvas\u003c/span\u003e, a name of the \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-060-005-850\\\"\u003eAvataṃsaka\u003c/span\u003e\u003c/cite\u003e, and a subtitle of the Vimala­kīrti­nirdeśa. \u003c/p\u003e\",\"names\":{\"english\":\"inconceivable liberation\",\"tibetan\":\"རྣམ་པར་ཐར་པ་བསམ་གྱིས་མི་ཁྱབ་པ།\",\"sanskrit\":\"acintyavimokṣa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rnam par thar pa bsam gyis mi khyab pa\"}},{\"uuid\":\"106b0a5f-94b9-4d3f-8a2b-d9bf63dfb70b\",\"authority\":\"c138b30b-fb5e-4bdc-aef1-bf390da05839\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee “\u003cspan data-glossary-id=\\\"UT22084-060-005-662\\\"\u003eDisciple Vehicle\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"Individual Vehicle\",\"tibetan\":\"ཐེག་པ་དམན་པ།\",\"sanskrit\":\"hīnayāna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"theg pa dman pa\"}},{\"uuid\":\"766ba35f-3608-4997-9124-c38604e872bb\",\"authority\":\"eda797cf-2934-4c67-98cd-62f8c8fff0b2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA major god in the Vedic pantheon, he dwindled in importance after Vedism was transformed into Hinduism in the early A.D. centuries. However, he was reinstated in Buddhist \u003cspan data-glossary-id=\\\"UT22084-060-005-670\\\"\u003esūtras\u003c/span\u003e as the king of the gods and as a disciple of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e and protector of the \u003cspan data-glossary-id=\\\"UT22084-060-005-537\\\"\u003eDharma\u003c/span\u003e and its practicers.\u003c/p\u003e\",\"names\":{\"english\":\"Indra\",\"tibetan\":\"དབང་པོ།\",\"sanskrit\":\"indra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dbang po\"}},{\"uuid\":\"042a4bea-a615-40c0-9912-c64e4affaf1a\",\"authority\":\"d71507c5-246a-4dba-9190-dc0aad91027f\",\"definition\":\"\",\"names\":{\"english\":\"Indrajāla\",\"tibetan\":\"མིག་འཕྲུལ་ཅན།\",\"sanskrit\":\"indrajāla\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mig ’phrul can\"}},{\"uuid\":\"afa25927-4dea-4b0e-8765-ac84bed2ff94\",\"authority\":\"48de3e6b-b841-4e34-a0e5-a360bf30f7d1\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe subconscious tendencies and predilections of the psychosomatic conglomerate. This most obvious word is seldom used in this context because of the hesitancy of scholars to employ “scientific” terminology.\u003c/p\u003e\",\"names\":{\"english\":\"instinct\",\"tibetan\":\"བག་ཆགས།\",\"sanskrit\":\"vāsanā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bag chags\"}},{\"uuid\":\"e99c8b55-d0a0-471a-bb37-d8b186e52742\",\"authority\":\"ffabaf3e-f647-490a-977a-dae3410f2641\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee “\u003cspan data-glossary-id=\\\"UT22084-060-005-502\\\"\u003eaggregate\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"intellect\",\"tibetan\":\"འདུ་ཤེས།\",\"sanskrit\":\"samjñā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’du shes\"}},{\"uuid\":\"fa991420-a40e-4cf0-ad1a-a06405b93975\",\"authority\":\"34b65e18-5785-4655-b83d-a949693b9bc5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee “\u003cspan data-glossary-id=\\\"UT22084-060-005-532\\\"\u003edefinitive meaning\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"interpretable in meaning, interpretable meaning\",\"tibetan\":\"དྲང་དོན།\",\"sanskrit\":\"neyārtha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"drang don\"}},{\"uuid\":\"4068d4e9-bd97-41e9-bb91-546490dbf9ff\",\"authority\":\"4fec47b0-cf62-43ed-932f-31a3041dce3e\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe fact that the \u003cspan data-glossary-id=\\\"UT22084-060-005-537\\\"\u003eDharma\u003c/span\u003e is not a single dogma, law, or fixed system, but instead an adaptable body of techniques available for any living being to aid in his development and \u003cspan data-glossary-id=\\\"UT22084-060-005-597\\\"\u003eliberation\u003c/span\u003e is emphasized by this metaphor. This wheel is said to turn by the current of energy from the needs and wishes of living beings, and its turning automatically converts negative energies (e.g., desire, hatred, and ignorance) to positive ones (e.g., detachment, love, and \u003cspan data-glossary-id=\\\"UT22084-060-005-691\\\"\u003ewisdom\u003c/span\u003e).\u003c/p\u003e\",\"names\":{\"english\":\"irreversible wheel of the Dharma\",\"tibetan\":\"ཕྱིར་མི་ལྡོག་པའི་ཆོས་ཀྱི་འཁོར་ལོ།\",\"sanskrit\":\"avaivartika­dharma­cakra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"phyir mi ldog pa’i chos kyi ’khor lo\"}},{\"uuid\":\"c23b1e28-0c14-495c-9dab-e6e4e3efc108\",\"authority\":\"a7cda283-f546-4c22-a300-03e6e78a6eff\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattva\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-060-005-595\\\"\u003elayman\u003c/span\u003e of \u003cspan data-glossary-id=\\\"UT22084-060-005-848\\\"\u003eVaiśālī\u003c/span\u003e, who is saved by \u003cspan data-glossary-id=\\\"UT22084-060-005-1257\\\"\u003eVimalakīrti\u003c/span\u003e from being fooled by \u003cspan data-glossary-id=\\\"UT22084-060-005-747\\\"\u003eMāra\u003c/span\u003e posing as \u003cspan data-glossary-id=\\\"UT22084-060-005-725\\\"\u003eIndra\u003c/span\u003e. This \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattva\u003c/span\u003e is mentioned in Mvy, No. 728, and in the \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eRāṣṭra­pāla­paripṛccha\u003c/cite\u003e (Toh 62, in the \u003cspan data-glossary-id=\\\"UT22084-060-005-779\\\"\u003eRatnakūṭa\u003c/span\u003e; see Lamotte, p. 204, n. 120 and Vienna Buddhist Studies Translation Group, trans., \u003ccite class=\\\"title text-en\\\" lang=\\\"en\\\"\u003eThe Questions of Rāṣṭrapāla\u003c/cite\u003e, \u003ca href=\\\"https://read.84000.co/translation/toh62#UT22084-042-003-321994\\\" target=\\\"UT22084-042-003.html\\\" data-pointer-type=\\\"id\\\"\u003e1.1\u003c/a\u003e).\u003c/p\u003e\",\"names\":{\"english\":\"Jagatindhara\",\"tibetan\":\"འགྲོ་བ་འཛིན།\",\"sanskrit\":\"jagatindhara\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’gro ba ’dzin\"}},{\"uuid\":\"c800f0ff-668a-46af-ae56-389860e4b174\",\"authority\":\"a79782b2-b317-4d88-b839-ca232d50dcc3\",\"definition\":\"\",\"names\":{\"english\":\"Jālinīprabha\",\"tibetan\":\"དྲ་བ་ཅན་གྱི་འོད།\",\"sanskrit\":\"jālinīprabha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dra ba can gyi ’od\"}},{\"uuid\":\"f08ab827-bf71-4a4e-88bf-b065370709c0\",\"authority\":\"a7b369fe-fecb-43b8-9447-c5373ac1fcf7\",\"definition\":\"$64\",\"names\":{\"english\":\"Jambudvīpa\",\"tibetan\":\"འཛམ་བུ་གླིང་།\",\"sanskrit\":\"jambudvīpa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’dzam bu gling\"}},{\"uuid\":\"613d0117-d4f3-4f64-bef2-3e5bbf8d7f31\",\"authority\":\"87c62587-f0d7-4b7a-95ff-053222f4fd94\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the six \u003cspan data-glossary-id=\\\"UT22084-060-005-627\\\"\u003eoutsider\u003c/span\u003e teachers.\u003c/p\u003e\",\"names\":{\"english\":\"Kakuda Kātyāyana\",\"tibetan\":\"ཀཱ་ཏྱའི་བུ་ནོག་ཅན།\",\"sanskrit\":\"kakuda kātyāyana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kA tya’i bu nog can\"}},{\"uuid\":\"84038a46-c74a-4367-b650-7bc5602f6cdd\",\"authority\":\"1535c5f2-31f2-4aa4-a040-91935cee186c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA mountain.\u003c/p\u003e\",\"names\":{\"english\":\"Kālaparvata\",\"tibetan\":\"རི་ནག་པོ།\",\"sanskrit\":\"kālaparvata\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ri nag po\"}},{\"uuid\":\"b50a8fcc-a5eb-409b-96d4-a5872524e192\",\"authority\":\"7dd6ef8c-0863-4183-a2fe-49c77e137f7b\",\"definition\":\"\u003cp\u003eMeaning “action” in its most basic sense, karma is an important concept in Buddhist philosophy as the cumulative force of previous physical, verbal, and mental acts, which determines present experience and will determine future existences.\u003c/p\u003e\",\"names\":{\"english\":\"karma\",\"tibetan\":\"ལས།\",\"sanskrit\":\"karman\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"las\"}},{\"uuid\":\"8effe26b-2996-454f-98a2-3e0cda7b9569\",\"authority\":\"0bdb7926-aba8-4e98-8a0f-dd172e756ce7\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e(also \u003cspan data-glossary-id=\\\"UT22084-060-005-739\\\"\u003eMahākātyāyana\u003c/span\u003e). Disciple of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e noted for his skill in analysis of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e’s discourses and, traditionally, the founder of the \u003cspan data-glossary-id=\\\"UT22084-060-005-498\\\"\u003eAbhidharma\u003c/span\u003e. See also \u003ca href=\\\"end-notes.xhtml#UT22084-060-005-936\\\" data-pointer-type=\\\"id\\\"\u003en.74\u003c/a\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Kātyāyana, Mahākātyāyana\",\"tibetan\":\"ཀ་ཏྱའི་བུ་ཆེན་པོ།, ཀ་ཏྱའི་བུ།\",\"sanskrit\":\"kātyāyana, mahākātyāyana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ka tya’i bu, ka tya’i bu chen po\"}},{\"uuid\":\"c3b23efb-6f2b-472a-a510-fb9bc8636224\",\"authority\":\"0bdb7926-aba8-4e98-8a0f-dd172e756ce7\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e(also \u003cspan data-glossary-id=\\\"UT22084-060-005-731\\\"\u003eKātyāyana\u003c/span\u003e). Disciple of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e noted for his skill in analysis of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e’s discourses and, traditionally, the founder of the \u003cspan data-glossary-id=\\\"UT22084-060-005-498\\\"\u003eAbhidharma\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Kātyāyana, Mahākātyāyana\",\"tibetan\":\"ཀ་ཏྱའི་བུ་ཆེན་པོ།, ཀ་ཏྱའི་བུ།\",\"sanskrit\":\"kātyāyana, mahākātyāyana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ka tya’i bu, ka tya’i bu chen po\"}},{\"uuid\":\"dd1e9e44-e367-48b7-83c7-a9543c9d4693\",\"authority\":\"d313e685-b792-4e73-87cf-85cafb75a231\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAnother name for \u003cspan data-glossary-id=\\\"UT22084-060-005-725\\\"\u003eIndra\u003c/span\u003e. \u003cspan class=\\\"ignore\\\"\u003eKauśika\u003c/span\u003e, \u003cspan data-glossary-id=\\\"UT22084-060-005-792\\\"\u003eŚakra\u003c/span\u003e, and \u003cspan data-glossary-id=\\\"UT22084-060-005-725\\\"\u003eIndra\u003c/span\u003e all refer to the same god, centrally prominent in the \u003cspan data-glossary-id=\\\"UT22084-060-005-861\\\"\u003eVedas\u003c/span\u003e, who in Buddhist cosmogony is regarded as the king of gods in the \u003cspan data-glossary-id=\\\"UT22084-060-005-637\\\"\u003erealm of desire\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Kauśika\",\"tibetan\":\"ཀཽ་ཤི་ཀ\",\"sanskrit\":\"kauśika\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kau shi ka\"}},{\"uuid\":\"1dff7c07-fc28-4276-b92d-2e5ec747e3c2\",\"authority\":\"b57a5182-b1eb-4168-bd5f-28ca6def5a9f\",\"definition\":\"\u003cp\u003eA class of nonhuman beings that resemble humans to the degree that their very name‍—which means “is that human?”‍—suggests some confusion as to their divine status. Kinnaras are mythological beings found in both Buddhist and Brahmanical literature, where they are portrayed as creatures half human, half animal. They are often depicted as highly skilled celestial musicians.\u003c/p\u003e\",\"names\":{\"english\":\"kinnara\",\"tibetan\":\"མིའམ་ཅི།\",\"sanskrit\":\"kinnara\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mi’am ci\"}},{\"uuid\":\"50940bab-2272-4591-b517-26769cb76c2e\",\"authority\":\"d302495a-694e-4ba5-a8e7-294fb46c1e63\",\"definition\":\"\",\"names\":{\"english\":\"knowledge and vision of liberation\",\"tibetan\":\"རྣམ་པར་གྲོལ་བའི་ཡེ་ཤེས་མཐོང་བ།\",\"sanskrit\":\"vimukti­jñāna­darśana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rnam par grol ba’i ye shes mthong ba\"}},{\"uuid\":\"0d6816bf-611c-43a9-86a7-b49753f85aeb\",\"authority\":\"6509e329-916d-46ff-8181-675cd303b258\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe first \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e of the “Good Eon” (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003ebhadrakalpa\u003c/em\u003e) of one thousand \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003ebuddhas\u003c/span\u003e, our own \u003cspan data-glossary-id=\\\"UT22084-060-005-794\\\"\u003eŚākyamuni\u003c/span\u003e having been the fourth, and \u003cspan data-glossary-id=\\\"UT22084-060-005-743\\\"\u003eMaitreya\u003c/span\u003e expected to come as the fifth. Also spelled Krakutsanda, Kukutsunda, Kukucchanda. \u003c/p\u003e\",\"names\":{\"english\":\"Krakucchanda\",\"tibetan\":\"འཁོར་བ་འཇིག, ལོག་པར་དད་སེལ།\",\"sanskrit\":\"krakucchanda\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"log par dad sel, ’khor ba ’jig\"}},{\"uuid\":\"88606e19-a9b0-42f3-8c74-d94083dc352c\",\"authority\":\"9118719b-fb1a-4dba-8ec9-340ad2acacfb\",\"definition\":\"\",\"names\":{\"english\":\"Kṣetralaṃkṛta\",\"tibetan\":\"ཞིང་སྙོམས་བརྒྱན།\",\"sanskrit\":\"kṣetralaṃkṛta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"zhing snyoms brgyan\"}},{\"uuid\":\"05d4dcc1-b553-4d8a-b913-3d42e28773e0\",\"authority\":\"4f532898-d25c-4545-b5f7-a53007be53c3\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eTranslator of this \u003cspan data-glossary-id=\\\"UT22084-060-005-670\\\"\u003esūtra\u003c/span\u003e into Chinese (344-409).\u003c/p\u003e\",\"names\":{\"english\":\"Kumārajīva\",\"tibetan\":\"\",\"sanskrit\":\"kumārajīva\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"\"}},{\"uuid\":\"f5c6ddf7-a472-4f48-a43d-76a7cf3622b3\",\"authority\":\"ebde0333-3de1-410a-9622-9a866b71bd89\",\"definition\":\"\",\"names\":{\"english\":\"Lakṣaṇa­kūṭa­samatikrānta\",\"tibetan\":\"མཚན་བརྩེགས་ཡང་དག་འདས།\",\"sanskrit\":\"lakṣaṇa­kūṭa­samatikrānta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mtshan brtsegs yang dag ’das\"}},{\"uuid\":\"441162aa-6112-465c-96b1-bf951ed9d5a3\",\"authority\":\"b2dbaf0a-b5c9-4ecb-82b6-bfe9a9232283\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eHouseholders with definite vows that set them off from the ordinary householder.\u003c/p\u003e\",\"names\":{\"english\":\"layman, laymen\",\"tibetan\":\"དགེ་བསྙེན།\",\"sanskrit\":\"upāsaka\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dge bsnyen\"}},{\"uuid\":\"1be70e05-dcfa-40d3-b155-2c8cceb5a63f\",\"authority\":\"1bc2f10d-50aa-4a44-b04f-0836bccf0774\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eHouseholders with definite vows that set them off from the ordinary householder.\u003c/p\u003e\",\"names\":{\"english\":\"laywoman, laywomen\",\"tibetan\":\"དགེ་བསྙེན་མ།\",\"sanskrit\":\"upāsikā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dge bsnyen ma\"}},{\"uuid\":\"1f6de051-60d0-418f-9255-9634be3f22b8\",\"authority\":\"4a9c787d-e93e-4757-b5c4-65281f956020\",\"definition\":\"$65\",\"names\":{\"english\":\"liberation, nirvāṇa\",\"tibetan\":\"མྱ་ངན་ལས་འདས་པ།, མྱ་ངན་ལས་འདས་པ།, རྣམ་པར་གྲོལ་བ།, རྣམ་པར་ཐར་པ།\",\"sanskrit\":\"nirvāṇa, nirvāṇa, vimokṣa, vimukti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mya ngan las ’das pa, mya ngan las ’das pa, rnam par grol ba, rnam par thar pa\"}},{\"uuid\":\"bc870b0a-74dc-452b-ab38-74618df3c1c1\",\"authority\":\"4a9c787d-e93e-4757-b5c4-65281f956020\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eFinal \u003cspan data-glossary-id=\\\"UT22084-060-005-597\\\"\u003eliberation\u003c/span\u003e from suffering. In the Hinayāna it is believed attainable by turning away from the world of living beings and transcending all \u003cspan data-glossary-id=\\\"UT22084-060-005-501\\\"\u003eafflictions\u003c/span\u003e and selfishnesses through meditative trances. In the \u003cspan data-glossary-id=\\\"UT22084-060-005-605\\\"\u003eMahāyāna\u003c/span\u003e, it is believed attainable only by the attainment of buddhahood, the nondual realization of the indivisibility of \u003cspan data-glossary-id=\\\"UT22084-060-005-600\\\"\u003elife\u003c/span\u003e and \u003cspan data-glossary-id=\\\"UT22084-060-005-597\\\"\u003eliberation\u003c/span\u003e, and the all-powerful compassion that establishes all living beings simultaneously in their own \u003cspan data-glossary-id=\\\"UT22084-060-005-597\\\"\u003eliberations\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"liberation, nirvāṇa\",\"tibetan\":\"མྱ་ངན་ལས་འདས་པ།, མྱ་ངན་ལས་འདས་པ།, རྣམ་པར་གྲོལ་བ།, རྣམ་པར་ཐར་པ།\",\"sanskrit\":\"nirvāṇa, nirvāṇa, vimokṣa, vimukti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mya ngan las ’das pa, mya ngan las ’das pa, rnam par grol ba, rnam par thar pa\"}},{\"uuid\":\"7c541c84-ac9d-49ce-92dc-9b1f6912648d\",\"authority\":\"08dc6ac2-dc3d-4cef-8bc2-38da137b5985\",\"definition\":\"$66\",\"names\":{\"english\":\"liberative art\",\"tibetan\":\"ཐབས།\",\"sanskrit\":\"upāya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"thabs\"}},{\"uuid\":\"33770a73-e8ab-4ffb-9409-eb25bda5915d\",\"authority\":\"63e7229a-51c6-4cec-b3af-4f443ab6ffa9\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eName of the tribe and republican city-state whose capital was \u003cspan data-glossary-id=\\\"UT22084-060-005-848\\\"\u003eVaiśālī\u003c/span\u003e, where \u003cspan data-glossary-id=\\\"UT22084-060-005-1257\\\"\u003eVimalakīrti\u003c/span\u003e lived, and the main events of this \u003cspan data-glossary-id=\\\"UT22084-060-005-670\\\"\u003esūtra\u003c/span\u003e take place.\u003c/p\u003e\",\"names\":{\"english\":\"Licchavi\",\"tibetan\":\"ལིད་ཙ་བཱི།\",\"sanskrit\":\"licchavi\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lid tsa bI\"}},{\"uuid\":\"6ecd17e0-5b7b-4765-a71a-c82d4fd5942c\",\"authority\":\"358d1f13-838f-44a7-9595-04699ebf2524\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA state of involuntary existence conditioned by afflicted mental states and the imprint of past actions, characterized by suffering in a cycle of life, death, and rebirth. On its reversal, the contrasting state of nirvāṇa is attained, free from suffering and the processes of rebirth.\u003c/p\u003e\",\"names\":{\"english\":\"life, saṃsāra\",\"tibetan\":\"འཁོར་བ།, འཁོར་བ།\",\"sanskrit\":\"saṃsāra, saṃsāra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’khor ba, ’khor ba\"}},{\"uuid\":\"6624d772-b0ed-4408-8bb0-479551664ed3\",\"authority\":\"358d1f13-838f-44a7-9595-04699ebf2524\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe cycle of birth and death; that is, \u003cspan class=\\\"ignore\\\"\u003elife\u003c/span\u003e as experienced by living beings under the influence of ignorance, not any sort of objective world external to the persons experiencing it.\u003c/p\u003e\",\"names\":{\"english\":\"life, saṃsāra\",\"tibetan\":\"འཁོར་བ།, འཁོར་བ།\",\"sanskrit\":\"saṃsāra, saṃsāra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’khor ba, ’khor ba\"}},{\"uuid\":\"f0a62e12-3b21-4023-b034-45ee86fb1e48\",\"authority\":\"954508e7-950c-49e1-8749-27bf6ff6e124\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eLit. “World-Protectors.” They are the same as the four Mahārājas, the great kings of the quarters (\u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003ergyal chen bzhi\u003c/em\u003e), namely, Vaiśravaṇa, Dhṛtarāṣṭra, Virūḍhaka, and Virūpākṣa, whose mission is to report on the activities of mankind to the gods of the \u003cspan data-glossary-id=\\\"UT22084-060-005-846\\\"\u003eTrāyastriṃśa\u003c/span\u003e heaven and who have pledged to protect the practitioners of the \u003cspan data-glossary-id=\\\"UT22084-060-005-537\\\"\u003eDharma\u003c/span\u003e. Each universe has its own set of four. \u003c/p\u003e\",\"names\":{\"english\":\"Lokapāla\",\"tibetan\":\"འཇིག་རྟེན་སྐྱོང་།\",\"sanskrit\":\"lokapāla\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’jig rten skyong\"}},{\"uuid\":\"41c623b8-3d94-4f8e-b2c5-1d7a5f5af6d3\",\"authority\":\"2b190410-5ef2-4a3a-a428-89d999d14336\",\"definition\":\"$67\",\"names\":{\"english\":\"lord\",\"tibetan\":\"བཅོམ་ལྡན་འདས།\",\"sanskrit\":\"bhagavān\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bcom ldan ’das\"}},{\"uuid\":\"cee798d3-8290-4ca3-b78b-795ba0b125be\",\"authority\":\"538ce3b5-840c-4ad8-8668-b3612db2eea2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eTeaching of the Middle Way.\u003c/p\u003e\",\"names\":{\"english\":\"Madhyamaka\",\"tibetan\":\"དབུ་མ།\",\"sanskrit\":\"madhyamaka\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dbu ma\"}},{\"uuid\":\"08688fff-c9ad-4aaa-83ac-1792ad208fff\",\"authority\":\"47f5f15f-15e4-421c-883f-544fc89b7b70\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSchool based on \u003cspan data-glossary-id=\\\"UT22084-060-005-602\\\"\u003eMadhyamaka\u003c/span\u003e, and followers of that school.\u003c/p\u003e\",\"names\":{\"english\":\"Mādhyamika\",\"tibetan\":\"དབུ་མ་པ།\",\"sanskrit\":\"mādhyamika\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dbu ma pa\"}},{\"uuid\":\"fec9b0f0-a7bd-48c3-8fd3-95b18ee7a432\",\"authority\":\"145ebab7-f855-4480-89e0-815915dd722f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe “Analysis of the Middle and the Extremes,” it is an important work of \u003cspan data-glossary-id=\\\"UT22084-060-005-687\\\"\u003eVijñānavāda\u003c/span\u003e philosophy, said to have been received as a revelation from the future \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-060-005-743\\\"\u003eMaitreya\u003c/span\u003e by the great scholar and saint, \u003cspan data-glossary-id=\\\"UT22084-060-005-705\\\"\u003eĀryāsaṅga\u003c/span\u003e, after twelve years of \u003cspan data-glossary-id=\\\"UT22084-060-005-612\\\"\u003emeditation\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Madhyānta­vibhāga\",\"tibetan\":\"དབུས་མཐའ་རྣམ་འབྱེད།\",\"sanskrit\":\"madhyānta­vibhāga\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dbus mtha’ rnam ’byed\"}},{\"uuid\":\"c986791c-8e80-4bb5-accc-0bf93b6d6eea\",\"authority\":\"299bddd2-05a9-4552-abbe-187662b538e6\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA mountain, or sometimes a range of mountains.\u003c/p\u003e\",\"names\":{\"english\":\"Mahācakravāḍa\",\"tibetan\":\"ཁོར་ཡུག་ཆེན་པོ།\",\"sanskrit\":\"mahācakravāḍa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"khor yug chen po\"}},{\"uuid\":\"cf40c4ec-f71c-47c7-bd39-47de5e6850b9\",\"authority\":\"1aff34d4-5da6-49ab-b312-523fffccb2d7\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eForemost disciple of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e; he inherited the leadership of the \u003cspan data-glossary-id=\\\"UT22084-060-005-646\\\"\u003esaṅgha\u003c/span\u003e after the \u003cspan data-glossary-id=\\\"UT22084-060-005-629\\\"\u003eParinirvāṇa\u003c/span\u003e. See also \u003ca href=\\\"end-notes.xhtml#UT22084-060-005-924\\\" data-pointer-type=\\\"id\\\"\u003en.62\u003c/a\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Mahākāśyapa\",\"tibetan\":\"འོད་སྲུང་ཆེན་པོ།\",\"sanskrit\":\"mahākāśyapa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’od srung chen po\"}},{\"uuid\":\"5ba4353e-ee45-4137-8e61-ebf953ac0dbc\",\"authority\":\"33bf04de-6482-4680-bbee-b6410380d8e6\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the chief \u003cspan data-glossary-id=\\\"UT22084-060-005-661\\\"\u003eśrāvakas\u003c/span\u003e, paired with \u003cspan data-glossary-id=\\\"UT22084-060-005-801\\\"\u003eŚāriputra\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Mahā­maudgalyāyana, Maudgalyāyana\",\"tibetan\":\"མཽད་གལ་གྱི་བུ་ཆེན་པོ།, མཽད་གལ་གྱི་བུ།\",\"sanskrit\":\"mahā­maudgalyāyana, maudgalyāyana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"maud gal gyi bu, maud gal gyi bu chen po\"}},{\"uuid\":\"8ae3a0a1-180a-4fc8-910a-cc2134148828\",\"authority\":\"33bf04de-6482-4680-bbee-b6410380d8e6\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the chief \u003cspan data-glossary-id=\\\"UT22084-060-005-661\\\"\u003eśrāvakas\u003c/span\u003e, paired with \u003cspan data-glossary-id=\\\"UT22084-060-005-801\\\"\u003eŚāriputra\u003c/span\u003e. See also \u003ca href=\\\"end-notes.xhtml#UT22084-060-005-919\\\" data-pointer-type=\\\"id\\\"\u003en.57\u003c/a\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Mahā­maudgalyāyana, Maudgalyāyana\",\"tibetan\":\"མཽད་གལ་གྱི་བུ་ཆེན་པོ།, མཽད་གལ་གྱི་བུ།\",\"sanskrit\":\"mahā­maudgalyāyana, maudgalyāyana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"maud gal gyi bu, maud gal gyi bu chen po\"}},{\"uuid\":\"11d13f8e-9250-4a7b-a90c-93d692627ecd\",\"authority\":\"28d566e7-5a94-4917-9d77-6ee5554c5aa4\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA mountain.\u003c/p\u003e\",\"names\":{\"english\":\"Mahāmucilinda\",\"tibetan\":\"རི་བཏང་ཟུང་ཆེན་པོ།\",\"sanskrit\":\"mahāmucilinda\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ri btang zung chen po\"}},{\"uuid\":\"aa77fe0c-f103-4bce-bb23-2bc3d416ca17\",\"authority\":\"4d024018-6232-484a-b5c4-9797707a79a9\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA “Great Sorcerer,” a master of the esoteric teachings and practices of \u003cspan data-glossary-id=\\\"UT22084-060-005-605\\\"\u003eMahāyāna\u003c/span\u003e Buddhism. \u003c/p\u003e\",\"names\":{\"english\":\"mahāsiddha\",\"tibetan\":\"གྲུབ་ཐོབ་ཆེན་པོ།\",\"sanskrit\":\"mahāsiddha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"grub thob chen po\"}},{\"uuid\":\"7a41b934-c990-46f8-9b38-feb9f548a2f9\",\"authority\":\"17b9b902-a287-45e5-9813-d8e7a6e9d763\",\"definition\":\"\",\"names\":{\"english\":\"Mahā­sthāma­prāpta\",\"tibetan\":\"མཐུ་ཆེན་ཐོབ།\",\"sanskrit\":\"mahā­sthāma­prāpta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mthu chen thob\"}},{\"uuid\":\"f843905e-7c06-4b89-b2c9-db7c54da8fe4\",\"authority\":\"3451ce5b-fc8b-487a-bb60-39273a344c1b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe name of one of the \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattvas\u003c/span\u003e in the assembly in Chap. 1. \u003c/p\u003e\",\"names\":{\"english\":\"Mahāvyūha\",\"tibetan\":\"བཀོད་པ་ཆེན་པོ།\",\"sanskrit\":\"mahāvyūha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bkod pa chen po\"}},{\"uuid\":\"1f3c1c4a-c0ad-4892-8575-0f2004bce7ec\",\"authority\":\"d2bd62ec-1e8b-4167-918a-8bedbe0c006e\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe name of the universe in the distant past where the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-060-005-708\\\"\u003eBhaiṣajyarāja\u003c/span\u003e presided, and taught the prince Chandracchattra about the \u003cspan data-glossary-id=\\\"UT22084-060-005-537\\\"\u003eDharma\u003c/span\u003e-worship (in the Epilogue).\u003c/p\u003e\",\"names\":{\"english\":\"Mahāvyūha\",\"tibetan\":\"ཆེར་བཀོད་པ།\",\"sanskrit\":\"mahāvyūha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"cher bkod pa\"}},{\"uuid\":\"99607e52-e246-4905-b531-6e6d7ccfd7b7\",\"authority\":\"9a756070-8289-4da7-8340-e4e06d2ade44\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe “Great Vehicle” of Buddhism, called “great” because it carries all living beings to \u003cspan data-glossary-id=\\\"UT22084-060-005-551\\\"\u003eenlightenment\u003c/span\u003e of Buddhahood. It is distinguished from the Hinayāna, including the Śrāvāka­yāna (\u003cspan data-glossary-id=\\\"UT22084-060-005-661\\\"\u003eŚrāvaka\u003c/span\u003e Vehicle) and Pratyeka­buddha­yāna (Solitary Sage Vehicle), which only carries each person who rides on it to their own personal \u003cspan data-glossary-id=\\\"UT22084-060-005-597\\\"\u003eliberation\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Mahāyāna\",\"tibetan\":\"ཐེག་པ་ཆེན་པོ།\",\"sanskrit\":\"mahāyāna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"theg pa chen po\"}},{\"uuid\":\"afacafea-c9ae-4ff3-8784-b2ac7da446e6\",\"authority\":\"eb1c6fc0-d2f8-4d3e-8fad-825f71769dd7\",\"definition\":\"\u003cp\u003eLiterally “great serpents,” mahoragas are supernatural beings depicted as large, subterranean beings with human torsos and heads and the lower bodies of serpents. Their movements are said to cause earthquakes, and they make up a class of subterranean geomantic spirits whose movement through the seasons and months of the year is deemed significant for construction projects.\u003c/p\u003e\",\"names\":{\"english\":\"mahoraga\",\"tibetan\":\"ལྟོ་འཕྱེ་ཆེན་པོ།\",\"sanskrit\":\"mahoraga\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lto ’phye chen po\"}},{\"uuid\":\"7067dbc9-9833-4f0d-880c-f1b6f821805f\",\"authority\":\"cdfb8e4f-6d68-4c38-a3c5-5bd8897f3897\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattva\u003c/span\u003e present throughout the \u003cspan data-glossary-id=\\\"UT22084-060-005-670\\\"\u003esūtra\u003c/span\u003e, prophesied as one birth away from buddhahood and designated by \u003cspan data-glossary-id=\\\"UT22084-060-005-794\\\"\u003eŚākyamuni\u003c/span\u003e as the next \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003ebuddha\u003c/span\u003e in the succession of one thousand \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003ebuddhas\u003c/span\u003e of our era. According to tradition, he resides in the \u003cspan data-glossary-id=\\\"UT22084-060-005-847\\\"\u003eTuṣita\u003c/span\u003e heaven preparing for his descent to earth at the appropriate time which, according to Buddhist belief, will occur in 4456 A.D.\u003c/p\u003e\",\"names\":{\"english\":\"Maitreya\",\"tibetan\":\"བྱམས་པ།\",\"sanskrit\":\"maitreya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"byams pa\"}},{\"uuid\":\"2d4e790b-515d-40b2-8fdc-9bd015b184fd\",\"authority\":\"71b01261-c006-43cd-9e58-7d98c6a5d215\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA mystic diagram, usually consisting of a square within a circle, used to define a sacred space in the context of esoteric rituals of initiation and consecration preliminary to certain advanced meditational practices. \u003c/p\u003e\",\"names\":{\"english\":\"maṇḍala\",\"tibetan\":\"དཀྱིལ་འཁོར།\",\"sanskrit\":\"maṇḍala\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dkyil ’khor\"}},{\"uuid\":\"a0c3f76c-3679-4d42-ae49-b849d336ffc0\",\"authority\":\"ffbf607d-302e-450a-ad71-0d7b99786d25\",\"definition\":\"\",\"names\":{\"english\":\"Maṇicūḍa\",\"tibetan\":\"གཙུག་ན་ནོར་བུ།\",\"sanskrit\":\"maṇicūḍa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gtsug na nor bu\"}},{\"uuid\":\"996d4bd5-bea2-4d8b-92a3-638bd7ff13d1\",\"authority\":\"75b44e4c-818c-42c9-907f-f6bef7f44581\",\"definition\":\"\",\"names\":{\"english\":\"Maṇi­ratnacchattra\",\"tibetan\":\"ནོར་བུ་རིན་ཆེན་གདུགས།\",\"sanskrit\":\"maṇi­ratnacchattra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nor bu rin chen gdugs\"}},{\"uuid\":\"10b56931-f8ef-48df-9532-76c888687d0f\",\"authority\":\"320c5523-4cde-4365-aeb1-3e69be9b0e42\",\"definition\":\"$68\",\"names\":{\"english\":\"Mañjuśrī, Mañjuśrī, the crown prince, Mañjuśrī­kumāra­bhūta, crown prince Mañjuśrī, crown, prince Mañjuśrī\",\"tibetan\":\"འཇམ་དཔལ་གཞོན་ནུར་གྱུར་པ།, འཇམ་དཔལ།\",\"sanskrit\":\"mañjuśrī, mañjuśrī­kumāra­bhūta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’jam dpal, ’jam dpal gzhon nur gyur pa\"}},{\"uuid\":\"dc91f42f-fab1-4b12-8cc4-98af048dd264\",\"authority\":\"1f2c5cff-2505-474f-a76d-38701fb52951\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe devil, or evil one, who leads the forces of the gods of the desire-world in seeking to tempt and seduce the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e and his disciples. But according to \u003cspan data-glossary-id=\\\"UT22084-060-005-1257\\\"\u003eVimalakīrti\u003c/span\u003e he is actually a \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattva\u003c/span\u003e who dwells in the \u003cspan data-glossary-id=\\\"UT22084-060-005-586\\\"\u003einconceivable liberation\u003c/span\u003e and displays evil activities in order to strengthen and consolidate the \u003cspan data-glossary-id=\\\"UT22084-060-005-576\\\"\u003ehigh resolve\u003c/span\u003e of all \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattvas\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Māra\",\"tibetan\":\"བདུད།\",\"sanskrit\":\"māra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bdud\"}},{\"uuid\":\"65df5e51-8919-4ab0-9716-5736946a105d\",\"authority\":\"d8ed2e81-5211-4c87-975c-3ef0051e7c5c\",\"definition\":\"\",\"names\":{\"english\":\"Mārajit\",\"tibetan\":\"བདུད་ལས་རྒྱལ།\",\"sanskrit\":\"mārajit\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bdud las rgyal\"}},{\"uuid\":\"d3e5cced-045b-4ac8-bde7-f2624a5c4f3c\",\"authority\":\"4401bbbd-ddab-44fe-a72b-5050c5a43590\",\"definition\":\"\",\"names\":{\"english\":\"Mārapramardin\",\"tibetan\":\"བདུད་འཇོམས།\",\"sanskrit\":\"mārapramardin\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bdud ’joms\"}},{\"uuid\":\"4d53e933-8f0d-442a-8b4a-c787670e6af5\",\"authority\":\"197c1d01-a4c4-4f71-a549-7ef8693a8acf\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eUniverse of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e Duṣprasāhā.\u003c/p\u003e\",\"names\":{\"english\":\"Marīci\",\"tibetan\":\"སྨིག་རྒྱུ།\",\"sanskrit\":\"marīci\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"smig rgyu\"}},{\"uuid\":\"442da60a-4137-433a-bf88-309e236a17cc\",\"authority\":\"ea4e6a1e-4f2a-4bc7-bc05-55771097f44b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the six \u003cspan data-glossary-id=\\\"UT22084-060-005-627\\\"\u003eoutsider\u003c/span\u003e teachers.\u003c/p\u003e\",\"names\":{\"english\":\"Māskārin Gośāli­putra\",\"tibetan\":\"ཀུན་ཏུ་རྒྱུ་གནག་ལྷས་ཀྱི་བུ།\",\"sanskrit\":\"māskārin gośāli­putra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kun tu rgyu gnag lhas kyi bu\"}},{\"uuid\":\"e4aa5e08-3018-4f5b-87f0-db3fcb4dc9b1\",\"authority\":\"2df915da-ff51-4444-afad-02e152ff7ceb\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe sense, which ordinarily binds us, of the “objective” solidity and physical reality of things.\u003c/p\u003e\",\"names\":{\"english\":\"materialism\",\"tibetan\":\"རིལ་པོར་འཛིན་པ།\",\"sanskrit\":\"piṇdagrāha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ril por ’dzin pa\"}},{\"uuid\":\"e5f7a767-c35a-41f3-8c5d-a7149d7ad6bd\",\"authority\":\"bfdbb746-6779-49b1-9b6f-262846a2373e\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eObject of egoistic or materialist interest (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003esatkāyadṛṣṭi\u003c/em\u003e). See “\u003cspan data-glossary-id=\\\"UT22084-060-005-542\\\"\u003eegoistic views\u003c/span\u003e.” \u003c/p\u003e\",\"names\":{\"english\":\"materiality\",\"tibetan\":\"འཇིག་ཚོགས།\",\"sanskrit\":\"satkāya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’jig tshogs\"}},{\"uuid\":\"70ce5b43-6da5-4c30-8f26-5499b63c8a0b\",\"authority\":\"0aceca01-10ab-4755-9560-4878eb40530d\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee “\u003cspan data-glossary-id=\\\"UT22084-060-005-502\\\"\u003eaggregate\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"matter\",\"tibetan\":\"གཟུགས།\",\"sanskrit\":\"rūpa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gzugs\"}},{\"uuid\":\"491d1590-45ab-45e0-98bc-0fd9c9c2aba9\",\"authority\":\"502ca73e-6500-4368-9aca-76bebaa8bd37\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eFour ways in which a \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattva\u003c/span\u003e forms a group of people united by the common aim of practicing the \u003cspan data-glossary-id=\\\"UT22084-060-005-537\\\"\u003eDharma\u003c/span\u003e: giving (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003edāna\u003c/em\u003e); pleasant speech (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003epriyavaditā\u003c/em\u003e); accomplishment of the aims (of others) by teaching \u003cspan data-glossary-id=\\\"UT22084-060-005-537\\\"\u003eDharma\u003c/span\u003e (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003earthacaryā\u003c/em\u003e); and consistency of behavior with the teaching (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003esamānārthatā\u003c/em\u003e). \u003c/p\u003e\",\"names\":{\"english\":\"means of unification\",\"tibetan\":\"བསྡུ་བའི་དངོས་པོ།\",\"sanskrit\":\"saṃgrahavastu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bsdu ba’i dngos po\"}},{\"uuid\":\"99e2183e-c2ce-48c9-b16d-e33a529349a0\",\"authority\":\"78b3b7c2-b25f-447a-9cab-71278587bbac\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee “\u003cspan data-glossary-id=\\\"UT22084-060-005-525\\\"\u003econceptualization\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"mental construction\",\"tibetan\":\"ཀུན་ཏུ་རྟོག་པ།\",\"sanskrit\":\"kalpanā, vikalpa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kun tu rtog pa\"}},{\"uuid\":\"5e339443-19eb-4ac1-8ec2-9c364443dd1c\",\"authority\":\"f2cbdf52-fb59-48b9-ab78-dba315b9aed3\",\"definition\":\"$69\",\"names\":{\"english\":\"mental quiescence\",\"tibetan\":\"ཞི་གནས།\",\"sanskrit\":\"śamatha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"zhi gnas\"}},{\"uuid\":\"4b8c7c59-42c6-46be-b5d2-cdf7b004a86c\",\"authority\":\"3c9bd49a-2bc5-456a-9bbb-3332de7a9f7d\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-060-005-516\\\"\u003eBuddhafield\u003c/span\u003e beyond \u003cspan data-glossary-id=\\\"UT22084-060-005-516\\\"\u003ebuddhafields\u003c/span\u003e as numerous as the sands of thirty-six Ganges rivers, administered by the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-060-005-752\\\"\u003eMeru­pradīpa­rāja\u003c/span\u003e, whence \u003cspan data-glossary-id=\\\"UT22084-060-005-1257\\\"\u003eVimalakīrti\u003c/span\u003e obtains the lion-thrones on which he seats his visitors.\u003c/p\u003e\",\"names\":{\"english\":\"Merudhvaja\",\"tibetan\":\"ལྷུན་པོའི་རྒྱལ་མཚན།\",\"sanskrit\":\"merudhvaja\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lhun po’i rgyal mtshan\"}},{\"uuid\":\"6dce3601-9a38-46be-a783-5623b83ab4ab\",\"authority\":\"ff627381-f811-419c-86c5-b9b2cb99900b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e of the universe \u003cspan data-glossary-id=\\\"UT22084-060-005-838\\\"\u003eMerudhvaja\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Meru­pradīpa­rāja\",\"tibetan\":\"ལྷུན་པོའི་སྒྲོན་མའི་རྒྱལ་པོ།\",\"sanskrit\":\"meru­pradīpa­rāja\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lhun po’i sgron ma’i rgyal po\"}},{\"uuid\":\"324d8870-bad2-4237-a723-c4203312fb79\",\"authority\":\"b38659ed-9407-4d7d-b9f4-1586169f4bc2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eMorally virtuous or disciplined conduct and the abandonment of morally undisciplined conduct of body, speech, and mind. In a general sense, moral discipline is the cause for rebirth in higher, more favorable states, but it is also foundational to Buddhist practice as one of the three trainings (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003etriśikṣā\u003c/em\u003e) and one of the six perfections of a bodhisattva. Often rendered as “ethics,” “discipline,” and “morality.”\u003c/p\u003e\",\"names\":{\"english\":\"morality\",\"tibetan\":\"ཚུལ་ཁྲིམས།\",\"sanskrit\":\"śīla\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"tshul khrims\"}},{\"uuid\":\"a5e38a9a-be9b-4e45-b562-c04a91779f15\",\"authority\":\"da1cbe63-d5d7-4ee7-b579-8f13a92555e3\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee “\u003cspan data-glossary-id=\\\"UT22084-060-005-502\\\"\u003eaggregate\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"motivation\",\"tibetan\":\"འདུ་བྱེད།\",\"sanskrit\":\"saṃskāra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’du byed\"}},{\"uuid\":\"27b2f5b9-9696-440c-abe8-86c1c3d136b9\",\"authority\":\"9831487d-406f-45e5-8163-fe5d67c76cf4\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA mountain.\u003c/p\u003e\",\"names\":{\"english\":\"Mucilinda\",\"tibetan\":\"རི་བཏང་བཟུང་།\",\"sanskrit\":\"mucilinda\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ri btang bzung\"}},{\"uuid\":\"eb6dcdc0-cf99-4b43-a0f9-a7c27c0b6f71\",\"authority\":\"bbc77e13-4bdd-4909-bfdd-d8a299ca4508\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the \u003cspan class=\\\"ignore\\\"\u003elords\u003c/span\u003e of the ocean, appearing as a great, many headed, sea dragon.\u003c/p\u003e\",\"names\":{\"english\":\"nāga\",\"tibetan\":\"ཀླུ།\",\"sanskrit\":\"nāga\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"klu\"}},{\"uuid\":\"68714aab-998c-4cd0-89e6-90509f6dcc76\",\"authority\":\"88ee2e82-3a64-4b39-a670-5b3686b5a774\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSaint, scholar, and mystic of Buddhist India from about four hundred years after the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e; discoverer of the \u003cspan data-glossary-id=\\\"UT22084-060-005-605\\\"\u003eMahāyāna\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-060-005-670\\\"\u003esūtras\u003c/span\u003e and author of the fundamental \u003cspan data-glossary-id=\\\"UT22084-060-005-602\\\"\u003eMadhyamaka\u003c/span\u003e treatise.\u003c/p\u003e\",\"names\":{\"english\":\"Nāgārjuna\",\"tibetan\":\"ཀླུ་སྒྲུབ།\",\"sanskrit\":\"nāgārjuna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"klu sgrub\"}},{\"uuid\":\"c93e428f-dcab-4e32-8ad0-ccb97241adc5\",\"authority\":\"a17d51df-7483-492c-8b9f-ff85e824b7d4\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eIn Indian lore, \u003cspan data-glossary-id=\\\"UT22084-060-005-582\\\"\u003eincarnation\u003c/span\u003e of Viṣṇu, whose strength was legendary (see \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-060-005-849\\\"\u003eAbhi­dharma­kośa\u003c/span\u003e\u003c/cite\u003e VII, pp. 72-74). \u003c/p\u003e\",\"names\":{\"english\":\"Nārāyaṇa\",\"tibetan\":\"སྲེད་མེད་ཀྱི་བུ།\",\"sanskrit\":\"nārāyaṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sred med kyi bu\"}},{\"uuid\":\"25edb04b-2e74-4313-816c-fd6ad8af9800\",\"authority\":\"16bfd86a-483a-415d-b05f-12855f338bea\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThis term refers to the restricted, biased, \u003cspan class=\\\"ignore\\\"\u003enarrow-minded attitudes\u003c/span\u003e and practices of the \u003cspan data-glossary-id=\\\"UT22084-060-005-662\\\"\u003eDisciple Vehicle\u003c/span\u003e, which itself is called Skt. \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eprādeśikāyāna\u003c/em\u003e (“limited, or narrow-minded, vehicle”) (Mvy, 1254). It is \u003cspan class=\\\"ignore\\\"\u003enarrow-minded\u003c/span\u003e because it posits the reality of the \u003cspan data-glossary-id=\\\"UT22084-060-005-548\\\"\u003eelements\u003c/span\u003e of existence as apparently perceived and because it aspires only to personal \u003cspan data-glossary-id=\\\"UT22084-060-005-597\\\"\u003eliberation\u003c/span\u003e, not to the exaltation of buddhahood. \u003c/p\u003e\",\"names\":{\"english\":\"narrow-minded attitude\",\"tibetan\":\"ཉི་ཚེ་བའི་སྤྱོད་པ།\",\"sanskrit\":\"pradeśakārin\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nyi tshe ba’i spyod pa\"}},{\"uuid\":\"98c3a819-3960-4bb9-8f58-7eae9460a866\",\"authority\":\"57cd4911-e2ab-4593-ad53-c7611ddc5a7a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eI.e. the teachings of the \u003cspan data-glossary-id=\\\"UT22084-060-005-662\\\"\u003eDisciple Vehicle\u003c/span\u003e (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-060-005-662\\\"\u003eśrāvakayāna\u003c/span\u003e\u003c/em\u003e). See “\u003cspan data-glossary-id=\\\"UT22084-060-005-618\\\"\u003enarrow-minded attitudes\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"narrow-minded teachings\",\"tibetan\":\"ཉི་ཚེ་བའི་ཆོས།\",\"sanskrit\":\"pradeśika­dharma\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nyi tshe ba’i chos\"}},{\"uuid\":\"da113d8a-755f-4f94-a385-5870d5914e38\",\"authority\":\"05167374-c12f-4cf6-90c5-c27560f816dd\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThese consist of various mental distractions caused by the nine considerations “He has caused, causes, will cause wrong to me. He has caused, causes, will cause wrong to one dear to me. He has served, serves, will serve my enemies.”\u003c/p\u003e\",\"names\":{\"english\":\"nine causes of irritation\",\"tibetan\":\"ཀུན་ནས་མནར་གསེམས་ཀྱི་དངོས་པོ་དགུ\",\"sanskrit\":\"āghātavastu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kun nas mnar gsems kyi dngos po dgu\"}},{\"uuid\":\"6e69d4d1-3c64-4054-b80b-f68df19c83e8\",\"authority\":\"29cd2258-6a62-4cc6-9f95-6124900ba019\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the six \u003cspan data-glossary-id=\\\"UT22084-060-005-627\\\"\u003eoutsider\u003c/span\u003e teachers.\u003c/p\u003e\",\"names\":{\"english\":\"Nirgrantha Jñāti­putra\",\"tibetan\":\"གཅེར་བུ་གཉེན་གྱི་བུ།\",\"sanskrit\":\"nirgrantha jñāti­putra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gcer bu gnyen gyi bu\"}},{\"uuid\":\"512593ec-b15a-4f3e-af83-c0aa9e355a7b\",\"authority\":\"3315bb31-855f-4783-a45d-6b80757e8ea7\",\"definition\":\"\",\"names\":{\"english\":\"Nitya­prahasita­pramuditendriya\",\"tibetan\":\"རྟག་ཏུ་དགའ་དགོད་དབང་པོ།\",\"sanskrit\":\"nitya­prahasita­pramuditendriya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rtag tu dga’ dgod dbang po\"}},{\"uuid\":\"4154a397-b0c4-44d0-8735-f4277fa10fa0\",\"authority\":\"ca9260f5-e5d2-485d-ad61-9e3bb89fd72e\",\"definition\":\"\",\"names\":{\"english\":\"Nityotkaṇṭhita\",\"tibetan\":\"རྟག་ཏུ་གདུང་།\",\"sanskrit\":\"nityotkaṇṭhita\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rtag tu gdung\"}},{\"uuid\":\"422054a4-3e86-4231-a05b-fa865fd6a4af\",\"authority\":\"da64b5c8-a8e1-41c2-bbf7-4c65701f9e5e\",\"definition\":\"\",\"names\":{\"english\":\"Nityotkṣipta­hasta\",\"tibetan\":\"རྟག་ཏུ་ལག་བརྐྱང་།\",\"sanskrit\":\"nityotkṣipta­hasta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rtag tu lag brkyang\"}},{\"uuid\":\"ae745020-8cbf-467e-9578-149274e7551d\",\"authority\":\"c1c4f55d-5ab2-4ecf-83e8-f7073b7346db\",\"definition\":\"\",\"names\":{\"english\":\"Nityotpalakṛta­hasta\",\"tibetan\":\"རྟག་ཏུ་ལག་བཏེག\",\"sanskrit\":\"nityotpalakṛta­hasta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rtag tu lag bteg\"}},{\"uuid\":\"335e47c2-eb5f-458f-89d8-346e929bc433\",\"authority\":\"207f5f53-fc1e-434b-8151-bc7b63581fd5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e‍—\u003c/p\u003e\",\"names\":{\"english\":\"noble\",\"tibetan\":\"འཕགས་པ།\",\"sanskrit\":\"ārya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’phags pa\"}},{\"uuid\":\"0f06ed1e-e4b7-40e4-acd7-d58e27e71907\",\"authority\":\"e4681e66-759e-4d4a-b650-1ee5acf5f0fd\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA practitioner of the \u003cspan data-glossary-id=\\\"UT22084-060-005-662\\\"\u003eDisciple Vehicle\u003c/span\u003e teaching who has reached at least the initial stages of realization. \u003c/p\u003e\",\"names\":{\"english\":\"noble disciple\",\"tibetan\":\"འཕགས་པ་ཉན་ཐོས།\",\"sanskrit\":\"āryaśrāvāka\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’phags pa nyan thos\"}},{\"uuid\":\"5bcad558-679e-41c8-a730-6e36945799b6\",\"authority\":\"85e00c7b-2c93-4630-9874-f0735613a307\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThis is synonymous with reality, \u003cspan data-glossary-id=\\\"UT22084-060-005-689\\\"\u003evoidness\u003c/span\u003e, etc. But it must be remembered that \u003cspan class=\\\"ignore\\\"\u003enonduality\u003c/span\u003e does not necessarily mean unity, that unity is only one of the pair unity-duality; hence \u003cspan class=\\\"ignore\\\"\u003enonduality\u003c/span\u003e implies nonunity as well. This point is obscured by designating this nondual philosophy as “monism,” as too many modern scholars have done.\u003c/p\u003e\",\"names\":{\"english\":\"nonduality\",\"tibetan\":\"གཉིས་སུ་མེད་པ།\",\"sanskrit\":\"advayatvā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gnyis su med pa\"}},{\"uuid\":\"c35fa257-9bec-472c-a315-46542dc21d4f\",\"authority\":\"1d2757e3-4008-41a0-b468-b2f1e5cb17c8\",\"definition\":\"\",\"names\":{\"english\":\"object-perception\",\"tibetan\":\"ལྷག་པར་དམིགས་པ།\",\"sanskrit\":\"adhyālambana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lhag par dmigs pa\"}},{\"uuid\":\"97a63228-3505-450d-8da8-b17f2117e156\",\"authority\":\"c90cb8c8-5e5b-4d54-bcae-310e30ba3ce8\",\"definition\":\"$6a\",\"names\":{\"english\":\"omniscience\",\"tibetan\":\"ཐམས་ཅད་མཁྱེན་པ།\",\"sanskrit\":\"sarvajñatā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"thams cad mkhyen pa\"}},{\"uuid\":\"b121c9a5-7c63-4bc5-be7a-4f7ac29b7113\",\"authority\":\"e5604cfb-e911-4e7f-9708-377807a2a901\",\"definition\":\"$6b\",\"names\":{\"english\":\"outsider\",\"tibetan\":\"མུ་སྟེགས་པ།\",\"sanskrit\":\"tīrthika\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mu stegs pa\"}},{\"uuid\":\"44254284-9334-4b34-8b2d-6f5cf820de7c\",\"authority\":\"c05656a4-30ea-4ba3-bfde-1b1f85828f6d\",\"definition\":\"\",\"names\":{\"english\":\"Padmaśrī­garbha\",\"tibetan\":\"པད་མོའི་དཔལ་གྱི་སྙིང་པོ།\",\"sanskrit\":\"padmaśrī­garbha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"pad mo’i dpal gyi snying po\"}},{\"uuid\":\"756c2e26-9432-402a-9082-2ca16ae0d1cb\",\"authority\":\"c296ed4d-f7aa-498f-8885-b43ca25466e0\",\"definition\":\"\",\"names\":{\"english\":\"Padmavyūha\",\"tibetan\":\"པད་མོ་བཀོད་པ།\",\"sanskrit\":\"padmavyūha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"pad mo bkod pa\"}},{\"uuid\":\"b0b04164-1cec-4c95-9c78-54e5889bc61c\",\"authority\":\"5f875178-30a6-4f0b-942f-f4df56125bfb\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe canonical language of Ceylonese Buddhists, believed to be very similar to the colloquial language spoken by \u003cspan data-glossary-id=\\\"UT22084-060-005-794\\\"\u003eŚākyamuni\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Pāli\",\"tibetan\":\"\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"\"}},{\"uuid\":\"f3755f91-c27d-4968-894e-14796bd04545\",\"authority\":\"be11b8dd-4778-46e8-ae9d-69f060ba11a8\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA more emphatic term for \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-060-005-621\\\"\u003enirvāṇa\u003c/span\u003e\u003c/em\u003e, when it is used in reference to the apparent passing away of a physical body of a \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003ebuddha\u003c/span\u003e. \u003c/p\u003e\",\"names\":{\"english\":\"parinirvāṇa\",\"tibetan\":\"ཡོངས་སུ་མྱ་ངན་ལས་འདས་པ།\",\"sanskrit\":\"parinirvāṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yongs su mya ngan las ’das pa\"}},{\"uuid\":\"e2d62fe8-36f7-47bd-9cda-305b2c1b66eb\",\"authority\":\"99a52c06-2268-45ba-9749-93d1043a002a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eIn general, a joyous attitude to help living beings and accomplish virtue. This is also the first stirring in the \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattva\u003c/span\u003e’s mind of the inspiration to attain \u003cspan data-glossary-id=\\\"UT22084-060-005-551\\\"\u003eenlightenment\u003c/span\u003e (see “\u003cspan data-glossary-id=\\\"UT22084-060-005-576\\\"\u003ehigh resolve\u003c/span\u003e”). See Lamotte, Appendice, Note II. \u003c/p\u003e\",\"names\":{\"english\":\"positive thought\",\"tibetan\":\"བསམ་པ།\",\"sanskrit\":\"āśaya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bsam pa\"}},{\"uuid\":\"5564b952-2491-426c-bb6f-96b0b05d818b\",\"authority\":\"fb94d08a-4273-46dc-b857-e1962e88f22b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the nonmental \u003cspan data-glossary-id=\\\"UT22084-060-005-616\\\"\u003emotivations\u003c/span\u003e, defined as the force of \u003cspan class=\\\"ignore\\\"\u003elife\u003c/span\u003e-duration, being a concept of the \u003cspan data-glossary-id=\\\"UT22084-060-005-498\\\"\u003eAbhidharma\u003c/span\u003e. See T. Stcherbatski, \u003ccite class=\\\"title text-en\\\" lang=\\\"en\\\"\u003eCentral Conception of Buddhism\u003c/cite\u003e (London, 1923), p. 105. \u003c/p\u003e\",\"names\":{\"english\":\"power of life\",\"tibetan\":\"སྲོག་གི་དབང་པོ།\",\"sanskrit\":\"jīvitendriya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"srog gi dbang po\"}},{\"uuid\":\"cf3a76e9-a92a-4a86-b54c-4af980edd52f\",\"authority\":\"a028aa20-15be-41bd-a94d-3bf63821138f\",\"definition\":\"\",\"names\":{\"english\":\"Prabhāketu\",\"tibetan\":\"འོད་ཀྱི་ཏོག\",\"sanskrit\":\"prabhāketu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’od kyi tog\"}},{\"uuid\":\"8dce1d66-6c81-4cb2-9f01-af3cc8e5b340\",\"authority\":\"a5e120bf-2a30-439c-8a43-51bf96654705\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattva\u003c/span\u003e present in the opening assembly, who later tells the story of his encounter with \u003cspan data-glossary-id=\\\"UT22084-060-005-1257\\\"\u003eVimalakīrti\u003c/span\u003e, who discourses to him about the \u003cspan data-glossary-id=\\\"UT22084-060-005-648\\\"\u003eseat of enlightenment\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Prabhāvyūha\",\"tibetan\":\"འོད་བཀོད་པ།\",\"sanskrit\":\"prabhāvyūha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’od bkod pa\"}},{\"uuid\":\"995806eb-a22d-4ef1-98c4-caa37076459c\",\"authority\":\"a5d7c117-2b70-4edd-9792-55a0fef7096d\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003ebuddhas\u003c/span\u003e who assembled at \u003cspan data-glossary-id=\\\"UT22084-060-005-1257\\\"\u003eVimalakīrti\u003c/span\u003e’s house to teach esoteric practices, according to the goddess (Chap. 7).\u003c/p\u003e\",\"names\":{\"english\":\"Prabhūtaratna\",\"tibetan\":\"རིན་ཆེན་མང་།\",\"sanskrit\":\"prabhūtaratna\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rin chen mang\"}},{\"uuid\":\"d4e82310-babf-4349-a016-7849f020c922\",\"authority\":\"62c91c63-830e-45b0-bf40-fa3a47cc241e\",\"definition\":\"\",\"names\":{\"english\":\"Prajñākūta\",\"tibetan\":\"ཤེས་རབ་བརྩེགས།\",\"sanskrit\":\"prajñākūta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shes rab brtsegs\"}},{\"uuid\":\"9766cba6-2a43-4122-9ec8-5c4bd430c239\",\"authority\":\"d8acec8f-b4a6-474e-9ce4-27ffb7a009cf\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eTranscendental \u003cspan data-glossary-id=\\\"UT22084-060-005-691\\\"\u003ewisdom\u003c/span\u003e, being the profound nondual understanding of the \u003cspan data-glossary-id=\\\"UT22084-060-005-683\\\"\u003eultimate\u003c/span\u003e reality, or \u003cspan data-glossary-id=\\\"UT22084-060-005-689\\\"\u003evoidness\u003c/span\u003e, or \u003cspan data-glossary-id=\\\"UT22084-060-005-640\\\"\u003erelativity\u003c/span\u003e, of all things; personified as a goddess, she is worshiped as the “Mother of all \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddhas\u003c/span\u003e” (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eSarva­jina­mātā\u003c/em\u003e). \u003c/p\u003e\",\"names\":{\"english\":\"Prajñā­pāramitā\",\"tibetan\":\"ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ།\",\"sanskrit\":\"prajñā­pāramitā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shes rab kyi pha rol tu phyin pa\"}},{\"uuid\":\"ab4d6b2c-102c-4a30-9c91-c3238504a23e\",\"authority\":\"127b5afb-eb39-41c2-8a5b-4cfb8d35884b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe \u003cspan data-glossary-id=\\\"UT22084-060-005-670\\\"\u003esūtra\u003c/span\u003e in which the transcendental \u003cspan data-glossary-id=\\\"UT22084-060-005-691\\\"\u003ewisdom\u003c/span\u003e is taught. There are nineteen versions of different lengths, ranging from the \u003ccite class=\\\"title text-en\\\" lang=\\\"en\\\"\u003eHeart Sūtra\u003c/cite\u003e of a few pages to the \u003ccite class=\\\"title text-en\\\" lang=\\\"en\\\"\u003eHundred-Thousand\u003c/cite\u003e. A great deal of information about these \u003cspan data-glossary-id=\\\"UT22084-060-005-670\\\"\u003esūtras\u003c/span\u003e can be found in the works of Dr. Edward Conze. \u003c/p\u003e\",\"names\":{\"english\":\"Prajñā­pāramitā­sūtra\",\"tibetan\":\"ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པའི་མདོ།\",\"sanskrit\":\"prajñā­pāramitā­sūtra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shes rab kyi pha rol tu phyin pa’i mdo\"}},{\"uuid\":\"dfafe214-f0c6-40bc-a862-534f47ad0264\",\"authority\":\"5556a0be-cc98-428f-ac3c-165369b97c5a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e A commentary on the \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-060-005-853\\\"\u003ePrajñā­pāramitā­sūtras\u003c/span\u003e\u003c/cite\u003e, composed by \u003cspan data-glossary-id=\\\"UT22084-060-005-734\\\"\u003eKumārajīva\u003c/span\u003e from oral traditions derived from \u003cspan data-glossary-id=\\\"UT22084-060-005-753\\\"\u003eNāgārjuna\u003c/span\u003e, and partially translated from Chinese into French by Dr. Etienne Lamotte, as \u003ccite class=\\\"title\\\"\u003eTraité de la Grande Vertu de la Sagesse\u003c/cite\u003e, Louvain, 1944-1949 (Bibliotheque du Museon, 18). \u003c/p\u003e\",\"names\":{\"english\":\"Prajñā­pāramitopadeśa\",\"tibetan\":\"\",\"sanskrit\":\"prajñā­pāramitopadeśa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"\"}},{\"uuid\":\"2bf4aa37-39a8-4e5f-a550-1d7a2011b292\",\"authority\":\"62b31890-9635-492d-b327-113c62a83bde\",\"definition\":\"\",\"names\":{\"english\":\"Prāmodyarāja\",\"tibetan\":\"མཆོག་ཏུ་དགའ་བའི་རྒྱལ་པོ།\",\"sanskrit\":\"prāmodyarāja\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mchog tu dga’ ba’i rgyal po\"}},{\"uuid\":\"91735aff-cd3e-4929-9a5b-d3b24dd7e651\",\"authority\":\"5b7a879a-7f60-4700-a8cb-8011282d5458\",\"definition\":\"\",\"names\":{\"english\":\"Praṇidhi­prayāta­prāpta\",\"tibetan\":\"སྨོན་ལམ་ལ་ཞུགས་པས་ཕྱིན་པ།\",\"sanskrit\":\"praṇidhi­prayāta­prāpta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"smon lam la zhugs pas phyin pa\"}},{\"uuid\":\"9ecd7639-710c-4154-8fc2-9e82f039ba06\",\"authority\":\"8f6d5349-1144-4691-b3e4-617c93d48af4\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe sub-school of the \u003cspan data-glossary-id=\\\"UT22084-060-005-603\\\"\u003eMādhyamika\u003c/span\u003e philosophical school founded by \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e-Pālita and further developed by \u003cspan data-glossary-id=\\\"UT22084-060-005-714\\\"\u003eCandrakīrti\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Prāsaṅgika\",\"tibetan\":\"ཐལ་འགྱུར་བ།\",\"sanskrit\":\"prāsaṅgika\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"thal ’gyur ba\"}},{\"uuid\":\"4a5c106e-cd41-4cc2-a93d-9512253462b6\",\"authority\":\"63f9450f-dbe5-4f1a-b931-4fe832992130\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-060-005-714\\\"\u003eCandrakīrti\u003c/span\u003e’s major commentary on \u003cspan data-glossary-id=\\\"UT22084-060-005-753\\\"\u003eNāgārjuna\u003c/span\u003e’s \u003ccite class=\\\"title text-en\\\" lang=\\\"en\\\"\u003eFundamental Stanzas on Wisdom\u003c/cite\u003e. \u003c/p\u003e\",\"names\":{\"english\":\"Prasannapadā\",\"tibetan\":\"ཚིག་གསལ།\",\"sanskrit\":\"prasannapadā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"tshig gsal\"}},{\"uuid\":\"97646ee8-ea9e-44b7-bb03-e0014921a6ed\",\"authority\":\"cec0aaaa-2511-43d5-8318-5d3f457696f3\",\"definition\":\"\",\"names\":{\"english\":\"Pratibhāna­kūṭa\",\"tibetan\":\"སྤོབས་པ་བརྩེགས་པ།\",\"sanskrit\":\"pratibhāna­kūṭa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"spobs pa brtsegs pa\"}},{\"uuid\":\"d679eb3d-889d-4c44-8432-f9fd73c8d4d8\",\"authority\":\"db02a6c7-38d1-4ec3-b7dd-b5261913ffc1\",\"definition\":\"\",\"names\":{\"english\":\"Prati­saṃvit­praṇāda­prāpta\",\"tibetan\":\"སོ་སོ་ཡང་དག་པར་རིག་པ་རབ་ཏུ་བསྒྲུབ་པ་ཐོབ།\",\"sanskrit\":\"prati­saṃvitpraṇāda­prāpta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"so so yang dag par rig pa rab tu bsgrub pa thob\"}},{\"uuid\":\"016a95f6-6eed-41e7-a916-3b9098b27158\",\"authority\":\"f42315f4-3cee-44ca-872f-8a076ac1f696\",\"definition\":\"$6c\",\"names\":{\"english\":\"pratyekabuddha\",\"tibetan\":\"རང་སངས་རྒྱས།\",\"sanskrit\":\"pratyekabuddha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rang sangs rgyas\"}},{\"uuid\":\"9dc6b0a5-e62b-4272-8089-ad2c7dd4f16c\",\"authority\":\"9df6cb22-9050-4fba-a510-bc97ac8e334d\",\"definition\":\"\",\"names\":{\"english\":\"Priyadarśana\",\"tibetan\":\"མཐོང་དགའ།\",\"sanskrit\":\"priyadarśana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mthong dga’\"}},{\"uuid\":\"04c383e3-5363-4b5d-bbb1-1e811f55c9e6\",\"authority\":\"f8429b0a-adf2-4e84-b1fc-2fc82d139bd1\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the six \u003cspan data-glossary-id=\\\"UT22084-060-005-627\\\"\u003eoutsider\u003c/span\u003e teachers.\u003c/p\u003e\",\"names\":{\"english\":\"Purāṇa Kāśyapa\",\"tibetan\":\"འོད་སྲུང་རྫོགས་བྱེད།\",\"sanskrit\":\"purāṇa kāśyapa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’od srung rdzogs byed\"}},{\"uuid\":\"a952daa2-b766-4a8f-a19e-633af3c5e6e2\",\"authority\":\"0281f417-c058-460c-ae73-badb10ec532c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-060-005-661\\\"\u003eŚrāvaka\u003c/span\u003e disciple of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e noted for his ability as a preacher of the Hinayāna teaching, especially skillful in the conversion and training of young monks; also known as \u003cspan data-glossary-id=\\\"UT22084-060-005-773\\\"\u003ePūrṇa­maitrāyaṇī­putra\u003c/span\u003e. See also \u003ca href=\\\"end-notes.xhtml#UT22084-060-005-934\\\" data-pointer-type=\\\"id\\\"\u003en.72\u003c/a\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Pūrṇa\",\"tibetan\":\"གང་པོ།\",\"sanskrit\":\"pūrṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gang po\"}},{\"uuid\":\"b95c7876-5459-44f6-86d0-2ff03ab2e84d\",\"authority\":\"63050a6e-0810-497f-a1fd-0cb013530a20\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee \u003cspan data-glossary-id=\\\"UT22084-060-005-772\\\"\u003ePūrṇa\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Pūrṇa­maitrāyaṇī­putra\",\"tibetan\":\"བྱམས་མའི་བུ་གང་པོ།\",\"sanskrit\":\"pūrṇa­maitrāyaṇī­putra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"byams ma’i bu gang po\"}},{\"uuid\":\"5a2b5afb-3eda-4a81-9892-6c2e79d6fd75\",\"authority\":\"a05175c9-e2b3-438b-bfb4-4670ca3ddf37\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-060-005-794\\\"\u003eŚākyamuni\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e’s own son, who became a distinguished disciple. See also \u003ca href=\\\"end-notes.xhtml#UT22084-060-005-945\\\" data-pointer-type=\\\"id\\\"\u003en.83\u003c/a\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Rāhula\",\"tibetan\":\"སྒྲ་གཅན་འཛིན།\",\"sanskrit\":\"rāhula\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sgra gcan ’dzin\"}},{\"uuid\":\"7989e812-179e-4295-8a13-cbb38e892c88\",\"authority\":\"002d5bdd-1a6f-4472-b564-151f1c31a972\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003ebuddhas\u003c/span\u003e who assembled at \u003cspan data-glossary-id=\\\"UT22084-060-005-1257\\\"\u003eVimalakīrti\u003c/span\u003e’s house to teach the \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eTathāgata­guhyaka\u003c/cite\u003e, according to the goddess. \u003c/p\u003e\",\"names\":{\"english\":\"Ratnacandra\",\"tibetan\":\"དཀོན་མཆོག་ཟླ་བ།\",\"sanskrit\":\"ratnacandra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dkon mchog zla ba\"}},{\"uuid\":\"33c0afab-6d36-4aa0-a580-56e19e22fc70\",\"authority\":\"6170b300-40ed-4afb-a23c-100b7ae2072b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eWheel-turning king said by the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e to be a former \u003cspan data-glossary-id=\\\"UT22084-060-005-582\\\"\u003eincarnation\u003c/span\u003e of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-060-005-783\\\"\u003eRatnārcis\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Ratnacchattra\",\"tibetan\":\"རིན་ཆེན་གདུགས།\",\"sanskrit\":\"ratnacchattra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rin chen gdugs\"}},{\"uuid\":\"d034f7ba-4307-44fe-9832-ed8bfb98b1e8\",\"authority\":\"d44a2372-c3a5-4c5b-9075-57e1f6f59056\",\"definition\":\"\",\"names\":{\"english\":\"Ratnajaha\",\"tibetan\":\"རིན་ཆེན་གཏོང་།\",\"sanskrit\":\"ratnajaha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rin chen gtong\"}},{\"uuid\":\"2f400df3-fb3c-4bd3-85ce-4b223afd1aad\",\"authority\":\"90b61789-4863-414e-973d-f2f008e3ad78\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eWealthy young \u003cspan data-glossary-id=\\\"UT22084-060-005-599\\\"\u003eLicchavi\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-060-005-505\\\"\u003enoble\u003c/span\u003e who leads the delegation that brings the precious parasols to the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Ratnākara\",\"tibetan\":\"དཀོན་མཆོག་འབྱུང་གནས།\",\"sanskrit\":\"ratnākara\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dkon mchog ’byung gnas\"}},{\"uuid\":\"723816e2-004f-4362-aa21-7cb78f09ac3b\",\"authority\":\"85a201ea-3de1-4bee-a405-61688a5d36b2\",\"definition\":\"\",\"names\":{\"english\":\"Ratnakūṭa\",\"tibetan\":\"རིན་པོ་ཆེ་བརྩེགས་པ།\",\"sanskrit\":\"ratnakūṭa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rin po che brtsegs pa\"}},{\"uuid\":\"c7cfa18a-058f-45d4-af3c-4ce2b8db6f41\",\"authority\":\"adcf1da0-67fc-4c3b-bb43-2201b2c9a768\",\"definition\":\"\",\"names\":{\"english\":\"Ratna­mudrā­hasta\",\"tibetan\":\"ལག་ན་ཕྱག་རྒྱ་རིན་པོ་ཆེ།\",\"sanskrit\":\"ratna­mudrā­hasta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lag na phyag rgya rin po che\"}},{\"uuid\":\"054447fa-19dd-4470-ba6f-bdc20d692e8a\",\"authority\":\"f77a942d-3d9c-4aa1-a115-ea7687225e9e\",\"definition\":\"\",\"names\":{\"english\":\"Ratnananda\",\"tibetan\":\"རིན་ཆེན་དགའ་བ།\",\"sanskrit\":\"ratnananda\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rin chen dga’ ba\"}},{\"uuid\":\"d53315cb-70f2-4ec6-8745-465e59be364f\",\"authority\":\"95db7154-78ef-43d6-91d2-1179f23937c4\",\"definition\":\"\",\"names\":{\"english\":\"Ratnapāṇi\",\"tibetan\":\"ལག་ན་རིན་པོ་ཆེ།\",\"sanskrit\":\"ratnapāṇi\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lag na rin po che\"}},{\"uuid\":\"ff9b0a9a-22be-42d1-99c5-b4079b71a5c0\",\"authority\":\"6dbcacec-167b-403e-964e-914ac0b5bd44\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA mountain.\u003c/p\u003e\",\"names\":{\"english\":\"Ratnaparvata\",\"tibetan\":\"རིན་པོ་ཆེའི་རི།\",\"sanskrit\":\"ratnaparvata\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rin po che’i ri\"}},{\"uuid\":\"83e05c6d-d7a0-4aba-b09f-19b2f23c3bcf\",\"authority\":\"f76694e8-6d53-4391-8921-60bc57ba33f9\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003ebuddhas\u003c/span\u003e who appear in the house of \u003cspan data-glossary-id=\\\"UT22084-060-005-1257\\\"\u003eVimalakīrti\u003c/span\u003e on esoteric occasions. According to the \u003cspan data-glossary-id=\\\"UT22084-060-005-633\\\"\u003ePrajñā­pāramitā\u003c/span\u003e, he is the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e of the universe Upaśānta, in the western direction (see Lamotte, p. 384, n. 27).\u003c/p\u003e\",\"names\":{\"english\":\"Ratnārcis\",\"tibetan\":\"དཀོན་མཆོག་འོད་འཕྲོ།\",\"sanskrit\":\"ratnārcis\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dkon mchog ’od ’phro\"}},{\"uuid\":\"93554961-8bff-46d8-90b2-3b1d358beb0c\",\"authority\":\"9bf340ae-8992-4c0f-b48d-909aa46d2ace\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003ebuddhas\u003c/span\u003e who appear in the house of \u003cspan data-glossary-id=\\\"UT22084-060-005-1257\\\"\u003eVimalakīrti\u003c/span\u003e on esoteric occasions; the Sanskrit name, but with a different rendering in Tibetan, also refers to a \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattva\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Ratnaśrī\",\"tibetan\":\"དཀོན་མཆོག་དཔལ།\",\"sanskrit\":\"ratnaśrī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dkon mchog dpal\"}},{\"uuid\":\"dd29d6aa-cb0b-4df5-b590-014daf33b3d6\",\"authority\":\"a2b508ed-e85f-464c-a654-3cb7dc68f62c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattva\u003c/span\u003e; the Sanskrit name, but with a different rendering in Tibetan, also refers to a \u003cspan data-glossary-id=\\\"UT22084-060-005-672\\\"\u003etathāgata\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Ratnaśrī\",\"tibetan\":\"རིན་ཆེན་དཔལ།\",\"sanskrit\":\"ratnaśrī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rin chen dpal\"}},{\"uuid\":\"50724418-d968-4416-b0d9-c28f9f96a1ca\",\"authority\":\"58bf469b-451b-445d-8e89-fb51eff695f5\",\"definition\":\"\",\"names\":{\"english\":\"Ratnavīra\",\"tibetan\":\"རིན་ཆེན་དཔའ།\",\"sanskrit\":\"ratnavīra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rin chen dpa’\"}},{\"uuid\":\"fccb3001-894d-4827-ad90-67e7ff6eabce\",\"authority\":\"88c34127-4c5c-4d55-80ca-9dfbd1f85734\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eLit. “Jewel-Array.” Name of one of the \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattvas\u003c/span\u003e in the original assembly (rendered in Tibetan as \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003erin chen bkod pa\u003c/em\u003e); also the name (with several renderings in Tibetan) of a \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003ebuddha\u003c/span\u003e who presides in the universe called \u003cspan data-glossary-id=\\\"UT22084-060-005-826\\\"\u003eAnanta­guṇa­ratna­vyūha\u003c/span\u003e, yet who comes to \u003cspan data-glossary-id=\\\"UT22084-060-005-1257\\\"\u003eVimalakīrti\u003c/span\u003e’s house at the latter’s supplication, to participate in the esoteric teachings. He can be identified with the \u003cspan data-glossary-id=\\\"UT22084-060-005-672\\\"\u003eTathāgata\u003c/span\u003e Ratnasaṃbhava, one of the five major \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003ebuddhas\u003c/span\u003e of the \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eGuhya­samāja­tantra\u003c/cite\u003e. \u003c/p\u003e\",\"names\":{\"english\":\"Ratnavyūha\",\"tibetan\":\"དཀོན་མཆོག་དཀོད་པ།, རིན་ཆེན་བཀོད་པ།, རིན་པོ་ཆེ་བཀོད་པ།\",\"sanskrit\":\"ratnavyūha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dkon mchog dkod pa, rin chen bkod pa, rin po che bkod pa\"}},{\"uuid\":\"9efcf73c-26a0-408c-9171-b6aef3035f7a\",\"authority\":\"0075299c-d2d8-40ae-85a6-6684eac0376c\",\"definition\":\"\",\"names\":{\"english\":\"Ratnayaṣṭin\",\"tibetan\":\"རིན་ཆེན་གདན་དཀར་ཅན།\",\"sanskrit\":\"ratnayaṣṭin\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rin chen gdan dkar can\"}},{\"uuid\":\"88a06c9a-f3cb-489e-b482-d2f4264220ae\",\"authority\":\"bc8c6439-fe10-4afc-896b-9a652d33d930\",\"definition\":\"\",\"names\":{\"english\":\"Ratnolkā­dhārin\",\"tibetan\":\"རིན་ཆེན་སྒྲོན་མ་འཛིན།\",\"sanskrit\":\"ratnolkā­dhārin\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rin chen sgron ma ’dzin\"}},{\"uuid\":\"fe59fd73-89db-4934-9361-12927e5e3e5b\",\"authority\":\"474544b7-f5a4-4439-b00f-30a1e436a12d\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA synonym of the \u003cspan data-glossary-id=\\\"UT22084-060-005-683\\\"\u003eultimate\u003c/span\u003e reality. In the \u003cspan data-glossary-id=\\\"UT22084-060-005-605\\\"\u003eMahāyāna\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-060-005-670\\\"\u003esūtras\u003c/span\u003e, it has a somewhat negative flavor, connoting the Hinayāna concept of a static \u003cspan data-glossary-id=\\\"UT22084-060-005-621\\\"\u003enirvāṇa\u003c/span\u003e. \u003cspan data-glossary-id=\\\"UT22084-060-005-809\\\"\u003eSthiramati\u003c/span\u003e glosses the term as follows: “ ‘Reality’ means undistorted truth. ‘Limit’ means the extreme beyond which there is nothing to be known by anyone” (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003ebhūtaṃ satyam aviparītamityarthaḥ / koṭiḥ paryanto yataḥ pareṇa-anyajjñeyaṃ nāsti…/\u003c/em\u003e). \u003c/p\u003e\",\"names\":{\"english\":\"reality-limit\",\"tibetan\":\"ཡང་དག་པའི་མཐའ།\",\"sanskrit\":\"bhūtakoṭi\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yang dag pa’i mtha’\"}},{\"uuid\":\"b61ff573-1c3d-4da4-ad62-805395b82896\",\"authority\":\"e10b59ca-5e79-48d3-b161-5d8bf612491f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eIn Buddhist cosmology, this is our own realm, the lowest and most coarse of the three realms of saṃsāra. It is called this because beings here are characterized by their strong longing for and attachment to the pleasures of the senses. The desire realm includes hell beings, hungry ghosts, animals, humans, asuras, and the lowest six heavens of the gods‍—from the Heaven of the Four Great Kings (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003ecāturmahā­rājika\u003c/em\u003e) up to the Heaven of Making Use of Others’ Emanations (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003epara­nirmita­vaśa­vartin\u003c/em\u003e). Located above the desire realm is the form realm (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003erūpadhātu\u003c/em\u003e) and the formless realm (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eārūpyadhātu\u003c/em\u003e).\u003c/p\u003e\",\"names\":{\"english\":\"realm of desire\",\"tibetan\":\"འདོད་ཁམས།\",\"sanskrit\":\"kāmadhātu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’dod khams\"}},{\"uuid\":\"435305a6-61e7-4eab-874f-001d28ba913d\",\"authority\":\"44c5da79-4e28-4cf5-a0bd-34763c4c4430\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the three realms of saṃsāra in Buddhist cosmology, it is characterized by subtle materiality. Here beings, though subtly embodied, are not driven primarily by the urge for sense gratification. It consists of seventeen heavens structured according to the four concentrations of the form realm (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003erūpāvacaradhyāna\u003c/em\u003e), the highest five of which are collectively called “pure abodes” (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eśuddhāvāsa\u003c/em\u003e). The form realm is located above the desire realm (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003ekāmadhātu\u003c/em\u003e) and below the formless realm (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eārūpya­dhātu\u003c/em\u003e). \u003c/p\u003e\",\"names\":{\"english\":\"realm of pure matter\",\"tibetan\":\"གཟུགས་ཁམས།\",\"sanskrit\":\"rūpadhātu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gzugs khams\"}},{\"uuid\":\"b1f05db9-7380-4a8c-b8c2-ff2145a720b9\",\"authority\":\"4f9bab09-628a-4c9d-91b7-7f9eebd8443f\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe twelfth of the \u003cspan data-glossary-id=\\\"UT22084-060-005-545\\\"\u003eeighteen special qualities of a bodhisattva\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"reconciliation of dichotomies, reconciling dichotomies\",\"tibetan\":\"སྣྲེལ་ཞི་བ།, སྣྲེལ་ཞིའི་རྒྱུད།\",\"sanskrit\":\"yamaka­vyatyastāhāra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"snrel zhi ba, snrel zhi’i rgyud\"}},{\"uuid\":\"ee159495-5ad2-4056-8ec0-27e368dabfa3\",\"authority\":\"9131f8de-10a9-4c7c-872f-ebfe1eba2f32\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eMentioned by the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e as the last of the thousand \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003ebuddhas\u003c/span\u003e of this eon.\u003c/p\u003e\",\"names\":{\"english\":\"Roca\",\"tibetan\":\"སྣང་མཛད།\",\"sanskrit\":\"roca\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"snang mdzad\"}},{\"uuid\":\"1ece340f-64af-448c-8b6e-68cd5c2003d8\",\"authority\":\"66e4f9ac-8898-4396-be29-f004d2d9b902\",\"definition\":\"\",\"names\":{\"english\":\"sacrifice\",\"tibetan\":\"མཆོད་སྦྱིན།\",\"sanskrit\":\"yajña\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mchod sbyin\"}},{\"uuid\":\"257e3d74-3b1c-455d-83a6-167b779248c7\",\"authority\":\"53c4843a-47d4-4c6c-9809-8e95f5045eb3\",\"definition\":\"\u003cp\u003eThe name for our world system, the universe of a thousand million worlds, or trichiliocosm, in which the four-continent world is located. Each trichiliocosm is ruled by a god Brahmā; thus, in this context, he bears the title of Sahāṃpati, Lord of Sahā. The world system of Sahā, or Sahālokadhātu, is also described as the buddhafield of the Buddha Śākyamuni where he teaches the Dharma to beings. \u003c/p\u003e\u003cp\u003eThe name Sahā possibly derives from the Sanskrit \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003e√sah\u003c/em\u003e, “to bear, endure, or withstand.” It is often interpreted as alluding to the inhabitants of this world being able to endure the suffering they encounter. The Tibetan translation, \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003emi mjed\u003c/em\u003e, follows along the same lines. It literally means “not painful,” in the sense that beings here are able to bear the suffering they experience.\u003c/p\u003e\",\"names\":{\"english\":\"Sahā\",\"tibetan\":\"མི་མཇེད།\",\"sanskrit\":\"sahā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mi mjed\"}},{\"uuid\":\"03c76c10-e256-4018-9d81-4a08522d2e5b\",\"authority\":\"957219b5-7232-448f-95bb-6ab467cbfd10\",\"definition\":\"\",\"names\":{\"english\":\"Śaila­śikhara­saṃghaṭṭana­rāja\",\"tibetan\":\"རིའི་རྩེ་མོ་ཀུན་ཏུ་འཇོམས་པའི་རྒྱལ་པོ།\",\"sanskrit\":\"śaila­śikhara­saṃghaṭṭana­rāja\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ri’i rtse mo kun tu ’joms pa’i rgyal po\"}},{\"uuid\":\"ff52ab68-0ea9-42a5-a0ae-44db0fdbe3b6\",\"authority\":\"6fbdb5b0-3b2a-4d90-a1e1-76b9a42657e0\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eIn Buddhist texts, usual name for \u003cspan data-glossary-id=\\\"UT22084-060-005-725\\\"\u003eIndra\u003c/span\u003e, king of gods of the desire-realm (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003ekāmadhātu\u003c/em\u003e) of a particular universe; hence a \u003cspan class=\\\"ignore\\\"\u003eŚakra\u003c/span\u003e is lower in status than a \u003cspan data-glossary-id=\\\"UT22084-060-005-710\\\"\u003eBrahmā\u003c/span\u003e, who resides at the summit of the \u003cspan data-glossary-id=\\\"UT22084-060-005-638\\\"\u003erealm of pure matter\u003c/span\u003e (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003erūpadhātu\u003c/em\u003e). As in the case of \u003cspan data-glossary-id=\\\"UT22084-060-005-710\\\"\u003eBrahmā\u003c/span\u003e, a title, or status, rather than a personal name; each universe has its \u003cspan class=\\\"ignore\\\"\u003eŚakra\u003c/span\u003e. \u003c/p\u003e\",\"names\":{\"english\":\"Śakra\",\"tibetan\":\"བརྒྱ་བྱིན།\",\"sanskrit\":\"śakra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"brgya byin\"}},{\"uuid\":\"e1813d20-97df-4f46-931f-83299e213602\",\"authority\":\"5639292d-64cd-48c8-b5a4-fcc21d5b497a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eName of the tribe dwelling in Northern India in which Gautama, or \u003cspan data-glossary-id=\\\"UT22084-060-005-794\\\"\u003eŚākyamuni\u003c/span\u003e, \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e was born as prince Siddhārtha.\u003c/p\u003e\",\"names\":{\"english\":\"Śākya\",\"tibetan\":\"ཤཱཀྱ།\",\"sanskrit\":\"śākya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shAkya\"}},{\"uuid\":\"4dde3f3a-6487-4806-890b-da311468effb\",\"authority\":\"315d1554-9570-42a2-82a3-36f3790eccc9\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe “Sage of the \u003cspan data-glossary-id=\\\"UT22084-060-005-793\\\"\u003eŚākyas\u003c/span\u003e,” name of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e of our era, who lived c. 563-483 B.C.\u003c/p\u003e\",\"names\":{\"english\":\"Śākyamuni\",\"tibetan\":\"ཤཱཀྱ་ཐུབ་པ།\",\"sanskrit\":\"śākyamuni\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shAkya thub pa\"}},{\"uuid\":\"fe02c8d4-f771-472c-bc65-6a2253f39b06\",\"authority\":\"15c36550-8189-4baf-80ba-1da4ce496fdc\",\"definition\":\"\",\"names\":{\"english\":\"Samadarśin\",\"tibetan\":\"མཉམ་པར་ལྟ་བ།\",\"sanskrit\":\"samadarśin\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mnyam par lta ba\"}},{\"uuid\":\"410a8c3f-585a-4db1-8bc9-da909753bdfa\",\"authority\":\"befaa8af-c1cf-490c-9790-f94fb8e9f55f\",\"definition\":\"\",\"names\":{\"english\":\"Samādhi­vikurvaṇa­rāja\",\"tibetan\":\"ཏིང་ངེ་འཛིན་རྣམ་པར་སྤྲུལ་པའི་རྒྱལ་པོ།\",\"sanskrit\":\"samādhi­vikurvaṇa­rāja\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ting nge ’dzin rnam par sprul pa’i rgyal po\"}},{\"uuid\":\"d4226273-15f9-4a99-aaeb-e0c57ed06f4d\",\"authority\":\"8a5b5372-0c4d-4ada-a6a2-b95c39812a1f\",\"definition\":\"\",\"names\":{\"english\":\"Sama­viṣama­darśin\",\"tibetan\":\"མཉམ་མི་མཉམ་ལྟ་བ།\",\"sanskrit\":\"sama­viṣama­darśin\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mnyam mi mnyam lta ba\"}},{\"uuid\":\"bce502de-187d-4fc2-a938-fe32a4604973\",\"authority\":\"3f67b9bb-d5d4-4da7-8b6d-72d3b17ec7ed\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe “\u003cspan data-glossary-id=\\\"UT22084-060-005-670\\\"\u003eSūtra\u003c/span\u003e of the Revelation of the Inner Intention,” it was the most important \u003cspan data-glossary-id=\\\"UT22084-060-005-605\\\"\u003eMahāyāna\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-060-005-670\\\"\u003esūtra\u003c/span\u003e for \u003cspan data-glossary-id=\\\"UT22084-060-005-705\\\"\u003eĀryāsaṅga\u003c/span\u003e and the \u003cspan data-glossary-id=\\\"UT22084-060-005-687\\\"\u003eVijñānavāda\u003c/span\u003e school.\u003c/p\u003e\",\"names\":{\"english\":\"Saṃdhi­nirmocana­sūtra\",\"tibetan\":\"མདོ་སྡེ་དགོངས་འགྲེལ།\",\"sanskrit\":\"saṃdhi­nirmocana­sūtra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mdo sde dgongs ’grel\"}},{\"uuid\":\"60ccd035-bf37-4920-98b9-7356b7539474\",\"authority\":\"be0a8b75-887f-4948-83f4-428cc444188b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the six \u003cspan data-glossary-id=\\\"UT22084-060-005-627\\\"\u003eoutsider\u003c/span\u003e teachers.\u003c/p\u003e\",\"names\":{\"english\":\"Saṃjāyin Vairaṭi­putra, Saṃjāyin Vairāṭī­putra\",\"tibetan\":\"སྨྲ་འདོད་ཀྱི་བུ་མོའི་བུ་ཡང་དག་རྒྱལ་བ་ཅན།\",\"sanskrit\":\"saṃjāyin vairāṭī­putra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"smra ’dod kyi bu mo’i bu yang dag rgyal ba can\"}},{\"uuid\":\"8079c844-6aa8-475b-95cb-57354847781e\",\"authority\":\"a6bb1f1c-12ef-45a0-b058-d57fde15ecd2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eKing of the gods of the \u003cspan data-glossary-id=\\\"UT22084-060-005-847\\\"\u003eTuṣita\u003c/span\u003e heaven.\u003c/p\u003e\",\"names\":{\"english\":\"Saṃtuṣita\",\"tibetan\":\"ཡོངས་སུ་དགའ་ལྡན།\",\"sanskrit\":\"saṃtuṣita\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yongs su dga’ ldan\"}},{\"uuid\":\"62ef6630-ce39-4719-8c3d-8bc80c440c40\",\"authority\":\"9fdd9aab-c544-4a22-bde1-502c5f644ddb\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eLit. “perfectly accomplished \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e.” Name of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"saṃyaksaṃbuddha\",\"tibetan\":\"ཡང་དག་པར་རྫོགས་པའི་སངས་རྒྱས།\",\"sanskrit\":\"saṃyak­saṃbuddha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yang dag par rdzogs pa’i sangs rgyas\"}},{\"uuid\":\"02725146-032e-4372-bc0f-78777524f0aa\",\"authority\":\"34e21f8f-bc5b-45e8-ac86-82156fd45708\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe third of the Three Jewels (Triratna) of Buddhism, the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e, the Teaching, and the Community. Sometimes narrowly defined as the community of mendicants, it can be understood as including lay practitioners.\u003c/p\u003e\",\"names\":{\"english\":\"Saṅgha\",\"tibetan\":\"དགེ་འདུན།\",\"sanskrit\":\"saṅgha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dge ’dun\"}},{\"uuid\":\"15d5cc78-99a1-4fc0-98c7-3b943fc66f8d\",\"authority\":\"5d9ab7d8-f992-407e-beee-219ff9875106\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e(Eighth century). A great master of the \u003cspan data-glossary-id=\\\"UT22084-060-005-603\\\"\u003eMādhyamika\u003c/span\u003e, famous for his remarkable work, “Introduction to the Practice of \u003cspan data-glossary-id=\\\"UT22084-060-005-551\\\"\u003eEnlightenment\u003c/span\u003e” (\u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eBodhi­caryāvatāra\u003c/cite\u003e). \u003c/p\u003e\",\"names\":{\"english\":\"Śāntideva\",\"tibetan\":\"ཞི་བ་ལྷ།\",\"sanskrit\":\"śāntideva\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"zhi ba lha\"}},{\"uuid\":\"4da7d125-a1b8-4820-b50f-9de69a2ab346\",\"authority\":\"028f92a7-eb1f-4d2a-9d19-a4c4c188481c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the major \u003cspan data-glossary-id=\\\"UT22084-060-005-661\\\"\u003eśrāvaka\u003c/span\u003e disciples, paired with \u003cspan data-glossary-id=\\\"UT22084-060-005-751\\\"\u003eMaudgalyāyana\u003c/span\u003e, and noted for having been praised by the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e as foremost of the wise; hence, the most frequent target for \u003cspan data-glossary-id=\\\"UT22084-060-005-1257\\\"\u003eVimalakīrti\u003c/span\u003e’s attacks on the \u003cspan data-glossary-id=\\\"UT22084-060-005-661\\\"\u003eśrāvakas\u003c/span\u003e and on the Hinayāna in general.\u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(See also \u003ca href=\\\"end-notes.xhtml#UT22084-060-005-902\\\" data-pointer-type=\\\"id\\\"\u003en.40\u003c/a\u003e)\u003c/p\u003e\",\"names\":{\"english\":\"Śāriputra\",\"tibetan\":\"ཤཱ་རིའི་བུ།\",\"sanskrit\":\"śāriputra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shA ri’i bu\"}},{\"uuid\":\"193f54d9-b372-4370-90ff-5e1cbf04462b\",\"authority\":\"aafd4b8c-f64e-44fc-85a6-dcfa1dd795d5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eUniverse of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-060-005-724\\\"\u003eGandhottama­kūṭa\u003c/span\u003e; a universe wherein the \u003cspan data-glossary-id=\\\"UT22084-060-005-537\\\"\u003eDharma\u003c/span\u003e is taught through the medium of scent. According to Lamotte, p. 319, n. 2, this universe is mentioned in the \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-060-005-858\\\"\u003eŚikṣāsamuccaya\u003c/span\u003e\u003c/cite\u003e, the \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eLaṇkāvatāra\u003c/cite\u003e, and the \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-060-005-855\\\"\u003ePrasannapadā\u003c/span\u003e\u003c/cite\u003e. However, In the \u003cspan data-glossary-id=\\\"UT22084-060-005-855\\\"\u003ePrasannapadā\u003c/span\u003e, this universe is said to be ruled by Samantabhadra, not \u003cspan data-glossary-id=\\\"UT22084-060-005-724\\\"\u003eGandhottama­kūṭa\u003c/span\u003e (see Lamotte, p. 320, n. 3). \u003c/p\u003e\",\"names\":{\"english\":\"Sarva­gandha­sugandhā\",\"tibetan\":\"སྤོས་ཐམས་ཅད་ཀྱི་དྲི་མཆོག\",\"sanskrit\":\"sarva­gandha­sugandhā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"spos thams cad kyi dri mchog\"}},{\"uuid\":\"7b9a1090-b83a-4b4b-afc2-fd8fd3328bdd\",\"authority\":\"05cb7daf-1fb7-4f36-8fa3-f188d97fb6c6\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003ebuddhas\u003c/span\u003e who appear in \u003cspan data-glossary-id=\\\"UT22084-060-005-1257\\\"\u003eVimalakīrti\u003c/span\u003e’s house to teach the \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eTathāgata­guhyaka\u003c/cite\u003e, according to the goddess. \u003c/p\u003e\",\"names\":{\"english\":\"Sarvārtha­siddha\",\"tibetan\":\"དོན་ཐམས་ཅད་གྲུབ་པ།\",\"sanskrit\":\"sarvārtha­siddha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"don thams cad grub pa\"}},{\"uuid\":\"6a09bb1f-f2ea-4b10-83c0-4cb9fa8135cd\",\"authority\":\"b25253a5-b6a7-4fb1-b6d8-92445edad184\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThis \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattva\u003c/span\u003e asks \u003cspan data-glossary-id=\\\"UT22084-060-005-1257\\\"\u003eVimalakīrti\u003c/span\u003e the whereabouts of his family, etc., thus prompting the latter’s extraordinary verses on the family and accoutrements of all \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattvas\u003c/span\u003e (Chap. 8).\u003c/p\u003e\",\"names\":{\"english\":\"Sarva­rūpa­saṃdarśana\",\"tibetan\":\"གཟུགས་ཐམས་ཅད་སྟོན་པ།\",\"sanskrit\":\"sarva­rūpa­saṃdarśana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gzugs thams cad ston pa\"}},{\"uuid\":\"ff3e441e-4f09-4277-af22-97924bb950fb\",\"authority\":\"bb64f0e1-e3a7-4a40-9619-dc2631a86e14\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA universe, or \u003cspan data-glossary-id=\\\"UT22084-060-005-516\\\"\u003ebuddhafield\u003c/span\u003e, where the \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattvas\u003c/span\u003e live in a constant state of bliss. The Skt. of the Potala MS has Sarva­sukha­pratimaṇḍita, that of the excerpt cited in the \u003cspan data-glossary-id=\\\"UT22084-060-005-858\\\"\u003eŚikṣāsamuccaya\u003c/span\u003e has Sarvasukhamaṇḍitā.\u003c/p\u003e\",\"names\":{\"english\":\"Sarva­sukha­pratimaṇḍita\",\"tibetan\":\"བདེ་བ་ཐམས་ཅད་ཀྱིས་རབ་ཏུ་བརྒྱན་པ།\",\"sanskrit\":\"sarva­sukha­pratimaṇḍita\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bde ba thams cad kyis rab tu brgyan pa\"}},{\"uuid\":\"0a4d080d-b5a3-4338-aca4-f25ac1885cc0\",\"authority\":\"86112632-9318-4e0b-9c28-ddef9804531d\",\"definition\":\"\",\"names\":{\"english\":\"Satatodyukta\",\"tibetan\":\"རྟག་ཏུ་འབད།\",\"sanskrit\":\"satatodyukta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rtag tu ’bad\"}},{\"uuid\":\"aa890c43-17f7-413b-a41f-433bfc888126\",\"authority\":\"b0b39e62-0912-43af-a32e-dd7cd05a2b7b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eHaribhadra defines it as “a place used as a seat, where the maṇḍa, here ‘essence,’ of \u003cspan data-glossary-id=\\\"UT22084-060-005-551\\\"\u003eenlightenment\u003c/span\u003e is present.” See Lamotte, p. 198, n. 105. The main “\u003cspan class=\\\"ignore\\\"\u003eseat of enlightenment\u003c/span\u003e” is the spot under the bo tree at \u003cspan data-glossary-id=\\\"UT22084-060-005-828\\\"\u003eBuddha Gaya\u003c/span\u003e, where the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e sat and attained unexcelled, perfect \u003cspan data-glossary-id=\\\"UT22084-060-005-551\\\"\u003eenlightenment\u003c/span\u003e. It is not to be confused with \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003ebodhimaṇḍala\u003c/em\u003e, “circle of \u003cspan data-glossary-id=\\\"UT22084-060-005-551\\\"\u003eenlightenment\u003c/span\u003e.” \u003c/p\u003e\",\"names\":{\"english\":\"seat of enlightenment\",\"tibetan\":\"བྱང་ཆུབ་ཀྱི་སྙིང་པོ།\",\"sanskrit\":\"bodhimaṇḍa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"byang chub kyi snying po\"}},{\"uuid\":\"6b47902b-462a-40ad-923c-f033caeaf1f2\",\"authority\":\"6e3e2782-f474-41c6-a561-1933c7ad9478\",\"definition\":\"$6d\",\"names\":{\"english\":\"self\",\"tibetan\":\"བདག\",\"sanskrit\":\"ātma\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bdag\"}},{\"uuid\":\"19b574d4-ec62-4f40-aff0-c7b3e662d6a9\",\"authority\":\"7ed7cd9f-0e6f-49df-8bbb-8e1850977341\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eLit. “The tight fist of the [bad] teacher.”\u003c/p\u003e\",\"names\":{\"english\":\"selfish reticence\",\"tibetan\":\"སློབ་དཔོན་དཔེ་མཁྱུད།\",\"sanskrit\":\"ācāryamuṣṭi\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"slob dpon dpe mkhyud\"}},{\"uuid\":\"3c9a7a89-0b91-478a-a4a4-f6730f0689f9\",\"authority\":\"ae725e46-479c-443f-a514-f38dcd244ba7\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003esee “\u003cspan data-glossary-id=\\\"UT22084-060-005-502\\\"\u003eaggregates\u003c/span\u003e”\u003c/p\u003e\",\"names\":{\"english\":\"sensation\",\"tibetan\":\"ཚོར་བ།\",\"sanskrit\":\"vedanā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"tshor ba\"}},{\"uuid\":\"f63a28fa-eaa5-4aa0-bcc2-44bd9e6badcf\",\"authority\":\"98a2a6bf-fbf2-44ff-bddd-c53418bf76d5\",\"definition\":\"$6e\",\"names\":{\"english\":\"sense-media\",\"tibetan\":\"སྐྱེ་མཆེད།\",\"sanskrit\":\"āyatana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"skye mched\"}},{\"uuid\":\"ebcff4b7-5238-4173-8c8e-4db2148b8fad\",\"authority\":\"c598343f-450f-4d7b-83df-36087f1967d3\",\"definition\":\"$6f\",\"names\":{\"english\":\"seven abodes of consciousness\",\"tibetan\":\"རྣམ་པར་ཤེས་པ་ལ་གནས་པ་བདུན།\",\"sanskrit\":\"vijñānasthiti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rnam par shes pa la gnas pa bdun\"}},{\"uuid\":\"fa80f7ed-d6c6-4a26-8e30-34293b74e47a\",\"authority\":\"a6aae578-f7bb-4a4c-8179-060d8728e1b2\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThese are the factors of remembrance (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003esmṛti\u003c/em\u003e), discrimination between teachings (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003edharma­pravicaya\u003c/em\u003e), effort (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003evīrya\u003c/em\u003e), joy (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eprīti\u003c/em\u003e), ecstasy (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003epraśrabdhi\u003c/em\u003e), \u003cspan data-glossary-id=\\\"UT22084-060-005-521\\\"\u003econcentration\u003c/span\u003e (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-060-005-642\\\"\u003esamādhi\u003c/span\u003e\u003c/em\u003e), and equanimity (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eupekṣā\u003c/em\u003e). These seven form a part of the \u003cspan data-glossary-id=\\\"UT22084-060-005-676\\\"\u003ethirty-seven aids to enlightenment\u003c/span\u003e. \u003c/p\u003e\",\"names\":{\"english\":\"seven factors of enlightenment\",\"tibetan\":\"བྱང་ཆུབ་ཀྱི་ཡན་ལག་བདུན།\",\"sanskrit\":\"saṃbodhyaṅga\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"byang chub kyi yan lag bdun\"}},{\"uuid\":\"7d73e343-f69c-4e58-b34d-11a2174e7d7a\",\"authority\":\"ae1dc199-7873-4f6b-a146-9ab46d4af143\",\"definition\":\"$70\",\"names\":{\"english\":\"signlessness\",\"tibetan\":\"མཚན་མ་མེད་པ།\",\"sanskrit\":\"animittatā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mtshan ma med pa\"}},{\"uuid\":\"b3fa9972-99a8-474b-bb7a-b5135af4c1f7\",\"authority\":\"f44ece09-8b6f-422b-a3c4-6c8d1f1e1a96\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe \u003cspan data-glossary-id=\\\"UT22084-060-005-710\\\"\u003eBrahmā\u003c/span\u003e of the universe \u003cspan data-glossary-id=\\\"UT22084-060-005-827\\\"\u003eAśoka\u003c/span\u003e, who is personally called \u003cspan class=\\\"ignore\\\"\u003eŚikhin\u003c/span\u003e to distinguish him from \u003cspan data-glossary-id=\\\"UT22084-060-005-710\\\"\u003eBrahmās\u003c/span\u003e of other universes (see \u003cspan data-glossary-id=\\\"UT22084-060-005-710\\\"\u003eBrahmā\u003c/span\u003e). The second of the “seven \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003ebuddhas\u003c/span\u003e of the past” is also called \u003cspan class=\\\"ignore\\\"\u003eŚikhin\u003c/span\u003e but his name is rendered in Tibetan as \u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003egtsug gtor can\u003c/em\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Śikhin\",\"tibetan\":\"རལ་པ་ཅན།\",\"sanskrit\":\"śikhin\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ral pa can\"}},{\"uuid\":\"84791ec1-7e10-4df6-ae4c-cd69fca87951\",\"authority\":\"b159e61d-0289-4d23-ae38-37d720c5a5c0\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe “Compendium of Precepts,” in which \u003cspan data-glossary-id=\\\"UT22084-060-005-800\\\"\u003eŚāntideva\u003c/span\u003e collects pertinent quotes from the \u003cspan data-glossary-id=\\\"UT22084-060-005-605\\\"\u003eMahāyāna\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-060-005-670\\\"\u003esūtras\u003c/span\u003e and presents them according to a pattern suited for systematic practice. The quotations he included from the Vimalakīrtinirdeśa were the only extant remnants of the original Sanskrit of the Vimalakīrtinirdeśa until the discovery of a Sanskrit text in the Potala Palace in 2002.\u003c/p\u003e\",\"names\":{\"english\":\"Śikṣāsamuccaya\",\"tibetan\":\"བསླབ་པ་ཀུན་ལས་བཏུས་པ།\",\"sanskrit\":\"śikṣāsamuccaya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bslab pa kun las btus pa\"}},{\"uuid\":\"8d1a100c-40e2-4308-83e0-43ac0acdc064\",\"authority\":\"898eaea2-85ec-4f25-aa3b-e7c2832871ea\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003ebuddhas\u003c/span\u003e who teach the \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eTathāgata­guhyaka\u003c/cite\u003e on certain occasions in \u003cspan data-glossary-id=\\\"UT22084-060-005-1257\\\"\u003eVimalakīrti\u003c/span\u003e’s house. \u003c/p\u003e\",\"names\":{\"english\":\"Siṃhaghoṣa\",\"tibetan\":\"སེང་གེའི་སྒྲ།\",\"sanskrit\":\"siṃhaghoṣa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"seng ge’i sgra\"}},{\"uuid\":\"05a8b2de-8ee0-493d-b70b-4d7c47cc2fc6\",\"authority\":\"45bf53fc-4ca3-4ae7-b265-e42a27b6e160\",\"definition\":\"\",\"names\":{\"english\":\"Siṃha­ghoṣābhigarjita­śvara\",\"tibetan\":\"སེང་གེ་ང་རོ་མངོན་པར་བསྒྲགས་པའི་དབྱངས།\",\"sanskrit\":\"siṃha­ghoṣābhigarjita­śvara\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"seng ge nga ro mngon par bsgrags pa’i dbyangs\"}},{\"uuid\":\"7b0d63cf-0c66-46d7-b490-257aa0a16209\",\"authority\":\"74f367fd-de70-474f-8aee-5d0f0afbf010\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003ebuddhas\u003c/span\u003e who teach the \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eTathāgata­guhyaka\u003c/cite\u003e on certain occasions in \u003cspan data-glossary-id=\\\"UT22084-060-005-1257\\\"\u003eVimalakīrti\u003c/span\u003e’s house. \u003c/p\u003e\",\"names\":{\"english\":\"Siṃhanādanādī\",\"tibetan\":\"སེང་གེ་བསྒྲགས་པ།\",\"sanskrit\":\"siṃhanādanādī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"seng ge bsgrags pa\"}},{\"uuid\":\"ec69bc18-9750-4031-baae-f9f28e6c506b\",\"authority\":\"07f1b819-fa9b-4d4f-aa53-6575ceebc564\",\"definition\":\"$71\",\"names\":{\"english\":\"six outsider masters\",\"tibetan\":\"སྟོན་པ་དྲུག\",\"sanskrit\":\"ṣāṭ śāstāraḥ\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ston pa drug\"}},{\"uuid\":\"3818013d-2c0e-4975-9bb7-4518a8a3bf8a\",\"authority\":\"42a58fc9-5956-4a99-be98-78e4e4176308\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThese are six things to keep in mind: the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e, the \u003cspan data-glossary-id=\\\"UT22084-060-005-537\\\"\u003eDharma\u003c/span\u003e, the \u003cspan data-glossary-id=\\\"UT22084-060-005-646\\\"\u003eSaṅgha\u003c/span\u003e, \u003cspan data-glossary-id=\\\"UT22084-060-005-615\\\"\u003emorality\u003c/span\u003e (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eśīla\u003c/em\u003e), generosity (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003etyāga\u003c/em\u003e), and deities (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003edevatā\u003c/em\u003e). \u003c/p\u003e\",\"names\":{\"english\":\"six remembrances\",\"tibetan\":\"རྗེས་སུ་དྲན་པ་དྲུག\",\"sanskrit\":\"anusmṛti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rjes su dran pa drug\"}},{\"uuid\":\"37e4a764-eef9-41ab-a440-151b1d76a025\",\"authority\":\"bc70afb7-78d1-4329-aa6a-97e485b8fc45\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e These are enumerated in the \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eBrahmājāla­sūtra\u003c/cite\u003e and in the \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eDighanikāya\u003c/cite\u003e and consist of all \u003cspan data-glossary-id=\\\"UT22084-060-005-686\\\"\u003eviews\u003c/span\u003e other than the “right \u003cspan data-glossary-id=\\\"UT22084-060-005-686\\\"\u003eview\u003c/span\u003e” of the \u003cspan data-glossary-id=\\\"UT22084-060-005-499\\\"\u003eabsence of self\u003c/span\u003e. All sixty-two fall into either one of the two categories known as the “two extremisms:” “eternalism” (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003esāśvatavāda\u003c/em\u003e) and “nihilism” (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eucchedavāda\u003c/em\u003e). \u003c/p\u003e\",\"names\":{\"english\":\"sixty-two convictions\",\"tibetan\":\"ལྟ་བར་གྱུར་པ་དྲུག་ཅུ་རྩ་གཉིས།\",\"sanskrit\":\"dṛṣṭigata\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lta bar gyur pa drug cu rtsa gnyis\"}},{\"uuid\":\"86e40054-da64-4b71-8b79-a0ee822f4d48\",\"authority\":\"71c3e498-a282-46c2-a1b2-09bff483deac\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e“Spirit” is preferred to “mind” because the mind of \u003cspan data-glossary-id=\\\"UT22084-060-005-551\\\"\u003eenlightenment\u003c/span\u003e should rather be the mind of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e, and to “thought” because a “thought of \u003cspan data-glossary-id=\\\"UT22084-060-005-551\\\"\u003eenlightenment\u003c/span\u003e” can easily be produced without the initiation of any sort of new resolve or awareness. “Will” also serves very well here.\u003c/p\u003e\",\"names\":{\"english\":\"spirit of enlightenment\",\"tibetan\":\"བྱང་ཆུབ་ཀྱི་སེམས།\",\"sanskrit\":\"bodhicitta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"byang chub kyi sems\"}},{\"uuid\":\"e5303c16-abe1-4662-81c1-ccb782cc20f3\",\"authority\":\"9861c4ef-4f1e-4332-bb65-01b36e4285a7\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA \u003cspan data-glossary-id=\\\"UT22084-060-005-605\\\"\u003eMahāyāna\u003c/span\u003e teacher is termed “friend,” or “benefactor,” which indicates that a \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattva\u003c/span\u003e-career depends on one’s own effort and that all a teacher can do is inspire, exemplify, and point the way.\u003c/p\u003e\",\"names\":{\"english\":\"spiritual benefactor\",\"tibetan\":\"དགེ་བའི་བཤེས་གཉེན།\",\"sanskrit\":\"kalyāṇamitra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dge ba’i bshes gnyen\"}},{\"uuid\":\"dfc960d5-7e6f-4230-ba38-5a0f6d68b1a4\",\"authority\":\"b662e79b-4cff-4567-b74a-1c23d3f1fea7\",\"definition\":\"$72\",\"names\":{\"english\":\"śrāvaka\",\"tibetan\":\"ཉན་ཐོས།\",\"sanskrit\":\"śrāvaka\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nyan thos\"}},{\"uuid\":\"095aa97b-0bf4-4815-b45c-8a849baa0317\",\"authority\":\"55532312-84c3-4ab9-9220-58b7598c8440\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eCapital city of the kingdom of Kosala, ruled by one of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e’s royal patrons, king Prasenajit, where the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e often dwelt in the Jetavana grove, site of many \u003cspan data-glossary-id=\\\"UT22084-060-005-605\\\"\u003eMahāyāna\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-060-005-670\\\"\u003esūtras\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Śrāvastī\",\"tibetan\":\"མཉན་ཡོད།\",\"sanskrit\":\"śrāvastī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mnyan yod\"}},{\"uuid\":\"aeadd9af-d927-459a-b67c-be1ec4505848\",\"authority\":\"8543f239-205e-4f42-9e5a-80a15fe72069\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e(c. fourth century). One of the important masters of the \u003cspan data-glossary-id=\\\"UT22084-060-005-687\\\"\u003eVijñānavāda\u003c/span\u003e school, he wrote important commentaries on the works of \u003cspan data-glossary-id=\\\"UT22084-060-005-819\\\"\u003eVasubandhu\u003c/span\u003e and \u003cspan data-glossary-id=\\\"UT22084-060-005-705\\\"\u003eĀryāsaṅga\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Sthiramati\",\"tibetan\":\"བློ་གྲོས་བརྟན་པ།\",\"sanskrit\":\"sthiramati\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"blo gros brtan pa\"}},{\"uuid\":\"fa55b464-cb87-4542-8570-44397712805f\",\"authority\":\"98339547-6c33-4a91-bbaf-139381d2be02\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe two great stores to be accumulated by \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattvas\u003c/span\u003e: the store of merit, arising from their practice of the first three transcendences, and the store of \u003cspan data-glossary-id=\\\"UT22084-060-005-691\\\"\u003ewisdom\u003c/span\u003e, arising from their practice of the last two transcendences. All deeds of \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattvas\u003c/span\u003e contribute to their accumulation of these two stores, which ultimately culminate in the two bodies of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e, the body of form and the \u003cspan data-glossary-id=\\\"UT22084-060-005-683\\\"\u003eultimate\u003c/span\u003e body.\u003c/p\u003e\",\"names\":{\"english\":\"stores of merit and wisdom\",\"tibetan\":\"བསོད་ནམས་དང་ཡེ་ཤེས་ཀྱི་ཚོགས།\",\"sanskrit\":\"puṇya­jñāna­saṃbhāra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bsod nams dang ye shes kyi tshogs\"}},{\"uuid\":\"e96fbc2c-92d5-4084-8a40-f75adcb7c7af\",\"authority\":\"d5b6340d-920f-4ac8-b731-9e6dfc0aa682\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThis is equivalent to \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003evāsanā\u003c/em\u003e, “instinctual predilection,” and refers in Buddhist psychology to the subconscious habit patterns that underlie emotional responses such as desire and hatred. \u003c/p\u003e\",\"names\":{\"english\":\"subconscious instinct\",\"tibetan\":\"བག་ལ་ཉལ་བ།\",\"sanskrit\":\"anuśaya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bag la nyal ba\"}},{\"uuid\":\"521379b7-ddbc-4672-aa8f-52c7e06118cf\",\"authority\":\"75ac4c58-10ba-4b16-99c3-7a8ee184d7da\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eIdentifiable with \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eālayavijñāna\u003c/em\u003e. However, as reference to the elaborate Vijñānavādin psychology of the “store-\u003cspan class=\\\"ignore\\\"\u003econsciousness\u003c/span\u003e” is out of place in this \u003cspan data-glossary-id=\\\"UT22084-060-005-670\\\"\u003esūtra\u003c/span\u003e, it is here simply translated “\u003cspan class=\\\"ignore\\\"\u003esubconsciousness\u003c/span\u003e.” \u003c/p\u003e\",\"names\":{\"english\":\"subconsciousness\",\"tibetan\":\"ཀུན་གཞི།\",\"sanskrit\":\"ālaya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"kun gzhi\"}},{\"uuid\":\"dc583342-5d78-4280-9cde-078dbcaa066d\",\"authority\":\"933908ca-b6e1-43c6-8195-baa7b34e72db\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA supreme god, or \u003cspan data-glossary-id=\\\"UT22084-060-005-710\\\"\u003eBrahmā\u003c/span\u003e, of another universe, who visits our universe to converse with \u003cspan data-glossary-id=\\\"UT22084-060-005-703\\\"\u003eAniruddha\u003c/span\u003e about the \u003cspan data-glossary-id=\\\"UT22084-060-005-540\\\"\u003edivine eye\u003c/span\u003e, and is taught instead by \u003cspan data-glossary-id=\\\"UT22084-060-005-1257\\\"\u003eVimalakīrti\u003c/span\u003e in Chap. 3.\u003c/p\u003e\",\"names\":{\"english\":\"Śubhavyūha\",\"tibetan\":\"དགེ་བ་བཀོད་པ།\",\"sanskrit\":\"śubhavyūha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dge ba bkod pa\"}},{\"uuid\":\"b5412ab5-da28-47a8-aaf4-65be6e28d7d4\",\"authority\":\"9ae8a691-3333-4856-9d49-ea92ff3cd94b\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eDisciple noted for his profound \u003cspan data-glossary-id=\\\"UT22084-060-005-521\\\"\u003econcentration\u003c/span\u003e on \u003cspan data-glossary-id=\\\"UT22084-060-005-689\\\"\u003evoidness\u003c/span\u003e; as interlocutor of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e, a major figure in the \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-060-005-853\\\"\u003ePrajñā­pāramitā­sūtras\u003c/span\u003e\u003c/cite\u003e. See also \u003ca href=\\\"end-notes.xhtml#UT22084-060-005-927\\\" data-pointer-type=\\\"id\\\"\u003en.65\u003c/a\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Subhūti\",\"tibetan\":\"རབ་འབྱོར།\",\"sanskrit\":\"subhūti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rab ’byor\"}},{\"uuid\":\"4199d85f-0076-4db9-9fac-7d91076437ea\",\"authority\":\"3ecb3ad1-1458-4da5-8f90-425697db25fe\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cspan class=\\\"ignore\\\"\u003eSudatta\u003c/span\u003e was a great lay patron of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e and philanthropist of \u003cspan data-glossary-id=\\\"UT22084-060-005-844\\\"\u003eŚrāvastī\u003c/span\u003e, and is more commonly called Anāthapiṇḍada (\u003cem class=\\\"foreign text-wy\\\" lang=\\\"bo-LATN\\\"\u003emgon med zas sbyin\u003c/em\u003e); he known as “the foremost of donors” (\u003cspan data-glossary-id=\\\"UT22084-060-005-628\\\"\u003ePāli\u003c/span\u003e; \u003cem class=\\\"foreign text-pi\\\" lang=\\\"pi-LATN\\\"\u003eaggo dāyakānaṃ\u003c/em\u003e). \u003c/p\u003e\",\"names\":{\"english\":\"Sudatta\",\"tibetan\":\"ལེགས་པར་བྱིན།\",\"sanskrit\":\"sudatta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"legs par byin\"}},{\"uuid\":\"ef7b7c86-e10d-4773-b851-60836577eac2\",\"authority\":\"e0c895bf-68db-4a04-be1e-98983ced51ee\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the standard epithets of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-060-005-794\\\"\u003eŚākyamuni\u003c/span\u003e and other \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003ebuddhas\u003c/span\u003e. According to Buddhaghoṣa, the term means that the way the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e went (Skt. \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003egata\u003c/em\u003e) is good (Skt. \u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003esu\u003c/em\u003e), and where he went (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003egata\u003c/em\u003e) is good (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003esu\u003c/em\u003e). \u003c/p\u003e\",\"names\":{\"english\":\"sugata\",\"tibetan\":\"བདེ་བར་གཤེགས་པ།\",\"sanskrit\":\"sugata\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"bde bar gshegs pa\"}},{\"uuid\":\"f09c5f12-b6bb-4937-be1d-7fb942862c5e\",\"authority\":\"c83c68a6-abab-47e7-a7dd-742d677a98dd\",\"definition\":\"\",\"names\":{\"english\":\"Sujāta\",\"tibetan\":\"མཛེས་པར་སྐྱེས།\",\"sanskrit\":\"sujāta\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mdzes par skyes\"}},{\"uuid\":\"0a487e8b-80f3-4d32-a273-53333cc425e1\",\"authority\":\"1419555a-15dc-4f80-8a53-7bbc43689a15\",\"definition\":\"\",\"names\":{\"english\":\"Sumati\",\"tibetan\":\"རབ་ཀྱི་བློ་སྒྲོས།\",\"sanskrit\":\"sumati\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rab kyi blo sgros\"}},{\"uuid\":\"6399a2f2-b35d-4507-a09f-efeccb434a76\",\"authority\":\"00c9880b-c835-42e4-8a54-7f9d0c52c4a4\",\"definition\":\"\u003cp\u003eAccording to ancient Buddhist cosmology, this is the great mountain forming the axis of the universe. At its summit is Sudarśana, home of Śakra and his thirty-two gods, and on its flanks live the asuras. The mount has four sides facing the cardinal directions, each of which is made of a different precious stone. Surrounding it are several mountain ranges and the great ocean where the four principal island continents lie: in the south, Jambudvīpa (our world); in the west, Godānīya; in the north, Uttarakuru; and in the east, Pūrvavideha. Above it are the abodes of the desire realm gods. It is variously referred to as Meru, Mount Meru, Sumeru, and Mount Sumeru.\u003c/p\u003e\",\"names\":{\"english\":\"Sumeru\",\"tibetan\":\"རིའི་རྒྱལ་པོ་རི་རབ།\",\"sanskrit\":\"sumeru\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ri’i rgyal po ri rab\"}},{\"uuid\":\"6b6440dd-6d95-46dd-9c77-9f9241f4e84a\",\"authority\":\"a788cae8-0c9d-45be-ac4b-eda48948b0c8\",\"definition\":\"$73\",\"names\":{\"english\":\"superknowledges\",\"tibetan\":\"མངོན་པར་ཤེས་པ།\",\"sanskrit\":\"abhijñā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mngon par shes pa\"}},{\"uuid\":\"c65438ed-99d8-45cc-bc87-72f8f617eea5\",\"authority\":\"73789e6d-8b90-414f-ab00-df45bd1a7268\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eIn general Indian usage, the word for a highly condensed arrangement of verses that lends itself to memorization, serving as a basic text for a particular school of thought. In Buddhism, a scripture, in as much as it records either the direct speech of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e, or the speech of someone manifestly inspired by him.\u003c/p\u003e\",\"names\":{\"english\":\"sūtra\",\"tibetan\":\"མདོ།\",\"sanskrit\":\"sūtra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mdo\"}},{\"uuid\":\"0476be01-c230-48e7-b58c-592d8e4e8989\",\"authority\":\"c74ef399-4bbc-4f7d-9e86-7bfaf8004bb5\",\"definition\":\"\",\"names\":{\"english\":\"Suvarnacūḍa\",\"tibetan\":\"གཙུག་ན་གསེར།\",\"sanskrit\":\"suvarnacūḍa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gtsug na gser\"}},{\"uuid\":\"140c4504-5fe9-4a99-b7e9-b25cb2395c1a\",\"authority\":\"8ac697bd-d7f9-4fce-a0a8-93a3d7338f00\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eMeaning “method” in general, in Buddhism it refers to an important body of literature dealing with a great variety of techniques of advanced \u003cspan data-glossary-id=\\\"UT22084-060-005-612\\\"\u003emeditations\u003c/span\u003e, incorporating rituals, \u003cspan data-glossary-id=\\\"UT22084-060-005-581\\\"\u003eincantations\u003c/span\u003e, and visualisations, that are stamped as esoteric until a practitioner has already attained a certain stage of ethical and philosophical development.\u003c/p\u003e\",\"names\":{\"english\":\"tantra\",\"tibetan\":\"རྒྱུད།\",\"sanskrit\":\"tantra\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rgyud\"}},{\"uuid\":\"f48b98da-0fa1-4d17-80bf-ea8056650eba\",\"authority\":\"5a111d8a-80a7-4fe9-889a-1d1e0020d424\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe “Blaze of Reason,” an important treatise of \u003cspan data-glossary-id=\\\"UT22084-060-005-709\\\"\u003eBhāvaviveka\u003c/span\u003e’s, in which he critically discusses all the major philosophical \u003cspan data-glossary-id=\\\"UT22084-060-005-686\\\"\u003eviews\u003c/span\u003e of his day.\u003c/p\u003e\",\"names\":{\"english\":\"Tarkajvāla\",\"tibetan\":\"རྟོག་གེ་འབར་བ།\",\"sanskrit\":\"tarkajvāla\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rtog ge ’bar ba\"}},{\"uuid\":\"e708dad0-3dd7-49b0-8de3-b2e34b3f8d08\",\"authority\":\"285a8525-75c9-4ab3-8d61-e257c5eb21ce\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eLit. “Thus-gone” or “Thus-come,” (one who proceeds always in \u003cspan data-glossary-id=\\\"UT22084-060-005-527\\\"\u003econsciousness\u003c/span\u003e of the \u003cspan data-glossary-id=\\\"UT22084-060-005-683\\\"\u003eultimate\u003c/span\u003e reality, or thatness of all things). A name of the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"tathāgata\",\"tibetan\":\"དེ་བཞིན་གཤེགས་པ།\",\"sanskrit\":\"tathāgata\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"de bzhin gshegs pa\"}},{\"uuid\":\"a72b2685-e31f-4aed-adff-8c13405c1c9f\",\"authority\":\"50455ffe-57ed-4802-83d7-95c67b3ab35e\",\"definition\":\"$74\",\"names\":{\"english\":\"ten powers\",\"tibetan\":\"སྟོབས་བཅུ།\",\"sanskrit\":\"daśabala\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"stobs bcu\"}},{\"uuid\":\"a4e54557-1252-4772-8e09-48968f0d335a\",\"authority\":\"5743b0ea-7639-4016-b446-6188c37684a3\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThese are the opposite of the \u003cspan data-glossary-id=\\\"UT22084-060-005-675\\\"\u003eten virtues\u003c/span\u003e, and consist of killing, stealing, sexual misconduct, lying, harsh speech, backbiting, frivolous speech, covetousness, malice, and false \u003cspan data-glossary-id=\\\"UT22084-060-005-686\\\"\u003eviews\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"ten sins\",\"tibetan\":\"མི་དགེ་བ་བཅུ།\",\"sanskrit\":\"daśākuśala\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mi dge ba bcu\"}},{\"uuid\":\"c3747e64-0286-4485-9ae2-6c8123a8cdc6\",\"authority\":\"5829cbde-4acd-426a-abfe-837963bdda67\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThese are the opposite of the \u003cspan data-glossary-id=\\\"UT22084-060-005-674\\\"\u003eten sins\u003c/span\u003e, i.e., refraining from engaging in activities related to the \u003cspan data-glossary-id=\\\"UT22084-060-005-674\\\"\u003eten sins\u003c/span\u003e and doing the opposite. There are three physical virtues: saving lives, giving, and sexual propriety. There are four verbal virtues: truthfulness, reconciling discussions, gentle speech, and religious speech. There are three mental virtues: loving attitude, generous attitude, and right \u003cspan data-glossary-id=\\\"UT22084-060-005-686\\\"\u003eviews\u003c/span\u003e. The whole doctrine is collectively called the “tenfold path of good action” (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003edaśa­kuśala­karma­patha\u003c/em\u003e). \u003c/p\u003e\",\"names\":{\"english\":\"ten virtues\",\"tibetan\":\"དགེ་བ་བཅུ།\",\"sanskrit\":\"kuśala\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dge ba bcu\"}},{\"uuid\":\"b5963753-f922-454c-a492-de9a236d39e5\",\"authority\":\"8a3d70f8-04a8-4c22-908e-5d96144a3e27\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThese consist of the \u003cspan data-glossary-id=\\\"UT22084-060-005-561\\\"\u003efour foci of mindfulness\u003c/span\u003e, the \u003cspan data-glossary-id=\\\"UT22084-060-005-567\\\"\u003efour right efforts\u003c/span\u003e, the \u003cspan data-glossary-id=\\\"UT22084-060-005-560\\\"\u003efour bases of magical powers\u003c/span\u003e, the \u003cspan data-glossary-id=\\\"UT22084-060-005-559\\\"\u003efive spiritual faculties\u003c/span\u003e, the \u003cspan data-glossary-id=\\\"UT22084-060-005-558\\\"\u003efive powers\u003c/span\u003e, the \u003cspan data-glossary-id=\\\"UT22084-060-005-654\\\"\u003eseven factors of enlightenment\u003c/span\u003e, and the \u003cspan data-glossary-id=\\\"UT22084-060-005-547\\\"\u003eeightfold noble path\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"thirty-seven aids to enlightenment\",\"tibetan\":\"བྱང་ཆུབ་ཀྱི་ཕྱོགས་སུམ་ཅུ་རྩ་བདུན་གྱི་ཆོས།\",\"sanskrit\":\"bodhi­pakṣika­dharma\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"byang chub kyi phyogs sum cu rtsa bdun gyi chos\"}},{\"uuid\":\"f44c5f13-b5c1-4ec7-a2af-c4a948074de3\",\"authority\":\"3aba3c23-34ef-45d7-9f98-fa54fe939ce3\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe three worlds or realms of which all universes are composed: of desire (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003ekāmadhātu\u003c/em\u003e), of pure \u003cspan data-glossary-id=\\\"UT22084-060-005-610\\\"\u003ematter\u003c/span\u003e (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003erūpadhātu\u003c/em\u003e), and the \u003cspan data-glossary-id=\\\"UT22084-060-005-580\\\"\u003eimmaterial realm\u003c/span\u003e (\u003cem class=\\\"foreign break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eārūpyadhātu\u003c/em\u003e). \u003c/p\u003e\",\"names\":{\"english\":\"three realms\",\"tibetan\":\"ཁམས་གསུམ།\",\"sanskrit\":\"traidhātuka\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"khams gsum\"}},{\"uuid\":\"d576fbe3-9011-4ae4-9a17-b7c8a391981a\",\"authority\":\"19e108c4-2f10-40ed-9649-5736f26a0424\",\"definition\":\"$75\",\"names\":{\"english\":\"tolerance of the birthlessness of things, tolerance of ultimate birthlessness\",\"tibetan\":\"མི་སྐྱེ་བའི་ཆོས་ལ་བཟོད་པ།, མི་སྐྱེ་བའི་ཆོས་ལ་བཟོད་པ།\",\"sanskrit\":\"anutpattika­dharma­kṣānti, anutpattika­dharma­kṣānti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mi skye ba’i chos la bzod pa, mi skye ba’i chos la bzod pa\"}},{\"uuid\":\"f1e6e8cc-6037-4186-8957-83f0739a3ca2\",\"authority\":\"19e108c4-2f10-40ed-9649-5736f26a0424\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSee “\u003cspan data-glossary-id=\\\"UT22084-060-005-678\\\"\u003etolerance of the birthlessness of things\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"tolerance of the birthlessness of things, tolerance of ultimate birthlessness\",\"tibetan\":\"མི་སྐྱེ་བའི་ཆོས་ལ་བཟོད་པ།, མི་སྐྱེ་བའི་ཆོས་ལ་བཟོད་པ།\",\"sanskrit\":\"anutpattika­dharma­kṣānti, anutpattika­dharma­kṣānti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mi skye ba’i chos la bzod pa, mi skye ba’i chos la bzod pa\"}},{\"uuid\":\"6cf08752-1b1f-4a66-a9c7-a593246c380d\",\"authority\":\"1d2816b9-3066-48b4-a1a3-8fa6080f6fa9\",\"definition\":\"$76\",\"names\":{\"english\":\"transcendental analysis\",\"tibetan\":\"ལྷག་མཐོང་།\",\"sanskrit\":\"vipaśyana\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lhag mthong\"}},{\"uuid\":\"21b59f56-882b-4762-9757-3b8990d8b21e\",\"authority\":\"93ef2892-3c6c-4c97-9836-1bb86d4de3e8\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e\u003cspan class=\\\"ignore\\\"\u003eTranscendental practice\u003c/span\u003e, as opposed to practice at an earlier stage.\u003c/p\u003e\",\"names\":{\"english\":\"transcendental practice\",\"tibetan\":\"ཡེ་ཤེས་སྒྲུབ་པ།\",\"sanskrit\":\"jñāna­pratipatti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"ye shes sgrub pa\"}},{\"uuid\":\"eaf5a861-85d2-4977-ae47-2981177eaf53\",\"authority\":\"301df2be-922b-4250-8aa4-55bc54d32961\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe Heaven of the “Thirty-Three,” second level of the desire-realm, located on top of Mount \u003cspan data-glossary-id=\\\"UT22084-060-005-845\\\"\u003eSumeru\u003c/span\u003e in the Buddhist cosmology.\u003c/p\u003e\",\"names\":{\"english\":\"Trāyastriṃśa\",\"tibetan\":\"སུམ་ཅུ་རྩ་གསུམ་པ།\",\"sanskrit\":\"trāyastriṃśa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sum cu rtsa gsum pa\"}},{\"uuid\":\"62829850-6321-48fc-9648-fba6953c3139\",\"authority\":\"007fe4df-bf4a-4d5b-8753-c4648a2f408a\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e(1357-1419). One of the greatest of all Tibetan Lamas, his saintliness was evidenced in his altruistic deeds that caused a renaissance in Tibet, his \u003cspan data-glossary-id=\\\"UT22084-060-005-551\\\"\u003eenlightenment\u003c/span\u003e in the extraordinary subtlety and profundity of his thought, and his scholarship in the breadth and clarity of his voluminous writings.\u003c/p\u003e\",\"names\":{\"english\":\"Tsong Khapa\",\"tibetan\":\"ཙོང་ཁ་པ།\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"tsong kha pa\"}},{\"uuid\":\"75f5ae84-90f1-481d-a135-617655cf457f\",\"authority\":\"edf1481c-c58e-455d-91ac-4483ead30568\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eA heaven, the fourth level of the heavens of the \u003cspan data-glossary-id=\\\"UT22084-060-005-637\\\"\u003erealm of desire\u003c/span\u003e, and the last stopping place of a \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003ebuddha\u003c/span\u003e before his descent and reincarnation on earth; at present the abode of the future \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-060-005-743\\\"\u003eMaitreya\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Tuṣita\",\"tibetan\":\"དགའ་ལྡན།\",\"sanskrit\":\"tuṣita\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dga’ ldan\"}},{\"uuid\":\"f0e037b0-dfc3-4e05-94ad-bc0d2dfc2cfb\",\"authority\":\"05192d5e-75d7-4994-aea6-cfc4c4c195e9\",\"definition\":\"$77\",\"names\":{\"english\":\"twelve ascetic practices\",\"tibetan\":\"སྦྱངས་པའི་ཡོན་ཏན་བཅུ་གཉིས།\",\"sanskrit\":\"dvādaśadhūtaguṇāḥ\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sbyangs pa’i yon tan bcu gnyis\"}},{\"uuid\":\"784c8158-9e46-4484-9152-e0d06cd46afc\",\"authority\":\"77fecb3c-ea5b-4747-9cda-31f83a9598b3\",\"definition\":\"$78\",\"names\":{\"english\":\"ultimate\",\"tibetan\":\"དོན་དམ་པ།\",\"sanskrit\":\"paramārtha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"don dam pa\"}},{\"uuid\":\"fb139747-a249-489b-947e-79301865b6d6\",\"authority\":\"ebb48fae-4edb-40ff-b9e7-188a2a3f4a98\",\"definition\":\"$79\",\"names\":{\"english\":\"ultimate realm\",\"tibetan\":\"ཆོས་ཀྱི་དབྱིངས།\",\"sanskrit\":\"dharmadhātu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"chos kyi dbyings\"}},{\"uuid\":\"6659d907-9318-46a8-9a7d-820e6a5d897f\",\"authority\":\"c548a75a-9f19-415c-bdb1-0706701bc2ba\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eReferring to actions, this term signifies the actions of beings in the subtle god-realms of form and formlessness that can only lead to rebirth in the same realm in the next \u003cspan class=\\\"ignore\\\"\u003elife\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"unmoving\",\"tibetan\":\"མི་གཡོ་བ།\",\"sanskrit\":\"āniñjya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"mi g.yo ba\"}},{\"uuid\":\"3cdcaa9d-3979-4ae9-a327-19723393a25f\",\"authority\":\"8213e863-ba8a-47f1-bfaf-807e085186da\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eDisciple; originally the barber of the \u003cspan data-glossary-id=\\\"UT22084-060-005-793\\\"\u003eŚākya\u003c/span\u003e princes, ordained together with them, and noted as an expert on the \u003cspan data-glossary-id=\\\"UT22084-060-005-688\\\"\u003eVinaya\u003c/span\u003e. \u003c/p\u003e\u003cp class=\\\"definition\\\"\u003e(See also \u003ca href=\\\"end-notes.xhtml#UT22084-060-005-942\\\" data-pointer-type=\\\"id\\\"\u003en.80\u003c/a\u003e).\u003c/p\u003e\",\"names\":{\"english\":\"Upāli\",\"tibetan\":\"ཉེ་བར་འཁོར།\",\"sanskrit\":\"upāli\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"nye bar ’khor\"}},{\"uuid\":\"e9c61804-d922-4a99-88ea-836faa6fd3c4\",\"authority\":\"1935a229-0372-406e-8848-47fd7cb522de\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eGreat city during the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e’s time, capital of the \u003cspan data-glossary-id=\\\"UT22084-060-005-599\\\"\u003eLicchavi\u003c/span\u003e republic; at present the town of Basarh, Muzaffarpur district, in Tirhut, Bihar province of India. (See Lamotte, pp. 80-83; p. 97, n. 1.).\u003c/p\u003e\",\"names\":{\"english\":\"Vaiśālī\",\"tibetan\":\"ཡངས་པ་ཅན།\",\"sanskrit\":\"vaiśālī\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"yangs pa can\"}},{\"uuid\":\"ab351a34-b865-4870-9b78-70b27c909293\",\"authority\":\"3d58ef2a-3ca7-41be-bc51-6e392c9774e7\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eAn important \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattva\u003c/span\u003e, “Wielder of the Thunderbolt,” whose compassion is to manifest in a terrific form to protect the practicers of the \u003cspan data-glossary-id=\\\"UT22084-060-005-537\\\"\u003eDharma\u003c/span\u003e from harmful influences.\u003c/p\u003e\",\"names\":{\"english\":\"Vajrapāṇi\",\"tibetan\":\"ཕྱག་ན་རྡོ་རྗེ།\",\"sanskrit\":\"vajrapāṇi\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"phyag na rdo rje\"}},{\"uuid\":\"d1321bbd-7a4b-4a02-90f9-2a0661cc9c6f\",\"authority\":\"3603889d-ed68-4b04-972a-d3a9f28b22c0\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003e(Fourth century). The younger brother of \u003cspan data-glossary-id=\\\"UT22084-060-005-705\\\"\u003eĀryāsaṅga\u003c/span\u003e, he was one of the greatest scholars in Buddhist history, author of the \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003e\u003cspan data-glossary-id=\\\"UT22084-060-005-849\\\"\u003eAbhi­dharma­kośa\u003c/span\u003e\u003c/cite\u003e, the most definitive work on the \u003cspan data-glossary-id=\\\"UT22084-060-005-498\\\"\u003eAbhidharma\u003c/span\u003e, and later of numerous important works on the \u003cspan data-glossary-id=\\\"UT22084-060-005-687\\\"\u003eVijñānavāda\u003c/span\u003e philosophy. \u003c/p\u003e\",\"names\":{\"english\":\"Vasubandhu\",\"tibetan\":\"དབྱིག་གཉེན།\",\"sanskrit\":\"vasubandhu\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dbyig gnyen\"}},{\"uuid\":\"a22977d5-fea2-4b92-b784-626f44c02c70\",\"authority\":\"5e98fe53-57e6-41b4-9ecf-919dcebc3d7d\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eName of the ancient sacred Scriptures of Brahmanism, most famous of which is the \u003ccite class=\\\"title break text-sa\\\" lang=\\\"sa-LATN\\\"\u003eṚg Veda\u003c/cite\u003e. \u003c/p\u003e\",\"names\":{\"english\":\"Veda\",\"tibetan\":\"རིག་བྱེད།\",\"sanskrit\":\"veda\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rig byed\"}},{\"uuid\":\"aed81034-62e0-40a0-a937-47ebe2130809\",\"authority\":\"dd63e3df-5b3b-48cf-93ca-9ba8ed227e86\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe name of the long-past eon during which the \u003cspan data-glossary-id=\\\"UT22084-060-005-515\\\"\u003eBuddha\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-060-005-708\\\"\u003eBhaiṣajyarāja\u003c/span\u003e presided in the \u003cspan data-glossary-id=\\\"UT22084-060-005-516\\\"\u003ebuddhafield\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-060-005-742\\\"\u003eMahāvyūha\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Vicaraṇa\",\"tibetan\":\"རྣམ་པར་སྦྱོང་བ།\",\"sanskrit\":\"vicaraṇa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rnam par sbyong ba\"}},{\"uuid\":\"cd2c19fc-31cc-4130-b06b-088728250db5\",\"authority\":\"5c27ed88-fe05-4c61-ad1c-806f29f8d680\",\"definition\":\"\",\"names\":{\"english\":\"Vidyuddeva\",\"tibetan\":\"གློག་གི་ལྷ།\",\"sanskrit\":\"vidyuddeva\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"glog gi lha\"}},{\"uuid\":\"706840df-0c20-4c5d-94a4-6b4383506ee4\",\"authority\":\"29baeb19-29e5-4deb-808a-9981baa5608c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThis means a mental conviction or opinion that conditions the mind and determines how it sees reality.\u003c/p\u003e\",\"names\":{\"english\":\"view\",\"tibetan\":\"ལྟ་བ།\",\"sanskrit\":\"dṛṣṭi\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"lta ba\"}},{\"uuid\":\"cda360b1-68ed-4f1f-a2b2-b87d209292db\",\"authority\":\"214e345c-54e1-4282-a948-702cff25d1d5\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe school of “\u003cspan class=\\\"ignore\\\"\u003eConsciousness\u003c/span\u003e-Only” founded by \u003cspan data-glossary-id=\\\"UT22084-060-005-743\\\"\u003eMaitreya\u003c/span\u003e and \u003cspan data-glossary-id=\\\"UT22084-060-005-705\\\"\u003eĀryāsaṅga\u003c/span\u003e, which shares with the \u003cspan data-glossary-id=\\\"UT22084-060-005-603\\\"\u003eMādhyamika\u003c/span\u003e most of the philosophical techniques of the \u003cspan data-glossary-id=\\\"UT22084-060-005-605\\\"\u003eMahāyāna\u003c/span\u003e, while differing on the interpretation of the profound meaning of \u003cspan data-glossary-id=\\\"UT22084-060-005-689\\\"\u003evoidness\u003c/span\u003e, or the \u003cspan data-glossary-id=\\\"UT22084-060-005-683\\\"\u003eultimate\u003c/span\u003e reality.\u003c/p\u003e\",\"names\":{\"english\":\"Vijñānavāda\",\"tibetan\":\"རྣམ་པར་ཤེས་པ་སྨྲ་བ།\",\"sanskrit\":\"vijñānavāda\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rnam par shes pa smra ba\"}},{\"uuid\":\"40a13f90-1efa-4c66-b539-68fe7a605aba\",\"authority\":\"883ecb53-cdb6-4a60-88da-51cd3a949aa9\",\"definition\":\"\",\"names\":{\"english\":\"Vikurvaṇarāja\",\"tibetan\":\"རྣམ་པར་འཕྲུལ་པའི་རྒྱལ་པོ།\",\"sanskrit\":\"vikurvaṇarāja\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"rnam par ’phrul pa’i rgyal po\"}},{\"uuid\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"authority\":\"244a342d-eb78-4762-a990-7501b3c37e47\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe wealthy \u003cspan data-glossary-id=\\\"UT22084-060-005-599\\\"\u003eLicchavi\u003c/span\u003e \u003cspan data-glossary-id=\\\"UT22084-060-005-595\\\"\u003elayman\u003c/span\u003e, from the city of \u003cspan data-glossary-id=\\\"UT22084-060-005-848\\\"\u003eVaiśālī\u003c/span\u003e, ranked as one of the great \u003cspan data-glossary-id=\\\"UT22084-060-005-513\\\"\u003ebodhisattvas\u003c/span\u003e. The main protagonist of this \u003cspan data-glossary-id=\\\"UT22084-060-005-670\\\"\u003esūtra\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"Vimalakīrti\",\"tibetan\":\"དྲི་མ་མེད་གྲགས་པ།\",\"sanskrit\":\"Vimalakīrti\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"dri ma med grags pa\"}},{\"uuid\":\"59bb2f56-d05e-43d5-a5a0-fe73d5597c93\",\"authority\":\"a1d9ee32-dfde-4b91-9bf4-9def86082df9\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eOne of the three Piṭakas, or “Baskets,” of the Buddhist canon; the one dealing specifically with the code of the monastic disipline. \u003c/p\u003e\",\"names\":{\"english\":\"Vinaya\",\"tibetan\":\"འདུལ་བ།\",\"sanskrit\":\"vinaya\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"’dul ba\"}},{\"uuid\":\"4ee3fa2c-4160-40ac-ad4c-1bf7f218e1ef\",\"authority\":\"ea8ba786-fc10-49cb-8def-e417af88f4ac\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThe \u003cspan class=\\\"ignore\\\"\u003evoidness of voidness\u003c/span\u003e, an important concept that indicates the \u003cspan data-glossary-id=\\\"UT22084-060-005-683\\\"\u003eultimate\u003c/span\u003e conceptuality of all terms, even those for the \u003cspan data-glossary-id=\\\"UT22084-060-005-683\\\"\u003eultimate\u003c/span\u003e, to avoid the major error of absolutising the \u003cspan data-glossary-id=\\\"UT22084-060-005-683\\\"\u003eultimate\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"voidness of voidness\",\"tibetan\":\"སྟོང་པ་ཉིད་ཀྱི་སྟོང་པ་ཉིད།\",\"sanskrit\":\"śūnyatāśūnyatā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"stong pa nyid kyi stong pa nyid\"}},{\"uuid\":\"06bddbe7-1139-4231-a993-4bc07054b09a\",\"authority\":\"898eef7e-4447-4e6f-9e44-8562bbd2d871\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eLit. “collect,” i.e., gather together into the \u003cspan data-glossary-id=\\\"UT22084-060-005-605\\\"\u003eMahāyāna\u003c/span\u003e.\u003c/p\u003e\",\"names\":{\"english\":\"win\",\"tibetan\":\"སྡུད་པ།\",\"sanskrit\":\"samgraha\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"sdud pa\"}},{\"uuid\":\"38971298-6f62-48f0-b271-36261568d441\",\"authority\":\"0463a3a0-7c70-451c-8dc5-e9db749dc718\",\"definition\":\"\",\"names\":{\"english\":\"wisdom\",\"tibetan\":\"ཤེས་རབ།\",\"sanskrit\":\"prajñā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"shes rab\"}},{\"uuid\":\"9c3e4b37-8479-4dee-a2a4-dc01c83a6254\",\"authority\":\"31657084-0b1c-484a-9de5-90999963f022\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eThird of the Three Doors of \u003cspan data-glossary-id=\\\"UT22084-060-005-597\\\"\u003eLiberation\u003c/span\u003e (see glossary). Objectively, it is equivalent to \u003cspan data-glossary-id=\\\"UT22084-060-005-689\\\"\u003evoidness\u003c/span\u003e; subjectively, it is the outcome of the holy \u003cspan data-glossary-id=\\\"UT22084-060-005-571\\\"\u003egnosis\u003c/span\u003e of \u003cspan data-glossary-id=\\\"UT22084-060-005-689\\\"\u003evoidness\u003c/span\u003e as the realization of the \u003cspan data-glossary-id=\\\"UT22084-060-005-683\\\"\u003eultimate\u003c/span\u003e lack of anything to wish for, whether \u003cspan data-glossary-id=\\\"UT22084-060-005-689\\\"\u003evoidness\u003c/span\u003e itself, or even Buddhahood. See “\u003cspan data-glossary-id=\\\"UT22084-060-005-550\\\"\u003eemptiness\u003c/span\u003e.”\u003c/p\u003e\",\"names\":{\"english\":\"wishlessness\",\"tibetan\":\"སྨོན་པ་མེད་པ།\",\"sanskrit\":\"apraṇihitatā\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"smon pa med pa\"}},{\"uuid\":\"d4a6a09d-8d75-48cd-91f4-20308ea589fb\",\"authority\":\"ba6e1ca5-841b-4e84-ac84-dbb5ee6cff8c\",\"definition\":\"\u003cp class=\\\"definition\\\"\u003eSeventh century Chinese scholar. One of the greatest translators in world history, he traveled to India, where he lived for many years, studying Sanskrit and all the sciences of the day. On his return to China he translated many volumes of important philosophical and religious works. He translated this \u003cspan data-glossary-id=\\\"UT22084-060-005-670\\\"\u003esūtra\u003c/span\u003e in 650.\u003c/p\u003e\",\"names\":{\"english\":\"Xuanzang\",\"tibetan\":\"\",\"sanskrit\":\"\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"\"}},{\"uuid\":\"38387383-1d37-4070-baa8-57f918748825\",\"authority\":\"6bc88464-d01f-41dd-83e3-906807fba845\",\"definition\":\"\u003cp\u003eA class of nonhuman beings who inhabit forests, mountainous areas, and other natural spaces, or serve as guardians of villages and towns, and may be propitiated for health, wealth, protection, and other boons, or controlled through magic. According to tradition, their homeland is in the north, where they live under the rule of the Great King Vaiśravaṇa.\u003c/p\u003e\u003cp\u003e Several members of this class have been deified as gods of wealth (these include the just-mentioned Vaiśravaṇa) or as bodhisattva generals of yakṣa armies, and have entered the Buddhist pantheon in a variety of forms, including, in tantric Buddhism, those of wrathful deities.\u003c/p\u003e\",\"names\":{\"english\":\"yakṣa\",\"tibetan\":\"གནོད་སྦྱིན།\",\"sanskrit\":\"yakṣa\",\"pali\":\"\",\"chinese\":\"\",\"wylie\":\"gnod sbyin\"}}]}]\n"])</script><div hidden id="S:5"><div dir="ltr" data-orientation="horizontal" data-slot="tabs" class="flex flex-col w-full gap-0 @container/sidebar"><div class="sticky top-0 pt-1 pb-2 z-10 w-full rounded-t bg-background overflow-x-auto text-center"><div role="tablist" aria-orientation="horizontal" data-slot="tabs-list" class="bg-background gap-1 sm:gap-3 h-10 items-center justify-center sm:p-1 w-fit px-6 inline-flex mx-auto rounded-none" tabindex="-1" data-orientation="horizontal" style="outline:none"><button type="button" role="tab" aria-selected="true" aria-controls="radix-_R_2npftt6btb_-content-endnotes" data-state="active" id="radix-_R_2npftt6btb_-trigger-endnotes" data-slot="tabs-trigger" class="inline-flex items-center justify-center whitespace-nowrap px-1 py-0.75 text-sm data-[state=active]:font-semibold ring-offset-background transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-background text-foreground border-b-2 border-transparent data-[state=active]:border-primary-300 decoration-primary-25 hover:text-primary hover:border-primary/20 hover:cursor-pointer" tabindex="-1" data-orientation="horizontal" data-radix-collection-item="">Notes</button><button type="button" role="tab" aria-selected="false" aria-controls="radix-_R_2npftt6btb_-content-glossary" data-state="inactive" id="radix-_R_2npftt6btb_-trigger-glossary" data-slot="tabs-trigger" class="inline-flex items-center justify-center whitespace-nowrap px-1 py-0.75 text-sm data-[state=active]:font-semibold ring-offset-background transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-background text-foreground border-b-2 border-transparent data-[state=active]:border-primary-300 decoration-primary-25 hover:text-primary hover:border-primary/20 hover:cursor-pointer" tabindex="-1" data-orientation="horizontal" data-radix-collection-item="">Glossary</button><button type="button" role="tab" aria-selected="false" aria-controls="radix-_R_2npftt6btb_-content-bibliography" data-state="inactive" id="radix-_R_2npftt6btb_-trigger-bibliography" data-slot="tabs-trigger" class="inline-flex items-center justify-center whitespace-nowrap px-1 py-0.75 text-sm data-[state=active]:font-semibold ring-offset-background transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-background text-foreground border-b-2 border-transparent data-[state=active]:border-primary-300 decoration-primary-25 hover:text-primary hover:border-primary/20 hover:cursor-pointer" tabindex="-1" data-orientation="horizontal" data-radix-collection-item="">Biblio</button><button type="button" role="tab" aria-selected="false" aria-controls="radix-_R_2npftt6btb_-content-abbreviations" data-state="inactive" id="radix-_R_2npftt6btb_-trigger-abbreviations" data-slot="tabs-trigger" class="inline-flex items-center justify-center whitespace-nowrap px-1 py-0.75 text-sm data-[state=active]:font-semibold ring-offset-background transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-background text-foreground border-b-2 border-transparent data-[state=active]:border-primary-300 decoration-primary-25 hover:text-primary hover:border-primary/20 hover:cursor-pointer" tabindex="-1" data-orientation="horizontal" data-radix-collection-item="">Abbr</button></div></div><div class="px-2"><div class="overflow-auto md:h-[calc(100vh-8.5rem)] h-[calc(100vh-4rem)] rounded bg-surface"><div class="rounded ps-10 pe-4 max-w-readable mx-auto"><div data-state="active" data-orientation="horizontal" role="tabpanel" aria-labelledby="radix-_R_2npftt6btb_-trigger-endnotes" id="radix-_R_2npftt6btb_-content-endnotes" tabindex="0" data-slot="tabs-content" class="mt-2 ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 data-[state=inactive]:hidden" style="animation-duration:0s"><div class="h-0"></div><div></div><div class="h-0"></div><div class="flex flex-col gap-4 pb-8"><div class="flex gap-5"><div class="animate-pulse rounded-md bg-foreground/10 h-6 w-6"></div><div class="animate-pulse rounded-md bg-foreground/10 h-32 grow"></div></div><div class="flex gap-5"><div class="animate-pulse rounded-md bg-foreground/10 h-6 w-6"></div><div class="animate-pulse rounded-md bg-foreground/10 h-32 grow"></div></div><div class="flex gap-5"><div class="animate-pulse rounded-md bg-foreground/10 h-6 w-6"></div><div class="animate-pulse rounded-md bg-foreground/10 h-32 grow"></div></div></div></div><div data-state="inactive" data-orientation="horizontal" role="tabpanel" aria-labelledby="radix-_R_2npftt6btb_-trigger-glossary" id="radix-_R_2npftt6btb_-content-glossary" tabindex="0" data-slot="tabs-content" class="mt-2 ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 pb-8 data-[state=inactive]:hidden"><div class="flex flex-col w-full"><div id="glossary" class="relative scroll-mt-20"><button type="button" id="radix-_R_2lanpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4 @c/sidebar:mt-5 mt-6">g.</button><div class="passage pl-6 @c/sidebar:pl-4"><h2 class="font-serif font-light text-primary scroll-m-20 text-xl @c/sidebar:mt-4 mt-6 @c/sidebar:pb-2 pb-3 @c/sidebar:text-left text-center section-title">Glossary</h2></div></div><div class="mt-3 flex flex-col gap-6"><div id="ccc150b4-2233-4e01-a530-7cc6f0aec169" class="relative scroll-mt-20"><button type="button" id="radix-_R_40d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.1</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Abhidharma</div><ul class="ml-4 list-disc"><li class="italic">chos mngon pa</li><li class="pt-1"><span class="font-tibetan text-base">ཆོས་མངོན་པ།</span></li><li class="italic">abhidharma</li></ul><div class="glossary-instance-definition"><p class="definition">Conventionally, the general name for the Buddhist teachings presented in a scientific manner, as a fully elaborated transcendental psychology. As one of the branches of the Canon, it corresponds to the discipline of <span data-glossary-id="UT22084-060-005-691">wisdom</span> (the <em class="foreign break text-sa" lang="sa-LATN"><span data-glossary-id="UT22084-060-005-670">Sūtras</span></em> corresponding to <span data-glossary-id="UT22084-060-005-612">meditation</span>, and the <em class="foreign break text-sa" lang="sa-LATN"><span data-glossary-id="UT22084-060-005-688">Vinaya</span></em> to <span data-glossary-id="UT22084-060-005-615">morality</span>). Ultimately the <span class="ignore">Abhidharma</span> <em class="emph">is</em> “pure <span data-glossary-id="UT22084-060-005-691">wisdom</span>, with its coordinate mental functions” (<em class="foreign break text-sa" lang="sa-LATN">Prajñāmalā sānucārā</em>), according to <span data-glossary-id="UT22084-060-005-819">Vasubandhu</span>. </p></div></div></div></div><div id="ed2ba03e-ccf4-47ec-adef-dd0302550a97" class="relative scroll-mt-20"><button type="button" id="radix-_R_40l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.2</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Abhi­dharma­kośa</div><ul class="ml-4 list-disc"><li class="italic">chos mngon pa’i mdzod</li><li class="pt-1"><span class="font-tibetan text-base">ཆོས་མངོན་པའི་མཛོད།</span></li><li class="italic">abhi­dharma­kośa</li></ul><div class="glossary-instance-definition"><p class="definition">An important work written by <span data-glossary-id="UT22084-060-005-819">Vasubandhu</span>, probably in the fourth century, as a critical compendium of the Abhidharmic science.</p></div></div></div></div><div id="1ce645a6-d4d1-4912-a8c2-9617e8932dd1" class="relative scroll-mt-20"><button type="button" id="radix-_R_40t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.3</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Abhirati</div><ul class="ml-4 list-disc"><li class="italic">mngon par dga’ ba</li><li class="pt-1"><span class="font-tibetan text-base">མངོན་པར་དགའ་བ།</span></li><li class="italic">abhirati</li></ul><div class="glossary-instance-definition"><p class="definition">Lit. “Intense Delight.” The universe, or <span data-glossary-id="UT22084-060-005-516">buddhafield</span> of the <span data-glossary-id="UT22084-060-005-672">Tathāgata</span> <span data-glossary-id="UT22084-060-005-697">Akṣobhya</span>, lying in the east beyond innumerable galaxies, whence <span data-glossary-id="UT22084-060-005-1257">Vimalakīrti</span> came to reincarnate in our <span data-glossary-id="UT22084-060-005-841">Sahā</span> universe.</p></div></div></div></div><div id="920e3646-8f88-46a8-a034-6f9cd1a69c0d" class="relative scroll-mt-20"><button type="button" id="radix-_R_4155anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.4</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">absence of self</div><ul class="ml-4 list-disc"><li class="italic">bdag med pa</li><li class="pt-1"><span class="font-tibetan text-base">བདག་མེད་པ།</span></li><li class="italic">anātmatā, nairātmya</li></ul><div class="glossary-instance-definition"><p class="definition">This describes actual reality, as finally there is no enduring person himself or thing itself, since persons and things exist only in the relative, conventional, or superficial sense, and not in any <span data-glossary-id="UT22084-060-005-683">ultimate</span> or absolute sense. To understand Buddhist teaching correctly, we must be clear about the two senses (conventional/<span data-glossary-id="UT22084-060-005-683">ultimate</span>, or relative/absolute), since mistaking denial of <span data-glossary-id="UT22084-060-005-683">ultimate</span> <span data-glossary-id="UT22084-060-005-649">self</span> as denial of conventional <span data-glossary-id="UT22084-060-005-649">self</span> leads to nihilism, and mistaking affirmation of conventional <span data-glossary-id="UT22084-060-005-649">self</span> as affirmation of <span data-glossary-id="UT22084-060-005-683">ultimate</span> <span data-glossary-id="UT22084-060-005-649">self</span> leads to absolutism. Nihilism and absolutism effectively prevent us from realizing our <span data-glossary-id="UT22084-060-005-551">enlightenment</span>, hence are to be avoided.</p></div></div></div></div><div id="a1e049fe-15a3-42ec-9ae6-63792aa4ffc6" class="relative scroll-mt-20"><button type="button" id="radix-_R_41d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.5</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">absorption, meditation</div><ul class="ml-4 list-disc"><li class="italic">snyoms par ’jug</li><li class="pt-1"><span class="font-tibetan text-base">སྙོམས་པར་འཇུག</span></li><li class="italic">samāpatti</li></ul><div class="glossary-instance-definition"><p class="definition">“<span class="ignore">Absorption</span>” has been translated as “<span data-glossary-id="UT22084-060-005-612">meditation</span>,” “<span data-glossary-id="UT22084-060-005-528">contemplation</span>,” “attainment,” etc., and any of these words might serve. The problem is to establish one English word for each of the important Sanskrit words <em class="foreign break text-sa" lang="sa-LATN">samāpatti</em>, <em class="foreign break text-sa" lang="sa-LATN">dhyāna</em>, <em class="foreign break text-sa" lang="sa-LATN"><span data-glossary-id="UT22084-060-005-642">samādhi</span></em>, <em class="foreign break text-sa" lang="sa-LATN">bhāvanā</em>, etc., so as to preserve a consistency with the original. Therefore, I have adopted for these terms, respectively, “<span class="ignore">absorption</span>,” “<span data-glossary-id="UT22084-060-005-528">contemplation</span>,” “<span data-glossary-id="UT22084-060-005-521">concentration</span>” and “realization” or “cultivation,” reserving the word “<span data-glossary-id="UT22084-060-005-612">meditation</span>” for general use with any of the terms when they are used not in a specific sense but to indicate mind-practice in general. </p></div></div></div></div><div id="72ea6449-0c42-401c-bff0-be87bffdfd07" class="relative scroll-mt-20"><button type="button" id="radix-_R_41l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.6</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">absorption, meditation</div><ul class="ml-4 list-disc"><li class="italic">snyoms par ’jug</li><li class="pt-1"><span class="font-tibetan text-base">སྙོམས་པར་འཇུག</span></li><li class="italic">samāpatti</li></ul><div class="glossary-instance-definition"><p class="definition">See “<span data-glossary-id="UT22084-060-005-500">absorption</span>.”</p></div></div></div></div><div id="62aa0bc0-1ed1-49a6-b18e-9b0f37c6aeef" class="relative scroll-mt-20"><button type="button" id="radix-_R_41t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.7</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">affliction, passion</div><ul class="ml-4 list-disc"><li class="italic">nyon mongs, nyon mongs</li><li class="pt-1"><span class="font-tibetan text-base">ཉོན་མོངས།, ཉོན་མོངས།</span></li><li class="italic">kleśa, kleśa</li></ul><div class="glossary-instance-definition"><p class="definition">Desire, hatred and anger, dullness, pride, and jealousy, as well as all their derivatives, said to number 84,000. Also translated “<span data-glossary-id="UT22084-060-005-630">passions</span>.”</p></div></div></div></div><div id="2370c8e3-79cc-4eab-bc82-33939081f558" class="relative scroll-mt-20"><button type="button" id="radix-_R_4255anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.8</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">affliction, passion</div><ul class="ml-4 list-disc"><li class="italic">nyon mongs, nyon mongs</li><li class="pt-1"><span class="font-tibetan text-base">ཉོན་མོངས།, ཉོན་མོངས།</span></li><li class="italic">kleśa, kleśa</li></ul><div class="glossary-instance-definition"><p class="definition">Desire, hatred and anger, dullness, pride, and jealousy, as well as all their derivatives, said to number 84,000. Also translated “<span data-glossary-id="UT22084-060-005-501">afflictions</span>.”</p></div></div></div></div><div id="95840062-0b03-40c7-ad24-49f28628a43e" class="relative scroll-mt-20"><button type="button" id="radix-_R_42d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.9</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">aggregate</div><ul class="ml-4 list-disc"><li class="italic">phung po</li><li class="pt-1"><span class="font-tibetan text-base">ཕུང་པོ།</span></li><li class="italic">skandha</li></ul><div class="glossary-instance-definition"><p class="definition">This translation of <em class="foreign break text-sa" lang="sa-LATN">skandha</em> is fairly well established, although some prefer the monosyllabic “group.” It is important to bear in mind that the original <em class="foreign break text-sa" lang="sa-LATN">skandha</em> has the sense of “pile,” or “heap,” which has the connotation of utter lack of internal structure, of a randomly collocated pile of things; thus “group” may convey a false connotation of structure and ordered arrangement. The five “compulsive” (<em class="foreign break text-sa" lang="sa-LATN">upādāna</em>) <span class="ignore">aggregates</span> are of great importance as a schema for introspective <span data-glossary-id="UT22084-060-005-612">meditation</span> in the <span data-glossary-id="UT22084-060-005-498">Abhidharma</span>, wherein each is defined with the greatest subtlety and precision. In fact, the five terms <em class="foreign break text-sa" lang="sa-LATN">rūpa</em>, <em class="foreign break text-sa" lang="sa-LATN">vedanā</em>, <em class="foreign break text-sa" lang="sa-LATN">samjñā</em>, <em class="foreign break text-sa" lang="sa-LATN">saṃskāra</em>, and <em class="foreign break text-sa" lang="sa-LATN">vijñāna</em> have such a particular technical sense that many translators have preferred to leave them untranslated. Nevertheless, in the <span data-glossary-id="UT22084-060-005-670">sūtra</span> context, where the five are meant rather more simply to represent the relative living being (in the <span data-glossary-id="UT22084-060-005-637">realm of desire</span>), it seems preferable to give a translation‍—in spite of the drawbacks of each possible term‍—in order to convey the same sense of a total categorization of the psychophysical complex. Thus, for <em class="foreign break text-sa" lang="sa-LATN">rūpa</em>, “<span data-glossary-id="UT22084-060-005-610">matter</span>” is preferred to “form” because it more concretely connotes the physical and gross; for <em class="foreign break text-sa" lang="sa-LATN">vedanā</em>, “<span data-glossary-id="UT22084-060-005-651">sensation</span>” is adopted, as limited to the aesthetic; for <em class="foreign break text-sa" lang="sa-LATN">samjñā</em>, “<span data-glossary-id="UT22084-060-005-588">intellect</span>” is useful in conveying the sense of verbal, conceptual intelligence. For <em class="foreign break text-sa" lang="sa-LATN">samskāra</em>, which covers a number of mental functions as well as inanimate forces, “<span data-glossary-id="UT22084-060-005-616">motivation</span>” gives a general idea. And “<span data-glossary-id="UT22084-060-005-527">consciousness</span>” is so well established for <em class="foreign break text-sa" lang="sa-LATN">vijñāna</em> (although what we normally think of as <span data-glossary-id="UT22084-060-005-527">consciousness</span> is more like <em class="foreign break text-sa" lang="sa-LATN">samjñā</em>, i.e., conceptual and notional, and <em class="foreign break text-sa" lang="sa-LATN">vijñāna</em> is rather the “pure awareness” prior to concepts) as to be left unchallenged. </p></div></div></div></div><div id="82d9a387-35b2-40eb-9e17-30cb35396ea1" class="relative scroll-mt-20"><button type="button" id="radix-_R_42l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.10</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">aids to enlightenment</div><ul class="ml-4 list-disc"><li class="italic">byang chub kyi phyogs kyi chos</li><li class="pt-1"><span class="font-tibetan text-base">བྱང་ཆུབ་ཀྱི་ཕྱོགས་ཀྱི་ཆོས།</span></li><li class="italic">bodhi­pakṣika­dharma</li></ul><div class="glossary-instance-definition"><p class="definition">See “<span data-glossary-id="UT22084-060-005-676">thirty-seven aids to enlightenment</span>”</p></div></div></div></div><div id="6162f2ee-5256-4e0d-9fc5-edcb092f77d7" class="relative scroll-mt-20"><button type="button" id="radix-_R_42t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.11</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ajita Keśakambala</div><ul class="ml-4 list-disc"><li class="italic">mi pham sgra’i la ba can</li><li class="pt-1"><span class="font-tibetan text-base">མི་ཕམ་སྒྲའི་ལ་བ་ཅན།</span></li><li class="italic">ajita keśakambala</li></ul><div class="glossary-instance-definition"><p class="definition">One of the six <span data-glossary-id="UT22084-060-005-627">outsider</span> teachers defeated by the <span data-glossary-id="UT22084-060-005-515">Buddha</span> at <span data-glossary-id="UT22084-060-005-844">Śrāvastī</span>.</p></div></div></div></div><div id="ffde421f-3310-441c-9b2b-58906d7447c7" class="relative scroll-mt-20"><button type="button" id="radix-_R_4355anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.12</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Akaniṣṭha</div><ul class="ml-4 list-disc"><li class="italic">’og min</li><li class="pt-1"><span class="font-tibetan text-base">འོག་མིན།</span></li><li class="italic">akaniṣṭha</li></ul><div class="glossary-instance-definition"><p class="definition">The highest heaven of the form-world, where a <span data-glossary-id="UT22084-060-005-515">buddha</span> always receives the anointment of the <span data-glossary-id="UT22084-060-005-683">ultimate</span> <span data-glossary-id="UT22084-060-005-691">wisdom</span>, reaching there mentally from his <span data-glossary-id="UT22084-060-005-648">seat of enlightenment</span> under the Bodhi-tree.</p></div></div></div></div><div id="9e2da1d0-a4aa-433e-aab2-ab4c9a510820" class="relative scroll-mt-20"><button type="button" id="radix-_R_43d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.13</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Akṣayamati</div><ul class="ml-4 list-disc"><li class="italic">blo gros mi zad pa</li><li class="pt-1"><span class="font-tibetan text-base">བློ་གྲོས་མི་ཟད་པ།</span></li><li class="italic">akṣayamati</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-060-005-513">bodhisattva</span> in the assembly at <span data-glossary-id="UT22084-060-005-1257">Vimalakīrti</span>’s house, often figuring in other <span data-glossary-id="UT22084-060-005-605">Mahāyāna</span> <span data-glossary-id="UT22084-060-005-670">sūtras</span>, especially <cite class="title break text-sa" lang="sa-LATN">Akṣayamati­nirdeśa­sūtra</cite>. </p></div></div></div></div><div id="230b32ae-e885-45ea-9324-b646974f8fa5" class="relative scroll-mt-20"><button type="button" id="radix-_R_43l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.14</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Akṣobhya</div><ul class="ml-4 list-disc"><li class="italic">mi ’khrugs pa</li><li class="pt-1"><span class="font-tibetan text-base">མི་འཁྲུགས་པ།</span></li><li class="italic">akṣobhya</li></ul><div class="glossary-instance-definition"><p class="definition"><span data-glossary-id="UT22084-060-005-515">Buddha</span> of the universe <span data-glossary-id="UT22084-060-005-824">Abhirati</span>, presiding over the eastern direction; also prominent in tantric works as one of the five dhyāni <span data-glossary-id="UT22084-060-005-515">buddhas</span>, or <span data-glossary-id="UT22084-060-005-672">tathāgatas</span> (see Lamotte, pp. 360-362, n. 9).</p></div></div></div></div><div id="f4f18382-cdf8-419b-b267-5fcdb5b97804" class="relative scroll-mt-20"><button type="button" id="radix-_R_43t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.15</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Amitābha</div><ul class="ml-4 list-disc"><li class="italic">snang ba mtha’ yas</li><li class="pt-1"><span class="font-tibetan text-base">སྣང་བ་མཐའ་ཡས།</span></li><li class="italic">amitābha</li></ul><div class="glossary-instance-definition"><p class="definition">The <span data-glossary-id="UT22084-060-005-515">Buddha</span> of boundless light; one of the five <span data-glossary-id="UT22084-060-005-672">Tathāgatas</span> in Tantrism; a visitor in <span data-glossary-id="UT22084-060-005-1257">Vimalakīrti</span>’s house, according to the goddess’s report.</p></div></div></div></div><div id="837c2527-85cb-4a76-bf21-913ecb4a5d69" class="relative scroll-mt-20"><button type="button" id="radix-_R_4455anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.16</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Āmrapālī</div><ul class="ml-4 list-disc"><li class="italic">a mra srung ba</li><li class="pt-1"><span class="font-tibetan text-base">ཨ་མྲ་སྲུང་བ།</span></li><li class="italic">āmrapālī</li></ul><div class="glossary-instance-definition"><p class="definition">A courtesan of <span data-glossary-id="UT22084-060-005-848">Vaiśālī</span> who gave her garden to the <span data-glossary-id="UT22084-060-005-515">Buddha</span> and his retinue, where they stay during the events of the <span data-glossary-id="UT22084-060-005-670">sūtra</span>.</p></div></div></div></div><div id="240d1cab-1211-41e4-8623-ecceecfb763d" class="relative scroll-mt-20"><button type="button" id="radix-_R_44d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.17</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ānanda</div><ul class="ml-4 list-disc"><li class="italic">kun dga’ bo</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་དགའ་བོ།</span></li><li class="italic">ānanda</li></ul><div class="glossary-instance-definition"><p class="definition">A major śrāvaka disciple and personal attendant of the Buddha Śākyamuni during the last twenty-five years of his life. He was a cousin of the Buddha (according to the <cite class="title break text-sa" lang="sa-LATN">Mahāvastu</cite>, he was a son of Śuklodana, one of the brothers of King Śuddhodana, which means he was a brother of Devadatta; other sources say he was a son of Amṛtodana, another brother of King Śuddhodana, which means he would have been a brother of Aniruddha).</p><p class="definition">Ānanda, having always been in the Buddha’s presence, is said to have memorized all the teachings he heard and is celebrated for having recited all the Buddha’s teachings by memory at the first council of the Buddhist saṅgha, thus preserving the teachings after the Buddha’s parinirvāṇa. The phrase “Thus did I hear at one time,” found at the beginning of the sūtras, usually stands for his recitation of the teachings. He became a patriarch after the passing of Mahākāśyapa.</p><p class="definition">See also <a href="end-notes.xhtml#UT22084-060-005-950" data-pointer-type="id">n.88</a> and <a href="end-notes.xhtml#UT22084-060-005-1055" data-pointer-type="id">n.193</a>.</p></div></div></div></div><div id="0aca3d2b-9f37-4ab1-aec7-084006cafb82" class="relative scroll-mt-20"><button type="button" id="radix-_R_44l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.18</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ananta­guṇa­ratna­vyūha</div><ul class="ml-4 list-disc"><li class="italic">yon tan rin chen mtha’ yas bkod pa</li><li class="pt-1"><span class="font-tibetan text-base">ཡོན་ཏན་རིན་ཆེན་མཐའ་ཡས་བཀོད་པ།</span></li><li class="italic">ananta­guṇa­ratna­vyūha</li></ul><div class="glossary-instance-definition"><p class="definition">Lit. “infinite array of jewel-qualities.” A universe of <span data-glossary-id="UT22084-060-005-515">Buddha</span> <span data-glossary-id="UT22084-060-005-787">Ratnavyūha</span>, also mentioned in the <cite class="title break text-sa" lang="sa-LATN">Lalita­vistara­sūtra</cite>. </p></div></div></div></div><div id="8d8f294c-e815-4e55-8049-80f4e6b89f5f" class="relative scroll-mt-20"><button type="button" id="radix-_R_44t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.19</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Anārambaṇa­dhyāyin</div><ul class="ml-4 list-disc"><li class="italic">dmigs pa med pa’i bsam gtan</li><li class="pt-1"><span class="font-tibetan text-base">དམིགས་པ་མེད་པའི་བསམ་གཏན།</span></li><li class="italic">anārambaṇa­dhyāyin</li></ul></div></div></div><div id="96cef1f6-a714-4f47-88ef-a5a912b3720d" class="relative scroll-mt-20"><button type="button" id="radix-_R_4555anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.20</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Anikṣiptadhura</div><ul class="ml-4 list-disc"><li class="italic">brtson pa mi ’dor ba</li><li class="pt-1"><span class="font-tibetan text-base">བརྩོན་པ་མི་འདོར་བ།</span></li><li class="italic">anikṣiptadhura</li></ul></div></div></div><div id="16a55775-56db-4c97-b4ea-04f04e755e72" class="relative scroll-mt-20"><button type="button" id="radix-_R_45d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.21</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Aniruddha</div><ul class="ml-4 list-disc"><li class="italic">ma ’gags pa</li><li class="pt-1"><span class="font-tibetan text-base">མ་འགགས་པ།</span></li><li class="italic">aniruddha</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-060-005-661">śrāvaka</span> disciple and cousin of the <span data-glossary-id="UT22084-060-005-515">Buddha</span> who was famed for his meditative prowess and <span data-glossary-id="UT22084-060-005-669">superknowledges</span>. See also <a href="end-notes.xhtml#UT22084-060-005-940" data-pointer-type="id">n.78</a>.</p></div></div></div></div><div id="8584345b-bf7d-481b-ac82-4146d2374b3c" class="relative scroll-mt-20"><button type="button" id="radix-_R_45l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.22</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">arhat</div><ul class="ml-4 list-disc"><li class="italic">dgra bcom pa</li><li class="pt-1"><span class="font-tibetan text-base">དགྲ་བཅོམ་པ།</span></li><li class="italic">arhat</li></ul><div class="glossary-instance-definition"><p class="definition">According to Buddhist tradition, one who has conquered his enemy <span data-glossary-id="UT22084-060-005-630">passions</span> (<em class="foreign break text-sa" lang="sa-LATN">kleśa-ari-hata</em>) and reached the supreme purity. The term can refer to <span data-glossary-id="UT22084-060-005-515">buddhas</span> as well as to those who have reached realization of the <span data-glossary-id="UT22084-060-005-662">Disciple Vehicle</span>.</p></div></div></div></div><div id="8ab1dcbc-81ec-4de9-9896-d229ab475fc4" class="relative scroll-mt-20"><button type="button" id="radix-_R_45t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.23</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Āryadeva</div><ul class="ml-4 list-disc"><li class="italic">’phags pa lha</li><li class="pt-1"><span class="font-tibetan text-base">འཕགས་པ་ལྷ།</span></li><li class="italic">āryadeva</li></ul><div class="glossary-instance-definition"><p class="definition">One of the great masters of Indian Buddhism. The main disciple of <span data-glossary-id="UT22084-060-005-753">Nāgārjuna</span>, he lived in the early a.d. centuries and wrote numerous important works of <span data-glossary-id="UT22084-060-005-603">Mādhyamika</span> philosophy.</p></div></div></div></div><div id="f6fd6d29-a938-42f9-93ff-3a9bfead6c1e" class="relative scroll-mt-20"><button type="button" id="radix-_R_4655anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.24</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Āryāsaṅga</div><ul class="ml-4 list-disc"><li class="italic">thogs med, ’phags pa thogs med</li><li class="pt-1"><span class="font-tibetan text-base">ཐོགས་མེད།, འཕགས་པ་ཐོགས་མེད།</span></li><li class="italic">asaṅga, āryāsaṅga</li></ul><div class="glossary-instance-definition"><p class="definition">This great Indian philosopher lived in the fourth century and was the founder of the <span data-glossary-id="UT22084-060-005-687">Vijñānavāda</span>, or “<span class="ignore">Consciousness</span>-Only,” school of <span data-glossary-id="UT22084-060-005-605">Mahāyāna</span> Buddhism.</p></div></div></div></div><div id="d998dae5-2058-4b49-8dff-5dc8ca681495" class="relative scroll-mt-20"><button type="button" id="radix-_R_46d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.25</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Aśoka</div><ul class="ml-4 list-disc"><li class="italic">mya ngan med pa</li><li class="pt-1"><span class="font-tibetan text-base">མྱ་ངན་མེད་པ།</span></li><li class="italic">aśoka</li></ul><div class="glossary-instance-definition"><p class="definition">Universe whence comes the <span data-glossary-id="UT22084-060-005-710">Brahmā</span> <span data-glossary-id="UT22084-060-005-805">Śikhin</span>.</p></div></div></div></div><div id="92f37c52-4181-48ff-8345-2132611c4071" class="relative scroll-mt-20"><button type="button" id="radix-_R_46l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.26</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">asura</div><ul class="ml-4 list-disc"><li class="italic">lha ma yin</li><li class="pt-1"><span class="font-tibetan text-base">ལྷ་མ་ཡིན།</span></li><li class="italic">asura</li></ul><div class="glossary-instance-definition"><p class="definition">Titan .</p></div></div></div></div><div id="4288ecec-62d3-4cb7-98ba-da11e7949e29" class="relative scroll-mt-20"><button type="button" id="radix-_R_46t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.27</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">auspicious signs and marks</div><ul class="ml-4 list-disc"><li class="italic">mtshan dang dpe byad bzang po</li><li class="pt-1"><span class="font-tibetan text-base">མཚན་དང་དཔེ་བྱད་བཟང་པོ།</span></li><li class="italic">lakṣaṇānuvyañjana</li></ul><div class="glossary-instance-definition"><p class="definition">The thirty-two signs and the eighty marks of a superior being.</p></div></div></div></div><div id="453b28f2-7da6-40ba-8cd2-772f8f6d626e" class="relative scroll-mt-20"><button type="button" id="radix-_R_4755anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.28</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Avalokiteśvara</div><ul class="ml-4 list-disc"><li class="italic">spyan ras gzigs kyi dbang phyug</li><li class="pt-1"><span class="font-tibetan text-base">སྤྱན་རས་གཟིགས་ཀྱི་དབང་ཕྱུག</span></li><li class="italic">avalokiteśvara</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-060-005-513">bodhisattva</span> emblematic of the <span data-glossary-id="UT22084-060-005-574">great compassion</span>; of great importance in Tibet as special protector of the religious <span class="ignore">life</span> of the country and in China, in female form, as Kwanyin, protectress of women, children, and animals.</p></div></div></div></div><div id="1b1c26fc-4bc7-4931-98c7-990b354311fe" class="relative scroll-mt-20"><button type="button" id="radix-_R_47d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.29</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Avataṃsaka</div><ul class="ml-4 list-disc"><li class="italic">phal po che</li><li class="pt-1"><span class="font-tibetan text-base">ཕལ་པོ་ཆེ།</span></li><li class="italic">avataṃsaka</li></ul><div class="glossary-instance-definition"><p class="definition">This vast <span data-glossary-id="UT22084-060-005-605">Mahāyāna</span> <span data-glossary-id="UT22084-060-005-670">sūtra</span> (also called the <cite class="title break text-sa" lang="sa-LATN"><span data-glossary-id="UT22084-060-005-851">Buddhāvataṃsaka</span></cite>) deals with the miraculous side of the <span data-glossary-id="UT22084-060-005-605">Mahāyāna</span>. It is important in relation to the Vimalakīrtinirdeśa, since the latter’s fifth chapter, “The <span data-glossary-id="UT22084-060-005-586">Inconceivable Liberation</span>,” is a highly abbreviated version of the essential teaching of the former.</p></div></div></div></div><div id="76486a80-1221-41fd-ba60-de89ee8525f0" class="relative scroll-mt-20"><button type="button" id="radix-_R_47l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.30</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">bad migrations</div><ul class="ml-4 list-disc"><li class="italic">ngan song</li><li class="pt-1"><span class="font-tibetan text-base">ངན་སོང་།</span></li><li class="italic">durgati</li></ul><div class="glossary-instance-definition"><p class="definition">The three <span class="ignore">bad migrations</span> are those of (1) denizens of hells, (2) inhabitants of the “limbo” of the <em class="foreign break text-sa" lang="sa-LATN">pretaloka</em>, where one wanders as an insatiably hungry and thirsty wretch, and (3) animals, who are trapped in the pattern of mutual devouring (Tib. <em class="foreign text-wy" lang="bo-LATN">gcig la gcig za</em>).</p></div></div></div></div><div id="526ff6d2-f868-424a-b128-8312e9a28d7c" class="relative scroll-mt-20"><button type="button" id="radix-_R_47t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.31</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">basic precepts</div><ul class="ml-4 list-disc"><li class="italic">bslab pa’i gzhi rnams</li><li class="pt-1"><span class="font-tibetan text-base">བསླབ་པའི་གཞི་རྣམས།</span></li><li class="italic">sikṣāpada</li></ul><div class="glossary-instance-definition"><p class="definition">These <span class="ignore">basic precepts</span> are five in number for the laity: (1) not killing, (2) not stealing, (3) chastity, (4) not lying, and (5) avoiding intoxicants. For monks, there are three or five more; avoidance of such things as perfumes, makeup, ointments, garlands, high beds, and afternoon meals.</p></div></div></div></div><div id="31fe2706-f727-4ee8-b460-9b438431fd2c" class="relative scroll-mt-20"><button type="button" id="radix-_R_4855anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.32</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bhaiṣajyarāja</div><ul class="ml-4 list-disc"><li class="italic">sman gyi rgyal po</li><li class="pt-1"><span class="font-tibetan text-base">སྨན་གྱི་རྒྱལ་པོ།</span></li><li class="italic">bhaiṣajyarāja</li></ul><div class="glossary-instance-definition"><p class="definition">Lit. “King of Healers.” In the story of <span data-glossary-id="UT22084-060-005-794">Śākyamuni</span>’s former <span class="ignore">life</span> in this <span data-glossary-id="UT22084-060-005-670">sūtra</span>, he is the <span data-glossary-id="UT22084-060-005-672">tathāgata</span> of the universe <span data-glossary-id="UT22084-060-005-742">Mahāvyūha</span>, during the eon called <span data-glossary-id="UT22084-060-005-685">Vicaraṇa</span>, who taught Prince <span data-glossary-id="UT22084-060-005-713">Candracchattra</span> about <span data-glossary-id="UT22084-060-005-537">Dharma</span>-worship. In later Buddhism, this <span data-glossary-id="UT22084-060-005-515">buddha</span> is believed to be the supernatural patron of healing and medicine. </p></div></div></div></div><div id="088e4e49-b2dd-41a5-88bf-d32d42333ac2" class="relative scroll-mt-20"><button type="button" id="radix-_R_48d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.33</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Bhāvaviveka</div><ul class="ml-4 list-disc"><li class="italic">legs ldan ’byed</li><li class="pt-1"><span class="font-tibetan text-base">ལེགས་ལྡན་འབྱེད།</span></li><li class="italic">bhāvaviveka</li></ul><div class="glossary-instance-definition"><p class="definition">(c. a.d. 400). A major Indian philosopher, a master of the <span data-glossary-id="UT22084-060-005-603">Mādhyamika</span> school of Buddhism, who founded a sub-school known as Svātantrika.</p></div></div></div></div><div id="700a47fd-7018-450b-b636-4ceaea2b8574" class="relative scroll-mt-20"><button type="button" id="radix-_R_48l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.34</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">bhikṣu</div><ul class="ml-4 list-disc"><li class="italic">dge slong</li><li class="pt-1"><span class="font-tibetan text-base">དགེ་སློང་།</span></li><li class="italic">bhikṣu</li></ul><div class="glossary-instance-definition"><p>The term <em class="foreign break text-sa" lang="sa-LATN">bhikṣu</em>, often translated as “monk,” refers to the highest among the eight types of prātimokṣa vows that make one part of the Buddhist assembly. The Sanskrit term literally means “beggar” or “mendicant,” referring to the fact that Buddhist monks and nuns‍—like other ascetics of the time‍—subsisted on alms (<em class="foreign break text-sa" lang="sa-LATN">bhikṣā</em>) begged from the laity. </p><p>In the Tibetan tradition, which follows the Mūlasarvāstivāda Vinaya, a monk follows 253 rules as part of his moral discipline. A nun (<em class="foreign">bhikṣuṇī</em>; <em class="foreign">dge slong ma</em>) follows 364 rules. A novice monk (<em class="foreign">śrāmaṇera</em>; <em class="foreign">dge tshul</em>) or nun (<em class="foreign">śrāmaṇerikā</em>; <em class="foreign">dge tshul ma</em>) follows thirty-six rules of moral discipline (although in other vinaya traditions novices typically follow only ten).</p></div></div></div></div><div id="b5e7eaef-2698-4621-9922-144a0ad94264" class="relative scroll-mt-20"><button type="button" id="radix-_R_48t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.35</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">billion-world galaxy, galaxy</div><ul class="ml-4 list-disc"><li class="italic">stong gsum gyi stong chen po’i ’jig rten gyi khams</li><li class="pt-1"><span class="font-tibetan text-base">སྟོང་གསུམ་གྱི་སྟོང་ཆེན་པོའི་འཇིག་རྟེན་གྱི་ཁམས།</span></li><li class="italic">trisāhasra­mahā­sāhasra­loka­dhātu</li></ul><div class="glossary-instance-definition"><p class="definition">Lit. “three-thousand-great-thousand-world realm.” Each of these is composed of one thousand realms, each of which contains one thousand realms, each of which contains one thousand realms = one thousand to the third power = one billion worlds.</p></div></div></div></div><div id="4031b212-ede8-469d-abc0-058f224db7a7" class="relative scroll-mt-20"><button type="button" id="radix-_R_4955anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.36</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">birthlessness</div><ul class="ml-4 list-disc"><li class="italic">mi skye ba</li><li class="pt-1"><span class="font-tibetan text-base">མི་སྐྱེ་བ།</span></li><li class="italic">anutpādatva</li></ul><div class="glossary-instance-definition"><p class="definition">This refers to the <span data-glossary-id="UT22084-060-005-683">ultimate</span> nature of reality, to the fact that, ultimately, nothing has ever been produced or born nor will it ever be because birth and production can occur only on the relative, or superficial, level. Hence “<span class="ignore">birthlessness</span>” is a synonym of “<span data-glossary-id="UT22084-060-005-689">voidness</span>,” “reality,” “absolute,” “<span data-glossary-id="UT22084-060-005-683">ultimate</span>,” “infinity,” etc.</p></div></div></div></div><div id="c72eb4f3-700e-454d-996e-5ccdba29e6be" class="relative scroll-mt-20"><button type="button" id="radix-_R_49d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.37</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">bodhisattva</div><ul class="ml-4 list-disc"><li class="italic">byang chub sems dpa’</li><li class="pt-1"><span class="font-tibetan text-base">བྱང་ཆུབ་སེམས་དཔའ།</span></li><li class="italic">bodhisattva</li></ul><div class="glossary-instance-definition"><p class="definition">A living being who has produced the <span data-glossary-id="UT22084-060-005-659">spirit of enlightenment</span> in himself and whose constant <span data-glossary-id="UT22084-060-005-531">dedication</span>, lifetime after lifetime, is to attain the unexcelled, perfect <span data-glossary-id="UT22084-060-005-551">enlightenment</span> of Buddhahood.</p></div></div></div></div><div id="112b506f-d873-4d8a-8ec5-bee73fb350d5" class="relative scroll-mt-20"><button type="button" id="radix-_R_49l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.38</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">body of Dharma</div><ul class="ml-4 list-disc"><li class="italic">chos kyi sku</li><li class="pt-1"><span class="font-tibetan text-base">ཆོས་ཀྱི་སྐུ།</span></li><li class="italic">dharmakāya</li></ul><div class="glossary-instance-definition"><p class="definition">Also translated “<span data-glossary-id="UT22084-060-005-683">ultimate</span> body.”</p></div></div></div></div><div id="dec71e18-7976-488d-9b81-73734580c4be" class="relative scroll-mt-20"><button type="button" id="radix-_R_49t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.39</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Brahmā</div><ul class="ml-4 list-disc"><li class="italic">tshangs pa</li><li class="pt-1"><span class="font-tibetan text-base">ཚངས་པ།</span></li><li class="italic">brahmā</li></ul><div class="glossary-instance-definition"><p class="definition">Creator-<span class="ignore">lord</span> of a universe, there being as many as there are universes, whose number is incalculable. Hence, in Buddhist belief, a title of a deity who has attained supremacy in a particular universe, rather than a personal name. For example, the <span class="ignore">Brahmā</span> of the <span data-glossary-id="UT22084-060-005-827">Aśoka</span> universe is personally called <span data-glossary-id="UT22084-060-005-805">Śikhin</span>, to distinguish him from other <span class="ignore">Brahmās</span>. A <span class="ignore">Brahmā</span> resides at the summit of the <span data-glossary-id="UT22084-060-005-638">realm of pure matter</span> (<em class="foreign break text-sa" lang="sa-LATN">rūpadhātu</em>), and is thus higher in status than a <span data-glossary-id="UT22084-060-005-792">Śakra</span>. </p></div></div></div></div><div id="05c2f937-6192-471c-8d02-d3ab3b65f9b9" class="relative scroll-mt-20"><button type="button" id="radix-_R_4a55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.40</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Brahmajāla</div><ul class="ml-4 list-disc"><li class="italic">tshangs pa’i dra ba</li><li class="pt-1"><span class="font-tibetan text-base">ཚངས་པའི་དྲ་བ།</span></li><li class="italic">brahmajāla</li></ul></div></div></div><div id="9b76e3ce-41f6-4da3-89a2-722141c90c1e" class="relative scroll-mt-20"><button type="button" id="radix-_R_4ad5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.41</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">buddha</div><ul class="ml-4 list-disc"><li class="italic">sangs rgyas</li><li class="pt-1"><span class="font-tibetan text-base">སངས་རྒྱས།</span></li><li class="italic">buddha</li></ul><div class="glossary-instance-definition"><p class="definition">Lit. “awakened one.” Title of one who has attained the highest attainment possible for a living being. “The <span class="ignore">Buddha</span>” often designates <span data-glossary-id="UT22084-060-005-794">Śākyamuni</span> because he is the <span class="ignore">buddha</span> mainly in charge of the <span data-glossary-id="UT22084-060-005-516">buddhafield</span> of our <span data-glossary-id="UT22084-060-005-841">Sahā</span> universe.</p></div></div></div></div><div id="ed4d199e-c981-4efb-aad2-ce056fa1ca12" class="relative scroll-mt-20"><button type="button" id="radix-_R_4al5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.42</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Buddha Gaya</div><ul class="ml-4 list-disc"><li class="italic">buddha gaya</li></ul><div class="glossary-instance-definition"><p class="definition">Ancient name for the town in Bihar province, where the <span data-glossary-id="UT22084-060-005-515">Buddha</span> attained his highest <span data-glossary-id="UT22084-060-005-551">enlightenment</span> under the Bodhi-tree. Modern name, Bodhgaya.</p></div></div></div></div><div id="1e5e85e8-4767-46b1-874e-5f1396a67ee6" class="relative scroll-mt-20"><button type="button" id="radix-_R_4at5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.43</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">buddhafield</div><ul class="ml-4 list-disc"><li class="italic">sangs rgyas kyi zhing</li><li class="pt-1"><span class="font-tibetan text-base">སངས་རྒྱས་ཀྱི་ཞིང་།</span></li><li class="italic">buddhakṣetra</li></ul><div class="glossary-instance-definition"><p class="definition">Roughly, a synonym for “universe,” although Buddhist cosmology contains many universes of different types and dimensions. “<span class="ignore">Buddhafield</span>” indicates, in regard to whatever type of world-sphere, that it is the field of influence of a particular <span data-glossary-id="UT22084-060-005-515">Buddha</span>. For a detailed discussion of these concepts, see Lamotte, Appendice, Note I.</p></div></div></div></div><div id="cfcbf167-1d29-491e-a45c-50dc1ab792ec" class="relative scroll-mt-20"><button type="button" id="radix-_R_4b55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.44</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Buddhapālita</div><ul class="ml-4 list-disc"><li class="italic">sangs rgyas bskyang</li><li class="pt-1"><span class="font-tibetan text-base">སངས་རྒྱས་བསྐྱང་།</span></li><li class="italic">buddhapālita</li></ul><div class="glossary-instance-definition"><p class="definition">(c. fourth century). A great <span data-glossary-id="UT22084-060-005-603">Mādhyamika</span> master, who was later regarded as the founder of the <span data-glossary-id="UT22084-060-005-634">Prāsaṅgika</span> sub-school.</p></div></div></div></div><div id="c26f5079-af67-4548-b824-6f8d81f9dbb7" class="relative scroll-mt-20"><button type="button" id="radix-_R_4bd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.45</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Buddhāvataṃsaka</div><ul class="ml-4 list-disc"><li class="italic">sangs rgyas phal po che</li><li class="pt-1"><span class="font-tibetan text-base">སངས་རྒྱས་ཕལ་པོ་ཆེ།</span></li><li class="italic">buddhāvataṃsaka</li></ul><div class="glossary-instance-definition"><p class="definition">See <span data-glossary-id="UT22084-060-005-850">Avataṃsaka</span>.</p></div></div></div></div><div id="7c4012a3-9741-43c6-8bcc-3e5bf7439e6f" class="relative scroll-mt-20"><button type="button" id="radix-_R_4bl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.46</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Cakravāḍa</div><ul class="ml-4 list-disc"><li class="italic">khor yug</li><li class="pt-1"><span class="font-tibetan text-base">ཁོར་ཡུག</span></li><li class="italic">cakravāḍa</li></ul><div class="glossary-instance-definition"><p class="definition">A mountain in this <span data-glossary-id="UT22084-060-005-670">sūtra</span> and many others; but, in systematized Buddhist cosmology, the name of the ring of mountains that surrounds the world.</p></div></div></div></div><div id="e221b979-e0ff-4bd4-a72c-89cad1a3699e" class="relative scroll-mt-20"><button type="button" id="radix-_R_4bt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.47</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Candracchattra</div><ul class="ml-4 list-disc"><li class="italic">zla gdugs</li><li class="pt-1"><span class="font-tibetan text-base">ཟླ་གདུགས།</span></li><li class="italic">candracchattra</li></ul><div class="glossary-instance-definition"><p class="definition">(1) Chief of the <span data-glossary-id="UT22084-060-005-599">Licchavi</span>. (2) Son of the king <span data-glossary-id="UT22084-060-005-776">Ratnacchattra</span>, mentioned in the former-<span class="ignore">life</span> story told by the <span data-glossary-id="UT22084-060-005-515">Buddha</span> to <span data-glossary-id="UT22084-060-005-792">Śakra</span> in Chapter 12.</p></div></div></div></div><div id="42824ff1-0d92-401f-b331-ea16963f07b4" class="relative scroll-mt-20"><button type="button" id="radix-_R_4c55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.48</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Candrakīrti</div><ul class="ml-4 list-disc"><li class="italic">zla ba grags pa</li><li class="pt-1"><span class="font-tibetan text-base">ཟླ་བ་གྲགས་པ།</span></li><li class="italic">candrakīrti</li></ul><div class="glossary-instance-definition"><p class="definition">(c. sixth century). The most important <span data-glossary-id="UT22084-060-005-603">Mādhyamika</span> philosopher after <span data-glossary-id="UT22084-060-005-753">Nāgārjuna</span> and <span data-glossary-id="UT22084-060-005-704">Āryadeva</span>, he refined the philosophical methods of the school to such a degree that later members of the tradition considered him one of the highest authorities on the subject of the profound nature of reality.</p></div></div></div></div><div id="42fd6f14-c233-4682-a011-443faf537523" class="relative scroll-mt-20"><button type="button" id="radix-_R_4cd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.49</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">canon of the bodhisattvas</div><ul class="ml-4 list-disc"><li class="italic">byang chub sems dpa’i sde snod</li><li class="pt-1"><span class="font-tibetan text-base">བྱང་ཆུབ་སེམས་དཔའི་སྡེ་སྣོད།</span></li><li class="italic">bodhi­sattva­piṭaka</li></ul><div class="glossary-instance-definition"><p class="definition">The collection of the Vast (<em class="foreign break text-sa" lang="sa-LATN">vaipulya</em>) <span data-glossary-id="UT22084-060-005-670">Sūtras</span> of the <span data-glossary-id="UT22084-060-005-605">Mahāyāna</span>, supposed to have been collected supernaturally by a great assembly of <span data-glossary-id="UT22084-060-005-513">bodhisattvas</span> led by <span data-glossary-id="UT22084-060-005-743">Maitreya</span>, <span data-glossary-id="UT22084-060-005-746">Mañjuśrī</span>, and <span data-glossary-id="UT22084-060-005-818">Vajrapāṇi</span>. There is a <span data-glossary-id="UT22084-060-005-605">Mahāyāna</span> <span data-glossary-id="UT22084-060-005-670">sūtra</span> called Bodhisattvapiṭaka, but the word more usually refers to the whole collection (<em class="foreign break text-sa" lang="sa-LATN">piṭaka</em>) of <span data-glossary-id="UT22084-060-005-605">Mahāyāna</span> <span data-glossary-id="UT22084-060-005-670">sūtras</span>, to distinguish them from the Three Collections (<em class="foreign break text-sa" lang="sa-LATN">Tripiṭaka</em>) of the Hinayāna.</p></div></div></div></div><div id="2c99efa2-82ea-426e-8c67-105bb43e05b5" class="relative scroll-mt-20"><button type="button" id="radix-_R_4cl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.50</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">cessation</div><ul class="ml-4 list-disc"><li class="italic">’gog pa</li><li class="pt-1"><span class="font-tibetan text-base">འགོག་པ།</span></li><li class="italic">nirodha</li></ul><div class="glossary-instance-definition"><p class="definition">The third <span data-glossary-id="UT22084-060-005-505">Noble</span> Truth, equivalent to <span data-glossary-id="UT22084-060-005-621">nirvāṇa</span>.</p></div></div></div></div><div id="a289b9ae-5d56-46bd-9a95-0227c18b3226" class="relative scroll-mt-20"><button type="button" id="radix-_R_4ct5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.51</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ch’an</div><ul class="ml-4 list-disc"></ul><div class="glossary-instance-definition"><p class="definition">Chinese word for <em class="foreign break text-sa" lang="sa-LATN">dhyāna</em>, which was adopted as the name of the school of <span data-glossary-id="UT22084-060-005-605">Mahāyāna</span> practice founded by Bodhidharma, and later to become famous in the west as Zen.</p></div></div></div></div><div id="34f0e6a4-28b4-49d9-ae71-234c4fa63529" class="relative scroll-mt-20"><button type="button" id="radix-_R_4d55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.52</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Chönyi Tsültrim</div><ul class="ml-4 list-disc"><li class="italic">chos nyid tshul khrims</li><li class="pt-1"><span class="font-tibetan text-base">ཆོས་ཉིད་ཚུལ་ཁྲིམས།</span></li></ul><div class="glossary-instance-definition"><p class="definition">Tibetan translator of this <span data-glossary-id="UT22084-060-005-670">sūtra</span> in the ninth century, also well known for his collaboration in compiling the <cite class="title break text-sa" lang="sa-LATN">Mahāvyutpatti</cite> (Skt.-Tib. dictionary). </p></div></div></div></div><div id="2eb83d5b-bb6f-440e-afdb-f8f67ee62aec" class="relative scroll-mt-20"><button type="button" id="radix-_R_4dd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.53</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">conceive the spirit of enlightenment, conceiving the spirit of enlightenment, conception of the spirit of enlightenment</div><ul class="ml-4 list-disc"><li class="italic">byang chub kyi sems bskyed pa</li><li class="pt-1"><span class="font-tibetan text-base">བྱང་ཆུབ་ཀྱི་སེམས་བསྐྱེད་པ།</span></li><li class="italic">bodhi­cittotpāda</li></ul><div class="glossary-instance-definition"><p class="definition">This can also be rendered by “initiation of…” because it means the mental event occurring when a living being, having been exposed to the teaching of the <span data-glossary-id="UT22084-060-005-515">Buddha</span> or of his magical emanations (e.g., <span data-glossary-id="UT22084-060-005-1257">Vimalakīrti</span>), realizes simultaneously his own level of conditioned ignorance, i.e., that his habitual stream of <span data-glossary-id="UT22084-060-005-527">consciousness</span> is like sleep compared to that of one who has awakened from ignorance; the possibility of his own attainment of a higher state of <span data-glossary-id="UT22084-060-005-527">consciousness</span>; and the necessity of attaining it in order to liberate other living beings from their stupefaction. Having realized this possibility, he becomes inspired with the intense ambition to attain, and that is called the “<span class="ignore">conception of the spirit of enlightenment</span>.” “Spirit” is preferred to “mind” because the mind of <span data-glossary-id="UT22084-060-005-551">enlightenment</span> should rather be the mind of the <span data-glossary-id="UT22084-060-005-515">Buddha</span>, and to “thought” because a “thought of <span data-glossary-id="UT22084-060-005-551">enlightenment</span>” can easily be produced without the initiation of any sort of new resolve or awareness. “Will” also serves very well here.</p></div></div></div></div><div id="7c9b18c2-de43-42af-9b86-2cadc11acbf8" class="relative scroll-mt-20"><button type="button" id="radix-_R_4dl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.54</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">concentration, samādhi</div><ul class="ml-4 list-disc"><li class="italic">ting nge ’dzin, ting nge ’dzin</li><li class="pt-1"><span class="font-tibetan text-base">ཏིང་ངེ་འཛིན།, ཏིང་ངེ་འཛིན།</span></li><li class="italic">samādhi, samādhi</li></ul><div class="glossary-instance-definition"><p class="definition">See “<span data-glossary-id="UT22084-060-005-500">absorption</span>.”</p></div></div></div></div><div id="12140d8a-6833-4267-9463-c0922ba5a70b" class="relative scroll-mt-20"><button type="button" id="radix-_R_4dt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.55</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">concentration, samādhi</div><ul class="ml-4 list-disc"><li class="italic">ting nge ’dzin, ting nge ’dzin</li><li class="pt-1"><span class="font-tibetan text-base">ཏིང་ངེ་འཛིན།, ཏིང་ངེ་འཛིན།</span></li><li class="italic">samādhi, samādhi</li></ul><div class="glossary-instance-definition"><p class="definition"><span data-glossary-id="UT22084-060-005-521">Concentration</span> of total mental equanimity which is such a powerful mental state it can be turned to accomplish amazing results.</p></div></div></div></div><div id="9f1b9148-fd02-40f8-963c-c5aee1733bf6" class="relative scroll-mt-20"><button type="button" id="radix-_R_4e55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.56</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">conceptualization</div><ul class="ml-4 list-disc"><li class="italic">rnam par rtog pa</li><li class="pt-1"><span class="font-tibetan text-base">རྣམ་པར་རྟོག་པ།</span></li><li class="italic">vikalpa</li></ul><div class="glossary-instance-definition"><p class="definition">This brings up another important group of words that has never been treated systematically in translation: <em class="foreign break text-sa" lang="sa-LATN">vikalpa</em>, <em class="foreign break text-sa" lang="sa-LATN">parikalpa</em>, <em class="foreign break text-sa" lang="sa-LATN">samāropa</em>, <em class="foreign break text-sa" lang="sa-LATN">adhyāropa</em>, <em class="foreign break text-sa" lang="sa-LATN">kalpanā</em>, <em class="foreign break text-sa" lang="sa-LATN">samjñā</em>, and <em class="foreign break text-sa" lang="sa-LATN">prapāñca</em>. All of these refer to mental functions that tend to superimpose upon reality, either relative or <span data-glossary-id="UT22084-060-005-683">ultimate</span>, a conceptualized reality fabricated by the subjective mind. Some translators have tended to lump these together under the rubric “discursive thought,” which leads to the misleading notion that all thought is bad, something to be eliminated, and that sheer “thoughtlessness” is “<span data-glossary-id="UT22084-060-005-551">enlightenment</span>,” or whatever higher state is desired. According to Buddhist scholars, thought in itself is simply a function, and only thought that is attached to its own content over and above the relative object, i.e., “egoistic” thought, is bad and to be eliminated. Therefore we have chosen a set of words for the seven Skt. terms: respectively, “<span class="ignore">conceptualization</span>,” “imagination,” “presumption,” “exaggeration,” “construction,” “conception” or “notion,” and “fabrication.” This does not mean that these words are not somewhat interchangeable or that another English word might not be better in certain contexts; it only represents an attempt to achieve consistency with the original usages. </p></div></div></div></div><div id="6d362ce6-8cff-4711-b6b4-f076e4737512" class="relative scroll-mt-20"><button type="button" id="radix-_R_4ed5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.57</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">conscious awareness</div><ul class="ml-4 list-disc"><li class="italic">bag yod pa</li><li class="pt-1"><span class="font-tibetan text-base">བག་ཡོད་པ།</span></li><li class="italic">apramāda</li></ul><div class="glossary-instance-definition"><p class="definition">This denotes a type of awareness of the most seemingly insignificant aspects of practical <span class="ignore">life</span>, an awareness derived as a consequence of the highest realization of the <span data-glossary-id="UT22084-060-005-683">ultimate</span> nature of reality. As it is stated in the <cite class="title break text-sa" lang="sa-LATN">Anavatapta­nāga­rāja­paripṛcchā­sūtra</cite> (Toh 156), <a href="https://read.84000.co/translation/toh156#UT22084-058-005-308" target="UT22084-058-005.html" data-pointer-type="id">1.191</a>: “He who realizes <span data-glossary-id="UT22084-060-005-689">voidness</span>, that person is consciously aware.” “<span data-glossary-id="UT22084-060-005-683">Ultimate</span> realization,” far from obliterating the relative world, brings it into highly specific, albeit dreamlike, focus. </p></div></div></div></div><div id="a8081b29-fd2e-425a-b8a0-900b375ccea0" class="relative scroll-mt-20"><button type="button" id="radix-_R_4el5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.58</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">consciousness</div><ul class="ml-4 list-disc"><li class="italic">rnam shes</li><li class="pt-1"><span class="font-tibetan text-base">རྣམ་ཤེས།</span></li><li class="italic">vijñāna</li></ul><div class="glossary-instance-definition"><p class="definition">See “<span data-glossary-id="UT22084-060-005-502">aggregate</span>.”</p></div></div></div></div><div id="cec4c4b6-fd31-476f-b413-c84faa28d822" class="relative scroll-mt-20"><button type="button" id="radix-_R_4et5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.59</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">contemplation</div><ul class="ml-4 list-disc"><li class="italic">bsam gtan</li><li class="pt-1"><span class="font-tibetan text-base">བསམ་གཏན།</span></li><li class="italic">dhyāna</li></ul><div class="glossary-instance-definition"><p class="definition">See “<span data-glossary-id="UT22084-060-005-500">absorption</span>.”</p></div></div></div></div><div id="802e1a5b-857b-432f-9274-35d3d2d8dbad" class="relative scroll-mt-20"><button type="button" id="radix-_R_4f55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.60</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">cosmic wind-atmosphere</div><ul class="ml-4 list-disc"><li class="italic">rlung gi dkyil ’khor</li><li class="pt-1"><span class="font-tibetan text-base">རླུང་གི་དཀྱིལ་འཁོར།</span></li><li class="italic">vātamaṇḍalī</li></ul><div class="glossary-instance-definition"><p class="definition">The ancient cosmology maintained that the cosmos was encircled by an atmosphere of fierce winds of impenetrable intensity (see Lamotte, p. 255, n. 15).</p></div></div></div></div><div id="500d0357-2bbe-4021-8b1b-35ac7932e50c" class="relative scroll-mt-20"><button type="button" id="radix-_R_4fd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.61</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">decisiveness</div><ul class="ml-4 list-disc"><li class="italic">nges par sems pa</li><li class="pt-1"><span class="font-tibetan text-base">ངེས་པར་སེམས་པ།</span></li><li class="italic">nidhyapti</li></ul><div class="glossary-instance-definition"><p class="definition">Analytic <span data-glossary-id="UT22084-060-005-521">concentration</span> that gains insight into the nature of reality, synonymous with “<span data-glossary-id="UT22084-060-005-680">transcendental analysis</span>,” <em class="foreign break text-sa" lang="sa-LATN">vipaśyana</em> (q.v.). </p></div></div></div></div><div id="cc21647f-dc89-4cb3-b927-6cf2286d5f85" class="relative scroll-mt-20"><button type="button" id="radix-_R_4fl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.62</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">dedication</div><ul class="ml-4 list-disc"><li class="italic">yongs su bsngo ba</li><li class="pt-1"><span class="font-tibetan text-base">ཡོངས་སུ་བསྔོ་བ།</span></li><li class="italic">pariṇāmana</li></ul><div class="glossary-instance-definition"><p class="definition">This refers to the <span data-glossary-id="UT22084-060-005-513">bodhisattva</span>’s constant mindfulness of the fact that all his actions of whatever form contribute to his purpose of attaining <span data-glossary-id="UT22084-060-005-551">enlightenment</span> for the sake of himself and others, i.e., his conscious deferral of the merit accruing from any virtuous action as he eschews immediate reward in favor of <span data-glossary-id="UT22084-060-005-683">ultimate</span> <span data-glossary-id="UT22084-060-005-551">enlightenment</span> for himself and all living beings.</p></div></div></div></div><div id="635916eb-923d-4aff-a4c7-9f4516721120" class="relative scroll-mt-20"><button type="button" id="radix-_R_4ft5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.63</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">definitive meaning</div><ul class="ml-4 list-disc"><li class="italic">nges don</li><li class="pt-1"><span class="font-tibetan text-base">ངེས་དོན།</span></li><li class="italic">nītārtha</li></ul><div class="glossary-instance-definition"><p class="definition">This refers to those teachings of the <span data-glossary-id="UT22084-060-005-515">Buddha</span> that are in terms of <span data-glossary-id="UT22084-060-005-683">ultimate</span> reality; it is opposed to those teachings given in terms of relative reality, termed “<span data-glossary-id="UT22084-060-005-589">interpretable meaning</span>,” because they require further interpretation before being relied on to indicate the <span data-glossary-id="UT22084-060-005-683">ultimate</span>. Hence <span class="ignore">definitive meaning</span> relates to <span data-glossary-id="UT22084-060-005-689">voidness</span>, etc., and no statement concerning the relative world, even by the <span data-glossary-id="UT22084-060-005-515">Buddha</span>, can be taken as definitive. This is especially important in the context of the <span data-glossary-id="UT22084-060-005-603">Mādhyamika</span> doctrine, hence in the context of <span data-glossary-id="UT22084-060-005-1257">Vimalakīrti</span>’s teachings, because he is constantly correcting the disciples and <span data-glossary-id="UT22084-060-005-513">bodhisattvas</span> who accept interpretable expressions of the <span data-glossary-id="UT22084-060-005-672">Tathāgata</span> as if they were definitive, thereby attaching themselves to them and adopting a one-sided approach.</p></div></div></div></div><div id="28a2831b-8ff3-473b-9ee3-6a0d997ccff0" class="relative scroll-mt-20"><button type="button" id="radix-_R_4g55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.64</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">dependent origination, relativity</div><ul class="ml-4 list-disc"><li class="italic">rten cing ’brel bar ’byung ba, rten cing ’brel bar ’byung ba</li><li class="pt-1"><span class="font-tibetan text-base">རྟེན་ཅིང་འབྲེལ་བར་འབྱུང་བ།, རྟེན་ཅིང་འབྲེལ་བར་འབྱུང་བ།</span></li><li class="italic">pratītya­samutpāda, pratītya­samutpāda</li></ul><div class="glossary-instance-definition"><p class="definition">See also “<span data-glossary-id="UT22084-060-005-640">relativity</span>.”</p></div></div></div></div><div id="a53cd052-8393-4f2f-b18f-df2aff5c0cdb" class="relative scroll-mt-20"><button type="button" id="radix-_R_4gd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.65</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">dependent origination, relativity</div><ul class="ml-4 list-disc"><li class="italic">rten cing ’brel bar ’byung ba, rten cing ’brel bar ’byung ba</li><li class="pt-1"><span class="font-tibetan text-base">རྟེན་ཅིང་འབྲེལ་བར་འབྱུང་བ།, རྟེན་ཅིང་འབྲེལ་བར་འབྱུང་བ།</span></li><li class="italic">pratītya­samutpāda, pratītya­samutpāda</li></ul><div class="glossary-instance-definition"><p class="definition">In most contexts, this term is properly translated by “<span data-glossary-id="UT22084-060-005-533">dependent origination</span>.” But in the <span data-glossary-id="UT22084-060-005-603">Mādhyamika</span> context, wherein the concept of the <span data-glossary-id="UT22084-060-005-683">ultimate</span> nonorigination of all things is emphasized, “<span class="ignore">relativity</span>” better serves to convey the message that things exist only in relation to verbal designation and that nothing exists as an independent, <span class="ignore">self</span>-sufficient entity, even on the superficial level.</p></div></div></div></div><div id="4c9b50c9-505f-449a-b81d-0b5514591f15" class="relative scroll-mt-20"><button type="button" id="radix-_R_4gl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.66</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">destined for the ultimate</div><ul class="ml-4 list-disc"><li class="italic">yang dag pa nyid du nges pa</li><li class="pt-1"><span class="font-tibetan text-base">ཡང་དག་པ་ཉིད་དུ་ངེས་པ།</span></li><li class="italic">samyaktvaniyata</li></ul><div class="glossary-instance-definition"><p class="definition">This generally describes one who has reached the <span data-glossary-id="UT22084-060-005-505">noble</span> path, either in <span data-glossary-id="UT22084-060-005-662">Disciple Vehicle</span> or <span data-glossary-id="UT22084-060-005-605">Mahāyāna</span> practice (see Lamotte, p. 115, n. 65).</p></div></div></div></div><div id="0fe01594-05ae-4d26-819d-47640d08397f" class="relative scroll-mt-20"><button type="button" id="radix-_R_4gt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.67</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">destiny for the ultimate</div><ul class="ml-4 list-disc"><li class="italic">nges pa la zhugs pa</li><li class="pt-1"><span class="font-tibetan text-base">ངེས་པ་ལ་ཞུགས་པ།</span></li><li class="italic">niyāmāvakrānti</li></ul><div class="glossary-instance-definition"><p class="definition">This is the stage attained by followers of the Hinayāna wherein they become determined for the attainment of <span data-glossary-id="UT22084-060-005-597">liberation</span> (<span data-glossary-id="UT22084-060-005-621">nirvāṇa</span>, i.e., the <span data-glossary-id="UT22084-060-005-683">ultimate</span> for them) in such a way as never to regress from their goals, and by <span data-glossary-id="UT22084-060-005-513">bodhisattvas</span> when they attain the holy path of insight. </p></div></div></div></div><div id="5da0fca1-89b3-47cd-a4ec-fa7a4448696b" class="relative scroll-mt-20"><button type="button" id="radix-_R_4h55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.68</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">deva</div><ul class="ml-4 list-disc"><li class="italic">lha</li><li class="pt-1"><span class="font-tibetan text-base">ལྷ།</span></li><li class="italic">deva</li></ul><div class="glossary-instance-definition"><p>In the most general sense the devas‍—the term is cognate with the English <em class="emph">divine</em>‍—are a class of celestial beings who frequently appear in Buddhist texts, often at the head of the assemblies of nonhuman beings who attend and celebrate the teachings of the Buddha Śākyamuni and other buddhas and bodhisattvas. In Buddhist cosmology the devas occupy the highest of the five or six “destinies” (<em class="foreign break text-sa" lang="sa-LATN">gati</em>) of saṃsāra among which beings take rebirth. The devas reside in the <em class="foreign break text-sa" lang="sa-LATN">devalokas</em>, “heavens” that traditionally number between twenty-six and twenty-eight and are divided between the desire realm (<em class="foreign break text-sa" lang="sa-LATN">kāmadhātu</em>), form realm (<em class="foreign break text-sa" lang="sa-LATN">rūpadhātu</em>), and formless realm (<em class="foreign break text-sa" lang="sa-LATN">ārūpyadhātu</em>). A being attains rebirth among the devas either through meritorious deeds (in the desire realm) or the attainment of subtle meditative states (in the form and formless realms). While rebirth among the devas is considered favorable, it is ultimately a transitory state from which beings will fall when the conditions that lead to rebirth there are exhausted. Thus, rebirth in the god realms is regarded as a diversion from the spiritual path. </p></div></div></div></div><div id="85e85193-24fb-4662-8b13-fda9ad0d4dbc" class="relative scroll-mt-20"><button type="button" id="radix-_R_4hd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.69</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Devarāja</div><ul class="ml-4 list-disc"><li class="italic">lha’i rgyal po</li><li class="pt-1"><span class="font-tibetan text-base">ལྷའི་རྒྱལ་པོ།</span></li><li class="italic">devarāja</li></ul></div></div></div><div id="c08db6f5-393e-4ec4-bf72-4043e53b3129" class="relative scroll-mt-20"><button type="button" id="radix-_R_4hl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.70</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dharma</div><ul class="ml-4 list-disc"><li class="italic">chos</li><li class="pt-1"><span class="font-tibetan text-base">ཆོས།</span></li><li class="italic">dharma</li></ul><div class="glossary-instance-definition"><p>The term <em class="foreign break text-sa" lang="sa-LATN">dharma</em> conveys ten different meanings, according to Vasubandhu’s <cite class="title break text-sa" lang="sa-LATN">Vyākhyā­yukti</cite>. The primary meanings are as follows: the doctrine taught by the Buddha (Dharma); the ultimate reality underlying and expressed through the Buddha’s teaching (Dharma); the trainings that the Buddha’s teaching stipulates (dharmas); the various awakened qualities or attainments acquired through practicing and realizing the Buddha’s teaching (dharmas); qualities or aspects more generally, i.e., phenomena or phenomenal attributes (dharmas); and mental objects (dharmas).</p></div></div></div></div><div id="79458ac8-a28e-44a0-88fa-1f9d3ee8f5df" class="relative scroll-mt-20"><button type="button" id="radix-_R_4ht5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.71</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dharma-door, door of the Dharma, doors of the Dharma</div><ul class="ml-4 list-disc"><li class="italic">chos kyi sgo, chos kyi sgo</li><li class="pt-1"><span class="font-tibetan text-base">ཆོས་ཀྱི་སྒོ།, ཆོས་ཀྱི་སྒོ།</span></li><li class="italic">dharmamukha, dharmamukha</li></ul><div class="glossary-instance-definition"><p class="definition">Certain teachings are called “<span class="ignore">Dharma-doors</span>” (or “<span data-glossary-id="UT22084-060-005-541">doors of the Dharma</span>”), as they provide access to the practice of the <span data-glossary-id="UT22084-060-005-537">Dharma</span>.</p></div></div></div></div><div id="5deb39e7-587e-4930-9b0d-5bcc72f42248" class="relative scroll-mt-20"><button type="button" id="radix-_R_4i55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.72</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dharma-door, door of the Dharma, doors of the Dharma</div><ul class="ml-4 list-disc"><li class="italic">chos kyi sgo, chos kyi sgo</li><li class="pt-1"><span class="font-tibetan text-base">ཆོས་ཀྱི་སྒོ།, ཆོས་ཀྱི་སྒོ།</span></li><li class="italic">dharmamukha, dharmamukha</li></ul><div class="glossary-instance-definition"><p class="definition">See “<span data-glossary-id="UT22084-060-005-538">Dharma-door</span>.”</p></div></div></div></div><div id="e6878b41-c299-40f7-bdcf-2a354e33818a" class="relative scroll-mt-20"><button type="button" id="radix-_R_4id5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.73</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dharma-eye</div><ul class="ml-4 list-disc"><li class="italic">chos kyi mig</li><li class="pt-1"><span class="font-tibetan text-base">ཆོས་ཀྱི་མིག</span></li><li class="italic">dharmacakṣu</li></ul><div class="glossary-instance-definition"><p class="definition">One of the “five eyes,” representing superior insights of the <span data-glossary-id="UT22084-060-005-515">buddhas</span> and <span data-glossary-id="UT22084-060-005-513">bodhisattvas</span>. The five eyes consist of five different faculties of vision: the physical eye (<em class="foreign break text-sa" lang="sa-LATN">māṃsa­cakṣu</em>), the <span data-glossary-id="UT22084-060-005-540">divine eye</span> (<em class="foreign break text-sa" lang="sa-LATN">dīvya­cakṣu</em>), the <span data-glossary-id="UT22084-060-005-691">wisdom</span> eye (<em class="foreign break text-sa" lang="sa-LATN">prajñā­cakṣu</em>), the <span class="ignore">Dharma-eye</span> (<em class="foreign break text-sa" lang="sa-LATN">dharma­cakṣu</em>), and the <span data-glossary-id="UT22084-060-005-515">Buddha</span>-eye (<em class="foreign break text-sa" lang="sa-LATN">buddha­cakṣu</em>).</p></div></div></div></div><div id="c6774227-0962-4900-913a-671acc2c4c89" class="relative scroll-mt-20"><button type="button" id="radix-_R_4il5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.74</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dharmaketu</div><ul class="ml-4 list-disc"><li class="italic">chos kyi tog</li><li class="pt-1"><span class="font-tibetan text-base">ཆོས་ཀྱི་ཏོག</span></li><li class="italic">dharmaketu</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-060-005-513">bodhisattva</span>.</p></div></div></div></div><div id="472fcc2b-059e-4329-8799-3ace4d2cf0c7" class="relative scroll-mt-20"><button type="button" id="radix-_R_4it5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.75</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Dharmeśvara</div><ul class="ml-4 list-disc"><li class="italic">chos kyi dbang phyug</li><li class="pt-1"><span class="font-tibetan text-base">ཆོས་ཀྱི་དབང་ཕྱུག</span></li><li class="italic">dharmeśvara</li></ul></div></div></div><div id="cc35d4b8-9151-485e-9199-cf5d9d646538" class="relative scroll-mt-20"><button type="button" id="radix-_R_4j55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.76</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Disciple Vehicle, Śrāvakayāna</div><ul class="ml-4 list-disc"><li class="italic">nyan thos kyi theg pa</li><li class="pt-1"><span class="font-tibetan text-base">ཉན་ཐོས་ཀྱི་ཐེག་པ།</span></li><li class="italic">śrāvakayāna</li></ul><div class="glossary-instance-definition"><p class="definition">The vehicle comprising the teaching of the <span data-glossary-id="UT22084-060-005-661">śrāvakas</span>.</p></div></div></div></div><div id="75a91ffb-ff79-483c-bf2e-bc68d02dc1e6" class="relative scroll-mt-20"><button type="button" id="radix-_R_4jd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.77</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">divine eye</div><ul class="ml-4 list-disc"><li class="italic">lha’i mig</li><li class="pt-1"><span class="font-tibetan text-base">ལྷའི་མིག</span></li><li class="italic">divyacakṣu</li></ul><div class="glossary-instance-definition"><p class="definition">One of the six “<span data-glossary-id="UT22084-060-005-669">superknowledges</span>” (q.v.) as well as one of the “five eyes,” this is the supernormal ability to see to an unlimited distance, observe events on other worlds, see through mountains, etc. The five eyes consist of five different faculties of vision: the physical eye (<em class="foreign break text-sa" lang="sa-LATN">māṃsa­cakṣu</em>), the <span class="ignore">divine eye</span> (<em class="foreign break text-sa" lang="sa-LATN">dīvya­cakṣu</em>), the <span data-glossary-id="UT22084-060-005-691">wisdom</span> eye (<em class="foreign break text-sa" lang="sa-LATN">prajñā­cakṣu</em>), the <span data-glossary-id="UT22084-060-005-539">Dharma-eye</span> (<em class="foreign break text-sa" lang="sa-LATN">dharma­cakṣu</em>), and the <span data-glossary-id="UT22084-060-005-515">Buddha</span>-eye (<em class="foreign break text-sa" lang="sa-LATN">buddha­cakṣu</em>).</p></div></div></div></div><div id="a4956bd4-d143-4797-a25e-72aa2fc5d7ba" class="relative scroll-mt-20"><button type="button" id="radix-_R_4jl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.78</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Duḥprasāha</div><ul class="ml-4 list-disc"><li class="italic">bzod dka’</li><li class="pt-1"><span class="font-tibetan text-base">བཟོད་དཀའ།</span></li><li class="italic">duḥprasāha</li></ul><div class="glossary-instance-definition"><p class="definition"><span data-glossary-id="UT22084-060-005-515">Buddha</span> of the universe <span data-glossary-id="UT22084-060-005-837">Marīci</span>, located sixty-one universes away; mentioned also in other <span data-glossary-id="UT22084-060-005-605">Mahāyāna</span> <span data-glossary-id="UT22084-060-005-670">sūtras</span>, with the interesting coincidence that his teaching ceased at the moment <span data-glossary-id="UT22084-060-005-794">Śākyamuni</span> began teaching at Benares.</p></div></div></div></div><div id="e5d4433d-1e7d-4687-816e-334e3b4acd52" class="relative scroll-mt-20"><button type="button" id="radix-_R_4jt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.79</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">egoistic views</div><ul class="ml-4 list-disc"><li class="italic">’jig tshogs la lta ba</li><li class="pt-1"><span class="font-tibetan text-base">འཇིག་ཚོགས་ལ་ལྟ་བ།</span></li><li class="italic">satkāyadṛṣṭi</li></ul><div class="glossary-instance-definition"><p class="definition">This consists of twenty varieties of false notion, consisting basically of regarding the temporally impermanent and ultimately insubstantial as “I” or “mine.” The five compulsive <span data-glossary-id="UT22084-060-005-502">aggregates</span> are paired with the <span data-glossary-id="UT22084-060-005-649">self</span>, giving the twenty false notions. For example, the first four false notions are that (1) <span data-glossary-id="UT22084-060-005-610">matter</span> is the <span data-glossary-id="UT22084-060-005-649">self</span>, which is like its owner (<em class="foreign break text-sa" lang="sa-LATN">rūpaṃ ātmā svāmivat</em>); (2) the <span data-glossary-id="UT22084-060-005-649">self</span> possesses <span data-glossary-id="UT22084-060-005-610">matter</span>, like its ornament (<em class="foreign break text-sa" lang="sa-LATN">rūpavañ ātmā alaņkāravat</em>); (3) <span data-glossary-id="UT22084-060-005-610">matter</span> belongs to the <span data-glossary-id="UT22084-060-005-649">self</span>, like a slave (<em class="foreign break text-sa" lang="sa-LATN">ātmīyaṃ rūpaṃ bhṛtyavat</em>); and (4) the <span data-glossary-id="UT22084-060-005-649">self</span> dwells in <span data-glossary-id="UT22084-060-005-610">matter</span> as in a vessel (<em class="foreign break text-sa" lang="sa-LATN">rūpe ātmā bhajanavat</em>). The other four compulsive <span data-glossary-id="UT22084-060-005-502">aggregates</span> are paired with the <span data-glossary-id="UT22084-060-005-649">self</span> in the same four ways, giving sixteen more false notions concerning <span data-glossary-id="UT22084-060-005-651">sensation</span>, <span data-glossary-id="UT22084-060-005-588">intellect</span>, <span data-glossary-id="UT22084-060-005-616">motivation</span>, and <span data-glossary-id="UT22084-060-005-527">consciousness</span>, hypostatizing an impossible relationship with a nonexistent, permanent, substantial <span data-glossary-id="UT22084-060-005-649">self</span>. </p></div></div></div></div><div id="dbddf014-9e12-4bcf-a5de-608dd7b43c2c" class="relative scroll-mt-20"><button type="button" id="radix-_R_4k55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.80</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">eight liberations</div><ul class="ml-4 list-disc"><li class="italic">rnam par thar pa brgyad</li><li class="pt-1"><span class="font-tibetan text-base">རྣམ་པར་ཐར་པ་བརྒྱད།</span></li><li class="italic">vimokṣa</li></ul><div class="glossary-instance-definition"><p class="definition">The first consists of the seeing of form by one who has form; the second consists of the seeing of external form by one with the concept of internal formlessness; the third consists of the physical realization of pleasant <span data-glossary-id="UT22084-060-005-597">liberation</span> and its successful consolidation; the fourth consists of the full entrance to the infinity of space through transcending all conceptions of <span data-glossary-id="UT22084-060-005-610">matter</span>, and the subsequent decline of conceptions of resistance and discredit of conceptions of diversity; the fifth consists of full entrance into the infinity of <span data-glossary-id="UT22084-060-005-527">consciousness</span>, having transcended the infinity of space; the sixth consists of the full entrance into the sphere of nothingness, having transcended the sphere of the infinity of conscious­ness; the seventh consists of the full entrance into the sphere of neither conscious­ness nor un­conscious­ness, having transcended the sphere of nothingness; the eighth consists of the perfect <span data-glossary-id="UT22084-060-005-518">cessation</span> of suffering, having transcended the sphere of neither conscious­ness nor un­conscious­ness. Thus the first three <span data-glossary-id="UT22084-060-005-597">liberations</span> form specific links to the ordinary perceptual world; the fourth to seventh are equivalent to the four <span data-glossary-id="UT22084-060-005-500">absorptions</span>; and the eighth represents the highest attainment.</p></div></div></div></div><div id="e2e43e4a-7d5b-42ef-b212-1c512b123c6b" class="relative scroll-mt-20"><button type="button" id="radix-_R_4kd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.81</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">eight perverse paths</div><ul class="ml-4 list-disc"><li class="italic">log pa brgyad, log pa nyid brgyad</li><li class="pt-1"><span class="font-tibetan text-base">ལོག་པ་ཉིད་བརྒྱད།, ལོག་པ་བརྒྱད།</span></li><li class="italic">mithyātva</li></ul><div class="glossary-instance-definition"><p class="definition">These consist of the exact opposites of the eight branches of the <span data-glossary-id="UT22084-060-005-547">eightfold noble path</span> (<em class="foreign break text-sa" lang="sa-LATN">aṣṭāṅgikamārga</em>). </p></div></div></div></div><div id="d0777c21-0a65-482f-99e1-8c59e27cb1f7" class="relative scroll-mt-20"><button type="button" id="radix-_R_4kl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.82</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">eighteen special qualities of a bodhisattva</div><ul class="ml-4 list-disc"><li class="italic">byang chub sems dpa’i chos ma ’dres pa bco brgyad</li><li class="pt-1"><span class="font-tibetan text-base">བྱང་ཆུབ་སེམས་དཔའི་ཆོས་མ་འདྲེས་པ་བཅོ་བརྒྱད།</span></li><li class="italic">aṣṭā­daśāveṇika­bodhi­sattva­dharma</li></ul><div class="glossary-instance-definition"><p class="definition">These consist of the <span data-glossary-id="UT22084-060-005-513">bodhisattva</span>’s natural (uninstructed) possession of generosity, <span data-glossary-id="UT22084-060-005-615">morality</span>, tolerance, effort, <span data-glossary-id="UT22084-060-005-612">meditation</span>, and <span data-glossary-id="UT22084-060-005-691">wisdom</span>; of his uniting all beings with the four <span data-glossary-id="UT22084-060-005-611">means of unification</span>, knowing the method of <span data-glossary-id="UT22084-060-005-531">dedication</span> (of virtue to <span data-glossary-id="UT22084-060-005-551">enlightenment</span>), exemplification, through skill in <span data-glossary-id="UT22084-060-005-598">liberative art</span>, of the positive results of the <span data-glossary-id="UT22084-060-005-605">Mahāyāna</span>, as suited to the (various) modes of behavior of all living beings, his not falling from the <span data-glossary-id="UT22084-060-005-605">Mahāyāna</span>, showing the entrances of <span data-glossary-id="UT22084-060-005-643">saṃsāra</span> and <span data-glossary-id="UT22084-060-005-621">nirvāṇa</span>, skill in the technique of <span data-glossary-id="UT22084-060-005-639">reconciliation of dichotomies</span>, impeccable progress in all his lives, guided by <span data-glossary-id="UT22084-060-005-691">wisdom</span> without any conditioned activities, possession of <span data-glossary-id="UT22084-060-005-683">ultimate</span> action of body, speech, and mind directed by the tenfold path of good action, nonabandonment of any of the realms of living beings, through his assumption of a body endowed with tolerance of every conceivable suffering, manifestation of that which delights all living beings, inexhaustible preservation of the mind of <span data-glossary-id="UT22084-060-005-626">omniscience</span>, as stable as the virtue-constituted tree of wish-fulfilling gems, (even) in the midst of the infantile (ordinary persons) and (narrow-minded) religious disciples, however trying they might be, and adamant irreversibility from demonstrating the quest of the <span data-glossary-id="UT22084-060-005-537">Dharma</span> of the <span data-glossary-id="UT22084-060-005-515">Buddha</span>, for the sake of the attainment of the miraculous consecration conferring the skill in <span data-glossary-id="UT22084-060-005-598">liberative art</span> that transmutes all things. (Mvy, nos. 787-804)</p></div></div></div></div><div id="22d552c8-644d-4406-b1ba-f2d731fff0c3" class="relative scroll-mt-20"><button type="button" id="radix-_R_4kt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.83</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">eighteen special qualities of the Buddha</div><ul class="ml-4 list-disc"><li class="italic">sangs rgyas kyi chos ma ’dres pa bco brgyad</li><li class="pt-1"><span class="font-tibetan text-base">སངས་རྒྱས་ཀྱི་ཆོས་མ་འདྲེས་པ་བཅོ་བརྒྱད།</span></li><li class="italic">aṣṭā­daśāveṇika­buddha­dharma</li></ul><div class="glossary-instance-definition"><p>Eighteen special features of a buddha’s behavior, realization, activity, and wisdom that are not shared by other beings. They are generally listed as: (1) he never makes a mistake, (2) he is never boisterous, (3) he never forgets, (4) his concentration never falters, (5) he has no notion of distinctness, (6) his equanimity is not due to lack of consideration, (7) his motivation never falters, (8) his endeavor never fails, (9) his mindfulness never falters, (10) he never abandons his concentration, (11) his insight (<em class="foreign break text-sa" lang="sa-LATN">prajñā</em>) never decreases, (12) his liberation never fails, (13) all his physical actions are preceded and followed by wisdom (<em class="foreign break text-sa" lang="sa-LATN">jñāna</em>), (14) all his verbal actions are preceded and followed by wisdom, (15) all his mental actions are preceded and followed by wisdom, (16) his wisdom and vision perceive the past without attachment or hindrance, (17) his wisdom and vision perceive the future without attachment or hindrance, and (18) his wisdom and vision perceive the present without attachment or hindrance.</p></div></div></div></div><div id="9ccf17fa-be73-442f-8de5-898a79eea2cf" class="relative scroll-mt-20"><button type="button" id="radix-_R_4l55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.84</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">eightfold noble path</div><ul class="ml-4 list-disc"><li class="italic">’phags pa’i lam gyi yan lag brgyad</li><li class="pt-1"><span class="font-tibetan text-base">འཕགས་པའི་ལམ་གྱི་ཡན་ལག་བརྒྱད།</span></li><li class="italic">āryāṣṭāṅga­mārga</li></ul><div class="glossary-instance-definition"><p class="definition">These are right <span data-glossary-id="UT22084-060-005-686">view</span> (<em class="foreign break text-sa" lang="sa-LATN">samyagdṛṣṭi</em>), right consideration (<em class="foreign break text-sa" lang="sa-LATN">samyak­saṃkalpa</em>), right speech (<em class="foreign break text-sa" lang="sa-LATN">samyakvāk</em>), right terminal action (<em class="foreign break text-sa" lang="sa-LATN">samyak­karmānta</em>), right livelihood (<em class="foreign break text-sa" lang="sa-LATN">samyagajiva</em>), right effort (<em class="foreign break text-sa" lang="sa-LATN">samyag­vyāyāma</em>), right remembrance (<em class="foreign break text-sa" lang="sa-LATN">samyak­smṛti</em>), and right <span data-glossary-id="UT22084-060-005-521">concentration</span> (<em class="foreign break text-sa" lang="sa-LATN">samyak­samādhi</em>). They are variously defined in the different Buddhist schools. These eight form a part of the <span data-glossary-id="UT22084-060-005-676">thirty-seven aids to enlightenment</span> (see entry). </p></div></div></div></div><div id="dbc4a2e4-dbc7-475b-8ed0-c63412da4b68" class="relative scroll-mt-20"><button type="button" id="radix-_R_4ld5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.85</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">element</div><ul class="ml-4 list-disc"><li class="italic">khams, ’byung ba chen po</li><li class="pt-1"><span class="font-tibetan text-base">ཁམས།, འབྱུང་བ་ཆེན་པོ།</span></li><li class="italic">dhātu, mahābhūta</li></ul><div class="glossary-instance-definition"><p class="definition">Depending on the context, may translate either: (a) Skt. <em class="foreign break text-sa" lang="sa-LATN">mahābhūta</em>, Tib. <em class="foreign text-wy" lang="bo-LATN">’byung ba chen po</em>, the four “main” or “great” outer <span class="ignore">elements</span> of earth, water, fire, air, and (when there is a fifth) space; or: (b) Skt. <em class="foreign break text-sa" lang="sa-LATN">dhātu</em>, Tib. <em class="foreign break text-sa" lang="sa-LATN">khams</em>, the “eighteen <span class="ignore">elements</span>” introduce, in the context of the <span data-glossary-id="UT22084-060-005-502">aggregates</span>, <span class="ignore">elements</span>, and <span data-glossary-id="UT22084-060-005-652">sense-media</span>, the same six pairs as the twelve <span data-glossary-id="UT22084-060-005-652">sense-media</span>, as <span class="ignore">elements</span> of experience, adding a third member to each set: the <span class="ignore">element</span> of <span data-glossary-id="UT22084-060-005-527">consciousness</span> (<em class="foreign break text-sa" lang="sa-LATN">vijñāna</em>), or sense. Hence the first pair gives the triad eye-element (<em class="foreign break text-sa" lang="sa-LATN">caksur­dhātu</em>), form-element (<em class="foreign break text-sa" lang="sa-LATN">rūpadhātu</em>), and eye-<span data-glossary-id="UT22084-060-005-527">consciousness</span>-element, or eye-sense-element (<em class="foreign break text-sa" lang="sa-LATN">caksur­vijñāna­dhātu</em>)‍—and so on with the other five, noting the last, mind-element (<em class="foreign break text-sa" lang="sa-LATN">manodhātu</em>), phenomena-element (<em class="foreign break text-sa" lang="sa-LATN">dharma­dhātu</em>), and mental-sense-element (<em class="foreign break text-sa" lang="sa-LATN">mano­vijñāna­dhātu</em>). </p></div></div></div></div><div id="2894cd42-61c0-4809-b7f0-d6a6f5248637" class="relative scroll-mt-20"><button type="button" id="radix-_R_4ll5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.86</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">emanated incarnation, incarnation</div><ul class="ml-4 list-disc"><li class="italic">sprul pa, sprul pa</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲུལ་པ།, སྤྲུལ་པ།</span></li><li class="italic">nirmāṇa, nirmāṇa</li></ul><div class="glossary-instance-definition"><p class="definition">This refers to the miraculous power of the <span data-glossary-id="UT22084-060-005-515">Buddha</span> and <span data-glossary-id="UT22084-060-005-513">bodhisattvas</span> of a certain stage to emanate apparently living beings in order to develop and teach living beings. This power reaches its culmination in the <em class="foreign break text-sa" lang="sa-LATN">nirmāṇa­kayā</em>, the “<span data-glossary-id="UT22084-060-005-582">incarnation</span> body,” which is one of the three bodies of buddhahood and includes all physical forms of all <span data-glossary-id="UT22084-060-005-515">buddhas</span>, including <span data-glossary-id="UT22084-060-005-794">Śākyamuni</span>, whose sole function as <span data-glossary-id="UT22084-060-005-582">incarnations</span> is the development and <span data-glossary-id="UT22084-060-005-597">liberation</span> of living beings. </p></div></div></div></div><div id="b9472c5e-2a0d-4ba9-80dc-8f56944f1752" class="relative scroll-mt-20"><button type="button" id="radix-_R_4lt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.87</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">emanated incarnation, incarnation</div><ul class="ml-4 list-disc"><li class="italic">sprul pa, sprul pa</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲུལ་པ།, སྤྲུལ་པ།</span></li><li class="italic">nirmāṇa, nirmāṇa</li></ul><div class="glossary-instance-definition"><p class="definition">See “<span data-glossary-id="UT22084-060-005-549">emanated incarnation</span>.”</p></div></div></div></div><div id="0e3b4cd3-64d5-4b41-a33a-86aa141f7277" class="relative scroll-mt-20"><button type="button" id="radix-_R_4m55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.88</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">emptiness, voidness, śūnyatā</div><ul class="ml-4 list-disc"><li class="italic">stong pa nyid, stong pa nyid, stong pa nyid</li><li class="pt-1"><span class="font-tibetan text-base">སྟོང་པ་ཉིད།, སྟོང་པ་ཉིད།, སྟོང་པ་ཉིད།</span></li><li class="italic">śūnyatā, śūnyatā, śūnyatā</li></ul><div class="glossary-instance-definition"><p class="definition">This Skt. term is usually translated by “<span data-glossary-id="UT22084-060-005-689">voidness</span>” because that English word is more rarely used in other contexts than “<span class="ignore">emptiness</span>” and does not refer to any sort of <span data-glossary-id="UT22084-060-005-683">ultimate</span> nothingness, as a thing-in-itself, or even as the thing-in-itself to end all things-in-themselves. It is a pure negation of the <span data-glossary-id="UT22084-060-005-683">ultimate</span> existence of anything or, in Buddhist terminology, the “<span class="ignore">emptiness</span> with respect to personal and phenomenal selves,” or “with respect to <span data-glossary-id="UT22084-060-005-579">identity</span>,” or “with respect to intrinsic nature,” or “with respect to essential substance,” or “with respect to <span class="ignore">self</span>-existence established by intrinsic <span data-glossary-id="UT22084-060-005-579">identity</span>,” or “with respect to <span data-glossary-id="UT22084-060-005-683">ultimate</span> truth-status,” etc. Thus <span class="ignore">emptiness</span> is a concept descriptive of the <span data-glossary-id="UT22084-060-005-683">ultimate</span> reality through its pure negation of whatever may be supposed to be ultimately real. It is an absence, hence not existent in itself. It is synonymous therefore with “infinity,” “absolute,” etc.‍—themselves all negative terms, i.e., formed etymologically from a positive concept by adding a negative prefix (in + finite = not finite; ab + solute = not compounded, etc.). But, since our verbally conditioned mental functions are habituated to the connection of word and thing, we tend to hypostatize a “void,” analogous to “outer space,” a “vacuum,” etc., which we either shrink from as a nihilistic nothingness or become attached to as a liberative nothingness; this great mistake can be cured only by realizing the meaning of the “<span class="ignore">emptiness</span> of <span class="ignore">emptiness</span>,” which brings us to the tolerance of <span data-glossary-id="UT22084-060-005-585">inconceivability</span>.</p></div></div></div></div><div id="1ede53af-8161-4358-9902-76ff3144ae49" class="relative scroll-mt-20"><button type="button" id="radix-_R_4md5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.89</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">emptiness, voidness, śūnyatā</div><ul class="ml-4 list-disc"><li class="italic">stong pa nyid, stong pa nyid, stong pa nyid</li><li class="pt-1"><span class="font-tibetan text-base">སྟོང་པ་ཉིད།, སྟོང་པ་ཉིད།, སྟོང་པ་ཉིད།</span></li><li class="italic">śūnyatā, śūnyatā, śūnyatā</li></ul><div class="glossary-instance-definition"><p class="definition"><span data-glossary-id="UT22084-060-005-689">Voidness</span>, <span data-glossary-id="UT22084-060-005-550">emptiness</span>; specifically, the <span data-glossary-id="UT22084-060-005-550">emptiness</span> of absolute substance, truth, <span data-glossary-id="UT22084-060-005-579">identity</span>, intrinsic reality, or <span data-glossary-id="UT22084-060-005-649">self</span> of all persons and things in the relative world, being quite opposed to any sort of absolute nothingness (see glossary, under “<span data-glossary-id="UT22084-060-005-550">emptiness</span>”).</p></div></div></div></div><div id="e74ef65c-8fc8-4dbf-9bba-7326d6b5d34d" class="relative scroll-mt-20"><button type="button" id="radix-_R_4ml5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.90</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">emptiness, voidness, śūnyatā</div><ul class="ml-4 list-disc"><li class="italic">stong pa nyid, stong pa nyid, stong pa nyid</li><li class="pt-1"><span class="font-tibetan text-base">སྟོང་པ་ཉིད།, སྟོང་པ་ཉིད།, སྟོང་པ་ཉིད།</span></li><li class="italic">śūnyatā, śūnyatā, śūnyatā</li></ul><div class="glossary-instance-definition"><p class="definition">See “<span data-glossary-id="UT22084-060-005-550">emptiness</span>.”</p></div></div></div></div><div id="62f923c5-8dfa-4620-8dec-7bb032231bf7" class="relative scroll-mt-20"><button type="button" id="radix-_R_4mt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.91</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">enlightenment</div><ul class="ml-4 list-disc"><li class="italic">byang chub</li><li class="pt-1"><span class="font-tibetan text-base">བྱང་ཆུབ།</span></li><li class="italic">bodhi</li></ul><div class="glossary-instance-definition"><p class="definition">This word requires too much explanation for this glossary because, indeed, the whole <span data-glossary-id="UT22084-060-005-670">sūtra</span>‍—and the whole of Buddhist literature‍—is explanatory of only this. Here we simply mention the translation equivalent.</p></div></div></div></div><div id="db2bd23e-00ed-4f18-9412-b132216e90b8" class="relative scroll-mt-20"><button type="button" id="radix-_R_4n55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.92</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">epitomes of the Dharma, four epitomes, four epitomes of the Dharma, four insignia of the Dharma</div><ul class="ml-4 list-disc"><li class="italic">bka’ rtags kyi phyag rgya bzhi, chos kyi phyag rgya bzhi</li><li class="pt-1"><span class="font-tibetan text-base">ཆོས་ཀྱི་ཕྱག་རྒྱ་བཞི།, བཀའ་རྟགས་ཀྱི་ཕྱག་རྒྱ་བཞི།</span></li><li class="italic">dharmoddāna</li></ul><div class="glossary-instance-definition"><p class="definition">The four are as follows: All compounded things are impermanent (<em class="foreign break text-sa" lang="sa-LATN">anityāḥ sarva­saṃskārāḥ</em>). All defiled things are suffering (<em class="foreign break text-sa" lang="sa-LATN">duḥkhāh sarva­sāsravāḥ</em>). All things are without <span data-glossary-id="UT22084-060-005-649">self</span> (<em class="foreign break text-sa" lang="sa-LATN">anātmanāḥ sarva­dharmāḥ</em>). <span data-glossary-id="UT22084-060-005-621">Nirvāṇa</span> is peace (<em class="foreign break text-sa" lang="sa-LATN">śāntaṃ nirvāṇaṃ</em>). Also called “the <span class="ignore">four insignia of the Dharma</span>.”</p></div></div></div></div><div id="3d00be41-eb5a-4c3b-912f-ae0bfe367b16" class="relative scroll-mt-20"><button type="button" id="radix-_R_4nd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.93</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">family of the Buddha</div><ul class="ml-4 list-disc"><li class="italic">sangs rgyas kyi rigs</li><li class="pt-1"><span class="font-tibetan text-base">སངས་རྒྱས་ཀྱི་རིགས།</span></li><li class="italic">buddhakula</li></ul><div class="glossary-instance-definition"><p class="definition">Lit. “family” or “lineage of the <span data-glossary-id="UT22084-060-005-515">Buddha</span>.” One becomes a member on the first <span data-glossary-id="UT22084-060-005-513">bodhisattva</span> stage. In another sense, all living beings belong to this exalted family because all have the capacity to wake up to <span data-glossary-id="UT22084-060-005-551">enlightenment</span>, conceiving its spirit within themselves and thenceforward seeking its realization (see <a data-pointer-target="#chapter-7" data-pointer-type="id">Chapter 7</a>).</p></div></div></div></div><div id="e4e4b3ff-ee08-45e4-8dbf-92d67f110c14" class="relative scroll-mt-20"><button type="button" id="radix-_R_4nl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.94</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">family of the tathāgatas, ‘family of the tathāgatas’</div><ul class="ml-4 list-disc"><li class="italic">de bzhin gshegs pa’i rigs</li><li class="pt-1"><span class="font-tibetan text-base">དེ་བཞིན་གཤེགས་པའི་རིགས།</span></li><li class="italic">tathāgatagotra</li></ul><div class="glossary-instance-definition"><p class="definition">This term arises from a classification of beings into different groups (lineages) according to their destinies: disciple lineage, solitary <span data-glossary-id="UT22084-060-005-515">buddha</span> lineage, <span data-glossary-id="UT22084-060-005-515">buddha</span> lineage, etc. The <span data-glossary-id="UT22084-060-005-603">Mādhyamika</span> school, and the <span data-glossary-id="UT22084-060-005-670">sūtras</span> that are its foundation, maintains that all living beings belong to the <span data-glossary-id="UT22084-060-005-515">buddha</span> lineage, that <span data-glossary-id="UT22084-060-005-662">Disciple Vehicle</span> <span data-glossary-id="UT22084-060-005-621">nirvāṇa</span> is not a final destiny, and that <span data-glossary-id="UT22084-060-005-504">arhats</span> must eventually enter the <span data-glossary-id="UT22084-060-005-605">Mahāyāna</span> path. <span data-glossary-id="UT22084-060-005-746">Mañjuśrī</span> carries this idea to the extreme, finding the <span data-glossary-id="UT22084-060-005-672">tathāgata</span> lineage everywhere, in all mundane things. See <a href="UT22084-060-005-chapter-7.xhtml#UT22084-060-005-21" data-pointer-type="id">7.9</a>, and Lamotte, Appendice, Note VII.</p></div></div></div></div><div id="b8daff33-91de-4457-9d38-959adf13a079" class="relative scroll-mt-20"><button type="button" id="radix-_R_4nt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.95</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">fearlessness, fearlessnesses</div><ul class="ml-4 list-disc"><li class="italic">mi ’jigs pa</li><li class="pt-1"><span class="font-tibetan text-base">མི་འཇིགས་པ།</span></li><li class="italic">vaiśāradya</li></ul><div class="glossary-instance-definition"><p class="definition">The <span data-glossary-id="UT22084-060-005-515">Buddha</span> has four <span class="ignore">fearlessnesses</span>, as do the <span data-glossary-id="UT22084-060-005-513">bodhisattvas</span>. The four <span class="ignore">fearlessnesses</span> of the <span data-glossary-id="UT22084-060-005-515">Buddha</span> are: <span class="ignore">fearlessness</span> regarding the realization of all things; <span class="ignore">fearlessness</span> regarding knowledge of the exhaustion of all impurities; <span class="ignore">fearlessness</span> of foresight through ascertainment of the persistence of obstructions; and <span class="ignore">fearlessness</span> in the rightness of the path leading to the attainment of the supreme success. The <span class="ignore">fearlessnesses</span> of the <span data-glossary-id="UT22084-060-005-513">bodhisattva</span> are: <span class="ignore">fearlessness</span> in teaching the meaning he has understood from what he has learned and practiced; <span class="ignore">fearlessness</span> resulting from the successful maintenance of purity in physical, verbal, and mental action‍—without relying on others’ kindness, being naturally flawless through his understanding of the <span data-glossary-id="UT22084-060-005-499">absence of self</span>; <span class="ignore">fearlessness</span> resulting from freedom from obstruction in virtue, in teaching, and in delivering living beings, through the perfection of <span data-glossary-id="UT22084-060-005-691">wisdom</span> and <span data-glossary-id="UT22084-060-005-598">liberative art</span> and through not forgetting and constantly upholding the teachings; and <span class="ignore">fearlessness</span> in the ambition to attain full mastery of <span data-glossary-id="UT22084-060-005-626">omniscience</span>‍—without any deterioration or deviation to other practices‍—and to accomplish all the aims of all living beings.</p></div></div></div></div><div id="b0ed4425-d04a-4f93-95c0-8e4b57d5f2cf" class="relative scroll-mt-20"><button type="button" id="radix-_R_4o55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.96</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">female attendants</div><ul class="ml-4 list-disc"><li class="italic">slas</li><li class="pt-1"><span class="font-tibetan text-base">སླས།</span></li><li class="italic">sahacāri</li></ul><div class="glossary-instance-definition"><p class="definition"><span class="ignore">Female attendants</span> who normally assisted the wife of a wealthy householder.</p></div></div></div></div><div id="b3f27308-d8e9-4edd-b1de-2bb77c99ef3a" class="relative scroll-mt-20"><button type="button" id="radix-_R_4od5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.97</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">five deadly sins</div><ul class="ml-4 list-disc"><li class="italic">mtshams med lnga</li><li class="pt-1"><span class="font-tibetan text-base">མཚམས་མེད་ལྔ།</span></li><li class="italic">ānantarya</li></ul><div class="glossary-instance-definition"><p class="definition">Lit. “sins of immediate retribution [after death].” These five, all of which cause immediate rebirth in hell, are killing one’s father, killing one’s mother, killing an <span data-glossary-id="UT22084-060-005-504">arhat</span>, breaking up the <span data-glossary-id="UT22084-060-005-646">saṅgha</span>, and causing, with evil intent, the <span data-glossary-id="UT22084-060-005-672">Tathāgata</span> to bleed.</p></div></div></div></div><div id="aeb42ef6-d010-4ece-a211-3e3833694ff0" class="relative scroll-mt-20"><button type="button" id="radix-_R_4ol5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.98</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">five desire objects</div><ul class="ml-4 list-disc"><li class="italic">’dod pa’i yon tan lnga</li><li class="pt-1"><span class="font-tibetan text-base">འདོད་པའི་ཡོན་ཏན་ལྔ།</span></li><li class="italic">pañcakāmaguṇaḥ</li></ul><div class="glossary-instance-definition"><p class="definition">Visibles, sound, scent, taste, and tangibles.</p></div></div></div></div><div id="1d9e7927-3a63-4200-b1a4-996d9730efa2" class="relative scroll-mt-20"><button type="button" id="radix-_R_4ot5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.99</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">five obscurations</div><ul class="ml-4 list-disc"><li class="italic">sgrib pa lnga</li><li class="pt-1"><span class="font-tibetan text-base">སྒྲིབ་པ་ལྔ།</span></li><li class="italic">nīvaraṇa</li></ul><div class="glossary-instance-definition"><p>Five impediments to meditation (<em class="foreign text-wy" lang="bo-LATN">bsam gtan</em>, <em class="foreign break text-sa" lang="sa-LATN">dhyāna</em>): sensory desire (<em class="foreign text-wy" lang="bo-LATN">’dod pa la ’dun pa</em>, <em class="foreign break text-sa" lang="sa-LATN">kāmacchanda</em>), ill will (<em class="foreign text-wy" lang="bo-LATN">gnod sems</em>, <em class="foreign break text-sa" lang="sa-LATN">vyāpāda</em>), drowsiness and torpor (<em class="foreign text-wy" lang="bo-LATN">rmugs pa dang gnyid</em>, <em class="foreign break text-sa" lang="sa-LATN">styānamiddha</em>), agitation and regret (<em class="foreign text-wy" lang="bo-LATN">rgod pa dang ’gyod pa</em>, <em class="foreign break text-sa" lang="sa-LATN">auddhatya­kaukṛtya</em>), and doubt (<em class="foreign text-wy" lang="bo-LATN">the tshom</em>, <em class="foreign break text-sa" lang="sa-LATN">vicikitsā</em>).</p></div></div></div></div><div id="b8fa8f2b-1b78-4cd1-b764-f677f3c421a2" class="relative scroll-mt-20"><button type="button" id="radix-_R_4p55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.100</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">five powers</div><ul class="ml-4 list-disc"><li class="italic">stobs lnga</li><li class="pt-1"><span class="font-tibetan text-base">སྟོབས་ལྔ།</span></li><li class="italic">bala</li></ul><div class="glossary-instance-definition"><p class="definition">These are the same as the <span data-glossary-id="UT22084-060-005-559">five spiritual faculties</span>, at a further stage of development.</p></div></div></div></div><div id="c4d85259-d78b-44af-a837-0dff8e4422f1" class="relative scroll-mt-20"><button type="button" id="radix-_R_4pd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.101</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">five spiritual faculties</div><ul class="ml-4 list-disc"><li class="italic">dbang po lnga</li><li class="pt-1"><span class="font-tibetan text-base">དབང་པོ་ལྔ།</span></li><li class="italic">indriya</li></ul><div class="glossary-instance-definition"><p class="definition">These are called “faculties” (<em class="foreign break text-sa" lang="sa-LATN">indriya</em>) by analogy, as they are considered as capacities to be developed: the spiritual faculties for faith (<em class="foreign break text-sa" lang="sa-LATN">śraddhā</em>), effort (<em class="foreign break text-sa" lang="sa-LATN">vīrya</em>), mindfulness (<em class="foreign break text-sa" lang="sa-LATN">smṛti</em>), <span data-glossary-id="UT22084-060-005-521">concentration</span> (<em class="foreign break text-sa" lang="sa-LATN"><span data-glossary-id="UT22084-060-005-642">samādhi</span></em>), and <span data-glossary-id="UT22084-060-005-691">wisdom</span> (<em class="foreign break text-sa" lang="sa-LATN">prajña</em>). These are included in the <span data-glossary-id="UT22084-060-005-676">thirty-seven aids to enlightenment</span>. </p></div></div></div></div><div id="99cbd2a0-b2ab-49e2-90c3-cf2f4370226f" class="relative scroll-mt-20"><button type="button" id="radix-_R_4pl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.102</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">four bases of magical power</div><ul class="ml-4 list-disc"><li class="italic">rdzu ’phrul gyi rkang pa bzhi</li><li class="pt-1"><span class="font-tibetan text-base">རྫུ་འཕྲུལ་གྱི་རྐང་པ་བཞི།</span></li><li class="italic">ṛddhipāda</li></ul><div class="glossary-instance-definition"><p class="definition">The first basis of magical power consists of the energy from the conscious cultivation of <span data-glossary-id="UT22084-060-005-521">concentration</span> of will (<em class="foreign break text-sa" lang="sa-LATN">chanda­samādhi­prahāṇa­saṃskāra­samanvāgataḥ</em>). The second consists of the energy from the conscious cultivation of <span data-glossary-id="UT22084-060-005-521">concentration</span> of mind (<em class="foreign break text-sa" lang="sa-LATN">citta‑</em>). The third consists of <span data-glossary-id="UT22084-060-005-521">concentration</span> of effort (<em class="foreign break text-sa" lang="sa-LATN">vīrya‑</em>). The fourth consists of <span data-glossary-id="UT22084-060-005-521">concentration</span> of analysis (<em class="foreign break text-sa" lang="sa-LATN">mīmāṃsa‑</em>). These four form a part of the <span data-glossary-id="UT22084-060-005-676">thirty-seven aids to enlightenment</span>. </p></div></div></div></div><div id="f4db2b9d-21ee-4f8d-bd01-e07a01cdcfc5" class="relative scroll-mt-20"><button type="button" id="radix-_R_4pt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.103</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">four foci of mindfulness</div><ul class="ml-4 list-disc"><li class="italic">dran pa nye bar gzhag pa</li><li class="pt-1"><span class="font-tibetan text-base">དྲན་པ་ཉེ་བར་གཞག་པ།</span></li><li class="italic">smṛtyupasṭhāna</li></ul><div class="glossary-instance-definition"><p class="definition">These are the stationing, or focusing, of mindfulness on the body, <span data-glossary-id="UT22084-060-005-651">sensations</span>, the mind, and things. These four form a part of the <span data-glossary-id="UT22084-060-005-676">thirty-seven aids to enlightenment</span>.</p></div></div></div></div><div id="549eeb32-c375-4406-b20e-a04cfda32ca6" class="relative scroll-mt-20"><button type="button" id="radix-_R_4q55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.104</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">four immeasurables</div><ul class="ml-4 list-disc"><li class="italic">tshad med bzhi</li><li class="pt-1"><span class="font-tibetan text-base">ཚད་མེད་བཞི།</span></li><li class="italic">catvāryapramāṇāni</li></ul><div class="glossary-instance-definition"><p class="definition">Immeasurable states, otherwise known as “pure abodes” (<em class="foreign break text-sa" lang="sa-LATN">brahmā­vihāra</em>). Immeasurable love arises from the wish for all living beings to have happiness and the cause of happiness. Immeasurable compassion arises from the wish for all living beings to be free from suffering and its cause. Immeasurable joy arises from the wish that living beings not be sundered from the supreme happiness of <span data-glossary-id="UT22084-060-005-597">liberation</span>. And immeasurable impartiality arises from the wish that the preceding‍—love, compassion, and joy‍—should apply equally to all living beings, without attachment to friend or hatred for enemy. </p></div></div></div></div><div id="91f74f01-6cd8-4a5e-8b20-7d6a23353d69" class="relative scroll-mt-20"><button type="button" id="radix-_R_4qd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.105</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">four misapprehensions</div><ul class="ml-4 list-disc"><li class="italic">phyin ci log bzhi</li><li class="pt-1"><span class="font-tibetan text-base">ཕྱིན་ཅི་ལོག་བཞི།</span></li><li class="italic">viparyāsa</li></ul><div class="glossary-instance-definition"><p class="definition">These consist of mistaking what is impermanent for permanent; mistaking what is without <span data-glossary-id="UT22084-060-005-649">self</span> for <span class="ignore">self</span>-possessing; mistaking what is impure for pure; and mistaking what is miserable for happy.</p></div></div></div></div><div id="09cf908e-1345-4575-86f2-fd0bf0c0fcce" class="relative scroll-mt-20"><button type="button" id="radix-_R_4ql5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.106</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">four reliances</div><ul class="ml-4 list-disc"><li class="italic">rton pa bzhi</li><li class="pt-1"><span class="font-tibetan text-base">རྟོན་པ་བཞི།</span></li><li class="italic">pratiśārana</li></ul><div class="glossary-instance-definition"><p class="definition">To attain higher realizations and final <span data-glossary-id="UT22084-060-005-551">enlightenment</span>, the <span data-glossary-id="UT22084-060-005-513">bodhisattva</span> should rely on the meaning (of the teaching) and not on the expression (<em class="foreign break text-sa" lang="sa-LATN">artha­pratisāraṇena bhavitavyaṃ na vyañjana­pratisāraṇena</em>); on the teaching and not on the person (who teaches it) (<em class="foreign break text-sa" lang="sa-LATN">dharma­pratisāraṇena bhavitavyaṃ na pudgala­pratisāraṇena</em>); on <span data-glossary-id="UT22084-060-005-571">gnosis</span> and not on normal <span data-glossary-id="UT22084-060-005-527">consciousness</span> (<em class="foreign break text-sa" lang="sa-LATN">jñāna­pratisāraṇena bhavitavyaṃ na vijñāna­pratisāraṇena</em>); and on discourses of <span data-glossary-id="UT22084-060-005-532">definitive meaning</span> and not on discourses of <span data-glossary-id="UT22084-060-005-589">interpretable meaning</span> (<em class="foreign break text-sa" lang="sa-LATN">nītārtha­sūtra­pratisāraṇena bhavitavyaṃ na neyārtha­sūtra­pratisāraṇena</em>) according to the order in this <span data-glossary-id="UT22084-060-005-670">sūtra</span>. The usual order, “teaching-reliance,” “meaning-reliance,” definitive-meaning-discourse-reliance,” and “<span data-glossary-id="UT22084-060-005-571">gnosis</span>-reliance,” seems to conform better to stages of practice. </p></div></div></div></div><div id="01a4b527-b5af-468a-9e30-4adee8b44243" class="relative scroll-mt-20"><button type="button" id="radix-_R_4qt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.107</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">four right efforts</div><ul class="ml-4 list-disc"><li class="italic">yang dag par spong ba bzhi</li><li class="pt-1"><span class="font-tibetan text-base">ཡང་དག་པར་སྤོང་བ་བཞི།</span></li><li class="italic">samyak­pradhāna, samyak­prahāṇa</li></ul><div class="glossary-instance-definition"><p class="definition">These are effort not to initiate sins not yet arisen; effort to eliminate sins already arisen; effort to initiate virtues not yet arisen; and effort to consolidate, increase, and not deteriorate virtues already arisen. For our use of “effort” (<em class="foreign break text-sa" lang="sa-LATN">samyak­pradhāna</em>) instead of lit. “abandonment” (<em class="foreign break text-sa" lang="sa-LATN">samyak­prahāna</em>) see Dayal, p. 102 ff. These four form a part of the <span data-glossary-id="UT22084-060-005-676">thirty-seven aids to enlightenment</span>.</p></div></div></div></div><div id="09a767b0-9237-4729-b8e7-f1b27198e5e2" class="relative scroll-mt-20"><button type="button" id="radix-_R_4r55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.108</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Gaganagañja</div><ul class="ml-4 list-disc"><li class="italic">nam mkha’i mdzod</li><li class="pt-1"><span class="font-tibetan text-base">ནམ་མཁའི་མཛོད།</span></li><li class="italic">gaganagañja</li></ul></div></div></div><div id="218fb105-f276-48ec-b576-7cdc92d2b3f9" class="relative scroll-mt-20"><button type="button" id="radix-_R_4rd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.109</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Gaja­gandha­hastin</div><ul class="ml-4 list-disc"><li class="italic">spos kyi ba glang glang po che</li><li class="pt-1"><span class="font-tibetan text-base">སྤོས་ཀྱི་བ་གླང་གླང་པོ་ཆེ།</span></li><li class="italic">gaja­gandha­hastin</li></ul></div></div></div><div id="f9f4f1c7-13b3-4110-9afc-cf4ed0a6085f" class="relative scroll-mt-20"><button type="button" id="radix-_R_4rl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.110</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Gandhahastin</div><ul class="ml-4 list-disc"><li class="italic">spos kyi glang po che</li><li class="pt-1"><span class="font-tibetan text-base">སྤོས་ཀྱི་གླང་པོ་ཆེ།</span></li><li class="italic">gandhahastin</li></ul></div></div></div><div id="c1ffdb8b-41ce-4926-99ed-06daf4f00177" class="relative scroll-mt-20"><button type="button" id="radix-_R_4rt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.111</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Gandhamādana</div><ul class="ml-4 list-disc"><li class="italic">spos kyi ngad ldan</li><li class="pt-1"><span class="font-tibetan text-base">སྤོས་ཀྱི་ངད་ལྡན།</span></li><li class="italic">gandhamādana</li></ul><div class="glossary-instance-definition"><p class="definition">A mountain known for its incense trees.</p></div></div></div></div><div id="dec6f90a-8d2e-4ef5-914c-698acd562891" class="relative scroll-mt-20"><button type="button" id="radix-_R_4s55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.112</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">gandharva</div><ul class="ml-4 list-disc"><li class="italic">dri za</li><li class="pt-1"><span class="font-tibetan text-base">དྲི་ཟ།</span></li><li class="italic">gandharva</li></ul><div class="glossary-instance-definition"><p>A class of generally benevolent nonhuman beings who inhabit the skies, sometimes said to inhabit fantastic cities in the clouds, and more specifically to dwell on the eastern slopes of Mount Meru, where they are ruled by the Great King Dhṛtarāṣṭra. They are most renowned as celestial musicians who serve the gods. In the Abhidharma, the term is also used to refer to the mental body assumed by sentient beings during the intermediate state between death and rebirth. Gandharvas are said to live on fragrances (<em class="foreign break text-sa" lang="sa-LATN">gandha</em>) in the desire realm, hence the Tibetan translation <em class="foreign text-wy" lang="bo-LATN">dri za</em>, meaning “scent eater.”</p></div></div></div></div><div id="f307d5db-ad76-494a-9e50-4220c05407a8" class="relative scroll-mt-20"><button type="button" id="radix-_R_4sd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.113</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Gandha­vyūhāhāra</div><ul class="ml-4 list-disc"><li class="italic">spos bkod pa’i zas</li><li class="pt-1"><span class="font-tibetan text-base">སྤོས་བཀོད་པའི་ཟས།</span></li><li class="italic">gandha­vyūhāhāra</li></ul><div class="glossary-instance-definition"><p class="definition">Deities who attend on the <span data-glossary-id="UT22084-060-005-515">Buddha</span> Sugandhakūta in the universe <span data-glossary-id="UT22084-060-005-842">Sarva­gandha­sugandhā</span>.</p></div></div></div></div><div id="f6620db3-953d-40c5-bb5d-2291ee6ff394" class="relative scroll-mt-20"><button type="button" id="radix-_R_4sl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.114</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Gandhottama­kūṭa</div><ul class="ml-4 list-disc"><li class="italic">spos mchog brtsegs pa</li><li class="pt-1"><span class="font-tibetan text-base">སྤོས་མཆོག་བརྩེགས་པ།</span></li><li class="italic">gandhottama­kūṭa</li></ul><div class="glossary-instance-definition"><p class="definition"><span data-glossary-id="UT22084-060-005-515">Buddha</span> of the universe <span data-glossary-id="UT22084-060-005-842">Sarva­gandha­sugandhā</span>, from whom <span data-glossary-id="UT22084-060-005-1257">Vimalakīrti</span>’s emanation-<span data-glossary-id="UT22084-060-005-513">bodhisattva</span> obtains the vessel of ambrosial food that magically feeds the entire assembly without diminishing in the slightest.</p></div></div></div></div><div id="957e97aa-bb76-4d91-9d03-7f77b3582fd1" class="relative scroll-mt-20"><button type="button" id="radix-_R_4st5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.115</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">garuḍa</div><ul class="ml-4 list-disc"><li class="italic">nam mkha’ lding</li><li class="pt-1"><span class="font-tibetan text-base">ནམ་མཁའ་ལྡིང་།</span></li><li class="italic">garuḍa</li></ul><div class="glossary-instance-definition"><p>In Indian mythology, the garuḍa is an eagle-like bird that is regarded as the king of all birds, normally depicted with a sharp, owl-like beak, often holding a snake, and with large and powerful wings. They are traditionally enemies of the nāgas. In the Vedas, they are said to have brought nectar from the heavens to earth. <em class="foreign break text-sa" lang="sa-LATN">Garuḍa</em> can also be used as a proper name for a king of such creatures.</p></div></div></div></div><div id="57f30533-44ff-42b7-a670-f57da1f54504" class="relative scroll-mt-20"><button type="button" id="radix-_R_4t55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.116</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">gnosis</div><ul class="ml-4 list-disc"><li class="italic">ye shes</li><li class="pt-1"><span class="font-tibetan text-base">ཡེ་ཤེས།</span></li><li class="italic">jñāna</li></ul><div class="glossary-instance-definition"><p class="definition">This is knowledge of the nonconceptual and transcendental which is realized by those attaining higher stages.</p></div></div></div></div><div id="8de0a524-74ca-4f51-8f2e-ba02b9f037a2" class="relative scroll-mt-20"><button type="button" id="radix-_R_4td5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.117</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">grace</div><ul class="ml-4 list-disc"><li class="italic">byin gyis brlabs</li><li class="pt-1"><span class="font-tibetan text-base">བྱིན་གྱིས་བརླབས།</span></li><li class="italic">adhiṣṭḥāna</li></ul><div class="glossary-instance-definition"><p class="definition">The “supernatural power” with which the <span data-glossary-id="UT22084-060-005-515">buddhas</span> sustain the <span data-glossary-id="UT22084-060-005-513">bodhisattvas</span> in their great efforts on behalf of living beings.</p></div></div></div></div><div id="dc1f3a82-a37b-47bc-a900-9c62a98401cb" class="relative scroll-mt-20"><button type="button" id="radix-_R_4tl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.118</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">great compassion</div><ul class="ml-4 list-disc"><li class="italic">snying rje chen po</li><li class="pt-1"><span class="font-tibetan text-base">སྙིང་རྗེ་ཆེན་པོ།</span></li><li class="italic">mahākaruṇā</li></ul><div class="glossary-instance-definition"><p class="definition">This refers to one of the two central qualities of <span data-glossary-id="UT22084-060-005-515">buddhas</span> or high <span data-glossary-id="UT22084-060-005-513">bodhisattvas</span>: their feeling born of the wish for all living beings to be free of suffering and to attain the supreme happiness. It is important to note that this great compassion has nothing to do with any sentimental emotion such as that stimulated by such a reflection as “Oh, the poor creatures! How they are suffering!” On the contrary, great compassion is accompanied by the clear awareness that ultimately there are no such things as living beings, suffering, etc., in reality. Thus it is a sensitivity that does not entertain any dualistic notion of subject and object; indeed, such an unlimited sensitivity might best be termed “empathy.”</p></div></div></div></div><div id="c1233550-43a1-4be4-9029-37b7e4e3f573" class="relative scroll-mt-20"><button type="button" id="radix-_R_4tt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.119</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">great love</div><ul class="ml-4 list-disc"><li class="italic">byams pa chen po</li><li class="pt-1"><span class="font-tibetan text-base">བྱམས་པ་ཆེན་པོ།</span></li><li class="italic">mahāmaitrī</li></ul><div class="glossary-instance-definition"><p class="definition">In an effort to maintain distinctions between Buddhism and Christianity, translators have used all sorts of euphemisms for this basic term. Granted, it is not the everyday “love” that means “to like”; it is still the altruistic love that is the finest inspiration of Christ’s teaching, as well as of the <span data-glossary-id="UT22084-060-005-605">Mahāyāna</span>.</p></div></div></div></div><div id="8f291152-70ba-4e56-9a1c-8d800b7f67e6" class="relative scroll-mt-20"><button type="button" id="radix-_R_4u55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.120</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">great spiritual hero</div><ul class="ml-4 list-disc"><li class="italic">sems dpa’ chen po</li><li class="pt-1"><span class="font-tibetan text-base">སེམས་དཔའ་ཆེན་པོ།</span></li><li class="italic">mahāsattva</li></ul><div class="glossary-instance-definition"><p class="definition">This translation follows the Tib. (lit. “great mind- hero”), whose translation from Skt. derives from the <em class="foreign text-wy" lang="bo-LATN">lo tsā ba</em>’s analysis of sattva as meaning “hero,” rather than simply “being.”</p></div></div></div></div><div id="9e965ab3-84e2-4b05-873f-324b2f5ca383" class="relative scroll-mt-20"><button type="button" id="radix-_R_4ud5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.121</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">high resolve</div><ul class="ml-4 list-disc"><li class="italic">lhag pa’i bsam pa</li><li class="pt-1"><span class="font-tibetan text-base">ལྷག་པའི་བསམ་པ།</span></li><li class="italic">adhyāśaya</li></ul><div class="glossary-instance-definition"><p class="definition">This is a stage in the conception or initiation of the spirit‌ of <span data-glossary-id="UT22084-060-005-551">enlightenment</span>‌. It follows upon the <span data-glossary-id="UT22084-060-005-631">positive thought</span>, or aspiration to attain it, wherein the <span data-glossary-id="UT22084-060-005-513">bodhisattva</span> becomes filled with a lofty determination that he himself should attain <span data-glossary-id="UT22084-060-005-551">enlightenment</span>, that it is the only thing to do to solve his own problems as well as those of all living beings. This <span class="ignore">high resolve</span> reaches its most intense purity when the <span data-glossary-id="UT22084-060-005-513">bodhisattva</span> simultaneously attains the Path of Insight and the first <span data-glossary-id="UT22084-060-005-513">bodhisattva</span>-stage, the Stage of Joy. The translation follows Lamotte’s happy coinage “<em class="foreign">haute résolution</em>.” </p></div></div></div></div><div id="7a1f711c-1731-4ba1-a7b6-cd7a91751a85" class="relative scroll-mt-20"><button type="button" id="radix-_R_4ul5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.122</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">highest deities</div><ul class="ml-4 list-disc"><li class="italic">gzhan ’phrul dbang byed kyi lha</li><li class="pt-1"><span class="font-tibetan text-base">གཞན་འཕྲུལ་དབང་བྱེད་ཀྱི་ལྷ།</span></li><li class="italic">para­nīrmita­vaśa­vartin</li></ul><div class="glossary-instance-definition"><p class="definition">The deities of this, the sixth level of the gods of the desire-realm, appropriate and enjoy the magical creations of others; hence their name, literally, “who assume control of the emanations of others.” Their abode contains all the wonders created elsewhere and is referred to as a standard of splendor.</p></div></div></div></div><div id="c66c5cc4-2a03-4fb4-a080-105299213002" class="relative scroll-mt-20"><button type="button" id="radix-_R_4ut5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.123</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Himavat</div><ul class="ml-4 list-disc"><li class="italic">gangs ri</li><li class="pt-1"><span class="font-tibetan text-base">གངས་རི།</span></li><li class="italic">himavat</li></ul><div class="glossary-instance-definition"><p class="definition">A mountain.</p></div></div></div></div><div id="d4033e0d-7c54-4df4-859f-ee56603feb86" class="relative scroll-mt-20"><button type="button" id="radix-_R_4v55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.124</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">identities, identity</div><ul class="ml-4 list-disc"><li class="italic">rang bzhin</li><li class="pt-1"><span class="font-tibetan text-base">རང་བཞིན།</span></li><li class="italic">svabhāva</li></ul><div class="glossary-instance-definition"><p class="definition"><em class="foreign break text-sa" lang="sa-LATN">Svabhāva</em> is usually rendered as “<span class="ignore">self</span>-nature,” sometimes as “own-being,” both of which have a certain literal validity. However, neither artificial term has any evocative power for the reader who has no familiarity with the original, and a term must be found that the reader can immediately relate to his own world to fulfill the function the original word had in its world. In our world of <span class="ignore">identities</span> (national, racial, religious, personal, sexual, etc.), “<span class="ignore">identity</span>” is a part of our makeup; thus, when we are taught the <span data-glossary-id="UT22084-060-005-683">ultimate</span> absence of <span class="ignore">identity</span> of all persons and things, it is easy to “identify” what is supposedly absent and hence to try to understand what that entails. </p></div></div></div></div><div id="1c8dbaa1-d394-4fd6-b49d-203c0c3613e7" class="relative scroll-mt-20"><button type="button" id="radix-_R_4vd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.125</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">immaterial realm</div><ul class="ml-4 list-disc"><li class="italic">gzugs med khams</li><li class="pt-1"><span class="font-tibetan text-base">གཟུགས་མེད་ཁམས།</span></li><li class="italic">ārūpyadhātu</li></ul><div class="glossary-instance-definition"><p class="definition">The highest and subtlest of the three realms of saṃsāra in Buddhist cosmology. Here beings are no longer bound by materiality and enjoy a purely mental state of absorption. It is divided in four levels according to each of the four formless concentrations (<em class="foreign break text-sa" lang="sa-LATN">ārūpyāvacaradhyāna</em>), namely, the Sphere of Infinite Space (<em class="foreign break text-sa" lang="sa-LATN">ākāśānantyāyatana</em>), the Sphere of Infinite Consciousness (<em class="foreign break text-sa" lang="sa-LATN">vijñānānantyāyatana</em>), the Sphere of Nothingness (<em class="foreign break text-sa" lang="sa-LATN">a­kiñ­canyāyatana</em>), and the Sphere of Neither Perception nor Non-perception (<em class="foreign break text-sa" lang="sa-LATN">naiva­saṃjñā­nāsaṃjñāyatana</em>). The formless realm is located above the other two realms of saṃsāra, the form realm (<em class="foreign break text-sa" lang="sa-LATN">rūpadhātu</em>) and the desire realm (<em class="foreign break text-sa" lang="sa-LATN">kāmadhātu</em>). </p></div></div></div></div><div id="e6cb9fdd-cfe1-4188-8cfb-b72314d72e94" class="relative scroll-mt-20"><button type="button" id="radix-_R_4vl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.126</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">incantation, retention</div><ul class="ml-4 list-disc"><li class="italic">gzungs</li><li class="pt-1"><span class="font-tibetan text-base">གཟུངས།</span></li><li class="italic">dhāraṇī</li></ul><div class="glossary-instance-definition"><p class="definition">The <span class="ignore">incantations</span>, or spells, are mnemonic formulas, possessed by advanced <span data-glossary-id="UT22084-060-005-513">bodhisattvas</span>, that contain a quintessence of their attainments, not simply magical charms‍—although the latter are included. The same term in Sanskrit and Tibetan also refers to a highly developed power present in <span data-glossary-id="UT22084-060-005-513">bodhisattvas</span> that is a process of memory and recall of detailed teachings, best translated “retention” in certain contexts. </p></div></div></div></div><div id="11384b0f-807e-4b8a-a7ef-a663577dfe40" class="relative scroll-mt-20"><button type="button" id="radix-_R_4vt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.127</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">incarnation-body</div><ul class="ml-4 list-disc"><li class="italic">sprul pa’i sku</li><li class="pt-1"><span class="font-tibetan text-base">སྤྲུལ་པའི་སྐུ།</span></li><li class="italic">nirmāṇakāya</li></ul><div class="glossary-instance-definition"><p class="definition">See “<span data-glossary-id="UT22084-060-005-549">emanated incarnation</span>.”</p></div></div></div></div><div id="2cd68d9f-da76-44be-a8e2-9c1463fce550" class="relative scroll-mt-20"><button type="button" id="radix-_R_5055anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.128</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">incomprehensibility, nonperception</div><ul class="ml-4 list-disc"><li class="italic">mi dmigs pa, mi dmigs pa</li><li class="pt-1"><span class="font-tibetan text-base">མི་དམིགས་པ།, མི་དམིགས་པ།</span></li><li class="italic">anupalambha, anupalambha</li></ul><div class="glossary-instance-definition"><p class="definition">This refers to the <span data-glossary-id="UT22084-060-005-683">ultimate</span> nature of things, which cannot be comprehended, grasped, etc., by the ordinary, conditioned, subjective mind. Hence it is significant that the realization of this nature is not couched in terms of understanding, or conviction, but in terms of tolerance (<em class="foreign break text-sa" lang="sa-LATN">kṣānti</em>), as the grasping mind cannot grasp its <span data-glossary-id="UT22084-060-005-683">ultimate</span> inability to grasp; it can only cultivate its tolerance of that inability. </p></div></div></div></div><div id="a7f0a1b7-f208-4ed3-bf1f-8e82c127ff0f" class="relative scroll-mt-20"><button type="button" id="radix-_R_50d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.129</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">incomprehensibility, nonperception</div><ul class="ml-4 list-disc"><li class="italic">mi dmigs pa, mi dmigs pa</li><li class="pt-1"><span class="font-tibetan text-base">མི་དམིགས་པ།, མི་དམིགས་པ།</span></li><li class="italic">anupalambha, anupalambha</li></ul><div class="glossary-instance-definition"><p class="definition">This refers to the mental openness cultivated by the <span data-glossary-id="UT22084-060-005-513">bodhisattva</span> who has reached a certain awareness of the nature of reality, in that he does not seek to perceive or apprehend any object or grasp any substance in anything; rather, he removes any static pretension of his mind to have grasped at any truth, conviction, or <span data-glossary-id="UT22084-060-005-686">view</span> (see also “<span data-glossary-id="UT22084-060-005-584">incomprehensibility</span>”).</p><p class="definition">(See also <a href="end-notes.xhtml#UT22084-060-005-986" data-pointer-type="id">n.124</a>).</p></div></div></div></div><div id="dc39b632-2a80-43b2-8eec-3bd2a37aa05c" class="relative scroll-mt-20"><button type="button" id="radix-_R_50l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.130</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">inconceivability</div><ul class="ml-4 list-disc"><li class="italic">bsam gyis mi khyab pa</li><li class="pt-1"><span class="font-tibetan text-base">བསམ་གྱིས་མི་ཁྱབ་པ།</span></li><li class="italic">acintyatā</li></ul><div class="glossary-instance-definition"><p class="definition">Lit. “unthinkability,” (on the part of a mind whose thinking is conditioned and bound by conceptual terms). This is essentially synonymous with “<span data-glossary-id="UT22084-060-005-584">incomprehensibility</span>” (see entry).</p></div></div></div></div><div id="9a3baeed-29d1-4683-bcd7-3c2f8f64c953" class="relative scroll-mt-20"><button type="button" id="radix-_R_50t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.131</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">inconceivable liberation</div><ul class="ml-4 list-disc"><li class="italic">rnam par thar pa bsam gyis mi khyab pa</li><li class="pt-1"><span class="font-tibetan text-base">རྣམ་པར་ཐར་པ་བསམ་གྱིས་མི་ཁྱབ་པ།</span></li><li class="italic">acintyavimokṣa</li></ul><div class="glossary-instance-definition"><p class="definition"><span class="ignore">Inconceivable liberation</span> of the <span data-glossary-id="UT22084-060-005-513">bodhisattvas</span>, a name of the <cite class="title break text-sa" lang="sa-LATN"><span data-glossary-id="UT22084-060-005-850">Avataṃsaka</span></cite>, and a subtitle of the Vimala­kīrti­nirdeśa. </p></div></div></div></div><div id="106b0a5f-94b9-4d3f-8a2b-d9bf63dfb70b" class="relative scroll-mt-20"><button type="button" id="radix-_R_5155anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.132</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Individual Vehicle</div><ul class="ml-4 list-disc"><li class="italic">theg pa dman pa</li><li class="pt-1"><span class="font-tibetan text-base">ཐེག་པ་དམན་པ།</span></li><li class="italic">hīnayāna</li></ul><div class="glossary-instance-definition"><p class="definition">See “<span data-glossary-id="UT22084-060-005-662">Disciple Vehicle</span>.”</p></div></div></div></div><div id="766ba35f-3608-4997-9124-c38604e872bb" class="relative scroll-mt-20"><button type="button" id="radix-_R_51d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.133</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Indra</div><ul class="ml-4 list-disc"><li class="italic">dbang po</li><li class="pt-1"><span class="font-tibetan text-base">དབང་པོ།</span></li><li class="italic">indra</li></ul><div class="glossary-instance-definition"><p class="definition">A major god in the Vedic pantheon, he dwindled in importance after Vedism was transformed into Hinduism in the early A.D. centuries. However, he was reinstated in Buddhist <span data-glossary-id="UT22084-060-005-670">sūtras</span> as the king of the gods and as a disciple of the <span data-glossary-id="UT22084-060-005-515">Buddha</span> and protector of the <span data-glossary-id="UT22084-060-005-537">Dharma</span> and its practicers.</p></div></div></div></div><div id="042a4bea-a615-40c0-9912-c64e4affaf1a" class="relative scroll-mt-20"><button type="button" id="radix-_R_51l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.134</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Indrajāla</div><ul class="ml-4 list-disc"><li class="italic">mig ’phrul can</li><li class="pt-1"><span class="font-tibetan text-base">མིག་འཕྲུལ་ཅན།</span></li><li class="italic">indrajāla</li></ul></div></div></div><div id="afa25927-4dea-4b0e-8765-ac84bed2ff94" class="relative scroll-mt-20"><button type="button" id="radix-_R_51t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.135</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">instinct</div><ul class="ml-4 list-disc"><li class="italic">bag chags</li><li class="pt-1"><span class="font-tibetan text-base">བག་ཆགས།</span></li><li class="italic">vāsanā</li></ul><div class="glossary-instance-definition"><p class="definition">The subconscious tendencies and predilections of the psychosomatic conglomerate. This most obvious word is seldom used in this context because of the hesitancy of scholars to employ “scientific” terminology.</p></div></div></div></div><div id="e99c8b55-d0a0-471a-bb37-d8b186e52742" class="relative scroll-mt-20"><button type="button" id="radix-_R_5255anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.136</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">intellect</div><ul class="ml-4 list-disc"><li class="italic">’du shes</li><li class="pt-1"><span class="font-tibetan text-base">འདུ་ཤེས།</span></li><li class="italic">samjñā</li></ul><div class="glossary-instance-definition"><p class="definition">See “<span data-glossary-id="UT22084-060-005-502">aggregate</span>.”</p></div></div></div></div><div id="fa991420-a40e-4cf0-ad1a-a06405b93975" class="relative scroll-mt-20"><button type="button" id="radix-_R_52d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.137</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">interpretable in meaning, interpretable meaning</div><ul class="ml-4 list-disc"><li class="italic">drang don</li><li class="pt-1"><span class="font-tibetan text-base">དྲང་དོན།</span></li><li class="italic">neyārtha</li></ul><div class="glossary-instance-definition"><p class="definition">See “<span data-glossary-id="UT22084-060-005-532">definitive meaning</span>.”</p></div></div></div></div><div id="4068d4e9-bd97-41e9-bb91-546490dbf9ff" class="relative scroll-mt-20"><button type="button" id="radix-_R_52l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.138</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">irreversible wheel of the Dharma</div><ul class="ml-4 list-disc"><li class="italic">phyir mi ldog pa’i chos kyi ’khor lo</li><li class="pt-1"><span class="font-tibetan text-base">ཕྱིར་མི་ལྡོག་པའི་ཆོས་ཀྱི་འཁོར་ལོ།</span></li><li class="italic">avaivartika­dharma­cakra</li></ul><div class="glossary-instance-definition"><p class="definition">The fact that the <span data-glossary-id="UT22084-060-005-537">Dharma</span> is not a single dogma, law, or fixed system, but instead an adaptable body of techniques available for any living being to aid in his development and <span data-glossary-id="UT22084-060-005-597">liberation</span> is emphasized by this metaphor. This wheel is said to turn by the current of energy from the needs and wishes of living beings, and its turning automatically converts negative energies (e.g., desire, hatred, and ignorance) to positive ones (e.g., detachment, love, and <span data-glossary-id="UT22084-060-005-691">wisdom</span>).</p></div></div></div></div><div id="c23b1e28-0c14-495c-9dab-e6e4e3efc108" class="relative scroll-mt-20"><button type="button" id="radix-_R_52t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.139</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Jagatindhara</div><ul class="ml-4 list-disc"><li class="italic">’gro ba ’dzin</li><li class="pt-1"><span class="font-tibetan text-base">འགྲོ་བ་འཛིན།</span></li><li class="italic">jagatindhara</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-060-005-513">bodhisattva</span> <span data-glossary-id="UT22084-060-005-595">layman</span> of <span data-glossary-id="UT22084-060-005-848">Vaiśālī</span>, who is saved by <span data-glossary-id="UT22084-060-005-1257">Vimalakīrti</span> from being fooled by <span data-glossary-id="UT22084-060-005-747">Māra</span> posing as <span data-glossary-id="UT22084-060-005-725">Indra</span>. This <span data-glossary-id="UT22084-060-005-513">bodhisattva</span> is mentioned in Mvy, No. 728, and in the <cite class="title break text-sa" lang="sa-LATN">Rāṣṭra­pāla­paripṛccha</cite> (Toh 62, in the <span data-glossary-id="UT22084-060-005-779">Ratnakūṭa</span>; see Lamotte, p. 204, n. 120 and Vienna Buddhist Studies Translation Group, trans., <cite class="title text-en" lang="en">The Questions of Rāṣṭrapāla</cite>, <a href="https://read.84000.co/translation/toh62#UT22084-042-003-321994" target="UT22084-042-003.html" data-pointer-type="id">1.1</a>).</p></div></div></div></div><div id="c800f0ff-668a-46af-ae56-389860e4b174" class="relative scroll-mt-20"><button type="button" id="radix-_R_5355anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.140</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Jālinīprabha</div><ul class="ml-4 list-disc"><li class="italic">dra ba can gyi ’od</li><li class="pt-1"><span class="font-tibetan text-base">དྲ་བ་ཅན་གྱི་འོད།</span></li><li class="italic">jālinīprabha</li></ul></div></div></div><div id="f08ab827-bf71-4a4e-88bf-b065370709c0" class="relative scroll-mt-20"><button type="button" id="radix-_R_53d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.141</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Jambudvīpa</div><ul class="ml-4 list-disc"><li class="italic">’dzam bu gling</li><li class="pt-1"><span class="font-tibetan text-base">འཛམ་བུ་གླིང་།</span></li><li class="italic">jambudvīpa</li></ul><div class="glossary-instance-definition"><p>The name of the southern continent in Buddhist cosmology, which can signify either the known human world, or more specifically the Indian subcontinent, literally “the <em class="foreign break text-sa" lang="sa-LATN">jambu</em> island/continent.” Jambu is the name used for a range of plum-like fruits from trees belonging to the genus <em class="foreign">Szygium</em>, particularly <em class="foreign">Szygium jambos</em> and <em class="foreign">Szygium cumini</em>, and it has commonly been rendered “rose apple,” although “black plum” may be a less misleading term. Among various explanations given for the continent being so named, one (in the <cite class="title break text-sa" lang="sa-LATN">Abhidharmakośa</cite>) is that a jambu tree grows in its northern mountains beside Lake Anavatapta, mythically considered the source of the four great rivers of India, and that the continent is therefore named from the tree or the fruit. Jambudvīpa has the Vajrāsana at its center and is the only continent upon which buddhas attain awakening.</p></div></div></div></div><div id="613d0117-d4f3-4f64-bef2-3e5bbf8d7f31" class="relative scroll-mt-20"><button type="button" id="radix-_R_53l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.142</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Kakuda Kātyāyana</div><ul class="ml-4 list-disc"><li class="italic">kA tya’i bu nog can</li><li class="pt-1"><span class="font-tibetan text-base">ཀཱ་ཏྱའི་བུ་ནོག་ཅན།</span></li><li class="italic">kakuda kātyāyana</li></ul><div class="glossary-instance-definition"><p class="definition">One of the six <span data-glossary-id="UT22084-060-005-627">outsider</span> teachers.</p></div></div></div></div><div id="84038a46-c74a-4367-b650-7bc5602f6cdd" class="relative scroll-mt-20"><button type="button" id="radix-_R_53t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.143</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Kālaparvata</div><ul class="ml-4 list-disc"><li class="italic">ri nag po</li><li class="pt-1"><span class="font-tibetan text-base">རི་ནག་པོ།</span></li><li class="italic">kālaparvata</li></ul><div class="glossary-instance-definition"><p class="definition">A mountain.</p></div></div></div></div><div id="b50a8fcc-a5eb-409b-96d4-a5872524e192" class="relative scroll-mt-20"><button type="button" id="radix-_R_5455anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.144</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">karma</div><ul class="ml-4 list-disc"><li class="italic">las</li><li class="pt-1"><span class="font-tibetan text-base">ལས།</span></li><li class="italic">karman</li></ul><div class="glossary-instance-definition"><p>Meaning “action” in its most basic sense, karma is an important concept in Buddhist philosophy as the cumulative force of previous physical, verbal, and mental acts, which determines present experience and will determine future existences.</p></div></div></div></div><div id="8effe26b-2996-454f-98a2-3e0cda7b9569" class="relative scroll-mt-20"><button type="button" id="radix-_R_54d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.145</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Kātyāyana, Mahākātyāyana</div><ul class="ml-4 list-disc"><li class="italic">ka tya’i bu, ka tya’i bu chen po</li><li class="pt-1"><span class="font-tibetan text-base">ཀ་ཏྱའི་བུ་ཆེན་པོ།, ཀ་ཏྱའི་བུ།</span></li><li class="italic">kātyāyana, mahākātyāyana</li></ul><div class="glossary-instance-definition"><p class="definition">(also <span data-glossary-id="UT22084-060-005-739">Mahākātyāyana</span>). Disciple of the <span data-glossary-id="UT22084-060-005-515">Buddha</span> noted for his skill in analysis of the <span data-glossary-id="UT22084-060-005-515">Buddha</span>’s discourses and, traditionally, the founder of the <span data-glossary-id="UT22084-060-005-498">Abhidharma</span>. See also <a href="end-notes.xhtml#UT22084-060-005-936" data-pointer-type="id">n.74</a>.</p></div></div></div></div><div id="c3b23efb-6f2b-472a-a510-fb9bc8636224" class="relative scroll-mt-20"><button type="button" id="radix-_R_54l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.146</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Kātyāyana, Mahākātyāyana</div><ul class="ml-4 list-disc"><li class="italic">ka tya’i bu, ka tya’i bu chen po</li><li class="pt-1"><span class="font-tibetan text-base">ཀ་ཏྱའི་བུ་ཆེན་པོ།, ཀ་ཏྱའི་བུ།</span></li><li class="italic">kātyāyana, mahākātyāyana</li></ul><div class="glossary-instance-definition"><p class="definition">(also <span data-glossary-id="UT22084-060-005-731">Kātyāyana</span>). Disciple of the <span data-glossary-id="UT22084-060-005-515">Buddha</span> noted for his skill in analysis of the <span data-glossary-id="UT22084-060-005-515">Buddha</span>’s discourses and, traditionally, the founder of the <span data-glossary-id="UT22084-060-005-498">Abhidharma</span>.</p></div></div></div></div><div id="dd1e9e44-e367-48b7-83c7-a9543c9d4693" class="relative scroll-mt-20"><button type="button" id="radix-_R_54t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.147</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Kauśika</div><ul class="ml-4 list-disc"><li class="italic">kau shi ka</li><li class="pt-1"><span class="font-tibetan text-base">ཀཽ་ཤི་ཀ</span></li><li class="italic">kauśika</li></ul><div class="glossary-instance-definition"><p class="definition">Another name for <span data-glossary-id="UT22084-060-005-725">Indra</span>. <span class="ignore">Kauśika</span>, <span data-glossary-id="UT22084-060-005-792">Śakra</span>, and <span data-glossary-id="UT22084-060-005-725">Indra</span> all refer to the same god, centrally prominent in the <span data-glossary-id="UT22084-060-005-861">Vedas</span>, who in Buddhist cosmogony is regarded as the king of gods in the <span data-glossary-id="UT22084-060-005-637">realm of desire</span>.</p></div></div></div></div><div id="1dff7c07-fc28-4276-b92d-2e5ec747e3c2" class="relative scroll-mt-20"><button type="button" id="radix-_R_5555anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.148</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">kinnara</div><ul class="ml-4 list-disc"><li class="italic">mi’am ci</li><li class="pt-1"><span class="font-tibetan text-base">མིའམ་ཅི།</span></li><li class="italic">kinnara</li></ul><div class="glossary-instance-definition"><p>A class of nonhuman beings that resemble humans to the degree that their very name‍—which means “is that human?”‍—suggests some confusion as to their divine status. Kinnaras are mythological beings found in both Buddhist and Brahmanical literature, where they are portrayed as creatures half human, half animal. They are often depicted as highly skilled celestial musicians.</p></div></div></div></div><div id="50940bab-2272-4591-b517-26769cb76c2e" class="relative scroll-mt-20"><button type="button" id="radix-_R_55d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.149</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">knowledge and vision of liberation</div><ul class="ml-4 list-disc"><li class="italic">rnam par grol ba’i ye shes mthong ba</li><li class="pt-1"><span class="font-tibetan text-base">རྣམ་པར་གྲོལ་བའི་ཡེ་ཤེས་མཐོང་བ།</span></li><li class="italic">vimukti­jñāna­darśana</li></ul></div></div></div><div id="0d6816bf-611c-43a9-86a7-b49753f85aeb" class="relative scroll-mt-20"><button type="button" id="radix-_R_55l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.150</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Krakucchanda</div><ul class="ml-4 list-disc"><li class="italic">log par dad sel, ’khor ba ’jig</li><li class="pt-1"><span class="font-tibetan text-base">འཁོར་བ་འཇིག, ལོག་པར་དད་སེལ།</span></li><li class="italic">krakucchanda</li></ul><div class="glossary-instance-definition"><p class="definition">The first <span data-glossary-id="UT22084-060-005-515">Buddha</span> of the “Good Eon” (<em class="foreign break text-sa" lang="sa-LATN">bhadrakalpa</em>) of one thousand <span data-glossary-id="UT22084-060-005-515">buddhas</span>, our own <span data-glossary-id="UT22084-060-005-794">Śākyamuni</span> having been the fourth, and <span data-glossary-id="UT22084-060-005-743">Maitreya</span> expected to come as the fifth. Also spelled Krakutsanda, Kukutsunda, Kukucchanda. </p></div></div></div></div><div id="88606e19-a9b0-42f3-8c74-d94083dc352c" class="relative scroll-mt-20"><button type="button" id="radix-_R_55t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.151</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Kṣetralaṃkṛta</div><ul class="ml-4 list-disc"><li class="italic">zhing snyoms brgyan</li><li class="pt-1"><span class="font-tibetan text-base">ཞིང་སྙོམས་བརྒྱན།</span></li><li class="italic">kṣetralaṃkṛta</li></ul></div></div></div><div id="05d4dcc1-b553-4d8a-b913-3d42e28773e0" class="relative scroll-mt-20"><button type="button" id="radix-_R_5655anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.152</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Kumārajīva</div><ul class="ml-4 list-disc"><li class="italic">kumārajīva</li></ul><div class="glossary-instance-definition"><p class="definition">Translator of this <span data-glossary-id="UT22084-060-005-670">sūtra</span> into Chinese (344-409).</p></div></div></div></div><div id="f5c6ddf7-a472-4f48-a43d-76a7cf3622b3" class="relative scroll-mt-20"><button type="button" id="radix-_R_56d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.153</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Lakṣaṇa­kūṭa­samatikrānta</div><ul class="ml-4 list-disc"><li class="italic">mtshan brtsegs yang dag ’das</li><li class="pt-1"><span class="font-tibetan text-base">མཚན་བརྩེགས་ཡང་དག་འདས།</span></li><li class="italic">lakṣaṇa­kūṭa­samatikrānta</li></ul></div></div></div><div id="441162aa-6112-465c-96b1-bf951ed9d5a3" class="relative scroll-mt-20"><button type="button" id="radix-_R_56l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.154</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">layman, laymen</div><ul class="ml-4 list-disc"><li class="italic">dge bsnyen</li><li class="pt-1"><span class="font-tibetan text-base">དགེ་བསྙེན།</span></li><li class="italic">upāsaka</li></ul><div class="glossary-instance-definition"><p class="definition">Householders with definite vows that set them off from the ordinary householder.</p></div></div></div></div><div id="1be70e05-dcfa-40d3-b155-2c8cceb5a63f" class="relative scroll-mt-20"><button type="button" id="radix-_R_56t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.155</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">laywoman, laywomen</div><ul class="ml-4 list-disc"><li class="italic">dge bsnyen ma</li><li class="pt-1"><span class="font-tibetan text-base">དགེ་བསྙེན་མ།</span></li><li class="italic">upāsikā</li></ul><div class="glossary-instance-definition"><p class="definition">Householders with definite vows that set them off from the ordinary householder.</p></div></div></div></div><div id="1f6de051-60d0-418f-9255-9634be3f22b8" class="relative scroll-mt-20"><button type="button" id="radix-_R_5755anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.156</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">liberation, nirvāṇa</div><ul class="ml-4 list-disc"><li class="italic">mya ngan las ’das pa, mya ngan las ’das pa, rnam par grol ba, rnam par thar pa</li><li class="pt-1"><span class="font-tibetan text-base">མྱ་ངན་ལས་འདས་པ།, མྱ་ངན་ལས་འདས་པ།, རྣམ་པར་གྲོལ་བ།, རྣམ་པར་ཐར་པ།</span></li><li class="italic">nirvāṇa, nirvāṇa, vimokṣa, vimukti</li></ul><div class="glossary-instance-definition"><p class="definition">In Sanskrit, the term <em class="foreign break text-sa" lang="sa-LATN">nirvāṇa</em> literally means “extinguishment” and the Tibetan <em class="foreign text-wy" lang="bo-LATN">mya ngan las ’das pa</em> literally means “gone beyond sorrow.” As a general term, it refers to the cessation of all suffering, afflicted mental states (<em class="foreign break text-sa" lang="sa-LATN">kleśa</em>), and causal processes (<em class="foreign break text-sa" lang="sa-LATN">karman</em>) that lead to rebirth and suffering in cyclic existence, as well as to the state in which all such rebirth and suffering has permanently ceased.</p><p class="definition">More specifically, three main types of nirvāṇa are identified. (1) The first type of nirvāṇa, called nirvāṇa with remainder (<em class="foreign break text-sa" lang="sa-LATN">sopadhiśeṣanirvāṇa</em>), is the state in which arhats or buddhas have attained awakening but are still dependent on the conditioned aggregates until their lifespan is exhausted. (2) At the end of life, given that there are no more causes for rebirth, these aggregates cease and no new aggregates arise. What occurs then is called nirvāṇa without remainder (<em class="foreign break text-sa" lang="sa-LATN"> anupadhiśeṣanirvāṇa</em>), which refers to the unconditioned element (<em class="foreign break text-sa" lang="sa-LATN">dhātu</em>) of nirvāṇa in which there is no remainder of the aggregates. (3) The Mahāyāna teachings distinguish the final nirvāṇa of buddhas from that of arhats, the nirvāṇa of arhats not being considered ultimate. The buddhas attain what is called nonabiding nirvāṇa (<em class="foreign break text-sa" lang="sa-LATN">apratiṣṭhitanirvāṇa</em>), which transcends the extremes of saṃsāra and nirvāṇa, i.e., existence and peace. This is the nirvāṇa that is the goal of the Mahāyāna path.</p></div></div></div></div><div id="bc870b0a-74dc-452b-ab38-74618df3c1c1" class="relative scroll-mt-20"><button type="button" id="radix-_R_57d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.157</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">liberation, nirvāṇa</div><ul class="ml-4 list-disc"><li class="italic">mya ngan las ’das pa, mya ngan las ’das pa, rnam par grol ba, rnam par thar pa</li><li class="pt-1"><span class="font-tibetan text-base">མྱ་ངན་ལས་འདས་པ།, མྱ་ངན་ལས་འདས་པ།, རྣམ་པར་གྲོལ་བ།, རྣམ་པར་ཐར་པ།</span></li><li class="italic">nirvāṇa, nirvāṇa, vimokṣa, vimukti</li></ul><div class="glossary-instance-definition"><p class="definition">Final <span data-glossary-id="UT22084-060-005-597">liberation</span> from suffering. In the Hinayāna it is believed attainable by turning away from the world of living beings and transcending all <span data-glossary-id="UT22084-060-005-501">afflictions</span> and selfishnesses through meditative trances. In the <span data-glossary-id="UT22084-060-005-605">Mahāyāna</span>, it is believed attainable only by the attainment of buddhahood, the nondual realization of the indivisibility of <span data-glossary-id="UT22084-060-005-600">life</span> and <span data-glossary-id="UT22084-060-005-597">liberation</span>, and the all-powerful compassion that establishes all living beings simultaneously in their own <span data-glossary-id="UT22084-060-005-597">liberations</span>.</p></div></div></div></div><div id="7c541c84-ac9d-49ce-92dc-9b1f6912648d" class="relative scroll-mt-20"><button type="button" id="radix-_R_57l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.158</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">liberative art</div><ul class="ml-4 list-disc"><li class="italic">thabs</li><li class="pt-1"><span class="font-tibetan text-base">ཐབས།</span></li><li class="italic">upāya</li></ul><div class="glossary-instance-definition"><p class="definition">This is the expression in action of the <span data-glossary-id="UT22084-060-005-574">great compassion</span> of the <span data-glossary-id="UT22084-060-005-515">Buddha</span> and the <span data-glossary-id="UT22084-060-005-513">bodhisattvas</span>‍—physical, verbal, and mental. It follows that one empathetically aware of the troubles of living beings would, for his very survival, devise the most potent and efficacious techniques possible to remove those troubles, and the troubles of living beings are removed effectively only when they reach <span data-glossary-id="UT22084-060-005-597">liberation</span>. “Art” was chosen over the usual “method” and “means” because it has a stronger connotation of efficacy in our technological world; also, in Buddhism, <span class="ignore">liberative art</span> is identified with the extreme of power, energy, and efficacy, as symbolized in the <em class="foreign break text-sa" lang="sa-LATN">vajra</em> (adamantine scepter): The importance of this term is highlighted in this <span data-glossary-id="UT22084-060-005-670">sūtra</span> by the fact that <span data-glossary-id="UT22084-060-005-1257">Vimalakīrti</span> himself is introduced in the chapter entitled “Inconceivable Skill in <span class="ignore">Liberative Art</span>”; this indicates that he, as a function of the <em class="foreign break text-sa" lang="sa-LATN">nirmāṇakāya</em> (<span data-glossary-id="UT22084-060-005-583">incarnation-body</span>), just like the <span data-glossary-id="UT22084-060-005-515">Buddha</span> himself, is the very <span data-glossary-id="UT22084-060-005-582">incarnation</span> of <span class="ignore">liberative art</span>, and every act of his <span class="ignore">life</span> is therefore a technique for the development and <span data-glossary-id="UT22084-060-005-597">liberation</span> of living beings. The “liberative” part of the translation follows “<em class="foreign">salvifique</em>” in Lamotte’s phrase “<em class="foreign">moyens salvifique</em>.” </p></div></div></div></div><div id="33770a73-e8ab-4ffb-9409-eb25bda5915d" class="relative scroll-mt-20"><button type="button" id="radix-_R_57t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.159</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Licchavi</div><ul class="ml-4 list-disc"><li class="italic">lid tsa bI</li><li class="pt-1"><span class="font-tibetan text-base">ལིད་ཙ་བཱི།</span></li><li class="italic">licchavi</li></ul><div class="glossary-instance-definition"><p class="definition">Name of the tribe and republican city-state whose capital was <span data-glossary-id="UT22084-060-005-848">Vaiśālī</span>, where <span data-glossary-id="UT22084-060-005-1257">Vimalakīrti</span> lived, and the main events of this <span data-glossary-id="UT22084-060-005-670">sūtra</span> take place.</p></div></div></div></div><div id="6ecd17e0-5b7b-4765-a71a-c82d4fd5942c" class="relative scroll-mt-20"><button type="button" id="radix-_R_5855anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.160</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">life, saṃsāra</div><ul class="ml-4 list-disc"><li class="italic">’khor ba, ’khor ba</li><li class="pt-1"><span class="font-tibetan text-base">འཁོར་བ།, འཁོར་བ།</span></li><li class="italic">saṃsāra, saṃsāra</li></ul><div class="glossary-instance-definition"><p class="definition">A state of involuntary existence conditioned by afflicted mental states and the imprint of past actions, characterized by suffering in a cycle of life, death, and rebirth. On its reversal, the contrasting state of nirvāṇa is attained, free from suffering and the processes of rebirth.</p></div></div></div></div><div id="6624d772-b0ed-4408-8bb0-479551664ed3" class="relative scroll-mt-20"><button type="button" id="radix-_R_58d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.161</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">life, saṃsāra</div><ul class="ml-4 list-disc"><li class="italic">’khor ba, ’khor ba</li><li class="pt-1"><span class="font-tibetan text-base">འཁོར་བ།, འཁོར་བ།</span></li><li class="italic">saṃsāra, saṃsāra</li></ul><div class="glossary-instance-definition"><p class="definition">The cycle of birth and death; that is, <span class="ignore">life</span> as experienced by living beings under the influence of ignorance, not any sort of objective world external to the persons experiencing it.</p></div></div></div></div><div id="f0a62e12-3b21-4023-b034-45ee86fb1e48" class="relative scroll-mt-20"><button type="button" id="radix-_R_58l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.162</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Lokapāla</div><ul class="ml-4 list-disc"><li class="italic">’jig rten skyong</li><li class="pt-1"><span class="font-tibetan text-base">འཇིག་རྟེན་སྐྱོང་།</span></li><li class="italic">lokapāla</li></ul><div class="glossary-instance-definition"><p class="definition">Lit. “World-Protectors.” They are the same as the four Mahārājas, the great kings of the quarters (<em class="foreign text-wy" lang="bo-LATN">rgyal chen bzhi</em>), namely, Vaiśravaṇa, Dhṛtarāṣṭra, Virūḍhaka, and Virūpākṣa, whose mission is to report on the activities of mankind to the gods of the <span data-glossary-id="UT22084-060-005-846">Trāyastriṃśa</span> heaven and who have pledged to protect the practitioners of the <span data-glossary-id="UT22084-060-005-537">Dharma</span>. Each universe has its own set of four. </p></div></div></div></div><div id="41c623b8-3d94-4f8e-b2c5-1d7a5f5af6d3" class="relative scroll-mt-20"><button type="button" id="radix-_R_58t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.163</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">lord</div><ul class="ml-4 list-disc"><li class="italic">bcom ldan ’das</li><li class="pt-1"><span class="font-tibetan text-base">བཅོམ་ལྡན་འདས།</span></li><li class="italic">bhagavān</li></ul><div class="glossary-instance-definition"><p class="definition">“<span class="ignore">Lord</span>” is chosen to translate the title <em class="foreign break text-sa" lang="sa-LATN">Bhagavān</em> because it is the term of greatest respect current in our “sacred” language, as established for the Deity in the Elizabethan version of the Bible. Indeed, the Skt. <em class="foreign break text-sa" lang="sa-LATN">Bhagavān</em> was given as a title to the <span data-glossary-id="UT22084-060-005-515">Buddha</span>, although it also served the non-Buddhist Indians of the day and, subsequently, it served as an honorific title of their particular deities. As the <span data-glossary-id="UT22084-060-005-515">Buddha</span> is clearly described in the <span data-glossary-id="UT22084-060-005-670">sūtras</span> as the “Supreme Teacher of Gods and Men,” there seems little danger that he may be confused with any particular deity through the use of this term [as indeed in Buddhist <span data-glossary-id="UT22084-060-005-670">sūtras</span> various deities, creators, protectors, etc., are shown in their respective roles]. Thus I feel it would compromise the weight and function of the original <em class="foreign break text-sa" lang="sa-LATN">Bhagavān</em> to use any less weighty term than “<span class="ignore">Lord</span>” for the <span data-glossary-id="UT22084-060-005-515">Buddha</span>. </p></div></div></div></div><div id="cee798d3-8290-4ca3-b78b-795ba0b125be" class="relative scroll-mt-20"><button type="button" id="radix-_R_5955anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.164</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Madhyamaka</div><ul class="ml-4 list-disc"><li class="italic">dbu ma</li><li class="pt-1"><span class="font-tibetan text-base">དབུ་མ།</span></li><li class="italic">madhyamaka</li></ul><div class="glossary-instance-definition"><p class="definition">Teaching of the Middle Way.</p></div></div></div></div><div id="08688fff-c9ad-4aaa-83ac-1792ad208fff" class="relative scroll-mt-20"><button type="button" id="radix-_R_59d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.165</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mādhyamika</div><ul class="ml-4 list-disc"><li class="italic">dbu ma pa</li><li class="pt-1"><span class="font-tibetan text-base">དབུ་མ་པ།</span></li><li class="italic">mādhyamika</li></ul><div class="glossary-instance-definition"><p class="definition">School based on <span data-glossary-id="UT22084-060-005-602">Madhyamaka</span>, and followers of that school.</p></div></div></div></div><div id="fec9b0f0-a7bd-48c3-8fd3-95b18ee7a432" class="relative scroll-mt-20"><button type="button" id="radix-_R_59l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.166</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Madhyānta­vibhāga</div><ul class="ml-4 list-disc"><li class="italic">dbus mtha’ rnam ’byed</li><li class="pt-1"><span class="font-tibetan text-base">དབུས་མཐའ་རྣམ་འབྱེད།</span></li><li class="italic">madhyānta­vibhāga</li></ul><div class="glossary-instance-definition"><p class="definition">The “Analysis of the Middle and the Extremes,” it is an important work of <span data-glossary-id="UT22084-060-005-687">Vijñānavāda</span> philosophy, said to have been received as a revelation from the future <span data-glossary-id="UT22084-060-005-515">Buddha</span> <span data-glossary-id="UT22084-060-005-743">Maitreya</span> by the great scholar and saint, <span data-glossary-id="UT22084-060-005-705">Āryāsaṅga</span>, after twelve years of <span data-glossary-id="UT22084-060-005-612">meditation</span>.</p></div></div></div></div><div id="c986791c-8e80-4bb5-accc-0bf93b6d6eea" class="relative scroll-mt-20"><button type="button" id="radix-_R_59t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.167</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahācakravāḍa</div><ul class="ml-4 list-disc"><li class="italic">khor yug chen po</li><li class="pt-1"><span class="font-tibetan text-base">ཁོར་ཡུག་ཆེན་པོ།</span></li><li class="italic">mahācakravāḍa</li></ul><div class="glossary-instance-definition"><p class="definition">A mountain, or sometimes a range of mountains.</p></div></div></div></div><div id="cf40c4ec-f71c-47c7-bd39-47de5e6850b9" class="relative scroll-mt-20"><button type="button" id="radix-_R_5a55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.168</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahākāśyapa</div><ul class="ml-4 list-disc"><li class="italic">’od srung chen po</li><li class="pt-1"><span class="font-tibetan text-base">འོད་སྲུང་ཆེན་པོ།</span></li><li class="italic">mahākāśyapa</li></ul><div class="glossary-instance-definition"><p class="definition">Foremost disciple of the <span data-glossary-id="UT22084-060-005-515">Buddha</span>; he inherited the leadership of the <span data-glossary-id="UT22084-060-005-646">saṅgha</span> after the <span data-glossary-id="UT22084-060-005-629">Parinirvāṇa</span>. See also <a href="end-notes.xhtml#UT22084-060-005-924" data-pointer-type="id">n.62</a>.</p></div></div></div></div><div id="5ba4353e-ee45-4137-8e61-ebf953ac0dbc" class="relative scroll-mt-20"><button type="button" id="radix-_R_5ad5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.169</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahā­maudgalyāyana, Maudgalyāyana</div><ul class="ml-4 list-disc"><li class="italic">maud gal gyi bu, maud gal gyi bu chen po</li><li class="pt-1"><span class="font-tibetan text-base">མཽད་གལ་གྱི་བུ་ཆེན་པོ།, མཽད་གལ་གྱི་བུ།</span></li><li class="italic">mahā­maudgalyāyana, maudgalyāyana</li></ul><div class="glossary-instance-definition"><p class="definition">One of the chief <span data-glossary-id="UT22084-060-005-661">śrāvakas</span>, paired with <span data-glossary-id="UT22084-060-005-801">Śāriputra</span>.</p></div></div></div></div><div id="8ae3a0a1-180a-4fc8-910a-cc2134148828" class="relative scroll-mt-20"><button type="button" id="radix-_R_5al5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.170</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahā­maudgalyāyana, Maudgalyāyana</div><ul class="ml-4 list-disc"><li class="italic">maud gal gyi bu, maud gal gyi bu chen po</li><li class="pt-1"><span class="font-tibetan text-base">མཽད་གལ་གྱི་བུ་ཆེན་པོ།, མཽད་གལ་གྱི་བུ།</span></li><li class="italic">mahā­maudgalyāyana, maudgalyāyana</li></ul><div class="glossary-instance-definition"><p class="definition">One of the chief <span data-glossary-id="UT22084-060-005-661">śrāvakas</span>, paired with <span data-glossary-id="UT22084-060-005-801">Śāriputra</span>. See also <a href="end-notes.xhtml#UT22084-060-005-919" data-pointer-type="id">n.57</a>.</p></div></div></div></div><div id="11d13f8e-9250-4a7b-a90c-93d692627ecd" class="relative scroll-mt-20"><button type="button" id="radix-_R_5at5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.171</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahāmucilinda</div><ul class="ml-4 list-disc"><li class="italic">ri btang zung chen po</li><li class="pt-1"><span class="font-tibetan text-base">རི་བཏང་ཟུང་ཆེན་པོ།</span></li><li class="italic">mahāmucilinda</li></ul><div class="glossary-instance-definition"><p class="definition">A mountain.</p></div></div></div></div><div id="aa77fe0c-f103-4bce-bb23-2bc3d416ca17" class="relative scroll-mt-20"><button type="button" id="radix-_R_5b55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.172</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">mahāsiddha</div><ul class="ml-4 list-disc"><li class="italic">grub thob chen po</li><li class="pt-1"><span class="font-tibetan text-base">གྲུབ་ཐོབ་ཆེན་པོ།</span></li><li class="italic">mahāsiddha</li></ul><div class="glossary-instance-definition"><p class="definition">A “Great Sorcerer,” a master of the esoteric teachings and practices of <span data-glossary-id="UT22084-060-005-605">Mahāyāna</span> Buddhism. </p></div></div></div></div><div id="7a41b934-c990-46f8-9b38-feb9f548a2f9" class="relative scroll-mt-20"><button type="button" id="radix-_R_5bd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.173</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahā­sthāma­prāpta</div><ul class="ml-4 list-disc"><li class="italic">mthu chen thob</li><li class="pt-1"><span class="font-tibetan text-base">མཐུ་ཆེན་ཐོབ།</span></li><li class="italic">mahā­sthāma­prāpta</li></ul></div></div></div><div id="f843905e-7c06-4b89-b2c9-db7c54da8fe4" class="relative scroll-mt-20"><button type="button" id="radix-_R_5bl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.174</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahāvyūha</div><ul class="ml-4 list-disc"><li class="italic">bkod pa chen po</li><li class="pt-1"><span class="font-tibetan text-base">བཀོད་པ་ཆེན་པོ།</span></li><li class="italic">mahāvyūha</li></ul><div class="glossary-instance-definition"><p class="definition">The name of one of the <span data-glossary-id="UT22084-060-005-513">bodhisattvas</span> in the assembly in Chap. 1. </p></div></div></div></div><div id="1f3c1c4a-c0ad-4892-8575-0f2004bce7ec" class="relative scroll-mt-20"><button type="button" id="radix-_R_5bt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.175</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahāvyūha</div><ul class="ml-4 list-disc"><li class="italic">cher bkod pa</li><li class="pt-1"><span class="font-tibetan text-base">ཆེར་བཀོད་པ།</span></li><li class="italic">mahāvyūha</li></ul><div class="glossary-instance-definition"><p class="definition">The name of the universe in the distant past where the <span data-glossary-id="UT22084-060-005-515">Buddha</span> <span data-glossary-id="UT22084-060-005-708">Bhaiṣajyarāja</span> presided, and taught the prince Chandracchattra about the <span data-glossary-id="UT22084-060-005-537">Dharma</span>-worship (in the Epilogue).</p></div></div></div></div><div id="99607e52-e246-4905-b531-6e6d7ccfd7b7" class="relative scroll-mt-20"><button type="button" id="radix-_R_5c55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.176</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mahāyāna</div><ul class="ml-4 list-disc"><li class="italic">theg pa chen po</li><li class="pt-1"><span class="font-tibetan text-base">ཐེག་པ་ཆེན་པོ།</span></li><li class="italic">mahāyāna</li></ul><div class="glossary-instance-definition"><p class="definition">The “Great Vehicle” of Buddhism, called “great” because it carries all living beings to <span data-glossary-id="UT22084-060-005-551">enlightenment</span> of Buddhahood. It is distinguished from the Hinayāna, including the Śrāvāka­yāna (<span data-glossary-id="UT22084-060-005-661">Śrāvaka</span> Vehicle) and Pratyeka­buddha­yāna (Solitary Sage Vehicle), which only carries each person who rides on it to their own personal <span data-glossary-id="UT22084-060-005-597">liberation</span>.</p></div></div></div></div><div id="afacafea-c9ae-4ff3-8784-b2ac7da446e6" class="relative scroll-mt-20"><button type="button" id="radix-_R_5cd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.177</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">mahoraga</div><ul class="ml-4 list-disc"><li class="italic">lto ’phye chen po</li><li class="pt-1"><span class="font-tibetan text-base">ལྟོ་འཕྱེ་ཆེན་པོ།</span></li><li class="italic">mahoraga</li></ul><div class="glossary-instance-definition"><p>Literally “great serpents,” mahoragas are supernatural beings depicted as large, subterranean beings with human torsos and heads and the lower bodies of serpents. Their movements are said to cause earthquakes, and they make up a class of subterranean geomantic spirits whose movement through the seasons and months of the year is deemed significant for construction projects.</p></div></div></div></div><div id="7067dbc9-9833-4f0d-880c-f1b6f821805f" class="relative scroll-mt-20"><button type="button" id="radix-_R_5cl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.178</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Maitreya</div><ul class="ml-4 list-disc"><li class="italic">byams pa</li><li class="pt-1"><span class="font-tibetan text-base">བྱམས་པ།</span></li><li class="italic">maitreya</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-060-005-513">bodhisattva</span> present throughout the <span data-glossary-id="UT22084-060-005-670">sūtra</span>, prophesied as one birth away from buddhahood and designated by <span data-glossary-id="UT22084-060-005-794">Śākyamuni</span> as the next <span data-glossary-id="UT22084-060-005-515">buddha</span> in the succession of one thousand <span data-glossary-id="UT22084-060-005-515">buddhas</span> of our era. According to tradition, he resides in the <span data-glossary-id="UT22084-060-005-847">Tuṣita</span> heaven preparing for his descent to earth at the appropriate time which, according to Buddhist belief, will occur in 4456 A.D.</p></div></div></div></div><div id="2d4e790b-515d-40b2-8fdc-9bd015b184fd" class="relative scroll-mt-20"><button type="button" id="radix-_R_5ct5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.179</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">maṇḍala</div><ul class="ml-4 list-disc"><li class="italic">dkyil ’khor</li><li class="pt-1"><span class="font-tibetan text-base">དཀྱིལ་འཁོར།</span></li><li class="italic">maṇḍala</li></ul><div class="glossary-instance-definition"><p class="definition">A mystic diagram, usually consisting of a square within a circle, used to define a sacred space in the context of esoteric rituals of initiation and consecration preliminary to certain advanced meditational practices. </p></div></div></div></div><div id="a0c3f76c-3679-4d42-ae49-b849d336ffc0" class="relative scroll-mt-20"><button type="button" id="radix-_R_5d55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.180</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Maṇicūḍa</div><ul class="ml-4 list-disc"><li class="italic">gtsug na nor bu</li><li class="pt-1"><span class="font-tibetan text-base">གཙུག་ན་ནོར་བུ།</span></li><li class="italic">maṇicūḍa</li></ul></div></div></div><div id="996d4bd5-bea2-4d8b-92a3-638bd7ff13d1" class="relative scroll-mt-20"><button type="button" id="radix-_R_5dd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.181</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Maṇi­ratnacchattra</div><ul class="ml-4 list-disc"><li class="italic">nor bu rin chen gdugs</li><li class="pt-1"><span class="font-tibetan text-base">ནོར་བུ་རིན་ཆེན་གདུགས།</span></li><li class="italic">maṇi­ratnacchattra</li></ul></div></div></div><div id="10b56931-f8ef-48df-9532-76c888687d0f" class="relative scroll-mt-20"><button type="button" id="radix-_R_5dl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.182</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mañjuśrī, Mañjuśrī, the crown prince, Mañjuśrī­kumāra­bhūta, crown prince Mañjuśrī, crown, prince Mañjuśrī</div><ul class="ml-4 list-disc"><li class="italic">’jam dpal, ’jam dpal gzhon nur gyur pa</li><li class="pt-1"><span class="font-tibetan text-base">འཇམ་དཔལ་གཞོན་ནུར་གྱུར་པ།, འཇམ་དཔལ།</span></li><li class="italic">mañjuśrī, mañjuśrī­kumāra­bhūta</li></ul><div class="glossary-instance-definition"><p class="definition">The eternally youthful crown prince (<em class="foreign break text-sa" lang="sa-LATN">kumārabhūta</em>), so called because of his special identification with the <em class="foreign break text-sa" lang="sa-LATN"><span data-glossary-id="UT22084-060-005-633">Prajñā­pāramitā</span></em>, or Transcendence of <span data-glossary-id="UT22084-060-005-691">Wisdom</span>. He is the only member of the <span data-glossary-id="UT22084-060-005-515">Buddha</span>’s retinue who volunteers to visit <span data-glossary-id="UT22084-060-005-1257">Vimalakīrti</span>, and he serves as <span data-glossary-id="UT22084-060-005-1257">Vimalakīrti</span>’s principal interlocutor throughout the <span data-glossary-id="UT22084-060-005-670">sūtra</span>. Traditionally regarded as the wisest of <span data-glossary-id="UT22084-060-005-513">bodhisattvas</span>, in Tibetan tradition he is known as <em class="foreign text-wy" lang="bo-LATN">rgyal ba’i yab gcig</em>, the “sole father of <span data-glossary-id="UT22084-060-005-515">buddhas</span>,” as he inspires them in their realization of the profound. He is represented as bearing the sword of <span data-glossary-id="UT22084-060-005-691">wisdom</span> in his right hand and a volume of the <cite class="title break text-sa" lang="sa-LATN"><span data-glossary-id="UT22084-060-005-853">Prajñā­pāramitā­sūtra</span></cite> in his left. He is always youthful in appearance, like a boy of sixteen. </p></div></div></div></div><div id="dc91f42f-fab1-4b12-8cc4-98af048dd264" class="relative scroll-mt-20"><button type="button" id="radix-_R_5dt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.183</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Māra</div><ul class="ml-4 list-disc"><li class="italic">bdud</li><li class="pt-1"><span class="font-tibetan text-base">བདུད།</span></li><li class="italic">māra</li></ul><div class="glossary-instance-definition"><p class="definition">The devil, or evil one, who leads the forces of the gods of the desire-world in seeking to tempt and seduce the <span data-glossary-id="UT22084-060-005-515">Buddha</span> and his disciples. But according to <span data-glossary-id="UT22084-060-005-1257">Vimalakīrti</span> he is actually a <span data-glossary-id="UT22084-060-005-513">bodhisattva</span> who dwells in the <span data-glossary-id="UT22084-060-005-586">inconceivable liberation</span> and displays evil activities in order to strengthen and consolidate the <span data-glossary-id="UT22084-060-005-576">high resolve</span> of all <span data-glossary-id="UT22084-060-005-513">bodhisattvas</span>.</p></div></div></div></div><div id="65df5e51-8919-4ab0-9716-5736946a105d" class="relative scroll-mt-20"><button type="button" id="radix-_R_5e55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.184</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mārajit</div><ul class="ml-4 list-disc"><li class="italic">bdud las rgyal</li><li class="pt-1"><span class="font-tibetan text-base">བདུད་ལས་རྒྱལ།</span></li><li class="italic">mārajit</li></ul></div></div></div><div id="d3e5cced-045b-4ac8-bde7-f2624a5c4f3c" class="relative scroll-mt-20"><button type="button" id="radix-_R_5ed5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.185</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mārapramardin</div><ul class="ml-4 list-disc"><li class="italic">bdud ’joms</li><li class="pt-1"><span class="font-tibetan text-base">བདུད་འཇོམས།</span></li><li class="italic">mārapramardin</li></ul></div></div></div><div id="4d53e933-8f0d-442a-8b4a-c787670e6af5" class="relative scroll-mt-20"><button type="button" id="radix-_R_5el5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.186</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Marīci</div><ul class="ml-4 list-disc"><li class="italic">smig rgyu</li><li class="pt-1"><span class="font-tibetan text-base">སྨིག་རྒྱུ།</span></li><li class="italic">marīci</li></ul><div class="glossary-instance-definition"><p class="definition">Universe of the <span data-glossary-id="UT22084-060-005-515">Buddha</span> Duṣprasāhā.</p></div></div></div></div><div id="442da60a-4137-433a-bf88-309e236a17cc" class="relative scroll-mt-20"><button type="button" id="radix-_R_5et5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.187</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Māskārin Gośāli­putra</div><ul class="ml-4 list-disc"><li class="italic">kun tu rgyu gnag lhas kyi bu</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་ཏུ་རྒྱུ་གནག་ལྷས་ཀྱི་བུ།</span></li><li class="italic">māskārin gośāli­putra</li></ul><div class="glossary-instance-definition"><p class="definition">One of the six <span data-glossary-id="UT22084-060-005-627">outsider</span> teachers.</p></div></div></div></div><div id="e4aa5e08-3018-4f5b-87f0-db3fcb4dc9b1" class="relative scroll-mt-20"><button type="button" id="radix-_R_5f55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.188</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">materialism</div><ul class="ml-4 list-disc"><li class="italic">ril por ’dzin pa</li><li class="pt-1"><span class="font-tibetan text-base">རིལ་པོར་འཛིན་པ།</span></li><li class="italic">piṇdagrāha</li></ul><div class="glossary-instance-definition"><p class="definition">The sense, which ordinarily binds us, of the “objective” solidity and physical reality of things.</p></div></div></div></div><div id="e5f7a767-c35a-41f3-8c5d-a7149d7ad6bd" class="relative scroll-mt-20"><button type="button" id="radix-_R_5fd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.189</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">materiality</div><ul class="ml-4 list-disc"><li class="italic">’jig tshogs</li><li class="pt-1"><span class="font-tibetan text-base">འཇིག་ཚོགས།</span></li><li class="italic">satkāya</li></ul><div class="glossary-instance-definition"><p class="definition">Object of egoistic or materialist interest (<em class="foreign break text-sa" lang="sa-LATN">satkāyadṛṣṭi</em>). See “<span data-glossary-id="UT22084-060-005-542">egoistic views</span>.” </p></div></div></div></div><div id="70ce5b43-6da5-4c30-8f26-5499b63c8a0b" class="relative scroll-mt-20"><button type="button" id="radix-_R_5fl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.190</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">matter</div><ul class="ml-4 list-disc"><li class="italic">gzugs</li><li class="pt-1"><span class="font-tibetan text-base">གཟུགས།</span></li><li class="italic">rūpa</li></ul><div class="glossary-instance-definition"><p class="definition">See “<span data-glossary-id="UT22084-060-005-502">aggregate</span>.”</p></div></div></div></div><div id="491d1590-45ab-45e0-98bc-0fd9c9c2aba9" class="relative scroll-mt-20"><button type="button" id="radix-_R_5ft5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.191</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">means of unification</div><ul class="ml-4 list-disc"><li class="italic">bsdu ba’i dngos po</li><li class="pt-1"><span class="font-tibetan text-base">བསྡུ་བའི་དངོས་པོ།</span></li><li class="italic">saṃgrahavastu</li></ul><div class="glossary-instance-definition"><p class="definition">Four ways in which a <span data-glossary-id="UT22084-060-005-513">bodhisattva</span> forms a group of people united by the common aim of practicing the <span data-glossary-id="UT22084-060-005-537">Dharma</span>: giving (<em class="foreign break text-sa" lang="sa-LATN">dāna</em>); pleasant speech (<em class="foreign break text-sa" lang="sa-LATN">priyavaditā</em>); accomplishment of the aims (of others) by teaching <span data-glossary-id="UT22084-060-005-537">Dharma</span> (<em class="foreign break text-sa" lang="sa-LATN">arthacaryā</em>); and consistency of behavior with the teaching (<em class="foreign break text-sa" lang="sa-LATN">samānārthatā</em>). </p></div></div></div></div><div id="99e2183e-c2ce-48c9-b16d-e33a529349a0" class="relative scroll-mt-20"><button type="button" id="radix-_R_5g55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.192</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">mental construction</div><ul class="ml-4 list-disc"><li class="italic">kun tu rtog pa</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་ཏུ་རྟོག་པ།</span></li><li class="italic">kalpanā, vikalpa</li></ul><div class="glossary-instance-definition"><p class="definition">See “<span data-glossary-id="UT22084-060-005-525">conceptualization</span>.”</p></div></div></div></div><div id="5e339443-19eb-4ac1-8ec2-9c364443dd1c" class="relative scroll-mt-20"><button type="button" id="radix-_R_5gd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.193</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">mental quiescence</div><ul class="ml-4 list-disc"><li class="italic">zhi gnas</li><li class="pt-1"><span class="font-tibetan text-base">ཞི་གནས།</span></li><li class="italic">śamatha</li></ul><div class="glossary-instance-definition"><p class="definition">“<span class="ignore">Mental quiescence</span>” is a general term for all types of mind-practice, <span data-glossary-id="UT22084-060-005-612">meditation</span>, <span data-glossary-id="UT22084-060-005-528">contemplation</span>, <span data-glossary-id="UT22084-060-005-521">concentration</span>, etc., that cultivate one-pointedness of mind and lead to a state of peacefulness and freedom from concern with any sort of object. It is paired with “<span data-glossary-id="UT22084-060-005-680">transcendental analysis</span>” or “insight,” which combines the analytic faculty with this one-pointedness to reach high realizations such as the <span data-glossary-id="UT22084-060-005-499">absence of self</span> (see “<span data-glossary-id="UT22084-060-005-680">transcendental analysis</span>”). “<span class="ignore">Mental quiescence</span>” and “<span data-glossary-id="UT22084-060-005-680">transcendental analysis</span>” were coined by E. Obermiller in his invaluable study “Prajṅa Pāramitā Doctrine, as Exposed in the Abhisamayālaṃkāra of <span data-glossary-id="UT22084-060-005-743">Maitreya</span>” (Acta Orientalia, Vol. XI [Heidelberg, 1932], pp. 1-134).</p></div></div></div></div><div id="4b8c7c59-42c6-46be-b5d2-cdf7b004a86c" class="relative scroll-mt-20"><button type="button" id="radix-_R_5gl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.194</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Merudhvaja</div><ul class="ml-4 list-disc"><li class="italic">lhun po’i rgyal mtshan</li><li class="pt-1"><span class="font-tibetan text-base">ལྷུན་པོའི་རྒྱལ་མཚན།</span></li><li class="italic">merudhvaja</li></ul><div class="glossary-instance-definition"><p class="definition"><span data-glossary-id="UT22084-060-005-516">Buddhafield</span> beyond <span data-glossary-id="UT22084-060-005-516">buddhafields</span> as numerous as the sands of thirty-six Ganges rivers, administered by the <span data-glossary-id="UT22084-060-005-515">Buddha</span> <span data-glossary-id="UT22084-060-005-752">Meru­pradīpa­rāja</span>, whence <span data-glossary-id="UT22084-060-005-1257">Vimalakīrti</span> obtains the lion-thrones on which he seats his visitors.</p></div></div></div></div><div id="6dce3601-9a38-46be-a783-5623b83ab4ab" class="relative scroll-mt-20"><button type="button" id="radix-_R_5gt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.195</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Meru­pradīpa­rāja</div><ul class="ml-4 list-disc"><li class="italic">lhun po’i sgron ma’i rgyal po</li><li class="pt-1"><span class="font-tibetan text-base">ལྷུན་པོའི་སྒྲོན་མའི་རྒྱལ་པོ།</span></li><li class="italic">meru­pradīpa­rāja</li></ul><div class="glossary-instance-definition"><p class="definition"><span data-glossary-id="UT22084-060-005-515">Buddha</span> of the universe <span data-glossary-id="UT22084-060-005-838">Merudhvaja</span>.</p></div></div></div></div><div id="324d8870-bad2-4237-a723-c4203312fb79" class="relative scroll-mt-20"><button type="button" id="radix-_R_5h55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.196</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">morality</div><ul class="ml-4 list-disc"><li class="italic">tshul khrims</li><li class="pt-1"><span class="font-tibetan text-base">ཚུལ་ཁྲིམས།</span></li><li class="italic">śīla</li></ul><div class="glossary-instance-definition"><p class="definition">Morally virtuous or disciplined conduct and the abandonment of morally undisciplined conduct of body, speech, and mind. In a general sense, moral discipline is the cause for rebirth in higher, more favorable states, but it is also foundational to Buddhist practice as one of the three trainings (<em class="foreign break text-sa" lang="sa-LATN">triśikṣā</em>) and one of the six perfections of a bodhisattva. Often rendered as “ethics,” “discipline,” and “morality.”</p></div></div></div></div><div id="a5e38a9a-be9b-4e45-b562-c04a91779f15" class="relative scroll-mt-20"><button type="button" id="radix-_R_5hd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.197</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">motivation</div><ul class="ml-4 list-disc"><li class="italic">’du byed</li><li class="pt-1"><span class="font-tibetan text-base">འདུ་བྱེད།</span></li><li class="italic">saṃskāra</li></ul><div class="glossary-instance-definition"><p class="definition">See “<span data-glossary-id="UT22084-060-005-502">aggregate</span>.”</p></div></div></div></div><div id="27b2f5b9-9696-440c-abe8-86c1c3d136b9" class="relative scroll-mt-20"><button type="button" id="radix-_R_5hl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.198</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Mucilinda</div><ul class="ml-4 list-disc"><li class="italic">ri btang bzung</li><li class="pt-1"><span class="font-tibetan text-base">རི་བཏང་བཟུང་།</span></li><li class="italic">mucilinda</li></ul><div class="glossary-instance-definition"><p class="definition">A mountain.</p></div></div></div></div><div id="eb6dcdc0-cf99-4b43-a0f9-a7c27c0b6f71" class="relative scroll-mt-20"><button type="button" id="radix-_R_5ht5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.199</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">nāga</div><ul class="ml-4 list-disc"><li class="italic">klu</li><li class="pt-1"><span class="font-tibetan text-base">ཀླུ།</span></li><li class="italic">nāga</li></ul><div class="glossary-instance-definition"><p class="definition">One of the <span class="ignore">lords</span> of the ocean, appearing as a great, many headed, sea dragon.</p></div></div></div></div><div id="68714aab-998c-4cd0-89e6-90509f6dcc76" class="relative scroll-mt-20"><button type="button" id="radix-_R_5i55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.200</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Nāgārjuna</div><ul class="ml-4 list-disc"><li class="italic">klu sgrub</li><li class="pt-1"><span class="font-tibetan text-base">ཀླུ་སྒྲུབ།</span></li><li class="italic">nāgārjuna</li></ul><div class="glossary-instance-definition"><p class="definition">Saint, scholar, and mystic of Buddhist India from about four hundred years after the <span data-glossary-id="UT22084-060-005-515">Buddha</span>; discoverer of the <span data-glossary-id="UT22084-060-005-605">Mahāyāna</span> <span data-glossary-id="UT22084-060-005-670">sūtras</span> and author of the fundamental <span data-glossary-id="UT22084-060-005-602">Madhyamaka</span> treatise.</p></div></div></div></div><div id="c93e428f-dcab-4e32-8ad0-ccb97241adc5" class="relative scroll-mt-20"><button type="button" id="radix-_R_5id5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.201</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Nārāyaṇa</div><ul class="ml-4 list-disc"><li class="italic">sred med kyi bu</li><li class="pt-1"><span class="font-tibetan text-base">སྲེད་མེད་ཀྱི་བུ།</span></li><li class="italic">nārāyaṇa</li></ul><div class="glossary-instance-definition"><p class="definition">In Indian lore, <span data-glossary-id="UT22084-060-005-582">incarnation</span> of Viṣṇu, whose strength was legendary (see <cite class="title break text-sa" lang="sa-LATN"><span data-glossary-id="UT22084-060-005-849">Abhi­dharma­kośa</span></cite> VII, pp. 72-74). </p></div></div></div></div><div id="25edb04b-2e74-4313-816c-fd6ad8af9800" class="relative scroll-mt-20"><button type="button" id="radix-_R_5il5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.202</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">narrow-minded attitude</div><ul class="ml-4 list-disc"><li class="italic">nyi tshe ba’i spyod pa</li><li class="pt-1"><span class="font-tibetan text-base">ཉི་ཚེ་བའི་སྤྱོད་པ།</span></li><li class="italic">pradeśakārin</li></ul><div class="glossary-instance-definition"><p class="definition">This term refers to the restricted, biased, <span class="ignore">narrow-minded attitudes</span> and practices of the <span data-glossary-id="UT22084-060-005-662">Disciple Vehicle</span>, which itself is called Skt. <em class="foreign break text-sa" lang="sa-LATN">prādeśikāyāna</em> (“limited, or narrow-minded, vehicle”) (Mvy, 1254). It is <span class="ignore">narrow-minded</span> because it posits the reality of the <span data-glossary-id="UT22084-060-005-548">elements</span> of existence as apparently perceived and because it aspires only to personal <span data-glossary-id="UT22084-060-005-597">liberation</span>, not to the exaltation of buddhahood. </p></div></div></div></div><div id="98c3a819-3960-4bb9-8f58-7eae9460a866" class="relative scroll-mt-20"><button type="button" id="radix-_R_5it5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.203</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">narrow-minded teachings</div><ul class="ml-4 list-disc"><li class="italic">nyi tshe ba’i chos</li><li class="pt-1"><span class="font-tibetan text-base">ཉི་ཚེ་བའི་ཆོས།</span></li><li class="italic">pradeśika­dharma</li></ul><div class="glossary-instance-definition"><p class="definition">I.e. the teachings of the <span data-glossary-id="UT22084-060-005-662">Disciple Vehicle</span> (<em class="foreign break text-sa" lang="sa-LATN"><span data-glossary-id="UT22084-060-005-662">śrāvakayāna</span></em>). See “<span data-glossary-id="UT22084-060-005-618">narrow-minded attitudes</span>.”</p></div></div></div></div><div id="da113d8a-755f-4f94-a385-5870d5914e38" class="relative scroll-mt-20"><button type="button" id="radix-_R_5j55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.204</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">nine causes of irritation</div><ul class="ml-4 list-disc"><li class="italic">kun nas mnar gsems kyi dngos po dgu</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་ནས་མནར་གསེམས་ཀྱི་དངོས་པོ་དགུ</span></li><li class="italic">āghātavastu</li></ul><div class="glossary-instance-definition"><p class="definition">These consist of various mental distractions caused by the nine considerations “He has caused, causes, will cause wrong to me. He has caused, causes, will cause wrong to one dear to me. He has served, serves, will serve my enemies.”</p></div></div></div></div><div id="6e69d4d1-3c64-4054-b80b-f68df19c83e8" class="relative scroll-mt-20"><button type="button" id="radix-_R_5jd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.205</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Nirgrantha Jñāti­putra</div><ul class="ml-4 list-disc"><li class="italic">gcer bu gnyen gyi bu</li><li class="pt-1"><span class="font-tibetan text-base">གཅེར་བུ་གཉེན་གྱི་བུ།</span></li><li class="italic">nirgrantha jñāti­putra</li></ul><div class="glossary-instance-definition"><p class="definition">One of the six <span data-glossary-id="UT22084-060-005-627">outsider</span> teachers.</p></div></div></div></div><div id="512593ec-b15a-4f3e-af83-c0aa9e355a7b" class="relative scroll-mt-20"><button type="button" id="radix-_R_5jl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.206</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Nitya­prahasita­pramuditendriya</div><ul class="ml-4 list-disc"><li class="italic">rtag tu dga’ dgod dbang po</li><li class="pt-1"><span class="font-tibetan text-base">རྟག་ཏུ་དགའ་དགོད་དབང་པོ།</span></li><li class="italic">nitya­prahasita­pramuditendriya</li></ul></div></div></div><div id="4154a397-b0c4-44d0-8735-f4277fa10fa0" class="relative scroll-mt-20"><button type="button" id="radix-_R_5jt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.207</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Nityotkaṇṭhita</div><ul class="ml-4 list-disc"><li class="italic">rtag tu gdung</li><li class="pt-1"><span class="font-tibetan text-base">རྟག་ཏུ་གདུང་།</span></li><li class="italic">nityotkaṇṭhita</li></ul></div></div></div><div id="422054a4-3e86-4231-a05b-fa865fd6a4af" class="relative scroll-mt-20"><button type="button" id="radix-_R_5k55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.208</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Nityotkṣipta­hasta</div><ul class="ml-4 list-disc"><li class="italic">rtag tu lag brkyang</li><li class="pt-1"><span class="font-tibetan text-base">རྟག་ཏུ་ལག་བརྐྱང་།</span></li><li class="italic">nityotkṣipta­hasta</li></ul></div></div></div><div id="ae745020-8cbf-467e-9578-149274e7551d" class="relative scroll-mt-20"><button type="button" id="radix-_R_5kd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.209</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Nityotpalakṛta­hasta</div><ul class="ml-4 list-disc"><li class="italic">rtag tu lag bteg</li><li class="pt-1"><span class="font-tibetan text-base">རྟག་ཏུ་ལག་བཏེག</span></li><li class="italic">nityotpalakṛta­hasta</li></ul></div></div></div><div id="335e47c2-eb5f-458f-89d8-346e929bc433" class="relative scroll-mt-20"><button type="button" id="radix-_R_5kl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.210</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">noble</div><ul class="ml-4 list-disc"><li class="italic">’phags pa</li><li class="pt-1"><span class="font-tibetan text-base">འཕགས་པ།</span></li><li class="italic">ārya</li></ul><div class="glossary-instance-definition"><p class="definition">‍—</p></div></div></div></div><div id="0f06ed1e-e4b7-40e4-acd7-d58e27e71907" class="relative scroll-mt-20"><button type="button" id="radix-_R_5kt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.211</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">noble disciple</div><ul class="ml-4 list-disc"><li class="italic">’phags pa nyan thos</li><li class="pt-1"><span class="font-tibetan text-base">འཕགས་པ་ཉན་ཐོས།</span></li><li class="italic">āryaśrāvāka</li></ul><div class="glossary-instance-definition"><p class="definition">A practitioner of the <span data-glossary-id="UT22084-060-005-662">Disciple Vehicle</span> teaching who has reached at least the initial stages of realization. </p></div></div></div></div><div id="5bcad558-679e-41c8-a730-6e36945799b6" class="relative scroll-mt-20"><button type="button" id="radix-_R_5l55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.212</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">nonduality</div><ul class="ml-4 list-disc"><li class="italic">gnyis su med pa</li><li class="pt-1"><span class="font-tibetan text-base">གཉིས་སུ་མེད་པ།</span></li><li class="italic">advayatvā</li></ul><div class="glossary-instance-definition"><p class="definition">This is synonymous with reality, <span data-glossary-id="UT22084-060-005-689">voidness</span>, etc. But it must be remembered that <span class="ignore">nonduality</span> does not necessarily mean unity, that unity is only one of the pair unity-duality; hence <span class="ignore">nonduality</span> implies nonunity as well. This point is obscured by designating this nondual philosophy as “monism,” as too many modern scholars have done.</p></div></div></div></div><div id="c35fa257-9bec-472c-a315-46542dc21d4f" class="relative scroll-mt-20"><button type="button" id="radix-_R_5ld5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.213</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">object-perception</div><ul class="ml-4 list-disc"><li class="italic">lhag par dmigs pa</li><li class="pt-1"><span class="font-tibetan text-base">ལྷག་པར་དམིགས་པ།</span></li><li class="italic">adhyālambana</li></ul></div></div></div><div id="97a63228-3505-450d-8da8-b17f2117e156" class="relative scroll-mt-20"><button type="button" id="radix-_R_5ll5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.214</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">omniscience</div><ul class="ml-4 list-disc"><li class="italic">thams cad mkhyen pa</li><li class="pt-1"><span class="font-tibetan text-base">ཐམས་ཅད་མཁྱེན་པ།</span></li><li class="italic">sarvajñatā</li></ul><div class="glossary-instance-definition"><p class="definition">This refers to the <span data-glossary-id="UT22084-060-005-571">gnosis</span> of the <span data-glossary-id="UT22084-060-005-515">Buddha</span>, with which there is nothing he does not know. However, not to confuse “<span class="ignore">omniscience</span>” with the theistic conception of an omniscient god, the “everything” here is specifically everything about the source of the predicament of worldly <span data-glossary-id="UT22084-060-005-600">life</span> and the way of transcendence of that world through <span data-glossary-id="UT22084-060-005-597">liberation</span>. Since “everything” is only an abstract term without any particular referent, once we are clear about the implications of infinity, it does not refer to any sort of <span data-glossary-id="UT22084-060-005-683">ultimate</span> totality, since a totality can only be relative, i.e., a totality within a particular frame of reference. Thus, as Dharmakīrti has remarked, “it is not a question of the <span data-glossary-id="UT22084-060-005-515">Buddha</span>’s knowing the number of fish in the ocean,” i.e., since there are infinity of fish in infinity of oceans in infinity of worlds and universes. The <span data-glossary-id="UT22084-060-005-515">Buddha</span>’s <span class="ignore">omniscience</span>, rather, knows how to develop and liberate any fish in any ocean, as well as all other living beings. </p></div></div></div></div><div id="b121c9a5-7c63-4bc5-be7a-4f7ac29b7113" class="relative scroll-mt-20"><button type="button" id="radix-_R_5lt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.215</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">outsider</div><ul class="ml-4 list-disc"><li class="italic">mu stegs pa</li><li class="pt-1"><span class="font-tibetan text-base">མུ་སྟེགས་པ།</span></li><li class="italic">tīrthika</li></ul><div class="glossary-instance-definition"><p class="definition">Those of other religious or philosophical orders, contemporary with the early Buddhist order, including Jains, Jaṭilas, Ājīvikas, and Cārvākas. Tīrthika (“forder”) literally translates as “one belonging to or associated with (possessive suffix <em class="foreign break text-sa" lang="sa-LATN">–ika</em>) stairs for landing or for descent into a river,” or “a bathing place,” or “a place of pilgrimage on the banks of sacred streams” (Monier-Williams). The term may have originally referred to temple priests at river crossings or fords where travelers propitiated a deity before crossing. The Sanskrit term seems to have undergone metonymic transfer in referring to those able to ford the turbulent river of saṃsāra (as in the Jain tīrthaṅkaras, “ford makers”), and it came to be used in Buddhist sources to refer to teachers of rival religious traditions. The Sanskrit term is closely rendered by the Tibetan <em class="foreign text-wy" lang="bo-LATN">mu stegs pa</em>: “those on the steps (<em class="foreign text-wy" lang="bo-LATN">stegs pa</em>) at the edge (<em class="foreign text-wy" lang="bo-LATN">mu</em>).”</p></div></div></div></div><div id="44254284-9334-4b34-8b2d-6f5cf820de7c" class="relative scroll-mt-20"><button type="button" id="radix-_R_5m55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.216</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Padmaśrī­garbha</div><ul class="ml-4 list-disc"><li class="italic">pad mo’i dpal gyi snying po</li><li class="pt-1"><span class="font-tibetan text-base">པད་མོའི་དཔལ་གྱི་སྙིང་པོ།</span></li><li class="italic">padmaśrī­garbha</li></ul></div></div></div><div id="756c2e26-9432-402a-9082-2ca16ae0d1cb" class="relative scroll-mt-20"><button type="button" id="radix-_R_5md5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.217</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Padmavyūha</div><ul class="ml-4 list-disc"><li class="italic">pad mo bkod pa</li><li class="pt-1"><span class="font-tibetan text-base">པད་མོ་བཀོད་པ།</span></li><li class="italic">padmavyūha</li></ul></div></div></div><div id="b0b04164-1cec-4c95-9c78-54e5889bc61c" class="relative scroll-mt-20"><button type="button" id="radix-_R_5ml5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.218</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Pāli</div><ul class="ml-4 list-disc"></ul><div class="glossary-instance-definition"><p class="definition">The canonical language of Ceylonese Buddhists, believed to be very similar to the colloquial language spoken by <span data-glossary-id="UT22084-060-005-794">Śākyamuni</span> <span data-glossary-id="UT22084-060-005-515">Buddha</span>.</p></div></div></div></div><div id="f3755f91-c27d-4968-894e-14796bd04545" class="relative scroll-mt-20"><button type="button" id="radix-_R_5mt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.219</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">parinirvāṇa</div><ul class="ml-4 list-disc"><li class="italic">yongs su mya ngan las ’das pa</li><li class="pt-1"><span class="font-tibetan text-base">ཡོངས་སུ་མྱ་ངན་ལས་འདས་པ།</span></li><li class="italic">parinirvāṇa</li></ul><div class="glossary-instance-definition"><p class="definition">A more emphatic term for <em class="foreign break text-sa" lang="sa-LATN"><span data-glossary-id="UT22084-060-005-621">nirvāṇa</span></em>, when it is used in reference to the apparent passing away of a physical body of a <span data-glossary-id="UT22084-060-005-515">buddha</span>. </p></div></div></div></div><div id="e2d62fe8-36f7-47bd-9cda-305b2c1b66eb" class="relative scroll-mt-20"><button type="button" id="radix-_R_5n55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.220</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">positive thought</div><ul class="ml-4 list-disc"><li class="italic">bsam pa</li><li class="pt-1"><span class="font-tibetan text-base">བསམ་པ།</span></li><li class="italic">āśaya</li></ul><div class="glossary-instance-definition"><p class="definition">In general, a joyous attitude to help living beings and accomplish virtue. This is also the first stirring in the <span data-glossary-id="UT22084-060-005-513">bodhisattva</span>’s mind of the inspiration to attain <span data-glossary-id="UT22084-060-005-551">enlightenment</span> (see “<span data-glossary-id="UT22084-060-005-576">high resolve</span>”). See Lamotte, Appendice, Note II. </p></div></div></div></div><div id="5564b952-2491-426c-bb6f-96b0b05d818b" class="relative scroll-mt-20"><button type="button" id="radix-_R_5nd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.221</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">power of life</div><ul class="ml-4 list-disc"><li class="italic">srog gi dbang po</li><li class="pt-1"><span class="font-tibetan text-base">སྲོག་གི་དབང་པོ།</span></li><li class="italic">jīvitendriya</li></ul><div class="glossary-instance-definition"><p class="definition">One of the nonmental <span data-glossary-id="UT22084-060-005-616">motivations</span>, defined as the force of <span class="ignore">life</span>-duration, being a concept of the <span data-glossary-id="UT22084-060-005-498">Abhidharma</span>. See T. Stcherbatski, <cite class="title text-en" lang="en">Central Conception of Buddhism</cite> (London, 1923), p. 105. </p></div></div></div></div><div id="cf3a76e9-a92a-4a86-b54c-4af980edd52f" class="relative scroll-mt-20"><button type="button" id="radix-_R_5nl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.222</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Prabhāketu</div><ul class="ml-4 list-disc"><li class="italic">’od kyi tog</li><li class="pt-1"><span class="font-tibetan text-base">འོད་ཀྱི་ཏོག</span></li><li class="italic">prabhāketu</li></ul></div></div></div><div id="8dce1d66-6c81-4cb2-9f01-af3cc8e5b340" class="relative scroll-mt-20"><button type="button" id="radix-_R_5nt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.223</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Prabhāvyūha</div><ul class="ml-4 list-disc"><li class="italic">’od bkod pa</li><li class="pt-1"><span class="font-tibetan text-base">འོད་བཀོད་པ།</span></li><li class="italic">prabhāvyūha</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-060-005-513">bodhisattva</span> present in the opening assembly, who later tells the story of his encounter with <span data-glossary-id="UT22084-060-005-1257">Vimalakīrti</span>, who discourses to him about the <span data-glossary-id="UT22084-060-005-648">seat of enlightenment</span>.</p></div></div></div></div><div id="995806eb-a22d-4ef1-98c4-caa37076459c" class="relative scroll-mt-20"><button type="button" id="radix-_R_5o55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.224</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Prabhūtaratna</div><ul class="ml-4 list-disc"><li class="italic">rin chen mang</li><li class="pt-1"><span class="font-tibetan text-base">རིན་ཆེན་མང་།</span></li><li class="italic">prabhūtaratna</li></ul><div class="glossary-instance-definition"><p class="definition">One of the <span data-glossary-id="UT22084-060-005-515">buddhas</span> who assembled at <span data-glossary-id="UT22084-060-005-1257">Vimalakīrti</span>’s house to teach esoteric practices, according to the goddess (Chap. 7).</p></div></div></div></div><div id="d4e82310-babf-4349-a016-7849f020c922" class="relative scroll-mt-20"><button type="button" id="radix-_R_5od5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.225</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Prajñākūta</div><ul class="ml-4 list-disc"><li class="italic">shes rab brtsegs</li><li class="pt-1"><span class="font-tibetan text-base">ཤེས་རབ་བརྩེགས།</span></li><li class="italic">prajñākūta</li></ul></div></div></div><div id="9766cba6-2a43-4122-9ec8-5c4bd430c239" class="relative scroll-mt-20"><button type="button" id="radix-_R_5ol5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.226</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Prajñā­pāramitā</div><ul class="ml-4 list-disc"><li class="italic">shes rab kyi pha rol tu phyin pa</li><li class="pt-1"><span class="font-tibetan text-base">ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པ།</span></li><li class="italic">prajñā­pāramitā</li></ul><div class="glossary-instance-definition"><p class="definition">Transcendental <span data-glossary-id="UT22084-060-005-691">wisdom</span>, being the profound nondual understanding of the <span data-glossary-id="UT22084-060-005-683">ultimate</span> reality, or <span data-glossary-id="UT22084-060-005-689">voidness</span>, or <span data-glossary-id="UT22084-060-005-640">relativity</span>, of all things; personified as a goddess, she is worshiped as the “Mother of all <span data-glossary-id="UT22084-060-005-515">Buddhas</span>” (<em class="foreign break text-sa" lang="sa-LATN">Sarva­jina­mātā</em>). </p></div></div></div></div><div id="ab4d6b2c-102c-4a30-9c91-c3238504a23e" class="relative scroll-mt-20"><button type="button" id="radix-_R_5ot5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.227</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Prajñā­pāramitā­sūtra</div><ul class="ml-4 list-disc"><li class="italic">shes rab kyi pha rol tu phyin pa’i mdo</li><li class="pt-1"><span class="font-tibetan text-base">ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པའི་མདོ།</span></li><li class="italic">prajñā­pāramitā­sūtra</li></ul><div class="glossary-instance-definition"><p class="definition">The <span data-glossary-id="UT22084-060-005-670">sūtra</span> in which the transcendental <span data-glossary-id="UT22084-060-005-691">wisdom</span> is taught. There are nineteen versions of different lengths, ranging from the <cite class="title text-en" lang="en">Heart Sūtra</cite> of a few pages to the <cite class="title text-en" lang="en">Hundred-Thousand</cite>. A great deal of information about these <span data-glossary-id="UT22084-060-005-670">sūtras</span> can be found in the works of Dr. Edward Conze. </p></div></div></div></div><div id="dfafe214-f0c6-40bc-a862-534f47ad0264" class="relative scroll-mt-20"><button type="button" id="radix-_R_5p55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.228</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Prajñā­pāramitopadeśa</div><ul class="ml-4 list-disc"><li class="italic">prajñā­pāramitopadeśa</li></ul><div class="glossary-instance-definition"><p class="definition"> A commentary on the <cite class="title break text-sa" lang="sa-LATN"><span data-glossary-id="UT22084-060-005-853">Prajñā­pāramitā­sūtras</span></cite>, composed by <span data-glossary-id="UT22084-060-005-734">Kumārajīva</span> from oral traditions derived from <span data-glossary-id="UT22084-060-005-753">Nāgārjuna</span>, and partially translated from Chinese into French by Dr. Etienne Lamotte, as <cite class="title">Traité de la Grande Vertu de la Sagesse</cite>, Louvain, 1944-1949 (Bibliotheque du Museon, 18). </p></div></div></div></div><div id="2bf4aa37-39a8-4e5f-a550-1d7a2011b292" class="relative scroll-mt-20"><button type="button" id="radix-_R_5pd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.229</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Prāmodyarāja</div><ul class="ml-4 list-disc"><li class="italic">mchog tu dga’ ba’i rgyal po</li><li class="pt-1"><span class="font-tibetan text-base">མཆོག་ཏུ་དགའ་བའི་རྒྱལ་པོ།</span></li><li class="italic">prāmodyarāja</li></ul></div></div></div><div id="91735aff-cd3e-4929-9a5b-d3b24dd7e651" class="relative scroll-mt-20"><button type="button" id="radix-_R_5pl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.230</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Praṇidhi­prayāta­prāpta</div><ul class="ml-4 list-disc"><li class="italic">smon lam la zhugs pas phyin pa</li><li class="pt-1"><span class="font-tibetan text-base">སྨོན་ལམ་ལ་ཞུགས་པས་ཕྱིན་པ།</span></li><li class="italic">praṇidhi­prayāta­prāpta</li></ul></div></div></div><div id="9ecd7639-710c-4154-8fc2-9e82f039ba06" class="relative scroll-mt-20"><button type="button" id="radix-_R_5pt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.231</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Prāsaṅgika</div><ul class="ml-4 list-disc"><li class="italic">thal ’gyur ba</li><li class="pt-1"><span class="font-tibetan text-base">ཐལ་འགྱུར་བ།</span></li><li class="italic">prāsaṅgika</li></ul><div class="glossary-instance-definition"><p class="definition">The sub-school of the <span data-glossary-id="UT22084-060-005-603">Mādhyamika</span> philosophical school founded by <span data-glossary-id="UT22084-060-005-515">Buddha</span>-Pālita and further developed by <span data-glossary-id="UT22084-060-005-714">Candrakīrti</span>.</p></div></div></div></div><div id="4a5c106e-cd41-4cc2-a93d-9512253462b6" class="relative scroll-mt-20"><button type="button" id="radix-_R_5q55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.232</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Prasannapadā</div><ul class="ml-4 list-disc"><li class="italic">tshig gsal</li><li class="pt-1"><span class="font-tibetan text-base">ཚིག་གསལ།</span></li><li class="italic">prasannapadā</li></ul><div class="glossary-instance-definition"><p class="definition"><span data-glossary-id="UT22084-060-005-714">Candrakīrti</span>’s major commentary on <span data-glossary-id="UT22084-060-005-753">Nāgārjuna</span>’s <cite class="title text-en" lang="en">Fundamental Stanzas on Wisdom</cite>. </p></div></div></div></div><div id="97646ee8-ea9e-44b7-bb03-e0014921a6ed" class="relative scroll-mt-20"><button type="button" id="radix-_R_5qd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.233</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Pratibhāna­kūṭa</div><ul class="ml-4 list-disc"><li class="italic">spobs pa brtsegs pa</li><li class="pt-1"><span class="font-tibetan text-base">སྤོབས་པ་བརྩེགས་པ།</span></li><li class="italic">pratibhāna­kūṭa</li></ul></div></div></div><div id="d679eb3d-889d-4c44-8432-f9fd73c8d4d8" class="relative scroll-mt-20"><button type="button" id="radix-_R_5ql5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.234</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Prati­saṃvit­praṇāda­prāpta</div><ul class="ml-4 list-disc"><li class="italic">so so yang dag par rig pa rab tu bsgrub pa thob</li><li class="pt-1"><span class="font-tibetan text-base">སོ་སོ་ཡང་དག་པར་རིག་པ་རབ་ཏུ་བསྒྲུབ་པ་ཐོབ།</span></li><li class="italic">prati­saṃvitpraṇāda­prāpta</li></ul></div></div></div><div id="016a95f6-6eed-41e7-a916-3b9098b27158" class="relative scroll-mt-20"><button type="button" id="radix-_R_5qt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.235</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">pratyekabuddha</div><ul class="ml-4 list-disc"><li class="italic">rang sangs rgyas</li><li class="pt-1"><span class="font-tibetan text-base">རང་སངས་རྒྱས།</span></li><li class="italic">pratyekabuddha</li></ul><div class="glossary-instance-definition"><p class="definition">Literally, “buddha for oneself” or “solitary realizer.” Someone who, in his or her last life, attains awakening entirely through their own contemplation, without relying on a teacher. Unlike the awakening of a fully realized buddha (<em class="foreign break text-sa" lang="sa-LATN">samyaksambuddha</em>), the accomplishment of a pratyeka­buddha is not regarded as final or ultimate. They attain realization of the nature of dependent origination, the selflessness of the person, and a partial realization of the selflessness of phenomena, by observing the suchness of all that arises through interdependence. This is the result of progress in previous lives but, unlike a buddha, they do not have the necessary merit, compassion or motivation to teach others. They are named as “rhinoceros-like” (<em class="foreign break text-sa" lang="sa-LATN">khaḍgaviṣāṇakalpa</em>) for their preference for staying in solitude or as “congregators” (<em class="foreign break text-sa" lang="sa-LATN">vargacārin</em>) when their preference is to stay among peers.</p></div></div></div></div><div id="9dc6b0a5-e62b-4272-8089-ad2c7dd4f16c" class="relative scroll-mt-20"><button type="button" id="radix-_R_5r55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.236</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Priyadarśana</div><ul class="ml-4 list-disc"><li class="italic">mthong dga’</li><li class="pt-1"><span class="font-tibetan text-base">མཐོང་དགའ།</span></li><li class="italic">priyadarśana</li></ul></div></div></div><div id="04c383e3-5363-4b5d-bbb1-1e811f55c9e6" class="relative scroll-mt-20"><button type="button" id="radix-_R_5rd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.237</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Purāṇa Kāśyapa</div><ul class="ml-4 list-disc"><li class="italic">’od srung rdzogs byed</li><li class="pt-1"><span class="font-tibetan text-base">འོད་སྲུང་རྫོགས་བྱེད།</span></li><li class="italic">purāṇa kāśyapa</li></ul><div class="glossary-instance-definition"><p class="definition">One of the six <span data-glossary-id="UT22084-060-005-627">outsider</span> teachers.</p></div></div></div></div><div id="a952daa2-b766-4a8f-a19e-633af3c5e6e2" class="relative scroll-mt-20"><button type="button" id="radix-_R_5rl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.238</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Pūrṇa</div><ul class="ml-4 list-disc"><li class="italic">gang po</li><li class="pt-1"><span class="font-tibetan text-base">གང་པོ།</span></li><li class="italic">pūrṇa</li></ul><div class="glossary-instance-definition"><p class="definition"><span data-glossary-id="UT22084-060-005-661">Śrāvaka</span> disciple of the <span data-glossary-id="UT22084-060-005-515">Buddha</span> noted for his ability as a preacher of the Hinayāna teaching, especially skillful in the conversion and training of young monks; also known as <span data-glossary-id="UT22084-060-005-773">Pūrṇa­maitrāyaṇī­putra</span>. See also <a href="end-notes.xhtml#UT22084-060-005-934" data-pointer-type="id">n.72</a>.</p></div></div></div></div><div id="b95c7876-5459-44f6-86d0-2ff03ab2e84d" class="relative scroll-mt-20"><button type="button" id="radix-_R_5rt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.239</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Pūrṇa­maitrāyaṇī­putra</div><ul class="ml-4 list-disc"><li class="italic">byams ma’i bu gang po</li><li class="pt-1"><span class="font-tibetan text-base">བྱམས་མའི་བུ་གང་པོ།</span></li><li class="italic">pūrṇa­maitrāyaṇī­putra</li></ul><div class="glossary-instance-definition"><p class="definition">See <span data-glossary-id="UT22084-060-005-772">Pūrṇa</span>.</p></div></div></div></div><div id="5a2b5afb-3eda-4a81-9892-6c2e79d6fd75" class="relative scroll-mt-20"><button type="button" id="radix-_R_5s55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.240</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Rāhula</div><ul class="ml-4 list-disc"><li class="italic">sgra gcan ’dzin</li><li class="pt-1"><span class="font-tibetan text-base">སྒྲ་གཅན་འཛིན།</span></li><li class="italic">rāhula</li></ul><div class="glossary-instance-definition"><p class="definition"><span data-glossary-id="UT22084-060-005-794">Śākyamuni</span> <span data-glossary-id="UT22084-060-005-515">Buddha</span>’s own son, who became a distinguished disciple. See also <a href="end-notes.xhtml#UT22084-060-005-945" data-pointer-type="id">n.83</a>.</p></div></div></div></div><div id="7989e812-179e-4295-8a13-cbb38e892c88" class="relative scroll-mt-20"><button type="button" id="radix-_R_5sd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.241</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratnacandra</div><ul class="ml-4 list-disc"><li class="italic">dkon mchog zla ba</li><li class="pt-1"><span class="font-tibetan text-base">དཀོན་མཆོག་ཟླ་བ།</span></li><li class="italic">ratnacandra</li></ul><div class="glossary-instance-definition"><p class="definition">One of the <span data-glossary-id="UT22084-060-005-515">buddhas</span> who assembled at <span data-glossary-id="UT22084-060-005-1257">Vimalakīrti</span>’s house to teach the <cite class="title break text-sa" lang="sa-LATN">Tathāgata­guhyaka</cite>, according to the goddess. </p></div></div></div></div><div id="33c0afab-6d36-4aa0-a580-56e19e22fc70" class="relative scroll-mt-20"><button type="button" id="radix-_R_5sl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.242</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratnacchattra</div><ul class="ml-4 list-disc"><li class="italic">rin chen gdugs</li><li class="pt-1"><span class="font-tibetan text-base">རིན་ཆེན་གདུགས།</span></li><li class="italic">ratnacchattra</li></ul><div class="glossary-instance-definition"><p class="definition">Wheel-turning king said by the <span data-glossary-id="UT22084-060-005-515">Buddha</span> to be a former <span data-glossary-id="UT22084-060-005-582">incarnation</span> of the <span data-glossary-id="UT22084-060-005-515">Buddha</span> <span data-glossary-id="UT22084-060-005-783">Ratnārcis</span>.</p></div></div></div></div><div id="d034f7ba-4307-44fe-9832-ed8bfb98b1e8" class="relative scroll-mt-20"><button type="button" id="radix-_R_5st5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.243</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratnajaha</div><ul class="ml-4 list-disc"><li class="italic">rin chen gtong</li><li class="pt-1"><span class="font-tibetan text-base">རིན་ཆེན་གཏོང་།</span></li><li class="italic">ratnajaha</li></ul></div></div></div><div id="2f400df3-fb3c-4bd3-85ce-4b223afd1aad" class="relative scroll-mt-20"><button type="button" id="radix-_R_5t55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.244</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratnākara</div><ul class="ml-4 list-disc"><li class="italic">dkon mchog ’byung gnas</li><li class="pt-1"><span class="font-tibetan text-base">དཀོན་མཆོག་འབྱུང་གནས།</span></li><li class="italic">ratnākara</li></ul><div class="glossary-instance-definition"><p class="definition">Wealthy young <span data-glossary-id="UT22084-060-005-599">Licchavi</span> <span data-glossary-id="UT22084-060-005-505">noble</span> who leads the delegation that brings the precious parasols to the <span data-glossary-id="UT22084-060-005-515">Buddha</span>.</p></div></div></div></div><div id="723816e2-004f-4362-aa21-7cb78f09ac3b" class="relative scroll-mt-20"><button type="button" id="radix-_R_5td5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.245</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratnakūṭa</div><ul class="ml-4 list-disc"><li class="italic">rin po che brtsegs pa</li><li class="pt-1"><span class="font-tibetan text-base">རིན་པོ་ཆེ་བརྩེགས་པ།</span></li><li class="italic">ratnakūṭa</li></ul></div></div></div><div id="c7cfa18a-058f-45d4-af3c-4ce2b8db6f41" class="relative scroll-mt-20"><button type="button" id="radix-_R_5tl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.246</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratna­mudrā­hasta</div><ul class="ml-4 list-disc"><li class="italic">lag na phyag rgya rin po che</li><li class="pt-1"><span class="font-tibetan text-base">ལག་ན་ཕྱག་རྒྱ་རིན་པོ་ཆེ།</span></li><li class="italic">ratna­mudrā­hasta</li></ul></div></div></div><div id="054447fa-19dd-4470-ba6f-bdc20d692e8a" class="relative scroll-mt-20"><button type="button" id="radix-_R_5tt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.247</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratnananda</div><ul class="ml-4 list-disc"><li class="italic">rin chen dga’ ba</li><li class="pt-1"><span class="font-tibetan text-base">རིན་ཆེན་དགའ་བ།</span></li><li class="italic">ratnananda</li></ul></div></div></div><div id="d53315cb-70f2-4ec6-8745-465e59be364f" class="relative scroll-mt-20"><button type="button" id="radix-_R_5u55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.248</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratnapāṇi</div><ul class="ml-4 list-disc"><li class="italic">lag na rin po che</li><li class="pt-1"><span class="font-tibetan text-base">ལག་ན་རིན་པོ་ཆེ།</span></li><li class="italic">ratnapāṇi</li></ul></div></div></div><div id="ff9b0a9a-22be-42d1-99c5-b4079b71a5c0" class="relative scroll-mt-20"><button type="button" id="radix-_R_5ud5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.249</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratnaparvata</div><ul class="ml-4 list-disc"><li class="italic">rin po che’i ri</li><li class="pt-1"><span class="font-tibetan text-base">རིན་པོ་ཆེའི་རི།</span></li><li class="italic">ratnaparvata</li></ul><div class="glossary-instance-definition"><p class="definition">A mountain.</p></div></div></div></div><div id="83e05c6d-d7a0-4aba-b09f-19b2f23c3bcf" class="relative scroll-mt-20"><button type="button" id="radix-_R_5ul5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.250</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratnārcis</div><ul class="ml-4 list-disc"><li class="italic">dkon mchog ’od ’phro</li><li class="pt-1"><span class="font-tibetan text-base">དཀོན་མཆོག་འོད་འཕྲོ།</span></li><li class="italic">ratnārcis</li></ul><div class="glossary-instance-definition"><p class="definition">One of the <span data-glossary-id="UT22084-060-005-515">buddhas</span> who appear in the house of <span data-glossary-id="UT22084-060-005-1257">Vimalakīrti</span> on esoteric occasions. According to the <span data-glossary-id="UT22084-060-005-633">Prajñā­pāramitā</span>, he is the <span data-glossary-id="UT22084-060-005-515">Buddha</span> of the universe Upaśānta, in the western direction (see Lamotte, p. 384, n. 27).</p></div></div></div></div><div id="93554961-8bff-46d8-90b2-3b1d358beb0c" class="relative scroll-mt-20"><button type="button" id="radix-_R_5ut5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.251</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratnaśrī</div><ul class="ml-4 list-disc"><li class="italic">dkon mchog dpal</li><li class="pt-1"><span class="font-tibetan text-base">དཀོན་མཆོག་དཔལ།</span></li><li class="italic">ratnaśrī</li></ul><div class="glossary-instance-definition"><p class="definition">One of the <span data-glossary-id="UT22084-060-005-515">buddhas</span> who appear in the house of <span data-glossary-id="UT22084-060-005-1257">Vimalakīrti</span> on esoteric occasions; the Sanskrit name, but with a different rendering in Tibetan, also refers to a <span data-glossary-id="UT22084-060-005-513">bodhisattva</span>.</p></div></div></div></div><div id="dd29d6aa-cb0b-4df5-b590-014daf33b3d6" class="relative scroll-mt-20"><button type="button" id="radix-_R_5v55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.252</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratnaśrī</div><ul class="ml-4 list-disc"><li class="italic">rin chen dpal</li><li class="pt-1"><span class="font-tibetan text-base">རིན་ཆེན་དཔལ།</span></li><li class="italic">ratnaśrī</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-060-005-513">bodhisattva</span>; the Sanskrit name, but with a different rendering in Tibetan, also refers to a <span data-glossary-id="UT22084-060-005-672">tathāgata</span>.</p></div></div></div></div><div id="50724418-d968-4416-b0d9-c28f9f96a1ca" class="relative scroll-mt-20"><button type="button" id="radix-_R_5vd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.253</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratnavīra</div><ul class="ml-4 list-disc"><li class="italic">rin chen dpa’</li><li class="pt-1"><span class="font-tibetan text-base">རིན་ཆེན་དཔའ།</span></li><li class="italic">ratnavīra</li></ul></div></div></div><div id="fccb3001-894d-4827-ad90-67e7ff6eabce" class="relative scroll-mt-20"><button type="button" id="radix-_R_5vl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.254</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratnavyūha</div><ul class="ml-4 list-disc"><li class="italic">dkon mchog dkod pa, rin chen bkod pa, rin po che bkod pa</li><li class="pt-1"><span class="font-tibetan text-base">དཀོན་མཆོག་དཀོད་པ།, རིན་ཆེན་བཀོད་པ།, རིན་པོ་ཆེ་བཀོད་པ།</span></li><li class="italic">ratnavyūha</li></ul><div class="glossary-instance-definition"><p class="definition">Lit. “Jewel-Array.” Name of one of the <span data-glossary-id="UT22084-060-005-513">bodhisattvas</span> in the original assembly (rendered in Tibetan as <em class="foreign text-wy" lang="bo-LATN">rin chen bkod pa</em>); also the name (with several renderings in Tibetan) of a <span data-glossary-id="UT22084-060-005-515">buddha</span> who presides in the universe called <span data-glossary-id="UT22084-060-005-826">Ananta­guṇa­ratna­vyūha</span>, yet who comes to <span data-glossary-id="UT22084-060-005-1257">Vimalakīrti</span>’s house at the latter’s supplication, to participate in the esoteric teachings. He can be identified with the <span data-glossary-id="UT22084-060-005-672">Tathāgata</span> Ratnasaṃbhava, one of the five major <span data-glossary-id="UT22084-060-005-515">buddhas</span> of the <cite class="title break text-sa" lang="sa-LATN">Guhya­samāja­tantra</cite>. </p></div></div></div></div><div id="9efcf73c-26a0-408c-9171-b6aef3035f7a" class="relative scroll-mt-20"><button type="button" id="radix-_R_5vt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.255</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratnayaṣṭin</div><ul class="ml-4 list-disc"><li class="italic">rin chen gdan dkar can</li><li class="pt-1"><span class="font-tibetan text-base">རིན་ཆེན་གདན་དཀར་ཅན།</span></li><li class="italic">ratnayaṣṭin</li></ul></div></div></div><div id="88a06c9a-f3cb-489e-b482-d2f4264220ae" class="relative scroll-mt-20"><button type="button" id="radix-_R_6055anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.256</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Ratnolkā­dhārin</div><ul class="ml-4 list-disc"><li class="italic">rin chen sgron ma ’dzin</li><li class="pt-1"><span class="font-tibetan text-base">རིན་ཆེན་སྒྲོན་མ་འཛིན།</span></li><li class="italic">ratnolkā­dhārin</li></ul></div></div></div><div id="fe59fd73-89db-4934-9361-12927e5e3e5b" class="relative scroll-mt-20"><button type="button" id="radix-_R_60d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.257</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">reality-limit</div><ul class="ml-4 list-disc"><li class="italic">yang dag pa’i mtha’</li><li class="pt-1"><span class="font-tibetan text-base">ཡང་དག་པའི་མཐའ།</span></li><li class="italic">bhūtakoṭi</li></ul><div class="glossary-instance-definition"><p class="definition">A synonym of the <span data-glossary-id="UT22084-060-005-683">ultimate</span> reality. In the <span data-glossary-id="UT22084-060-005-605">Mahāyāna</span> <span data-glossary-id="UT22084-060-005-670">sūtras</span>, it has a somewhat negative flavor, connoting the Hinayāna concept of a static <span data-glossary-id="UT22084-060-005-621">nirvāṇa</span>. <span data-glossary-id="UT22084-060-005-809">Sthiramati</span> glosses the term as follows: “ ‘Reality’ means undistorted truth. ‘Limit’ means the extreme beyond which there is nothing to be known by anyone” (<em class="foreign break text-sa" lang="sa-LATN">bhūtaṃ satyam aviparītamityarthaḥ / koṭiḥ paryanto yataḥ pareṇa-anyajjñeyaṃ nāsti…/</em>). </p></div></div></div></div><div id="b61ff573-1c3d-4da4-ad62-805395b82896" class="relative scroll-mt-20"><button type="button" id="radix-_R_60l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.258</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">realm of desire</div><ul class="ml-4 list-disc"><li class="italic">’dod khams</li><li class="pt-1"><span class="font-tibetan text-base">འདོད་ཁམས།</span></li><li class="italic">kāmadhātu</li></ul><div class="glossary-instance-definition"><p class="definition">In Buddhist cosmology, this is our own realm, the lowest and most coarse of the three realms of saṃsāra. It is called this because beings here are characterized by their strong longing for and attachment to the pleasures of the senses. The desire realm includes hell beings, hungry ghosts, animals, humans, asuras, and the lowest six heavens of the gods‍—from the Heaven of the Four Great Kings (<em class="foreign break text-sa" lang="sa-LATN">cāturmahā­rājika</em>) up to the Heaven of Making Use of Others’ Emanations (<em class="foreign break text-sa" lang="sa-LATN">para­nirmita­vaśa­vartin</em>). Located above the desire realm is the form realm (<em class="foreign break text-sa" lang="sa-LATN">rūpadhātu</em>) and the formless realm (<em class="foreign break text-sa" lang="sa-LATN">ārūpyadhātu</em>).</p></div></div></div></div><div id="435305a6-61e7-4eab-874f-001d28ba913d" class="relative scroll-mt-20"><button type="button" id="radix-_R_60t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.259</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">realm of pure matter</div><ul class="ml-4 list-disc"><li class="italic">gzugs khams</li><li class="pt-1"><span class="font-tibetan text-base">གཟུགས་ཁམས།</span></li><li class="italic">rūpadhātu</li></ul><div class="glossary-instance-definition"><p class="definition">One of the three realms of saṃsāra in Buddhist cosmology, it is characterized by subtle materiality. Here beings, though subtly embodied, are not driven primarily by the urge for sense gratification. It consists of seventeen heavens structured according to the four concentrations of the form realm (<em class="foreign break text-sa" lang="sa-LATN">rūpāvacaradhyāna</em>), the highest five of which are collectively called “pure abodes” (<em class="foreign break text-sa" lang="sa-LATN">śuddhāvāsa</em>). The form realm is located above the desire realm (<em class="foreign break text-sa" lang="sa-LATN">kāmadhātu</em>) and below the formless realm (<em class="foreign break text-sa" lang="sa-LATN">ārūpya­dhātu</em>). </p></div></div></div></div><div id="b1f05db9-7380-4a8c-b8c2-ff2145a720b9" class="relative scroll-mt-20"><button type="button" id="radix-_R_6155anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.260</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">reconciliation of dichotomies, reconciling dichotomies</div><ul class="ml-4 list-disc"><li class="italic">snrel zhi ba, snrel zhi’i rgyud</li><li class="pt-1"><span class="font-tibetan text-base">སྣྲེལ་ཞི་བ།, སྣྲེལ་ཞིའི་རྒྱུད།</span></li><li class="italic">yamaka­vyatyastāhāra</li></ul><div class="glossary-instance-definition"><p class="definition">The twelfth of the <span data-glossary-id="UT22084-060-005-545">eighteen special qualities of a bodhisattva</span>.</p></div></div></div></div><div id="ee159495-5ad2-4056-8ec0-27e368dabfa3" class="relative scroll-mt-20"><button type="button" id="radix-_R_61d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.261</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Roca</div><ul class="ml-4 list-disc"><li class="italic">snang mdzad</li><li class="pt-1"><span class="font-tibetan text-base">སྣང་མཛད།</span></li><li class="italic">roca</li></ul><div class="glossary-instance-definition"><p class="definition">Mentioned by the <span data-glossary-id="UT22084-060-005-515">Buddha</span> as the last of the thousand <span data-glossary-id="UT22084-060-005-515">buddhas</span> of this eon.</p></div></div></div></div><div id="1ece340f-64af-448c-8b6e-68cd5c2003d8" class="relative scroll-mt-20"><button type="button" id="radix-_R_61l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.262</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">sacrifice</div><ul class="ml-4 list-disc"><li class="italic">mchod sbyin</li><li class="pt-1"><span class="font-tibetan text-base">མཆོད་སྦྱིན།</span></li><li class="italic">yajña</li></ul></div></div></div><div id="257e3d74-3b1c-455d-83a6-167b779248c7" class="relative scroll-mt-20"><button type="button" id="radix-_R_61t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.263</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sahā</div><ul class="ml-4 list-disc"><li class="italic">mi mjed</li><li class="pt-1"><span class="font-tibetan text-base">མི་མཇེད།</span></li><li class="italic">sahā</li></ul><div class="glossary-instance-definition"><p>The name for our world system, the universe of a thousand million worlds, or trichiliocosm, in which the four-continent world is located. Each trichiliocosm is ruled by a god Brahmā; thus, in this context, he bears the title of Sahāṃpati, Lord of Sahā. The world system of Sahā, or Sahālokadhātu, is also described as the buddhafield of the Buddha Śākyamuni where he teaches the Dharma to beings. </p><p>The name Sahā possibly derives from the Sanskrit <em class="foreign break text-sa" lang="sa-LATN">√sah</em>, “to bear, endure, or withstand.” It is often interpreted as alluding to the inhabitants of this world being able to endure the suffering they encounter. The Tibetan translation, <em class="foreign text-wy" lang="bo-LATN">mi mjed</em>, follows along the same lines. It literally means “not painful,” in the sense that beings here are able to bear the suffering they experience.</p></div></div></div></div><div id="03c76c10-e256-4018-9d81-4a08522d2e5b" class="relative scroll-mt-20"><button type="button" id="radix-_R_6255anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.264</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Śaila­śikhara­saṃghaṭṭana­rāja</div><ul class="ml-4 list-disc"><li class="italic">ri’i rtse mo kun tu ’joms pa’i rgyal po</li><li class="pt-1"><span class="font-tibetan text-base">རིའི་རྩེ་མོ་ཀུན་ཏུ་འཇོམས་པའི་རྒྱལ་པོ།</span></li><li class="italic">śaila­śikhara­saṃghaṭṭana­rāja</li></ul></div></div></div><div id="ff52ab68-0ea9-42a5-a0ae-44db0fdbe3b6" class="relative scroll-mt-20"><button type="button" id="radix-_R_62d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.265</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Śakra</div><ul class="ml-4 list-disc"><li class="italic">brgya byin</li><li class="pt-1"><span class="font-tibetan text-base">བརྒྱ་བྱིན།</span></li><li class="italic">śakra</li></ul><div class="glossary-instance-definition"><p class="definition">In Buddhist texts, usual name for <span data-glossary-id="UT22084-060-005-725">Indra</span>, king of gods of the desire-realm (<em class="foreign break text-sa" lang="sa-LATN">kāmadhātu</em>) of a particular universe; hence a <span class="ignore">Śakra</span> is lower in status than a <span data-glossary-id="UT22084-060-005-710">Brahmā</span>, who resides at the summit of the <span data-glossary-id="UT22084-060-005-638">realm of pure matter</span> (<em class="foreign break text-sa" lang="sa-LATN">rūpadhātu</em>). As in the case of <span data-glossary-id="UT22084-060-005-710">Brahmā</span>, a title, or status, rather than a personal name; each universe has its <span class="ignore">Śakra</span>. </p></div></div></div></div><div id="e1813d20-97df-4f46-931f-83299e213602" class="relative scroll-mt-20"><button type="button" id="radix-_R_62l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.266</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Śākya</div><ul class="ml-4 list-disc"><li class="italic">shAkya</li><li class="pt-1"><span class="font-tibetan text-base">ཤཱཀྱ།</span></li><li class="italic">śākya</li></ul><div class="glossary-instance-definition"><p class="definition">Name of the tribe dwelling in Northern India in which Gautama, or <span data-glossary-id="UT22084-060-005-794">Śākyamuni</span>, <span data-glossary-id="UT22084-060-005-515">Buddha</span> was born as prince Siddhārtha.</p></div></div></div></div><div id="4dde3f3a-6487-4806-890b-da311468effb" class="relative scroll-mt-20"><button type="button" id="radix-_R_62t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.267</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Śākyamuni</div><ul class="ml-4 list-disc"><li class="italic">shAkya thub pa</li><li class="pt-1"><span class="font-tibetan text-base">ཤཱཀྱ་ཐུབ་པ།</span></li><li class="italic">śākyamuni</li></ul><div class="glossary-instance-definition"><p class="definition">The “Sage of the <span data-glossary-id="UT22084-060-005-793">Śākyas</span>,” name of the <span data-glossary-id="UT22084-060-005-515">Buddha</span> of our era, who lived c. 563-483 B.C.</p></div></div></div></div><div id="fe02c8d4-f771-472c-bc65-6a2253f39b06" class="relative scroll-mt-20"><button type="button" id="radix-_R_6355anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.268</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Samadarśin</div><ul class="ml-4 list-disc"><li class="italic">mnyam par lta ba</li><li class="pt-1"><span class="font-tibetan text-base">མཉམ་པར་ལྟ་བ།</span></li><li class="italic">samadarśin</li></ul></div></div></div><div id="410a8c3f-585a-4db1-8bc9-da909753bdfa" class="relative scroll-mt-20"><button type="button" id="radix-_R_63d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.269</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Samādhi­vikurvaṇa­rāja</div><ul class="ml-4 list-disc"><li class="italic">ting nge ’dzin rnam par sprul pa’i rgyal po</li><li class="pt-1"><span class="font-tibetan text-base">ཏིང་ངེ་འཛིན་རྣམ་པར་སྤྲུལ་པའི་རྒྱལ་པོ།</span></li><li class="italic">samādhi­vikurvaṇa­rāja</li></ul></div></div></div><div id="d4226273-15f9-4a99-aaeb-e0c57ed06f4d" class="relative scroll-mt-20"><button type="button" id="radix-_R_63l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.270</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sama­viṣama­darśin</div><ul class="ml-4 list-disc"><li class="italic">mnyam mi mnyam lta ba</li><li class="pt-1"><span class="font-tibetan text-base">མཉམ་མི་མཉམ་ལྟ་བ།</span></li><li class="italic">sama­viṣama­darśin</li></ul></div></div></div><div id="bce502de-187d-4fc2-a938-fe32a4604973" class="relative scroll-mt-20"><button type="button" id="radix-_R_63t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.271</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Saṃdhi­nirmocana­sūtra</div><ul class="ml-4 list-disc"><li class="italic">mdo sde dgongs ’grel</li><li class="pt-1"><span class="font-tibetan text-base">མདོ་སྡེ་དགོངས་འགྲེལ།</span></li><li class="italic">saṃdhi­nirmocana­sūtra</li></ul><div class="glossary-instance-definition"><p class="definition">The “<span data-glossary-id="UT22084-060-005-670">Sūtra</span> of the Revelation of the Inner Intention,” it was the most important <span data-glossary-id="UT22084-060-005-605">Mahāyāna</span> <span data-glossary-id="UT22084-060-005-670">sūtra</span> for <span data-glossary-id="UT22084-060-005-705">Āryāsaṅga</span> and the <span data-glossary-id="UT22084-060-005-687">Vijñānavāda</span> school.</p></div></div></div></div><div id="60ccd035-bf37-4920-98b9-7356b7539474" class="relative scroll-mt-20"><button type="button" id="radix-_R_6455anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.272</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Saṃjāyin Vairaṭi­putra, Saṃjāyin Vairāṭī­putra</div><ul class="ml-4 list-disc"><li class="italic">smra ’dod kyi bu mo’i bu yang dag rgyal ba can</li><li class="pt-1"><span class="font-tibetan text-base">སྨྲ་འདོད་ཀྱི་བུ་མོའི་བུ་ཡང་དག་རྒྱལ་བ་ཅན།</span></li><li class="italic">saṃjāyin vairāṭī­putra</li></ul><div class="glossary-instance-definition"><p class="definition">One of the six <span data-glossary-id="UT22084-060-005-627">outsider</span> teachers.</p></div></div></div></div><div id="8079c844-6aa8-475b-95cb-57354847781e" class="relative scroll-mt-20"><button type="button" id="radix-_R_64d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.273</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Saṃtuṣita</div><ul class="ml-4 list-disc"><li class="italic">yongs su dga’ ldan</li><li class="pt-1"><span class="font-tibetan text-base">ཡོངས་སུ་དགའ་ལྡན།</span></li><li class="italic">saṃtuṣita</li></ul><div class="glossary-instance-definition"><p class="definition">King of the gods of the <span data-glossary-id="UT22084-060-005-847">Tuṣita</span> heaven.</p></div></div></div></div><div id="62ef6630-ce39-4719-8c3d-8bc80c440c40" class="relative scroll-mt-20"><button type="button" id="radix-_R_64l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.274</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">saṃyaksaṃbuddha</div><ul class="ml-4 list-disc"><li class="italic">yang dag par rdzogs pa’i sangs rgyas</li><li class="pt-1"><span class="font-tibetan text-base">ཡང་དག་པར་རྫོགས་པའི་སངས་རྒྱས།</span></li><li class="italic">saṃyak­saṃbuddha</li></ul><div class="glossary-instance-definition"><p class="definition">Lit. “perfectly accomplished <span data-glossary-id="UT22084-060-005-515">Buddha</span>.” Name of the <span data-glossary-id="UT22084-060-005-515">Buddha</span>.</p></div></div></div></div><div id="02725146-032e-4372-bc0f-78777524f0aa" class="relative scroll-mt-20"><button type="button" id="radix-_R_64t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.275</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Saṅgha</div><ul class="ml-4 list-disc"><li class="italic">dge ’dun</li><li class="pt-1"><span class="font-tibetan text-base">དགེ་འདུན།</span></li><li class="italic">saṅgha</li></ul><div class="glossary-instance-definition"><p class="definition">The third of the Three Jewels (Triratna) of Buddhism, the <span data-glossary-id="UT22084-060-005-515">Buddha</span>, the Teaching, and the Community. Sometimes narrowly defined as the community of mendicants, it can be understood as including lay practitioners.</p></div></div></div></div><div id="15d5cc78-99a1-4fc0-98c7-3b943fc66f8d" class="relative scroll-mt-20"><button type="button" id="radix-_R_6555anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.276</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Śāntideva</div><ul class="ml-4 list-disc"><li class="italic">zhi ba lha</li><li class="pt-1"><span class="font-tibetan text-base">ཞི་བ་ལྷ།</span></li><li class="italic">śāntideva</li></ul><div class="glossary-instance-definition"><p class="definition">(Eighth century). A great master of the <span data-glossary-id="UT22084-060-005-603">Mādhyamika</span>, famous for his remarkable work, “Introduction to the Practice of <span data-glossary-id="UT22084-060-005-551">Enlightenment</span>” (<cite class="title break text-sa" lang="sa-LATN">Bodhi­caryāvatāra</cite>). </p></div></div></div></div><div id="4da7d125-a1b8-4820-b50f-9de69a2ab346" class="relative scroll-mt-20"><button type="button" id="radix-_R_65d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.277</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Śāriputra</div><ul class="ml-4 list-disc"><li class="italic">shA ri’i bu</li><li class="pt-1"><span class="font-tibetan text-base">ཤཱ་རིའི་བུ།</span></li><li class="italic">śāriputra</li></ul><div class="glossary-instance-definition"><p class="definition">One of the major <span data-glossary-id="UT22084-060-005-661">śrāvaka</span> disciples, paired with <span data-glossary-id="UT22084-060-005-751">Maudgalyāyana</span>, and noted for having been praised by the <span data-glossary-id="UT22084-060-005-515">Buddha</span> as foremost of the wise; hence, the most frequent target for <span data-glossary-id="UT22084-060-005-1257">Vimalakīrti</span>’s attacks on the <span data-glossary-id="UT22084-060-005-661">śrāvakas</span> and on the Hinayāna in general.</p><p class="definition">(See also <a href="end-notes.xhtml#UT22084-060-005-902" data-pointer-type="id">n.40</a>)</p></div></div></div></div><div id="193f54d9-b372-4370-90ff-5e1cbf04462b" class="relative scroll-mt-20"><button type="button" id="radix-_R_65l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.278</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sarva­gandha­sugandhā</div><ul class="ml-4 list-disc"><li class="italic">spos thams cad kyi dri mchog</li><li class="pt-1"><span class="font-tibetan text-base">སྤོས་ཐམས་ཅད་ཀྱི་དྲི་མཆོག</span></li><li class="italic">sarva­gandha­sugandhā</li></ul><div class="glossary-instance-definition"><p class="definition">Universe of the <span data-glossary-id="UT22084-060-005-515">Buddha</span> <span data-glossary-id="UT22084-060-005-724">Gandhottama­kūṭa</span>; a universe wherein the <span data-glossary-id="UT22084-060-005-537">Dharma</span> is taught through the medium of scent. According to Lamotte, p. 319, n. 2, this universe is mentioned in the <cite class="title break text-sa" lang="sa-LATN"><span data-glossary-id="UT22084-060-005-858">Śikṣāsamuccaya</span></cite>, the <cite class="title break text-sa" lang="sa-LATN">Laṇkāvatāra</cite>, and the <cite class="title break text-sa" lang="sa-LATN"><span data-glossary-id="UT22084-060-005-855">Prasannapadā</span></cite>. However, In the <span data-glossary-id="UT22084-060-005-855">Prasannapadā</span>, this universe is said to be ruled by Samantabhadra, not <span data-glossary-id="UT22084-060-005-724">Gandhottama­kūṭa</span> (see Lamotte, p. 320, n. 3). </p></div></div></div></div><div id="7b9a1090-b83a-4b4b-afc2-fd8fd3328bdd" class="relative scroll-mt-20"><button type="button" id="radix-_R_65t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.279</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sarvārtha­siddha</div><ul class="ml-4 list-disc"><li class="italic">don thams cad grub pa</li><li class="pt-1"><span class="font-tibetan text-base">དོན་ཐམས་ཅད་གྲུབ་པ།</span></li><li class="italic">sarvārtha­siddha</li></ul><div class="glossary-instance-definition"><p class="definition">One of the <span data-glossary-id="UT22084-060-005-515">buddhas</span> who appear in <span data-glossary-id="UT22084-060-005-1257">Vimalakīrti</span>’s house to teach the <cite class="title break text-sa" lang="sa-LATN">Tathāgata­guhyaka</cite>, according to the goddess. </p></div></div></div></div><div id="6a09bb1f-f2ea-4b10-83c0-4cb9fa8135cd" class="relative scroll-mt-20"><button type="button" id="radix-_R_6655anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.280</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sarva­rūpa­saṃdarśana</div><ul class="ml-4 list-disc"><li class="italic">gzugs thams cad ston pa</li><li class="pt-1"><span class="font-tibetan text-base">གཟུགས་ཐམས་ཅད་སྟོན་པ།</span></li><li class="italic">sarva­rūpa­saṃdarśana</li></ul><div class="glossary-instance-definition"><p class="definition">This <span data-glossary-id="UT22084-060-005-513">bodhisattva</span> asks <span data-glossary-id="UT22084-060-005-1257">Vimalakīrti</span> the whereabouts of his family, etc., thus prompting the latter’s extraordinary verses on the family and accoutrements of all <span data-glossary-id="UT22084-060-005-513">bodhisattvas</span> (Chap. 8).</p></div></div></div></div><div id="ff3e441e-4f09-4277-af22-97924bb950fb" class="relative scroll-mt-20"><button type="button" id="radix-_R_66d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.281</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sarva­sukha­pratimaṇḍita</div><ul class="ml-4 list-disc"><li class="italic">bde ba thams cad kyis rab tu brgyan pa</li><li class="pt-1"><span class="font-tibetan text-base">བདེ་བ་ཐམས་ཅད་ཀྱིས་རབ་ཏུ་བརྒྱན་པ།</span></li><li class="italic">sarva­sukha­pratimaṇḍita</li></ul><div class="glossary-instance-definition"><p class="definition">A universe, or <span data-glossary-id="UT22084-060-005-516">buddhafield</span>, where the <span data-glossary-id="UT22084-060-005-513">bodhisattvas</span> live in a constant state of bliss. The Skt. of the Potala MS has Sarva­sukha­pratimaṇḍita, that of the excerpt cited in the <span data-glossary-id="UT22084-060-005-858">Śikṣāsamuccaya</span> has Sarvasukhamaṇḍitā.</p></div></div></div></div><div id="0a4d080d-b5a3-4338-aca4-f25ac1885cc0" class="relative scroll-mt-20"><button type="button" id="radix-_R_66l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.282</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Satatodyukta</div><ul class="ml-4 list-disc"><li class="italic">rtag tu ’bad</li><li class="pt-1"><span class="font-tibetan text-base">རྟག་ཏུ་འབད།</span></li><li class="italic">satatodyukta</li></ul></div></div></div><div id="aa890c43-17f7-413b-a41f-433bfc888126" class="relative scroll-mt-20"><button type="button" id="radix-_R_66t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.283</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">seat of enlightenment</div><ul class="ml-4 list-disc"><li class="italic">byang chub kyi snying po</li><li class="pt-1"><span class="font-tibetan text-base">བྱང་ཆུབ་ཀྱི་སྙིང་པོ།</span></li><li class="italic">bodhimaṇḍa</li></ul><div class="glossary-instance-definition"><p class="definition">Haribhadra defines it as “a place used as a seat, where the maṇḍa, here ‘essence,’ of <span data-glossary-id="UT22084-060-005-551">enlightenment</span> is present.” See Lamotte, p. 198, n. 105. The main “<span class="ignore">seat of enlightenment</span>” is the spot under the bo tree at <span data-glossary-id="UT22084-060-005-828">Buddha Gaya</span>, where the <span data-glossary-id="UT22084-060-005-515">Buddha</span> sat and attained unexcelled, perfect <span data-glossary-id="UT22084-060-005-551">enlightenment</span>. It is not to be confused with <em class="foreign break text-sa" lang="sa-LATN">bodhimaṇḍala</em>, “circle of <span data-glossary-id="UT22084-060-005-551">enlightenment</span>.” </p></div></div></div></div><div id="6b47902b-462a-40ad-923c-f033caeaf1f2" class="relative scroll-mt-20"><button type="button" id="radix-_R_6755anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.284</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">self</div><ul class="ml-4 list-disc"><li class="italic">bdag</li><li class="pt-1"><span class="font-tibetan text-base">བདག</span></li><li class="italic">ātma</li></ul><div class="glossary-instance-definition"><p class="definition">It is crucial to understand what is meant by “<span class="ignore">self</span>,” before one is able to realize the all-important “<span data-glossary-id="UT22084-060-005-499">absence of self</span>.” Before we can discover an absence, we have to know what we are looking for. In <span data-glossary-id="UT22084-060-005-605">Mahāyāna</span>, there is a <span class="ignore">self</span> of persons and a <span class="ignore">self</span> of things, both presumed habitually by living beings and hence informative of their perceptions. Were these “selves” to exist as they appear because of our presumption, they should exist as substantial, <span class="ignore">self</span>-subsistent entities within things, or as the intrinsic realities of things, or as the intrinsic <span data-glossary-id="UT22084-060-005-579">identities</span> of things, all permanent, unrelated and unrelative, etc. The nondiscovery of such “selves” within changing, relative, interdependent persons and things is the realization of <span data-glossary-id="UT22084-060-005-683">ultimate</span> reality, or <span data-glossary-id="UT22084-060-005-499">absence of self</span>.</p></div></div></div></div><div id="19b574d4-ec62-4f40-aff0-c7b3e662d6a9" class="relative scroll-mt-20"><button type="button" id="radix-_R_67d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.285</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">selfish reticence</div><ul class="ml-4 list-disc"><li class="italic">slob dpon dpe mkhyud</li><li class="pt-1"><span class="font-tibetan text-base">སློབ་དཔོན་དཔེ་མཁྱུད།</span></li><li class="italic">ācāryamuṣṭi</li></ul><div class="glossary-instance-definition"><p class="definition">Lit. “The tight fist of the [bad] teacher.”</p></div></div></div></div><div id="3c9a7a89-0b91-478a-a4a4-f6730f0689f9" class="relative scroll-mt-20"><button type="button" id="radix-_R_67l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.286</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">sensation</div><ul class="ml-4 list-disc"><li class="italic">tshor ba</li><li class="pt-1"><span class="font-tibetan text-base">ཚོར་བ།</span></li><li class="italic">vedanā</li></ul><div class="glossary-instance-definition"><p class="definition">see “<span data-glossary-id="UT22084-060-005-502">aggregates</span>”</p></div></div></div></div><div id="f63a28fa-eaa5-4aa0-bcc2-44bd9e6badcf" class="relative scroll-mt-20"><button type="button" id="radix-_R_67t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.287</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">sense-media</div><ul class="ml-4 list-disc"><li class="italic">skye mched</li><li class="pt-1"><span class="font-tibetan text-base">སྐྱེ་མཆེད།</span></li><li class="italic">āyatana</li></ul><div class="glossary-instance-definition"><p class="definition">The twelve <span class="ignore">sense-media</span> are eye-medium (<em class="foreign break text-sa" lang="sa-LATN">cakṣurāyatana</em>), form-medium (<em class="foreign break text-sa" lang="sa-LATN">rūpa</em>-), ear-medium (<em class="foreign break text-sa" lang="sa-LATN">śrotra</em>-), sound-medium (<em class="foreign break text-sa" lang="sa-LATN">śabda</em>-), nose-medium (<em class="foreign break text-sa" lang="sa-LATN">ghrāna</em>-), scent-medium (<em class="foreign break text-sa" lang="sa-LATN">gandha</em>-), tongue-medium (<em class="foreign break text-sa" lang="sa-LATN">jihvā</em>-), taste-medium (<em class="foreign break text-sa" lang="sa-LATN">rasa</em>-), body-medium (<em class="foreign break text-sa" lang="sa-LATN">kāya</em>-), texture-medium (<em class="foreign break text-sa" lang="sa-LATN">spraṣṭavya</em>), mental-medium (<em class="foreign break text-sa" lang="sa-LATN">mana</em>-), and phenomena-medium (<em class="foreign break text-sa" lang="sa-LATN">dharmāyatana</em>). In some passages they are enumerated as six, the object-faculty pair being taken as one, and it is this set of six that is the fifth member of the twelve links of <span data-glossary-id="UT22084-060-005-533">dependent origination</span>. The word āyatana is usually translated as “base,” but the Skt., Tib., and Ch. all indicate “something through which the senses function” rather than a basis from which they function; hence “medium” is suggested. </p></div></div></div></div><div id="ebcff4b7-5238-4173-8c8e-4db2148b8fad" class="relative scroll-mt-20"><button type="button" id="radix-_R_6855anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.288</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">seven abodes of consciousness</div><ul class="ml-4 list-disc"><li class="italic">rnam par shes pa la gnas pa bdun</li><li class="pt-1"><span class="font-tibetan text-base">རྣམ་པར་ཤེས་པ་ལ་གནས་པ་བདུན།</span></li><li class="italic">vijñānasthiti</li></ul><div class="glossary-instance-definition"><p class="definition">This refers to the seven categories of living beings, as enumerated in the <cite class="title break text-sa" lang="sa-LATN"><span data-glossary-id="UT22084-060-005-849">Abhi­dharma­kośa</span></cite>, III, v. 5-6a. The <span class="ignore">seven abodes of consciousness</span> consist of beings who differ physically and intellectually; beings who differ physically but are similar intellectually; beings similar physically but who differ intellectually; beings similar physically and intellectually; and three types of immaterial beings (<em class="foreign break text-sa" lang="sa-LATN">nānātvakāya­saṃjñāś ca nānākāyaika­saṃjñinaḥ / viparyayāc caikakāya­saṃjñāś cārūpiṇas trayaḥ // vijñāna­sthitayaḥ sapta…</em>). According to <span data-glossary-id="UT22084-060-005-819">Vasubandhu</span> the first category consists of men, the six types of gods of the desire-realm, and the gods of the first realm of <span data-glossary-id="UT22084-060-005-528">contemplation</span> (<em class="foreign break text-sa" lang="sa-LATN">brahma­vihāra</em>) except those fallen from higher realms (<em class="foreign break text-sa" lang="sa-LATN">prathamābhinivṛta</em>); the second category consists of those fallen (<em class="foreign break text-sa" lang="sa-LATN">prathamābhiniṛvṛta</em>) gods who have different bodies but whose <span data-glossary-id="UT22084-060-005-588">intellects</span> are single-mindedly aware of the idea of being created by <span data-glossary-id="UT22084-060-005-710">Brahmā</span>; the third category consists of the gods of the second realm of <span data-glossary-id="UT22084-060-005-528">contemplation</span>‍—the <em class="foreign break text-sa" lang="sa-LATN">abhāsvara</em> (clear-light) gods, the <em class="foreign break text-sa" lang="sa-LATN">parīṭṭābha</em> (radiant) gods, and the <em class="foreign break text-sa" lang="sa-LATN">apramāṇābha</em> (immeasurably luminous) gods‍—who have similar luminous bodies but differ in their thoughts, which are bent on the experiences of pleasure and numbness; the fourth category consists of the <em class="foreign break text-sa" lang="sa-LATN">śubhakṛtsna</em> (pure-wholeness) gods, whose <span data-glossary-id="UT22084-060-005-588">intellects</span> are united in <span data-glossary-id="UT22084-060-005-521">concentration</span> on bliss; the fifth category consists of the immaterial beings who reside in the realm of infinite space; the sixth category consists of the immaterial beings who reside in the realm of infinite <span data-glossary-id="UT22084-060-005-527">consciousness</span>; and the seventh category consists of the immaterial beings who reside in the realm of nothingness. (See also Mvy, Nos. 2289-2295.) </p></div></div></div></div><div id="fa80f7ed-d6c6-4a26-8e30-34293b74e47a" class="relative scroll-mt-20"><button type="button" id="radix-_R_68d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.289</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">seven factors of enlightenment</div><ul class="ml-4 list-disc"><li class="italic">byang chub kyi yan lag bdun</li><li class="pt-1"><span class="font-tibetan text-base">བྱང་ཆུབ་ཀྱི་ཡན་ལག་བདུན།</span></li><li class="italic">saṃbodhyaṅga</li></ul><div class="glossary-instance-definition"><p class="definition">These are the factors of remembrance (<em class="foreign break text-sa" lang="sa-LATN">smṛti</em>), discrimination between teachings (<em class="foreign break text-sa" lang="sa-LATN">dharma­pravicaya</em>), effort (<em class="foreign break text-sa" lang="sa-LATN">vīrya</em>), joy (<em class="foreign break text-sa" lang="sa-LATN">prīti</em>), ecstasy (<em class="foreign break text-sa" lang="sa-LATN">praśrabdhi</em>), <span data-glossary-id="UT22084-060-005-521">concentration</span> (<em class="foreign break text-sa" lang="sa-LATN"><span data-glossary-id="UT22084-060-005-642">samādhi</span></em>), and equanimity (<em class="foreign break text-sa" lang="sa-LATN">upekṣā</em>). These seven form a part of the <span data-glossary-id="UT22084-060-005-676">thirty-seven aids to enlightenment</span>. </p></div></div></div></div><div id="7d73e343-f69c-4e58-b34d-11a2174e7d7a" class="relative scroll-mt-20"><button type="button" id="radix-_R_68l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.290</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">signlessness</div><ul class="ml-4 list-disc"><li class="italic">mtshan ma med pa</li><li class="pt-1"><span class="font-tibetan text-base">མཚན་མ་མེད་པ།</span></li><li class="italic">animittatā</li></ul><div class="glossary-instance-definition"><p class="definition">In <span data-glossary-id="UT22084-060-005-683">ultimate</span> reality, there is no sign, as a sign signals or signifies something to someone and hence is inextricably involved with the relative world. We are so conditioned by signs that they seem to speak to us as if they had a voice of their own. The letter “A” seems to pronounce itself to us as we see it, and the stop-sign fairly shouts at us. However, the configuration of two slanted lines with a crossbar has in itself nothing whatsoever to do with the phenomenon made with the mouth and throat in the open position, when expulsion of breath makes the vocal cords resonate “ah.” By extending such analysis to all signs, we may get an inkling of what is meant by “<span class="ignore">signlessness</span>,” which is essentially equivalent to <span data-glossary-id="UT22084-060-005-689">voidness</span>, and to “<span data-glossary-id="UT22084-060-005-692">wishlessness</span>” (see entry). <span data-glossary-id="UT22084-060-005-689">Voidness</span>, <span class="ignore">signlessness</span>, and <span data-glossary-id="UT22084-060-005-692">wishlessness</span> form the “Three Doors of <span data-glossary-id="UT22084-060-005-597">Liberation</span>.”</p></div></div></div></div><div id="b3fa9972-99a8-474b-bb7a-b5135af4c1f7" class="relative scroll-mt-20"><button type="button" id="radix-_R_68t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.291</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Śikhin</div><ul class="ml-4 list-disc"><li class="italic">ral pa can</li><li class="pt-1"><span class="font-tibetan text-base">རལ་པ་ཅན།</span></li><li class="italic">śikhin</li></ul><div class="glossary-instance-definition"><p class="definition">The <span data-glossary-id="UT22084-060-005-710">Brahmā</span> of the universe <span data-glossary-id="UT22084-060-005-827">Aśoka</span>, who is personally called <span class="ignore">Śikhin</span> to distinguish him from <span data-glossary-id="UT22084-060-005-710">Brahmās</span> of other universes (see <span data-glossary-id="UT22084-060-005-710">Brahmā</span>). The second of the “seven <span data-glossary-id="UT22084-060-005-515">buddhas</span> of the past” is also called <span class="ignore">Śikhin</span> but his name is rendered in Tibetan as <em class="foreign text-wy" lang="bo-LATN">gtsug gtor can</em>.</p></div></div></div></div><div id="84791ec1-7e10-4df6-ae4c-cd69fca87951" class="relative scroll-mt-20"><button type="button" id="radix-_R_6955anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.292</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Śikṣāsamuccaya</div><ul class="ml-4 list-disc"><li class="italic">bslab pa kun las btus pa</li><li class="pt-1"><span class="font-tibetan text-base">བསླབ་པ་ཀུན་ལས་བཏུས་པ།</span></li><li class="italic">śikṣāsamuccaya</li></ul><div class="glossary-instance-definition"><p class="definition">The “Compendium of Precepts,” in which <span data-glossary-id="UT22084-060-005-800">Śāntideva</span> collects pertinent quotes from the <span data-glossary-id="UT22084-060-005-605">Mahāyāna</span> <span data-glossary-id="UT22084-060-005-670">sūtras</span> and presents them according to a pattern suited for systematic practice. The quotations he included from the Vimalakīrtinirdeśa were the only extant remnants of the original Sanskrit of the Vimalakīrtinirdeśa until the discovery of a Sanskrit text in the Potala Palace in 2002.</p></div></div></div></div><div id="8d1a100c-40e2-4308-83e0-43ac0acdc064" class="relative scroll-mt-20"><button type="button" id="radix-_R_69d5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.293</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Siṃhaghoṣa</div><ul class="ml-4 list-disc"><li class="italic">seng ge’i sgra</li><li class="pt-1"><span class="font-tibetan text-base">སེང་གེའི་སྒྲ།</span></li><li class="italic">siṃhaghoṣa</li></ul><div class="glossary-instance-definition"><p class="definition">One of the <span data-glossary-id="UT22084-060-005-515">buddhas</span> who teach the <cite class="title break text-sa" lang="sa-LATN">Tathāgata­guhyaka</cite> on certain occasions in <span data-glossary-id="UT22084-060-005-1257">Vimalakīrti</span>’s house. </p></div></div></div></div><div id="05a8b2de-8ee0-493d-b70b-4d7c47cc2fc6" class="relative scroll-mt-20"><button type="button" id="radix-_R_69l5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.294</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Siṃha­ghoṣābhigarjita­śvara</div><ul class="ml-4 list-disc"><li class="italic">seng ge nga ro mngon par bsgrags pa’i dbyangs</li><li class="pt-1"><span class="font-tibetan text-base">སེང་གེ་ང་རོ་མངོན་པར་བསྒྲགས་པའི་དབྱངས།</span></li><li class="italic">siṃha­ghoṣābhigarjita­śvara</li></ul></div></div></div><div id="7b0d63cf-0c66-46d7-b490-257aa0a16209" class="relative scroll-mt-20"><button type="button" id="radix-_R_69t5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.295</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Siṃhanādanādī</div><ul class="ml-4 list-disc"><li class="italic">seng ge bsgrags pa</li><li class="pt-1"><span class="font-tibetan text-base">སེང་གེ་བསྒྲགས་པ།</span></li><li class="italic">siṃhanādanādī</li></ul><div class="glossary-instance-definition"><p class="definition">One of the <span data-glossary-id="UT22084-060-005-515">buddhas</span> who teach the <cite class="title break text-sa" lang="sa-LATN">Tathāgata­guhyaka</cite> on certain occasions in <span data-glossary-id="UT22084-060-005-1257">Vimalakīrti</span>’s house. </p></div></div></div></div><div id="ec69bc18-9750-4031-baae-f9f28e6c506b" class="relative scroll-mt-20"><button type="button" id="radix-_R_6a55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.296</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">six outsider masters</div><ul class="ml-4 list-disc"><li class="italic">ston pa drug</li><li class="pt-1"><span class="font-tibetan text-base">སྟོན་པ་དྲུག</span></li><li class="italic">ṣāṭ śāstāraḥ</li></ul><div class="glossary-instance-definition"><p class="definition">These six teachers of nihilism, sophism, determinism, asceticism, etc. sought to rival the <span data-glossary-id="UT22084-060-005-515">Buddha</span> in his day: Purāna Kāśyapa, who negated the effects of action, good or evil; <span data-glossary-id="UT22084-060-005-750">Māskārin Gośāli­putra</span>, who taught a theory of randomness, negating causality; <span data-glossary-id="UT22084-060-005-798">Saṃjāyin Vairaṭi­putra</span>, who was agnostic in refusing to maintain any opinion about anything; <span data-glossary-id="UT22084-060-005-729">Kakuda Kātyāyana</span>, who taught a <span data-glossary-id="UT22084-060-005-608">materialism</span> in which there was no such thing as killer or killed, but only transformations of <span data-glossary-id="UT22084-060-005-548">elements</span>; <span data-glossary-id="UT22084-060-005-695">Ajita Keśakambala</span>, who taught a more extreme nihilism regarding everything except the four main <span data-glossary-id="UT22084-060-005-548">elements</span>; and <span data-glossary-id="UT22084-060-005-755">Nirgrantha Jñāti­putra</span>, otherwise known as Mahāvīra, the founder of Jainism, who taught the doctrine of indeterminism (<em class="foreign break text-sa" lang="sa-LATN">syādvāda</em>), considering all things in terms of “maybe.” They were allowed to proclaim their doctrines unchallenged until a famous assembly at <span data-glossary-id="UT22084-060-005-844">Śrāvastī</span>, where the <span data-glossary-id="UT22084-060-005-515">Buddha</span> eclipsed them with a display of miracles and teachings. </p></div></div></div></div><div id="3818013d-2c0e-4975-9bb7-4518a8a3bf8a" class="relative scroll-mt-20"><button type="button" id="radix-_R_6ad5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.297</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">six remembrances</div><ul class="ml-4 list-disc"><li class="italic">rjes su dran pa drug</li><li class="pt-1"><span class="font-tibetan text-base">རྗེས་སུ་དྲན་པ་དྲུག</span></li><li class="italic">anusmṛti</li></ul><div class="glossary-instance-definition"><p class="definition">These are six things to keep in mind: the <span data-glossary-id="UT22084-060-005-515">Buddha</span>, the <span data-glossary-id="UT22084-060-005-537">Dharma</span>, the <span data-glossary-id="UT22084-060-005-646">Saṅgha</span>, <span data-glossary-id="UT22084-060-005-615">morality</span> (<em class="foreign break text-sa" lang="sa-LATN">śīla</em>), generosity (<em class="foreign break text-sa" lang="sa-LATN">tyāga</em>), and deities (<em class="foreign break text-sa" lang="sa-LATN">devatā</em>). </p></div></div></div></div><div id="37e4a764-eef9-41ab-a440-151b1d76a025" class="relative scroll-mt-20"><button type="button" id="radix-_R_6al5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.298</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">sixty-two convictions</div><ul class="ml-4 list-disc"><li class="italic">lta bar gyur pa drug cu rtsa gnyis</li><li class="pt-1"><span class="font-tibetan text-base">ལྟ་བར་གྱུར་པ་དྲུག་ཅུ་རྩ་གཉིས།</span></li><li class="italic">dṛṣṭigata</li></ul><div class="glossary-instance-definition"><p class="definition"> These are enumerated in the <cite class="title break text-sa" lang="sa-LATN">Brahmājāla­sūtra</cite> and in the <cite class="title break text-sa" lang="sa-LATN">Dighanikāya</cite> and consist of all <span data-glossary-id="UT22084-060-005-686">views</span> other than the “right <span data-glossary-id="UT22084-060-005-686">view</span>” of the <span data-glossary-id="UT22084-060-005-499">absence of self</span>. All sixty-two fall into either one of the two categories known as the “two extremisms:” “eternalism” (<em class="foreign break text-sa" lang="sa-LATN">sāśvatavāda</em>) and “nihilism” (<em class="foreign break text-sa" lang="sa-LATN">ucchedavāda</em>). </p></div></div></div></div><div id="86e40054-da64-4b71-8b79-a0ee822f4d48" class="relative scroll-mt-20"><button type="button" id="radix-_R_6at5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.299</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">spirit of enlightenment</div><ul class="ml-4 list-disc"><li class="italic">byang chub kyi sems</li><li class="pt-1"><span class="font-tibetan text-base">བྱང་ཆུབ་ཀྱི་སེམས།</span></li><li class="italic">bodhicitta</li></ul><div class="glossary-instance-definition"><p class="definition">“Spirit” is preferred to “mind” because the mind of <span data-glossary-id="UT22084-060-005-551">enlightenment</span> should rather be the mind of the <span data-glossary-id="UT22084-060-005-515">Buddha</span>, and to “thought” because a “thought of <span data-glossary-id="UT22084-060-005-551">enlightenment</span>” can easily be produced without the initiation of any sort of new resolve or awareness. “Will” also serves very well here.</p></div></div></div></div><div id="e5303c16-abe1-4662-81c1-ccb782cc20f3" class="relative scroll-mt-20"><button type="button" id="radix-_R_6b55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.300</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">spiritual benefactor</div><ul class="ml-4 list-disc"><li class="italic">dge ba’i bshes gnyen</li><li class="pt-1"><span class="font-tibetan text-base">དགེ་བའི་བཤེས་གཉེན།</span></li><li class="italic">kalyāṇamitra</li></ul><div class="glossary-instance-definition"><p class="definition">A <span data-glossary-id="UT22084-060-005-605">Mahāyāna</span> teacher is termed “friend,” or “benefactor,” which indicates that a <span data-glossary-id="UT22084-060-005-513">bodhisattva</span>-career depends on one’s own effort and that all a teacher can do is inspire, exemplify, and point the way.</p></div></div></div></div><div id="dfc960d5-7e6f-4230-ba38-5a0f6d68b1a4" class="relative scroll-mt-20"><button type="button" id="radix-_R_6bd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.301</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">śrāvaka</div><ul class="ml-4 list-disc"><li class="italic">nyan thos</li><li class="pt-1"><span class="font-tibetan text-base">ཉན་ཐོས།</span></li><li class="italic">śrāvaka</li></ul><div class="glossary-instance-definition"><p>The Sanskrit term <em class="foreign break text-sa" lang="sa-LATN">śrāvaka</em>, and the Tibetan <em class="foreign text-wy" lang="bo-LATN">nyan thos</em>, both derived from the verb “to hear,” are usually defined as “those who <em class="emph">hear</em> the teaching from the Buddha and <em class="emph">make it heard</em> to others.” Primarily this refers to those disciples of the Buddha who aspire to attain the state of an arhat seeking their own liberation and nirvāṇa. They are the practitioners of the first turning of the wheel of the Dharma on the four noble truths, who realize the suffering inherent in saṃsāra and focus on understanding that there is no independent self. By conquering afflicted mental states (<em class="foreign break text-sa" lang="sa-LATN">kleśa</em>), they liberate themselves, attaining first the stage of stream enterers at the path of seeing, followed by the stage of once-returners who will be reborn only one more time, and then the stage of non-returners who will no longer be reborn into the desire realm. The final goal is to become an arhat. These four stages are also known as the “four results of spiritual practice.”</p></div></div></div></div><div id="095aa97b-0bf4-4815-b45c-8a849baa0317" class="relative scroll-mt-20"><button type="button" id="radix-_R_6bl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.302</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Śrāvastī</div><ul class="ml-4 list-disc"><li class="italic">mnyan yod</li><li class="pt-1"><span class="font-tibetan text-base">མཉན་ཡོད།</span></li><li class="italic">śrāvastī</li></ul><div class="glossary-instance-definition"><p class="definition">Capital city of the kingdom of Kosala, ruled by one of the <span data-glossary-id="UT22084-060-005-515">Buddha</span>’s royal patrons, king Prasenajit, where the <span data-glossary-id="UT22084-060-005-515">Buddha</span> often dwelt in the Jetavana grove, site of many <span data-glossary-id="UT22084-060-005-605">Mahāyāna</span> <span data-glossary-id="UT22084-060-005-670">sūtras</span>.</p></div></div></div></div><div id="aeadd9af-d927-459a-b67c-be1ec4505848" class="relative scroll-mt-20"><button type="button" id="radix-_R_6bt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.303</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sthiramati</div><ul class="ml-4 list-disc"><li class="italic">blo gros brtan pa</li><li class="pt-1"><span class="font-tibetan text-base">བློ་གྲོས་བརྟན་པ།</span></li><li class="italic">sthiramati</li></ul><div class="glossary-instance-definition"><p class="definition">(c. fourth century). One of the important masters of the <span data-glossary-id="UT22084-060-005-687">Vijñānavāda</span> school, he wrote important commentaries on the works of <span data-glossary-id="UT22084-060-005-819">Vasubandhu</span> and <span data-glossary-id="UT22084-060-005-705">Āryāsaṅga</span>.</p></div></div></div></div><div id="fa55b464-cb87-4542-8570-44397712805f" class="relative scroll-mt-20"><button type="button" id="radix-_R_6c55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.304</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">stores of merit and wisdom</div><ul class="ml-4 list-disc"><li class="italic">bsod nams dang ye shes kyi tshogs</li><li class="pt-1"><span class="font-tibetan text-base">བསོད་ནམས་དང་ཡེ་ཤེས་ཀྱི་ཚོགས།</span></li><li class="italic">puṇya­jñāna­saṃbhāra</li></ul><div class="glossary-instance-definition"><p class="definition">The two great stores to be accumulated by <span data-glossary-id="UT22084-060-005-513">bodhisattvas</span>: the store of merit, arising from their practice of the first three transcendences, and the store of <span data-glossary-id="UT22084-060-005-691">wisdom</span>, arising from their practice of the last two transcendences. All deeds of <span data-glossary-id="UT22084-060-005-513">bodhisattvas</span> contribute to their accumulation of these two stores, which ultimately culminate in the two bodies of the <span data-glossary-id="UT22084-060-005-515">Buddha</span>, the body of form and the <span data-glossary-id="UT22084-060-005-683">ultimate</span> body.</p></div></div></div></div><div id="e96fbc2c-92d5-4084-8a40-f75adcb7c7af" class="relative scroll-mt-20"><button type="button" id="radix-_R_6cd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.305</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">subconscious instinct</div><ul class="ml-4 list-disc"><li class="italic">bag la nyal ba</li><li class="pt-1"><span class="font-tibetan text-base">བག་ལ་ཉལ་བ།</span></li><li class="italic">anuśaya</li></ul><div class="glossary-instance-definition"><p class="definition">This is equivalent to <em class="foreign break text-sa" lang="sa-LATN">vāsanā</em>, “instinctual predilection,” and refers in Buddhist psychology to the subconscious habit patterns that underlie emotional responses such as desire and hatred. </p></div></div></div></div><div id="521379b7-ddbc-4672-aa8f-52c7e06118cf" class="relative scroll-mt-20"><button type="button" id="radix-_R_6cl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.306</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">subconsciousness</div><ul class="ml-4 list-disc"><li class="italic">kun gzhi</li><li class="pt-1"><span class="font-tibetan text-base">ཀུན་གཞི།</span></li><li class="italic">ālaya</li></ul><div class="glossary-instance-definition"><p class="definition">Identifiable with <em class="foreign break text-sa" lang="sa-LATN">ālayavijñāna</em>. However, as reference to the elaborate Vijñānavādin psychology of the “store-<span class="ignore">consciousness</span>” is out of place in this <span data-glossary-id="UT22084-060-005-670">sūtra</span>, it is here simply translated “<span class="ignore">subconsciousness</span>.” </p></div></div></div></div><div id="dc583342-5d78-4280-9cde-078dbcaa066d" class="relative scroll-mt-20"><button type="button" id="radix-_R_6ct5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.307</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Śubhavyūha</div><ul class="ml-4 list-disc"><li class="italic">dge ba bkod pa</li><li class="pt-1"><span class="font-tibetan text-base">དགེ་བ་བཀོད་པ།</span></li><li class="italic">śubhavyūha</li></ul><div class="glossary-instance-definition"><p class="definition">A supreme god, or <span data-glossary-id="UT22084-060-005-710">Brahmā</span>, of another universe, who visits our universe to converse with <span data-glossary-id="UT22084-060-005-703">Aniruddha</span> about the <span data-glossary-id="UT22084-060-005-540">divine eye</span>, and is taught instead by <span data-glossary-id="UT22084-060-005-1257">Vimalakīrti</span> in Chap. 3.</p></div></div></div></div><div id="b5412ab5-da28-47a8-aaf4-65be6e28d7d4" class="relative scroll-mt-20"><button type="button" id="radix-_R_6d55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.308</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Subhūti</div><ul class="ml-4 list-disc"><li class="italic">rab ’byor</li><li class="pt-1"><span class="font-tibetan text-base">རབ་འབྱོར།</span></li><li class="italic">subhūti</li></ul><div class="glossary-instance-definition"><p class="definition">Disciple noted for his profound <span data-glossary-id="UT22084-060-005-521">concentration</span> on <span data-glossary-id="UT22084-060-005-689">voidness</span>; as interlocutor of the <span data-glossary-id="UT22084-060-005-515">Buddha</span>, a major figure in the <cite class="title break text-sa" lang="sa-LATN"><span data-glossary-id="UT22084-060-005-853">Prajñā­pāramitā­sūtras</span></cite>. See also <a href="end-notes.xhtml#UT22084-060-005-927" data-pointer-type="id">n.65</a>.</p></div></div></div></div><div id="4199d85f-0076-4db9-9fac-7d91076437ea" class="relative scroll-mt-20"><button type="button" id="radix-_R_6dd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.309</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sudatta</div><ul class="ml-4 list-disc"><li class="italic">legs par byin</li><li class="pt-1"><span class="font-tibetan text-base">ལེགས་པར་བྱིན།</span></li><li class="italic">sudatta</li></ul><div class="glossary-instance-definition"><p class="definition"><span class="ignore">Sudatta</span> was a great lay patron of the <span data-glossary-id="UT22084-060-005-515">Buddha</span> and philanthropist of <span data-glossary-id="UT22084-060-005-844">Śrāvastī</span>, and is more commonly called Anāthapiṇḍada (<em class="foreign text-wy" lang="bo-LATN">mgon med zas sbyin</em>); he known as “the foremost of donors” (<span data-glossary-id="UT22084-060-005-628">Pāli</span>; <em class="foreign text-pi" lang="pi-LATN">aggo dāyakānaṃ</em>). </p></div></div></div></div><div id="ef7b7c86-e10d-4773-b851-60836577eac2" class="relative scroll-mt-20"><button type="button" id="radix-_R_6dl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.310</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">sugata</div><ul class="ml-4 list-disc"><li class="italic">bde bar gshegs pa</li><li class="pt-1"><span class="font-tibetan text-base">བདེ་བར་གཤེགས་པ།</span></li><li class="italic">sugata</li></ul><div class="glossary-instance-definition"><p class="definition">One of the standard epithets of the <span data-glossary-id="UT22084-060-005-515">Buddha</span> <span data-glossary-id="UT22084-060-005-794">Śākyamuni</span> and other <span data-glossary-id="UT22084-060-005-515">buddhas</span>. According to Buddhaghoṣa, the term means that the way the <span data-glossary-id="UT22084-060-005-515">Buddha</span> went (Skt. <em class="foreign break text-sa" lang="sa-LATN">gata</em>) is good (Skt. <em class="foreign break text-sa" lang="sa-LATN">su</em>), and where he went (<em class="foreign break text-sa" lang="sa-LATN">gata</em>) is good (<em class="foreign break text-sa" lang="sa-LATN">su</em>). </p></div></div></div></div><div id="f09c5f12-b6bb-4937-be1d-7fb942862c5e" class="relative scroll-mt-20"><button type="button" id="radix-_R_6dt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.311</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sujāta</div><ul class="ml-4 list-disc"><li class="italic">mdzes par skyes</li><li class="pt-1"><span class="font-tibetan text-base">མཛེས་པར་སྐྱེས།</span></li><li class="italic">sujāta</li></ul></div></div></div><div id="0a487e8b-80f3-4d32-a273-53333cc425e1" class="relative scroll-mt-20"><button type="button" id="radix-_R_6e55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.312</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sumati</div><ul class="ml-4 list-disc"><li class="italic">rab kyi blo sgros</li><li class="pt-1"><span class="font-tibetan text-base">རབ་ཀྱི་བློ་སྒྲོས།</span></li><li class="italic">sumati</li></ul></div></div></div><div id="6399a2f2-b35d-4507-a09f-efeccb434a76" class="relative scroll-mt-20"><button type="button" id="radix-_R_6ed5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.313</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Sumeru</div><ul class="ml-4 list-disc"><li class="italic">ri’i rgyal po ri rab</li><li class="pt-1"><span class="font-tibetan text-base">རིའི་རྒྱལ་པོ་རི་རབ།</span></li><li class="italic">sumeru</li></ul><div class="glossary-instance-definition"><p>According to ancient Buddhist cosmology, this is the great mountain forming the axis of the universe. At its summit is Sudarśana, home of Śakra and his thirty-two gods, and on its flanks live the asuras. The mount has four sides facing the cardinal directions, each of which is made of a different precious stone. Surrounding it are several mountain ranges and the great ocean where the four principal island continents lie: in the south, Jambudvīpa (our world); in the west, Godānīya; in the north, Uttarakuru; and in the east, Pūrvavideha. Above it are the abodes of the desire realm gods. It is variously referred to as Meru, Mount Meru, Sumeru, and Mount Sumeru.</p></div></div></div></div><div id="6b6440dd-6d95-46dd-9c77-9f9241f4e84a" class="relative scroll-mt-20"><button type="button" id="radix-_R_6el5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.314</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">superknowledges</div><ul class="ml-4 list-disc"><li class="italic">mngon par shes pa</li><li class="pt-1"><span class="font-tibetan text-base">མངོན་པར་ཤེས་པ།</span></li><li class="italic">abhijñā</li></ul><div class="glossary-instance-definition"><p class="definition">Special powers of which five, acquired through the meditative <span data-glossary-id="UT22084-060-005-528">contemplations</span> (<em class="foreign break text-sa" lang="sa-LATN">dhyāna</em>), are considered mundane (<em class="foreign break text-sa" lang="sa-LATN">laukika</em>) and can be attained to some extent by <span data-glossary-id="UT22084-060-005-627">outsider</span> yogis as well as Buddhist <span data-glossary-id="UT22084-060-005-504">arhats</span> and <span data-glossary-id="UT22084-060-005-513">bodhisattvas</span>; and a sixth‍—being acquired through a <span data-glossary-id="UT22084-060-005-513">bodhisattva</span>’s realization, or by <span data-glossary-id="UT22084-060-005-515">buddhas</span> alone according to some accounts‍—is supramundane (<em class="foreign break text-sa" lang="sa-LATN">lokottara</em>). The first five are: <span data-glossary-id="UT22084-060-005-540">divine eye</span> or vision (<em class="foreign break text-sa" lang="sa-LATN">divyacakṣu</em>), divine hearing (<em class="foreign break text-sa" lang="sa-LATN">divyaśrotra</em>), knowledge of others’ minds (<em class="foreign break text-sa" lang="sa-LATN">paracittajñāna</em>), knowledge of former (and future) lives (<em class="foreign break text-sa" lang="sa-LATN">pūrva­[para]­nivāsānu­smṛti­jñāna</em>), and knowledge of magical operations (<em class="foreign break text-sa" lang="sa-LATN">ṛddhi­vidhi­jñāna</em>). The sixth, supramundane one is knowledge of the exhaustion of defilements (<em class="foreign break text-sa" lang="sa-LATN">āsravakṣaya­jñāna</em>).</p></div></div></div></div><div id="c65438ed-99d8-45cc-bc87-72f8f617eea5" class="relative scroll-mt-20"><button type="button" id="radix-_R_6et5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.315</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">sūtra</div><ul class="ml-4 list-disc"><li class="italic">mdo</li><li class="pt-1"><span class="font-tibetan text-base">མདོ།</span></li><li class="italic">sūtra</li></ul><div class="glossary-instance-definition"><p class="definition">In general Indian usage, the word for a highly condensed arrangement of verses that lends itself to memorization, serving as a basic text for a particular school of thought. In Buddhism, a scripture, in as much as it records either the direct speech of the <span data-glossary-id="UT22084-060-005-515">Buddha</span>, or the speech of someone manifestly inspired by him.</p></div></div></div></div><div id="0476be01-c230-48e7-b58c-592d8e4e8989" class="relative scroll-mt-20"><button type="button" id="radix-_R_6f55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.316</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Suvarnacūḍa</div><ul class="ml-4 list-disc"><li class="italic">gtsug na gser</li><li class="pt-1"><span class="font-tibetan text-base">གཙུག་ན་གསེར།</span></li><li class="italic">suvarnacūḍa</li></ul></div></div></div><div id="140c4504-5fe9-4a99-b7e9-b25cb2395c1a" class="relative scroll-mt-20"><button type="button" id="radix-_R_6fd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.317</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">tantra</div><ul class="ml-4 list-disc"><li class="italic">rgyud</li><li class="pt-1"><span class="font-tibetan text-base">རྒྱུད།</span></li><li class="italic">tantra</li></ul><div class="glossary-instance-definition"><p class="definition">Meaning “method” in general, in Buddhism it refers to an important body of literature dealing with a great variety of techniques of advanced <span data-glossary-id="UT22084-060-005-612">meditations</span>, incorporating rituals, <span data-glossary-id="UT22084-060-005-581">incantations</span>, and visualisations, that are stamped as esoteric until a practitioner has already attained a certain stage of ethical and philosophical development.</p></div></div></div></div><div id="f48b98da-0fa1-4d17-80bf-ea8056650eba" class="relative scroll-mt-20"><button type="button" id="radix-_R_6fl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.318</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Tarkajvāla</div><ul class="ml-4 list-disc"><li class="italic">rtog ge ’bar ba</li><li class="pt-1"><span class="font-tibetan text-base">རྟོག་གེ་འབར་བ།</span></li><li class="italic">tarkajvāla</li></ul><div class="glossary-instance-definition"><p class="definition">The “Blaze of Reason,” an important treatise of <span data-glossary-id="UT22084-060-005-709">Bhāvaviveka</span>’s, in which he critically discusses all the major philosophical <span data-glossary-id="UT22084-060-005-686">views</span> of his day.</p></div></div></div></div><div id="e708dad0-3dd7-49b0-8de3-b2e34b3f8d08" class="relative scroll-mt-20"><button type="button" id="radix-_R_6ft5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.319</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">tathāgata</div><ul class="ml-4 list-disc"><li class="italic">de bzhin gshegs pa</li><li class="pt-1"><span class="font-tibetan text-base">དེ་བཞིན་གཤེགས་པ།</span></li><li class="italic">tathāgata</li></ul><div class="glossary-instance-definition"><p class="definition">Lit. “Thus-gone” or “Thus-come,” (one who proceeds always in <span data-glossary-id="UT22084-060-005-527">consciousness</span> of the <span data-glossary-id="UT22084-060-005-683">ultimate</span> reality, or thatness of all things). A name of the <span data-glossary-id="UT22084-060-005-515">Buddha</span>.</p></div></div></div></div><div id="a72b2685-e31f-4aed-adff-8c13405c1c9f" class="relative scroll-mt-20"><button type="button" id="radix-_R_6g55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.320</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">ten powers</div><ul class="ml-4 list-disc"><li class="italic">stobs bcu</li><li class="pt-1"><span class="font-tibetan text-base">སྟོབས་བཅུ།</span></li><li class="italic">daśabala</li></ul><div class="glossary-instance-definition"><p class="definition">There are two different sets of <span class="ignore">ten powers</span>, those of the <span data-glossary-id="UT22084-060-005-515">Buddha</span> and those of <span data-glossary-id="UT22084-060-005-513">bodhisattvas</span>. Those of the <span data-glossary-id="UT22084-060-005-515">Buddha</span> consist of power from knowing right from wrong (<em class="foreign break text-sa" lang="sa-LATN">sthānāsthāna­jñāna­bala</em>); power from knowing the consequences of actions (<em class="foreign break text-sa" lang="sa-LATN">karma­vipāka­jñāna</em>-); power from knowing the various inclinations (of living beings) (<em class="foreign break text-sa" lang="sa-LATN">nānādhimukti­jñāna</em>-); power from knowing the various types (of living beings) (<em class="foreign break text-sa" lang="sa-LATN">nānādhātujñāna</em>-); power from knowing the degree of the capacities (of living beings) (<em class="foreign break text-sa" lang="sa-LATN">indriya­varāvara­jñāna</em>-); power from knowing the path that leads everywhere (<em class="foreign break text-sa" lang="sa-LATN">sarva­tragāmīmpratipat­jñāna</em>-); power from knowing the obscuration, <span data-glossary-id="UT22084-060-005-501">affliction</span>, and purification of all <span data-glossary-id="UT22084-060-005-528">contemplations</span>, <span data-glossary-id="UT22084-060-005-612">meditations</span>, <span data-glossary-id="UT22084-060-005-597">liberations</span>, <span data-glossary-id="UT22084-060-005-521">concentrations</span>, and <span data-glossary-id="UT22084-060-005-500">absorptions</span> (<em class="foreign break text-sa" lang="sa-LATN">sarva­dhyāna­vimokṣa­samādhi­samāpatti­saṃkleśa­vyavadāna­vyutthāna­jñāna</em>-); power from knowing his own former lives (<em class="foreign break text-sa" lang="sa-LATN">pūrva­nivāsānu­smṛti­jñāna</em>-); power from knowing deaths and future lives (<em class="foreign break text-sa" lang="sa-LATN">cyutyutpatti­jñāna</em>-); and power from knowing the exhaustion of defilements (<em class="foreign break text-sa" lang="sa-LATN">āsravakṣaya­jñāna</em>-). The latter set consists of the <span data-glossary-id="UT22084-060-005-513">bodhisattva</span>’s power of <span data-glossary-id="UT22084-060-005-631">positive thought</span> (<em class="foreign break text-sa" lang="sa-LATN">āśayabala</em>); power of <span data-glossary-id="UT22084-060-005-576">high resolve</span> (<em class="foreign break text-sa" lang="sa-LATN">adhyāśaya</em>-); power of application (<em class="foreign break text-sa" lang="sa-LATN">prayoga</em>-); power of <span data-glossary-id="UT22084-060-005-691">wisdom</span> (<em class="foreign break text-sa" lang="sa-LATN">prajña</em>-); power of prayer (<em class="foreign break text-sa" lang="sa-LATN">praṇidhāna</em>-); power of vehicle (<em class="foreign break text-sa" lang="sa-LATN">yāna</em>-); power of activities (<em class="foreign break text-sa" lang="sa-LATN">caryā</em>-); power of emanations (<em class="foreign break text-sa" lang="sa-LATN">vikurvaṇa</em>-); power of <span data-glossary-id="UT22084-060-005-551">enlightenment</span> (<em class="foreign break text-sa" lang="sa-LATN">bodhi</em>-); and power of turning the wheel of the <span data-glossary-id="UT22084-060-005-537">Dharma</span> (<em class="foreign break text-sa" lang="sa-LATN">dharma­cakra­pravartaṇa</em>-). </p></div></div></div></div><div id="a4e54557-1252-4772-8e09-48968f0d335a" class="relative scroll-mt-20"><button type="button" id="radix-_R_6gd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.321</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">ten sins</div><ul class="ml-4 list-disc"><li class="italic">mi dge ba bcu</li><li class="pt-1"><span class="font-tibetan text-base">མི་དགེ་བ་བཅུ།</span></li><li class="italic">daśākuśala</li></ul><div class="glossary-instance-definition"><p class="definition">These are the opposite of the <span data-glossary-id="UT22084-060-005-675">ten virtues</span>, and consist of killing, stealing, sexual misconduct, lying, harsh speech, backbiting, frivolous speech, covetousness, malice, and false <span data-glossary-id="UT22084-060-005-686">views</span>.</p></div></div></div></div><div id="c3747e64-0286-4485-9ae2-6c8123a8cdc6" class="relative scroll-mt-20"><button type="button" id="radix-_R_6gl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.322</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">ten virtues</div><ul class="ml-4 list-disc"><li class="italic">dge ba bcu</li><li class="pt-1"><span class="font-tibetan text-base">དགེ་བ་བཅུ།</span></li><li class="italic">kuśala</li></ul><div class="glossary-instance-definition"><p class="definition">These are the opposite of the <span data-glossary-id="UT22084-060-005-674">ten sins</span>, i.e., refraining from engaging in activities related to the <span data-glossary-id="UT22084-060-005-674">ten sins</span> and doing the opposite. There are three physical virtues: saving lives, giving, and sexual propriety. There are four verbal virtues: truthfulness, reconciling discussions, gentle speech, and religious speech. There are three mental virtues: loving attitude, generous attitude, and right <span data-glossary-id="UT22084-060-005-686">views</span>. The whole doctrine is collectively called the “tenfold path of good action” (<em class="foreign break text-sa" lang="sa-LATN">daśa­kuśala­karma­patha</em>). </p></div></div></div></div><div id="b5963753-f922-454c-a492-de9a236d39e5" class="relative scroll-mt-20"><button type="button" id="radix-_R_6gt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.323</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">thirty-seven aids to enlightenment</div><ul class="ml-4 list-disc"><li class="italic">byang chub kyi phyogs sum cu rtsa bdun gyi chos</li><li class="pt-1"><span class="font-tibetan text-base">བྱང་ཆུབ་ཀྱི་ཕྱོགས་སུམ་ཅུ་རྩ་བདུན་གྱི་ཆོས།</span></li><li class="italic">bodhi­pakṣika­dharma</li></ul><div class="glossary-instance-definition"><p class="definition">These consist of the <span data-glossary-id="UT22084-060-005-561">four foci of mindfulness</span>, the <span data-glossary-id="UT22084-060-005-567">four right efforts</span>, the <span data-glossary-id="UT22084-060-005-560">four bases of magical powers</span>, the <span data-glossary-id="UT22084-060-005-559">five spiritual faculties</span>, the <span data-glossary-id="UT22084-060-005-558">five powers</span>, the <span data-glossary-id="UT22084-060-005-654">seven factors of enlightenment</span>, and the <span data-glossary-id="UT22084-060-005-547">eightfold noble path</span>.</p></div></div></div></div><div id="f44c5f13-b5c1-4ec7-a2af-c4a948074de3" class="relative scroll-mt-20"><button type="button" id="radix-_R_6h55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.324</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">three realms</div><ul class="ml-4 list-disc"><li class="italic">khams gsum</li><li class="pt-1"><span class="font-tibetan text-base">ཁམས་གསུམ།</span></li><li class="italic">traidhātuka</li></ul><div class="glossary-instance-definition"><p class="definition">The three worlds or realms of which all universes are composed: of desire (<em class="foreign break text-sa" lang="sa-LATN">kāmadhātu</em>), of pure <span data-glossary-id="UT22084-060-005-610">matter</span> (<em class="foreign break text-sa" lang="sa-LATN">rūpadhātu</em>), and the <span data-glossary-id="UT22084-060-005-580">immaterial realm</span> (<em class="foreign break text-sa" lang="sa-LATN">ārūpyadhātu</em>). </p></div></div></div></div><div id="d576fbe3-9011-4ae4-9a17-b7c8a391981a" class="relative scroll-mt-20"><button type="button" id="radix-_R_6hd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.325</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">tolerance of the birthlessness of things, tolerance of ultimate birthlessness</div><ul class="ml-4 list-disc"><li class="italic">mi skye ba’i chos la bzod pa, mi skye ba’i chos la bzod pa</li><li class="pt-1"><span class="font-tibetan text-base">མི་སྐྱེ་བའི་ཆོས་ལ་བཟོད་པ།, མི་སྐྱེ་བའི་ཆོས་ལ་བཟོད་པ།</span></li><li class="italic">anutpattika­dharma­kṣānti, anutpattika­dharma­kṣānti</li></ul><div class="glossary-instance-definition"><p class="definition">Here we are concerned with the “intuitive tolerance of the <span data-glossary-id="UT22084-060-005-512">birthlessness</span> (or <span data-glossary-id="UT22084-060-005-584">incomprehensibility</span>) of all things” (<em class="foreign break text-sa" lang="sa-LATN">anutpattika­dharma­kṣānti</em> or <em class="foreign break text-sa" lang="sa-LATN">anupalabdhi­dharma­kṣānti</em>). To translate <em class="foreign break text-sa" lang="sa-LATN">kṣānti</em> as “knowledge” or “conviction” defeats entirely the Skt. usage and its intended sense: In the face of <span data-glossary-id="UT22084-060-005-512">birthlessness</span> or <span data-glossary-id="UT22084-060-005-584">incomprehensibility</span> (i.e., the <span data-glossary-id="UT22084-060-005-683">ultimate</span> reality), ordinary knowledge and especially convictions are utterly lost; this is because the mind loses objectifiability of anything and has nothing to grasp, and its process of coming to terms may be described only as a conscious cancellation through absolute negations of any false sense of certainty about anything. Through this tolerance, the mind reaches a stage where it can bear its lack of bearings, as it were, can endure this kind of extreme openness, this lack of any conviction, etc. There are three degrees of this tolerance‍—verbal (<em class="foreign break text-sa" lang="sa-LATN">ghoṣānugā</em>), conforming (<em class="foreign break text-sa" lang="sa-LATN">anulomikī</em>), and complete. See Introduction, <a href="UT22084-060-005-introduction.xhtml#UT22084-060-005-19" data-pointer-type="id">i.9</a>, and Lamotte, <cite class="title text-en" lang="en">Appendice</cite>, Note III. </p></div></div></div></div><div id="f1e6e8cc-6037-4186-8957-83f0739a3ca2" class="relative scroll-mt-20"><button type="button" id="radix-_R_6hl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.326</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">tolerance of the birthlessness of things, tolerance of ultimate birthlessness</div><ul class="ml-4 list-disc"><li class="italic">mi skye ba’i chos la bzod pa, mi skye ba’i chos la bzod pa</li><li class="pt-1"><span class="font-tibetan text-base">མི་སྐྱེ་བའི་ཆོས་ལ་བཟོད་པ།, མི་སྐྱེ་བའི་ཆོས་ལ་བཟོད་པ།</span></li><li class="italic">anutpattika­dharma­kṣānti, anutpattika­dharma­kṣānti</li></ul><div class="glossary-instance-definition"><p class="definition">See “<span data-glossary-id="UT22084-060-005-678">tolerance of the birthlessness of things</span>.”</p></div></div></div></div><div id="6cf08752-1b1f-4a66-a9c7-a593246c380d" class="relative scroll-mt-20"><button type="button" id="radix-_R_6ht5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.327</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">transcendental analysis</div><ul class="ml-4 list-disc"><li class="italic">lhag mthong</li><li class="pt-1"><span class="font-tibetan text-base">ལྷག་མཐོང་།</span></li><li class="italic">vipaśyana</li></ul><div class="glossary-instance-definition"><p class="definition">This is paired with “<span data-glossary-id="UT22084-060-005-614">mental quiescence</span>” (see entry). In general “<span data-glossary-id="UT22084-060-005-612">meditation</span>” is too often understood as only the types of practices categorized as “quietistic”‍—which eschew objects, learning, analysis, discrimination, etc., and lead only to the attainment of temporary peace and one-pointedness. However, in order to reach any high realization, such as the absence of a personal <span data-glossary-id="UT22084-060-005-649">self</span>, the absence of a <span data-glossary-id="UT22084-060-005-649">self</span> in phenomena, or <span data-glossary-id="UT22084-060-005-689">voidness</span>, “<span class="ignore">transcendental analysis</span>,” with its analytical penetration to the nature of <span data-glossary-id="UT22084-060-005-683">ultimate</span> reality, is indispensable. The analysis is called “transcendental” because it does not accept anything it sees as it appears. Instead, through analytic examination, it penetrates to its deeper reality, going ever deeper in infinite penetration until tolerance is reached. All apparently <span class="ignore">self</span>-sufficient objects are seen through and their truth-status is rejected‍—first conceptually and finally perceptually, at buddhahood. Thus “<span data-glossary-id="UT22084-060-005-612">meditation</span>,” to be efficacious, must include both <span data-glossary-id="UT22084-060-005-614">mental quiescence</span> (<em class="foreign break text-sa" lang="sa-LATN">śamatha</em>), and <span class="ignore">transcendental analysis</span> (<em class="foreign break text-sa" lang="sa-LATN">vipaśyana</em>) in integrated combination. </p></div></div></div></div><div id="21b59f56-882b-4762-9757-3b8990d8b21e" class="relative scroll-mt-20"><button type="button" id="radix-_R_6i55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.328</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">transcendental practice</div><ul class="ml-4 list-disc"><li class="italic">ye shes sgrub pa</li><li class="pt-1"><span class="font-tibetan text-base">ཡེ་ཤེས་སྒྲུབ་པ།</span></li><li class="italic">jñāna­pratipatti</li></ul><div class="glossary-instance-definition"><p class="definition"><span class="ignore">Transcendental practice</span>, as opposed to practice at an earlier stage.</p></div></div></div></div><div id="eaf5a861-85d2-4977-ae47-2981177eaf53" class="relative scroll-mt-20"><button type="button" id="radix-_R_6id5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.329</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Trāyastriṃśa</div><ul class="ml-4 list-disc"><li class="italic">sum cu rtsa gsum pa</li><li class="pt-1"><span class="font-tibetan text-base">སུམ་ཅུ་རྩ་གསུམ་པ།</span></li><li class="italic">trāyastriṃśa</li></ul><div class="glossary-instance-definition"><p class="definition">The Heaven of the “Thirty-Three,” second level of the desire-realm, located on top of Mount <span data-glossary-id="UT22084-060-005-845">Sumeru</span> in the Buddhist cosmology.</p></div></div></div></div><div id="62829850-6321-48fc-9648-fba6953c3139" class="relative scroll-mt-20"><button type="button" id="radix-_R_6il5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.330</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Tsong Khapa</div><ul class="ml-4 list-disc"><li class="italic">tsong kha pa</li><li class="pt-1"><span class="font-tibetan text-base">ཙོང་ཁ་པ།</span></li></ul><div class="glossary-instance-definition"><p class="definition">(1357-1419). One of the greatest of all Tibetan Lamas, his saintliness was evidenced in his altruistic deeds that caused a renaissance in Tibet, his <span data-glossary-id="UT22084-060-005-551">enlightenment</span> in the extraordinary subtlety and profundity of his thought, and his scholarship in the breadth and clarity of his voluminous writings.</p></div></div></div></div><div id="75f5ae84-90f1-481d-a135-617655cf457f" class="relative scroll-mt-20"><button type="button" id="radix-_R_6it5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.331</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Tuṣita</div><ul class="ml-4 list-disc"><li class="italic">dga’ ldan</li><li class="pt-1"><span class="font-tibetan text-base">དགའ་ལྡན།</span></li><li class="italic">tuṣita</li></ul><div class="glossary-instance-definition"><p class="definition">A heaven, the fourth level of the heavens of the <span data-glossary-id="UT22084-060-005-637">realm of desire</span>, and the last stopping place of a <span data-glossary-id="UT22084-060-005-515">buddha</span> before his descent and reincarnation on earth; at present the abode of the future <span data-glossary-id="UT22084-060-005-515">Buddha</span> <span data-glossary-id="UT22084-060-005-743">Maitreya</span>.</p></div></div></div></div><div id="f0e037b0-dfc3-4e05-94ad-bc0d2dfc2cfb" class="relative scroll-mt-20"><button type="button" id="radix-_R_6j55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.332</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">twelve ascetic practices</div><ul class="ml-4 list-disc"><li class="italic">sbyangs pa’i yon tan bcu gnyis</li><li class="pt-1"><span class="font-tibetan text-base">སྦྱངས་པའི་ཡོན་ཏན་བཅུ་གཉིས།</span></li><li class="italic">dvādaśadhūtaguṇāḥ</li></ul><div class="glossary-instance-definition"><p class="definition">These consist of (1) wearing rags (<em class="foreign break text-sa" lang="sa-LATN">pāṃśukūlika</em>, <em class="foreign text-wy" lang="bo-LATN">phyag dar khrod pa</em>), (2) (in the form of only) three religious robes (<em class="foreign break text-sa" lang="sa-LATN">traicīvarika</em>, <em class="foreign text-wy" lang="bo-LATN">chos gos gsum</em>), (3) (coarse in texture as) garments of felt (<em class="foreign break text-sa" lang="sa-LATN">nāma[n]tika</em>, <em class="foreign text-wy" lang="bo-LATN">’phyings pa pa</em>), (4) eating by alms (<em class="foreign break text-sa" lang="sa-LATN">paiṇḍapātika</em>, <em class="foreign text-wy" lang="bo-LATN">bsod snyoms pa</em>), (5) having a single mat to sit on (<em class="foreign break text-sa" lang="sa-LATN">aikāsanika</em>, <em class="foreign text-wy" lang="bo-LATN">stan gcig pa</em>), (6) not eating after noon (<em class="foreign break text-sa" lang="sa-LATN">khalu paścād bhaktika</em>, <em class="foreign text-wy" lang="bo-LATN">zas phyis mi len pa</em>), (7) living alone in the forest (<em class="foreign break text-sa" lang="sa-LATN">āraṇyaka</em>, <em class="foreign text-wy" lang="bo-LATN">dgon pa pa</em>), (8) living at the base of a tree (<em class="foreign break text-sa" lang="sa-LATN">vṛkṣamūlika</em>, <em class="foreign text-wy" lang="bo-LATN">shing drungs pa</em>), (9) living in the open (not under a roof) (<em class="foreign break text-sa" lang="sa-LATN">ābhyavakāśika</em>, <em class="foreign text-wy" lang="bo-LATN">bla gab med pa</em>), (10) frequenting burning grounds (Indian equivalent of cemeteries) (<em class="foreign break text-sa" lang="sa-LATN">śmāśānika</em>, <em class="foreign text-wy" lang="bo-LATN">dur khrod pa</em>), (11) sleeping sitting up (in meditative posture) (<em class="foreign break text-sa" lang="sa-LATN">naiṣadika</em>, <em class="foreign text-wy" lang="bo-LATN">cog bu pa</em>), and (12) accepting whatever seating position is offered (<em class="foreign break text-sa" lang="sa-LATN">yāthāsaṃstarika</em>, <em class="foreign text-wy" lang="bo-LATN">gzhi ji bzhin pa</em>). <cite class="title break text-sa" lang="sa-LATN">Mahāvyutpatti</cite>, 1127-39.</p></div></div></div></div><div id="784c8158-9e46-4484-9152-e0d06cd46afc" class="relative scroll-mt-20"><button type="button" id="radix-_R_6jd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.333</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">ultimate</div><ul class="ml-4 list-disc"><li class="italic">don dam pa</li><li class="pt-1"><span class="font-tibetan text-base">དོན་དམ་པ།</span></li><li class="italic">paramārtha</li></ul><div class="glossary-instance-definition"><p class="definition">“<span class="ignore">Ultimate</span>” is preferable to the usual “absolute” because it carries fewer connotations than “absolute”‍—which, however, when understood logically, is also correct. It is contrasted with “superficial” (<em class="foreign break text-sa" lang="sa-LATN">vyavahāra</em>) or “relative” (<em class="foreign break text-sa" lang="sa-LATN">samvṛtti</em>) to give the two types, or “levels.,” of truth. It is synonymous with <span class="ignore">ultimate</span> reality, the uncompounded, <span data-glossary-id="UT22084-060-005-689">voidness</span>, reality, limit of reality, absolute, <span data-glossary-id="UT22084-060-005-621">nirvāṇa</span>, <span class="ignore">ultimate</span> <span data-glossary-id="UT22084-060-005-597">liberation</span>, infinity, permanence, eternity, independence, etc. It also has the soteriological sense of “sacred” as opposed to “profane” as is conveyed by its literal rendering “supreme” (<em class="foreign break text-sa" lang="sa-LATN">parama</em>) “object” (<em class="foreign break text-sa" lang="sa-LATN">artha</em>). </p></div></div></div></div><div id="fb139747-a249-489b-947e-79301865b6d6" class="relative scroll-mt-20"><button type="button" id="radix-_R_6jl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.334</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">ultimate realm</div><ul class="ml-4 list-disc"><li class="italic">chos kyi dbyings</li><li class="pt-1"><span class="font-tibetan text-base">ཆོས་ཀྱི་དབྱིངས།</span></li><li class="italic">dharmadhātu</li></ul><div class="glossary-instance-definition"><p class="definition">This compound is actually metaphorical in sense, with (at least) two interpretations possible because of ambiguities in the word <em class="foreign break text-sa" lang="sa-LATN">dhātu</em>. <em class="foreign break text-sa" lang="sa-LATN">Dhātu</em> as in the expression <em class="foreign break text-sa" lang="sa-LATN">kāmadhātu</em> (desire-realm), may mean “realm”; or it may mean “<span data-glossary-id="UT22084-060-005-548">element</span>,” as in the eighteen <span data-glossary-id="UT22084-060-005-548">elements</span> (see entry), where it is explained as analogous to a mineral such as copper. Thus the realm of the <span data-glossary-id="UT22084-060-005-537">Dharma</span> is the dharmakāyā, the pure source and sphere of the <span data-glossary-id="UT22084-060-005-537">Dharma</span>. And the <span data-glossary-id="UT22084-060-005-548">element</span> of the <span data-glossary-id="UT22084-060-005-537">Dharma</span> is like a mine from which the verbal <span data-glossary-id="UT22084-060-005-537">Dharma</span>, the <span data-glossary-id="UT22084-060-005-515">buddha</span>-qualities, and the <span data-glossary-id="UT22084-060-005-691">wisdoms</span> of the <span data-glossary-id="UT22084-060-005-504">arhats</span> and <span data-glossary-id="UT22084-060-005-513">bodhisattvas</span> are culled. This is metaphorical, as <span data-glossary-id="UT22084-060-005-1257">Vimalakīrti</span> would remind us, because the <span data-glossary-id="UT22084-060-005-537">Dharma</span>, the <span data-glossary-id="UT22084-060-005-683">ultimate</span>, is <em class="emph">ultimately</em> not a particular place; it is immanent in all places, being the actuality and <span data-glossary-id="UT22084-060-005-683">ultimate</span> condition of all things and being relatively no one thing except, like <span data-glossary-id="UT22084-060-005-689">voidness</span>, the supremely beneficent of concepts. </p></div></div></div></div><div id="6659d907-9318-46a8-9a7d-820e6a5d897f" class="relative scroll-mt-20"><button type="button" id="radix-_R_6jt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.335</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">unmoving</div><ul class="ml-4 list-disc"><li class="italic">mi g.yo ba</li><li class="pt-1"><span class="font-tibetan text-base">མི་གཡོ་བ།</span></li><li class="italic">āniñjya</li></ul><div class="glossary-instance-definition"><p class="definition">Referring to actions, this term signifies the actions of beings in the subtle god-realms of form and formlessness that can only lead to rebirth in the same realm in the next <span class="ignore">life</span>.</p></div></div></div></div><div id="3cdcaa9d-3979-4ae9-a327-19723393a25f" class="relative scroll-mt-20"><button type="button" id="radix-_R_6k55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.336</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Upāli</div><ul class="ml-4 list-disc"><li class="italic">nye bar ’khor</li><li class="pt-1"><span class="font-tibetan text-base">ཉེ་བར་འཁོར།</span></li><li class="italic">upāli</li></ul><div class="glossary-instance-definition"><p class="definition">Disciple; originally the barber of the <span data-glossary-id="UT22084-060-005-793">Śākya</span> princes, ordained together with them, and noted as an expert on the <span data-glossary-id="UT22084-060-005-688">Vinaya</span>. </p><p class="definition">(See also <a href="end-notes.xhtml#UT22084-060-005-942" data-pointer-type="id">n.80</a>).</p></div></div></div></div><div id="e9c61804-d922-4a99-88ea-836faa6fd3c4" class="relative scroll-mt-20"><button type="button" id="radix-_R_6kd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.337</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vaiśālī</div><ul class="ml-4 list-disc"><li class="italic">yangs pa can</li><li class="pt-1"><span class="font-tibetan text-base">ཡངས་པ་ཅན།</span></li><li class="italic">vaiśālī</li></ul><div class="glossary-instance-definition"><p class="definition">Great city during the <span data-glossary-id="UT22084-060-005-515">Buddha</span>’s time, capital of the <span data-glossary-id="UT22084-060-005-599">Licchavi</span> republic; at present the town of Basarh, Muzaffarpur district, in Tirhut, Bihar province of India. (See Lamotte, pp. 80-83; p. 97, n. 1.).</p></div></div></div></div><div id="ab351a34-b865-4870-9b78-70b27c909293" class="relative scroll-mt-20"><button type="button" id="radix-_R_6kl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.338</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vajrapāṇi</div><ul class="ml-4 list-disc"><li class="italic">phyag na rdo rje</li><li class="pt-1"><span class="font-tibetan text-base">ཕྱག་ན་རྡོ་རྗེ།</span></li><li class="italic">vajrapāṇi</li></ul><div class="glossary-instance-definition"><p class="definition">An important <span data-glossary-id="UT22084-060-005-513">bodhisattva</span>, “Wielder of the Thunderbolt,” whose compassion is to manifest in a terrific form to protect the practicers of the <span data-glossary-id="UT22084-060-005-537">Dharma</span> from harmful influences.</p></div></div></div></div><div id="d1321bbd-7a4b-4a02-90f9-2a0661cc9c6f" class="relative scroll-mt-20"><button type="button" id="radix-_R_6kt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.339</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vasubandhu</div><ul class="ml-4 list-disc"><li class="italic">dbyig gnyen</li><li class="pt-1"><span class="font-tibetan text-base">དབྱིག་གཉེན།</span></li><li class="italic">vasubandhu</li></ul><div class="glossary-instance-definition"><p class="definition">(Fourth century). The younger brother of <span data-glossary-id="UT22084-060-005-705">Āryāsaṅga</span>, he was one of the greatest scholars in Buddhist history, author of the <cite class="title break text-sa" lang="sa-LATN"><span data-glossary-id="UT22084-060-005-849">Abhi­dharma­kośa</span></cite>, the most definitive work on the <span data-glossary-id="UT22084-060-005-498">Abhidharma</span>, and later of numerous important works on the <span data-glossary-id="UT22084-060-005-687">Vijñānavāda</span> philosophy. </p></div></div></div></div><div id="a22977d5-fea2-4b92-b784-626f44c02c70" class="relative scroll-mt-20"><button type="button" id="radix-_R_6l55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.340</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Veda</div><ul class="ml-4 list-disc"><li class="italic">rig byed</li><li class="pt-1"><span class="font-tibetan text-base">རིག་བྱེད།</span></li><li class="italic">veda</li></ul><div class="glossary-instance-definition"><p class="definition">Name of the ancient sacred Scriptures of Brahmanism, most famous of which is the <cite class="title break text-sa" lang="sa-LATN">Ṛg Veda</cite>. </p></div></div></div></div><div id="aed81034-62e0-40a0-a937-47ebe2130809" class="relative scroll-mt-20"><button type="button" id="radix-_R_6ld5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.341</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vicaraṇa</div><ul class="ml-4 list-disc"><li class="italic">rnam par sbyong ba</li><li class="pt-1"><span class="font-tibetan text-base">རྣམ་པར་སྦྱོང་བ།</span></li><li class="italic">vicaraṇa</li></ul><div class="glossary-instance-definition"><p class="definition">The name of the long-past eon during which the <span data-glossary-id="UT22084-060-005-515">Buddha</span> <span data-glossary-id="UT22084-060-005-708">Bhaiṣajyarāja</span> presided in the <span data-glossary-id="UT22084-060-005-516">buddhafield</span> <span data-glossary-id="UT22084-060-005-742">Mahāvyūha</span>.</p></div></div></div></div><div id="cd2c19fc-31cc-4130-b06b-088728250db5" class="relative scroll-mt-20"><button type="button" id="radix-_R_6ll5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.342</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vidyuddeva</div><ul class="ml-4 list-disc"><li class="italic">glog gi lha</li><li class="pt-1"><span class="font-tibetan text-base">གློག་གི་ལྷ།</span></li><li class="italic">vidyuddeva</li></ul></div></div></div><div id="706840df-0c20-4c5d-94a4-6b4383506ee4" class="relative scroll-mt-20"><button type="button" id="radix-_R_6lt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.343</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">view</div><ul class="ml-4 list-disc"><li class="italic">lta ba</li><li class="pt-1"><span class="font-tibetan text-base">ལྟ་བ།</span></li><li class="italic">dṛṣṭi</li></ul><div class="glossary-instance-definition"><p class="definition">This means a mental conviction or opinion that conditions the mind and determines how it sees reality.</p></div></div></div></div><div id="cda360b1-68ed-4f1f-a2b2-b87d209292db" class="relative scroll-mt-20"><button type="button" id="radix-_R_6m55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.344</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vijñānavāda</div><ul class="ml-4 list-disc"><li class="italic">rnam par shes pa smra ba</li><li class="pt-1"><span class="font-tibetan text-base">རྣམ་པར་ཤེས་པ་སྨྲ་བ།</span></li><li class="italic">vijñānavāda</li></ul><div class="glossary-instance-definition"><p class="definition">The school of “<span class="ignore">Consciousness</span>-Only” founded by <span data-glossary-id="UT22084-060-005-743">Maitreya</span> and <span data-glossary-id="UT22084-060-005-705">Āryāsaṅga</span>, which shares with the <span data-glossary-id="UT22084-060-005-603">Mādhyamika</span> most of the philosophical techniques of the <span data-glossary-id="UT22084-060-005-605">Mahāyāna</span>, while differing on the interpretation of the profound meaning of <span data-glossary-id="UT22084-060-005-689">voidness</span>, or the <span data-glossary-id="UT22084-060-005-683">ultimate</span> reality.</p></div></div></div></div><div id="40a13f90-1efa-4c66-b539-68fe7a605aba" class="relative scroll-mt-20"><button type="button" id="radix-_R_6md5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.345</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vikurvaṇarāja</div><ul class="ml-4 list-disc"><li class="italic">rnam par ’phrul pa’i rgyal po</li><li class="pt-1"><span class="font-tibetan text-base">རྣམ་པར་འཕྲུལ་པའི་རྒྱལ་པོ།</span></li><li class="italic">vikurvaṇarāja</li></ul></div></div></div><div id="b9ca12fb-e3be-4924-ad28-b09e52530acb" class="relative scroll-mt-20"><button type="button" id="radix-_R_6ml5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.346</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vimalakīrti</div><ul class="ml-4 list-disc"><li class="italic">dri ma med grags pa</li><li class="pt-1"><span class="font-tibetan text-base">དྲི་མ་མེད་གྲགས་པ།</span></li><li class="italic">Vimalakīrti</li></ul><div class="glossary-instance-definition"><p class="definition">The wealthy <span data-glossary-id="UT22084-060-005-599">Licchavi</span> <span data-glossary-id="UT22084-060-005-595">layman</span>, from the city of <span data-glossary-id="UT22084-060-005-848">Vaiśālī</span>, ranked as one of the great <span data-glossary-id="UT22084-060-005-513">bodhisattvas</span>. The main protagonist of this <span data-glossary-id="UT22084-060-005-670">sūtra</span>.</p></div></div></div></div><div id="59bb2f56-d05e-43d5-a5a0-fe73d5597c93" class="relative scroll-mt-20"><button type="button" id="radix-_R_6mt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.347</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Vinaya</div><ul class="ml-4 list-disc"><li class="italic">’dul ba</li><li class="pt-1"><span class="font-tibetan text-base">འདུལ་བ།</span></li><li class="italic">vinaya</li></ul><div class="glossary-instance-definition"><p class="definition">One of the three Piṭakas, or “Baskets,” of the Buddhist canon; the one dealing specifically with the code of the monastic disipline. </p></div></div></div></div><div id="4ee3fa2c-4160-40ac-ad4c-1bf7f218e1ef" class="relative scroll-mt-20"><button type="button" id="radix-_R_6n55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.348</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">voidness of voidness</div><ul class="ml-4 list-disc"><li class="italic">stong pa nyid kyi stong pa nyid</li><li class="pt-1"><span class="font-tibetan text-base">སྟོང་པ་ཉིད་ཀྱི་སྟོང་པ་ཉིད།</span></li><li class="italic">śūnyatāśūnyatā</li></ul><div class="glossary-instance-definition"><p class="definition">The <span class="ignore">voidness of voidness</span>, an important concept that indicates the <span data-glossary-id="UT22084-060-005-683">ultimate</span> conceptuality of all terms, even those for the <span data-glossary-id="UT22084-060-005-683">ultimate</span>, to avoid the major error of absolutising the <span data-glossary-id="UT22084-060-005-683">ultimate</span>.</p></div></div></div></div><div id="06bddbe7-1139-4231-a993-4bc07054b09a" class="relative scroll-mt-20"><button type="button" id="radix-_R_6nd5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.349</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">win</div><ul class="ml-4 list-disc"><li class="italic">sdud pa</li><li class="pt-1"><span class="font-tibetan text-base">སྡུད་པ།</span></li><li class="italic">samgraha</li></ul><div class="glossary-instance-definition"><p class="definition">Lit. “collect,” i.e., gather together into the <span data-glossary-id="UT22084-060-005-605">Mahāyāna</span>.</p></div></div></div></div><div id="38971298-6f62-48f0-b271-36261568d441" class="relative scroll-mt-20"><button type="button" id="radix-_R_6nl5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.350</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">wisdom</div><ul class="ml-4 list-disc"><li class="italic">shes rab</li><li class="pt-1"><span class="font-tibetan text-base">ཤེས་རབ།</span></li><li class="italic">prajñā</li></ul></div></div></div><div id="9c3e4b37-8479-4dee-a2a4-dc01c83a6254" class="relative scroll-mt-20"><button type="button" id="radix-_R_6nt5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.351</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">wishlessness</div><ul class="ml-4 list-disc"><li class="italic">smon pa med pa</li><li class="pt-1"><span class="font-tibetan text-base">སྨོན་པ་མེད་པ།</span></li><li class="italic">apraṇihitatā</li></ul><div class="glossary-instance-definition"><p class="definition">Third of the Three Doors of <span data-glossary-id="UT22084-060-005-597">Liberation</span> (see glossary). Objectively, it is equivalent to <span data-glossary-id="UT22084-060-005-689">voidness</span>; subjectively, it is the outcome of the holy <span data-glossary-id="UT22084-060-005-571">gnosis</span> of <span data-glossary-id="UT22084-060-005-689">voidness</span> as the realization of the <span data-glossary-id="UT22084-060-005-683">ultimate</span> lack of anything to wish for, whether <span data-glossary-id="UT22084-060-005-689">voidness</span> itself, or even Buddhahood. See “<span data-glossary-id="UT22084-060-005-550">emptiness</span>.”</p></div></div></div></div><div id="d4a6a09d-8d75-48cd-91f4-20308ea589fb" class="relative scroll-mt-20"><button type="button" id="radix-_R_6o55anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.352</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">Xuanzang</div><ul class="ml-4 list-disc"></ul><div class="glossary-instance-definition"><p class="definition">Seventh century Chinese scholar. One of the greatest translators in world history, he traveled to India, where he lived for many years, studying Sanskrit and all the sciences of the day. On his return to China he translated many volumes of important philosophical and religious works. He translated this <span data-glossary-id="UT22084-060-005-670">sūtra</span> in 650.</p></div></div></div></div><div id="38387383-1d37-4070-baa8-57f918748825" class="relative scroll-mt-20"><button type="button" id="radix-_R_6od5anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">g.353</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="flex gap-1 flex-col p-0 @c/sidebar:-mt-0.5"><div class="text-secondary font-sans text-base font-bold">yakṣa</div><ul class="ml-4 list-disc"><li class="italic">gnod sbyin</li><li class="pt-1"><span class="font-tibetan text-base">གནོད་སྦྱིན།</span></li><li class="italic">yakṣa</li></ul><div class="glossary-instance-definition"><p>A class of nonhuman beings who inhabit forests, mountainous areas, and other natural spaces, or serve as guardians of villages and towns, and may be propitiated for health, wealth, protection, and other boons, or controlled through magic. According to tradition, their homeland is in the north, where they live under the rule of the Great King Vaiśravaṇa.</p><p> Several members of this class have been deified as gods of wealth (these include the just-mentioned Vaiśravaṇa) or as bodhisattva generals of yakṣa armies, and have entered the Buddhist pantheon in a variety of forms, including, in tantric Buddhism, those of wrathful deities.</p></div></div></div></div></div></div></div><div data-state="inactive" data-orientation="horizontal" role="tabpanel" aria-labelledby="radix-_R_2npftt6btb_-trigger-bibliography" id="radix-_R_2npftt6btb_-content-bibliography" tabindex="0" data-slot="tabs-content" class="mt-2 ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 pb-8 data-[state=inactive]:hidden"><div class="flex flex-col w-full"><div id="bibliography" class="relative scroll-mt-20"><button type="button" id="radix-_R_2nanpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4 @c/sidebar:mt-5 mt-6">b.</button><div class="passage pl-6 @c/sidebar:pl-4"><h2 class="font-serif font-light text-primary scroll-m-20 text-xl @c/sidebar:mt-4 mt-6 @c/sidebar:pb-2 pb-3 @c/sidebar:text-left text-center section-title">Bibliography</h2></div></div><div class="mt-3 flex flex-col gap-6"><div class="flex flex-col gap-4"><div id="Tibetan and Sanskrit sources-0" class="relative scroll-mt-20"><button type="button" id="radix-_R_ad7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4 @c/sidebar:mt-0.5 mt-4">b.1</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="text-secondary font-sans text-base font-bold">Tibetan and Sanskrit sources</div></div></div><div id="13ac6994-4acd-4d7b-8816-ffe963c1bc56" class="relative scroll-mt-20"><button type="button" id="radix-_R_1cd7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.1.1</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p> <em>’phags pa dri ma med par grags pas bstan pa zhes bya ba theg pa chen po’i mdo </em> (<em>Ārya­vimala­kīrti­nirdeśa­nāma­mahā­yāna­sūtra</em>). Toh. 176, Degé Kangyur, vol. 60 (mdo sde, ma), folios 175b–239a. </p></div></div></div><div id="46439e84-baeb-4a66-8dcf-c7a96d627dac" class="relative scroll-mt-20"><button type="button" id="radix-_R_1kd7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.1.2</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p> <em>’phags pa dri ma med par grags pas bstan pa zhes bya ba theg pa chen po’i mdo </em> (<em>Ārya­vimala­kīrti­nirdeśa­nāma­mahā­yāna­sūtra</em>). [Comparative Edition of the Kangyur], krung go’i bod rig pa zhib ’jug ste gnas kyi bka’ bstan dpe sdur khang (The Tibetan Tripitaka Collation Bureau of the China Tibetology Research Center). 108 volumes. Beijing: krung go’i bod rig pa dpe skrun khang (China Tibetology Publishing House), 2006–2009, vol. 60, pp. 476–635. </p></div></div></div><div id="6b544210-2614-4b95-b653-cf7a457551db" class="relative scroll-mt-20"><button type="button" id="radix-_R_1sd7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.1.3</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p> Study Group on Buddhist Sanskrit Literature. <em>梵文維摩經 : ポタラ宮所蔵写本に基づく校訂</em>. <em>Vimalakīrtinirdeśa, A Sanskrit Edition Based upon the Manuscript Newly Found at the Potala Palace</em>. Tokyo: Institute for Comprehensive Studies of Buddhism, Taishō Daigaku Shuppankai, 2006. </p></div></div></div></div><div class="flex flex-col gap-4"><div id="Translations of this text-1" class="relative scroll-mt-20"><button type="button" id="radix-_R_al7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4 @c/sidebar:mt-0.5 mt-4">b.2</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="text-secondary font-sans text-base font-bold">Translations of this text</div></div></div><div id="3580ed8b-4d8d-4502-9aae-b641ab4eafe4" class="relative scroll-mt-20"><button type="button" id="radix-_R_1cl7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.2.1</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p> Lamotte, Étienne. <em>L’Enseignement de Vimalakīrti</em> (<em>Vimala­kīrti­nirdeśa</em>). Louvain: Université de Louvain, Institut Orientaliste, 1962. [Translated from Tib. and Xuanzang’s Chinese]. </p></div></div></div><div id="b773fffa-3a05-409a-b2da-8ef77ba0436f" class="relative scroll-mt-20"><button type="button" id="radix-_R_1kl7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.2.2</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p> Luk, Charles (tr.). <em>The Vimalakīrti Nirdeśa Sūtra</em>. Berkeley and London: Shambhala, 1972. [Translated from Kumārajīva’s Chinese]. </p></div></div></div><div id="76ad3dd9-0bc2-4d1a-97f8-0088de40f755" class="relative scroll-mt-20"><button type="button" id="radix-_R_1sl7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.2.3</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p> McRae, John R. (tr.). <em>The Vimalakīrti Sūtra</em>. Berkeley: Numata Center for Buddhist Translation and Research, 2004. [Translated from Kumārajīva’s Chinese]. </p></div></div></div></div><div class="flex flex-col gap-4"><div id="Canonical references-2" class="relative scroll-mt-20"><button type="button" id="radix-_R_at7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4 @c/sidebar:mt-0.5 mt-4">b.3</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="text-secondary font-sans text-base font-bold">Canonical references</div></div></div><div id="d58c8876-8cb7-444e-9fb5-8c1d5707fc43" class="relative scroll-mt-20"><button type="button" id="radix-_R_2ct7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.1</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p> <em>Saṃdhi­nirmocana­sūtra</em>. Sanskrit text: see Lamotte 1935. Tibetan text: <em>’phags pa dgongs pa nges par ’grel pa zhes bya ba theg pa chen po’i mdo</em>, Toh 106, Degé Kangyur vol. 49 (mdo sde, tsha), folios 1b–55b. English translation: see Buddhavacana Translation Group.</p></div></div></div><div id="23a4d040-59f0-42e0-b84f-b78472505675" class="relative scroll-mt-20"><button type="button" id="radix-_R_2kt7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.2</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p> <em>Saddharma­puṇḍarīka</em>. Sanskrit text: see Vaidya 1960, Wogihara et al. 1934-1935. Tibetan text: <em>dpal dam chos pad ma dkar po zhes bya ba theg pa chen po’i mdo</em>, Toh 113, Degé Kangyur, vol. 51 (mdo sed, ja), folios 1b–180b. English translations: see Kern 1884; Roberts, 2018. </p></div></div></div><div id="d7c3e72e-1be1-47fe-a1a2-3b97d2b8eba2" class="relative scroll-mt-20"><button type="button" id="radix-_R_2st7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.3</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p> <em>Guhya­samāja­tantra</em>. Sanskrit text: see Bagchi 1965. Tibetan text: <em>de bzhin gshegs pa thams cad kyi sku gsung thugs kyi gsang chen gsang ba ’dus pa zhes bya ba brtag pa’i rgyal po chen po</em>, Toh 442, Degé Kangyur vol. 81 (rgyud ’bum, ca), folios 89b–148a. </p></div></div></div><div id="452ad89f-23fc-467c-90f1-013cd6e84a97" class="relative scroll-mt-20"><button type="button" id="radix-_R_34t7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.4</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p> <em>yul ’khor skyong gis zhus pa</em> (<em>Rāṣṭrapālaparipṛcchā</em>). Toh 62, Degé Kangyur vol. 42 (dkon brtsegs, nga), folios 227.a–257.a. English translation in Vienna Buddhist Translation Studies Group (2021). </p></div></div></div><div id="ec447c50-acea-4aa1-bbd4-233512d70923" class="relative scroll-mt-20"><button type="button" id="radix-_R_3ct7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.5</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p> Candrakīrti. <em>Prasannapadā­nāma­mūla­madhyamaka­vṛtti</em>. Sanskrit text: see La Vallée Poussin 1903-1912. Tibetan text: <em>dbu ma rtsa ba’i ’grel pa tshig gsal ba</em>, Toh 3860, Degé Tengyur vol. 102 (dbu ma, ’a), folios 1b–200a. </p></div></div></div><div id="5edc09f3-d561-4d7d-adb0-a4328084dabe" class="relative scroll-mt-20"><button type="button" id="radix-_R_3kt7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.6</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p> Nāgārjuna. <em>Prajña­nāma­mūla­mādhyamaka­kārikā</em>. Sanskrit text and translation: see Inada 1970. Tibetan text: dbu ma rtsa ba’i tshig le’ur byas pa shes rab, Toh 3824, Degé Tengyur vol. 96 (dbu ma, tsa), folios 1b–19a. </p></div></div></div><div id="3ed80670-400f-4caa-b0b4-76bcc27d431b" class="relative scroll-mt-20"><button type="button" id="radix-_R_3st7anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.3.7</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p> Śāntideva. <em>Śikṣāsamuccaya</em>. Sanskrit text: see Vaidya, 1961. Tibetan text: bslab pa kun las btus pa, Toh 3940, Degé Tengyur vol. 111 (dbu ma, khi), folios 3a–194b. English translation: see Goodman 2016. </p></div></div></div></div><div class="flex flex-col gap-4"><div id="Editions and translations of works referenced-3" class="relative scroll-mt-20"><button type="button" id="radix-_R_b57anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4 @c/sidebar:mt-0.5 mt-4">b.4</button><div class="passage pl-6 @c/sidebar:pl-4"><div class="text-secondary font-sans text-base font-bold">Editions and translations of works referenced</div></div></div><div id="bdf85482-2675-4ba7-98c5-a1c4d12a6b0e" class="relative scroll-mt-20"><button type="button" id="radix-_R_4d57anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.4.1</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p> Bagchi, S. (ed.). <em>Guhya­samāja­tantra</em>. Buddhist Sanskrit Texts, No. 9. Darbhanga: Mithila Institute of Postgraduate Studies and Research in Sanskrit Learning, 1965. </p></div></div></div><div id="5ef66357-b2da-4760-a378-1c1587f3760c" class="relative scroll-mt-20"><button type="button" id="radix-_R_4l57anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.4.2</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p> Buddhavacana Translation Group. <em><span lang="en"><a href="https://read.84000.co/translation/toh106.html">The Sūtra Unravelling the Intent</a></em> (<em>Saṃdhi­nirmocana­sūtra</em>, Toh 106). 84000: Translating the Words of the Buddha, 2020.</p></div></div></div><div id="e635e5e6-1917-4a46-92f9-0b03726af09a" class="relative scroll-mt-20"><button type="button" id="radix-_R_4t57anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.4.3</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p> Dayal, Har. <em>The Bodhisattva Doctrine in Buddhist Sanskrit Literature</em>. 1932. Reprint, Delhi: Motilal Banarsidass, 1970.</p></div></div></div><div id="056c7a67-9a98-467e-aad6-1e722a381c2b" class="relative scroll-mt-20"><button type="button" id="radix-_R_5557anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.4.4</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p> Goodman, Charles. <em>The Training Anthology of Śāntideva: A Translation of the Śikṣā-samuccaya</em>. New York: Oxford University Press, 2016. </p></div></div></div><div id="d4d32daf-df01-4701-babf-3ca902fd0525" class="relative scroll-mt-20"><button type="button" id="radix-_R_5d57anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.4.5</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p> Inada, K. <em>Nāgārjuna</em>. Buffalo, N.Y., 1970. </p></div></div></div><div id="12b4b726-cd03-4c60-a54a-e35eed441387" class="relative scroll-mt-20"><button type="button" id="radix-_R_5l57anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.4.6</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p> Kern, H. (ed.). <em>Saddharma-Puṇḍarīka, or Lotus of the True Law</em>. Sacred Books of the East, Vol. XXI. Oxford: Clarendon, 1884. </p></div></div></div><div id="1a22b510-b296-44a0-bfec-e911cf9b9d20" class="relative scroll-mt-20"><button type="button" id="radix-_R_5t57anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.4.7</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p> Lamotte, Étienne (tr.). <em>Saṃdhi­nirmocana­sūtra: L’Explication des mystères</em>. [Tib. text and French translation]. Louvain: Université de Louvain; and Paris: Adrien Maisonneuve, 1935. </p></div></div></div><div id="4ac86ac1-b126-4e91-acc0-d62e843c45ba" class="relative scroll-mt-20"><button type="button" id="radix-_R_6557anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.4.8</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p> La Vallée Poussin, L. de (ed.). <em>Mūla­madhyamaka­kārikās (Mādhyamika­sūtras) de Nāgārjuna avec la Prasanna­padā, commentaire de Candrakīrti</em> . Bibliotheca Buddhica IV. St. Petersburg: Académie Impériale des sciences, 1903-1913. </p></div></div></div><div id="2d08fd0d-7182-475d-a89c-040ed33c3c2d" class="relative scroll-mt-20"><button type="button" id="radix-_R_6d57anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.4.9</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p> Roberts, Peter (tr.). <em><a href="http://read.84000.co/translation/toh113.html">The White Lotus of the Good Dharma</a></em> (<em>Saddharma­puṇḍarīka­sūtra</em>, Toh 113). 84000: Translating the Words of the Buddha, 2018.</p></div></div></div><div id="4bc649ae-3c8f-4b73-bb5c-64bc6a6cfc7e" class="relative scroll-mt-20"><button type="button" id="radix-_R_6l57anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.4.10</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p> Sakaki (ed.). <em>Mahāvyutpatti</em>, Skt.-Tib. lexicon. Kyoto, 1916-1925. </p></div></div></div><div id="f8f4ea40-7c27-4a7e-a664-3f7eabcb3a7c" class="relative scroll-mt-20"><button type="button" id="radix-_R_6t57anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.4.11</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p> Vaidya, P. L. (ed.) <em>Saddharma­puṇḍarīka­sūtra</em>. Darbhanga: The Mithila Institute of Post-Graduate Studies and Research in Sanskrit Learning, 1960. </p></div></div></div><div id="20ddee48-7471-4262-956f-761a6436ca50" class="relative scroll-mt-20"><button type="button" id="radix-_R_7557anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.4.12</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p> Vaidya, P. L. (ed.) <em>Śikṣāsamuccaya of Śāntideva</em>. Buddhist Sanskrit Texts, No. 11. Darbhanga: Mithila Institute of Postgraduate Studies and Research in Sanskrit Learning, 1961. </p></div></div></div><div id="0e191872-4c97-4e8b-8c7a-47672797dac4" class="relative scroll-mt-20"><button type="button" id="radix-_R_7d57anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.4.13</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p>Vienna Buddhist Translation Studies Group, trans. <em> <a href="https://read.84000.co/translation/toh62.html">The Questions of Rāṣṭrapāla</a> </em> (<em>Rāṣṭrapālaparipṛcchāsūtra</em>, Toh 62). 84000: Translating the Words of the Buddha, 2021.</p></div></div></div><div id="e54dd9ce-e300-45af-bdc4-08e3edf5a699" class="relative scroll-mt-20"><button type="button" id="radix-_R_7l57anpftt6btb_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="absolute labeled -left-16 w-16 text-end hover:cursor-pointer whitespace-pre-line leading-4">b.4.14</button><div class="passage pl-6 @c/sidebar:pl-4"><div><p> Wogihara, Unrai and Tsuchida, Chikao. <em>Saddharma­puṇḍarīka-sūtram: Romanized and Revised Text of the Bibliotheca Buddhica publication by consulting a Sanskrit Ms. &amp; Tibetan and Chinese translations</em>. Tōkyō: Seigo-Kenkyūkai, 1934–1935. </p></div></div></div></div></div></div></div><div data-state="inactive" data-orientation="horizontal" role="tabpanel" aria-labelledby="radix-_R_2npftt6btb_-trigger-abbreviations" id="radix-_R_2npftt6btb_-content-abbreviations" tabindex="0" data-slot="tabs-content" class="mt-2 ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 data-[state=inactive]:hidden"><div class="h-0"></div><div></div><div class="h-0"></div><div class="flex flex-col gap-4 pb-8"><div class="flex gap-5"><div class="animate-pulse rounded-md bg-foreground/10 h-6 w-6"></div><div class="animate-pulse rounded-md bg-foreground/10 h-32 grow"></div></div><div class="flex gap-5"><div class="animate-pulse rounded-md bg-foreground/10 h-6 w-6"></div><div class="animate-pulse rounded-md bg-foreground/10 h-32 grow"></div></div><div class="flex gap-5"><div class="animate-pulse rounded-md bg-foreground/10 h-6 w-6"></div><div class="animate-pulse rounded-md bg-foreground/10 h-32 grow"></div></div></div></div></di