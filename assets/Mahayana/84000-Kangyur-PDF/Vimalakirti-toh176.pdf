8,\"end\":784}},{\"type\":\"text\",\"text\":\"Mahākāśyapa\",\"attrs\":{\"start\":784,\"end\":795},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"cf40c4ec-f71c-47c7-bd39-47de5e6850b9\",\"uuid\":\"8950cc3d-f493-4754-96b9-c69bbf33482e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", is the practice of eating by alms meaningful.’\",\"attrs\":{\"start\":795,\"end\":843}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"1324a73e-298d-4e2b-9553-ba42098567bc\",\"sort\":2301,\"type\":\"translation\",\"label\":\"3.14\",\"alignments\":{\"toh176\":{\"folioUuid\":\"70f0b045-6524-4642-a561-713115cfc07e\",\"toh\":\"toh176\",\"tibetan\":\"བཅོམ་ལྡན་འདས་བདག་ཆོས་བསྟན་པ་འདི་ཐོས་ནས་ངོ་མཚར་དུ་གྱུར་ཏེ། བྱང་ཆུབ་སེམས་དཔའ་ཐམས་ཅད་ལ་ཕྱག་འཚལ་ལོ། །ཁྱིམ་ན་གནས་པ་ཡང་འདི་ལྟ་བུའི་སྤོབས་པ་དང་ལྡན་ན། སུ་ཞིག་བླ་ན་མེད་པ་ཡང་དག་པར་རྫོགས་པའི་བྱང་ཆུབ་ཏུ་\\nསེམས་མི་སྐྱེད་སྙམ་ནས་དེ་ཚུན་ཆད་བདག་གིས་སེམས་ཅན་གང་ཡང་ཐེག་པ་ཆེན་པོ་མ་ལགས་པར་ཉན་ཐོས་ཀྱི་ཐེག་པ་དང་། རང་སངས་རྒྱས་ཀྱི་ཐེག་པ་ལ་སྔོན་ཆད་མ་བཙུད་དོ། །བཅོམ་ལྡན་འདས་དེའི་སླད་དུ་བདག་སྐྱེས་བུ་དམ་པ་དེའི་བྲོ་འདྲི་ཞིང་མཆི་བར་མི་སྤྲོའོ། །\",\"folioNumber\":186,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":452,\"uuid\":\"1324a73e-298d-4e2b-9553-ba42098567bc\"},\"content\":[{\"type\":\"text\",\"text\":\"“\",\"attrs\":{\"start\":0,\"end\":1}},{\"type\":\"text\",\"text\":\"Lord\",\"attrs\":{\"start\":1,\"end\":5},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41c623b8-3d94-4f8e-b2c5-1d7a5f5af6d3\",\"uuid\":\"c0043e91-8bc3-4e34-a53c-9e60acbd3db5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", when I heard this teaching, I was astonished and thought, ‘Reverence to all \",\"attrs\":{\"start\":5,\"end\":83}},{\"type\":\"text\",\"text\":\"bodhisattvas\",\"attrs\":{\"start\":83,\"end\":95},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c72eb4f3-700e-454d-996e-5ccdba29e6be\",\"uuid\":\"68823778-e8b6-43de-b6b9-42c1fb1bc8a6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"! If a lay \",\"attrs\":{\"start\":95,\"end\":106}},{\"type\":\"text\",\"text\":\"bodhisattva\",\"attrs\":{\"start\":106,\"end\":117},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c72eb4f3-700e-454d-996e-5ccdba29e6be\",\"uuid\":\"528f9cf9-e362-427b-af09-0125a40b2aab\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" may be endowed with such eloquence, who is there who would not conceive the spirit of unexcelled, perfect \",\"attrs\":{\"start\":117,\"end\":224}},{\"type\":\"text\",\"text\":\"enlightenment\",\"attrs\":{\"start\":224,\"end\":237},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"62f923c5-8dfa-4620-8dec-7bb032231bf7\",\"uuid\":\"cba13c55-a4bc-4768-887a-49db0c8edfe7\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"?’ From that time forth, I no longer recommend the vehicles of the disciples and of the solitary sages but recommend the \",\"attrs\":{\"start\":237,\"end\":358}},{\"type\":\"text\",\"text\":\"Mahāyāna\",\"attrs\":{\"start\":358,\"end\":366},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"99607e52-e246-4905-b531-6e6d7ccfd7b7\",\"uuid\":\"ae079429-51f7-4e3c-b628-deb347b82d86\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". And thus, \",\"attrs\":{\"start\":366,\"end\":378}},{\"type\":\"text\",\"text\":\"Lord\",\"attrs\":{\"start\":378,\"end\":382},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41c623b8-3d94-4f8e-b2c5-1d7a5f5af6d3\",\"uuid\":\"34c86683-35c6-448e-b86c-6c96aa1cb218\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", I am reluctant to go to this good man to inquire about his illness.”\",\"attrs\":{\"start\":382,\"end\":452}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"90ac06fd-a9b1-4c7a-8b8f-4b6dd4354d9d\",\"sort\":2316,\"type\":\"translation\",\"label\":\"3.15\",\"alignments\":{\"toh176\":{\"folioUuid\":\"70f0b045-6524-4642-a561-713115cfc07e\",\"toh\":\"toh176\",\"tibetan\":\"$26\",\"folioNumber\":186,\"volumeNumber\":60}}},\"content\":[{\"type\":\"par