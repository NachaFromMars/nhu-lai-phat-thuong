type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"784c8158-9e46-4484-9152-e0d06cd46afc\",\"uuid\":\"2d4355c9-2d26-4189-8e45-476093188aa8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" meaning.\",\"attrs\":{\"start\":202,\"end\":211},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"9d7e05a8-e6fa-4f44-97e0-516f8ade1522\",\"label\":\"27\",\"uuid\":\"75d7aada-f76e-4875-a9be-0f60094b3515\",\"start\":211,\"end\":211,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":211,\"end\":212}}],\"attrs\":{\"start\":139,\"end\":212,\"uuid\":\"60d25172-ebd5-48a6-9cff-226bda6f166d\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"Sovereign \",\"attrs\":{\"start\":212,\"end\":222}},{\"type\":\"text\",\"text\":\"Lord\",\"attrs\":{\"start\":222,\"end\":226},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41c623b8-3d94-4f8e-b2c5-1d7a5f5af6d3\",\"uuid\":\"855b4cd2-2eb5-479e-89a3-3573b5f254fb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of \",\"attrs\":{\"start\":226,\"end\":230}},{\"type\":\"text\",\"text\":\"Dharma\",\"attrs\":{\"start\":230,\"end\":236},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c08db6f5-393e-4ec4-bf72-4043e53b3129\",\"uuid\":\"7976b0a8-b5d2-420a-8917-b9ecaa12d43a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", obeisance to you!\",\"attrs\":{\"start\":236,\"end\":255}}],\"attrs\":{\"start\":212,\"end\":255,\"uuid\":\"6a84666a-cab4-447d-9d28-76894ef6ecfc\"}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"a3af57be-b163-4c9e-8281-2816063edeaf\",\"sort\":1059,\"type\":\"translation\",\"label\":\"1.19\",\"alignments\":{\"toh176\":{\"folioUuid\":\"e36e306d-01a9-49b8-89fc-9eff457bdf7b\",\"toh\":\"toh176\",\"tibetan\":\"མཆིས་པ་མ་ལགས་པ་དང་མ་མཆིས་མ་\\nལགས་དང་། །ཆོས་འདི་ཐམས་ཅད་རྒྱུ་ལས་བརྟེན་ནས་འབྱུང་བ་དང་། །འདི་ལ་བདག་མེད་ཚོར་བ་པོ་དང་བྱེད་མེད་ཅིང་། །དགེ་སྡིག་ལས་ཅིའང་ཆུད་མི་ཟ་ཞེས་གསུང་གིས་སྟོན། །\",\"folioNumber\":177,\"volumeNumber\":60}}},\"content\":[{\"type\":\"lineGroup\",\"attrs\":{\"start\":0,\"end\":218,\"uuid\":\"9fa24e38-059e-4035-92d1-9c2e85f02c79\"},\"content\":[{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"“All these things arise dependently, from causes, \",\"attrs\":{\"start\":0,\"end\":50}}],\"attrs\":{\"start\":0,\"end\":50,\"uuid\":\"2c916096-7474-433a-b6da-a6727c029d68\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"Yet they are neither existent nor nonexistent. \",\"attrs\":{\"start\":50,\"end\":97}}],\"attrs\":{\"start\":50,\"end\":97,\"uuid\":\"8821b4b9-cc70-436c-880c-f4fb288180d7\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"Therein is neither ego, nor experiencer, nor doer, \",\"attrs\":{\"start\":97,\"end\":148}}],\"attrs\":{\"start\":97,\"end\":148,\"uuid\":\"b74051ae-dab8-43dc-9adf-e6fc60e7c13c\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"Yet no action, good or evil, loses its effects.\",\"attrs\":{\"start\":148,\"end\":195},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"5e51243a-014e-4fdf-bab7-ec2d325785b3\",\"label\":\"28\",\"uuid\":\"26ab6ef9-922c-4550-bff7-d0b418459c62\",\"start\":195,\"end\":195,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" Such is your teaching.\",\"attrs\":{\"start\":195,\"end\":218}}],\"attrs\":{\"start\":148,\"end\":218,\"uuid\":\"7b7ff17f-40d2-424e-b1c3-e3aedff466a1\"}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"373819cd-bb7f-4f12-a5f1-7e8e02e68645\",\"sort\":1069,\"type\":\"translation\",\"label\":\"1.20\",\"alignments\":{\"toh176\":{\"folioUuid\":\"e36e306d-01a9-49b8-89fc-9eff457bdf7b\",\"toh\":\"toh176\",\"tibetan\":\"ཐུབ་དབང་ཁྱོད་ཀྱིས་བདུད་དཔུང་སྟོབས་ཅན་རབ་བཏུལ་ནས། །བྱང་ཆུབ་མཆོག་རབ་ཞི་བ་མི་འཆི་བདེ་བ་བརྙེས། །\\nདེ་ལ་ཚོར་མེད་སེམས་དང་ཡིད་ཀྱི་རྒྱུ་བ་མེད། །མུ་སྟེགས་ངན་པའི་ཚོགས་རྣམས་ཀུན་གྱིས་དེ་མི་རྟོགས། །\",\"folioNumber\":177,\"volumeNumber\":60}}},\"content\":[{\"type\":\"lineGroup\",\"attrs\":{\"start\":0,\"end\":243