0-9f24c530a4ca\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", endowed with an infinite knowledge of skill in \",\"attrs\":{\"start\":465,\"end\":514}},{\"type\":\"text\",\"text\":\"liberative arts\",\"attrs\":{\"start\":514,\"end\":529},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7c541c84-ac9d-49ce-92dc-9b1f6912648d\",\"uuid\":\"f4dd0baf-50a3-457d-bc69-91e99b643cc9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":529,\"end\":530}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"2cdc958f-b070-4ce4-a2bf-04dc1de82a79\",\"sort\":1896,\"type\":\"translation\",\"label\":\"2.7\",\"alignments\":{\"toh176\":{\"folioUuid\":\"462089d7-cf87-40e2-b81e-56bc11a3b41a\",\"toh\":\"toh176\",\"tibetan\":\"དེ་ཐབས་ལ་མཁས་པས་བདག་ཉིད་ན་བ་ལྟ་བུར་བསྟན་ནས་དེ་ལ་ནད་འདྲི་བའི་ཕྱིར་ཡངས་པའི་གྲོང་ཁྱེར་ཆེན་པོ་ནས་རྒྱལ་པོ་དང་། བློན་པོ་དང་། དབང་པོ་དང་། གཞོན་ནུའི་འཁོར་དང་། བྲམ་ཟེ་དང་། ཁྱིམ་བདག་དང་། ཚོང་དཔོན་དང་།[F.183.a]གྲོང་པ་དང་། ཡུལ་གྱི་མི་དང་། དེ་མ་ཡིན་པ་སྲོག་ཆགས་སྟོང་ཕྲག་མང་པོ་ནད་འདྲིར་འོངས་ཏེ། དེར་ལྷགས་པ་དེ་དག་ལ་ལིད་ཙ་བཱི་དྲི་མ་མེད་པར་གྲགས་པས་འབྱུང་བ་ཆེན་པོ་བཞིའི་ལུས་འདི་ཉིད་ལས་བརྩམས་ནས་ཆོས་སྟོན་ཏེ། \",\"folioNumber\":182,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":486,\"uuid\":\"2cdc958f-b070-4ce4-a2bf-04dc1de82a79\"},\"content\":[{\"type\":\"text\",\"text\":\"At that time, out of this very skill in \",\"attrs\":{\"start\":0,\"end\":40}},{\"type\":\"text\",\"text\":\"liberative art\",\"attrs\":{\"start\":40,\"end\":54},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"7c541c84-ac9d-49ce-92dc-9b1f6912648d\",\"uuid\":\"92d4d1a9-54ae-48f8-8211-1abef874835e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":54,\"end\":56}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":56,\"end\":67},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"7d081de6-9eb6-4b02-a0b7-74f3d2fb3b2a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" manifested himself as if sick. To inquire after his health, the king, the officials, the lords, the youths, the brahmins, the householders, the businessmen, the townfolk, the countryfolk, and thousands of other living beings came forth from the great city of \",\"attrs\":{\"start\":67,\"end\":327}},{\"type\":\"text\",\"text\":\"Vaiśālī\",\"attrs\":{\"start\":327,\"end\":334},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e9c61804-d922-4a99-88ea-836faa6fd3c4\",\"uuid\":\"dd959a10-ce8e-4051-9a4d-a85e601b868f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and called on the invalid. When they arrived, \",\"attrs\":{\"start\":334,\"end\":381}},{\"type\":\"text\",\"text\":\"Vimalakīrti\",\"attrs\":{\"start\":381,\"end\":392},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b9ca12fb-e3be-4924-ad28-b09e52530acb\",\"uuid\":\"6d20ca8c-4e68-4422-94ac-d08291390a7b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" taught them the \",\"attrs\":{\"start\":392,\"end\":409}},{\"type\":\"text\",\"text\":\"Dharma\",\"attrs\":{\"start\":409,\"end\":415},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c08db6f5-393e-4ec4-bf72-4043e53b3129\",\"uuid\":\"5025ff81-4133-4438-9306-4549bc729371\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", beginning his discourse from the actuality of the four main \",\"attrs\":{\"start\":415,\"end\":477}},{\"type\":\"text\",\"text\":\"elements\",\"attrs\":{\"start\":477,\"end\":485},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"dbc4a2e4-dbc7-475b-8ed0-c63412da4b68\",\"uuid\":\"aeead413-daf5-44a5-822f-60b953babe6d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\":\",\"attrs\":{\"start\":485,\"end\":486}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"654a6a8a-e2c7-4f95-88cb-51fed15ab589\",\"sort\":1914,\"type\":\"translation\",\"label\":\"2.8\",\"alignments\":{\"toh176\":{\"folioUuid\":\"25c7df2b-fb26-4c5f-803f-bf24a3063744\",\"toh\":\"toh176\",\"tibetan\":\"$22\",\"folioNumber\":183,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1018,\"uuid\":\"654a6a8a-e2c7-4f95-88cb-51fed15ab589\"},\"content\":[{\"type\":\"text\",\"text\":\"“Friends, this body is so impermanent, fragile, unworthy of confidence, and feeble. It is so insubstantial, perishable, short-lived, painful, filled with diseases, and subject to changes. Thus, my friends, as this body is only a vessel of many sicknesses, wise men do not rely on it. This body is like a ball of foam, unable to bear any pressure. It is like a water bubble, not remaining very long. It is like a mirage, born from the appetites of the \",\"attrs\":{\"start\":0,\"end\":451}},{\"type\":\"text\",\"text\":\"passions\",\"attrs\":{\"start\":451,\"end\":459},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2370c8e3-79cc-4eab-bc82-33939081f558\",\"uuid\":\"47c77273-0da2-430e-b676-10595564190a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". It is like the trunk of the plantain tree, having no core. Alas! This body is like a machine, a nexus of bones and tendons. It is like a magical illusion, consisting of falsifications.\",\"attrs\":{\"start\":459,\"end\":645},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"b345fefb-5ac0-49a1-965f-4188b6275ee3\",\"label\":\"48\",\"uuid\":\"540bba8f-83ed-45a9-9028-0e20236f7ff0\",\"start\":645,\"end\":645,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" It is like a dream, being an unreal vision. It is like a reflection, being the image of former actions. It is like an echo, being dependent on conditioning. It is like a cloud, being characterized by turbulence and dissolution. It is like a flash of lightning, being unstable, and decaying every moment. The body is ownerless, being the product of a variety of conditions.\",\"attrs\":{\"start\":645,\"end\":1018}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"64e240a1-76bf-4029-b1a3-8df275d06976\",\"sort\":1920,\"type\":\"translation\",\"label\":\"2.9\",\"alignments\":{\"toh176\":{\"folioUuid\":\"25c7df2b-fb26-4c5f-803f-bf24a3063744\",\"toh\":\"toh176\",\"tibetan\":\"ལུས་འདི་ནི་ས་དང་འདྲ་སྟེ་བྱེད་པ་མེད་པའོ། །ལུས་འདི་ནི་ཆུ་དང་འདྲ་སྟེ་བདག་མེད་པའོ། །ལུས་འདི་ནི་མེ་དང་འདྲ་སྟེ་སྲོག་མེད་པའོ། །ལུས་འདི་ནི་རླུང་དང་འདྲ་སྟེ་གང་ཟག་མེད་པའོ། །ལུས་\\nའདི་ནི་ནམ་མཁའ་དང་འདྲ་སྟེ་རང་བཞིན་མེད་པའོ། །ལུས་འདི་ནི་འབྱུང་བ་ཆེན་པོ་རྣམས་ཀྱི་གནས་ཏེ་ཡང་དག་པ་མ་ཡིན་པའོ། །ལུས་འདི་ནི་བདག་དང་བདག་གི་མེད་པ་སྟེ་སྟོང་པའོ། །ལུས་འདི་ནི་རྩྭ་དང་། ཤིང་དང་། རྩིག་པ་དང་། བོང་བ་དང་། མིག་ཡོར་ལྟ་བུ་སྟེ་བེམས་པོའོ། །[F.183.b]ལུས་འདི་ནི་རླུང་གི་འཁྲུལ་འཁོར་དང་ལྡན་པས་འབྱུང་སྟེ་ཚོར་བ་མེད་པའོ། །ལུས་འདི་ནི་རྣག་དང་མི་གཙང་བ་བསགས་པ་སྟེ་གསོག་གོ། །ལུས་འདི་ནི་རྟག་ཏུ་བསྐུ་བ་དང་། མཉེ་བ་དང་། འཇིག་པ་དང་། འགྱེས་པའི་ཆོས་ཅན་ཏེ་གསོབ་བོ། །ལུས་འདི་ནི་ནད་བཞི་བརྒྱ་རྩ་བཞིས་\\nགཙེས་པའོ། །ལུས་འདི་ནི་རྟག་ཏུ་རྒ་བས་ཟིལ་གྱིས་ནོན་པ་སྟེ་ཁྲོན་པ་རྙིང་པ་དང་འདྲ་བའོ། །ལུས་འདི་ནི་འཆི་བའི་མཐའ་ཡིན་ཏེ་མཐར་མི་གནས་པའོ། །ལུས་འདི་ནི་ཕུང་པོ་དང་། ཁམས་དང་། སྐྱེ་མཆེད་ཀྱིས་ཡོངས་སུ་ཟིན་པ་སྟེ། གཤེད་མ་དང་སྦྲུལ་གདུག་པ་\\nདང་། གྲོང་སྟོང་པ་ལྟ་བུ་སྟེ། ཁྱོད་ཀྱིས་དེ་ལྟ་བུའི་ལུས་དེ་ལ་ཡིད་བྱུང་བ་དང་སྐྱོ་བ་བསྐྱེད་ཅིང་དེ་བཞིན་གཤེགས་པའི་སྐུ་ལ་མོས་པ་བསྐྱེད་པར་བགྱིའོ། །\",\"folioNumber\":183,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1019,\"uuid\":\"64e240a1-76bf-4029-b1a3-8df275d06976\"},\"content\":[{\"type\":\"text\",\"text\":\"“This body is inert, like the earth; selfless, like water; lifeless, like fire; impersonal, like the wind; and nonsubstantial, like space. This body is unreal, being a collocation of the four main \",\"attrs\":{\"start\":0,\"end\":197}},{\"type\":\"text\",\"text\":\"elements\",\"attrs\":{\"start\":197,\"end\":205},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"dbc4a2e4-dbc7-475b-8ed0-c63412da4b68\",\"uuid\":\"db585602-44da-45e0-b138-9925f5f8e9e0\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". It is void, not existing as \",\"attrs\":{\"start\":205,\"end\":235}},{\"type\":\"text\",\"text\":\"self\",\"attrs\":{\"start\":235,\"end\":239},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"6b47902b-462a-40ad-923c-f033caeaf1f2\",\"uuid\":\"83696391-bef8-4b6d-9bf2-9feb37a5cd11\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" or as \",\"attrs\":{\"start\":239,\"end\":246}},{\"type\":\"text\",\"text\":\"self\",\"attrs\":{\"start\":246,\"end\":250},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"6b47902b-462a-40ad-923c-f033caeaf1f2\",\"uuid\":\"fe1cbf65-1955-45fc-b7f1-fce53b2856ba\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"-possessed. It is inanimate, being like grass, trees, walls, clods of earth, and illusions. It is insensate, being driven like a windmill. It is filthy, being an agglomeration of pus and excrement. It is false, being fated to be broken and destroyed, in spite of being anointed and massaged. It is afflicted by the four hundred and four diseases.\",\"attrs\":{\"start\":250,\"end\":596},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"fc7ff723-e051-46b7-b84d-18d63596c136\",\"label\":\"49\",\"uuid\":\"a680b315-6bdd-4a5c-acca-1cf6bc7ecd43\",\"start\":596,\"end\":596,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" It is like an ancient well, constantly overwhelmed by old age. Its duration is never certain‍—certain only is its end in death. This body is a combination of \",\"attrs\":{\"start\":596,\"end\":755}},{\"type\":\"text\",\"text\":\"aggregates\",\"attrs\":{\"start\":755,\"end\":765},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"95840062-0b03-40c7-ad24-49f28628a43e\",\"uuid\":\"9fb5b0d5-ff47-4278-ba9d-8ad4cd792ea2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":765,\"end\":767}},{\"type\":\"text\",\"text\":\"elements\",\"attrs\":{\"start\":767,\"end\":775},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"dbc4a2e4-dbc7-475b-8ed0-c63412da4b68\",\"uuid\":\"b50be99e-9477-452e-a96b-ad7fa2a2ccc5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and \",\"attrs\":{\"start\":775,\"end\":781}},{\"type\":\"text\",\"text\":\"sense-media\",\"attrs\":{\"start\":781,\"end\":792},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"f63a28fa-eaa5-4aa0-bcc2-44bd9e6badcf\",\"uuid\":\"0de718d8-313f-4cf4-9cbc-9c93880cea27\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", which are comparable to murderers, poisonous snakes, and an empty town, respectively.\",\"attrs\":{\"start\":792,\"end\":879},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"563ed2e9-753d-4b0b-8ec5-1facb86e7906\",\"label\":\"50\",\"uuid\":\"bdd56a9b-11f6-4ceb-9848-bc15ca439ead\",\"start\":879,\"end\":879,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" Therefore, you should be repelled by such a body. You should despair of it and should arouse your admiration for the body of the \",\"attrs\":{\"start\":879,\"end\":1009}},{\"type\":\"text\",\"text\":\"Tathāgata\",\"attrs\":{\"start\":1009,\"end\":1018},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e708dad0-3dd7-49b0-8de3-b2e34b3f8d08\",\"uuid\":\"f6645ef7-57e7-424a-b309-ecc42a2e53aa\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":1018,\"end\":1019}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"8fce92d2-9b04-4bcc-b9f4-a92ed26a4913\",\"sort\":1942,\"type\":\"translation\",\"label\":\"2.10\",\"alignments\":{\"toh176\":{\"folioUuid\":\"ddd2a2f6-2cac-42d8-9ab0-1e39cb2a7c7b\",\"toh\":\"toh176\",\"tibetan\":\"$23\",\"folioNumber\":183,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":1116,\"uuid\":\"8fce92d2-9b04-4bcc-b9f4-a92ed26a4913\"},\"content\":[{\"type\":\"text\",\"text\":\"“Friends, the body of a \",\"attrs\":{\"start\":0,\"end\":24}},{\"type\":\"text\",\"text\":\"tathāgata\",\"attrs\":{\"start\":24,\"end\":33},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{