e5-78fb910a661d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":627,\"end\":628}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"2cc33f93-34ea-484a-bad0-d83a0f6e65f4\",\"sort\":687,\"type\":\"translation\",\"label\":\"1.5\",\"alignments\":{\"toh176\":{\"folioUuid\":\"cabaf8cf-128e-41eb-bfd0-62bbfb99a69a\",\"toh\":\"toh176\",\"tibetan\":\"སེམས་ཅན་ཐམས་ཅད་ཀྱི་དབང་པོ་ཤེས་པ་ལ་མཁས་པ། འཁོར་ཐམས་ཅད་ཀྱི་ཟིལ་གྱིས་མི་ནོན་པའི་མི་འཇིགས་པས་རྣམ་པར་གནོན་པ། བསོད་ནམས་དང་ཡེ་ཤེས་ཀྱི་ཚོགས་ཆེན་པོ་བསགས་པ། མཚན་དང་\\nདཔེ་བྱད་བཟང་པོ་ཐམས་ཅད་ཀྱིས་ལུས་ཤིན་ཏུ་བརྒྱན་པ། གཟུགས་དམ་པ་འཛིན་པ། རྒྱན་དང་བྲལ་བ། རི་རབ་ཀྱི་རྩེ་མོ་མཐོ་བ་བཞིན་དུ་སྙན་པ་དང་གྲགས་པས་མངོན་པར་འཕགས་པ། ལྷག་པའི་བསམ་པ་རྡོ་རྗེ་ལྟར་སྲ་བས་སངས་རྒྱས་དང་ཆོས་དང་དགེ་འདུན་ལ་མི་ཕྱེད་པའི་དད་པ་རྙེད་པ། \\nཆོས་རིན་པོ་ཆེའི་འོད་ཟེར་ལས་བདུད་རྩིའི་ཆར་ཤིན་ཏུ་འབེབས་པ། \",\"folioNumber\":175,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":605,\"uuid\":\"2cc33f93-34ea-484a-bad0-d83a0f6e65f4\"},\"content\":[{\"type\":\"text\",\"text\":\"They were expert in knowing the spiritual faculties of all living beings. They were brave with the confidence that overawes all assemblies. They had gathered the great stores of merit and of \",\"attrs\":{\"start\":0,\"end\":191}},{\"type\":\"text\",\"text\":\"wisdom\",\"attrs\":{\"start\":191,\"end\":197},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"38971298-6f62-48f0-b271-36261568d441\",\"uuid\":\"eae5d10e-f861-47ad-b06a-c1e4761a9b86\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and their bodies, beautiful without ornaments, were adorned with all the \",\"attrs\":{\"start\":197,\"end\":272}},{\"type\":\"text\",\"text\":\"auspicious signs and marks\",\"attrs\":{\"start\":272,\"end\":298},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4288ecec-62d3-4cb7-98ba-da11e7949e29\",\"uuid\":\"fc0df04f-de4d-465b-8c0e-f693f7eaae06\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". They were exalted in fame and glory, like the lofty summit of Mount \",\"attrs\":{\"start\":298,\"end\":368}},{\"type\":\"text\",\"text\":\"Sumeru\",\"attrs\":{\"start\":368,\"end\":374},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"6399a2f2-b35d-4507-a09f-efeccb434a76\",\"uuid\":\"a8b4b471-5c92-448d-a992-0c2a16144e90\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Their \",\"attrs\":{\"start\":374,\"end\":382}},{\"type\":\"text\",\"text\":\"high resolve\",\"attrs\":{\"start\":382,\"end\":394},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9e965ab3-84e2-4b05-873f-324b2f5ca383\",\"uuid\":\"953a669b-61c8-4500-a64d-2a6f06cf69f5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" as hard as diamond, unbreakable in their faith in the \",\"attrs\":{\"start\":394,\"end\":449}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":449,\"end\":455},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"68b64be5-ce59-4da5-ba9b-2c08d0e5e0c5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":455,\"end\":457}},{\"type\":\"text\",\"text\":\"Dharma\",\"attrs\":{\"start\":457,\"end\":463},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c08db6f5-393e-4ec4-bf72-4043e53b3129\",\"uuid\":\"4b3755b7-94fb-4010-98b3-5a7153cc5e5c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and \",\"attrs\":{\"start\":463,\"end\":469}},{\"type\":\"text\",\"text\":\"Saṅgha\",\"attrs\":{\"start\":469,\"end\":475},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"02725146-032e-4372-bc0f-78777524f0aa\",\"uuid\":\"5fb9b7f5-eb5d-4d72-97ba-ff9c8ef0302e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", they showered forth the rain of ambrosia that is released by the light rays of the jewel of the \",\"attrs\":{\"start\":475,\"end\":573}},{\"type\":\"text\",\"text\":\"Dharma\",\"attrs\":{\"start\":573,\"end\":579},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c08db6f5-393e-4ec4-bf72-4043e53b3129\",\"uuid\":\"f0d90c0d-1674-4a0e-bf61-852be9637204\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", which shines everywhere.\",\"attrs\":{\"start\":579,\"end\":605}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"aa43c73f-2bbf-441f-aa80-6e32943a1af3\",\"sort\":705,\"type\":\"translation\",\"label\":\"1.6\",\"alignments\":{\"toh176\":{\"folioUuid\":\"cabaf8cf-128e-41eb-bfd0-62bbfb99a69a\",\"toh\":\"toh176\",\"tibetan\":\"སེམས་ཅན་ཐམས་ཅད་ཀྱི་སྐད་དང་། སྨྲ་བ་དང་། དབྱངས་ཀྱི་ཡན་ལག་དང་། སྒྲ་རྣམ་པར་དག་པའི་དབྱངས་དང་ལྡན་པ། ཆོས་ཟབ་མོ་རྟེན་ཅིང་འབྲེལ་བར་འབྱུང་བ་ལ་འཇུག་ཅིང་མཐའ་དང་། མཐའ་མེད་པར་ལྟ་བའི་བག་\\nཆགས་ཀྱི་མཚམས་སྦྱོར་བ་ཀུན་གཅོད་པ་དང་། སེང་གེ་ལྟར་འཇིགས་པ་མེད་ཅིང་སྒྲ་མངོན་པར་སྒྲོགས་པ། ཆོས་ཆེན་པོའི་འབྲུག་སྒྲ་སྒྲོགས་པ། མཚུངས་པ་དང་མི་མཚུངས་པའི་ཆོས་ལས་ཡང་དག་པར་འདས་པ། ཆོས་རིན་པོ་ཆེའི་ཤེས་རབ་དང་བསོད་ནམས་ཀྱི་ཚོགས་ཡང་དག་པར་\\nསྒྲུབ་པའི་དེད་དཔོན་ཆེན་པོ་\",\"folioNumber\":175,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":523,\"uuid\":\"aa43c73f-2bbf-441f-aa80-6e32943a1af3\"},\"content\":[{\"type\":\"text\",\"text\":\"Their voices were perfect in diction and resonance, and versatile in speaking all languages. They had penetrated the profound principle of \",\"attrs\":{\"start\":0,\"end\":139}},{\"type\":\"text\",\"text\":\"relativity\",\"attrs\":{\"start\":139,\"end\":149},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a53cd052-8393-4f2f-b18f-df2aff5c0cdb\",\"uuid\":\"2597bf05-d6a1-4445-8225-1024c5864192\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" and had destroyed the persistence of the instinctual mental habits underlying all convictions concerning finitude and infinitude.\",\"attrs\":{\"start\":149,\"end\":279},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"d69ff26c-fc62-4d34-8032-002625e1034b\",\"label\":\"18\",\"uuid\":\"273d5420-6344-4606-bb58-efc5b7ccb769\",\"start\":279,\"end\":279,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" They spoke fearlessly, like lions, sounding the thunder of the magnificent teaching. Unequaled, they surpassed all measure. They were the best captains for the voyage of discovery of the treasures of the \",\"attrs\":{\"start\":279,\"end\":484}},{\"type\":\"text\",\"text\":\"Dharma\",\"attrs\":{\"start\":484,\"end\":490},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c08db6f5-393e-4ec4-bf72-4043e53b3129\",\"uuid\":\"df9c4734-1622-40a1-8ce2-f7ba7076b212\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the \",\"attrs\":{\"start\":490,\"end\":496}},{\"type\":\"text\",\"text\":\"stores of merit and wisdom\",\"attrs\":{\"start\":496,\"end\":522},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"fa55b464-cb87-4542-8570-44397712805f\",\"uuid\":\"bc515ea6-c00d-4621-b875-0f73e06c9d35\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":522,\"end\":523}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"a6644b4c-189c-4f03-94c3-c80f73832976\",\"sort\":715,\"type\":\"translation\",\"label\":\"1.7\",\"alignments\":{\"toh176\":{\"folioUuid\":\"cabaf8cf-128e-41eb-bfd0-62bbfb99a69a\",\"toh\":\"toh176\",\"tibetan\":\"དྲང་བ་དང་། ཞི་བ་དང་། ཕྲ་བ་དང་། འཇམ་པ་དང་། བལྟ་དཀའ་བ་དང་། རྟོགས་པར་དཀའ་བའི་ཆོས་ཀྱི་ཚུལ་ལ་མཁས་པ། སེམས་ཅན་རྣམས་ཀྱི་འོང་བ་དང་། འགྲོ་བ་དང་། སེམས་ཅན་གྱི་བསམ་པ་རྟོགས་པའི་རྗེས་སུ་ཞུགས་པའི་ཡེ་ཤེས་ཀྱི་ཡུལ་དང་ལྡན་\\nཔ། མི་མཉམ་པ་དང་མཉམ་པའི་སངས་རྒྱས་ཀྱི་ཡེ་ཤེས་ལ་དབང་བསྐུར་བས་དབང་བསྐུར་བ། སྟོབས་བཅུ་དང་། མི་འཇིགས་པ་དང་། སངས་རྒྱས་ཀྱི་མ་འདྲེས་པ་ལ་ལྷག་པའི་བསམ་པས་ཞུགས་པ། \",\"folioNumber\":175,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":471,\"uuid\":\"a6644b4c-189c-4f03-94c3-c80f73832976\"},\"content\":[{\"type\":\"text\",\"text\":\"They were expert in the way of the \",\"attrs\":{\"start\":0,\"end\":35}},{\"type\":\"text\",\"text\":\"Dharma\",\"attrs\":{\"start\":35,\"end\":41},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c08db6f5-393e-4ec4-bf72-4043e53b3129\",\"uuid\":\"26b90000-e848-466a-9bfd-6b77c870830a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", which is straight, peaceful, subtle, gentle, hard to see, and difficult to realize. They were endowed with the \",\"attrs\":{\"start\":41,\"end\":154}},{\"type\":\"text\",\"text\":\"wisdom\",\"attrs\":{\"start\":154,\"end\":160},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"38971298-6f62-48f0-b271-36261568d441\",\"uuid\":\"37930c1f-6c26-4b47-880d-fe4c58f64893\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" that is able to understand the thoughts of living beings, as well as their comings and goings. They had been consecrated with the anointment of the peerless \",\"attrs\":{\"start\":160,\"end\":318}},{\"type\":\"text\",\"text\":\"gnosis\",\"attrs\":{\"start\":318,\"end\":324},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"57f30533-44ff-42b7-a670-f57da1f54504\",\"uuid\":\"392ac126-c326-4625-b8b4-a00cdcff73ae\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of the \",\"attrs\":{\"start\":324,\"end\":332}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":332,\"end\":338},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"a267c144-754a-4d40-99bd-0b2e5520444b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". With their \",\"attrs\":{\"start\":338,\"end\":351}},{\"type\":\"text\",\"text\":\"high resolve\",\"attrs\":{\"start\":351,\"end\":363},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9e965ab3-84e2-4b05-873f-324b2f5ca383\",\"uuid\":\"e412fc06-20e7-4de7-a6d4-6a2d32f85e1c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", they approached the \",\"attrs\":{\"start\":363,\"end\":385}},{\"type\":\"text\",\"text\":\"ten powers\",\"attrs\":{\"start\":385,\"end\":395},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"a72b2685-e31f-4aed-adff-8c13405c1c9f\",\"uuid\":\"fc83ef7a-ee6d-4fef-b76e-91aa6b256abe\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the four \",\"attrs\":{\"start\":395,\"end\":406}},{\"type\":\"text\",\"text\":\"fearlessnesses\",\"attrs\":{\"start\":406,\"end\":420},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"b8daff33-91de-4457-9d38-959adf13a079\",\"uuid\":\"8bbb70e0-046c-4466-9108-a72d2d24c4b1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and the \",\"attrs\":{\"start\":420,\"end\":430}},{\"type\":\"text\",\"text\":\"eighteen special qualities of the Buddha\",\"attrs\":{\"start\":430,\"end\":470},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"22d552c8-644d-4406-b1ba-f2d731fff0c3\",\"uuid\":\"370ce0fd-f25a-4c46-95a6-82e2eed218d2\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\".\",\"attrs\":{\"start\":470,\"end\":471}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"3af6f79e-8638-4bd9-a352-6c69fc00f5e3\",\"sort\":733,\"type\":\"translation\",\"label\":\"1.8\",\"alignments\":{\"toh176\":{\"folioUuid\":\"cabaf8cf-128e-41eb-bfd0-62bbfb99a69a\",\"toh\":\"toh176\",\"tibetan\":\"ངན་སོང་གི་འཇིགས་པ་དང་། ངན་འགྲོའི་ལོག་པར་ལྟུང་བའི་འཇིགས་པའི་[F.176.a]འོབས་ཐམས་ཅད་ལས་རྒལ་བས་བསམས་བཞིན་དུ་སྲིད་པའི་འགྲོ་བར་སྐྱེ་བ་སྟོན་པ། སྨན་པའི་རྒྱལ་པོ་ཆེན་པོ། སེམས་ཅན་ཐམས་ཅད་འདུལ་བའི་ཆོ་ག་ལ་མཁས་པ། སེམས་ཅན་ཐམས་ཅད་ཀྱི་ཉོན་མོངས་པའི་ནད་ཐམས་ཅད་རྟོགས་པ། ཅི་རིགས་པར་ཆོས་ཀྱི་སྨན་\\nསྦྱར་བ་རབ་ཏུ་སྦྱོར་བ། \",\"folioNumber\":175,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":299,\"uuid\":\"3af6f79e-8638-4bd9-a352-6c69fc00f5e3\"},\"content\":[{\"type\":\"text\",\"text\":\"They had crossed the terrifying abyss of the \",\"attrs\":{\"start\":0,\"end\":45}},{\"type\":\"text\",\"text\":\"bad migrations\",\"attrs\":{\"start\":45,\"end\":59},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"76486a80-1221-41fd-ba60-de89ee8525f0\",\"uuid\":\"dd4e389e-77c0-4eec-b6a2-ba6b62486e81\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and yet they assumed reincarnation voluntarily in all migrations for the sake of disciplining living beings. Great Kings of medicine, understanding all the sicknesses of \",\"attrs\":{\"start\":59,\"end\":231}},{\"type\":\"text\",\"text\":\"passions\",\"attrs\":{\"start\":231,\"end\":239},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2370c8e3-79cc-4eab-bc82-33939081f558\",\"uuid\":\"0cb748f4-8897-41e5-8b38-dcf1f8926e1b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", they could apply the medicine of the \",\"attrs\":{\"start\":239,\"end\":278}},{\"type\":\"text\",\"text\":\"Dharma\",\"attrs\":{\"start\":278,\"end\":284},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c08db6f5-393e-4ec4-bf72-4043e53b3129\",\"uuid\":\"f89896cf-86e5-445d-945e-62c9e9dc97e1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" appropriately.\",\"attrs\":{\"start\":284,\"end\":299}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"1cb3ec4c-3cd3-46bf-9f7d-373e10e93332\",\"sort\":743,\"type\":\"translation\",\"label\":\"1.9\",\"alignments\":{\"toh176\":{\"folioUuid\":\"672a4346-0c10-4d6a-a2b8-3e2cffa8526d\",\"toh\":\"toh176\",\"tibetan\":\"ཡོན་ཏན་མཐའ་ཡས་པའི་འབྱུང་གནས་དང་ལྡན་པ། སངས་རྒྱས་ཀྱི་ཞིང་མཐའ་ཡས་པར་ཡོན་ཏན་བཀོད་པས་ལེགས་པར་བརྒྱན་པ་མཐོང་བ་དང་། ཐོས་པ་འབྲས་བུ་ཡོད་པ། གོམ་པ་འདོར་བ་འབྲས་བུ་ཡོད་པ། བསྐལ་པ་བྱེ་བ་ཁྲག་ཁྲིག་བརྒྱ་སྟོང་དཔག་\\nཏུ་མེད་པར་ཡོན་ཏན་ཡོངས་སུ་བརྗོད་ཀྱང་ཡོན་ཏན་གྱི་ཆུ་བོ་མཐའ་ཡས་པར་རྟོགས་པ་ལ་འདི་ལྟ་སྟེ། \",\"folioNumber\":176,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":338,\"uuid\":\"1cb3ec4c-3cd3-46bf-9f7d-373e10e93332\"},\"content\":[{\"type\":\"text\",\"text\":\"They were inexhaustible mines of limitless virtues, and they glorified innumerable \",\"attrs\":{\"start\":0,\"end\":83}},{\"type\":\"text\",\"text\":\"buddhafields\",\"attrs\":{\"start\":83,\"end\":95},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1e5e85e8-4767-46b1-874e-5f1396a67ee6\",\"uuid\":\"d9539c6f-ffaa-49be-9f4d-fbf67adec5cb\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" with the splendor of these virtues. They conferred great benefit when seen, heard, or even approached. Were one to extol them for innumerable hundreds of thousands of myriads of eons, one still could not exhaust their mighty flood of virtues.\",\"attrs\":{\"start\":95,\"end\":338}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"7c195da2-ce63-4c41-98fa-17d919984789\",\"sort\":747,\"type\":\"translation\",\"label\":\"1.10\",\"alignments\":{\"toh176\":{\"folioUuid\":\"672a4346-0c10-4d6a-a2b8-3e2cffa8526d\",\"toh\":\"toh176\",\"tibetan\":\"$20\",\"folioNumber\":176,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":978,\"uuid\":\"7c195da2-ce63-4c41-98fa-17d919984789\"},\"content\":[{\"type\":\"text\",\"text\":\"These \",\"attrs\":{\"start\":0,\"end\":6}},{\"type\":\"text\",\"text\":\"bodhisattvas\",\"attrs\":{\"start\":6,\"end\":18},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c72eb4f3-700e-454d-996e-5ccdba29e6be\",\"uuid\":\"765e82db-9c7b-43f4-b189-766d16ccf8f5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" were named: \",\"attrs\":{\"start\":18,\"end\":31}},{\"type\":\"text\",\"text\":\"Samadarśin\",\"attrs\":{\"start\":31,\"end\":41},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"fe02c8d4-f771-472c-bc65-6a2253f39b06\",\"uuid\":\"8b8de09a-bcb2-4427-affd-db938ea3c568\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":41,\"end\":43}},{\"type\":\"text\",\"text\":\"Sama­viṣama­darśin\",\"attrs\":{\"start\":43,\"end\":61},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"d4226273-15f9-4a99-aaeb-e0c57ed06f4d\",\"uuid\":\"68bb085c-47aa-4936-811f-2e07680364e3\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", \",\"attrs\":{\"start\":61,\"end\":63}},{\"type\":\"text\",\"text\":\"Samādhi­vikurvaṇa­rāja\",\"attrs\":{\"start\":63,\"end\":85},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"410a8c3f-585a-4db1-8bc9-da9097