:[{\"endNote\":\"2279b6bc-516e-4a39-b3df-dda3ce1e1fbd\",\"label\":\"23\",\"uuid\":\"27d8396a-4489-4235-84a2-424d62c55c50\",\"start\":776,\"end\":776,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" all the great oceans, rivers, bays, torrents, streams, brooks, and springs; and finally, all the villages, suburbs, cities, capitals, provinces, and wildernesses. All this could be clearly seen by everyone. And the voices of all the \",\"attrs\":{\"start\":776,\"end\":1010}},{\"type\":\"text\",\"text\":\"buddhas\",\"attrs\":{\"start\":1010,\"end\":1017},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"cd441d5a-3db8-4aff-a910-fa8d9c8ce968\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of the ten directions could be heard proclaiming their teachings of the \",\"attrs\":{\"start\":1017,\"end\":1090}},{\"type\":\"text\",\"text\":\"Dharma\",\"attrs\":{\"start\":1090,\"end\":1096},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"c08db6f5-393e-4ec4-bf72-4043e53b3129\",\"uuid\":\"7c2c0a63-1dc4-4f2c-969d-bbf068b049b6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" in all the worlds, the sounds reverberating in the space beneath the great precious canopy.\",\"attrs\":{\"start\":1096,\"end\":1188}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"3abc6575-3839-46cc-840b-af7846d459cd\",\"sort\":998,\"type\":\"translation\",\"label\":\"1.15\",\"alignments\":{\"toh176\":{\"folioUuid\":\"74b87cd4-db86-4a50-944c-d97e328a9f09\",\"toh\":\"toh176\",\"tibetan\":\"དེ་ནས་བཅོམ་ལྡན་འདས་ལས་དེ་ལྟ་བུའི་ཆོ་འཕྲུལ་ཆེན་པོ་འདི་མཐོང་ནས་ཐམས་ཅད་དང་ལྡན་པའི་འཁོར་དེ་ངོ་མཚར་དུ་གྱུར་ཏེ། ཚིམ་ཞིང་མགུ་ནས་ཡི་རངས་ཏེ། རབ་ཏུ་དགའ་ཞིང་དགའ་བ་དང་།[F.177.b]ཡིད་བདེ་བ་སྐྱེས་ནས་དེ་བཞིན་གཤེགས་པ་ལ་ཕྱག་འཚལ་ཏེ། མིག་མི་འཛུམས་པར་ལྟ་ཞིང་འཁོད་དོ། །དེ་ནས་ལིད་ཙ་བཱི་གཞོན་ནུ་དཀོན་མཆོག་འབྱུང་གནས་ཀྱིས་བཅོམ་ལྡན་འདས་ལས་དེ་ལྟ་བུའི་ཆོ་འཕྲུལ་ཆེན་པོ་འདི་མཐོང་ནས་པུས་མོ་གཡས་པའི་ལྷ་ང་ས་ལ་བཙུགས་ཏེ། བཅོམ་ལྡན་\\nའདས་ག་ལ་བ་དེ་ལོགས་སུ་ཐལ་མོ་སྦྱར་བ་བཏུད་ནས་བཅོམ་ལྡན་འདས་ལ་ཚིགས་སུ་བཅད་པ་འདི་དག་གིས་མངོན་པར་བསྟོད་དོ། །\",\"folioNumber\":177,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":512,\"uuid\":\"3abc6575-3839-46cc-840b-af7846d459cd\"},\"content\":[{\"type\":\"text\",\"text\":\"At this vision of the magnificent miracle effected by the supernatural power of the \",\"attrs\":{\"start\":0,\"end\":84}},{\"type\":\"text\",\"text\":\"Lord\",\"attrs\":{\"start\":84,\"end\":88},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41c623b8-3d94-4f8e-b2c5-1d7a5f5af6d3\",\"uuid\":\"c51b7e23-579d-4323-ad27-c17fee32c0b1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":88,\"end\":89}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":89,\"end\":95},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"2f7d465a-eb8b-4f61-9653-487336f9af8c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the entire host was ecstatic, enraptured, astonished, delighted, satisfied, and filled with awe and pleasure. They all bowed down to the \",\"attrs\":{\"start\":95,\"end\":234}},{\"type\":\"text\",\"text\":\"Tathāgata\",\"attrs\":{\"start\":234,\"end\":243},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e708dad0-3dd7-49b0-8de3-b2e34b3f8d08\",\"uuid\":\"5d419fd0-591a-4b54-8f99-7fe3056f11a8\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", withdrew to one side with palms pressed together, and gazed upon him with fixed attention. The young \",\"attrs\":{\"start\":243,\"end\":346}},{\"type\":\"text\",\"text\":\"Licchavi\",\"attrs\":{\"start\":346,\"end\":354},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"33770a73-e8ab-4ffb-9409-eb25bda5915d\",\"uuid\":\"16d441b8-0720-4f31-92ab-d4a4f7a0aa9f\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":354,\"end\":355}},{\"type\":\"text\",\"text\":\"Ratnākara\",\"attrs\":{\"start\":355,\"end\":364},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"2f400df3-fb3c-4bd3-85ce-4b223afd1aad\",\"uuid\":\"54b402d1-c92e-4882-abe5-33e9b3c77b9c\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" knelt with his right knee on the ground, raised his hands, palms pressed together in salute of the \",\"attrs\":{\"start\":364,\"end\":464}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":464,\"end\":470},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"de598571-d4ee-4486-abe6-e920779835fc\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", and praised him with the following hymn:\",\"attrs\":{\"start\":470,\"end\":512}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"feb3cc34-8b3e-4e33-b261-f5a6d59982c3\",\"sort\":1014,\"type\":\"translation\",\"label\":\"1.16\",\"alignments\":{\"toh176\":{\"folioUuid\":\"e36e306d-01a9-49b8-89fc-9eff457bdf7b\",\"toh\":\"toh176\",\"tibetan\":\"གཙང་ཞིང་མཛེས་པ་པད་མའི་འདབ་ལྟར་ཡངས་པའི་སྤྱན། །དགོངས་པ་དག་ཅིང་ཞི་གནས་ཕ་རོལ་ཕྱིན་མཆོག་བརྙེས། །དགེ་བའི་ལས་བསགས་ཡོན་\\nཏན་རྒྱ་མཚོ་དཔག་མི་ལང་། །དགེ་སྦྱོང་ཞི་བའི་ལམ་བརྟེན་ཁྱོད་ལ་ཕྱག་འཚལ་ལོ། །\",\"folioNumber\":177,\"volumeNumber\":60}}},\"content\":[{\"type\":\"lineGroup\",\"attrs\":{\"start\":0,\"end\":301,\"uuid\":\"e008dd2e-2d31-4947-8ff5-6a6454f9fa58\"},\"content\":[{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"“Pure are your eyes, broad and beautiful, like the petals of a blue lotus. \",\"attrs\":{\"start\":0,\"end\":75}}],\"attrs\":{\"start\":0,\"end\":75,\"uuid\":\"ad38e39d-9f06-4d44-b21f-591398b22e99\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"Pure is your thought, having discovered the supreme transcendence of all trances.\",\"attrs\":{\"start\":75,\"end\":156},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"eacae560-a60b-4cc5-a4fb-db45da1c3b73\",\"label\":\"24\",\"uuid\":\"32a98bc8-2da6-4206-94e9-4f796ba49a83\",\"start\":156,\"end\":156,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":156,\"end\":157}}],\"attrs\":{\"start\":75,\"end\":157,\"uuid\":\"d214ad41-845d-4c3a-885a-7d3985414f36\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"Immeasurable is the ocean of your virtues, the accumulation of your good deeds. \",\"attrs\":{\"start\":157,\"end\":237}}],\"attrs\":{\"start\":157,\"end\":237,\"uuid\":\"cf2a9726-9063-4ae8-8dc0-6e98ddfc55e2\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"You affirm the path of peace. O Great Ascetic, obeisance to you!\",\"attrs\":{\"start\":237,\"end\":301}}],\"attrs\":{\"start\":237,\"end\":301,\"uuid\":\"e3ff045c-fbee-4a81-939c-128d8077a406\"}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"4886cae5-ff59-491b-9f9a-92c369997e94\",\"sort\":1023,\"type\":\"translation\",\"label\":\"1.17\",\"alignments\":{\"toh176\":{\"folioUuid\":\"e36e306d-01a9-49b8-89fc-9eff457bdf7b\",\"toh\":\"toh176\",\"tibetan\":\"སྐྱེས་བུ་ཁྱུ་མཆོག་འདྲེན་པའི་རྫུ་འཕྲུལ་ཁྱོད་གཟིགས་ཤིག །བདེ་བར་གཤེགས་པའི་ཞིང་མཆོག་རབ་གསལ་ཀུན་ཀྱང་གདའ། །ཁྱོད་ཀྱི་ཆོས་ཀྱི་བཀའ་མཆིད་རྒྱ་ཆེ་འཆི་མེད་འགྲོ། །དེ་དག་ཐམས་ཅད་ནམ་མཁའ་\\nའདི་ཡི་དཀྱིལ་ན་གདའ། །\",\"folioNumber\":177,\"volumeNumber\":60}}},\"content\":[{\"type\":\"lineGroup\",\"attrs\":{\"start\":0,\"end\":249,\"uuid\":\"c912e8cb-c065-4f01-9332-91374ac44d4c\"},\"content\":[{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"text\":\"“Leader, bull of men,\",\"attrs\":{\"start\":0,\"end\":21},\"marks\":[{\"type\":\"endNoteLink\",\"attrs\":{\"notes\":[{\"endNote\":\"c5a85dc7-e629-473b-9696-529e0c80500e\",\"label\":\"25\",\"uuid\":\"b9e0163e-bcae-4122-91ff-89e45c3daea6\",\"start\":21,\"end\":21,\"location\":\"end\",\"toh\":null}]}}]},{\"type\":\"text\",\"text\":\" we behold the revelation of your miracle. \",\"attrs\":{\"start\":21,\"end\":64}}],\"attrs\":{\"start\":0,\"end\":64,\"uuid\":\"7535f2ef-1413-43c3-a9bc-d134fdce9a76\"}},{\"type\":\"line\",\"content\":[{\"type\":\"text\",\"t