"attrs\":{\"start\":387,\"end\":406}},{\"type\":\"text\",\"text\":\"buddhafield\",\"attrs\":{\"start\":406,\"end\":417},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1e5e85e8-4767-46b1-874e-5f1396a67ee6\",\"uuid\":\"d397f761-34b3-479a-aa4e-293d6886277e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" as perfectly pure.”\",\"attrs\":{\"start\":417,\"end\":437}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"1f9a21c0-ad2b-422b-a9e9-746cee5d07bb\",\"sort\":1685,\"type\":\"translation\",\"label\":\"1.51\",\"alignments\":{\"toh176\":{\"folioUuid\":\"b702af0c-5582-48c9-aee8-3ecf5cdab5eb\",\"toh\":\"toh176\",\"tibetan\":\"དེ་ནས་བཅོམ་ལྡན་འདས་ཀྱིས་སྟོང་གསུམ་གྱི་སྟོང་ཆེན་པོའི་འཇིག་རྟེན་གྱི་ཁམས་འདི་ལ་ཞབས་ཀྱི་མཐེ་བོས་བསྣུན་པ་དང་། བསྣུན་མ་ཐག་ཏུ་འཇིག་རྟེན་གྱི་ཁམས་འདི་རིན་པོ་ཆེ་དུ་མ་བརྩེགས་པ་དང་། རིན་པོ་ཆེ་བརྒྱ་སྟོང་དུ་མའི་ཚོགས་དག་རིན་པོ་ཆེ་བརྒྱ་སྟོང་དུ་\\nམ་སོ་སོར་བཀོད་པར་གྱུར་པ་འདི་ལྟ་སྟེ་དཔེར་ན་དེ་བཞིན་གཤེགས་པ་རིན་པོ་ཆེ་བཀོད་པའི་འཇིག་རྟེན་གྱི་ཁམས་ཡོན་ཏན་རིན་ཆེན་མཐའ་ཡས་བཀོད་པ་བཞིན་དུ་འཇིག་རྟེན་གྱི་ཁམས་འདིའང་དེ་འདྲའོ། །དེ་ནས་ཐམས་ཅད་དང་ལྡན་པའི་འཁོར་དེའང་ངོ་མཚར་དུ་གྱུར་ཅིང་བདག་ཉིད་ཀྱང་རིན་པོ་ཆེའི་པད་\\nམ་བཀོད་པའི་སྟན་ལ་འདུག་པ་སྙམ་བྱེད་དོ། །\",\"folioNumber\":181,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":456,\"uuid\":\"1f9a21c0-ad2b-422b-a9e9-746cee5d07bb\"},\"content\":[{\"type\":\"text\",\"text\":\"Thereupon the \",\"attrs\":{\"start\":0,\"end\":14}},{\"type\":\"text\",\"text\":\"Lord\",\"attrs\":{\"start\":14,\"end\":18},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41c623b8-3d94-4f8e-b2c5-1d7a5f5af6d3\",\"uuid\":\"757d297a-2909-49f3-9c41-95fe7ab8eeaa\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" touched the ground of this billion-world galactic universe with his big toe, and suddenly it was transformed into a huge mass of precious jewels, a magnificent array of many hundreds of thousands of clusters of precious gems, until it resembled the universe of the \",\"attrs\":{\"start\":18,\"end\":284}},{\"type\":\"text\",\"text\":\"Tathāgata\",\"attrs\":{\"start\":284,\"end\":293},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e708dad0-3dd7-49b0-8de3-b2e34b3f8d08\",\"uuid\":\"50cfd6a5-5324-42fc-a906-bc55390c8b57\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" \",\"attrs\":{\"start\":293,\"end\":294}},{\"type\":\"text\",\"text\":\"Ratnavyūha\",\"attrs\":{\"start\":294,\"end\":304},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"fccb3001-894d-4827-ad90-67e7ff6eabce\",\"uuid\":\"11cac14b-e2fa-45d5-b739-2431175dd170\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", called \",\"attrs\":{\"start\":304,\"end\":313}},{\"type\":\"text\",\"text\":\"Ananta­guṇa­ratna­vyūha\",\"attrs\":{\"start\":313,\"end\":336},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"0aca3d2b-9f37-4ab1-aec7-084006cafb82\",\"uuid\":\"8fcf3a8e-3b9a-4be9-80da-d57b398bfc3b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\". Everyone in the entire assembly was filled with wonder, each perceiving himself seated on a throne of jeweled lotuses.\",\"attrs\":{\"start\":336,\"end\":456}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"458241f4-6723-4694-9828-9a5edd186ac7\",\"sort\":1695,\"type\":\"translation\",\"label\":\"1.52\",\"alignments\":{\"toh176\":{\"folioUuid\":\"b702af0c-5582-48c9-aee8-3ecf5cdab5eb\",\"toh\":\"toh176\",\"tibetan\":\"དེ་ནས་བཅོམ་ལྡན་འདས་ཀྱིས་ཚེ་དང་ལྡན་པ་ཤཱ་རིའི་བུ་ལ་བཀའ་སྩལ་པ། ཤཱ་རིའི་བུ་ཁྱོད་ཀྱིས་སངས་རྒྱས་ཀྱི་ཞིང་གི་ཡོན་ཏན་བཀོད་པ་འདི་མཐོང་ངམ་གསོལ་པ། བཅོམ་ལྡན་འདས་མཐོང་ལགས་སོ། །སྔོན་མ་མཐོང་མ་ཐོས་པའི་བཀོད་པ་\\nའདི་དག་གདའོ། །\",\"folioNumber\":181,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":123,\"uuid\":\"cd8da083-9577-44b3-afc8-897a6f510483\"},\"content\":[{\"type\":\"text\",\"text\":\"Then, the \",\"attrs\":{\"start\":0,\"end\":10}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":10,\"end\":16},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"5031031e-6b92-4ab1-be7b-1111831f222e\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" said to the venerable \",\"attrs\":{\"start\":16,\"end\":39}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":39,\"end\":48},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4da7d125-a1b8-4820-b50f-9de69a2ab346\",\"uuid\":\"cea02255-1d07-482e-ba88-5925db1a7a87\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", “\",\"attrs\":{\"start\":48,\"end\":51}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":51,\"end\":60},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4da7d125-a1b8-4820-b50f-9de69a2ab346\",\"uuid\":\"176bcf02-2452-47c2-9099-0000671a34d9\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", do you see this splendor of the virtues of the \",\"attrs\":{\"start\":60,\"end\":109}},{\"type\":\"text\",\"text\":\"buddhafield\",\"attrs\":{\"start\":109,\"end\":120},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1e5e85e8-4767-46b1-874e-5f1396a67ee6\",\"uuid\":\"306e0c5f-fdff-46a3-ab55-f095495fd911\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"?” \",\"attrs\":{\"start\":120,\"end\":123}}]},{\"type\":\"paragraph\",\"attrs\":{\"start\":123,\"end\":242,\"uuid\":\"5010654c-913b-4846-b82a-3868fd289b0d\"},\"content\":[{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":123,\"end\":132},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4da7d125-a1b8-4820-b50f-9de69a2ab346\",\"uuid\":\"c07afc31-1af7-430a-bf59-6cff3dbbe08b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" replied, “I see it, \",\"attrs\":{\"start\":132,\"end\":153}},{\"type\":\"text\",\"text\":\"Lord\",\"attrs\":{\"start\":153,\"end\":157},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"41c623b8-3d94-4f8e-b2c5-1d7a5f5af6d3\",\"uuid\":\"982bca67-0c40-4609-85fe-543378c627d6\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\"! Here before me is a display of splendor such as I never before heard of or beheld!”\",\"attrs\":{\"start\":157,\"end\":242}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"e13be840-0bd8-4728-b9f8-20d3adae0fea\",\"sort\":1709,\"type\":\"translation\",\"label\":\"1.53\",\"alignments\":{\"toh176\":{\"folioUuid\":\"b702af0c-5582-48c9-aee8-3ecf5cdab5eb\",\"toh\":\"toh176\",\"tibetan\":\"བཀའ་སྩལ་པ། ཤཱ་རིའི་བུ་སངས་རྒྱས་ཀྱི་ཞིང་འདི་ནི་རྟག་ཏུ་འདི་འདྲ་མོད་ཀྱི་སེམས་ཅན་དམན་པ་རྣམས་ཡོངས་སུ་སྨིན་པར་བྱས་པའི་ཕྱིར་དེ་བཞིན་གཤེགས་པས་སངས་རྒྱས་ཀྱི་ཞིང་དེ་ལྟ་བུར་ཉེས་པ་མང་པོའི་སྐྱོན་ཆགས་པར་སྟོན་ཏེ། ཤཱ་རིའི་བུ་འདི་ལྟ་སྟེ་དཔེར་ན་ལྷའི་བུ་རྣམས་\\nརིན་པོ་ཆེའི་སྣོད་གཅིག་ཏུ་ཟས་ཟ་ཡང་བསོད་ནམས་ཇི་ལྟ་བུ་བསགས་པའི་བྱེ་བྲག་གིས་ལྷའི་ཟས་བདུད་རྩི་ཉེ་བར་གནས་པ་དེ་བཞིན་དུ་ཤཱ་རིའི་བུ་སེམས་ཅན་སངས་རྒྱས་ཀྱི་ཞིང་གཅིག་ཏུ་སྐྱེས་པ་དག་ཀྱང་སེམས་ཅན་ཇི་ལྟར་ཡོངས་སུ་དག་པ་བཞིན་དུ་སངས་རྒྱས་རྣམས་ཀྱི་སངས་རྒྱས་ཀྱི་ཞིང་གི་ཡོན་\\nཏན་བཀོད་པ་མཐོང་ངོ་། །\",\"folioNumber\":181,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":590,\"uuid\":\"e13be840-0bd8-4728-b9f8-20d3adae0fea\"},\"content\":[{\"type\":\"text\",\"text\":\"The \",\"attrs\":{\"start\":0,\"end\":4}},{\"type\":\"text\",\"text\":\"Buddha\",\"attrs\":{\"start\":4,\"end\":10},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"d578060c-ae6d-410c-8d0f-741de42062e1\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" said, “\",\"attrs\":{\"start\":10,\"end\":18}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":18,\"end\":27},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4da7d125-a1b8-4820-b50f-9de69a2ab346\",\"uuid\":\"8b01be59-0b7d-4e16-b6cd-dfb19176b283\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", this \",\"attrs\":{\"start\":27,\"end\":34}},{\"type\":\"text\",\"text\":\"buddhafield\",\"attrs\":{\"start\":34,\"end\":45},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1e5e85e8-4767-46b1-874e-5f1396a67ee6\",\"uuid\":\"07f1025f-5a7a-4704-8ffc-8ea259164ab5\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" is always thus pure, but the \",\"attrs\":{\"start\":45,\"end\":75}},{\"type\":\"text\",\"text\":\"Tathāgata\",\"attrs\":{\"start\":75,\"end\":84},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"e708dad0-3dd7-49b0-8de3-b2e34b3f8d08\",\"uuid\":\"2b0b00a6-f610-4f67-8b98-ce37ec72c069\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" makes it appear to be spoiled by many faults, in order to bring about the maturity of inferior living beings. For example, \",\"attrs\":{\"start\":84,\"end\":208}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":208,\"end\":217},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4da7d125-a1b8-4820-b50f-9de69a2ab346\",\"uuid\":\"22b2e81c-16cb-40b8-8492-05ff6c051263\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", the gods of the Trayastriṃśa heaven all take their food from a single precious vessel, yet the nectar that nourishes each one differs according to the differences of the merits each has accumulated. Just so, \",\"attrs\":{\"start\":217,\"end\":427}},{\"type\":\"text\",\"text\":\"Śāriputra\",\"attrs\":{\"start\":427,\"end\":436},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"4da7d125-a1b8-4820-b50f-9de69a2ab346\",\"uuid\":\"d5a2ca6c-4529-42cf-ae47-ca06ff10b41b\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\", living beings born in the same \",\"attrs\":{\"start\":436,\"end\":469}},{\"type\":\"text\",\"text\":\"buddhafield\",\"attrs\":{\"start\":469,\"end\":480},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1e5e85e8-4767-46b1-874e-5f1396a67ee6\",\"uuid\":\"14ed81e7-9b0d-409e-9bb7-37cfe4932410\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" see the splendor of the virtues of the \",\"attrs\":{\"start\":480,\"end\":520}},{\"type\":\"text\",\"text\":\"buddhafields\",\"attrs\":{\"start\":520,\"end\":532},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1e5e85e8-4767-46b1-874e-5f1396a67ee6\",\"uuid\":\"92128c4a-457a-4500-88b8-3e5cded2df8a\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" of the \",\"attrs\":{\"start\":532,\"end\":540}},{\"type\":\"text\",\"text\":\"buddhas\",\"attrs\":{\"start\":540,\"end\":547},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"9b76e3ce-41f6-4da3-89a2-722141c90c1e\",\"uuid\":\"4ec37c9f-7e53-4ab7-b760-2b465b4ced03\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" according to their own degrees of purity.”\",\"attrs\":{\"start\":547,\"end\":590}}]}]},{\"type\":\"passage\",\"attrs\":{\"uuid\":\"8099f34e-51da-472f-a43e-c863a39b4f66\",\"sort\":1729,\"type\":\"translation\",\"label\":\"1.54\",\"alignments\":{\"toh176\":{\"folioUuid\":\"b702af0c-5582-48c9-aee8-3ecf5cdab5eb\",\"toh\":\"toh176\",\"tibetan\":\"སངས་རྒྱས་ཀྱི་ཞིང་གི་ཡོན་ཏན་གྱི་རྒྱན་བཀོད་པ་འདི་སྣང་བ་ན་སྲོག་ཆགས་བརྒྱད་ཁྲི་བཞི་སྟོང་བླ་ན་མེད་པ་ཡང་དག་པར་རྫོགས་པའི་བྱང་ཆུབ་ཏུ་སེམས་སྐྱེས་སོ། །ལིད་ཙ་བཱི་གཞོན་ནུ་གང་དག་ལིད་ཙ་བཱི་གཞོན་ནུ་དཀོན་མཆོག་འབྱུང་གནས་དང་ལྷན་ཅིག་ཏུ་ལྷགས་པ་ལྔ་བརྒྱ་\\nཔོ་དེ་དག་ཀྱང་རྗེས་སུ་འཐུན་པའི་བཟོད་པ་ཐོབ་པར་གྱུར་ཏོ། །\",\"folioNumber\":181,\"volumeNumber\":60}}},\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"start\":0,\"end\":318,\"uuid\":\"8099f34e-51da-472f-a43e-c863a39b4f66\"},\"content\":[{\"type\":\"text\",\"text\":\"When this splendor of the beauty of the virtues of the \",\"attrs\":{\"start\":0,\"end\":55}},{\"type\":\"text\",\"text\":\"buddhafield\",\"attrs\":{\"start\":55,\"end\":66},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"1e5e85e8-4767-46b1-874e-5f1396a67ee6\",\"uuid\":\"eb0310d4-aead-4b8f-91d3-08f407944c0d\",\"toh\":null}}]},{\"type\":\"text\",\"text\":\" shone forth, eighty-four thousand beings conceived the spirit of unexcelled perfect \",\"attrs\":{\"start\":66,\"end\":151}},{\"type\":\"text\",\"text\":\"enlightenment\",\"attrs\":{\"start\":151,\"end\":164},\"marks\":[{\"type\":\"glossaryInstance\",\"attrs\":{\"glossary\":\"62f923c5-8df